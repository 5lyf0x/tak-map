    team_name=_tak_team_name(sender_team_raw)
    event=ET.Element('event', {
        'version':'2.0',
        'uid':event_uid,
        'type':'a-f-G-U-C',
        'time':_cot_time(now),
        'start':_cot_time(now),
        'stale':_cot_time(stale),
        'how':'h-g-i-g-o',
    })
    ET.SubElement(event, 'point', {'lat':f'{float(lat or 0.0):.8f}','lon':f'{float(lon or 0.0):.8f}','hae':'0.0','ce':'9999999.0','le':'9999999.0'})
    detail=ET.SubElement(event, 'detail')
    ET.SubElement(detail, 'contact', {'callsign':sender_callsign or 'takdash'})
    ET.SubElement(detail, '__group', {'name':team_name, 'role':'Team Member'})
    ET.SubElement(detail, 'remarks').text='TAK Dashboard basemap fileshare marker-route test'
    ET.SubElement(detail, 'fileshare', {
        'filename':filename,
        'name':content_display_name,
        'sender':sender_callsign,
        'senderCallsign':sender_callsign,
        'senderUid':sender_uid,
        'senderUrl':sender_url,
        'url':sender_url,
        'sha256':package['sha256'],
        'sizeInBytes':str(int(package.get('size_bytes') or 0)),
    })
    ET.SubElement(detail, 'ackrequest', {'uid':ack_uid,'tag':'transfer','ackrequested':'true'})
    if not broadcast:
        marti=ET.SubElement(detail, 'marti')
        dest={'callsign':str(target_callsign or '')}
        if str(target_uid or '').strip():
            dest['uid']=str(target_uid).strip()
        ET.SubElement(marti, 'dest', dest)
    xml='<?xml version="1.0" encoding="utf-8"?>' + ET.tostring(event, encoding='unicode', short_empty_elements=True)
    return xml, {'event_uid':event_uid,'ack_uid':ack_uid,'sender_url':sender_url,'sender_url_receiver_query_added':('/Marti/api/sync/metadata/' in str(sender_url) and 'receiver=' in str(sender_url)),'stale_seconds':stale_seconds,'target_uid':str(target_uid or ''),'target_team':_tak_team_name(target_team) if str(target_team or '').strip() else '','fileshare_sender_team':team_name,'fileshare_cot_name':content_display_name,'fileshare_variant':str(variant or ''),'broadcast':bool(broadcast),'marker_fileshare_route_test':True,'cot_type':'a-f-G-U-C','ack_tag':'transfer'}

def _build_basemap_datapackage_cot(target_callsign, package, sender_callsign, sender_uid, server_host, lat=0.0, lon=0.0, target_uid='', target_team='', sender_url_override='', broadcast=False, variant='datapackage-basemap-targeted'):
    """Build an experimental basemap DataPackage CoT notification.

    This intentionally tests the community-suggested ATAK import trigger shape:
    a CoT event with detail/fileshare plus detail/dataPackage type="basemap".
    It does not replace the native OTS DP upload path; it only changes the
    notification XML sent to the EUD.
    """
    now=datetime.now(timezone.utc)
    try:
        stale_seconds=max(300, int(os.environ.get('TAK_DASH_FILESHARE_STALE_SECONDS','3600') or '3600'))
    except Exception:
        stale_seconds=3600
    stale=now + timedelta(seconds=stale_seconds)
    sha=str(package.get('sha256') or '').strip()
    dp_uid=str(package.get('data_package_uid') or package.get('native_cleanup_hash') or sha or uuid.uuid4()).strip()
    event_uid=str(package.get('event_uid') or dp_uid or str(uuid.uuid4()))
    ack_uid=str(uuid.uuid4())
    port=_ots_marti_https_port()
    host=_url_host(server_host or _default_server_host())
    sender_url=str(sender_url_override or '').strip() or f"https://{host}:{port}/Marti/api/sync/metadata/{sha}/tool"
    if not broadcast:
        sender_url=_fileshare_url_with_receiver(sender_url, target_callsign, target_uid)
    content_display_name=_fileshare_cot_display_name(package)
    filename=_fileshare_cot_filename_for_url(package, sender_url)
    event_type=os.environ.get('TAK_DASH_BASEMAP_DATAPACKAGE_COT_TYPE','b-m-r').strip() or 'b-m-r'
    how=os.environ.get('TAK_DASH_BASEMAP_DATAPACKAGE_COT_HOW','h-g-i').strip() or 'h-g-i'
    event=ET.Element('event', {
        'version':'2.0',
        'uid':event_uid,
        'type':event_type,
        'time':_cot_time(now),
        'start':_cot_time(now),
        'stale':_cot_time(stale),
        'how':how,
    })
    ET.SubElement(event, 'point', {'lat':f'{float(lat or 0.0):.8f}','lon':f'{float(lon or 0.0):.8f}','hae':'0.0','ce':'9999999.0','le':'9999999.0'})
    detail=ET.SubElement(event, 'detail')
    # Include both common FileShare attribute spellings so ATAK can key off the
    # one it expects. senderUrl is used by native ATAK FileShare notices; url is
    # included for DataPackage-style basemap import triggers.
    ET.SubElement(detail, 'fileshare', {
        'filename':filename,
        'name':content_display_name,
        'sender':sender_callsign,
        'senderCallsign':sender_callsign,
        'senderUid':sender_uid,
        'senderUrl':sender_url,
        'url':sender_url,
        'sha256':sha,
        'sizeInBytes':str(int(package.get('size_bytes') or 0)),
    })
    dp=ET.SubElement(detail, 'dataPackage', {
        'name':content_display_name,
        'type':os.environ.get('TAK_DASH_BASEMAP_DATAPACKAGE_TYPE','basemap').strip() or 'basemap',
        'uid':dp_uid,
    })
    ET.SubElement(dp, 'concept', {'uid':dp_uid})
    # Keep a TAK FileShare ack request so receiver/plugin code has the same
    # transfer acknowledgement cue as the earlier b-f-t-r attempts.
    ack_tag=os.environ.get('TAK_DASH_FILESHARE_ACK_TAG','transfer').strip() or 'transfer'
    ET.SubElement(detail, 'ackrequest', {'uid':ack_uid,'tag':ack_tag,'ackrequested':'true'})
    if not broadcast:
        marti=ET.SubElement(detail, 'marti')
        dest={'callsign':str(target_callsign or '')}
        if str(target_uid or '').strip():
            dest['uid']=str(target_uid).strip()
        ET.SubElement(marti, 'dest', dest)
    xml='<?xml version="1.0" encoding="utf-8"?>' + ET.tostring(event, encoding='unicode', short_empty_elements=True)
    return xml, {'event_uid':event_uid,'ack_uid':ack_uid,'sender_url':sender_url,'sender_url_receiver_query_added':('/Marti/api/sync/metadata/' in str(sender_url) and 'receiver=' in str(sender_url)),'stale_seconds':stale_seconds,'target_uid':str(target_uid or ''),'target_team':_tak_team_name(target_team) if str(target_team or '').strip() else '','fileshare_cot_name':content_display_name,'fileshare_variant':str(variant or ''),'broadcast':bool(broadcast),'dataPackage_uid':dp_uid,'dataPackage_type':os.environ.get('TAK_DASH_BASEMAP_DATAPACKAGE_TYPE','basemap').strip() or 'basemap','cot_type':event_type,'ack_tag':ack_tag}

def _fileshare_sender_url_variants(package, server_host):
    """Return senderUrl candidates for ATAK fileshare CoT.

    v205 prefers the native ATAK/OTS metadata-tool URL when the dashboard has
    already completed the successful missionupload + PUT /metadata/<hash>/tool
    registration sequence. Dashboard-hosted package URLs remain as fallback.
    """
    host=_url_host(server_host or _default_server_host())
    port=_ots_marti_https_port()
    sha=str(package.get('sha256') or '').strip()
    fn=quote(str(package.get('package_name') or 'TAK Map Source.zip'), safe='')
    urls=[]
    def add(label, url):
        if sha and url and all(u.get('url') != url for u in urls):
            urls.append({'label':label,'url':url})

    raw_tmpl=os.environ.get('TAK_DASH_FILESHARE_SENDER_URL_TEMPLATE','').strip()
    if raw_tmpl:
        try:
            add('custom', raw_tmpl.format(host=host, port=port, sha256=sha, hash=sha, filename=fn, package_name=fn))
        except Exception:
            pass

    preferred=str(package.get('preferred_sender_url') or '').strip()
    if preferred:
        add('preferred-native-metadata-tool', preferred)

    dash_origin=_dashboard_https_origin('', host)
    if str(package.get('delivery_kind') or '').strip().lower() == 'mapsource-xml':
        add('dashboard-mapsource-xml', f"{dash_origin}/api/tak-map/fileshare-mapsource/{sha}/{fn}")
    else:
        add('dashboard-package', f"{dash_origin}/api/tak-map/fileshare-package/{sha}/{fn}")

    if os.environ.get('TAK_DASH_ENABLE_OTS_FILESHARE_URL_VARIANTS','').strip().lower() in ('1','true','yes','on'):
        if package.get('registered_ots_data_package'):
            add('ots-api-data-package-download', f"https://{host}:{port}/api/data_packages/download?hash={sha}")
        add('metadata-tool', f"https://{host}:{port}/Marti/api/sync/metadata/{sha}/tool")
        add('sync-content-hash', f"https://{host}:{port}/Marti/sync/content?hash={sha}")
        add('sync-content-hash-filename', f"https://{host}:{port}/Marti/sync/content?hash={sha}&filename={fn}")

    mode=os.environ.get('TAK_DASH_FILESHARE_URL_MODE','').strip().lower()
    if mode:
        filtered=[u for u in urls if mode in u.get('label','').lower()]
        if filtered:
            urls=filtered
    try:
        max_urls=int(os.environ.get('TAK_DASH_FILESHARE_URL_VARIANTS','1') or '1')
    except Exception:
        max_urls=1
    max_urls=max(1,min(max_urls,5))
    return urls[:max_urls]


def _fileshare_broadcast_enabled():
    return os.environ.get('TAK_DASH_DISABLE_FILESHARE_BROADCAST_FALLBACK','').strip().lower() not in ('1','true','yes','on')

def _ots_cert_candidates():
    """Return TLS client cert/key pairs that the dashboard process can actually read.

    v154 could discover an existing /root/ots administrator cert and then crash when
    the locked-down dashboard process tried to stat or load it. Discovery is now
    defensive: prefer explicit env paths only when readable, prefer non-root user
    OTS homes, and ignore any candidate that raises PermissionError/OSError.
    """
    pairs=[]
    env_cert=os.environ.get('TAK_DASH_OTS_CLIENT_CERT','').strip()
    env_key=os.environ.get('TAK_DASH_OTS_CLIENT_KEY','').strip()

    def add_pair(cert, key):
        try:
            cert=Path(str(cert)).expanduser()
            key=Path(str(key)).expanduser()
        except Exception:
            return
        pairs.append((cert,key))

    def add_base(base):
        try:
            base=Path(str(base)).expanduser()
        except Exception:
            return
        for rel, cert_name, key_name in (
            ('ca/certs/takdash', 'takdash.pem', 'takdash.nopass.key'),
            ('ca/certs/takdash', 'takdash.pem', 'takdash.key'),
            ('ca/certs/takdash', 'takdash.pem', '../keys/takdash.nopass.key'),
            ('ca/certs/takdash', 'takdash.pem', '../keys/takdash.key'),
            ('ca/certs/tak-dashboard', 'tak-dashboard.pem', 'tak-dashboard.nopass.key'),
            ('ca/certs/administrator', 'administrator.pem', 'administrator.nopass.key'),
            ('ca/certs/admin', 'admin.pem', 'admin.nopass.key'),
        ):
            add_pair(base/rel/cert_name, base/rel/key_name)

    if env_cert and env_key:
        add_pair(env_cert, env_key)

    for raw in (os.environ.get('OTS_DATA_FOLDER',''), os.environ.get('TAK_DASH_OTS_WORKDIR','')):
        if str(raw or '').strip():
            add_base(str(raw).strip())
    for cfg in re.split(r'[,;]+', os.environ.get('TAK_DASH_OTS_CONFIG_PATHS','')):
        cfg=str(cfg or '').strip()
        if cfg:
            try: add_base(Path(cfg).expanduser().parent)
            except Exception: pass
    try:
        for home in Path('/home').glob('*'):
            try:
                if home.is_dir():
                    add_base(home/'ots')
            except OSError:
                continue
    except Exception:
        pass
    # /root is deliberately late and is accepted only if readable by this process.
    for base in (Path('/var/lib/opentakserver'), Path('/opt/opentakserver'), Path('/opt/OpenTAKServer'), Path('/srv/opentakserver'), Path('/root/ots')):
        add_base(base)

    out=[]; seen=set()
    for cert,key in pairs:
        k=(str(cert),str(key))
        if k in seen:
            continue
        seen.add(k)
        try:
            if not (cert.exists() and key.exists()):
                continue
            if not (os.access(str(cert), os.R_OK) and os.access(str(key), os.R_OK)):
                continue
        except (PermissionError, OSError):
            continue
        except Exception:
            continue
        out.append((cert,key))
    return out




def _selected_ots_cert_identity():
    """Return the preferred TLS client cert identity currently available.

    v205 prefers the explicit env-configured client name when present, then the
    readable cert/key pair selected by _ots_cert_candidates(). CN parsing from
    PEM body text is unreliable, so fall back to the configured client name or
    the cert parent/stem.
    """
    pairs=_ots_cert_candidates()
    if not pairs:
        return {}
    cert,key=pairs[0]
    env_name=str(os.environ.get('TAK_DASH_OTS_CLIENT_NAME','') or '').strip()
    cn=env_name
    if not cn:
        try:
            parent=Path(cert).parent.name.strip()
            stem=Path(cert).stem.strip()
            cn=parent or stem
        except Exception:
            cn=''
    return {'cert':str(cert), 'key':str(key), 'cn':cn}


def _preferred_fileshare_sender_identity(default_callsign='tak-dashboard', default_uid='TAK-DASHBOARD'):
    sid=_selected_ots_cert_identity()
    client_name=str(os.environ.get('TAK_DASH_OTS_CLIENT_NAME','') or sid.get('cn') or '').strip()
    callsign=(
        str(os.environ.get('TAK_DASH_FILESHARE_SENDER_CALLSIGN','') or '').strip()
        or str(os.environ.get('TAK_DASH_OFFLINE_SENDER_CALLSIGN','') or '').strip()
        or client_name
        or str(default_callsign or 'tak-dashboard').strip()
        or 'tak-dashboard'
    )
    uid=(
        str(os.environ.get('TAK_DASH_FILESHARE_SENDER_UID','') or '').strip()
        or str(os.environ.get('TAK_DASH_OFFLINE_SENDER_UID','') or '').strip()
        or client_name
        or str(default_uid or 'TAK-DASHBOARD').strip()
        or 'TAK-DASHBOARD'
    )
    return {'callsign':callsign,'uid':uid,'client_name':client_name,'cert':sid.get('cert',''),'key':sid.get('key','')}


def _cot_port_candidates():
    vals=[]
    for name in ('TAK_DASH_OTS_COT_PORT','TAK_DASH_OTS_TLS_COT_PORT','TAK_DASH_OTS_TCP_COT_PORT'):
        raw=os.environ.get(name,'').strip()
        if raw:
            for part in re.split(r'[, ]+', raw):
                try: vals.append(int(part))
                except Exception: pass
    # OpenTAKServer defaults commonly expose TLS client streaming on 8089 and
    # plaintext local/client streaming on 8088. Keep 8087 last because it has
    # repeatedly been refused in field diagnostics.
    vals.extend([8089, 8088, 8087])
    out=[]
    for v in vals:
        try:
            iv=int(v)
        except Exception:
            continue
        if iv not in out and 1 <= iv <= 65535: out.append(iv)
    return out

def _cot_tls_ports():
    raw=os.environ.get('TAK_DASH_OTS_TLS_COT_PORT','').strip()
    vals=[]
    if raw:
        for part in re.split(r'[, ]+', raw):
            try: vals.append(int(part))
            except Exception: pass
    vals.append(8089)
    out=[]
    for v in vals:
        if v not in out: out.append(v)
    return out

def _cot_tcp_ports():
    raw=os.environ.get('TAK_DASH_OTS_TCP_COT_PORT','').strip()
    vals=[]
    if raw:
        for part in re.split(r'[, ]+', raw):
            try: vals.append(int(part))
            except Exception: pass
    # Do not include 8089 in plaintext TCP candidates. 8089 is the
    # OpenTAKServer eud_handler_ssl listener and must receive TLS only.
    vals.append(8088)
    out=[]
    for v in vals:
        try:
            iv=int(v)
        except Exception:
            continue
        if iv == 8089:
            continue
        if iv not in out: out.append(iv)
    return out


def _cot_socket_auth_xml(xml):
    """Optional OTS SSL socket auth preamble for short-lived dashboard CoT sends.

    OpenTAKServer's SSL socket expects ATAK-style <auth><cot .../></auth>
    credentials before it accepts client CoT.  Certificate CN auth may work on
    some installs, but for short-lived dashboard connections explicit auth plus
    a brief post-send hold gives eud_handler enough time to authenticate, open
    RabbitMQ, and route the following b-f-t-r message before we close.
    """
    if os.environ.get('TAK_DASH_DISABLE_OTS_SOCKET_AUTH','').strip().lower() in ('1','true','yes','on'):
        return '', {'auth_enabled': False, 'auth_sent': False, 'auth_reason': 'disabled by TAK_DASH_DISABLE_OTS_SOCKET_AUTH'}
    username=(
        os.environ.get('TAK_DASH_OTS_SOCKET_AUTH_USER','').strip()
        or os.environ.get('TAK_DASH_OTS_CLIENT_NAME','').strip()
        or os.environ.get('TAK_DASH_FILESHARE_SENDER_CALLSIGN','').strip()
    )
    password=(
        os.environ.get('TAK_DASH_OTS_SOCKET_AUTH_PASSWORD','').strip()
        or os.environ.get('TAK_DASH_OTS_CLIENT_PASSWORD','').strip()
        or os.environ.get('TAK_DASH_OTS_PASSWORD','').strip()
    )
    uid=''
    try:
        m=re.search(r'\bsenderUid=["\']([^"\']+)["\']', str(xml or ''), re.I)
        if m: uid=m.group(1).strip()
    except Exception:
        pass
    uid=uid or os.environ.get('TAK_DASH_OTS_SOCKET_AUTH_UID','').strip() or os.environ.get('TAK_DASH_FILESHARE_SENDER_UID','').strip() or username
    if not username:
        return '', {'auth_enabled': False, 'auth_sent': False, 'auth_reason': 'no socket auth username configured'}
    if not password:
        return '', {'auth_enabled': False, 'auth_sent': False, 'auth_username': username, 'auth_uid': uid, 'auth_reason': 'no socket auth password configured'}
    try:
        root=ET.Element('auth')
        ET.SubElement(root, 'cot', {'username': username, 'password': password, 'uid': uid or username})
        auth_xml=ET.tostring(root, encoding='unicode', short_empty_elements=True)
        return auth_xml, {'auth_enabled': True, 'auth_sent': True, 'auth_username': username, 'auth_uid': uid or username}
    except Exception as e:
        return '', {'auth_enabled': False, 'auth_sent': False, 'auth_username': username, 'auth_uid': uid, 'auth_reason': 'auth xml build failed: '+str(e)}

def _cot_socket_message_suffix(is_fileshare_req=False, use_tls=False):
    """Return socket message terminator bytes plus a diagnostic label.

    v202: default FileShare/TLS sends use traditional TAK XML stream framing:
    auth XML followed immediately by the next XML document, with no NUL/newline
    delimiter between documents and no extra bytes after </event>.  The TAK
    protocol notes describe traditional streaming connections as one XML CoT
    <event> after another, split by the </event> token; NUL framing did not
    reach public.cot on this OTS instance.  Env override remains for compare
    tests.
    """
    raw=(os.environ.get('TAK_DASH_COT_SOCKET_TERMINATOR','') or '').strip().lower()
    if not raw:
        # v216: use traditional TAK XML stream framing for all TLS CoT sends.
        # The manual takdash marker test that reached public.cot used TLS auth
        # followed by a normal XML event with no NUL delimiter.
        raw='traditional' if use_tls else 'newline'
    if raw in ('traditional','xml','tak-xml','concat','adjacent'):
        return b'', 'traditional-xml'
    if raw in ('nul','null','zero','0','\0','atak'):
        return b'\x00', 'nul'
    if raw in ('crlf','\r\n'):
        return b'\r\n', 'crlf'
    if raw in ('none','raw',''):
        return b'', 'none'
    return b'\n', 'newline'

def _normalize_traditional_xml_stream_doc(text):
    """Return an XML document suitable for traditional TAK TCP stream mode.

    TAK's traditional stream mode expects an XML declaration, a newline, then
    the XML document; messages are split by XML document boundaries rather than
    NUL bytes.  Normalizing the dashboard-generated one-line XML removes one
    more framing variable from Send Basemap diagnostics.
    """
    t=str(text or '').strip()
    if not t:
        return t
    m=re.match(r'^(<\?xml[^>]*\?>)(.*)$', t, re.I|re.S)
    if m:
        return m.group(1) + '\n' + m.group(2).lstrip()
    return '<?xml version="1.0" encoding="UTF-8"?>\n' + t

def _send_cot_socket(host, port, xml, use_tls=False, cert_pair=None):
    start_ts=time.time()
    is_fileshare_req = bool(re.search(r'<fileshare\b|<dataPackage\b|<event\b[^>]*\btype=["\']b-f-t-r["\']|<event\b[^>]*\btype=["\']b-m-r["\']', str(xml or ''), re.I))
    auth_xml=''
    auth_diag={'auth_enabled': False, 'auth_sent': False, 'auth_reason': 'not tls'}
    # v216: authenticate all TLS CoT sends, not only FileShare/DataPackage.
    # This makes the dashboard send helper match the manual Python test that
    # successfully inserted TAKDASH-SOCKET-TEST-* into public.cot.
    if use_tls and os.environ.get('TAK_DASH_DISABLE_OTS_SOCKET_AUTH','').strip().lower() not in ('1','true','yes','on'):
        auth_xml, auth_diag = _cot_socket_auth_xml(xml)
    suffix, framing = _cot_socket_message_suffix(is_fileshare_req=is_fileshare_req, use_tls=use_tls)
    try:
        if use_tls and auth_xml:
            default_hold='3.0'
        elif is_fileshare_req:
            default_hold='0.75'
        else:
            default_hold='0.15'
        hold_seconds=float(os.environ.get('TAK_DASH_COT_SOCKET_HOLD_SECONDS', default_hold) or default_hold)
    except Exception:
        hold_seconds=3.0 if (use_tls and auth_xml) else (0.75 if is_fileshare_req else 0.15)
    try:
        auth_pause=float(os.environ.get('TAK_DASH_COT_SOCKET_AUTH_PAUSE_SECONDS','0.5') or '0.5')
    except Exception:
        auth_pause=0.5
    try:
        raw=socket.create_connection((host, int(port)), timeout=5)
        try:
            if use_tls:
                ctx=ssl.create_default_context()
                ctx.check_hostname=False
                ctx.verify_mode=ssl.CERT_NONE
                if cert_pair:
                    ctx.load_cert_chain(str(cert_pair[0]), str(cert_pair[1]))
                s=ctx.wrap_socket(raw, server_hostname=host)
            else:
                s=raw
            with s:
                if framing == 'traditional-xml':
                    if auth_xml:
                        # v205: match the manual test that successfully reached public.cot:
                        # send raw <auth><cot .../></auth> first, without an XML
                        # declaration or stream terminator, then send the CoT XML doc.
                        # Normalizing auth into <?xml...?><auth> can prevent OTS from
                        # recognizing the preamble even though the socket write succeeds.
                        s.sendall(str(auth_xml or '').encode('utf-8'))
                        if auth_pause > 0:
                            time.sleep(min(max(auth_pause, 0.0), 3.0))
                    s.sendall(_normalize_traditional_xml_stream_doc(xml).encode('utf-8'))
                else:
                    if auth_xml:
                        s.sendall(auth_xml.encode('utf-8') + suffix)
                        if auth_pause > 0:
                            time.sleep(min(max(auth_pause, 0.0), 3.0))
                    s.sendall(str(xml or '').encode('utf-8') + suffix)
                if hold_seconds > 0:
                    time.sleep(min(max(hold_seconds, 0.0), 15.0))
            return {'ok':True,'host':host,'port':int(port),'tls':bool(use_tls),'cert':str(cert_pair[0]) if cert_pair else '', 'socket_hold_seconds':hold_seconds, 'auth_pause_seconds':auth_pause if auth_xml else 0, 'duration_seconds':round(time.time()-start_ts,3), 'socket_framing':framing, 'traditional_xml_normalized': bool(framing == 'traditional-xml'), 'traditional_auth_raw': bool(framing == 'traditional-xml' and auth_xml), **auth_diag}
        except Exception:
            try: raw.close()
            except Exception: pass
            raise
    except Exception as e:
        return {'ok':False,'host':host,'port':int(port),'tls':bool(use_tls),'cert':str(cert_pair[0]) if cert_pair else '', 'socket_hold_seconds':hold_seconds, 'socket_framing':framing, **auth_diag, 'duration_seconds':round(time.time()-start_ts,3), 'error':str(e)}

def _cot_xml_ids(xml):
    text=str(xml or '')
    event_uid=''
    ack_uid=''
    sha=''
    m=re.search(r'<event\b[^>]*\buid=["\']([^"\']+)["\']', text, re.I)
    if m: event_uid=m.group(1)
    m=re.search(r'<ackrequest\b[^>]*\buid=["\']([^"\']+)["\']', text, re.I)
    if m: ack_uid=m.group(1)
    m=re.search(r'<fileshare\b[^>]*\bsha256=["\']([^"\']+)["\']', text, re.I)
    if m: sha=m.group(1)
    return event_uid, ack_uid, sha

def _wait_for_cot_db(event_uid, ack_uid, sha, timeout=None, interval=0.75):
    try:
        timeout=float(timeout if timeout is not None else os.environ.get('TAK_DASH_COT_DB_VERIFY_TIMEOUT','3'))
    except Exception:
        timeout=3.0
    timeout=max(0.5, min(timeout, 15.0))
    deadline=time.time()+timeout
    last={'ok':False,'error':'not checked','rows':[]}
    # Verify by the unique fileshare event/ack IDs only.  Do not count SHA-only
    # matches as success, because repeated sends of the same package reuse the
    # same SHA and can otherwise match an older b-f-t-r row.
    while True:
        last=_cot_db_lookup(event_uid, ack_uid, '')
        if last.get('ok'):
            last['waited_seconds']=max(0.0, timeout-(deadline-time.time()))
            return last
        if time.time() >= deadline:
            # Include the SHA lookup only as diagnostic context after the strict
            # event/ack lookup times out.
            sha_diag=_cot_db_lookup('', '', sha) if sha else {'ok':False,'rows':[],'error':'no sha'}
            last['sha_lookup_diagnostic']=sha_diag
            last['waited_seconds']=timeout
            return last
        time.sleep(float(interval or 0.75))

def _send_diag_dir():
    d=DATA_DIR/'send_diagnostics'
    d.mkdir(parents=True, exist_ok=True)
    try: os.chmod(d, 0o755)
    except Exception: pass
    return d

def _write_send_diag(label, payload=None, xml=None):
    """Always write Send Map / Send Offline diagnostics.
    This is intentionally independent of success/failure so a 200 HTTP response still leaves evidence.
    """
    try:
        d=_send_diag_dir()
        stamp=datetime.now(timezone.utc).strftime('%Y%m%d-%H%M%S') + '-' + hashlib.sha1((str(time.time())+str(uuid.uuid4())).encode()).hexdigest()[:8]
        base=re.sub(r'[^A-Za-z0-9_.-]+','-', str(label or 'send')).strip('-') or 'send'
        paths={}
        if xml is not None:
            xp=d/(stamp+'-'+base+'.xml')
            xp.write_text(str(xml), encoding='utf-8')
            paths['xml']=str(xp)
        if payload is not None:
            jp=d/(stamp+'-'+base+'.json')
            jp.write_text(json.dumps(json_safe(payload), indent=2, sort_keys=True), encoding='utf-8')
            paths['json']=str(jp)
        return paths
    except Exception as e:
        return {'error':str(e)}

def _cot_db_lookup(event_uid='', ack_uid='', sha='', package_name='', timeout=8):
    pg_uris, cfg_errors=_candidate_ots_pg_uris()
    if not pg_uris:
        return {'ok':False,'rows':[],'error':'No OpenTAKServer PostgreSQL URI found.','config_errors':cfg_errors}
    clauses=[]
    for val in (event_uid, ack_uid, sha, package_name):
        val=str(val or '').strip()
        if val:
            clauses.append('xml ilike ' + _pg_sql_literal('%'+val+'%'))
            if val==event_uid:
                clauses.append('uid=' + _pg_sql_literal(val))
    if not clauses:
        return {'ok':False,'rows':[],'error':'No CoT identifiers to query.'}
    sql="""select row_to_json(q) from (
select id, uid, type, sender_callsign, sender_uid, recipients, start, left(regexp_replace(xml, '\\s+', ' ', 'g'), 2000) as xml_preview
from public.cot
where %s
order by start desc
limit 20
) q""" % (' or '.join('('+c+')' for c in clauses))
    rows, err=_pg_rows_json(pg_uris[0], sql)
    if err:
        return {'ok':False,'rows':[],'error':err,'sql_preview':sql[:600]}
    return {'ok':bool(rows),'rows':rows,'error':'','sql_preview':sql[:600]}

def _http_cot_url_candidates():
    urls=[]
    raw=os.environ.get('TAK_DASH_OTS_COT_HTTP_URLS','').strip()
    for u in re.split(r'[,\s]+', raw) if raw else []:
        if u and u not in urls: urls.append(u)
    # These are diagnostic attempts only. OpenTAKServer versions differ, so return status/body for every route.
    for base in ('http://127.0.0.1:8080','http://127.0.0.1:8081'):
        for path in ('/Marti/api/cot/xml','/Marti/api/cot','/api/cot/xml','/api/cot','/api/events'):
            u=base+path
            if u not in urls: urls.append(u)
    return urls

def _send_cot_http(url, xml):
    try:
        data=str(xml or '').encode('utf-8')
        req=Request(url, data=data, method='POST', headers={'Content-Type':'application/xml','Accept':'application/json,text/plain,*/*','User-Agent':'TAKDashboard/2.11 fileshare-cot'})
        ctx=None
        if str(url).lower().startswith('https://'):
            ctx=ssl._create_unverified_context()
        if ctx is not None:
            resp=urlopen(req, timeout=5, context=ctx)
        else:
            resp=urlopen(req, timeout=5)
        body=resp.read(800).decode('utf-8','replace')
        code=getattr(resp,'status',None) or resp.getcode()
        return {'ok':200 <= int(code) < 300,'method':'http-post','url':url,'status':int(code),'body_preview':body[:800]}
    except HTTPError as e:
        try: body=e.read(800).decode('utf-8','replace')
        except Exception: body=''
        return {'ok':False,'method':'http-post','url':url,'status':getattr(e,'code',0),'error':str(e),'body_preview':body[:800]}
    except Exception as e:
        return {'ok':False,'method':'http-post','url':url,'error':str(e)}


def _send_cot_rabbitmq(xml):
    """Inject CoT directly into OpenTAKServer's RabbitMQ cot_parser exchange."""
    cfg, cfg_errors = _load_ots_config_values()
    host=(os.environ.get('TAK_DASH_RABBITMQ_HOST','').strip() or cfg.get('OTS_RABBITMQ_SERVER_ADDRESS','').strip() or '127.0.0.1')
    user=(os.environ.get('TAK_DASH_RABBITMQ_USERNAME','').strip() or cfg.get('OTS_RABBITMQ_USERNAME','').strip() or 'guest')
    password=(os.environ.get('TAK_DASH_RABBITMQ_PASSWORD','').strip() or cfg.get('OTS_RABBITMQ_PASSWORD','').strip() or 'guest')
    ttl=(os.environ.get('TAK_DASH_RABBITMQ_TTL','').strip() or cfg.get('OTS_RABBITMQ_TTL','').strip() or '86400000')
    exchange=(os.environ.get('TAK_DASH_RABBITMQ_COT_EXCHANGE','').strip() or 'cot_parser')
    raw_keys=os.environ.get('TAK_DASH_RABBITMQ_ROUTING_KEYS','').strip()
    keys=[]
    for k in re.split(r'[, ]+', raw_keys) if raw_keys else []:
        if k not in keys: keys.append(k)
    for k in ('', 'cot', 'cot_parser', 'event', 'eud'):
        if k not in keys: keys.append(k)
    script = """
import json, sys
try:
    import pika
except Exception as e:
    print(json.dumps({'ok':False,'method':'rabbitmq','error':'pika import failed: '+str(e)})); sys.exit(0)
payload=json.loads(sys.stdin.read())
xml=payload.get('xml','')
host=payload.get('host') or '127.0.0.1'
user=payload.get('user') or 'guest'
password=payload.get('password') or 'guest'
exchange=payload.get('exchange') or 'cot_parser'
keys=payload.get('keys') or ['']
ttl=str(payload.get('ttl') or '86400000')
attempts=[]
try:
    creds=pika.PlainCredentials(user, password)
    params=pika.ConnectionParameters(host=host, credentials=creds, heartbeat=10, blocked_connection_timeout=5, connection_attempts=1, retry_delay=0)
    conn=pika.BlockingConnection(params)
    ch=conn.channel()
    props=pika.BasicProperties(expiration=ttl)
    body=xml.encode('utf-8')
    for rk in keys:
        try:
            ch.basic_publish(exchange=exchange, routing_key=rk, body=body, properties=props)
            attempts.append({'ok':True,'routing_key':rk})
        except Exception as e:
            attempts.append({'ok':False,'routing_key':rk,'error':str(e)})
    try: conn.close()
    except Exception: pass
    print(json.dumps({'ok':any(a.get('ok') for a in attempts),'method':'rabbitmq','host':host,'exchange':exchange,'attempts':attempts}))
except Exception as e:
    print(json.dumps({'ok':False,'method':'rabbitmq','host':host,'exchange':exchange,'error':str(e),'attempts':attempts}))
"""
    payload={'xml':str(xml or ''),'host':host,'user':user,'password':password,'exchange':exchange,'keys':keys,'ttl':ttl}
    candidates=[]
    exe_candidates=[os.environ.get('TAK_DASH_OTS_VENV_PYTHON','').strip()]
    try:
        home_root=Path('/home')
        if home_root.exists():
            for home in sorted(home_root.iterdir()):
                if home.is_dir():
                    exe_candidates.extend([str(home/'.opentakserver_venv/bin/python3'), str(home/'.opentakserver_venv/bin/python')])
    except Exception:
        pass
    exe_candidates.extend([sys.executable, '/usr/bin/python3'])
    for exe in exe_candidates:
        if exe and exe not in candidates and Path(exe).exists(): candidates.append(exe)
    errors=[]
    for exe in candidates:
        try:
            res=subprocess.run([exe,'-c',script], input=json.dumps(payload), capture_output=True, text=True, timeout=8)
            out=(res.stdout or '').strip().splitlines()[-1] if (res.stdout or '').strip() else ''
            if out:
                try:
                    data=json.loads(out)
                except Exception:
                    data={'ok':False,'method':'rabbitmq','error':'non-json rabbitmq helper output','stdout':(res.stdout or '')[-1000:],'stderr':(res.stderr or '')[-1000:]}
            else:
                data={'ok':False,'method':'rabbitmq','error':'empty rabbitmq helper output','stderr':(res.stderr or '')[-1000:]}
            data.setdefault('method','rabbitmq')
            data['python']=exe
            data['config_errors']=cfg_errors
            if data.get('ok'):
                return data
            errors.append(data)
        except Exception as e:
            errors.append({'ok':False,'method':'rabbitmq','python':exe,'error':str(e)})
    return {'ok':False,'method':'rabbitmq','host':host,'exchange':exchange,'error':'RabbitMQ publish failed for all helper paths.','attempts':errors,'config_errors':cfg_errors}




def _send_cot_to_ots(xml):
    """Send CoT through OpenTAKServer with low CPU overhead.

    v197 defaults to low-power Send Map behavior for Raspberry Pi stability:
    - write one start diagnostic and one final diagnostic;
    - try TLS 8089 once first;
    - fall back to TCP 8088 only if TLS fails to write;
    - do not poll PostgreSQL for transient b-f-t-r rows unless explicitly enabled.

    Enable old heavy verification only when actively debugging:
      TAK_DASH_ENABLE_FILESHARE_COT_DB_VERIFY=1
      TAK_DASH_ENABLE_FILESHARE_COT_MULTI_ATTEMPT=1
    """
    event_uid, ack_uid, sha = _cot_xml_ids(xml)
    xml_text = str(xml or '')
    is_fileshare_req = bool(re.search(r'<fileshare\b|<dataPackage\b|<event\b[^>]*\btype=["\']b-f-t-r["\']', xml_text, re.I))
    verify_db = os.environ.get('TAK_DASH_ENABLE_FILESHARE_COT_DB_VERIFY','').strip().lower() in ('1','true','yes','on')
    multi_attempt = os.environ.get('TAK_DASH_ENABLE_FILESHARE_COT_MULTI_ATTEMPT','').strip().lower() in ('1','true','yes','on')
    strict_db = os.environ.get('TAK_DASH_REQUIRE_FILESHARE_COT_DB','').strip().lower() in ('1','true','yes','on')

    start_diag = {
        'event_uid': event_uid,
        'ack_uid': ack_uid,
        'sha256': sha,
        'phase': 'start',
        'time': datetime.now(timezone.utc).isoformat(),
        'low_power_mode': not verify_db,
        'db_verification_enabled': verify_db,
        'multi_attempt_enabled': multi_attempt,
        'preferred_ingest': 'eud_handler_ssl:8089; fallback eud_handler:8088 only if primary write fails',
        'fileshare_sender_team': os.environ.get('TAK_DASH_FILESHARE_SENDER_TEAM','').strip() or os.environ.get('TAK_DASH_OFFLINE_SENDER_TEAM','').strip() or 'Cyan',
    }
    try:
        m_url = re.search(r'\bsenderUrl=["\']([^"\']+)["\']', xml_text, re.I)
        if m_url: start_diag['senderUrl'] = m_url.group(1)
        start_diag['broadcast'] = ('<marti>' not in xml_text.lower())
        m_name = re.search(r'<fileshare\b[^>]*\bname=["\']([^"\']+)["\']', xml_text, re.I)
        if m_name: start_diag['fileshare_name'] = m_name.group(1)
    except Exception:
        pass
    diag_paths = _write_send_diag('fileshare-cot-start', start_diag, xml)
    attempts = []

    def finalize_sent_unverified(first_ok, warning):
        db = {'ok': False, 'rows': [], 'error': '', 'skipped': True, 'reason': 'DB verification disabled for low-power Send Map FileShare/DataPackage mode'}
        out = {**first_ok,
               'ok': True,
               'verified_in_cot_db': False,
               'accepted_unverified': True,
               'db_lookup': db,
               'attempts': [dict(a) for a in attempts],
               'diag_paths': diag_paths,
               'event_uid': event_uid,
               'ack_uid': ack_uid,
               'sha256': sha,
               'low_power_mode': True,
               'warning': warning,
               'error': ''}
        _write_send_diag('fileshare-cot-sent-unverified', out, xml)
        return out

    def verify_or_finish(r):
        if is_fileshare_req and not verify_db and not strict_db:
            return finalize_sent_unverified(r, 'CoT socket write accepted. DB polling skipped to reduce Raspberry Pi CPU/heat; watch ATAK for ack/import.')
        db = _wait_for_cot_db(event_uid, ack_uid, sha, timeout=2 if is_fileshare_req else 5, interval=1.0)
        r['db_after_send'] = db
        if db.get('ok'):
            out = {**r, 'ok': True, 'verified_in_cot_db': True, 'attempts': [dict(a) for a in attempts], 'diag_paths': diag_paths, 'low_power_mode': not verify_db}
            _write_send_diag('fileshare-cot-success', out, xml)
            return out
        if is_fileshare_req and not strict_db:
            return finalize_sent_unverified(r, 'CoT socket write accepted, but no matching public.cot row was observed. Treating Send Map FileShare/DataPackage notification as sent-unverified.')
        return None

    raw_hosts = os.environ.get('TAK_DASH_OTS_COT_HOST','').strip()
    hosts = []
    for h in re.split(r'[, ]+', raw_hosts) if raw_hosts else []:
        if h and h not in hosts: hosts.append(h)
    for h in ('127.0.0.1', 'localhost'):
        if h and h not in hosts: hosts.append(h)
    if not multi_attempt:
        hosts = hosts[:1] or ['127.0.0.1']

    # Primary: TLS 8089 only. Low-power mode returns immediately after first accepted write.
    certs = _ots_cert_candidates()
    tls_write_failed = True
    if not certs:
        attempts.append({'ok': False, 'method': 'socket-tls-primary', 'host': hosts[0] if hosts else '127.0.0.1', 'port': 8089, 'tls': True, 'error': 'No readable OTS TLS client cert/key found. Set TAK_DASH_OTS_CLIENT_CERT and TAK_DASH_OTS_CLIENT_KEY, or rerun install.sh so ACLs are applied.'})
    else:
        tls_ports = _cot_tls_ports()
        if not multi_attempt:
            tls_ports = [8089]
            certs = certs[:1]
        for host in hosts:
            for port in tls_ports:
                if int(port) != 8089 and os.environ.get('TAK_DASH_ALLOW_NONDEFAULT_TLS_COT_PORTS','').strip() not in ('1','true','yes','on'):
                    continue
                for pair in certs:
                    r = _send_cot_socket(host, port, xml, use_tls=True, cert_pair=pair)
                    r['method'] = 'socket-tls-primary'
                    attempts.append(r)
                    if r.get('ok'):
                        tls_write_failed = False
                        done = verify_or_finish(r)
                        if done is not None:
                            return done
                    if not multi_attempt and not tls_write_failed:
                        break
                if not multi_attempt and not tls_write_failed:
                    break
            if not multi_attempt and not tls_write_failed:
                break

    # Fallback: plaintext 8088 only if TLS did not write, unless explicitly debugging.
    do_tcp_fallback = tls_write_failed or multi_attempt
    if do_tcp_fallback and os.environ.get('TAK_DASH_DISABLE_PLAINTEXT_8088_FALLBACK','').strip().lower() not in ('1','true','yes','on'):
        tcp_ports = []
        for pval in _cot_tcp_ports():
            try: ip = int(pval)
            except Exception: continue
            if ip == 8089: continue
            if ip not in tcp_ports: tcp_ports.append(ip)
        if 8088 not in tcp_ports:
            tcp_ports.insert(0, 8088)
        if not multi_attempt:
            tcp_ports = [8088]
        for host in hosts:
            for port in tcp_ports:
                r = _send_cot_socket(host, port, xml, use_tls=False, cert_pair=None)
                r['method'] = 'socket-tcp-fallback'
                attempts.append(r)
                if r.get('ok'):
                    done = verify_or_finish(r)
                    if done is not None:
                        return done
                if not multi_attempt and r.get('ok'):
                    break
            if not multi_attempt and any(a.get('ok') and a.get('method') == 'socket-tcp-fallback' for a in attempts):
                break

    # Heavy fallback diagnostics are opt-in only.
    if multi_attempt and os.environ.get('TAK_DASH_ALLOW_RABBITMQ_COT_FALLBACK','').strip().lower() in ('1','true','yes','on'):
        rb = _send_cot_rabbitmq(xml)
        attempts.append(rb)
        if rb.get('ok'):
            done = verify_or_finish(rb)
            if done is not None:
                return done

    if multi_attempt and os.environ.get('TAK_DASH_ALLOW_HTTP_COT_FALLBACK','').strip().lower() in ('1','true','yes','on'):
        for url in _http_cot_url_candidates():
            r = _send_cot_http(url, xml)
            attempts.append(r)
            if r.get('ok'):
                done = verify_or_finish(r)
                if done is not None:
                    return done

    final_db = {'ok': False, 'rows': [], 'error': '', 'skipped': not verify_db}
    if verify_db or strict_db:
        final_db = _wait_for_cot_db(event_uid, ack_uid, sha, timeout=3, interval=1.0)
    error_parts = []
    for a in attempts[-8:]:
        if a.get('method') == 'http-post':
            error_parts.append(str(a.get('url','')) + ': ' + str(a.get('status') or a.get('error') or 'failed'))
        elif str(a.get('method','')).startswith('rabbitmq'):
            error_parts.append('rabbitmq ' + str(a.get('host','')) + '/' + str(a.get('exchange','cot_parser')) + ': ' + str(a.get('error') or 'failed'))
        else:
            error_parts.append(str(a.get('host','')) + ':' + str(a.get('port')) + ('/tls' if a.get('tls') else '/tcp') + ': ' + str(a.get('error') or ('socket write ok but no cot DB row' if a.get('ok') else 'failed')))
    out = {'ok': False,
           'host': ','.join(hosts),
           'port': '8089/tls,8088/tcp-fallback',
           'event_uid': event_uid,
           'ack_uid': ack_uid,
           'sha256': sha,
           'verified_in_cot_db': False,
           'db_lookup': final_db,
           'attempts': attempts,
           'diag_paths': diag_paths,
           'low_power_mode': not verify_db,
           'error': '; '.join(error_parts) or 'No CoT submit paths attempted.'}
    more_paths = _write_send_diag('fileshare-cot-failed', out, xml)
    out['diag_paths'] = {**(diag_paths or {}), **({'final_json': more_paths.get('json')} if isinstance(more_paths, dict) else {})}
    return out

def _fileshare_ack_status(send_record):
    ack_uids=[str(t.get('ack_uid') or '') for t in (send_record.get('targets') or []) if t.get('ack_uid')]
    sha=str(send_record.get('sha256') or '')
    if not ack_uids and not sha:
        return []
    pg_uris, _cfg_errors = _candidate_ots_pg_uris()
    if not pg_uris:
        return []
    clauses=[]
    for au in ack_uids:
        clauses.append("xml ilike " + _pg_sql_literal('%'+au+'%'))
    if sha:
        clauses.append("xml ilike " + _pg_sql_literal('%'+sha+'%'))
    sql=f"select row_to_json(q) from (select id, uid, type, sender_callsign, sender_uid, start, xml from public.cot where type='b-f-t-a' and ({' or '.join(clauses)}) order by start desc limit 50) q"
    rows, err=_pg_rows_json(pg_uris[0], sql)
    if err:
        return []
    out=[]
    for r in rows:
        xml=str(r.get('xml') or '')
        m_uid=re.search(r'<ackresponse\b[^>]*\buid=["\']([^"\']+)["\']', xml, re.I)
        m_succ=re.search(r'<ackresponse\b[^>]*\bsuccess=["\']([^"\']+)["\']', xml, re.I)
        m_reason=re.search(r'<ackresponse\b[^>]*\breason=["\']([^"\']+)["\']', xml, re.I)
        out.append({'ack_uid':m_uid.group(1) if m_uid else '', 'success':(m_succ.group(1).lower()=='true') if m_succ else None, 'reason':m_reason.group(1) if m_reason else '', 'sender_callsign':r.get('sender_callsign') or '', 'start':r.get('start') or ''})
    return out


def _mission_publish_creator_uid(preferred_uid=''):
    """Choose a creatorUid acceptable to OTS Mission API.

    Mission create requires a UID already known in the OTS EUD table. Prefer an
    explicit env/config value, then the supplied value, then the freshest known EUD.
    This is used only as the Mission API author; it does not expose server GPS.
    """
    env=(
        os.environ.get('TAK_DASH_MISSION_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_DATA_SYNC_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_NATIVE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_FILESHARE_CREATOR_UID','').strip()
    )
    dash_identity=(
        os.environ.get('TAK_DASH_FILESHARE_SENDER_UID','').strip()
        or os.environ.get('TAK_DASH_OTS_CLIENT_NAME','').strip()
        or os.environ.get('TAK_DASH_FILESHARE_SENDER_CALLSIGN','').strip()
        or 'takdash'
    )
    candidates=[]
    for val,src in ((env,'env'), (preferred_uid,'argument'), (dash_identity,'dashboard-identity')):
        val=str(val or '').strip()
        if val and val not in [x.get('uid') for x in candidates]:
            candidates.append({'uid':val,'source':src})
    try:
        euds=tak_map_euds().get('euds') or []
        def age(e):
            try: return float(e.get('location_age_seconds'))
            except Exception: return 999999.0
        for e in sorted(euds, key=age):
            uid=str(e.get('uid') or '').strip()
            cs=str(e.get('callsign') or '').strip().lower()
            blob=str([e.get('kind'),e.get('source'),e.get('type'),e.get('client'),e.get('client_label'),e.get('callsign'),e.get('uid')]).lower()
            if uid and cs and not any(x in blob for x in ('ads-b','adsb','aircraft','webform','server_gps')):
                if uid not in [x.get('uid') for x in candidates]:
                    candidates.append({'uid':uid,'source':'tak_map_euds'})
    except Exception:
        pass
    pg_uris, _cfg_errors=_candidate_ots_pg_uris()
    for cand in candidates:
        uid=str(cand.get('uid') or '').strip()
        if not uid:
            continue
        if pg_uris:
            try:
                cnt,err=_pg_first_value(pg_uris[0], 'select count(*) from public.euds where uid=' + _pg_sql_literal(uid))
                if not err and int(cnt or 0) > 0:
                    return {'ok':True,'uid':uid,'source':cand.get('source'),'candidates':candidates}
                # v216: for Data Sync publishes, prefer the dashboard/takdash identity
                # even if it is a certificate/user identity rather than a recent EUD row.
                # If OTS rejects it, the publish function retries with a real EUD creator.
                if cand.get('source') in ('env','argument','dashboard-identity'):
                    return {'ok':True,'uid':uid,'source':str(cand.get('source'))+':unverified-preferred','candidates':candidates}
            except Exception:
                if cand.get('source') in ('env','argument','dashboard-identity'):
                    return {'ok':True,'uid':uid,'source':str(cand.get('source'))+':unverified-error-preferred','candidates':candidates}
        elif uid:
            return {'ok':True,'uid':uid,'source':str(cand.get('source'))+':unverified','candidates':candidates}
    # Last-chance direct DB lookup, independent of tak_map_euds column normalization.
    if pg_uris:
        try:
            rows,err=_pg_rows_json(pg_uris[0], "select row_to_json(q) from (select uid from public.euds where uid is not null and uid<>'' order by id desc limit 1) q")
            if not err and rows:
                uid=str(rows[0].get('uid') or '').strip()
                if uid:
                    return {'ok':True,'uid':uid,'source':'postgres:euds-latest','candidates':candidates}
        except Exception:
            pass
    return {'ok':False,'uid':'','error':'No known OTS EUD UID found for Mission API creatorUid. Connect one ATAK EUD or set TAK_DASH_MISSION_CREATOR_UID=<EUD_UID>.','candidates':candidates}

def _ots_https_context_for_mission_api(cert_pair=None):
    ctx=ssl.create_default_context()
    ctx.check_hostname=False
    ctx.verify_mode=ssl.CERT_NONE
    if cert_pair:
        ctx.load_cert_chain(str(cert_pair[0]), str(cert_pair[1]))
    return ctx

def _ots_mission_api_hosts(public_host=''):
    host_public=_url_host(public_host or _default_server_host()).strip('[]')
    hosts=[]
    for h in (host_public, '127.0.0.1', 'localhost'):
        h=str(h or '').strip()
        if h and h not in hosts:
            hosts.append(h)
    return hosts

def _ots_mission_api_request(path, method='GET', body=None, headers=None, token='', public_host='', timeout=25):
    cert_pairs=_ots_cert_candidates()
    cert_pair=cert_pairs[0] if cert_pairs else None
    port=_ots_marti_https_port()
    attempts=[]
    headers=dict(headers or {})
    headers.setdefault('Accept','application/json,*/*')
    headers.setdefault('User-Agent','TAKDashboard/v301 MissionAPI')
    if token:
        headers['Authorization']='Bearer '+str(token)
    if isinstance(body, str):
        body=body.encode('utf-8')
    for host in _ots_mission_api_hosts(public_host):
        url=f'https://{_url_host(host)}:{port}{path}'
        try:
            req=Request(url, data=body, method=method, headers=headers)
            with urlopen(req, timeout=timeout, context=_ots_https_context_for_mission_api(cert_pair)) as resp:
                raw=resp.read(8*1024*1024)
                text=decode_http_body(raw, getattr(resp,'headers',{}) or {})
                code=int(getattr(resp,'status',None) or resp.getcode())
                rec={'host':host,'url':url,'method':method,'status':code,'ok':200 <= code < 300,'body_preview':text[:2400]}
                try: rec['json']=json.loads(text) if text.strip() else {}
                except Exception: rec['json_parse_error']='response was not JSON'
                attempts.append(rec)
                return {'ok':rec['ok'],'status':code,'url':url,'host':host,'body':text,'json':rec.get('json') or {},'attempts':attempts,'cert':str(cert_pair[0]) if cert_pair else ''}
        except HTTPError as e:
            try: text=decode_http_body(e.read(2400), getattr(e,'headers',{}) or {})
            except Exception: text=''
            attempts.append({'host':host,'url':url,'method':method,'status':int(getattr(e,'code',0) or 0),'ok':False,'error':str(e),'body_preview':text[:2400]})
        except Exception as e:
            attempts.append({'host':host,'url':url,'method':method,'ok':False,'error':str(e)})
    return {'ok':False,'error':'All OTS Mission API attempts failed.','attempts':attempts,'cert':str(cert_pair[0]) if cert_pair else ''}

def _extract_mission_token(resp_json):
    try:
        data=resp_json.get('data') or []
        if isinstance(data, list) and data:
            return str((data[0] or {}).get('token') or '')
    except Exception:
        pass
    return ''

def tak_map_publish_package_to_mission(zip_path, package_filename, sha256_hash, mission_name='', content_label='', content_kind='package', server_host='', preferred_creator_uid=''):
    mission=str(mission_name or '').strip() or os.environ.get('TAK_DASH_DEFAULT_MISSION_NAME','TAK Dashboard Basemaps').strip() or 'TAK Dashboard Basemaps'
    zp=Path(str(zip_path))
    if not zp.exists():
        return {'ok':False,'error':'Package ZIP does not exist.','path':str(zp),'mission':mission}
    creator=_mission_publish_creator_uid(preferred_creator_uid)
    if not creator.get('ok'):
        return {'ok':False,'error':creator.get('error') or 'No Mission API creator UID available.','creator':creator,'mission':mission}
    creator_uid=str(creator.get('uid') or '').strip()
    sha=str(sha256_hash or '').strip() or hashlib.sha256(zp.read_bytes()).hexdigest()
    base_fn=str(package_filename or zp.name or 'TAK-Dashboard-Package.zip').strip() or 'TAK-Dashboard-Package.zip'
    stem,ext=os.path.splitext(base_fn)
    if not ext: ext='.zip'
    # Use a unique stored MissionContent filename so repeated basemap publishes do
    # not overwrite a different-hash file in OTS_DATA_FOLDER/missions.
    publish_filename=f"{stem}-{sha[:12]}{ext}"
    keywords=['missionpackage','tak-dashboard',str(content_kind or 'package')]
    if 'basemap' in str(content_kind).lower() or 'map' in str(content_kind).lower():
        keywords.append('basemap')
    file_bytes=zp.read_bytes()
    creator_attempts=[]
    def run_publish_with_creator(cuid):
        # 1) Create or update mission and obtain a mission token.
        q='creatorUid='+quote(cuid, safe='')+'&tool=public&defaultRole=MISSION_SUBSCRIBER'
        create_path='/Marti/api/missions/'+quote(mission, safe='')+'?'+q
        create=_ots_mission_api_request(create_path, method='PUT', body=b'', headers={'Content-Length':'0'}, public_host=server_host, timeout=20)
        token=_extract_mission_token(create.get('json') or {})
        # 2) Upload content through the Data Sync upload endpoint.
        upload_q='name='+quote(publish_filename, safe='')+'&creatorUid='+quote(cuid, safe='')
        for kw in keywords:
            upload_q += '&keywords=' + quote(str(kw), safe='')
        upload=_ots_mission_api_request('/Marti/sync/upload?'+upload_q, method='POST', body=file_bytes, headers={'Content-Type':'application/zip','Content-Length':str(len(file_bytes))}, public_host=server_host, timeout=45)
        uploaded_hash=str(((upload.get('json') or {}).get('Hash') or (upload.get('json') or {}).get('hash') or sha)).strip()
        # 3) Associate uploaded content hash with mission. This should trigger OTS's
        # MissionChange path for Data Sync subscribers.
        assoc_body=json.dumps({'hashes':[uploaded_hash]}).encode('utf-8')
        assoc_path='/Marti/api/missions/'+quote(mission, safe='')+'/contents?creatorUid='+quote(cuid, safe='')
        assoc=_ots_mission_api_request(assoc_path, method='PUT', body=assoc_body, headers={'Content-Type':'application/json','Content-Length':str(len(assoc_body))}, token=token, public_host=server_host, timeout=25)
        return create, upload, assoc, uploaded_hash

    create, upload, assoc, uploaded_hash = run_publish_with_creator(creator_uid)
    creator_attempts.append({'uid':creator_uid,'source':creator.get('source'),'ok':bool(create.get('ok') and upload.get('ok') and assoc.get('ok'))})
    # If takdash/dashboard identity is rejected by OTS on this build, retry with
    # the first verified EUD creator so publish still works. The retry is explicit
    # in diagnostics so we know why an EUD name appears as the author.
    if not bool(create.get('ok') and upload.get('ok') and assoc.get('ok')):
        fallback=_mission_publish_creator_uid('')
        for cand in (fallback.get('candidates') or []):
            if cand.get('source') == 'tak_map_euds' and str(cand.get('uid') or '').strip() and str(cand.get('uid')).strip() != creator_uid:
                fb_uid=str(cand.get('uid')).strip()
                c2,u2,a2,h2=run_publish_with_creator(fb_uid)
                creator_attempts.append({'uid':fb_uid,'source':'tak_map_euds-fallback','ok':bool(c2.get('ok') and u2.get('ok') and a2.get('ok'))})
                if bool(c2.get('ok') and u2.get('ok') and a2.get('ok')):
                    creator_uid=fb_uid
                    creator={'ok':True,'uid':fb_uid,'source':'tak_map_euds-fallback','candidates':fallback.get('candidates') or []}
                    create,upload,assoc,uploaded_hash=c2,u2,a2,h2
                break
    out={
        'ok': bool(create.get('ok') and upload.get('ok') and assoc.get('ok')),
        'mission': mission,
        'creator_uid': creator_uid,
        'creator': creator,
        'creator_attempts': creator_attempts,
        'content_kind': content_kind,
        'content_label': content_label,
        'package_filename': base_fn,
        'publish_filename': publish_filename,
        'sha256': sha,
        'uploaded_hash': uploaded_hash,
        'keywords': keywords,
        'create_mission': create,
        'upload_content': upload,
        'associate_content': assoc,
        'message': '',
        'error': '',
    }
    if out['ok']:
        out['message']=f'Published {content_label or base_fn} to Data Sync Mission {mission}.'
    else:
        parts=[]
        for label,obj in (('create mission',create),('upload content',upload),('associate content',assoc)):
            if not obj.get('ok'):
                parts.append(label+': '+str(obj.get('error') or obj.get('status') or (obj.get('attempts') or [{}])[-1].get('error','failed')))
        out['error']='; '.join(parts) or 'Mission publish failed.'
    diag=_write_send_diag('mission-datasync-publish', out, None)
    if isinstance(diag, dict):
        out['diag_paths']=diag
    return out

def tak_map_live_basemap_source_mission_publish(basemap_id, mission_name='', dashboard_origin='', server_host=''):
    pkg=tak_map_live_basemap_source_package(basemap_id, dashboard_origin, server_host)
    if not pkg.get('ok'):
        return pkg
    res=tak_map_publish_package_to_mission(Path(pkg['path']), pkg.get('package_name') or 'TAK Map Source.zip', pkg.get('sha256') or '', mission_name, pkg.get('content_name') or pkg.get('fileshare_cot_name') or 'Basemap', 'basemap', server_host, '')
    res['package']={k:v for k,v in pkg.items() if k!='xml'}
    return res

def tak_map_offline_mission_publish(map_id, mission_name='', server_host=''):
    mid=str(map_id or '').strip()
    if not mid:
        return {'ok':False,'error':'Offline map id is required.'}
    maps=_load_offline_maps()
    target_map=next((m for m in maps if str(m.get('id'))==mid), None)
    if not target_map:
        return {'ok':False,'error':'Offline map not found.'}
    pkg=tak_map_offline_eud_package(mid)
    if not pkg.get('ok'):
        return pkg
    res=tak_map_publish_package_to_mission(Path(pkg['path']), pkg.get('package_name') or 'Offline Map.zip', pkg.get('sha256') or '', mission_name, target_map.get('name') or pkg.get('content_name') or 'Offline Map', 'offline-map', server_host, '')
    res['package']=pkg
    # Store a compact publish history on the offline map record.
    maps=_load_offline_maps()
    now=datetime.now(timezone.utc).isoformat()
    for m in maps:
        if str(m.get('id'))==mid:
            hist=list(m.get('mission_publish_history') or [])
            hist.append({'created':now,'mission':res.get('mission'),'ok':res.get('ok'),'sha256':pkg.get('sha256'),'package_name':pkg.get('package_name'),'diag_paths':res.get('diag_paths',{}),'error':res.get('error','')})
            m['last_mission_publish']=hist[-1]
            m['mission_publish_history']=hist[-12:]
    _save_offline_maps(maps)
    res['maps']=_load_offline_maps()
    return res
def tak_map_offline_send_status(send_id):
    sid=str(send_id or '').strip()
    for m in _load_offline_maps():
        for s in (m.get('send_history') or []):
            if str(s.get('send_id') or '')==sid:
                acks=_fileshare_ack_status(s)
                by={a.get('ack_uid'):a for a in acks}
                targets=[]
                delivered=0
                for t in s.get('targets') or []:
                    ack=by.get(t.get('ack_uid'))
                    row=dict(t)
                    if ack:
                        row['ack']=ack
                        if ack.get('success') is True:
                            row['status']='delivered'; delivered+=1
                        elif ack.get('success') is False:
                            row['status']='failed'
                    targets.append(row)
                return {'ok':True,'send_id':sid,'status':('delivered' if targets and delivered==len(targets) else s.get('status','sent')),'delivered':delivered,'targets':targets,'acks':acks}
    return {'ok':False,'error':'Send request not found.'}

def tak_map_offline_send(map_id, targets, server_host=''):
    """Upload/register an ATAK-style offline map fileshare package and send b-f-t-r CoT notifications."""
    mid=str(map_id or '').strip()
    if not mid:
        return {'ok':False,'error':'Offline map id is required.'}
    if not isinstance(targets, list):
        targets=[]
    clean=[]
    for t in targets[:50]:
        if not isinstance(t, dict):
            continue
        uid=str(t.get('uid') or t.get('id') or '').strip()[:160]
        callsign=str(t.get('callsign') or t.get('name') or uid or '').strip()[:160]
        lat=_coerce_float(t.get('lat')); lon=_coerce_float(t.get('lon'))
        if callsign:
            clean.append({'uid':uid,'callsign':callsign,'lat':lat,'lon':lon,'team':str(t.get('team') or t.get('group') or '').strip()[:80]})
    if not clean:
        return {'ok':False,'error':'Select at least one online EUD.'}
    maps=_load_offline_maps()
    target_map=next((m for m in maps if str(m.get('id'))==mid), None)
    if not target_map:
        return {'ok':False,'error':'Offline map not found.'}
    pkg=tak_map_offline_eud_package(mid)
    if not pkg.get('ok'):
        return pkg
    _sender=_preferred_fileshare_sender_identity('tak-dashboard','TAK-DASHBOARD')
    sender_callsign=str(_sender.get('callsign') or 'tak-dashboard').strip() or 'tak-dashboard'
    sender_uid=str(_sender.get('uid') or 'TAK-DASHBOARD').strip() or 'TAK-DASHBOARD'
    native_creator_uid=(
        os.environ.get('TAK_DASH_FILESHARE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_NATIVE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_OTS_CREATOR_UID','').strip()
        or str((clean[0] or {}).get('uid') or '').strip()
        or sender_uid
    )
    reg=_ots_missionupload_and_register_tool(Path(pkg['path']), pkg['package_name'], pkg['sha256'], native_creator_uid, server_host)
    _write_send_diag('native-ots-registration', {**reg, 'sha256':pkg.get('sha256'), 'package_name':pkg.get('package_name'), 'content_name':pkg.get('content_name'), 'sender_callsign':sender_callsign, 'sender_uid':sender_uid, 'native_creator_uid_candidate':native_creator_uid, 'send_kind':'offline-map'}, None)
    if reg.get('ok'):
        pkg['preferred_sender_url']=str(reg.get('sender_url') or '')
    else:
        # Keep a working fallback path for diagnostics/manual delivery when the
        # native metadata-tool registration fails.
        fallback_reg=_register_ots_data_package(Path(pkg['path']), pkg['package_name'], pkg['sha256'], pkg['size_bytes'], sender_uid)
        reg['fallback_register']=fallback_reg
        if fallback_reg.get('ok'):
            pkg['registered_ots_data_package']=True
        else:
            return {'ok':False,'error':'Offline map package upload failed: '+str(reg.get('error') or 'unknown error'),'package':pkg,'register':reg}
    lat,lon=_offline_map_center(target_map)
    send_id=str(uuid.uuid4())
    results=[]
    any_ok=False
    url_variants=_fileshare_sender_url_variants(pkg, server_host)
    broadcast_fallback=_fileshare_broadcast_enabled()
    for t in clean:
        for uv in url_variants:
            delivery_variants=[]
            enable_full_fallback=os.environ.get('TAK_DASH_ENABLE_FULL_FILESHARE_COT_FALLBACK','').strip().lower() in ('1','true','yes','on')
            if broadcast_fallback:
                # v205 default: minimal FileShare CoT only, broadcast first then targeted.
                # Full dashboard-metadata CoT is opt-in because it was being written last
                # and made diagnostics look like the minimal/native branch never ran.
                delivery_variants.extend([
                    ('native-minimal-broadcast', True, 'minimal'),
                    ('native-minimal-targeted', False, 'minimal'),
                ])
                if enable_full_fallback:
                    delivery_variants.extend([
                        ('full-broadcast', True, 'full'),
                        ('full-targeted', False, 'full'),
                    ])
            else:
                # v199: explicitly test the community-suggested ATAK basemap
                # DataPackage CoT shape: type=b-m-r with detail/dataPackage
                # type=basemap plus a fileshare URL.  Keep old b-f-t-r shapes
                # behind a comparison flag so this test is clean.
                delivery_variants.extend([
                    ('datapackage-basemap-targeted', False, 'datapackage-basemap'),
                ])
                if os.environ.get('TAK_DASH_ENABLE_LEGACY_FILESHARE_COT_COMPARISON','').strip().lower() in ('1','true','yes','on'):
                    delivery_variants.extend([
                        ('native-minimal-targeted', False, 'minimal'),
                    ])
                    if os.environ.get('TAK_DASH_DISABLE_LIVE_BASEMAP_FULL_TARGETED','').strip().lower() not in ('1','true','yes','on'):
                        delivery_variants.extend([
                            ('full-targeted', False, 'full'),
                        ])
                    elif enable_full_fallback:
                        delivery_variants.extend([
                            ('full-targeted', False, 'full'),
                        ])
            for delivery_label, is_broadcast, cot_shape in delivery_variants:
                variant_label=delivery_label+'-'+str(uv.get('label') or 'url')
                if cot_shape == 'minimal':
                    xml, meta=_build_fileshare_cot_minimal(t['callsign'], pkg, sender_callsign, sender_uid, server_host, lat, lon, t.get('uid') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                else:
                    xml, meta=_build_fileshare_cot(t['callsign'], pkg, sender_callsign, sender_uid, server_host, lat, lon, t.get('uid') or '', t.get('team') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                sent=_send_cot_to_ots(xml)
                row={**t, **meta, 'status':'sent' if sent.get('ok') else 'failed', 'send_error':sent.get('error',''), 'cot_host':sent.get('host',''), 'cot_port':sent.get('port',''), 'cot_xml_preview':xml[:1200], 'cot_attempts':sent.get('attempts',[]), 'verified_in_cot_db':sent.get('verified_in_cot_db',False), 'accepted_unverified':sent.get('accepted_unverified',False), 'send_warning':sent.get('warning',''), 'diag_paths':sent.get('diag_paths',{}), 'db_lookup':sent.get('db_lookup') or sent.get('db_after_send') or {}}
                results.append(row)
                any_ok=any_ok or sent.get('ok')
    maps=_load_offline_maps()
    now=datetime.now(timezone.utc).isoformat()
    for m in maps:
        if str(m.get('id'))==mid:
            sends=list(m.get('send_history') or [])
            sends.append({'send_id':send_id,'created':now,'targets':results,'package_url':pkg.get('package_url'),'package_name':pkg.get('package_name'),'content_name':pkg.get('content_name'),'sha256':pkg.get('sha256'),'size_bytes':pkg.get('size_bytes'),'status':'sent' if any_ok else 'failed','sender_callsign':sender_callsign,'sender_uid':sender_uid})
            m['last_send_request']=sends[-1]
            m['send_history']=sends[-12:]
    _save_offline_maps(maps)
    fail_msg='Package uploaded to OTS Data Packages, but no verified b-f-t-r fileshare CoT reached the OTS cot table. See send diagnostics.'
    ok_msg=('FileShare CoT sent using native OTS metadata/tool URL.' if reg.get('ok') else 'Native OTS metadata/tool registration failed; FileShare CoT sent using dashboard fallback URL. See native-ots-registration diagnostics.')
    return {'ok':any_ok,'status':'sent' if any_ok else 'failed','message':(ok_msg if any_ok else fail_msg),'error':('' if any_ok else fail_msg),'send_id':send_id,'targets':results,'package':pkg,'register':reg,'maps':_load_offline_maps()}



def _active_offline_jobs_summary():
    jobs=[]
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        for j in TAK_MAP_OFFLINE_DOWNLOAD_JOBS.values():
            if str(j.get('status') or '').lower() in ('queued','running'):
                jobs.append(dict(j))
    if not jobs:
        return {'active':0,'eta_seconds':None,'eta':'','jobs':[]}
    etas=[]
    for j in jobs:
        eta=_offline_job_eta_seconds(j)
        if eta is not None:
            etas.append(eta)
        j['eta_seconds']=eta
        j['eta']=_format_eta(eta) if eta is not None else ''
    return {'active':len(jobs),'eta_seconds':min(etas) if etas else None,'eta':_format_eta(min(etas)) if etas else '', 'jobs':jobs[:5]}

def _offline_job_eta_seconds(job):
    try:
        done=int(job.get('done') or 0)
        total=int(job.get('tile_count') or 0)
        if done <= 0 or total <= 0 or done >= total:
            return None
        start=_parse_ts_epoch(job.get('started') or job.get('created') or '')
        if start is None:
            return None
        elapsed=max(1.0, time.time()-float(start))
        rate=done/elapsed
        if rate <= 0:
            return None
        return max(0, int((total-done)/rate))
    except Exception:
        return None

def _format_eta(seconds):
    try:
        s=int(seconds)
    except Exception:
        return ''
    if s < 0: s=0
    h=s//3600; m=(s%3600)//60; sec=s%60
    if h:
        return f"ETA {h}h {m:02d}m"
    return f"ETA {m}m {sec:02d}s"


def tak_map_non_tak_sensor_count():
    try:
        markers,_notes=_ots_pg_markers(limit_per_table=1200)
        count=0
        for m in markers or []:
            kind=str(m.get('kind') or '').lower()
            if kind in ('aircraft','webform','server_gps','eud','datasync'):
                continue
            if not is_valid_latlon_py(m.get('lat'), m.get('lon')):
                continue
            blob=' '.join(str(m.get(k) or '') for k in ('uid','callsign','source','client','client_label','type')).lower()
            if any(x in blob for x in ('ads-b','adsb','aircraft','webform','tak-dashboard','server_gps','server gps')):
                continue
            if _has_tak_client_version(m, ''):
                continue
            count += 1
        return count
    except Exception:
        return 0

def is_valid_latlon_py(lat, lon):
    try:
        lat=float(lat); lon=float(lon)
        return -90 <= lat <= 90 and -180 <= lon <= 180 and not (abs(lat)<0.000001 and abs(lon)<0.000001)
    except Exception:
        return False

def tak_map_status_banner():
    internet='Disconnected'
    try:
        inet=get_internet_status() or {}
        state=str(inet.get('state') or '').upper()
        internet='Connected' if state in ('UP','ONLINE','CONNECTED') else 'Disconnected'
    except Exception:
        pass
    tak='Offline'
    try:
        r=run_cmd(['systemctl','is-active','opentakserver'],3)
        tak='Online' if str(r.get('stdout') or '').strip()=='active' else 'Offline'
    except Exception:
        pass
    eud_count=0
    try:
        eud_count=len((tak_map_euds() or {}).get('euds') or [])
    except Exception:
        pass
    adsb_count=0
    try:
        adsb_count=len((tak_map_adsb() or {}).get('aircraft') or [])
    except Exception:
        pass
    non_tak_sensor=0
    try:
        non_tak_sensor=tak_map_non_tak_sensor_count()
    except Exception:
        pass
    dl=_active_offline_jobs_summary()
    return {'ok':True,'tak_server':tak,'internet':internet,'euds_connected':eud_count,'non_tak_sensor':non_tak_sensor,'adsb_aircraft':adsb_count,'downloads':dl}

def _live_basemap_by_id(basemap_id):
    bid=str(basemap_id or '').strip()
    for b in TAK_MAP_BASEMAPS:
        if str(b.get('id'))==bid:
            return b
    return None

def _safe_filename_label(label, ext='xml'):
    base=re.sub(r'[^A-Za-z0-9_. -]+','-',str(label or 'TAK Dashboard Basemap')).strip(' .-_')[:90]
    base=base or 'TAK Dashboard Basemap'
    if not base.lower().endswith('.'+ext.lower()):
        base += '.'+ext
    return base

def tak_map_live_tile(basemap_id, z, x, y):
    b=_live_basemap_by_id(basemap_id)
    if not b:
        return None, 'text/plain', 'Unknown live basemap.'
    url=_tile_url(b.get('url') or '', int(z), int(x), int(y))
    if not url.startswith(('https://','http://')):
        return None, 'text/plain', 'Unsupported live basemap URL.'
    try:
        req=Request(url, headers={'User-Agent':'TAKDashboard/2.11 live-basemap-proxy'})
        with urlopen(req, timeout=12) as resp:
            data=resp.read(8*1024*1024)
            ctype=resp.headers.get('Content-Type') or 'image/png'
            return data, ctype.split(';')[0], ''
    except Exception as e:
        return None, 'text/plain', str(e)

def _build_mapsource_xml(basemap, dashboard_origin):
    # ATAK mapsource XMLs are normally placed under /atak/imagery/mobile/mapsources/ on the EUD.
    label_l=str(basemap.get('label','')).lower(); url_l=str(basemap.get('url','')).lower(); tile_type='jpg' if ('imagery' in label_l or 'esri' in label_l or 'arcgisonline.com' in url_l or 'arcgis/rest/services' in url_l) else 'png'
    minz=int(basemap.get('minZoom') or 0)
    maxz=int(basemap.get('maxZoom') or 19)
    # Convert dashboard/Leaflet URL placeholders to ATAK/MOBAC placeholders
    # while preserving provider tile order, e.g. ArcGIS REST remains /tile/{$z}/{$y}/{$x}.
    url=_atak_mapsource_url(basemap.get('url') or '')
    root=ET.Element('customMapSource')
    ET.SubElement(root,'name').text=str(basemap.get('label') or basemap.get('id') or 'Basemap')
    ET.SubElement(root,'minZoom').text=str(minz)
    ET.SubElement(root,'maxZoom').text=str(maxz)
    ET.SubElement(root,'tileType').text=tile_type
    ET.SubElement(root,'tileUpdate').text='None'
    ET.SubElement(root,'url').text=url
    ET.SubElement(root,'backgroundColor').text='#000000'
    ET.SubElement(root,'ignoreErrors').text='false'
    ET.SubElement(root,'serverParts').text=''
    return '<?xml version="1.0" encoding="UTF-8"?>\n' + ET.tostring(root, encoding='unicode', short_empty_elements=False)

def tak_map_live_basemap_source_package(basemap_id, dashboard_origin='', server_host=''):
    b=_live_basemap_by_id(basemap_id)
    if not b:
        return {'ok':False,'error':'Live basemap source not found or unsupported.'}
    TAK_MAP_OFFLINE_PACKAGE_DIR.mkdir(parents=True, exist_ok=True)
    base_xml_name=_safe_filename_label(str(b.get('label') or b.get('id') or 'Basemap'), 'xml')
    content_xml_name=base_xml_name
    safe_origin=_dashboard_https_origin(dashboard_origin, server_host)
    xml_text=_build_mapsource_xml(b, safe_origin)
    xml_data=xml_text.encode('utf-8')
    raw_sha=hashlib.sha256(xml_data).hexdigest()

    # Keep a raw XML copy for diagnostics/manual download.
    raw_id=_safe_offline_id('mapsource-xml-' + str(b.get('id') or '') + '-' + raw_sha[:8])
    raw_path=TAK_MAP_OFFLINE_PACKAGE_DIR/(raw_id + '.xml')
    raw_path.write_bytes(xml_data)

    # v205 delivery format: keep the manifest-based Mission Package, but make
    # the fileshare metadata look like the v178 shape that ATAK actually surfaced:
    # the transfer filename is a ZIP, but the displayed FileShare name is the XML
    # mapsource.  The manifest content entry follows TAK map-package examples:
    # a hash/member directory plus contentType=External Native Data.  Extra
    # fallback copies are included but not listed as separate manifest Content
    # entries so they do not create duplicate imports.
    label=str(b.get('label') or b.get('id') or 'Basemap').strip() or 'Basemap'
    display_name=(base_xml_name[:-4] + ' Map Source') if base_xml_name.lower().endswith('.xml') else (base_xml_name + ' Map Source')
    zip_name=display_name + '.xml.zip'
    package_uid=str(uuid.uuid4())
    content_dir=hashlib.md5((content_xml_name + raw_sha).encode('utf-8')).hexdigest()
    mapsource_entry=content_dir + '/' + content_xml_name
    fallback_imagery_entry='atak/imagery/' + content_xml_name
    fallback_mobile_entry='atak/imagery/mobile/mapsources/' + content_xml_name
    root_entry=content_xml_name
    root=ET.Element('MissionPackageManifest', {'version':'2'})
    cfg=ET.SubElement(root, 'Configuration')
    ET.SubElement(cfg, 'Parameter', {'name':'uid', 'value':package_uid})
    ET.SubElement(cfg, 'Parameter', {'name':'name', 'value':display_name})
    ET.SubElement(cfg, 'Parameter', {'name':'onReceiveImport', 'value':'true'})
    ET.SubElement(cfg, 'Parameter', {'name':'onReceiveDelete', 'value':'true'})
    contents=ET.SubElement(root, 'Contents')
    c=ET.SubElement(contents, 'Content', {'ignore':'false', 'zipEntry':mapsource_entry})
    ET.SubElement(c, 'Parameter', {'name':'name', 'value':content_xml_name})
    ET.SubElement(c, 'Parameter', {'name':'contentType', 'value':'External Native Data'})
    ET.SubElement(c, 'Parameter', {'name':'visible', 'value':'false'})
    manifest_text='<?xml version="1.0" encoding="UTF-8"?>\n' + ET.tostring(root, encoding='unicode', short_empty_elements=True)

    zip_id=_safe_offline_id('mapsource-mission-' + str(b.get('id') or '') + '-' + hashlib.sha256((manifest_text+xml_text+str(time.time())).encode()).hexdigest()[:8])
    zip_path=TAK_MAP_OFFLINE_PACKAGE_DIR/(zip_id + '.zip')
    with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:
        def write_stable(name, data):
            info=zipfile.ZipInfo(name)
            info.date_time=(2024,1,1,0,0,0)
            info.compress_type=zipfile.ZIP_DEFLATED
            zf.writestr(info, data)
        write_stable('MANIFEST/manifest.xml', manifest_text.encode('utf-8'))
        write_stable(mapsource_entry, xml_data)
        write_stable(fallback_imagery_entry, xml_data)
        write_stable(fallback_mobile_entry, xml_data)
        write_stable(root_entry, xml_data)
    zip_sha=hashlib.sha256(zip_path.read_bytes()).hexdigest()

    test_tile_url=f"{safe_origin.rstrip('/')}/api/tak-map/live-tile/{quote(str(b.get('id')), safe='')}/0/0/0.{('jpg' if 'imagery' in str(b.get('label','')).lower() else 'png')}"
    return {
        'ok':True,
        'delivery_kind':'mission-package-mapsource-external-native',
        'package_name':zip_name,
        'content_name':content_xml_name,
        'cot_name':content_xml_name,
        'path':str(zip_path),
        'sha256':zip_sha,
        'size_bytes':zip_path.stat().st_size,
        'basemap':b,
        'xml':xml_text,
        'manifest':manifest_text,
        'manifest_path':'MANIFEST/manifest.xml',
        'mapsource_path':mapsource_entry,
        'fallback_imagery_path':fallback_imagery_entry,
        'fallback_mobile_mapsource_path':fallback_mobile_entry,
        'root_mapsource_path':root_entry,
        'test_tile_url':test_tile_url,
        'mapsource_internal_name':label,
        'mapsource_file_name':content_xml_name,
        'raw_xml_path':str(raw_path),
        'raw_xml_sha256':raw_sha,
        'raw_xml_size_bytes':raw_path.stat().st_size,
    }



def _schedule_ots_native_package_cleanup(sha256_hash='', upload_filename='', delay_seconds=None, reason='live-basemap'):
    """Best-effort cleanup for temporary native OTS missionupload packages.

    There is no reliable dashboard-side signal that ATAK has fully imported a
    FileShare package on every OTS/ATAK combination.  v205 therefore supports a
    delayed cleanup instead of immediate deletion.  This keeps the metadata/tool
    URL alive long enough for the target EUD to fetch it, while preventing
    per-send temporary packages from accumulating forever.
    """
    try:
        if delay_seconds is None:
            raw=os.environ.get('TAK_DASH_OTS_TEMP_DP_CLEANUP_SECONDS','1800')
            delay_seconds=float(raw if raw not in (None,'') else 1800)
        delay_seconds=max(60.0, min(float(delay_seconds), 86400.0))
    except Exception:
        delay_seconds=1800.0
    sha=str(sha256_hash or '').strip()
    fn=str(upload_filename or '').strip()
    enabled=os.environ.get('TAK_DASH_DISABLE_OTS_TEMP_DP_CLEANUP','').strip().lower() not in ('1','true','yes','on')
    if not enabled or (not sha and not fn):
        return {'scheduled':False,'enabled':enabled,'sha256':sha,'upload_filename':fn,'reason':'disabled-or-empty'}

    def worker():
        try:
            time.sleep(delay_seconds)
            pg_uris, cfg_errors=_candidate_ots_pg_uris()
            out={'scheduled':True,'executed':True,'sha256':sha,'upload_filename':fn,'delay_seconds':delay_seconds,'reason':reason,'config_errors':cfg_errors}
            if not pg_uris:
                out['ok']=False; out['error']='No OpenTAKServer PostgreSQL URI found.'
                _write_send_diag('native-ots-cleanup', out, None); return
            cols, err=_pg_columns(pg_uris[0], 'public', 'data_packages')
            if err:
                out['ok']=False; out['error']=err
                _write_send_diag('native-ots-cleanup', out, None); return
            hash_col=_find_col(cols, ('hash','sha256','sha'))
            filename_col=_find_col(cols, ('filename','file_name','name'))
            clauses=[]
            if hash_col and sha:
                clauses.append(f"{_pg_ident(hash_col)}={_pg_sql_literal(sha)}")
            if filename_col and fn:
                clauses.append(f"{_pg_ident(filename_col)}={_pg_sql_literal(fn)}")
            if not clauses:
                out['ok']=False; out['error']='No hash/filename columns available for cleanup.'
                _write_send_diag('native-ots-cleanup', out, None); return
            sql='delete from public.data_packages where ' + ' or '.join(clauses)
            ok, err=_pg_exec(pg_uris[0], sql)
            out['ok']=bool(ok); out['error']=err or ''; out['sql_preview']=sql
            _write_send_diag('native-ots-cleanup', out, None)
        except Exception as e:
            try:
                _write_send_diag('native-ots-cleanup', {'ok':False,'error':str(e),'traceback':traceback.format_exc(),'sha256':sha,'upload_filename':fn,'delay_seconds':delay_seconds,'reason':reason}, None)
            except Exception:
                pass
    try:
        th=threading.Thread(target=worker, daemon=True)
        th.start()
        return {'scheduled':True,'enabled':True,'sha256':sha,'upload_filename':fn,'delay_seconds':delay_seconds,'reason':reason}
    except Exception as e:
        return {'scheduled':False,'enabled':enabled,'sha256':sha,'upload_filename':fn,'error':str(e)}

def tak_map_live_basemap_source_send(basemap_id, targets, dashboard_origin='', server_host=''):
    if not isinstance(targets, list):
        targets=[]
    clean=[]
    for t in targets[:50]:
        if not isinstance(t, dict): continue
        uid=str(t.get('uid') or t.get('id') or '').strip()[:160]
        callsign=str(t.get('callsign') or t.get('name') or uid or '').strip()[:160]
        lat=_coerce_float(t.get('lat')); lon=_coerce_float(t.get('lon'))
        if callsign:
            clean.append({'uid':uid,'callsign':callsign,'lat':lat,'lon':lon,'team':str(t.get('team') or t.get('group') or '').strip()[:80]})
    if not clean:
        return {'ok':False,'error':'Select at least one online EUD.'}
    pkg=tak_map_live_basemap_source_package(basemap_id, dashboard_origin, server_host)
    if not pkg.get('ok'):
        return pkg
    _sender=_preferred_fileshare_sender_identity('tak-dashboard','TAK-DASHBOARD')
    sender_callsign=str(_sender.get('callsign') or 'tak-dashboard').strip() or 'tak-dashboard'
    sender_uid=str(_sender.get('uid') or 'TAK-DASHBOARD').strip() or 'TAK-DASHBOARD'
    # v205 registers live-basemap Mission Packages in OTS for server-side inventory,
    # but uses the dashboard-hosted URL for the actual fileshare senderUrl. Field
    # testing showed OTS /api/data_packages/download?hash=... returned a non-ZIP
    # response to curl/ATAK on this install.
    native_creator_uid=(
        os.environ.get('TAK_DASH_FILESHARE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_NATIVE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_OTS_CREATOR_UID','').strip()
        or str((clean[0] or {}).get('uid') or '').strip()
        or sender_uid
    )
    reg=_ots_missionupload_and_register_tool(Path(pkg['path']), pkg['package_name'], pkg['sha256'], native_creator_uid, server_host or _default_server_host())
    _write_send_diag('native-ots-registration', {**reg, 'sha256':pkg.get('sha256'), 'package_name':pkg.get('package_name'), 'content_name':pkg.get('content_name'), 'sender_callsign':sender_callsign, 'sender_uid':sender_uid, 'native_creator_uid_candidate':native_creator_uid, 'send_kind':'live-basemap'}, None)
    if reg.get('ok'):
        pkg['preferred_sender_url']=str(reg.get('sender_url') or '')
        pkg['registered_ots_data_package']=True
        # v205: for native OTS metadata/tool delivery, advertise the same
        # filename that OTS stored during missionupload. Successful ATAK sends
        # keep the CoT fileshare filename aligned with the server-side package
        # record. The actual mapsource inside the ZIP remains ESRI Street.xml.
        if reg.get('upload_filename'):
            pkg['native_upload_filename']=str(reg.get('upload_filename') or '')
            pkg['fileshare_filename']=str(reg.get('upload_filename') or '')
        pkg['native_cleanup_hash']=str(pkg.get('sha256') or '')
        pkg['native_cleanup_filename']=str(reg.get('upload_filename') or '')
    else:
        # Keep server-side registration for inventory if native metadata/tool setup fails.
        fallback_reg={'ok':True,'skipped':True,'reason':'Registration disabled by TAK_DASH_DISABLE_LIVE_BASEMAP_OTS_REGISTER.'}
        if os.environ.get('TAK_DASH_DISABLE_LIVE_BASEMAP_OTS_REGISTER','').strip().lower() not in ('1','true','yes','on'):
            fallback_reg=_register_ots_data_package(Path(pkg['path']), pkg['package_name'], pkg['sha256'], pkg['size_bytes'], sender_uid)
            if fallback_reg.get('ok'):
                pkg['registered_ots_data_package']=True
                pkg['ots_registered_path']=fallback_reg.get('path','')
            else:
                pkg['registered_ots_data_package']=False
                pkg['ots_register_error']=str(fallback_reg.get('error') or '')
        reg['fallback_register']=fallback_reg
    send_id=str(uuid.uuid4())
    results=[]; any_ok=False
    # v201: for live Send Map, use the dashboard-hosted package URL by default
    # while testing the DataPackage basemap CoT schema.  This separates the
    # notification/schema question from OTS client-cert metadata/tool downloads.
    url_variants=_fileshare_sender_url_variants(pkg, server_host or _default_server_host())
    live_url_mode=os.environ.get('TAK_DASH_LIVE_BASEMAP_URL_MODE','dashboard-package').strip().lower() or 'dashboard-package'
    if live_url_mode in ('dashboard','dashboard-package','9443','fallback'):
        try:
            host=_url_host(server_host or _default_server_host())
            sha=str(pkg.get('sha256') or '').strip()
            fn=quote(str(pkg.get('package_name') or 'TAK Map Source.zip'), safe='')
            dash_origin=_dashboard_https_origin('', host)
            url_variants=[{'label':'dashboard-package-v201','url':f'{dash_origin}/api/tak-map/fileshare-package/{sha}/{fn}'}]
            pkg['live_basemap_url_mode']='dashboard-package'
            pkg['live_basemap_dashboard_sender_url']=url_variants[0]['url']
        except Exception as e:
            pkg['live_basemap_url_mode_error']=str(e)
    # v205: live basemap sends are targeted-only by default. Earlier builds sent
    # both a broadcast CoT and a targeted CoT; on this OTS/ATAK path the broadcast
    # copy can cause the server/client to process the native metadata URL without
    # receiver context. Re-enable only if explicitly requested.
    broadcast_fallback=(
        os.environ.get('TAK_DASH_ENABLE_LIVE_BASEMAP_BROADCAST','').strip().lower() in ('1','true','yes','on')
        and _fileshare_broadcast_enabled()
    )
    for t in clean:
        for uv in url_variants:
            delivery_variants=[]
            enable_full_fallback=os.environ.get('TAK_DASH_ENABLE_FULL_FILESHARE_COT_FALLBACK','').strip().lower() in ('1','true','yes','on')
            # v205 sends only TAK-native minimal FileShare CoT by default. This
            # matches common TAK FileShare builders: detail/fileshare +
            # ackrequest tag="transfer". Full dashboard metadata fallback is
            # opt-in only to avoid noisy/ambiguous diagnostics and reduce CPU.
            if broadcast_fallback:
                delivery_variants.extend([
                    ('native-minimal-broadcast', True, 'minimal'),
                    ('native-minimal-targeted', False, 'minimal'),
                ])
                if enable_full_fallback:
                    delivery_variants.extend([
                        ('full-broadcast', True, 'full'),
                        ('full-targeted', False, 'full'),
                    ])
            else:
                # v205: the takdash TLS socket path was proven to insert a normal
                # marker CoT into public.cot, while the b-m-r DataPackage shape was
                # not parsed/routed.  Return the live Send Map notification to the
                # TAK-native FileShare builder shape used by common TAK CoT tooling:
                # type=b-f-t-r, how=h-e, detail/fileshare, ackrequest tag=transfer.
                # Use the dashboard-hosted 9443 URL and broadcast by default so OTS
                # does not need to interpret a marti/dest routing wrapper around the
                # fileshare event.
                delivery_variants.extend([
                    ('route-control-marker-broadcast-v216', True, 'route-control-marker'),
                    ('marker-fileshare-broadcast-v216', True, 'marker-fileshare'),
                    ('native-minimal-broadcast-v216', True, 'minimal'),
                ])
                if os.environ.get('TAK_DASH_ENABLE_LIVE_BASEMAP_TARGETED_COPY','').strip().lower() in ('1','true','yes','on'):
                    delivery_variants.extend([
                        ('native-minimal-targeted-v216', False, 'minimal'),
                    ])
                if os.environ.get('TAK_DASH_ENABLE_BASEMAP_DATAPACKAGE_COMPARISON','').strip().lower() in ('1','true','yes','on'):
                    delivery_variants.extend([
                        ('datapackage-basemap-targeted-comparison', False, 'datapackage-basemap'),
                    ])
                if os.environ.get('TAK_DASH_ENABLE_LEGACY_FILESHARE_COT_COMPARISON','').strip().lower() in ('1','true','yes','on'):
                    if os.environ.get('TAK_DASH_DISABLE_LIVE_BASEMAP_FULL_TARGETED','').strip().lower() not in ('1','true','yes','on'):
                        delivery_variants.extend([
                            ('full-targeted-comparison', False, 'full'),
                        ])
                    elif enable_full_fallback:
                        delivery_variants.extend([
                            ('full-targeted-comparison', False, 'full'),
                        ])
            for delivery_label, is_broadcast, cot_shape in delivery_variants:
                variant_label=delivery_label+'-'+str(uv.get('label') or 'url')
                if cot_shape == 'datapackage-basemap':
                    xml,meta=_build_basemap_datapackage_cot(t['callsign'], pkg, sender_callsign, sender_uid, server_host or _default_server_host(), t.get('lat') or 0.0, t.get('lon') or 0.0, t.get('uid') or '', t.get('team') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                elif cot_shape == 'route-control-marker':
                    xml,meta=_build_route_control_marker_cot(t['callsign'], pkg, sender_callsign, sender_uid, server_host or _default_server_host(), t.get('lat') or 0.0, t.get('lon') or 0.0, t.get('uid') or '', t.get('team') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                elif cot_shape == 'marker-fileshare':
                    xml,meta=_build_fileshare_marker_cot(t['callsign'], pkg, sender_callsign, sender_uid, server_host or _default_server_host(), t.get('lat') or 0.0, t.get('lon') or 0.0, t.get('uid') or '', t.get('team') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                elif cot_shape == 'minimal':
                    xml,meta=_build_fileshare_cot_minimal(t['callsign'], pkg, sender_callsign, sender_uid, server_host or _default_server_host(), t.get('lat') or 0.0, t.get('lon') or 0.0, t.get('uid') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                else:
                    xml,meta=_build_fileshare_cot(t['callsign'], pkg, sender_callsign, sender_uid, server_host or _default_server_host(), t.get('lat') or 0.0, t.get('lon') or 0.0, t.get('uid') or '', t.get('team') or '', sender_url_override=uv.get('url') or '', broadcast=is_broadcast, variant=variant_label)
                download_check={}
                try:
                    if not is_broadcast and '/Marti/api/sync/metadata/' in str(meta.get('sender_url') or ''):
                        download_check=_ots_metadata_tool_download_check(meta.get('sender_url') or '', t.get('callsign') or '', t.get('uid') or '')
                except Exception as e:
                    download_check={'ok':False,'error':str(e)}
                sent=_send_cot_to_ots(xml)
                # v198: RabbitMQ-direct EUD/team queue publishing was removed entirely.
                # It disconnected the target EUD on this OTS deployment and is not
                # left behind as a lab flag or hidden option.
                db_postcheck={}
                try:
                    # v197: even in low-power mode, do one short targeted postcheck
                    # for live-basemap CoT routing so we know whether OTS parsed it
                    # into public.cot. This is diagnostic only; send success still
                    # follows socket/RabbitMQ acceptance unless strict DB is set.
                    db_postcheck=_wait_for_cot_db(meta.get('event_uid') or '', meta.get('ack_uid') or '', pkg.get('sha256') or '', timeout=int(os.environ.get('TAK_DASH_LIVE_BASEMAP_COT_POSTCHECK_SECONDS','5') or '5'), interval=1.0)
                except Exception as e:
                    db_postcheck={'ok':False,'error':str(e),'rows':[]}
                effective_sent_ok=bool(sent.get('ok'))
                post_paths=_write_send_diag('fileshare-cot-live-basemap-postcheck', {'target':t, 'meta':meta, 'download_check':download_check, 'db_postcheck':db_postcheck, 'sent_ok':sent.get('ok'), 'effective_sent_ok':effective_sent_ok, 'send_error':sent.get('error',''), 'sha256':pkg.get('sha256')}, xml)
                diag_paths={**(sent.get('diag_paths',{}) or {})}
                if isinstance(post_paths, dict) and post_paths.get('json'):
                    diag_paths['postcheck_json']=post_paths.get('json')
                row={**t, **meta, 'status':'sent' if effective_sent_ok else 'failed', 'send_error':sent.get('error',''), 'cot_host':sent.get('host',''), 'cot_port':sent.get('port',''), 'cot_xml_preview':xml[:1200], 'cot_attempts':sent.get('attempts',[]), 'verified_in_cot_db':bool(sent.get('verified_in_cot_db',False) or db_postcheck.get('ok')), 'accepted_unverified':sent.get('accepted_unverified',False), 'send_warning':sent.get('warning',''), 'diag_paths':diag_paths, 'db_lookup':sent.get('db_lookup') or sent.get('db_after_send') or {}, 'db_postcheck':db_postcheck, 'download_check':download_check}
                results.append(row); any_ok=any_ok or effective_sent_ok
    cleanup={'scheduled':False,'reason':'not scheduled by default in v197; temporary native OTS DPs are retained until delivery is confirmed or TAK_DASH_ENABLE_UNCONFIRMED_TEMP_DP_CLEANUP=1 is set'}
    if any_ok and reg.get('ok') and pkg.get('native_cleanup_hash') and os.environ.get('TAK_DASH_ENABLE_UNCONFIRMED_TEMP_DP_CLEANUP','').strip().lower() in ('1','true','yes','on'):
        cleanup=_schedule_ots_native_package_cleanup(pkg.get('native_cleanup_hash'), pkg.get('native_cleanup_filename'), reason='live-basemap-send-unconfirmed-explicitly-enabled')
    fail_msg='Map source uploaded to OTS Data Packages, but no verified b-f-t-r fileshare CoT reached the OTS cot table. See send diagnostics.'
    ok_msg=('Live basemap sent using DataPackage basemap CoT and dashboard-hosted package URL; check ATAK for download/import.' if reg.get('ok') else 'Native OTS metadata/tool registration failed; Live basemap FileShare CoT sent using dashboard fallback URL. See native-ots-registration diagnostics.')
    return {'ok':any_ok,'status':'sent' if any_ok else 'failed','message':(ok_msg if any_ok else fail_msg),'error':('' if any_ok else fail_msg),'send_id':send_id,'targets':results,'package':{k:v for k,v in pkg.items() if k!='xml'},'register':reg,'cleanup':cleanup}

def _mbtiles_tile_bytes(map_id, z, x, y):
    mid=str(map_id or '').strip()
    target=None
    for m in _load_offline_maps():
        if str(m.get('id'))==mid:
            target=m; break
    if not target:
        return None, 'application/octet-stream'
    fp=Path(str(target.get('path') or ''))
    if not fp.exists():
        return None, 'application/octet-stream'
    import sqlite3
    z=int(z); x=int(x); y=int(y)
    tms_y=(2**z - 1) - y
    uri='file:' + quote(str(fp.resolve()), safe='/') + '?mode=ro'
    conn=sqlite3.connect(uri, uri=True)
    try:
        cur=conn.cursor()
        cur.execute('select tile_data from tiles where zoom_level=? and tile_column=? and tile_row=? limit 1',(z,x,tms_y))
        row=cur.fetchone()
        if not row:
            # Some MBTiles files are stored XYZ-style despite the spec.
            cur.execute('select tile_data from tiles where zoom_level=? and tile_column=? and tile_row=? limit 1',(z,x,y))
            row=cur.fetchone()
        if not row:
            return None, 'application/octet-stream'
        data=row[0]
        if isinstance(data, memoryview): data=data.tobytes()
        if data[:8].startswith(b'\x89PNG'): ctype='image/png'
        elif data[:3]==b'\xff\xd8\xff': ctype='image/jpeg'
        elif data[:4]==b'RIFF' and b'WEBP' in data[:16]: ctype='image/webp'
        else:
            fmt=str(target.get('format') or '').lower()
            ctype='image/jpeg' if fmt in ('jpg','jpeg') else ('image/png' if fmt=='png' else 'application/octet-stream')
        return data, ctype
    finally:
        conn.close()

def _offline_package_path(package_id):
    pid=_safe_offline_id(package_id)
    fp=TAK_MAP_OFFLINE_PACKAGE_DIR/(pid + '.zip')
    if fp.exists() and fp.is_file():
        return fp
    return None


def _offline_download_sources():
    out=[]
    for b in TAK_MAP_BASEMAPS:
        url=str(b.get('url') or '')
        if url.startswith(('http://','https://')) and all(t in url for t in ('{z}','{x}','{y}')):
            out.append({
                'id':b.get('id'),
                'label':b.get('label'),
                'group':b.get('group') or 'Basemaps',
                'url':url,
                'attribution':b.get('attribution') or '',
                'minZoom':b.get('minZoom') or 0,
                'maxZoom':b.get('maxZoom') or 19,
            })
    return out

def _offline_source_by_id(source_id):
    sid=str(source_id or '').strip()
    for b in _offline_download_sources():
        if str(b.get('id'))==sid:
            return b
    return None

def _clip_lat(lat):
    try: lat=float(lat)
    except Exception: lat=0.0
    return max(-85.05112878, min(85.05112878, lat))

def _clip_lon(lon):
    try: lon=float(lon)
    except Exception: lon=0.0
    return max(-180.0, min(180.0, lon))

def _lonlat_to_xyz(lon, lat, z):
    lat=_clip_lat(lat); lon=_clip_lon(lon); z=int(z)
    n=2**z
    x=int((lon + 180.0) / 360.0 * n)
    lat_rad=math.radians(lat)
    y=int((1.0 - math.log(math.tan(lat_rad) + (1.0 / math.cos(lat_rad))) / math.pi) / 2.0 * n)
    return max(0,min(n-1,x)), max(0,min(n-1,y))

def _normalize_bounds(bounds):
    if isinstance(bounds, dict):
        west=_clip_lon(bounds.get('west') if bounds.get('west') is not None else bounds.get('minLon'))
        east=_clip_lon(bounds.get('east') if bounds.get('east') is not None else bounds.get('maxLon'))
        south=_clip_lat(bounds.get('south') if bounds.get('south') is not None else bounds.get('minLat'))
        north=_clip_lat(bounds.get('north') if bounds.get('north') is not None else bounds.get('maxLat'))
    elif isinstance(bounds, (list, tuple)) and len(bounds)>=4:
        west=_clip_lon(bounds[0]); south=_clip_lat(bounds[1]); east=_clip_lon(bounds[2]); north=_clip_lat(bounds[3])
    else:
        raise ValueError('Invalid bounds. Expected west/south/east/north.')
    if east < west: west,east=east,west
    if north < south: south,north=north,south
    if abs(east-west) < 0.00001 or abs(north-south) < 0.00001:
        raise ValueError('Selected area is too small.')
    return {'west':west,'south':south,'east':east,'north':north}

def _tile_ranges_for_bounds(bounds, min_zoom, max_zoom):
    b=_normalize_bounds(bounds)
    minz=max(0,int(min_zoom)); maxz=max(minz,min(19,int(max_zoom)))
    ranges=[]; total=0
    for z in range(minz,maxz+1):
        x1,y1=_lonlat_to_xyz(b['west'], b['north'], z)
        x2,y2=_lonlat_to_xyz(b['east'], b['south'], z)
        xmin,xmax=min(x1,x2),max(x1,x2)
        ymin,ymax=min(y1,y2),max(y1,y2)
        count=(xmax-xmin+1)*(ymax-ymin+1)
        ranges.append({'z':z,'xmin':xmin,'xmax':xmax,'ymin':ymin,'ymax':ymax,'count':count})
        total += count
    return b, ranges, total

def _tile_url(template, z, x, y):
    # Dashboard Leaflet layers use {z}/{x}/{y}; ATAK/MOBAC map-source XMLs
    # use {$z}/{$x}/{$y}. Support both so one provider list can feed both paths.
    return (str(template)
        .replace('{$z}',str(z)).replace('{$x}',str(x)).replace('{$y}',str(y)).replace('{$s}','a')
        .replace('{z}',str(z)).replace('{x}',str(x)).replace('{y}',str(y)).replace('{s}','a'))


def _atak_mapsource_url(template):
    # ATAK map source XMLs are MOBAC-style customMapSource files. ATAK-Maps
    # examples use {$z}/{$y}/{$x}; using bare {z}/{y}/{x} can import but render
    # misplaced/incorrect tiles on ATAK builds that expect MOBAC placeholders.
    u=str(template or '').strip()
    u=(u.replace('{z}','{$z}').replace('{x}','{$x}').replace('{y}','{$y}').replace('{s}','{$s}'))
    # Avoid double-converting already-MOBAC templates.
    u=u.replace('${$z}', '$z').replace('${$x}', '$x').replace('${$y}', '$y').replace('${$s}', '$s')
    return u

def _detect_tile_format(data, fallback='png'):
    if not data:
        return fallback or 'png'
    if data[:8].startswith(b'\x89PNG'): return 'png'
    if data[:3]==b'\xff\xd8\xff': return 'jpg'
    if data[:4]==b'RIFF' and b'WEBP' in data[:16]: return 'webp'
    if data[:2]==b'\x1f\x8b': return 'pbf'
    return fallback or 'png'

def tak_map_offline_download_estimate(payload):
    try:
        source=_offline_source_by_id(payload.get('source_id'))
        if not source:
            return {'ok':False,'error':'Unknown or unsupported offline map source.'}
        b,ranges,total=_tile_ranges_for_bounds(payload.get('bounds') or {}, payload.get('min_zoom',8), payload.get('max_zoom',12))
        avg=32000 if 'imagery' in str(source.get('label','')).lower() else 18000
        return {'ok':True,'source':source,'bounds':b,'ranges':ranges,'tile_count':total,'max_tiles':TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES,'estimated_bytes':total*avg,'allowed':total<=TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES}
    except Exception as e:
        return {'ok':False,'error':str(e)}


def _parse_offline_bounds(bounds):
    if isinstance(bounds, dict):
        return _normalize_bounds(bounds)
    txt=str(bounds or '').strip()
    parts=[_coerce_float(x) for x in re.split(r'\s*,\s*', txt) if str(x).strip()]
    if len(parts)>=4 and all(x is not None for x in parts[:4]):
        return _normalize_bounds({'west':parts[0],'south':parts[1],'east':parts[2],'north':parts[3]})
    raise ValueError('Offline map bounds are missing or invalid.')

def _mbtiles_tile_exists(cur, z, x, y):
    n=2**int(z)
    tms_y=(n-1)-int(y)
    cur.execute('select 1 from tiles where zoom_level=? and tile_column=? and tile_row=? limit 1',(int(z),int(x),tms_y))
    if cur.fetchone():
        return True
    # tolerate XYZ row storage too
    cur.execute('select 1 from tiles where zoom_level=? and tile_column=? and tile_row=? limit 1',(int(z),int(x),int(y)))
    return bool(cur.fetchone())

def _mbtiles_tile_count(path):
    try:
        import sqlite3
        conn=sqlite3.connect(str(path))
        try:
            cur=conn.cursor()
            cur.execute('select count(*) from tiles')
            return int(cur.fetchone()[0] or 0)
        finally:
            conn.close()
    except Exception:
        return 0

def _upsert_offline_map_record(rec):
    maps=_load_offline_maps()
    out=[]; found=False
    for m in maps:
        if str(m.get('id'))==str(rec.get('id')):
            merged=dict(m); merged.update(rec); out.append(merged); found=True
        else:
            out.append(m)
    if not found:
        out.append(rec)
    _save_offline_maps(out)
    return _load_offline_maps()

def _offline_map_record(map_id):
    mid=str(map_id or '').strip()
    for m in _load_offline_maps():
        if str(m.get('id'))==mid:
            return m
    return None

def _offline_record_from_job(job, mid, final_path, status, done, saved, failed, first_format='png'):
    b=job.get('bounds') or {}
    source=job.get('source') or {}
    total=int(job.get('tile_count') or 0)
    size=Path(final_path).stat().st_size if Path(final_path).exists() else 0
    return {
        'id':mid,
        'name':job.get('name') or source.get('label') or 'Offline map',
        'filename':Path(final_path).name,
        'path':str(final_path),
        'uploaded':datetime.now(timezone.utc).isoformat(),
        'created_by':'download',
        'download_status':status,
        'partial':status in ('partial','paused','canceled'),
        'source_id':source.get('id'),
        'source_label':source.get('label'),
        'size_bytes':size,
        'tile_count':int(saved or 0),
        'requested_tile_count':total,
        'remaining_tile_count':max(0, total-int(done or 0)),
        'failed_tile_count':int(failed or 0),
        'min_zoom':job.get('min_zoom'),
        'max_zoom':job.get('max_zoom'),
        'format':first_format or 'png',
        'bounds':f"{b.get('west')},{b.get('south')},{b.get('east')},{b.get('north')}",
        'center':f"{(float(b.get('west'))+float(b.get('east')))/2},{(float(b.get('south'))+float(b.get('north')))/2},{job.get('min_zoom')}",
        'attribution':source.get('attribution') or '',
        'eud_package_url':'',
        'resume_available':status in ('partial','paused','canceled'),
        'updated':datetime.now(timezone.utc).isoformat(),
    }

def tak_map_offline_download_start(payload):
    est=tak_map_offline_download_estimate(payload)
    if not est.get('ok'):
        return est
    if not est.get('allowed'):
        return {'ok':False,'error':f"Selected pack has {est.get('tile_count')} tiles, above current limit of {TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES}. Reduce area or zoom range."}
    source=est['source']
    name=str(payload.get('name') or '').strip()[:120] or (str(source.get('label') or 'Offline Map') + ' offline')
    job_id=secrets.token_hex(8)
    job={'id':job_id,'ok':True,'status':'queued','name':name,'source':source,'bounds':est['bounds'],'min_zoom':min(r['z'] for r in est['ranges']),'max_zoom':max(r['z'] for r in est['ranges']),'tile_count':est['tile_count'],'done':0,'saved':0,'failed':0,'message':'Queued offline map download','created':datetime.now(timezone.utc).isoformat(),'map_id':'','request':''}
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        TAK_MAP_OFFLINE_DOWNLOAD_JOBS[job_id]=job
    th=threading.Thread(target=_offline_download_worker,args=(job_id,job,est['ranges'],None),daemon=True)
    th.start()
    return {'ok':True,'job':job}

def _update_offline_job(job_id, **kw):
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        j=TAK_MAP_OFFLINE_DOWNLOAD_JOBS.get(job_id)
        if j:
            j.update(kw)
            j['updated']=datetime.now(timezone.utc).isoformat()
            return dict(j)
    return None

def _get_offline_job(job_id):
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        j=TAK_MAP_OFFLINE_DOWNLOAD_JOBS.get(str(job_id))
        return dict(j) if j else None

def tak_map_offline_job_status(job_id=''):
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        if job_id:
            j=TAK_MAP_OFFLINE_DOWNLOAD_JOBS.get(str(job_id))
            return {'ok':bool(j),'job':j or {},'error':'' if j else 'Offline map download job not found.'}
        jobs=list(TAK_MAP_OFFLINE_DOWNLOAD_JOBS.values())[-20:]
        return {'ok':True,'jobs':jobs}

def tak_map_offline_job_control(job_id, action):
    jid=str(job_id or '').strip()
    act=str(action or '').strip().lower()
    if act not in ('pause','cancel'):
        return {'ok':False,'error':'Invalid offline download control action.'}
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        job=TAK_MAP_OFFLINE_DOWNLOAD_JOBS.get(jid)
        if not job:
            return {'ok':False,'error':'Offline map download job not found.'}
        if job.get('status') in ('done','paused','canceled','error'):
            return {'ok':True,'job':job,'message':'Job is already finished.'}
        job['request']=act
        job['message']='Pause requested; saving downloaded tiles...' if act=='pause' else 'Cancel requested; saving downloaded tiles as partial pack...'
        job['updated']=datetime.now(timezone.utc).isoformat()
        return {'ok':True,'job':job}

def tak_map_offline_resume(map_id):
    rec=_offline_map_record(map_id)
    if not rec:
        return {'ok':False,'error':'Offline map pack not found.'}
    if not rec.get('resume_available') and not rec.get('partial'):
        return {'ok':False,'error':'This offline map pack is not marked partial/resumable.'}
    source=_offline_source_by_id(rec.get('source_id'))
    if not source:
        return {'ok':False,'error':'Original source basemap is not available for resume.'}
    fp=Path(str(rec.get('path') or ''))
    if not fp.exists():
        return {'ok':False,'error':'Partial MBTiles file is missing on server.'}
    try:
        b,ranges,total=_tile_ranges_for_bounds(_parse_offline_bounds(rec.get('bounds')), rec.get('min_zoom',8), rec.get('max_zoom',12))
    except Exception as e:
        return {'ok':False,'error':'Cannot resume: '+str(e)}
    if total > TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES:
        return {'ok':False,'error':f"Resume range has {total} tiles, above current limit of {TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES}."}
    job_id=secrets.token_hex(8)
    existing=_mbtiles_tile_count(fp)
    job={'id':job_id,'ok':True,'status':'queued','name':rec.get('name') or 'Offline map resume','source':source,'bounds':b,'min_zoom':min(r['z'] for r in ranges),'max_zoom':max(r['z'] for r in ranges),'tile_count':total,'done':0,'saved':existing,'failed':int(rec.get('failed_tile_count') or 0),'message':'Queued resume; existing tiles will be skipped','created':datetime.now(timezone.utc).isoformat(),'map_id':rec.get('id'),'request':'','resume_path':str(fp)}
    with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
        TAK_MAP_OFFLINE_DOWNLOAD_JOBS[job_id]=job
    th=threading.Thread(target=_offline_download_worker,args=(job_id,job,ranges,rec),daemon=True)
    th.start()
    return {'ok':True,'job':job}

def _offline_download_worker(job_id, job, ranges, resume_rec=None):
    source=job.get('source') or {}
    b=job.get('bounds') or {}
    template=source.get('url') or ''
    resume_mode=bool(resume_rec)
    mid=str((resume_rec or {}).get('id') or _safe_offline_id(job.get('name','offline') + '-' + job_id[:6]))
    tmp=None; final=None; conn=None
    first_format=str((resume_rec or {}).get('format') or 'png')
    done=0; saved=int(job.get('saved') or 0); failed=int(job.get('failed') or 0); total=int(job.get('tile_count') or 0)
    concurrency=max(1, min(12, int(TAK_MAP_OFFLINE_DOWNLOAD_CONCURRENCY or 4)))
    try:
        TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
        if resume_mode:
            final=Path(str(resume_rec.get('path')))
            tmp=final
        else:
            tmp=TAK_MAP_OFFLINE_DIR/(mid + '.partial.mbtiles')
            final=TAK_MAP_OFFLINE_DIR/(mid + '.mbtiles')
        _update_offline_job(job_id,status='running',message='Downloading tiles',map_id=mid,concurrency=concurrency)
        import sqlite3
        conn=sqlite3.connect(str(tmp))
        cur=conn.cursor()
        cur.execute('create table if not exists metadata (name text, value text)')
        cur.execute('create table if not exists tiles (zoom_level integer, tile_column integer, tile_row integer, tile_data blob)')
        cur.execute('create unique index if not exists tile_index on tiles (zoom_level, tile_column, tile_row)')
        meta={
            'name':job.get('name') or 'Offline map',
            'type':'baselayer',
            'version':'1',
            'description':'Downloaded by TAK Server Dashboard Offline Maps',
            'format':first_format or 'png',
            'bounds':f"{b.get('west')},{b.get('south')},{b.get('east')},{b.get('north')}",
            'center':f"{(float(b.get('west'))+float(b.get('east')))/2},{(float(b.get('south'))+float(b.get('north')))/2},{job.get('min_zoom')}",
            'minzoom':str(job.get('min_zoom')),
            'maxzoom':str(job.get('max_zoom')),
            'attribution':source.get('attribution') or '',
        }
        for k,v in meta.items():
            cur.execute('delete from metadata where lower(name)=lower(?)',(k,))
            cur.execute('insert into metadata(name,value) values(?,?)',(k,str(v)))
        conn.commit()

        def requested_action():
            with TAK_MAP_OFFLINE_DOWNLOAD_LOCK:
                return (TAK_MAP_OFFLINE_DOWNLOAD_JOBS.get(job_id) or {}).get('request','')

        def finalize(status, msg):
            nonlocal conn, tmp, final, done, saved, failed, first_format
            try:
                if conn:
                    conn.commit(); conn.close(); conn=None
            except Exception:
                pass
            if not resume_mode:
                if final.exists(): final.unlink()
                if tmp.exists(): tmp.rename(final)
            saved_actual=_mbtiles_tile_count(final)
            rec=_offline_record_from_job(job, mid, final, status, done, saved_actual, failed, first_format or 'png')
            if status=='complete':
                rec['download_status']='complete'; rec['partial']=False; rec['resume_available']=False; rec['remaining_tile_count']=max(0,total-saved_actual)
            elif status in ('paused','canceled'):
                rec['download_status']=status; rec['partial']=True; rec['resume_available']=True; rec['remaining_tile_count']=max(0,total-saved_actual)
            rec['download_concurrency']=concurrency
            _upsert_offline_map_record(rec)
            try:
                tak_map_offline_eud_package(mid)
            except Exception as _pkg_err:
                pass
            _update_offline_job(job_id,status=('done' if status=='complete' else status),done=done,saved=saved_actual,failed=failed,map_id=mid,message=msg,maps=_load_offline_maps(),concurrency=concurrency)

        def fetch_tile(task):
            z,x,y,n=task
            url=_tile_url(template,z,x,y)
            try:
                req=Request(url, headers={'User-Agent':'tak-server-dash-offline-map/1.46'})
                with urlopen(req, timeout=12) as resp:
                    data=resp.read(2*1024*1024)
                return {'ok':bool(data),'z':z,'x':x,'y':y,'n':n,'data':data or b'','error':''}
            except Exception as e:
                return {'ok':False,'z':z,'x':x,'y':y,'n':n,'data':b'','error':str(e)[:120]}

        def process_batch(batch):
            nonlocal done, saved, failed, first_format, conn, cur
            if not batch:
                return True
            with ThreadPoolExecutor(max_workers=concurrency) as pool:
                futures=[pool.submit(fetch_tile, task) for task in batch]
                for fut in as_completed(futures):
                    action=requested_action()
                    if action in ('pause','cancel'):
                        # Let already-started tile requests finish, but do not queue more batches.
                        pass
                    res=fut.result()
                    done+=1
                    if res.get('ok') and res.get('data'):
                        data=res.get('data') or b''
                        fmt=_detect_tile_format(data, first_format or 'png')
                        if not first_format:
                            first_format=fmt
                        if fmt and fmt != first_format and first_format in ('unknown','png'):
                            first_format=fmt
                        if fmt:
                            cur.execute('update metadata set value=? where lower(name)=lower(?)',(fmt,'format'))
                        z=int(res['z']); x=int(res['x']); y=int(res['y']); n=int(res['n'])
                        tms_y=(n-1)-y
                        cur.execute('insert or replace into tiles(zoom_level,tile_column,tile_row,tile_data) values(?,?,?,?)',(z,x,tms_y,data))
                        saved+=1
                    else:
                        failed+=1
                    if done % max(25, concurrency*10) == 0:
                        conn.commit()
                        _update_offline_job(job_id,done=done,saved=saved,failed=failed,message=f'Downloaded/checked {done} of {total} tiles',concurrency=concurrency)
                conn.commit()
            action=requested_action()
            if action in ('pause','cancel'):
                finalize('paused' if action=='pause' else 'canceled', ('Paused' if action=='pause' else 'Canceled') + f'. Saved {_mbtiles_tile_count(tmp)} tiles as a partial offline map pack.')
                return False
            return True

        batch=[]
        batch_limit=max(16, concurrency*10)
        for rr in ranges:
            z=int(rr['z']); n=2**z
            for x in range(int(rr['xmin']), int(rr['xmax'])+1):
                for y in range(int(rr['ymin']), int(rr['ymax'])+1):
                    action=requested_action()
                    if action in ('pause','cancel'):
                        finalize('paused' if action=='pause' else 'canceled', ('Paused' if action=='pause' else 'Canceled') + f'. Saved {_mbtiles_tile_count(tmp)} tiles as a partial offline map pack.')
                        return
                    try:
                        if _mbtiles_tile_exists(cur,z,x,y):
                            done+=1
                            if done % max(50, concurrency*20) == 0:
                                _update_offline_job(job_id,done=done,saved=saved,failed=failed,message=f'Checked {done} of {total} tiles; existing tiles skipped',concurrency=concurrency)
                            continue
                    except Exception:
                        pass
                    batch.append((z,x,y,n))
                    if len(batch) >= batch_limit:
                        if not process_batch(batch):
                            return
                        batch=[]
        if batch:
            if not process_batch(batch):
                return
        finalize('complete', f'Completed. Saved {_mbtiles_tile_count(final if resume_mode else tmp)} tiles; {failed} failed.')
    except Exception as e:
        try:
            if conn:
                conn.commit(); conn.close()
        except Exception:
            pass
        # Keep partial data whenever possible instead of deleting it.
        try:
            if tmp and tmp.exists():
                if final is None:
                    final=TAK_MAP_OFFLINE_DIR/(mid + '.mbtiles')
                if not resume_mode and tmp != final:
                    if final.exists(): final.unlink()
                    tmp.rename(final)
                rec=_offline_record_from_job(job, mid, final, 'partial', done, _mbtiles_tile_count(final), failed, first_format or 'png')
                rec['download_status']='partial'; rec['partial']=True; rec['resume_available']=True; rec['download_concurrency']=concurrency
                _upsert_offline_map_record(rec)
                try:
                    tak_map_offline_eud_package(mid)
                except Exception:
                    pass
        except Exception:
            pass
        _update_offline_job(job_id,status='error',message=str(e),error=str(e),map_id=mid,concurrency=concurrency)



def _load_popup_edits():
    try:
        if TAK_MAP_POPUP_EDITS_FILE.exists():
            data=json.loads(TAK_MAP_POPUP_EDITS_FILE.read_text())
            if isinstance(data, dict):
                return data
    except Exception:
        pass
    return {}

def _save_popup_edits(data):
    TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
    if not isinstance(data, dict):
        data={}
    data['updated']=datetime.now(timezone.utc).isoformat()
    tmp=TAK_MAP_POPUP_EDITS_FILE.with_suffix('.tmp')
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True))
    tmp.replace(TAK_MAP_POPUP_EDITS_FILE)
    return data

def _popup_edit_key_candidates(obj):
    obj=obj or {}
    out=[]
    src=str(obj.get('source') or obj.get('source_table') or obj.get('kind') or 'object').strip()
    vals=[]
    for k in ('uid','id','callsign','name','filename','title'):
        v=str(obj.get(k) or '').strip()
        if v and v not in vals:
            vals.append(v)
    for v in vals:
        if src:
            out.append(src + ':' + v)
        out.append(v)
    try:
        lat=float(obj.get('lat')); lon=float(obj.get('lon'))
        coord='coord:' + f'{lat:.6f},{lon:.6f}'
        if src: out.append(src + ':' + coord)
        out.append(coord)
    except Exception:
        pass
    seen=set(); clean=[]
    for k in out:
        k=str(k or '').strip()
        if k and k not in seen:
            seen.add(k); clean.append(k)
    return clean

def _apply_popup_edit(obj, edits=None):
    if not isinstance(obj, dict):
        return obj
    edits=edits if isinstance(edits, dict) else _load_popup_edits()
    items=edits.get('items') if isinstance(edits.get('items'), dict) else {}
    edit=None; key_used=''
    for key in _popup_edit_key_candidates(obj):
        if key in items and isinstance(items.get(key), dict):
            edit=items[key]; key_used=key; break
    if not edit:
        return obj
    if bool(edit.get('deleted')) or str(edit.get('deleted') or '').strip().lower() in ('1','true','yes','on'):
        return None
    out=dict(obj)
    name=str(edit.get('name') or '').strip()
    typ=str(edit.get('type') or '').strip()
    asset=str(edit.get('asset') or '').strip()
    notes=str(edit.get('notes') or '').strip()
    if name:
        out['name']=name; out['callsign']=name
    if typ:
        out['type']=typ; out['cot_type']=typ
    if asset:
        out['asset_override']=asset; out['asset']=asset
    if notes:
        out['notes']=notes; out['remarks']=notes
    for k in ('lat','lon'):
        if str(edit.get(k) or '').strip():
            try:
                out[k]=float(edit.get(k))
            except Exception:
                pass
    out['popup_edit']={'key':key_used,'updated':edit.get('updated')}
    return out

def tak_map_popup_edit_update(payload):
    payload=payload if isinstance(payload, dict) else {}
    key=str(payload.get('key') or '').strip()
    if not key:
        return {'ok':False,'error':'Missing popup edit key.'}
    data=_load_popup_edits()
    items=data.get('items') if isinstance(data.get('items'), dict) else {}
    if bool(payload.get('delete')):
        items.pop(key, None)
        data['items']=items
        _save_popup_edits(data)
        return {'ok':True,'deleted':True,'key':key,'edits':data}
    if bool(payload.get('delete_item')):
        edit=items.get(key) if isinstance(items.get(key), dict) else {}
        edit=dict(edit)
        edit['source']=str(payload.get('source') or edit.get('source') or '').strip()
        edit['deleted']='true'
        edit['updated']=datetime.now(timezone.utc).isoformat()
        items[key]=edit
        data['items']=items
        _save_popup_edits(data)
        return {'ok':True,'deleted_item':True,'key':key,'edit':edit,'edits':data}
    edit={}
    for k in ('source','name','type','asset','notes','lat','lon'):
        v=payload.get(k)
        if v is not None:
            edit[k]=str(v).strip()
    edit['updated']=datetime.now(timezone.utc).isoformat()
    items[key]=edit
    data['items']=items
    _save_popup_edits(data)
    return {'ok':True,'key':key,'edit':edit,'edits':data}

def _load_tak_map_prefs():
    """Load TAK Map UI preferences.

    v216 reads both the canonical file and the compatibility filename.  If both
    exist, use the most recently updated one so operator basemap changes do not
    get overwritten by an older file.
    """
    candidates=[]
    for fp in (TAK_MAP_PREFS_FILE, TAK_MAP_PREFS_FILE_COMPAT):
        try:
            if fp.exists():
                data=json.loads(fp.read_text())
                if isinstance(data, dict):
                    data['_prefs_file']=str(fp)
                    try:
                        data['_prefs_mtime']=fp.stat().st_mtime
                    except Exception:
                        data['_prefs_mtime']=0
                    candidates.append(data)
        except Exception:
            pass
    if not candidates:
        return {}
    def _score(d):
        t=str(d.get('last_basemap_updated') or d.get('updated') or '')
        try:
            return datetime.fromisoformat(t.replace('Z','+00:00')).timestamp()
        except Exception:
            return float(d.get('_prefs_mtime') or 0)
    candidates.sort(key=_score, reverse=True)
    return candidates[0]

def _write_tak_map_prefs_file(fp, data):
    tmp=fp.with_suffix('.tmp')
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True))
    tmp.replace(fp)

def _save_tak_map_prefs(updates):
    TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
    data=_load_tak_map_prefs()
    if not isinstance(data, dict):
        data={}
    # Remove internal loader metadata before writing.
    data.pop('_prefs_file', None); data.pop('_prefs_mtime', None)
    if not isinstance(updates, dict):
        updates={}
    for k,v in updates.items():
        if v is not None:
            data[str(k)]=v
    data['updated']=datetime.now(timezone.utc).isoformat()
    # Write both names so checks against either path work and future installs can
    # read the same preference.  Use canonical map_prefs.json internally, but keep
    # tak_map_prefs.json as a mirror for operator diagnostics.
    _write_tak_map_prefs_file(TAK_MAP_PREFS_FILE, data)
    try:
        _write_tak_map_prefs_file(TAK_MAP_PREFS_FILE_COMPAT, data)
    except Exception:
        pass
    return data

def _normalize_tak_map_basemap_pref_payload(payload):
    payload=payload if isinstance(payload, dict) else {}
    out={}
    last=str(payload.get('last_basemap') or payload.get('lastBasemap') or payload.get('basemap') or payload.get('id') or '').strip()
    # v216: save any sane non-empty basemap id the browser reports, including
    # dynamic/offline ids. Store a dedicated timestamp so the browser can choose
    # the newest server/local value instead of falling back to the default.
    if last and re.match(r'^[A-Za-z0-9_.:-]{1,200}$', last):
        out['last_basemap']=last
        try:
            ts=float(payload.get('ts') or 0)/1000.0
            if ts > 0:
                out['last_basemap_updated']=datetime.fromtimestamp(ts, timezone.utc).isoformat()
            else:
                out['last_basemap_updated']=datetime.now(timezone.utc).isoformat()
        except Exception:
            out['last_basemap_updated']=datetime.now(timezone.utc).isoformat()
    return out

def tak_map_preferences_update(payload):
    out=_normalize_tak_map_basemap_pref_payload(payload)
    prefs=_save_tak_map_prefs(out) if out else _load_tak_map_prefs()
    return {'ok':True,'prefs':prefs,'saved':bool(out),'path':str(TAK_MAP_PREFS_FILE),'compat_path':str(TAK_MAP_PREFS_FILE_COMPAT),'path_exists':TAK_MAP_PREFS_FILE.exists(),'compat_exists':TAK_MAP_PREFS_FILE_COMPAT.exists()}

def tak_map_preferences_save_public_from_query(query):
    q=parse_qs(query or '')
    payload={
        'last_basemap':(q.get('last_basemap') or q.get('lastBasemap') or q.get('basemap') or q.get('id') or [''])[0],
        'ts':(q.get('ts') or [''])[0],
    }
    out=_normalize_tak_map_basemap_pref_payload(payload)
    if not out:
        return {'ok':False,'saved':False,'error':'No valid basemap id supplied.'}
    prefs=_save_tak_map_prefs(out)
    return {'ok':True,'saved':True,'prefs':prefs,'path':str(TAK_MAP_PREFS_FILE),'compat_path':str(TAK_MAP_PREFS_FILE_COMPAT),'path_exists':TAK_MAP_PREFS_FILE.exists(),'compat_exists':TAK_MAP_PREFS_FILE_COMPAT.exists()}

def _tak_map_all_basemaps_for_config():
    return list(TAK_MAP_BASEMAPS) + list(_offline_basemap_entries())

def _tak_map_basemap_exists(basemap_id, basemaps=None):
    bid=str(basemap_id or '').strip()
    if not bid:
        return False
    for b in (basemaps or _tak_map_all_basemaps_for_config()):
        try:
            if str(b.get('id') or '') == bid:
                return True
        except Exception:
            pass
    return False

def _tak_map_prefer_basemap_first(basemaps, preferred):
    preferred=str(preferred or '').strip()
    rows=list(basemaps or [])
    if not preferred:
        return rows
    first=[]; rest=[]
    for b in rows:
        try:
            (first if str(b.get('id') or '') == preferred else rest).append(b)
        except Exception:
            rest.append(b)
    return first + rest

def _tak_map_effective_basemap(prefs, basemaps):
    # v216: make the server preference authoritative.  Earlier builds saved the
    # preference correctly but a separate client-side fallback/default path could
    # still use config.default_basemap or the first basemap.  Return the saved
    # value as default_basemap too, and put it first in the list so every load
    # path resolves to the same operator-selected basemap.
    saved=str((prefs or {}).get('last_basemap') or '').strip()
    if saved and _tak_map_basemap_exists(saved, basemaps):
        return saved, 'saved-preference'
    env_default=str(TAK_MAP_DEFAULT_BASEMAP or '').strip()
    if env_default and _tak_map_basemap_exists(env_default, basemaps):
        return env_default, 'configured-default'
    if basemaps:
        try:
            return str(basemaps[0].get('id') or ''), 'first-basemap-fallback'
        except Exception:
            pass
    return 'esri_topo', 'hardcoded-fallback'

def tak_map_config():
    offline_maps=_load_offline_maps()
    prefs=_load_tak_map_prefs()
    raw_basemaps=_tak_map_all_basemaps_for_config()
    effective_basemap, effective_source=_tak_map_effective_basemap(prefs, raw_basemaps)
    basemaps=_tak_map_prefer_basemap_first(raw_basemaps, effective_basemap)
    return {
        'ok': True,
        'default_basemap': effective_basemap,
        'configured_default_basemap': TAK_MAP_DEFAULT_BASEMAP,
        'last_basemap': effective_basemap,
        'last_basemap_saved': str(prefs.get('last_basemap') or ''),
        'last_basemap_source': effective_source,
        'last_basemap_updated': str(prefs.get('last_basemap_updated') or prefs.get('updated') or ''),
        'basemaps': basemaps,
        'offline_maps': offline_maps,
        'offline_download_sources': _offline_download_sources(),
        'offline_download_max_tiles': TAK_MAP_OFFLINE_DOWNLOAD_MAX_TILES,
        'offline_download_concurrency': TAK_MAP_OFFLINE_DOWNLOAD_CONCURRENCY,
        'server_name': socket.gethostname(),
        'hostname': socket.gethostname(),
        'external_layers': TAK_MAP_EXTERNAL_LAYERS,
        'live_layers': [
            {'id':'cot_markers','label':'CoT markers','default':True},
            {'id':'euds','label':'EUDs / clients','default':True},
        ],
        'adsb': {'source_mode': TAK_DASH_ADSB_SOURCE, 'stale_seconds': TAK_DASH_ADSB_STALE_SECONDS, 'settings': _load_adsb_settings()},
    }

def _ots_data_folder_candidates():
    out=[]
    raw=os.environ.get('OTS_DATA_FOLDER','').strip()
    if raw:
        out.append(Path(raw).expanduser())
    for base in (Path('/var/lib/opentakserver'), Path('/opt/opentakserver'), Path('/srv/opentakserver')):
        out.append(base)
    try:
        for home in Path('/home').glob('*'):
            if home.is_dir():
                out.append(home/'ots')
    except Exception:
        pass
    out.append(Path('/root/ots'))
    seen=set(); final=[]
    for p in out:
        try: key=str(p.resolve())
        except Exception: key=str(p)
        if key not in seen:
            seen.add(key); final.append(p)
    return final

def tak_map_data_packages():
    packages=[]
    roots=[]
    for folder in _ots_data_folder_candidates():
        for rel in ('data_packages','DataPackages','mission_packages','MissionPackages','packages','uploads'):
            p=folder/rel
            if p.exists() and p.is_dir():
                roots.append(p)
    exts={'.kml','.kmz','.geojson','.json','.gpx','.csv','.zip'}
    seen=set()
    for root in roots:
        try:
            for fp in root.rglob('*'):
                if not fp.is_file() or fp.suffix.lower() not in exts:
                    continue
                key=str(fp.resolve())
                if key in seen: continue
                seen.add(key)
                st=fp.stat()
                packages.append({'name':fp.name,'type':fp.suffix.lower().lstrip('.').upper(),'size_bytes':st.st_size,'modified_ts':int(st.st_mtime),'previewable':fp.suffix.lower() in ('.kml','.kmz','.geojson','.json','.gpx','.csv'),'path':str(fp)})
                if len(packages)>=250:
                    break
        except Exception:
            pass
    return {'ok':True,'packages':packages,'roots':[str(x) for x in roots]}


def _pg_table_rows(uri, table, limit=500):
    """Return up to limit rows from a public PostgreSQL table as dictionaries.

    Prefer newest rows when a timestamp/id column is present. The TAK Map uses this
    for live CoT/EUD/ADS-B and Data Sync objects, so arbitrary PostgreSQL row order
    can put markers in stale/wrong locations.
    """
    try:
        limit=max(1, min(int(limit), 1500))
    except Exception:
        limit=500
    safe_table=str(table or '').strip()
    if not re.match(r'^[A-Za-z_][A-Za-z0-9_]*$', safe_table):
        return [], 'invalid table name'
    order_sql=''
    try:
        cols, _err = _pg_columns(uri, 'public', safe_table)
        cols_l={c.lower():c for c in cols}
        for cand in ('stale','time','start','updated','update_time','update_datetime','last_seen','last_seen_at','current_login_at','last_login_at','create_datetime','created_at','id'):
            if cand in cols_l:
                order_sql=' order by ' + _pg_ident(cols_l[cand]) + ' desc nulls last'
                break
    except Exception:
        order_sql=''
    sql=f"select row_to_json(q) from (select * from {_pg_table_ref('public', safe_table)}{order_sql} limit {limit}) q"
    return _pg_rows_json(uri, sql)

def _row_ci_get(row, names, default=None):
    if not isinstance(row, dict):
        return default
    exact={str(k).lower():k for k in row.keys()}
    for name in names:
        key=exact.get(str(name).lower())
        if key is not None and row.get(key) not in (None,''):
            return row.get(key)
    return default

def _coerce_float(v):
    try:
        if v is None or v == '': return None
        return float(str(v).strip())
    except Exception:
        return None

def _parse_ts_epoch(v):
    txt=str(v or '').strip()
    if not txt:
        return None
    try:
        if re.match(r'^\d+(?:\.\d+)?$', txt):
            n=float(txt)
            if n > 1000000000000: n /= 1000.0
            return n
    except Exception:
        pass
    for raw in (txt, txt.replace('Z','+00:00')):
        try:
            dt=datetime.fromisoformat(raw)
            if dt.tzinfo is None:
                # OpenTAKServer stores many PostgreSQL timestamps without timezone,
                # but they are local server time. Treating them as UTC makes
                # active EUDs appear stale by the local UTC offset.
                dt=dt.replace(tzinfo=datetime.now().astimezone().tzinfo)
            return dt.timestamp()
        except Exception:
            pass
    for fmt in ('%Y-%m-%d %H:%M:%S','%Y-%m-%dT%H:%M:%S','%m/%d/%Y %H:%M:%S'):
        try:
            return datetime.strptime(txt[:19], fmt).replace(tzinfo=datetime.now().astimezone().tzinfo).timestamp()
        except Exception:
            pass
    return None

def _is_live_marker_stale(updated, default_seconds=300):
    try:
        stale_seconds=int(os.environ.get('TAK_DASH_LIVE_STALE_SECONDS', str(default_seconds)))
    except Exception:
        stale_seconds=default_seconds
    ts=_parse_ts_epoch(updated)
    if ts is None:
        return False
    return (time.time() - ts) > max(30, stale_seconds)

def _row_text_values(row):
    for v in (row or {}).values():
        if isinstance(v, (dict,list)):
            try: yield json.dumps(v, default=str)[:20000]
            except Exception: pass
        else:
            txt=str(v or '')
            if txt:
                yield txt[:20000]

def _parse_cot_text_fields(row):
    out={}
    for txt in _row_text_values(row):
        if '<event' not in txt and '<point' not in txt and '<contact' not in txt and '<track' not in txt:
            continue
        m=re.search(r'<event\b[^>]*\buid=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('uid', m.group(1))
        m=re.search(r'<event\b[^>]*\btype=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('type', m.group(1))
        m=re.search(r'<point\b[^>]*\blat=["\']([-+0-9.]+)["\'][^>]*\blon=["\']([-+0-9.]+)["\']', txt, re.I)
        if m:
            out.setdefault('lat', m.group(1)); out.setdefault('lon', m.group(2))
        m=re.search(r'<point\b[^>]*\bhae=["\']([-+0-9.]+)["\']', txt, re.I)
        if m: out.setdefault('hae', m.group(1))
        m=re.search(r'<contact\b[^>]*\bcallsign=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('callsign', m.group(1))
        m=re.search(r'<marti\b[^>]*>.*?<dest\b[^>]*\bmission=["\']([^"\']+)["\']', txt, re.I|re.S)
        if m: out.setdefault('mission', m.group(1))
        m=re.search(r'<creator\b[^>]*\bcallsign=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('creator_callsign', m.group(1))
        m=re.search(r'<creator\b[^>]*\buid=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('creator_uid', m.group(1))
        m=re.search(r'<link\b[^>]*\bparent_callsign=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('parent_callsign', m.group(1))
        m=re.search(r'<track\b[^>]*\bcourse=["\']([-+0-9.]+)["\']', txt, re.I)
        if m: out.setdefault('course', m.group(1))
        m=re.search(r'<track\b[^>]*\bspeed=["\']([-+0-9.]+)["\']', txt, re.I)
        if m: out.setdefault('speed_mps', m.group(1))
    return out

def _is_aircraft_type(cot_type, uid='', callsign=''):
    blob=' '.join([str(cot_type or ''), str(uid or ''), str(callsign or '')]).lower()
    return ('a-f-a' in blob or 'ads-b' in blob or 'adsb' in blob or 'aircraft' in blob or 'icao' in blob)

def _is_mission_cot_fields(parsed, row=None):
    row=row or {}
    mission=str((parsed or {}).get('mission') or _row_ci_get(row, ('mission','mission_name','dest_mission'), '') or '').strip()
    if mission:
        return True
    # Avoid classifying ATAK-created mission objects as Non-TAK Sensors.
    blob=' '.join(str(x or '') for x in list((parsed or {}).values()) + list(row.values())[:40]).lower()
    return ('<marti' in blob and 'mission=' in blob) or ('dest mission' in blob)

def _normalize_tak_marker(row, source_table='cot', default_kind='cot'):
    row=row or {}
    parsed=_parse_cot_text_fields(row)
    def get(names, default=None):
        v=_row_ci_get(row, names, None)
        if v in (None,''):
            v=_row_ci_get(parsed, names, default)
        return v
    lat=_coerce_float(get(('lat','latitude','point_lat','point_latitude')))
    lon=_coerce_float(get(('lon','lng','longitude','point_lon','point_longitude')))
    if lat is None or lon is None:
        return None
    if not (-90 <= lat <= 90 and -180 <= lon <= 180):
        return None
    # 0,0 is almost always a no-fix/no-location placeholder in TAK/ADS-B/EUD data.
    # Do not render it as a real marker.
    if abs(lat) < 0.000001 and abs(lon) < 0.000001:
        return None
    uid=str(get(('uid','cot_uid','clientuid','clientUid','client_uid','device_uid','id'), '') or '').strip()
    callsign=str(get(('callsign','call_sign','name','title','username','clientUid','clientuid'), '') or '').strip()
    cot_type=str(get(('type','cot_type','event_type','category'), '') or '').strip()
    kind=default_kind
    # Aircraft/ADS-B CoT must always override EUD/client matching. Some OTS
    # tables can contain client-like metadata for aircraft feeds, but anything
    # with an aircraft/ADS-B type or UID/callsign should render as aircraft.
    if _is_aircraft_type(cot_type, uid, callsign):
        kind='aircraft'
    elif source_table.lower() in ('euds','eud_stats'):
        kind='eud'
    elif any(tok in (uid+' '+callsign+' '+cot_type).lower() for tok in ('server gps','tak server gps','tak-server-gps','server-location','server location','modem gps')):
        kind='server_gps'
    elif 'webform' in (uid+callsign+cot_type).lower():
        kind='webform'
    if kind == 'cot' and _is_mission_cot_fields(parsed, row):
        kind='datasync'
    mission=str(get(('mission','mission_name','dest_mission'), '') or '').strip()
    creator_callsign=str(get(('creator_callsign','creator'), '') or '').strip()
    creator_uid=str(get(('creator_uid',), '') or '').strip()
    parent_callsign=str(get(('parent_callsign',), '') or '').strip()
    alt=_coerce_float(get(('altitude_ft','alt_ft','alt_baro','altitude','hae','ce','le')))
    speed=get(('speed_kt','gs','speed','groundspeed','velocity'), None)
    speed_kt=_coerce_float(speed)
    if speed_kt is None:
        sp_mps=_coerce_float(get(('speed_mps',), None))
        if sp_mps is not None:
            speed_kt=round(sp_mps*1.95384, 1)
    track=_coerce_float(get(('track_deg','track','course','heading','bearing','true_heading','mag_heading'), None))
    updated=str(get(('start','timestamp','time','updated','update_time','update_datetime','last_seen','current_login_at','stale'), '') or '')
    # Remove stale live CoT/EUD/server markers from the live map. Data Sync rows
    # are handled separately and should remain mission history/mission content.
    if default_kind in ('cot','eud') and kind != 'webform' and _is_live_marker_stale(updated, 300):
        return None
    return {
        'id': uid or callsign or f'{source_table}:{lat:.5f},{lon:.5f}',
        'uid': uid,
        'callsign': callsign or uid or source_table,
        'type': cot_type or source_table,
        'kind': kind,
        'lat': lat,
        'lon': lon,
        'altitude_ft': alt,
        'speed_kt': speed_kt,
        'track_deg': track,
        'updated': updated,
        'source': 'OpenTAKServer ' + source_table,
        'source_table': source_table,
        'mission': mission,
        'creator_callsign': creator_callsign,
        'creator_uid': creator_uid,
        'parent_callsign': parent_callsign,
        'is_mission_object': bool(mission or creator_callsign or parent_callsign) and kind == 'datasync',
        'raw_lat': lat,
        'raw_lon': lon,
    }

def _ots_pg_markers(limit_per_table=800):
    markers=[]; source_notes=[]; eud_keys=set()
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if cfg_errors:
        source_notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    def add_eud_key(v):
        v=str(v or '').strip().lower()
        if v:
            eud_keys.add(v)
    for uri in pg_uris[:2]:
        for table,kind in (('cot','cot'),('euds','eud'),('eud_stats','eud'),('markers','cot'),('points','cot')):
            rows,err=_pg_table_rows(uri, table, limit_per_table)
            if err:
                continue
            source_notes.append({'source':'postgres:'+table,'ok':True,'rows':len(rows)})
            if table.lower() in ('euds','eud_stats'):
                for row in rows:
                    if isinstance(row, dict):
                        parsed=_parse_cot_text_fields(row)
                        for src in (row, parsed):
                            for k in ('uid','cot_uid','clientuid','clientUid','client_uid','device_uid','callsign','call_sign','name','title','username'):
                                add_eud_key(src.get(k) if isinstance(src, dict) else '')
            for row in rows:
                m=_normalize_tak_marker(row, table, kind)
                if m:
                    markers.append(m)
        if markers:
            break
    # CoT rows frequently contain the current EUD location, while euds/eud_stats
    # tables identify the same client. Mark matching CoT rows as EUDs so the
    # agreed EUD icon is used without sacrificing the newest CoT position.
    if eud_keys:
        for m in markers:
            # Do not let EUD matching steal ADS-B/aircraft rows.
            blob=str(' '.join(str(x or '') for x in (m.get('kind'),m.get('uid'),m.get('id'),m.get('callsign'),m.get('type'),m.get('source')))).lower()
            if m.get('kind') == 'aircraft' or _is_aircraft_type(m.get('type'), m.get('uid'), m.get('callsign')):
                m['kind']='aircraft'
                continue
            if 'webform' in blob or 'tak-dashboard' in blob or 'ads-b' in blob or 'adsb' in blob:
                if 'webform' in blob:
                    m['kind']='webform'
                continue
            keys=[m.get('uid'),m.get('id'),m.get('callsign')]
            if any(str(k or '').strip().lower() in eud_keys for k in keys):
                m['kind']='eud'
    # Dedupe by UID/callsign. Prefer EUD classification and newer source priority
    # while keeping the first/current position row when possible.
    dedup={}
    pref={'eud':4,'server_gps':3,'webform':3,'aircraft':3,'cot':2,'datasync':1}
    for m in markers:
        key=(m.get('uid') or m.get('id') or m.get('callsign') or '').lower()
        if not key:
            key=f"{m.get('lat')},{m.get('lon')},{m.get('kind')}"
        old=dedup.get(key)
        if old is None or pref.get(m.get('kind'),0) > pref.get(old.get('kind'),0):
            dedup[key]=m
    return list(dedup.values()), source_notes
def _ots_pg_aircraft():
    markers, notes = _ots_pg_markers(limit_per_table=1200)
    aircraft=[]
    for m in markers:
        if m.get('kind') == 'aircraft' or _is_aircraft_type(m.get('type'), m.get('uid'), m.get('callsign')):
            aircraft.append({
                'id': m.get('uid') or m.get('id') or m.get('callsign') or 'aircraft',
                'callsign': m.get('callsign') or m.get('uid') or 'aircraft',
                'type': m.get('type') or '',
                'lat': m.get('lat'), 'lon': m.get('lon'),
                'altitude_ft': m.get('altitude_ft'),
                'speed_kt': m.get('speed_kt'),
                'track_deg': m.get('track_deg'),
                'seen_seconds': None,
                'source': m.get('source') or 'OpenTAKServer ADS-B/CoT',
                'raw_lat': m.get('raw_lat') or m.get('lat'),
                'raw_lon': m.get('raw_lon') or m.get('lon'),
                'updated': m.get('updated') or '',
                'category': m.get('category') or m.get('type') or '',
                'aircraft_type': m.get('aircraft_type') or m.get('type') or '',
                'description': m.get('description') or '',
                'emitter_category': m.get('emitter_category') or m.get('type') or '',
            })
    return aircraft, notes

def tak_map_cot_markers():
    markers, source_notes = _ots_pg_markers()
    # Keep aircraft in the ADS-B endpoint so EUD/CoT marker layer does not double-render them.
    edits=_load_popup_edits()
    markers=[_apply_popup_edit(m, edits) for m in markers if m.get('kind') not in ('aircraft','webform')]
    return {'ok':True,'markers':markers,'sources':source_notes}


def _parse_takv_and_team(row):
    out={}
    for txt in _row_text_values(row):
        m=re.search(r'<takv\b([^>]*)>', txt, re.I)
        if m:
            attrs=m.group(1)
            for key,name in (('platform','client'),('version','version'),('device','device'),('os','os')):
                mm=re.search(r'\b'+key+r'=["\']([^"\']+)["\']', attrs, re.I)
                if mm: out.setdefault(name, mm.group(1))
        m=re.search(r'<__group\b[^>]*\bname=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('team', m.group(1))
        m=re.search(r'<__group\b[^>]*\brole=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('role', m.group(1))
        m=re.search(r'<contact\b[^>]*\bcallsign=["\']([^"\']+)["\']', txt, re.I)
        if m: out.setdefault('callsign', m.group(1))
    return out

def _age_seconds_from_value(v):
    ts=_parse_ts_epoch(v)
    if ts is None:
        return None
    return max(0, int(time.time() - ts))



def _has_tak_client_version(e, xml=''):
    blob=' '.join(str(x or '') for x in (e.get('client'), e.get('client_label'), e.get('version'), xml)).lower()
    has_client=any(k in blob for k in ('atak','itak','wintak','takv','tak client'))
    has_version=bool(str(e.get('version') or '').strip()) or bool(re.search(r'<takv\b[^>]*\bversion=["\']([^"\']+)["\']', str(xml or ''), re.I))
    return has_client and has_version

def _is_real_eud_candidate(e, xml=''):
    blob=' '.join(str(x or '') for x in (
        e.get('uid'), e.get('callsign'), e.get('source'), e.get('client'),
        e.get('client_label'), e.get('type'), xml
    )).lower()
    bad_terms=('webform','webform-gw','ads-b','adsb','aircraft','icao','server gps','server_gps','tak-dashboard','dashboard')
    if any(term in blob for term in bad_terms):
        return False
    cs=str(e.get('callsign') or '').strip().lower()
    if not cs or cs in ('webform','webform-gw','tak-dashboard'):
        return False
    if cs.startswith(('webform','ads-b','adsb')):
        return False
    # Count only true TAK clients. Generic CoT locations/sensors become Non-TAK Sensors.
    return _has_tak_client_version(e, xml)

def tak_map_euds():
    euds={}; notes=[]
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if cfg_errors:
        notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    def put(e, xml=''):
        uid=str(e.get('uid') or '').strip()
        cs=str(e.get('callsign') or '').strip()
        if not _is_real_eud_candidate(e, xml):
            return
        key=(uid or cs).lower()
        if not key: return
        old=euds.get(key)
        def score(x):
            return (10 if x.get('lat') is not None and x.get('lon') is not None else 0) - int(x.get('location_age_seconds') or 999999)/100000
        if old is None or score(e)>score(old):
            euds[key]=e
        else:
            old.update({k:v for k,v in e.items() if v not in (None,'') and old.get(k) in (None,'')})
    for uri in pg_uris[:2]:
        rows,err=_pg_table_rows(uri, 'cot', 1200)
        if not err:
            notes.append({'source':'postgres:cot','ok':True,'rows':len(rows)})
            for row in rows:
                if not isinstance(row, dict): continue
                xml=str(row.get('xml') or '')
                typ=str(row.get('type') or '')
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')) or typ.startswith('b-f-t') or typ.startswith('b-t-f'): continue
                parsed=_parse_cot_text_fields(row); extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or '').strip()
                callsign=str(row.get('sender_callsign') or extra.get('callsign') or parsed.get('callsign') or uid).strip()
                if not uid and not callsign: continue
                lat=_coerce_float(parsed.get('lat')); lon=_coerce_float(parsed.get('lon'))
                updated=str(row.get('start') or row.get('timestamp') or row.get('stale') or '')
                age=_age_seconds_from_value(updated)
                status='Online' if age is not None and age <= 180 else ('Recent' if age is not None and age <= 900 else ('Stale' if age is not None else 'Unknown'))
                put({'uid':uid,'callsign':callsign,'client':extra.get('client') or '','version':extra.get('version') or '', 'client_label':((' '.join([extra.get('client') or '', extra.get('version') or ''])).strip()),'team':extra.get('team') or '', 'lat':lat,'lon':lon,'updated':updated,'location_age_seconds':age,'status':status,'source':'cot','type':typ}, xml)
        for table in ('euds','eud_stats'):
            rows,err=_pg_table_rows(uri, table, 500)
            if err: continue
            notes.append({'source':'postgres:'+table,'ok':True,'rows':len(rows)})
            for row in rows:
                extra=_parse_takv_and_team(row)
                uid=str(_row_ci_get(row, ('uid','client_uid','clientUid','clientuid','device_uid','cot_uid'), '') or '').strip()
                callsign=str(_row_ci_get(row, ('callsign','call_sign','name','username','title'), '') or extra.get('callsign') or uid).strip()
                lat=_coerce_float(_row_ci_get(row, ('lat','latitude','point_lat'), None)); lon=_coerce_float(_row_ci_get(row, ('lon','lng','longitude','point_lon'), None))
                updated=str(_row_ci_get(row, ('last_seen','updated','update_time','last_connection','last_login_at','current_login_at','start','stale'), '') or '')
                age=_age_seconds_from_value(updated)
                put({'uid':uid,'callsign':callsign,'client':extra.get('client') or str(_row_ci_get(row, ('platform','client','takv_platform'), '') or ''),'version':extra.get('version') or str(_row_ci_get(row, ('version','takv_version','app_version'), '') or ''),'client_label':'','team':extra.get('team') or str(_row_ci_get(row, ('team','team_name','group','color'), '') or '').lower(),'lat':lat,'lon':lon,'updated':updated,'location_age_seconds':age,'status':'Online' if age is not None and age <= 180 else ('Recent' if age is not None and age <= 900 else 'Unknown'),'source':table})
        if euds:
            break
    out=[]
    for e in euds.values():
        if not e.get('client_label'):
            e['client_label']=' '.join([str(e.get('client') or ''), str(e.get('version') or '')]).strip()
        out.append(e)
    out.sort(key=lambda x: (x.get('status')!='Online', x.get('location_age_seconds') if x.get('location_age_seconds') is not None else 999999, x.get('callsign') or ''))
    return {'ok':True,'euds':out,'sources':notes}


def _is_online_send_eud(e):
    """Return True only for EUDs that should be offered as Send Map/Offline Map targets.

    The send picker must not show legacy webform points or EUD rows whose state is
    unknown. Prefer a recent CoT/location update, but also honor explicit online
    status fields when present in OTS tables.
    """
    if not isinstance(e, dict):
        return False
    blob=' '.join(str(e.get(k) or '') for k in ('kind','source','type','client','client_label','callsign','uid')).lower()
    if any(term in blob for term in ('webform','webform-gw','ads-b','adsb','aircraft','icao','server_gps','server gps','tak-dashboard')):
        return False
    cs=str(e.get('callsign') or '').strip().lower()
    if not cs or cs.startswith('webform') or cs in ('tak-dashboard','dashboard'):
        return False
    age=e.get('location_age_seconds')
    try:
        age=float(age)
    except Exception:
        age=None
    status=str(e.get('status') or '').strip().lower()
    # For the send screen, UNKNOWN is deliberately excluded.
    if age is not None and age <= 180:
        return True
    if status in ('online','connected','active'):
        return True
    return False




def _kml_coords_to_latlon(coord_text):
    pts=[]
    for part in re.split(r'\s+', str(coord_text or '').strip()):
        if not part or ',' not in part:
            continue
        bits=part.split(',')
        if len(bits) < 2:
            continue
        lon=_coerce_float(bits[0]); lat=_coerce_float(bits[1])
        if lat is not None and lon is not None and -90 <= lat <= 90 and -180 <= lon <= 180:
            pts.append([round(lat, 7), round(lon, 7)])
    return pts

def _xml_local(tag):
    return str(tag or '').split('}',1)[-1]

def _xml_text_child(node, name):
    for child in list(node):
        if _xml_local(child.tag).lower()==name.lower():
            return ''.join(child.itertext()).strip()
    return ''

def _feature_centroid(coords):
    pts=[]
    def walk(x):
        if isinstance(x, (list,tuple)):
            if len(x)>=2 and isinstance(x[0], (int,float)) and isinstance(x[1], (int,float)):
                pts.append((float(x[0]), float(x[1])))
            else:
                for y in x: walk(y)
    walk(coords)
    if not pts: return None
    return [round(sum(p[0] for p in pts)/len(pts),7), round(sum(p[1] for p in pts)/len(pts),7)]

def _clean_props(props):
    out={}
    if isinstance(props, dict):
        for k,v in props.items():
            if v in (None,''):
                continue
            ks=str(k)
            if ks.lower() in ('geometry','geom','shape','the_geom'):
                continue
            out[ks]=str(v)[:500]
    return out

def _feature_name(props, fallback='feature'):
    props=props or {}
    for k in ('name','Name','title','Title','label','Label','callsign','CALLSIGN','description','Description','id','ID'):
        if props.get(k) not in (None,''):
            return str(props.get(k))[:120]
    return fallback

def _geojson_positions_to_latlon(coords):
    if not isinstance(coords, (list,tuple)) or len(coords)<2:
        return None
    lon=_coerce_float(coords[0]); lat=_coerce_float(coords[1])
    if lat is not None and lon is not None and -90 <= lat <= 90 and -180 <= lon <= 180:
        return [round(lat,7), round(lon,7)]
    return None

def _geojson_line_to_latlon(coords):
    out=[]
    for c in coords or []:
        pt=_geojson_positions_to_latlon(c)
        if pt: out.append(pt)
    return out

def _geojson_polygon_to_latlon(coords):
    rings=[]
    for ring in coords or []:
        pts=_geojson_line_to_latlon(ring)
        if pts: rings.append(pts)
    return rings

def _parse_geojson_obj(obj, source_name='GeoJSON'):
    features=[]
    def add_geom(geom, props, name=None):
        if not isinstance(geom, dict):
            return
        gtype=str(geom.get('type') or '').lower()
        coords=geom.get('coordinates')
        props=_clean_props(props or {})
        label=name or _feature_name(props, source_name)
        if gtype=='point':
            pt=_geojson_positions_to_latlon(coords)
            if pt:
                features.append({'kind':'point','geometry':'point','name':label,'lat':pt[0],'lon':pt[1],'coords':[pt],'properties':props,'source':source_name})
        elif gtype=='multipoint':
            for i,c in enumerate(coords or []):
                pt=_geojson_positions_to_latlon(c)
                if pt:
                    features.append({'kind':'point','geometry':'point','name':f'{label} {i+1}','lat':pt[0],'lon':pt[1],'coords':[pt],'properties':props,'source':source_name})
        elif gtype=='linestring':
            pts=_geojson_line_to_latlon(coords)
            if len(pts)>=2:
                features.append({'kind':'route','geometry':'route','name':label,'coords':pts,'lat':pts[0][0],'lon':pts[0][1],'properties':props,'source':source_name})
        elif gtype=='multilinestring':
            for i,line in enumerate(coords or []):
                pts=_geojson_line_to_latlon(line)
                if len(pts)>=2:
                    features.append({'kind':'route','geometry':'route','name':f'{label} {i+1}','coords':pts,'lat':pts[0][0],'lon':pts[0][1],'properties':props,'source':source_name})
        elif gtype=='polygon':
            rings=_geojson_polygon_to_latlon(coords)
            if rings:
                cen=_feature_centroid(rings[0]) or rings[0][0]
                features.append({'kind':'shape','geometry':'shape','name':label,'coords':rings,'lat':cen[0],'lon':cen[1],'properties':props,'source':source_name})
        elif gtype=='multipolygon':
            for i,poly in enumerate(coords or []):
                rings=_geojson_polygon_to_latlon(poly)
                if rings:
                    cen=_feature_centroid(rings[0]) or rings[0][0]
                    features.append({'kind':'shape','geometry':'shape','name':f'{label} {i+1}','coords':rings,'lat':cen[0],'lon':cen[1],'properties':props,'source':source_name})
        elif gtype=='geometrycollection':
            for g in geom.get('geometries') or []:
                add_geom(g, props, label)
    def walk(item):
        if not isinstance(item, dict):
            return
        typ=str(item.get('type') or '').lower()
        if typ=='featurecollection':
            for f in item.get('features') or []:
                walk(f)
        elif typ=='feature':
            add_geom(item.get('geometry'), item.get('properties') or {}, None)
        else:
            add_geom(item, {}, source_name)
    walk(obj)
    return features

def _parse_geojson_bytes(data, source_name='GeoJSON'):
    try:
        return _parse_geojson_obj(json.loads(data.decode('utf-8','replace')), source_name)
    except Exception:
        return []

def _parse_gpx_bytes(data, source_name='GPX'):
    features=[]
    try:
        root=ET.fromstring(data)
    except Exception:
        return []
    def is_tag(n, name): return _xml_local(n.tag).lower()==name.lower()
    for wpt in [n for n in root.iter() if is_tag(n,'wpt')]:
        lat=_coerce_float(wpt.attrib.get('lat')); lon=_coerce_float(wpt.attrib.get('lon'))
        if lat is None or lon is None: continue
        name=_xml_text_child(wpt,'name') or _xml_text_child(wpt,'desc') or source_name
        features.append({'kind':'point','geometry':'point','name':name,'lat':lat,'lon':lon,'coords':[[lat,lon]],'properties':{'source_format':'GPX waypoint'},'source':source_name})
    for rte in [n for n in root.iter() if is_tag(n,'rte')]:
        pts=[]
        for rp in [n for n in rte.iter() if is_tag(n,'rtept')]:
            lat=_coerce_float(rp.attrib.get('lat')); lon=_coerce_float(rp.attrib.get('lon'))
            if lat is not None and lon is not None: pts.append([lat,lon])
        if len(pts)>=2:
            name=_xml_text_child(rte,'name') or source_name
            features.append({'kind':'route','geometry':'route','name':name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':{'source_format':'GPX route','points':len(pts)},'source':source_name})
    for trk in [n for n in root.iter() if is_tag(n,'trk')]:
        name=_xml_text_child(trk,'name') or source_name
        for idx,seg in enumerate([n for n in trk.iter() if is_tag(n,'trkseg')]):
            pts=[]
            for tp in [n for n in seg.iter() if is_tag(n,'trkpt')]:
                lat=_coerce_float(tp.attrib.get('lat')); lon=_coerce_float(tp.attrib.get('lon'))
                if lat is not None and lon is not None: pts.append([lat,lon])
            if len(pts)>=2:
                features.append({'kind':'route','geometry':'route','name':name if idx==0 else f'{name} {idx+1}','lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':{'source_format':'GPX track','points':len(pts)},'source':source_name})
    return features

def _parse_kml_bytes(data, source_name='KML'):
    features=[]
    try:
        root=ET.fromstring(data)
    except Exception:
        return []
    for pm in [n for n in root.iter() if _xml_local(n.tag).lower()=='placemark']:
        name=_xml_text_child(pm,'name') or source_name
        desc=_xml_text_child(pm,'description')
        props={'description':desc} if desc else {}
        handled=False
        for node in pm.iter():
            lname=_xml_local(node.tag).lower()
            if lname=='point':
                coord=''
                for c in node.iter():
                    if _xml_local(c.tag).lower()=='coordinates': coord=''.join(c.itertext())
                pts=_kml_coords_to_latlon(coord)
                if pts:
                    pt=pts[0]; features.append({'kind':'point','geometry':'point','name':name,'lat':pt[0],'lon':pt[1],'coords':[pt],'properties':props,'source':source_name}); handled=True
            elif lname=='linestring':
                coord=''
                for c in node.iter():
                    if _xml_local(c.tag).lower()=='coordinates': coord=''.join(c.itertext())
                pts=_kml_coords_to_latlon(coord)
                if len(pts)>=2:
                    features.append({'kind':'route','geometry':'route','name':name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':props,'source':source_name}); handled=True
            elif lname=='polygon':
                rings=[]
                for c in node.iter():
                    if _xml_local(c.tag).lower()=='coordinates':
                        pts=_kml_coords_to_latlon(''.join(c.itertext()))
                        if len(pts)>=3: rings.append(pts)
                if rings:
                    cen=_feature_centroid(rings[0]) or rings[0][0]
                    features.append({'kind':'shape','geometry':'shape','name':name,'lat':cen[0],'lon':cen[1],'coords':rings,'properties':props,'source':source_name}); handled=True
        # gx:Track / KML Track fallback with <coord> lon lat alt values
        if not handled:
            pts=[]
            for c in pm.iter():
                if _xml_local(c.tag).lower()=='coord':
                    bits=''.join(c.itertext()).strip().split()
                    if len(bits)>=2:
                        lon=_coerce_float(bits[0]); lat=_coerce_float(bits[1])
                        if lat is not None and lon is not None: pts.append([lat,lon])
            if len(pts)>=2:
                features.append({'kind':'route','geometry':'route','name':name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':props,'source':source_name})
    return features

def _parse_kmz_bytes(data, source_name='KMZ'):
    try:
        with zipfile.ZipFile(io.BytesIO(data)) as z:
            kmls=[n for n in z.namelist() if n.lower().endswith('.kml')]
            if not kmls: return []
            # prefer doc.kml, otherwise first KML
            kml=next((n for n in kmls if os.path.basename(n).lower()=='doc.kml'), kmls[0])
            return _parse_kml_bytes(z.read(kml), source_name)
    except Exception:
        return []

def _suppress_route_endpoint_points(features):
    """Remove auto/start/end point placemarks that duplicate route endpoints.

    Some KML exports include separate Point placemarks named Start/End alongside a
    LineString. TAK Map should render routes as line-only overlays, not as a route
    plus generated endpoint markers.
    """
    try:
        routes=[f for f in (features or []) if str(f.get('kind') or f.get('geometry') or '').lower() in ('route','linestring','track') and isinstance(f.get('coords'), list) and len(f.get('coords') or [])>=2]
        if not routes:
            return features
        endpoint_keys=set()
        for r in routes:
            pts=r.get('coords') or []
            for p in (pts[0], pts[-1]):
                try:
                    endpoint_keys.add((round(float(p[0]),7), round(float(p[1]),7)))
                except Exception:
                    pass
        route_names=[str(r.get('name') or '').strip().lower() for r in routes]
        out=[]
        for f in features or []:
            kind=str(f.get('kind') or f.get('geometry') or '').lower()
            if kind=='point' and f.get('lat') is not None and f.get('lon') is not None:
                key=(round(float(f.get('lat')),7), round(float(f.get('lon')),7))
                nm=str(f.get('name') or '').strip().lower()
                nm_clean=nm.strip().strip('()[]{} ').strip()
                is_endpoint_name=(nm_clean in ('start','end','finish','origin','destination','route start','route end','start point','end point','begin') or nm_clean.endswith(' start') or nm_clean.endswith(' end') or nm_clean.startswith('start ') or nm_clean.startswith('end '))
                near_route_named=any(nm and rn and (nm==rn+' start' or nm==rn+' end' or nm in (rn+' begin', rn+' finish')) for rn in route_names)
                if key in endpoint_keys and (is_endpoint_name or near_route_named):
                    continue
            out.append(f)
        return out
    except Exception:
        return features


def _parse_shapefile_zip_bytes(data, source_name='Shapefile'):
    features=[]
    try:
        import shapefile
    except Exception:
        return [{'kind':'other','geometry':'other','name':source_name,'properties':{'error':'Shapefile parser is not installed on this system. Install python3-pyshp or pyshp to parse shapefile ZIP bundles.'},'source':source_name}]
    try:
        import pyproj
    except Exception:
        pyproj=None
    with tempfile.TemporaryDirectory() as td:
        td=Path(td)
        try:
            with zipfile.ZipFile(io.BytesIO(data)) as z:
                for n in z.namelist():
                    if n.lower().endswith(('.shp','.shx','.dbf','.prj')):
                        z.extract(n, td)
        except Exception:
            return []
        shp_files=list(td.rglob('*.shp'))
        if not shp_files: return []
        shp=shp_files[0]
        transformer=None
        prj=shp.with_suffix('.prj')
        if pyproj and prj.exists():
            try:
                src=pyproj.CRS.from_wkt(prj.read_text(errors='ignore'))
                dst=pyproj.CRS.from_epsg(4326)
                if src != dst:
                    transformer=pyproj.Transformer.from_crs(src,dst,always_xy=True)
            except Exception:
                transformer=None
        def xy_to_latlon(x,y):
            try:
                if transformer:
                    x,y=transformer.transform(x,y)
                lon=float(x); lat=float(y)
                if -90<=lat<=90 and -180<=lon<=180:
                    return [round(lat,7), round(lon,7)]
            except Exception:
                return None
            return None
        try:
            r=shapefile.Reader(str(shp))
            fields=[f[0] for f in r.fields[1:]]
            for i,sr in enumerate(r.iterShapeRecords()):
                rec=dict(zip(fields, list(sr.record)))
                props=_clean_props(rec)
                name=_feature_name(props, f'{source_name} {i+1}')
                st=sr.shape.shapeType
                pts=[xy_to_latlon(x,y) for x,y in sr.shape.points]
                pts=[p for p in pts if p]
                if not pts: continue
                if st in (1,11,21):
                    pt=pts[0]; features.append({'kind':'point','geometry':'point','name':name,'lat':pt[0],'lon':pt[1],'coords':[pt],'properties':props,'source':source_name})
                elif st in (3,13,23):
                    if len(pts)>=2: features.append({'kind':'route','geometry':'route','name':name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':props,'source':source_name})
                elif st in (5,15,25):
                    if len(pts)>=3:
                        cen=_feature_centroid(pts) or pts[0]
                        features.append({'kind':'shape','geometry':'shape','name':name,'lat':cen[0],'lon':cen[1],'coords':[pts],'properties':props,'source':source_name})
                if len(features)>=1000: break
        except Exception:
            return []
    return features

def parse_map_file_bytes(filename, data):
    name=os.path.basename(str(filename or 'imported'))[:160]
    ext=Path(name).suffix.lower()
    if ext in ('.geojson','.json'):
        return _suppress_route_endpoint_points(_parse_geojson_bytes(data, name))
    if ext=='.gpx':
        return _suppress_route_endpoint_points(_parse_gpx_bytes(data, name))
    if ext=='.kml':
        return _suppress_route_endpoint_points(_parse_kml_bytes(data, name))
    if ext=='.kmz':
        return _suppress_route_endpoint_points(_parse_kmz_bytes(data, name))
    if ext=='.zip':
        # Prefer KMZ-like zip with KML; otherwise try zipped shapefile bundle.
        try:
            with zipfile.ZipFile(io.BytesIO(data)) as z:
                names=[n.lower() for n in z.namelist()]
                if any(n.endswith('.kml') for n in names):
                    return _suppress_route_endpoint_points(_parse_kmz_bytes(data, name))
                if any(n.endswith('.shp') for n in names):
                    return _suppress_route_endpoint_points(_parse_shapefile_zip_bytes(data, name))
        except Exception:
            pass
    return [{'kind':'other','geometry':'other','name':name,'properties':{'error':'Unsupported or unrecognized import format'},'source':name}]

def _import_summary(features):
    counts={'point':0,'route':0,'shape':0,'other':0}
    for f in features or []:
        k=str(f.get('kind') or f.get('geometry') or 'other').lower()
        if k not in counts: k='other'
        counts[k]+=1
    return counts

def _webform_features_from_ots(limit=600):
    """Return current OpenTAKServer webform reports as Local Data point features."""
    features=[]
    try:
        markers, _notes = _ots_pg_markers(limit_per_table=limit)
    except Exception:
        markers=[]
    seen=set()
    for m in markers or []:
        if not isinstance(m, dict):
            continue
        blob=' '.join(str(m.get(k) or '') for k in ('kind','uid','id','callsign','type','source')).lower()
        if m.get('kind') != 'webform' and 'webform' not in blob:
            continue
        lat=_coerce_float(m.get('lat')); lon=_coerce_float(m.get('lon'))
        if lat is None or lon is None or not (-90 <= lat <= 90 and -180 <= lon <= 180):
            continue
        uid=str(m.get('uid') or m.get('id') or m.get('callsign') or f'webform:{lat:.6f},{lon:.6f}').strip()
        key=uid.lower() or f'{lat:.6f},{lon:.6f}'
        if key in seen:
            continue
        seen.add(key)
        name=str(m.get('callsign') or m.get('name') or m.get('title') or uid or 'Webform Report').strip()
        if not name or name.lower() == 'webform':
            name='Webform Report'
        features.append({'kind':'point','geometry':'point','name':name,'id':'webform:' + uid,'uid':uid,'lat':lat,'lon':lon,'source':'Webform','import_name':'Webform Reports','properties':{'source':'Webform','uid':uid,'type':m.get('type') or 'webform','updated':m.get('updated') or ''}})
    return features[:1500]


def _remove_webform_features_from_imports(imports):
    out=[]; removed=0
    for imp in imports or []:
        if not isinstance(imp, dict):
            continue
        imp_blob=' '.join(str(imp.get(k) or '') for k in ('id','name','source')).lower()
        if 'webform' in imp_blob:
            removed += len(imp.get('features') or []) or 1
            continue
        new_feats=[]
        for f in imp.get('features') or []:
            if not isinstance(f, dict):
                continue
            props=f.get('properties') if isinstance(f.get('properties'), dict) else {}
            blob=' '.join(str(x or '') for x in (f.get('id'),f.get('uid'),f.get('name'),f.get('callsign'),f.get('source'),f.get('import_name'),props.get('source'),props.get('type'),props.get('callsign'))).lower()
            if 'webform' in blob:
                removed += 1
                continue
            new_feats.append(f)
        cp=dict(imp); cp['features']=new_feats; cp['counts']=_import_summary(new_feats)
        if new_feats:
            out.append(cp)
    return out, removed


def tak_map_cleanup_webform_items():
    """One-time v223/v223 cleanup: remove old webform rows/cached items."""
    result={'ok':True,'local_removed':0,'db':[]}
    try:
        data=load_json_file(TAK_MAP_IMPORT_FILE, {'imports':[]})
        imports=data.get('imports') if isinstance(data, dict) else []
        if not isinstance(imports, list): imports=[]
        cleaned, removed=_remove_webform_features_from_imports(imports)
        result['local_removed']=removed
        if removed:
            TAK_MAP_IMPORT_DIR.mkdir(parents=True, exist_ok=True)
            try:
                backup=TAK_MAP_IMPORT_DIR/('imports.pre-webform-cleanup.%s.json' % datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ'))
                atomic_write_json(backup, {'imports':imports})
            except Exception as e:
                result.setdefault('warnings',[]).append('Local import backup failed: '+str(e))
            atomic_write_json(TAK_MAP_IMPORT_FILE, {'imports':cleaned})
    except Exception as e:
        result['ok']=False; result.setdefault('warnings',[]).append('Local webform cleanup failed: '+str(e))
    pg_uris, cfg_errors=_candidate_ots_pg_uris()
    if cfg_errors:
        result['db_config_errors']=cfg_errors[:3]
    for uri in pg_uris[:2]:
        for table in ('cot','euds','eud_stats','markers','points'):
            try:
                cols,err=_pg_columns(uri,'public',table)
                if err or not cols:
                    continue
                cols_l={c.lower():c for c in cols}
                candidate_cols=[]
                for cand in ('sender_callsign','callsign','call_sign','uid','sender_uid','client_uid','clientuid','clientUid','device_uid','name','title','username','type','cot_type','event_type','source','xml','detail','event'):
                    c=cols_l.get(cand.lower())
                    if c and c not in candidate_cols:
                        candidate_cols.append(c)
                for c in cols:
                    lc=c.lower()
                    if any(tok in lc for tok in ('xml','detail','event','cot')) and c not in candidate_cols:
                        candidate_cols.append(c)
                if not candidate_cols:
                    continue
                cond=' OR '.join("coalesce(%s::text,'') ilike '%%webform%%'" % _pg_ident(c) for c in candidate_cols[:14])
                sql='with deleted as (delete from %s where %s returning 1) select count(*) from deleted' % (_pg_table_ref('public', table), cond)
                count,err=_pg_first_value(uri, sql, timeout=20)
                result['db'].append({'table':table,'deleted':int(count or 0) if not err else 0,'ok':not bool(err),'error':err})
            except Exception as e:
                result['db'].append({'table':table,'ok':False,'error':str(e)})
    return result


def tak_map_imported():
    data=load_json_file(TAK_MAP_IMPORT_FILE, {'imports':[]})
    if not isinstance(data, dict): data={'imports':[]}
    edits=_load_popup_edits()
    imports=[]
    for imp in data.get('imports') or []:
        if not isinstance(imp, dict):
            continue
        cp=dict(imp)
        cp['features']=[x for x in (_apply_popup_edit(f, edits) for f in (imp.get('features') or [])) if x]
        imports.append(cp)
    webform_features=[x for x in (_apply_popup_edit(f, edits) for f in _webform_features_from_ots()) if x]
    if webform_features:
        imports.append({'id':'webform-live','name':'Webform Reports','uploaded':datetime.now(timezone.utc).isoformat(),'size_bytes':0,'features':webform_features,'counts':_import_summary(webform_features),'source':'Webform'})
    return {'ok':True,'imports':imports}

def tak_map_clear_imports():
    TAK_MAP_IMPORT_DIR.mkdir(parents=True, exist_ok=True)
    atomic_write_json(TAK_MAP_IMPORT_FILE, {'imports':[]})
    return {'ok':True,'imports':[]}

def _parse_multipart_files(content_type, body):
    m=re.search(r'boundary=(?:"([^"]+)"|([^;]+))', str(content_type or ''), re.I)
    if not m:
        return []
    boundary=(m.group(1) or m.group(2) or '').strip()
    if not boundary:
        return []
    sep=b'--' + boundary.encode('utf-8','ignore')
    files=[]
    for part in body.split(sep):
        part=part.strip(b'\r\n')
        if not part or part==b'--':
            continue
        if part.endswith(b'--'):
            part=part[:-2].strip(b'\r\n')
        head, marker, payload = part.partition(b'\r\n\r\n')
        if not marker:
            continue
        headers=head.decode('utf-8','replace')
        disp=''
        for line in headers.splitlines():
            if line.lower().startswith('content-disposition:'):
                disp=line
                break
        if 'filename=' not in disp.lower():
            continue
        fm=re.search(r'filename="([^"]*)"', disp, re.I) or re.search(r'filename=([^;\s]+)', disp, re.I)
        filename=(fm.group(1) if fm else 'imported').strip().strip('"')
        payload=payload.rstrip(b'\r\n')
        if filename and payload:
            files.append((os.path.basename(filename), payload))
    return files

def handle_tak_map_import_upload(handler):
    try:
        ctype=handler.headers.get('Content-Type','')
        if 'multipart/form-data' not in ctype.lower():
            return handler._send_json({'ok':False,'error':'Expected multipart/form-data upload.'},400)
        n=int(handler.headers.get('Content-Length','0') or '0')
        if n <= 0:
            return handler._send_json({'ok':False,'error':'No upload body received.'},400)
        if n > 90*1024*1024:
            return handler._send_json({'ok':False,'error':'Import upload is too large. Limit is 90 MB per request.'},413)
        body=handler.rfile.read(n)
        uploaded=_parse_multipart_files(ctype, body)
        if not uploaded:
            return handler._send_json({'ok':False,'error':'No files found in upload.'},400)
        current=load_json_file(TAK_MAP_IMPORT_FILE, {'imports':[]})
        imports=current.get('imports') if isinstance(current, dict) else []
        if not isinstance(imports, list): imports=[]
        added=[]
        for filename, blob in uploaded:
            features=parse_map_file_bytes(filename, blob)
            imp={'id':secrets.token_hex(6),'name':filename,'uploaded':datetime.now(timezone.utc).isoformat(),'size_bytes':len(blob),'features':features[:1500],'counts':_import_summary(features)}
            imports.append(imp); added.append(imp)
        imports=imports[-30:]
        TAK_MAP_IMPORT_DIR.mkdir(parents=True, exist_ok=True)
        atomic_write_json(TAK_MAP_IMPORT_FILE, {'imports':imports})
        return handler._send_json({'ok':True,'added':added,'imports':imports})
    except Exception as e:
        return handler._send_json({'ok':False,'error':str(e)},500)


def tak_map_local_data_delete(ids):
    ids=set((str(x or '')[7:] if str(x or '').startswith('import:') else str(x or '')) for x in (ids or []) if str(x or '').strip())
    if not ids:
        return {'ok':False,'error':'No imported local-data items selected.'}
    data=load_json_file(TAK_MAP_IMPORT_FILE, {'imports':[]})
    imports=data.get('imports') if isinstance(data, dict) else []
    changed=False
    out=[]
    for imp in imports or []:
        imp_id=str(imp.get('id') or imp.get('name') or '')
        new_feats=[]
        for idx,f in enumerate(imp.get('features') or []):
            local=f'{imp_id}:{idx}'
            if local in ids:
                changed=True
                continue
            new_feats.append(f)
        imp=dict(imp)
        imp['features']=new_feats
        imp['counts']=_import_summary(new_feats)
        if new_feats:
            out.append(imp)
        elif imp_id+':0' not in ids:
            # Keep non-feature/other imports only if they were not explicitly emptied by selection.
            pass
    if changed:
        TAK_MAP_IMPORT_DIR.mkdir(parents=True, exist_ok=True)
        atomic_write_json(TAK_MAP_IMPORT_FILE, {'imports':out})
    return {'ok':True,'imports':out,'deleted':changed}


def _local_data_feature_kind(feature):
    s=str((feature or {}).get('kind') or (feature or {}).get('geometry') or (feature or {}).get('geometry_type') or (feature or {}).get('type') or '').lower()
    if any(x in s for x in ('route','track','line')):
        return 'route'
    if any(x in s for x in ('polygon','shape','area','rectangle','ellipse','circle')):
        return 'shape'
    return 'point'

def _local_data_flat_points(value):
    pts=[]
    def walk(x):
        if isinstance(x, (list, tuple)):
            if len(x)>=2 and all(isinstance(v, (int,float)) for v in x[:2]):
                lat=float(x[0]); lon=float(x[1])
                if -90 <= lat <= 90 and -180 <= lon <= 180:
                    pts.append([lat,lon])
            else:
                for y in x:
                    walk(y)
        elif isinstance(x, dict):
            lat=_coerce_float(x.get('lat') or x.get('latitude'))
            lon=_coerce_float(x.get('lon') or x.get('lng') or x.get('longitude'))
            if lat is not None and lon is not None and -90 <= lat <= 90 and -180 <= lon <= 180:
                pts.append([lat,lon])
    walk(value)
    return pts

def _local_data_feature_points(feature):
    f=feature or {}
    pts=[]
    if isinstance(f.get('coords'), list):
        pts=_local_data_flat_points(f.get('coords'))
    if not pts:
        lat=_coerce_float(f.get('lat') or f.get('latitude'))
        lon=_coerce_float(f.get('lon') or f.get('lng') or f.get('longitude'))
        if lat is not None and lon is not None and -90 <= lat <= 90 and -180 <= lon <= 180:
            pts=[[lat,lon]]
    out=[]
    for pnt in pts:
        if not out or abs(out[-1][0]-pnt[0])>1e-10 or abs(out[-1][1]-pnt[1])>1e-10:
            out.append(pnt)
    return out

def _selected_local_data_features(ids):
    wanted=set((str(x or '')[7:] if str(x or '').startswith('import:') else str(x or '')) for x in (ids or []) if str(x or '').strip())
    if not wanted:
        return []
    data=load_json_file(TAK_MAP_IMPORT_FILE, {'imports':[]})
    imports=data.get('imports') if isinstance(data, dict) else []
    edits=_load_popup_edits()
    out=[]
    for imp in imports or []:
        imp_id=str(imp.get('id') or imp.get('name') or '')
        for idx,feat in enumerate(imp.get('features') or []):
            local_id=f'{imp_id}:{idx}'
            if local_id not in wanted:
                continue
            f=dict(feat or {})
            f.setdefault('source', imp.get('name') or 'Local Data')
            f['import_id']=imp_id
            f['import_name']=imp.get('name') or ''
            f['_local_id']=local_id
            f=_apply_popup_edit(f, edits)
            if f:
                out.append(f)
    return out

def _local_data_geojson_bytes(features):
    gj={'type':'FeatureCollection','features':[]}
    for f in features or []:
        kind=_local_data_feature_kind(f)
        pts=_local_data_feature_points(f)
        if not pts:
            continue
        if kind=='point':
            geom={'type':'Point','coordinates':[pts[0][1],pts[0][0]]}
        elif kind=='route':
            if len(pts)<2: continue
            geom={'type':'LineString','coordinates':[[p[1],p[0]] for p in pts]}
        else:
            if len(pts)<3: continue
            ring=[[p[1],p[0]] for p in pts]
            if ring[0] != ring[-1]: ring.append(ring[0])
            geom={'type':'Polygon','coordinates':[ring]}
        props={k:v for k,v in (f.get('properties') or {}).items()} if isinstance(f.get('properties'), dict) else {}
        props.update({'name':f.get('name') or f.get('callsign') or f.get('title') or f.get('uid') or f.get('id') or 'Local Data','source':f.get('import_name') or f.get('source') or 'Local Data','kind':kind})
        gj['features'].append({'type':'Feature','geometry':geom,'properties':props})
    return json.dumps(gj, indent=2).encode('utf-8')

def _local_data_kml_bytes(features, title='TAK Map Local Data'):
    ns='http://www.opengis.net/kml/2.2'
    ET.register_namespace('', ns)
    kml=ET.Element('{%s}kml' % ns)
    doc=ET.SubElement(kml, '{%s}Document' % ns)
    ET.SubElement(doc, '{%s}name' % ns).text=title
    for f in features or []:
        kind=_local_data_feature_kind(f)
        pts=_local_data_feature_points(f)
        if not pts:
            continue
        pm=ET.SubElement(doc, '{%s}Placemark' % ns)
        ET.SubElement(pm, '{%s}name' % ns).text=str(f.get('name') or f.get('callsign') or f.get('title') or f.get('uid') or f.get('id') or 'Local Data')
        desc=[]
        for k,v in (('Source',f.get('import_name') or f.get('source') or 'Local Data'),('Kind',kind),('Type',f.get('type') or f.get('cot_type') or ''),('Notes',f.get('notes') or f.get('remarks') or f.get('description') or '')):
            if v:
                desc.append(f'{k}: {v}')
        if desc:
            ET.SubElement(pm, '{%s}description' % ns).text='\n'.join(map(str,desc))
        if kind=='point' or len(pts)==1:
            pt=ET.SubElement(pm, '{%s}Point' % ns)
            ET.SubElement(pt, '{%s}coordinates' % ns).text=f'{pts[0][1]:.7f},{pts[0][0]:.7f},0'
        elif kind=='route':
            line=ET.SubElement(pm, '{%s}LineString' % ns)
            ET.SubElement(line, '{%s}tessellate' % ns).text='1'
            ET.SubElement(line, '{%s}coordinates' % ns).text=' '.join(f'{p[1]:.7f},{p[0]:.7f},0' for p in pts)
        else:
            if len(pts)<3:
                continue
            ring_pts=list(pts)
            if ring_pts[0] != ring_pts[-1]: ring_pts.append(ring_pts[0])
            poly=ET.SubElement(pm, '{%s}Polygon' % ns)
            ET.SubElement(poly, '{%s}tessellate' % ns).text='1'
            outer=ET.SubElement(poly, '{%s}outerBoundaryIs' % ns)
            ring=ET.SubElement(outer, '{%s}LinearRing' % ns)
            ET.SubElement(ring, '{%s}coordinates' % ns).text=' '.join(f'{p[1]:.7f},{p[0]:.7f},0' for p in ring_pts)
    return ('<?xml version="1.0" encoding="UTF-8"?>\n' + ET.tostring(kml, encoding='unicode')).encode('utf-8')

def tak_map_local_data_mission_publish(ids, kind='', mission_name='', server_host=''):
    features=_selected_local_data_features(ids)
    if not features:
        return {'ok':False,'error':'No selected Local Data items were found.'}
    k=str(kind or '').strip().lower() or 'items'
    singular={'points':'Point','routes':'Route','shapes':'Shape','point':'Point','route':'Route','shape':'Shape'}.get(k,'Local Data')
    plural=singular if len(features)==1 else singular + 's'
    label=f'TAK Map Local {plural}'
    TAK_MAP_OFFLINE_PACKAGE_DIR.mkdir(parents=True, exist_ok=True)
    stamp=datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')
    safe_label=_safe_filename_label(label, 'zip')[:-4]
    package_uid=str(uuid.uuid4())
    kml_name=_safe_filename_label(label, 'kml')
    geojson_name=_safe_filename_label(label, 'geojson')
    kml_bytes=_local_data_kml_bytes(features, label)
    geojson_bytes=_local_data_geojson_bytes(features)
    content_dir=hashlib.md5((package_uid+kml_name).encode('utf-8')).hexdigest()
    kml_entry=content_dir + '/' + kml_name
    geojson_entry=content_dir + '/' + geojson_name
    root=ET.Element('MissionPackageManifest', {'version':'2'})
    cfg=ET.SubElement(root, 'Configuration')
    ET.SubElement(cfg, 'Parameter', {'name':'uid', 'value':package_uid})
    ET.SubElement(cfg, 'Parameter', {'name':'name', 'value':label})
    ET.SubElement(cfg, 'Parameter', {'name':'onReceiveImport', 'value':'true'})
    ET.SubElement(cfg, 'Parameter', {'name':'onReceiveDelete', 'value':'true'})
    contents=ET.SubElement(root, 'Contents')
    c=ET.SubElement(contents, 'Content', {'ignore':'false', 'zipEntry':kml_entry})
    ET.SubElement(c, 'Parameter', {'name':'name', 'value':kml_name})
    ET.SubElement(c, 'Parameter', {'name':'contentType', 'value':'External Native Data'})
    ET.SubElement(c, 'Parameter', {'name':'visible', 'value':'true'})
    c2=ET.SubElement(contents, 'Content', {'ignore':'false', 'zipEntry':geojson_entry})
    ET.SubElement(c2, 'Parameter', {'name':'name', 'value':geojson_name})
    ET.SubElement(c2, 'Parameter', {'name':'contentType', 'value':'External Native Data'})
    ET.SubElement(c2, 'Parameter', {'name':'visible', 'value':'false'})
    manifest_text='<?xml version="1.0" encoding="UTF-8"?>\n' + ET.tostring(root, encoding='unicode', short_empty_elements=True)
    zip_name=f'{safe_label}-{stamp}.zip'
    zip_id=_safe_offline_id('local-data-mission-' + hashlib.sha256((package_uid+stamp).encode()).hexdigest()[:10])
    zip_path=TAK_MAP_OFFLINE_PACKAGE_DIR/(zip_id + '.zip')
    with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zf:
        def write_stable(name, data):
            info=zipfile.ZipInfo(name)
            info.date_time=(2024,1,1,0,0,0)
            info.compress_type=zipfile.ZIP_DEFLATED
            zf.writestr(info, data)
        write_stable('MANIFEST/manifest.xml', manifest_text.encode('utf-8'))
        write_stable(kml_entry, kml_bytes)
        write_stable(geojson_entry, geojson_bytes)
        write_stable(kml_name, kml_bytes)
        write_stable(geojson_name, geojson_bytes)
    sha=hashlib.sha256(zip_path.read_bytes()).hexdigest()
    res=tak_map_publish_package_to_mission(zip_path, zip_name, sha, mission_name, label, 'local-data', server_host, '')
    res['package']={'path':str(zip_path),'package_name':zip_name,'sha256':sha,'feature_count':len(features),'kml_name':kml_name,'geojson_name':geojson_name}
    return res

def _extract_route_points_from_text(txt):
    txt=str(txt or '')
    pts=[]
    # ATAK route links often carry point="lat,lon,hae" or point="lat,lon".
    for m in re.finditer(r'\bpoint=["\']\s*([-+0-9.]+)\s*,\s*([-+0-9.]+)(?:\s*,\s*[-+0-9.]+)?\s*["\']', txt, re.I):
        lat=_coerce_float(m.group(1)); lon=_coerce_float(m.group(2))
        if lat is not None and lon is not None and -90<=lat<=90 and -180<=lon<=180 and not (abs(lat)<0.000001 and abs(lon)<0.000001):
            pts.append([lat,lon])
    # Some route XML/JSON stores control points as adjacent lat/lon attributes or fields.
    for m in re.finditer(r'(?:lat|latitude)["\']?\s*[:=]\s*["\']?([-+0-9.]+)["\']?[^\n\r{}<>]{0,160}?(?:lon|lng|longitude)["\']?\s*[:=]\s*["\']?([-+0-9.]+)', txt, re.I):
        lat=_coerce_float(m.group(1)); lon=_coerce_float(m.group(2))
        if lat is not None and lon is not None and -90<=lat<=90 and -180<=lon<=180 and not (abs(lat)<0.000001 and abs(lon)<0.000001):
            pts.append([lat,lon])
    # Reverse-field order: lon/lng/longitude followed by lat/latitude.
    for m in re.finditer(r'(?:lon|lng|longitude)["\']?\s*[:=]\s*["\']?([-+0-9.]+)["\']?[^\n\r{}<>]{0,160}?(?:lat|latitude)["\']?\s*[:=]\s*["\']?([-+0-9.]+)', txt, re.I):
        lon=_coerce_float(m.group(1)); lat=_coerce_float(m.group(2))
        if lat is not None and lon is not None and -90<=lat<=90 and -180<=lon<=180 and not (abs(lat)<0.000001 and abs(lon)<0.000001):
            pts.append([lat,lon])
    # GeoJSON/KML-ish raw numeric coordinate pairs in [lon,lat] order.
    if 'coordinates' in txt.lower() or '<coordinates' in txt.lower():
        for m in re.finditer(r'[-+]?\d+(?:\.\d+)?\s*,\s*[-+]?\d+(?:\.\d+)?(?:\s*,\s*[-+]?\d+(?:\.\d+)?)?', txt):
            parts=[_coerce_float(x) for x in re.split(r'\s*,\s*', m.group(0))[:2]]
            if len(parts)>=2 and parts[0] is not None and parts[1] is not None:
                lon,lat=parts[0],parts[1]
                if -90<=lat<=90 and -180<=lon<=180 and not (abs(lat)<0.000001 and abs(lon)<0.000001):
                    pts.append([lat,lon])
    # Dedupe while preserving order.
    out=[]; seen=set()
    for p in pts:
        k=(round(p[0],7), round(p[1],7))
        if k in seen: continue
        seen.add(k); out.append([k[0],k[1]])
    return out

def _parse_inline_map_features_from_text(txt, source_name='Data Sync'):
    txt=str(txt or '')
    low=txt.lower()
    feats=[]
    if '{' in txt and ('"features"' in low or '"geometry"' in low or "'features'" in low):
        # Try to find whole string JSON first.
        try:
            obj=json.loads(txt)
            feats.extend(_parse_geojson_obj(obj, source_name))
        except Exception:
            pass
    if '<kml' in low or '<placemark' in low or '<linestring' in low or '<polygon' in low:
        feats.extend(_parse_kml_bytes(txt.encode('utf-8','replace'), source_name))
    if '<gpx' in low or '<trkpt' in low or '<rtept' in low:
        feats.extend(_parse_gpx_bytes(txt.encode('utf-8','replace'), source_name))
    # ATAK route/detail fallback: if text is route-like and includes multiple CoT point elements, make one route.
    if ('route' in low or 'b-m-r' in low or 'u-r' in low) and txt.count('<point') >= 2:
        pts=[]
        for m in re.finditer(r'<point\b[^>]*\blat=["\']([-+0-9.]+)["\'][^>]*\blon=["\']([-+0-9.]+)["\']', txt, re.I):
            lat=_coerce_float(m.group(1)); lon=_coerce_float(m.group(2))
            if lat is not None and lon is not None and -90<=lat<=90 and -180<=lon<=180:
                pts.append([lat,lon])
        if len(pts)>=2:
            feats.append({'kind':'route','geometry':'route','name':source_name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':{'source_format':'CoT route/detail points','points':len(pts)},'source':source_name})
    if not feats and ('route' in low or 'b-m-r' in low or 'u-r' in low or 'checkpoint' in low or '<link' in low):
        pts=_extract_route_points_from_text(txt)
        if len(pts)>=2:
            feats.append({'kind':'route','geometry':'route','name':source_name,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':{'source_format':'ATAK route/link control points','points':len(pts)},'source':source_name})
    return feats

def _row_route_like(row, source_key=''):
    if not isinstance(row, dict):
        blob=str(source_key).lower()
    else:
        blob=' '.join(str(x or '') for x in [source_key, row.get('type'), row.get('cot_type'), row.get('uid'), row.get('name'), row.get('title'), row.get('filename'), row.get('content_type'), row.get('category')]).lower()
        # OTS/ATAK routes are often buried inside XML/JSON payload columns whose
        # column names are generic. Sample a bounded amount of row text so route
        # candidates are visible instead of silently omitted.
        try:
            blob += ' ' + ' '.join(str(x or '')[:4000] for x in _row_text_values(row)).lower()
        except Exception:
            pass
    return any(tok in blob for tok in ('route','gpx','track','path','checkpoint','waypoint','b-m-r','u-r','<link','__routeinfo','rtept','trkpt','linestring'))

def _row_shape_like(row, source_key=''):
    blob=' '.join(str(x or '') for x in [source_key, row.get('type'), row.get('cot_type'), row.get('uid'), row.get('name'), row.get('title'), row.get('filename'), row.get('content_type'), row.get('category')]).lower() if isinstance(row, dict) else str(source_key).lower()
    return any(tok in blob for tok in ('shape','polygon','area','circle','rectangle','freehand','sector','corridor'))

def _extract_data_sync_objects(rows_by_key):
    """Extract previewable map objects from OTS Mission/Data Sync rows.

    Routes and shapes are detected before point extraction so ATAK/EUD route
    rows do not render as a single wrong-location point marker just because an
    associated row contains a representative lat/lon.
    """
    objects=[]
    seen=set()
    for source_key, rows in (rows_by_key or {}).items():
        for row in rows or []:
            if not isinstance(row, dict):
                continue
            row_label=str(_row_ci_get(row, ('name','title','callsign','uid','filename','id'), source_key) or source_key)
            route_like=_row_route_like(row, source_key)
            shape_like=_row_shape_like(row, source_key)
            parsed_features=[]
            # Parse rich map geometry from any embedded KML/GPX/GeoJSON/CoT route content.
            for txt in _row_text_values(row):
                parsed_features.extend(_parse_inline_map_features_from_text(txt, row_label))
                if len(parsed_features) > 50:
                    break
            if not parsed_features and route_like:
                try:
                    pts=_extract_route_points_from_text(json.dumps(row, default=str))
                except Exception:
                    pts=[]
                if len(pts)>=2:
                    parsed_features.append({'kind':'route','geometry':'route','name':row_label,'lat':pts[0][0],'lon':pts[0][1],'coords':pts,'properties':{'source_format':'Data Sync route fields','points':len(pts)},'source':str(source_key)})
            if parsed_features:
                for f in parsed_features:
                    f['source']='OpenTAKServer Data Sync ' + str(source_key)
                    f.setdefault('id', secrets.token_hex(5))
                    f.setdefault('uid', str(_row_ci_get(row, ('uid','guid','id'), '') or ''))
                    f.setdefault('type', str(_row_ci_get(row, ('type','cot_type','content_type','category'), f.get('kind','Data Sync')) or f.get('kind','Data Sync')))
                    f.setdefault('added', str(_row_ci_get(row, ('created_at','create_datetime','created','updated','update_time','time','start'), '') or ''))
                    key=(f.get('uid') or f.get('id') or f.get('name') or '') + ':' + str(f.get('kind')) + ':' + str(f.get('coords') or f.get('lat'))[:200]
                    key=key.lower()
                    if key in seen: continue
                    seen.add(key); objects.append(f)
                    if len(objects) >= 500: return objects
                continue
            # If the row looks like a route/shape but no usable geometry was found,
            # do not fall back to a single point marker. Instead, show it as an
            # unparsed candidate in the menu so route storage problems are visible.
            if route_like or shape_like:
                cand_kind='route' if route_like else 'shape'
                cand={'kind':cand_kind,'geometry':cand_kind,'name':row_label,'uid':str(_row_ci_get(row, ('uid','guid','id'), '') or ''),'type':str(_row_ci_get(row, ('type','cot_type','content_type','category'), cand_kind) or cand_kind),'source':'OpenTAKServer Data Sync ' + str(source_key),'added':str(_row_ci_get(row, ('created_at','create_datetime','created','updated','update_time','time','start'), '') or ''),'coords':[],'properties':{'unparsed':True,'reason':'Route/shape-like Data Sync row found but no ordered geometry/control points could be parsed.','table':str(source_key),'available_fields':', '.join(list(row.keys())[:24])}}
                key=(cand.get('uid') or cand.get('name') or str(source_key)).lower()+':candidate:'+cand_kind
                if key not in seen:
                    seen.add(key); objects.append(cand)
                    if len(objects) >= 500: return objects
                continue
            m=_normalize_tak_marker(row, source_key, 'datasync')
            if not m:
                continue
            m['kind']='datasync'
            m['geometry']='point'
            m['coords']=[[m.get('lat'), m.get('lon')]]
            m['source']='OpenTAKServer Data Sync ' + str(source_key)
            m['added']=m.get('updated') or str(_row_ci_get(row, ('created_at','create_datetime','created','time','start'), '') or '')
            key=(m.get('uid') or m.get('id') or m.get('callsign') or f"{m.get('lat')},{m.get('lon')}").lower()
            if key in seen:
                continue
            seen.add(key)
            objects.append(m)
            if len(objects) >= 500:
                return objects
    return objects

def tak_map_data_sync():
    """Summarize OpenTAKServer Mission API / ATAK Data Sync tables."""
    out={'ok':True,'missions':[],'mission_content':[],'mission_logs':[],'mission_roles':[],'mission_uids':[],'mission_content_mission':[],'packages':[],'objects':[],'sources':[],'error':''}
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if cfg_errors:
        out['sources'].extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    if not pg_uris:
        out['ok']=False; out['error']='No OpenTAKServer PostgreSQL URI found.'; return out
    table_map={
        'missions':'missions',
        'mission_content':'mission_content',
        'mission_logs':'mission_logs',
        'mission_roles':'mission_roles',
        'mission_uids':'mission_uids',
        'mission_content_mission':'mission_content_mission',
        'packages':'packages',
    }
    rows_by_key={}
    for uri in pg_uris[:1]:
        for key,table in table_map.items():
            rows,err=_pg_table_rows(uri, table, 120 if key!='mission_logs' else 80)
            if err:
                out['sources'].append({'source':'postgres:'+table,'ok':False,'error':err[:160]})
                continue
            out[key]=rows
            rows_by_key[key]=rows
            out['sources'].append({'source':'postgres:'+table,'ok':True,'rows':len(rows)})
        break
    edits=_load_popup_edits()
    out['objects']=[x for x in (_apply_popup_edit(o, edits) for o in _extract_data_sync_objects(rows_by_key)) if x]
    out['popup_edits_count']=len((_load_popup_edits().get('items') or {}))
    return out

def tak_map_routes():
    # Legacy file-system route scanner disabled. Local Data routes come from imported/staged content.
    # Avoid scanning /root/ots/routes or other inaccessible paths in the normal UI.
    return {'ok':True,'routes':[],'roots':[],'scanner':'disabled'}

def _read_json_url(url, timeout=4):
    try:
        req=Request(url, headers={'User-Agent':'tak-server-dash/1.2.8'})
        with urlopen(req, timeout=timeout) as resp:
            return json.loads(resp.read(4*1024*1024).decode('utf-8','replace'))
    except Exception:
        return None


def _default_adsb_settings():
    try:
        default_radius=max(1, min(250, int(round(float(os.environ.get('TAK_DASH_ADSB_RADIUS_MILES','5') or 5)))))
    except Exception:
        default_radius=5
    try:
        default_interval=max(1, min(300, int(round(float(os.environ.get('TAK_DASH_ADSB_UPDATE_INTERVAL_SECONDS', os.environ.get('TAK_DASH_ADSB_UPDATE_INTERVAL','5')) or 5)))))
    except Exception:
        default_interval=5
    return {
        'radius_miles': default_radius,
        'center_source': os.environ.get('TAK_DASH_ADSB_CENTER_SOURCE','manual').strip() or 'manual',
        'center_lat': _coerce_float(os.environ.get('TAK_DASH_ADSB_CENTER_LAT','')),
        'center_lon': _coerce_float(os.environ.get('TAK_DASH_ADSB_CENTER_LON','')),
        'update_interval_seconds': default_interval,
        'apply_to_ots': False,
        'updated': '',
    }

def _load_adsb_settings():
    d=_default_adsb_settings()
    try:
        if TAK_MAP_ADSB_SETTINGS_FILE.exists():
            j=json.loads(TAK_MAP_ADSB_SETTINGS_FILE.read_text())
            if isinstance(j, dict):
                d.update(j)
    except Exception:
        pass
    try:
        d['radius_miles']=max(1, min(250, int(round(float(d.get('radius_miles') or 5)))))
    except Exception:
        d['radius_miles']=5
    try:
        d['update_interval_seconds']=max(1, min(300, int(round(float(d.get('update_interval_seconds') or d.get('update_interval') or 5)))))
    except Exception:
        d['update_interval_seconds']=5
    d['stale_seconds']=60
    d['center_lat']=_coerce_float(d.get('center_lat'))
    d['center_lon']=_coerce_float(d.get('center_lon'))
    d['center_source']=str(d.get('center_source') or 'manual')
    d['has_center']=d.get('center_lat') is not None and d.get('center_lon') is not None
    return d

def _save_adsb_settings(payload):
    payload=payload or {}
    cur=_load_adsb_settings()
    out={}
    out['radius_miles']=max(1, min(250, int(round(float(payload.get('radius_miles', cur.get('radius_miles') or 5))))))
    out['center_source']=str(payload.get('center_source') or cur.get('center_source') or 'manual').strip()[:64]
    out['center_lat']=_coerce_float(payload.get('center_lat', cur.get('center_lat')))
    out['center_lon']=_coerce_float(payload.get('center_lon', cur.get('center_lon')))
    if out['center_lat'] is not None and not (-90 <= out['center_lat'] <= 90): out['center_lat']=None
    if out['center_lon'] is not None and not (-180 <= out['center_lon'] <= 180): out['center_lon']=None
    try:
        out['update_interval_seconds']=max(1, min(300, int(round(float(payload.get('update_interval_seconds', payload.get('update_interval', cur.get('update_interval_seconds') or 5)))))))
    except Exception:
        out['update_interval_seconds']=int(cur.get('update_interval_seconds') or 5)
    out['stale_seconds']=60
    out['updated']=datetime.now(timezone.utc).isoformat()
    TAK_MAP_ADSB_SETTINGS_FILE.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_json(TAK_MAP_ADSB_SETTINGS_FILE, out)
    apply_to_ots=bool(payload.get('apply_to_ots'))
    ots={'attempted':False,'ok':False,'message':'ADS-B settings saved locally only.'}
    if apply_to_ots:
        if out['center_lat'] is None or out['center_lon'] is None:
            ots={'attempted':True,'ok':False,'message':'Apply to OTS requires valid ADS-B center latitude and longitude.'}
        else:
            ots=_apply_adsb_settings_to_ots_config(out)
    result={'ok':True,'settings':_load_adsb_settings(),'ots':ots}
    return result

def _haversine_miles(lat1, lon1, lat2, lon2):
    try:
        r=3958.7613
        p1=math.radians(float(lat1)); p2=math.radians(float(lat2))
        dp=math.radians(float(lat2)-float(lat1)); dl=math.radians(float(lon2)-float(lon1))
        a=math.sin(dp/2)**2+math.cos(p1)*math.cos(p2)*math.sin(dl/2)**2
        return r*2*math.atan2(math.sqrt(a), math.sqrt(1-a))
    except Exception:
        return None

def _adsb_stale_seconds(settings=None):
    # v237: ADS-B map-side stale timeout is fixed at 60 seconds.
    # Do not derive stale timing from update interval; that proved too restrictive
    # for OTS/plugin-backed ADS-B rows.
    return 60

def _adsb_in_radius(ac, settings=None):
    settings=settings or _load_adsb_settings()
    if not settings.get('has_center'):
        return True
    d=_haversine_miles(settings.get('center_lat'), settings.get('center_lon'), ac.get('lat'), ac.get('lon'))
    if d is None:
        return False
    ac['range_miles']=round(float(d), 2)
    return float(d) <= float(settings.get('radius_miles') or 5)

def _candidate_ots_adsb_config_paths():
    """Return candidate OTS config files for ADS-B settings updates.

    Do not redefine _candidate_ots_config_paths() here; TAK Map login/auth
    depends on the earlier broader OpenTAKServer config discovery helper.
    v229 accidentally shadowed that helper and broke login on installs where
    the OTS config is under a user home or supplied by TAK_DASH_* env vars.
    """
    paths=[]
    # Reuse the main OTS config discovery path used by login/auth.
    try:
        paths.extend(_candidate_ots_config_paths())
    except Exception:
        pass
    for name in ('OTS_CONFIG','OPENTAKSERVER_CONFIG'):
        env=os.environ.get(name,'').strip()
        if env:
            paths.append(Path(env).expanduser())
    for raw in ('/opt/opentakserver/config.yml','/opt/opentakserver/config.yaml','/etc/opentakserver/config.yml','/etc/opentakserver/config.yaml','/var/lib/opentakserver/config.yml','/usr/local/share/opentakserver/config.yml'):
        paths.append(Path(raw))
    seen=[]
    out=[]
    for p in paths:
        try:
            k=str(p.resolve())
        except Exception:
            k=str(p)
        if k not in seen:
            seen.append(k); out.append(p)
    return out

def _find_ots_config_file():
    for p in _candidate_ots_adsb_config_paths():
        try:
            if p.exists() and p.is_file(): return p
        except Exception:
            pass
    return None

def _apply_adsb_settings_to_ots_config(settings):
    res={'attempted':True,'ok':False,'config_path':'','backup_path':'','restarted':False,'message':''}
    cfg=_find_ots_config_file()
    if not cfg:
        res['message']='OTS config.yml not found; TAK Map ADS-B filter settings were saved locally only.'
        return res
    res['config_path']=str(cfg)
    # Prefer the install-time privileged helper. The dashboard service normally
    # cannot write under a real user's /home/.../ots directory, so direct writes
    # can fail with Permission denied on config.yml.tmp.
    helper=Path('/usr/local/sbin/tak-map-action')
    if helper.exists():
        lat='' if settings.get('center_lat') is None else str(settings.get('center_lat'))
        lon='' if settings.get('center_lon') is None else str(settings.get('center_lon'))
        r=run_cmd(['sudo','-n',str(helper),'adsb-update-ots-config',str(cfg),lat,lon],75)
        out=(str(r.get('stdout') or '')+'\n'+str(r.get('stderr') or '')).strip()
        res['restarted']=bool(r.get('ok'))
        res['ok']=bool(r.get('ok'))
        res['message']='OTS config updated and opentakserver restarted.' if r.get('ok') else ('Failed to update OTS config via helper: '+out[:500])
        for line in str(r.get('stdout') or '').splitlines():
            if line.startswith('BACKUP_PATH='):
                res['backup_path']=line.split('=',1)[1].strip()
        return res
    # Direct fallback for unusual installs where the dashboard service can write the OTS config.
    try:
        lat=settings.get('center_lat'); lon=settings.get('center_lon')
        if lat is None or lon is None or not (-90 <= float(lat) <= 90) or not (-180 <= float(lon) <= 180):
            res['message']='Invalid ADS-B latitude/longitude; OTS config was not changed.'
            return res
        raw=cfg.read_text()
        backups=CONFIG_BACKUP_DIR/'opentakserver'
        backups.mkdir(parents=True, exist_ok=True)
        stamp=datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')
        backup=backups/(cfg.name+'.adsb-'+stamp+'.bak')
        shutil.copy2(cfg, backup)
        res['backup_path']=str(backup)
        def fmt_coord(v):
            return f"{float(v):.6f}"
        def update_yaml_line(text, key, value):
            value=fmt_coord(value)
            pat=re.compile(r'^(\s*'+re.escape(key)+r'\s*:\s*)([^#\r\n]*)(\s*(?:#.*)?)$', re.M)
            if pat.search(text):
                return pat.sub(lambda m: m.group(1)+value+(m.group(3) or ''), text, count=1)
            if text and not text.endswith('\n'):
                text+='\n'
            return text+f'{key}: {value}\n'
        rendered=update_yaml_line(update_yaml_line(raw,'OTS_ADSB_LAT',lat),'OTS_ADSB_LON',lon)
        tmp=cfg.with_name(cfg.name+f'.takdash-{os.getpid()}.tmp')
        tmp.write_text(rendered)
        shutil.copystat(cfg, tmp, follow_symlinks=True)
        os.replace(tmp, cfg)
        r=run_cmd(['sudo','-n','systemctl','restart','opentakserver'],45)
        res['restarted']=bool(r.get('ok'))
        res['ok']=bool(r.get('ok'))
        res['message']='OTS config updated and opentakserver restarted.' if r.get('ok') else ('OTS config updated, but restart failed: '+str(r.get('stderr') or r.get('stdout') or r.get('rc'))[:500])
        return res
    except Exception as e:
        res['message']='Failed to update OTS config: '+str(e)
        return res

def _candidate_aircraft_json_sources():
    sources=[]
    if TAK_DASH_ADSB_AIRCRAFT_JSON_URL:
        sources.append(('configured', TAK_DASH_ADSB_AIRCRAFT_JSON_URL))
    if TAK_DASH_ADSB_SOURCE in ('auto','local','dump1090','readsb'):
        for url in ('http://127.0.0.1:8080/data/aircraft.json','http://127.0.0.1/tar1090/data/aircraft.json','http://127.0.0.1:8080/tar1090/data/aircraft.json'):
            sources.append(('local-json', url))
    return sources

def _normalize_adsb_aircraft(item, source):
    lat=item.get('lat'); lon=item.get('lon')
    if lat is None or lon is None:
        return None
    try:
        lat=float(lat); lon=float(lon)
    except Exception:
        return None
    ident=str(item.get('flight') or item.get('callsign') or item.get('hex') or item.get('icao') or 'aircraft').strip()
    return {
        'id': str(item.get('hex') or item.get('icao') or ident).strip(),
        'callsign': ident,
        'lat': lat,
        'lon': lon,
        'altitude_ft': item.get('alt_baro') if item.get('alt_baro') != 'ground' else 0,
        'speed_kt': item.get('gs') or item.get('speed'),
        'track_deg': item.get('track') or item.get('true_heading') or item.get('mag_heading'),
        'seen_seconds': item.get('seen') or item.get('seen_pos'),
        'category': item.get('category') or item.get('type') or item.get('aircraft_type') or item.get('desc') or '',
        'type': item.get('category') or item.get('type') or item.get('aircraft_type') or item.get('t') or item.get('desc') or '',
        'aircraft_type': item.get('aircraft_type') or item.get('type') or item.get('t') or '',
        'description': item.get('desc') or item.get('description') or '',
        'emitter_category': item.get('category') or item.get('emitter_category') or '',
        'source': source,
    }

def tak_map_adsb():
    aircraft_by_id={}
    source_notes=[]
    settings=_load_adsb_settings()
    stale_seconds=_adsb_stale_seconds(settings)
    # Primary: OpenTAKServer ADS-B/CoT PostgreSQL data used by the OTS web map.
    try:
        pg_aircraft, pg_notes = _ots_pg_aircraft()
        source_notes.extend(pg_notes)
        for ac in pg_aircraft:
            key=str(ac.get('id') or ac.get('callsign') or '').strip().lower()
            if key:
                aircraft_by_id[key]=ac
    except Exception as e:
        source_notes.append({'source':'postgres:adsb','ok':False,'error':str(e)[:180]})
    # Secondary: direct local/remote dump1090/readsb/tar1090 aircraft.json feed.
    for source_name,url in _candidate_aircraft_json_sources():
        data=_read_json_url(url)
        if not isinstance(data,dict):
            source_notes.append({'source':source_name,'url':url,'ok':False})
            continue
        source_notes.append({'source':source_name,'url':url,'ok':True})
        for item in data.get('aircraft') or []:
            if not isinstance(item,dict): continue
            ac=_normalize_adsb_aircraft(item, source_name)
            if not ac: continue
            try:
                if ac.get('seen_seconds') is not None and float(ac.get('seen_seconds') or 999999) > stale_seconds:
                    continue
            except Exception:
                pass
            key=str(ac.get('id') or ac.get('callsign') or '').strip().lower()
            if not key: continue
            old=aircraft_by_id.get(key)
            if old is None or float(ac.get('seen_seconds') or 9999) < float(old.get('seen_seconds') or 9999):
                aircraft_by_id[key]=ac
    final=[]
    for ac in aircraft_by_id.values():
        try:
            lat=float(ac.get('lat')); lon=float(ac.get('lon'))
            if not (-90<=lat<=90 and -180<=lon<=180) or (abs(lat)<0.000001 and abs(lon)<0.000001):
                continue
            ac['lat']=lat; ac['lon']=lon
            if ac.get('seen_seconds') is not None and float(ac.get('seen_seconds') or 999999) > stale_seconds:
                continue
            if ac.get('updated') and _is_live_marker_stale(ac.get('updated'), stale_seconds):
                continue
            if not _adsb_in_radius(ac, settings):
                continue
        except Exception:
            continue
        final.append(ac)
    return {'ok':True,'aircraft':final,'sources':source_notes,'stale_seconds':stale_seconds,'settings':settings}




# --- v233 TAK Map EUD/status backend refinements ---
def _v233_uid_like(value):
    v=str(value or '').strip()
    if not v:
        return False
    if v.upper().startswith('ANDROID-'):
        return True
    if re.match(r'^[0-9a-f]{8}-[0-9a-f-]{27,}$', v, re.I):
        return True
    return False

def _v233_best_callsign(row=None, parsed=None, extra=None, fallback=''):
    row=row or {}; parsed=parsed or {}; extra=extra or {}
    candidates=[_row_ci_get(row, ('sender_callsign','callsign','call_sign','name','username','title'), ''), extra.get('callsign'), parsed.get('callsign'), parsed.get('creator_callsign'), parsed.get('parent_callsign'), fallback]
    for c in candidates:
        c=str(c or '').strip()
        if c and not _v233_uid_like(c) and c.lower() not in ('none','null','unknown','webform','tak-dashboard'):
            return c
    for c in candidates:
        c=str(c or '').strip()
        if c:
            return c
    return ''

def tak_map_euds():
    """v233: stable TAK-client-only EUD list with real user/callsign labels."""
    euds={}; notes=[]
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if cfg_errors:
        notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    def put(e, xml=''):
        if not isinstance(e, dict) or not _is_real_eud_candidate(e, xml):
            return
        uid=str(e.get('uid') or '').strip(); cs=str(e.get('callsign') or '').strip()
        if not cs or _v233_uid_like(cs):
            cs = cs if not _v233_uid_like(cs) else ''
        key=(uid or cs).lower()
        if not key:
            return
        e['callsign']=cs or (('UID '+uid[:10]+'...') if uid else 'TAK Client')
        old=euds.get(key)
        def score(x):
            try: age=float(x.get('location_age_seconds'))
            except Exception: age=999999
            return (20 if not _v233_uid_like(x.get('callsign')) else 0) + (10 if x.get('lat') is not None and x.get('lon') is not None else 0) - age/100000
        if old is None or score(e)>score(old):
            euds[key]=e
        else:
            old.update({k:v for k,v in e.items() if v not in (None,'') and old.get(k) in (None,'')})
    for uri in pg_uris[:2]:
        for table in ('euds','eud_stats'):
            rows,err=_pg_table_rows(uri, table, 800)
            if err: continue
            notes.append({'source':'postgres:'+table,'ok':True,'rows':len(rows)})
            for row in rows:
                if not isinstance(row, dict): continue
                extra=_parse_takv_and_team(row)
                uid=str(_row_ci_get(row, ('uid','client_uid','clientUid','clientuid','device_uid','cot_uid'), '') or '').strip()
                callsign=_v233_best_callsign(row, {}, extra, uid)
                lat=_coerce_float(_row_ci_get(row, ('lat','latitude','point_lat'), None)); lon=_coerce_float(_row_ci_get(row, ('lon','lng','longitude','point_lon'), None))
                updated=str(_row_ci_get(row, ('last_seen','updated','update_time','last_connection','last_login_at','current_login_at','start','stale'), '') or '')
                age=_age_seconds_from_value(updated)
                client=extra.get('client') or str(_row_ci_get(row, ('platform','client','takv_platform'), '') or '')
                version=extra.get('version') or str(_row_ci_get(row, ('version','takv_version','app_version'), '') or '')
                put({'uid':uid,'callsign':callsign,'client':client,'version':version,'client_label':' '.join([client,version]).strip(),'team':extra.get('team') or str(_row_ci_get(row, ('team','team_name','group','color'), '') or '').lower(),'lat':lat,'lon':lon,'updated':updated,'location_age_seconds':age,'status':'Online' if age is not None and age <= 180 else ('Recent' if age is not None and age <= 900 else 'Unknown'),'source':table}, '')
        rows,err=_pg_table_rows(uri, 'cot', 1800)
        if not err:
            notes.append({'source':'postgres:cot','ok':True,'rows':len(rows)})
            for row in rows:
                if not isinstance(row, dict): continue
                xml=str(row.get('xml') or '')
                parsed=_parse_cot_text_fields(row); typ=str(row.get('type') or parsed.get('type') or '')
                if _is_mission_cot_fields(parsed, row): continue
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')) or typ.startswith('b-f-t') or typ.startswith('b-t-f'): continue
                extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or '').strip()
                callsign=_v233_best_callsign(row, parsed, extra, uid)
                if not uid and not callsign: continue
                lat=_coerce_float(parsed.get('lat')); lon=_coerce_float(parsed.get('lon'))
                updated=str(row.get('start') or row.get('timestamp') or row.get('stale') or '')
                age=_age_seconds_from_value(updated)
                status='Online' if age is not None and age <= 180 else ('Recent' if age is not None and age <= 900 else ('Stale' if age is not None else 'Unknown'))
                put({'uid':uid,'callsign':callsign,'client':extra.get('client') or '','version':extra.get('version') or '', 'client_label':((' '.join([extra.get('client') or '', extra.get('version') or ''])).strip()),'team':extra.get('team') or '', 'lat':lat,'lon':lon,'updated':updated,'location_age_seconds':age,'status':status,'source':'cot','type':typ}, xml)
    out=[]
    for e in euds.values():
        if not e.get('client_label'):
            e['client_label']=' '.join([str(e.get('client') or ''), str(e.get('version') or '')]).strip()
        out.append(e)
    out.sort(key=lambda x: (x.get('status')!='Online', x.get('location_age_seconds') if x.get('location_age_seconds') is not None else 999999, x.get('callsign') or ''))
    return {'ok':True,'euds':out,'sources':notes}

def tak_map_non_tak_sensor_count():
    try:
        markers,_notes=_ots_pg_markers(limit_per_table=1200); count=0
        for m in markers or []:
            kind=str(m.get('kind') or '').lower()
            if kind in ('aircraft','webform','server_gps','server-gps','eud','datasync'): continue
            if m.get('mission') or m.get('is_mission_object') or m.get('creator_callsign') or m.get('parent_callsign'): continue
            if not is_valid_latlon_py(m.get('lat'), m.get('lon')): continue
            blob=' '.join(str(m.get(k) or '') for k in ('uid','callsign','source','client','client_label','type')).lower()
            if any(x in blob for x in ('ads-b','adsb','aircraft','webform','tak-dashboard','server_gps','server gps')): continue
            if _has_tak_client_version(m, ''): continue
            count += 1
        return count
    except Exception:
        return 0

# --- v234 live EUD/ADS-B filtering refinements ---
_v233_tak_map_euds = tak_map_euds
_v233_tak_map_adsb = tak_map_adsb

def _v234_online_eud_seconds():
    try:
        return max(20, int(os.environ.get('TAK_DASH_EUD_ONLINE_SECONDS', '90')))
    except Exception:
        return 90

def _v234_eud_callsign_lookup(limit=1500):
    """Map sender/device UID to the latest user-facing TAK callsign from CoT XML/contact."""
    out={}
    try:
        uris, _errs = _candidate_ots_pg_uris()
        for uri in uris[:2]:
            rows, err = _pg_table_rows(uri, 'cot', limit)
            if err:
                continue
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                typ=str(row.get('type') or '')
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')):
                    continue
                parsed=_parse_cot_text_fields(row)
                uid=str(row.get('sender_uid') or parsed.get('creator_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                cs=str(row.get('sender_callsign') or parsed.get('callsign') or parsed.get('creator_callsign') or '').strip()
                if uid and cs and not _v233_uid_like(cs) and cs.lower() not in ('none','null','unknown'):
                    out.setdefault(uid.lower(), cs)
            if out:
                break
    except Exception:
        pass
    return out

def _v234_is_online_eud(e):
    """Online means a currently live TAK client, not stale/offline EUD table history."""
    if not isinstance(e, dict):
        return False
    blob=' '.join(str(e.get(k) or '') for k in ('kind','source','type','client','client_label','callsign','uid')).lower()
    if any(term in blob for term in ('webform','webform-gw','ads-b','adsb','aircraft','icao','server_gps','server gps','tak-dashboard')):
        return False
    if not str(e.get('uid') or e.get('callsign') or '').strip():
        return False
    age=e.get('location_age_seconds')
    try:
        age=float(age)
    except Exception:
        age=None
    # Do not trust historical table status alone; use a recent location/CoT age.
    return age is not None and age <= _v234_online_eud_seconds()

def _is_online_send_eud(e):
    return _v234_is_online_eud(e)

def tak_map_euds():
    data=_v233_tak_map_euds() or {'ok':True,'euds':[],'sources':[]}
    lookup=_v234_eud_callsign_lookup()
    out=[]
    seen=set()
    for e in data.get('euds') or []:
        uid=str(e.get('uid') or '').strip()
        cs=str(e.get('callsign') or '').strip()
        best=lookup.get(uid.lower()) if uid else ''
        if best and (not cs or _v233_uid_like(cs)):
            e['callsign']=best
        if not _v234_is_online_eud(e):
            continue
        key=(uid or e.get('callsign') or '').lower()
        if key and key in seen:
            continue
        if key:
            seen.add(key)
        out.append(e)
    out.sort(key=lambda x: (str(x.get('callsign') or '').lower(), float(x.get('location_age_seconds') or 999999)))
    data['euds']=out
    data['online_only']=True
    data['online_seconds']=_v234_online_eud_seconds()
    return data

def _v234_adsb_is_fresh(ac, stale_seconds):
    if not isinstance(ac, dict):
        return False
    try:
        lat=float(ac.get('lat')); lon=float(ac.get('lon'))
        if not (-90 <= lat <= 90 and -180 <= lon <= 180) or (abs(lat)<0.000001 and abs(lon)<0.000001):
            return False
    except Exception:
        return False
    seen=ac.get('seen_seconds')
    try:
        if seen is not None and float(seen) > stale_seconds:
            return False
    except Exception:
        pass
    updated=ac.get('updated') or ac.get('time') or ac.get('timestamp') or ac.get('start') or ''
    if updated and _is_live_marker_stale(updated, stale_seconds):
        return False
    return True

def tak_map_adsb():
    data=_v233_tak_map_adsb() or {'ok':True,'aircraft':[],'sources':[]}
    settings=data.get('settings') or _load_adsb_settings()
    stale_seconds=_adsb_stale_seconds(settings)
    aircraft=[]
    seen={}
    for ac in data.get('aircraft') or []:
        if not _v234_adsb_is_fresh(ac, stale_seconds):
            continue
        key=str(ac.get('id') or ac.get('icao') or ac.get('uid') or ac.get('callsign') or '').strip().lower()
        if not key:
            continue
        old=seen.get(key)
        old_seen=float(old.get('seen_seconds') or 999999) if old else 999999
        new_seen=float(ac.get('seen_seconds') or 999999)
        if old is None or new_seen < old_seen:
            seen[key]=ac
    aircraft=list(seen.values())
    data['aircraft']=aircraft
    data['count']=len(aircraft)
    data['stale_seconds']=stale_seconds
    data['settings']=settings
    return data
# --- end v234 live EUD/ADS-B filtering refinements ---
# --- end v233 backend refinements ---
INDEX_HTML=r'''<!doctype html><html lang="en"><head><meta charset="utf-8"><title>TAK Server Dash</title><meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"><style>
:root{--bg:#07090c;--panel:#121820;--text:#e8edf2;--muted:#8ea0ad;--good:#39d98a;--warn:#ffcc66;--bad:#ff5f57;--accent:#ff6a2a;--line:#26313d}*{box-sizing:border-box}body{margin:0;background:radial-gradient(circle at top,#17212b,var(--bg) 45%);color:var(--text);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}header{padding:18px 18px 8px;border-bottom:1px solid var(--line);background:rgba(0,0,0,.25);position:sticky;top:0;backdrop-filter:blur(8px);z-index:2}h1{margin:0;font-size:1.35rem;letter-spacing:.08em;text-transform:uppercase}.subtitle{margin-top:4px;color:var(--muted);font-size:.9rem}.header-row{display:flex;align-items:center;justify-content:space-between;gap:14px}.release-version{display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,106,42,.45);border-radius:999px;padding:5px 10px;background:rgba(255,106,42,.08);color:#ffd0b0;font-size:.78rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap}.iteration-marker{color:rgba(142,160,173,.38);font-size:.72rem;line-height:1;padding:10px 14px 14px;text-align:center;user-select:text}.privacy-toggle{white-space:nowrap;background:#1d2833;color:var(--text);border:1px solid #354556;border-radius:999px;padding:8px 14px;cursor:pointer;font-weight:750}.privacy-toggle:hover{border-color:var(--accent);color:#fff}body.privacy .sensitive{filter:blur(4px);user-select:none;transition:filter .15s ease}body.privacy .sensitive:hover{filter:blur(3px)}.section-toggle-grid{display:flex;flex-wrap:wrap;gap:8px 14px;margin:4px 0 8px}.section-toggle-grid label{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:999px;padding:6px 10px;background:rgba(255,255,255,.025);font-size:.86rem;color:var(--text)}.section-toggle-grid input{accent-color:var(--accent)}main{padding:14px;display:grid;grid-template-columns:repeat(12,1fr);gap:12px}.card{background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.015));border:1px solid var(--line);border-radius:14px;padding:14px;box-shadow:0 10px 30px rgba(0,0,0,.25)}.card h2{margin:0 0 10px;font-size:.95rem;letter-spacing:.06em;text-transform:uppercase}.span-4{grid-column:span 4}.span-6{grid-column:span 6}.span-12{grid-column:span 12}.kv{display:grid;grid-template-columns:150px 1fr;gap:6px 10px;font-size:.92rem}.k{color:var(--muted)}.v{word-break:break-word}.status{display:inline-flex;width:fit-content;max-width:100%;align-self:flex-start;align-items:center;gap:6px;border:1px solid var(--line);border-radius:999px;padding:4px 9px;font-size:.82rem;text-transform:uppercase;white-space:nowrap}.signal-wrap{display:inline-flex;align-items:center;gap:8px;vertical-align:middle}.signal-bars{display:inline-flex;align-items:flex-end;gap:4px;height:28px;vertical-align:middle}.signal-bars .bar{width:8px;border-radius:3px;background:#25313b;box-shadow:inset 0 0 0 1px rgba(255,255,255,.05)}.signal-bars .bar:nth-child(1){height:8px}.signal-bars .bar:nth-child(2){height:13px}.signal-bars .bar:nth-child(3){height:18px}.signal-bars .bar:nth-child(4){height:23px}.signal-bars .bar:nth-child(5){height:28px}.signal-bars.signal-good .bar.on{background:linear-gradient(180deg,var(--good),#1dba63);box-shadow:0 0 8px rgba(57,217,138,.35)}.signal-bars.signal-warn .bar.on{background:linear-gradient(180deg,var(--warn),#cc8a11);box-shadow:0 0 8px rgba(255,204,102,.25)}.signal-bars.signal-bad .bar.on{background:linear-gradient(180deg,var(--bad),#b43b36);box-shadow:0 0 8px rgba(255,95,87,.30)}.signal-text{font-size:.9rem;font-weight:750;letter-spacing:.02em}.dot{width:9px;height:9px;border-radius:50%;background:var(--muted);display:inline-block}.good .dot{background:var(--good);box-shadow:0 0 8px var(--good)}.warn .dot{background:var(--warn);box-shadow:0 0 8px var(--warn)}.bad .dot{background:var(--bad);box-shadow:0 0 8px var(--bad)}.good{color:var(--good)}.warn{color:var(--warn)}.bad{color:var(--bad)}.lte-state-good{color:var(--good);font-weight:750}.lte-state-warn{color:var(--warn)}.lte-state-warn-bold{color:var(--warn);font-weight:850}.lte-state-bad-bold{color:var(--bad);font-weight:850}.wifi-not-connected{font-size:.95rem;font-weight:750;letter-spacing:.02em;text-transform:none}table{width:100%;border-collapse:collapse;font-size:.9rem}th,td{text-align:left;border-bottom:1px solid var(--line);padding:8px 6px;vertical-align:middle}th{color:var(--muted);font-size:.78rem;text-transform:uppercase;letter-spacing:.06em}button{background:#1d2833;color:var(--text);border:1px solid #354556;border-radius:9px;padding:7px 10px;cursor:pointer;margin:2px;font-weight:650}button.restart{border:2px solid rgba(255,204,102,.9);background:rgba(255,204,102,.14)}button.restart:hover{background:rgba(255,204,102,.22)}button.stop{border:2px solid rgba(255,95,87,.9);background:rgba(255,95,87,.14)}button.stop:hover{background:rgba(255,95,87,.22)}button:hover{border-color:var(--accent);color:#fff}button.start{border-color:rgba(57,217,138,.45)}button.stop{border-color:rgba(255,95,87,.45)}button.restart{border-color:rgba(255,204,102,.45)}button.primary{background:linear-gradient(180deg,#ff7a33,#b84618);border-color:#ff8b4d;color:white}pre{white-space:pre-wrap;background:#070a0f;border:1px solid var(--line);border-radius:10px;padding:10px;color:#d7e0e7;max-height:260px;overflow:auto}.small{font-size:.82rem;color:var(--muted)}.big{font-size:2rem;font-weight:750}.cpu-temp-value{font-size:1.05rem;font-weight:700}.bandwidth-value{font-size:1.05rem;font-weight:700}.zt-online{color:var(--good);font-weight:750}.zt-offline{color:var(--bad);font-weight:750}.zt-unknown{color:var(--warn);font-weight:750}.sortable{cursor:pointer;user-select:none;white-space:nowrap;padding:0}.sortable:hover{color:#fff}.sort-head{width:100%;min-height:38px;margin:0;border:0;border-radius:0;background:transparent;color:inherit;display:inline-flex;align-items:center;justify-content:flex-start;gap:7px;padding:8px 6px;font:inherit;font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}.sort-head:hover{border:0;background:rgba(255,255,255,.035)}.sort-head span:first-child{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.sort-icon{display:inline-flex;align-items:center;justify-content:center;width:18px;height:18px;min-width:18px;border:1px solid rgba(255,139,77,.45);border-radius:6px;color:var(--muted);background:rgba(0,0,0,.18);font-size:.72rem;line-height:1}.sortable.sort-asc .sort-icon,.sortable.sort-desc .sort-icon{color:var(--accent);border-color:rgba(255,139,77,.75)}.sortable.sort-asc .sort-icon::before{content:'↑'}.sortable.sort-desc .sort-icon::before{content:'↓'}.sortable:not(.sort-asc):not(.sort-desc) .sort-icon::before{content:'↕'}.cmd-tabs{display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 12px;border-bottom:1px solid var(--line);padding-bottom:10px}.cmd-tab{border:1px solid #354556;border-radius:999px;background:#101821;color:var(--muted);padding:8px 12px;font-weight:750;white-space:nowrap}.cmd-tab.active{border-color:#ff8b4d;background:linear-gradient(180deg,rgba(255,122,51,.28),rgba(184,70,24,.14));color:#fff}.cmd-restore-wrap{display:flex;align-items:center;justify-content:flex-end;gap:12px;flex-wrap:wrap;margin:10px 0 0}.cmd-restore-note{font-size:.78rem;line-height:1.32;color:#d7b5a5;text-align:center}.cmd-restore-note span{display:block;white-space:nowrap}.cmd-command-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:8px}.cmd-command-card{border:1px solid rgba(255,255,255,.08);border-radius:12px;background:rgba(7,10,15,.38);padding:13px;display:grid;grid-template-columns:minmax(0,1fr) 88px;gap:12px;align-items:start;min-height:166px}.cmd-command-title-line{display:flex;align-items:center;gap:8px;min-width:0;margin-bottom:4px}.cmd-command-title{font-weight:850;color:#fff;letter-spacing:.02em;min-width:0}.cmd-command-kind{border-radius:999px;padding:2px 7px;font-size:.64rem;font-weight:900;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}.cmd-command-kind.default{color:#ffd0bb;border:1px solid rgba(255,106,42,.42);background:rgba(255,106,42,.08)}.cmd-command-kind.custom{color:#c7ffdd;border:1px solid rgba(57,217,138,.38);background:rgba(57,217,138,.06)}.cmd-command-desc{font-size:.82rem;color:var(--muted);margin-bottom:8px}.cmd-command-code{display:block;font-size:.78rem;line-height:1.3;max-height:4.5em;overflow:auto;padding:7px 8px;border-radius:8px;background:#070a0f;border:1px solid var(--line);color:#ffd0bb}.cmd-command-actions{display:flex;flex-direction:column;gap:6px;align-items:stretch}.cmd-command-actions button{width:88px;margin:0}.cmd-command-actions .mini-remove{font-size:.72rem;padding:6px 8px}
