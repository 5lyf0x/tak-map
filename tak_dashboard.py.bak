    .terrain3d-coverage-chip{font-size:.62rem;color:#aebdc3;line-height:1.22;margin-top:-2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .terrain3d-controls.v293-terrain-panel.local-elevation-active{border-color:rgba(255,111,46,.48)!important;box-shadow:0 14px 34px rgba(0,0,0,.42),0 0 0 1px rgba(255,111,46,.12),inset 0 1px 0 rgba(255,255,255,.08)!important;}
