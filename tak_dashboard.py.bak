  `;document.head.appendChild(st)}
  function syncButtons(){try{const id=String(S.id||'').toLowerCase();qa('.adsb-track-btn').forEach(b=>{const bid=String((b.dataset&&b.dataset.adsbTrackId)||b.getAttribute('data-adsb-track-id')||'').toLowerCase();const on=!!id&&bid===id;b.classList.toggle('v307-active',on);b.classList.toggle('active',on);b.classList.toggle('tracking',on);b.dataset.adsbTracking=on?'1':'0';const dot=q('.adsb-track-light',b);if(dot)dot.classList.toggle('active',on);const txt=q('.adsb-track-text',b);if(txt)txt.textContent=on?'Untrack':'Track';})}catch(_){}}
  function redraw(){const layers=ensureLayers();if(!layers)return;try{layers.track.clearLayers();layers.label.clearLayers()}catch(_){}const pts=S.points||[];const ll=pts.map(p=>[p.lat,p.lon]);if(ll.length>=2){try{S.line=L.polyline(ll,{color:'#ff3b30',weight:4,opacity:.98,lineCap:'round',lineJoin:'round',interactive:false}).addTo(layers.track);S.line.bringToFront&&S.line.bringToFront()}catch(e){console.warn('v307 ADS-B track line failed',e)}}if(ll.length>=1){try{const txt=distText(distMeters(pts));S.label=L.marker(ll[ll.length-1],{interactive:false,zIndexOffset:1900,icon:L.divIcon({className:'adsb-track-distance-label-wrap',html:'<div class="adsb-track-distance-label">'+esc(txt)+'</div>',iconAnchor:[0,0]})}).addTo(layers.label)}catch(e){console.warn('v307 ADS-B track label failed',e)}}syncButtons()}
  function addPoint(a){if(!a||!S.id||idOf(a)!==S.id)return false;const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return false;const pts=S.points||(S.points=[]);const last=pts[pts.length-1],now=Date.now();if(last){let d=999;try{d=L.latLng(last.lat,last.lon).distanceTo(L.latLng(lat,lon))}catch(_){}if(d<2&&(now-(last.t||0))<2500){S.meta=a;redraw();return true}}pts.push({lat,lon,alt:Number(a.altitude_ft||a.alt_baro||a.alt_geom)||0,t:now});if(pts.length>3000)pts.splice(0,pts.length-3000);S.meta=a;redraw();return true}
  function updateFrom(items){try{const arr=Array.isArray(items)?items:(window.lastAircraft||[]);if(Array.isArray(arr))window.__v307LastAircraft=arr;if(!S.id)return;const a=findAircraft(S.id)||(Array.isArray(arr)?arr.find(x=>idOf(x)===S.id):null);if(a)addPoint(a);else syncButtons()}catch(e){console.warn('v307 ADS-B track update failed',e)}}
  function clearVisual(){try{if(S.trackLayer)S.trackLayer.clearLayers();if(S.labelLayer)S.labelLayer.clearLayers()}catch(_){}S.line=null;S.label=null}
