    def _v316_menu_html():
        return '''<div id="adsbMenuHostV316" class="adsb-v316-menu"><div class="adsb-v316-top"><button id="adsbToggleBtn" class="layer-button" type="button">Disable ADS-B</button></div><div class="adsb-settings-grid"><label>Radius miles<input id="adsbRadiusMiles" class="adsb-radius-input" type="number" min="1" max="250" step="1" value="5" inputmode="numeric"></label><label>Update Interval (sec)<input id="adsbUpdateInterval" class="adsb-radius-input" type="number" min="1" max="300" step="1" value="5" inputmode="numeric"></label><label class="adsb-center-source-row">Center Source<select id="adsbCenterSource"><option value="manual">Manual</option><option value="map_center">Map Center</option><option value="follow_map_center">Follow Map Center</option></select></label><label class="adsb-center-combo-row">Center Lat/Lon<input id="adsbCenterLatLon" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="34.000000, -118.000000"></label><input id="adsbCenterLat" type="hidden"><input id="adsbCenterLon" type="hidden"></div><div class="adsb-v316-filter-row"><label><input id="adsbFilterCivil" type="checkbox" checked> Civil</label><label><input id="adsbFilterMilitary" type="checkbox" checked> Military</label><label><input id="adsbFilterGovt" type="checkbox" checked> Govt</label><label><input id="adsbFilterUnknown" type="checkbox" checked> Unknown</label></div><div class="adsb-v316-actions"><button class="layer-button" type="button" onclick="useMapCenterForAdsb()">Use Map Center</button><button class="layer-button" type="button" onclick="saveAdsbSettings(false)">Save Filter</button><button class="layer-button" type="button" onclick="refreshAdsb()">Refresh ADS-B</button></div><div id="adsbSettingsStatus" class="muted" style="margin-top:7px"></div></div>'''

    def _v316_restore(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v316_re.sub(r'<script[^>]*id=["\']v315AdsbMenuRuntime["\'][^>]*>.*?</script>\s*', '', _html, flags=_v316_re.S)
        _html = _v316_re.sub(r'<style[^>]*id=["\']v315AdsbMenuStyle["\'][^>]*>.*?</style>\s*', '', _html, flags=_v316_re.S)
        _html = _v316_re.sub(r'<script[^>]*id=["\']v316AdsbControlsRuntime["\'][^>]*>.*?</script>\s*', '', _html, flags=_v316_re.S)
        _html = _v316_re.sub(r'<style[^>]*id=["\']v316AdsbControlsStyle["\'][^>]*>.*?</style>\s*', '', _html, flags=_v316_re.S)
        _menu = _v316_menu_html()
        _html = _v316_re.sub(r'<div id="adsbMenuHostV315"[\s\S]*?<div id="adsbSettingsStatus"[^>]*></div></div>', _menu, _html, count=1)
        _html = _v316_re.sub(r'<div id="adsbMenuHostV316"[\s\S]*?<div id="adsbSettingsStatus"[^>]*></div></div>', _menu, _html, count=1)
        _html = _html.replace('<div id="adsbMenuHostV282"></div>', _menu)
        if 'id="adsbMenuHostV316"' not in _html:
            _html = _v316_re.sub(r'(<div class="panel collapsible" data-collapse-key="adsbSettings"><h2 onclick="togglePanelCollapse\(this\)">ADS-B <span class="panel-toggle">▾</span></h2><div class="panel-body">)\s*</div>', r'\1'+_menu+'</div>', _html, count=1)
        if 'id="bannerAdsb"' not in _html:
            _html = _html.replace('<span class="status-item" id="bannerDownloadsItem"', '<span class="status-item status-dropdown-trigger" id="bannerAdsbItem" onclick="toggleStatusDropdown(\'adsb\',event)"><span class="status-dot unknown" id="bannerAdsbDot"></span>ADS-B: <b id="bannerAdsb">0 Aircraft</b></span><span class="status-item" id="bannerDownloadsItem"', 1)
        if 'id="toolViewshed"' not in _html:
            _viewshed_btn = '''<button id="toolViewshed" class="tool-btn" onclick="openTakMapViewshed(event)" title="Viewshed"><svg viewBox="0 0 24 24"><path d="M3 12s3.4-6 9-6 9 6 9 6-3.4 6-9 6-9-6-9-6Z"/><circle cx="12" cy="12" r="2.4"/><path d="M12 3v3"/><path d="M12 18v3"/><path d="M3 12h3"/><path d="M18 12h3"/></svg><span class="tool-label">Viewshed</span></button>'''
            _html = _html.replace('<button id="tool3d"', _viewshed_btn + '<button id="tool3d"', 1)
        _css = '''<style id="v316AdsbControlsStyle">.adsb-v316-menu{display:grid;gap:8px}.adsb-v316-top{display:flex;gap:7px;flex-wrap:wrap}.adsb-v316-filter-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px 10px;margin-top:2px}.adsb-v316-filter-row label{display:flex;align-items:center;gap:6px;color:var(--muted);font-size:.74rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em}.adsb-v316-actions{display:flex;flex-wrap:wrap;gap:7px;margin-top:2px}.adsb-v316-actions .layer-button,.adsb-v316-top .layer-button{font-weight:700}.adsb-center-combo-row{grid-column:1/-1}.adsb-local-off{border-color:rgba(255,120,90,.72)!important;color:#ffd1c8!important}#toolViewshed svg{width:19px;height:19px;display:block;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}</style>'''
        if 'v316AdsbControlsStyle' not in _html:
            _html = _html.replace('</head>', _css+'</head>', 1) if '</head>' in _html else _css+_html
        _script = r'''<script id="v316AdsbControlsRuntime">
(function(){
  'use strict';
  const V='v316';
  const $=id=>document.getElementById(id);
  const qs=s=>document.querySelector(s);
  const qsa=s=>Array.from(document.querySelectorAll(s));
  function clamp(v,min,max,def){v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def}
  function mapObj(){try{if(window.takLeafletMap&&window.takLeafletMap.getCenter)return window.takLeafletMap}catch(_){}try{if(window.map&&window.map.getCenter)return window.map}catch(_){}try{if(typeof map!=='undefined'&&map&&map.getCenter){window.map=map;return map}}catch(_){}return null}
  function menuHtml(){return `__V316_MENU__`}
  function status(msg,bad){try{const n=$('adsbSettingsStatus');if(n){n.textContent=msg||'';n.classList.toggle('adsb-status-bad',!!bad);n.classList.toggle('adsb-status-ok',!bad)}}catch(_){} }
  function localDisabled(){try{return localStorage.getItem('takmap.adsb.localDisabled')==='1'}catch(_){return false}}
  function setLocalDisabled(v){try{localStorage.setItem('takmap.adsb.localDisabled',v?'1':'0')}catch(_){} }
  function readCenterText(){const raw=String(($('adsbCenterLatLon')||{}).value||'').trim();const m=raw.match(/(-?\d+(?:\.\d+)?)\s*[,\s]+\s*(-?\d+(?:\.\d+)?)/);if(!m)return null;const lat=Number(m[1]),lon=Number(m[2]);if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180)return null;return {lat,lon}}
  function writeCenter(lat,lon){lat=Number(lat);lon=Number(lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return;const txt=lat.toFixed(6)+', '+lon.toFixed(6);if($('adsbCenterLatLon'))$('adsbCenterLatLon').value=txt;if($('adsbCenterLat'))$('adsbCenterLat').value=lat.toFixed(6);if($('adsbCenterLon'))$('adsbCenterLon').value=lon.toFixed(6)}
  function ensureMenu(){try{const body=qs('.panel[data-collapse-key="adsbSettings"] .panel-body');if(!body)return;const ok=$('adsbMenuHostV316')&&$('adsbToggleBtn')&&$('adsbCenterLatLon')&&($('adsbCenterSource')||{}).querySelector('option[value="follow_map_center"]');if(!ok){body.innerHTML=menuHtml()}qsa('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V);updateToggleButton();}catch(e){console.warn('v316 ADS-B menu ensure failed',e)}}
  function ensureStatusBar(){try{let bar=$('mapStatusBanner');if(!bar)return null;let item=$('bannerAdsbItem');if(!item){item=document.createElement('span');item.id='bannerAdsbItem';item.className='status-item status-dropdown-trigger';item.onclick=function(ev){try{if(typeof toggleStatusDropdown==='function')toggleStatusDropdown('adsb',ev)}catch(_){}};item.innerHTML='<span class="status-dot unknown" id="bannerAdsbDot"></span>ADS-B: <b id="bannerAdsb">0 Aircraft</b>';const dl=$('bannerDownloadsItem');if(dl&&dl.parentElement===bar)bar.insertBefore(item,dl);else bar.appendChild(item)}return item}catch(e){console.warn('v316 ADS-B status bar restore failed',e);return null}}
  function updateBanner(count){try{ensureStatusBar();count=Number(count);if(!Number.isFinite(count))count=0;const b=$('bannerAdsb');if(b)b.textContent=Math.round(count)+' Aircraft';const d=$('bannerAdsbDot');if(d){d.classList.remove('unknown','good','warn','bad');d.classList.add(localDisabled()?'bad':(count>0?'good':'warn'))}const s=$('adsbStatus');if(s)s.textContent=Math.round(count)+' active'}catch(_){} }
  function updateToggleButton(){try{const b=$('adsbToggleBtn');if(!b)return;const off=localDisabled();b.textContent=off?'Enable ADS-B':'Disable ADS-B';b.classList.toggle('adsb-local-off',off);b.title='Toggle TAK Map ADS-B display';}catch(_){} }
  function clearAircraft(){try{const ctl=window.TakMapControllers&&window.TakMapControllers.adsb;if(ctl){try{if(ctl.layer&&ctl.markers){ctl.markers.forEach(m=>{try{ctl.layer.removeLayer(m)}catch(_){}})}}catch(_){}try{ctl.markers&&ctl.markers.clear&&ctl.markers.clear()}catch(_){}try{ctl.data&&ctl.data.clear&&ctl.data.clear()}catch(_){}ctl.lastList=[]}}catch(_){}try{if(window.aircraftLayer&&aircraftLayer.clearLayers)aircraftLayer.clearLayers()}catch(_){}try{window.lastAircraft=[]}catch(_){}updateBanner(0)}
  window.toggleTakMapAdsbLocal=function(){const off=!localDisabled();setLocalDisabled(off);updateToggleButton();if(off){clearAircraft();status('ADS-B disabled.');return false}else{status('ADS-B enabled.');setTimeout(()=>{try{window.refreshAdsb&&window.refreshAdsb()}catch(_){}},50);return true}};
  function source(){return String(($('adsbCenterSource')||{}).value||'manual')}
  function applySettings(s){try{s=s||{};if($('adsbRadiusMiles'))$('adsbRadiusMiles').value=String(clamp(s.radius_miles,1,250,5));if($('adsbUpdateInterval'))$('adsbUpdateInterval').value=String(clamp(s.update_interval_seconds,1,300,5));let src=String(s.center_source||'manual');if(src==='follow')src='follow_map_center';if(!['manual','map_center','follow_map_center'].includes(src))src='manual';if($('adsbCenterSource'))$('adsbCenterSource').value=src;if(s.center_lat!=null&&s.center_lon!=null)writeCenter(s.center_lat,s.center_lon);else {const m=mapObj();if(m&&m.getCenter){const c=m.getCenter();writeCenter(c.lat,c.lng)}}}catch(_){} }
  function values(){try{let src=source();const m=mapObj();if((src==='map_center'||src==='follow_map_center')&&m){const c=m.getCenter();writeCenter(c.lat,c.lng)}const c=readCenterText();return {radius_miles:clamp(($('adsbRadiusMiles')||{}).value,1,250,5),update_interval_seconds:clamp(($('adsbUpdateInterval')||{}).value,1,300,5),center_source:src,center_lat:c?c.lat:null,center_lon:c?c.lon:null}}catch(_){return {}}}
  async function loadSettings(){try{const r=await fetch('/api/tak-map/adsb-settings',{cache:'no-store'});const j=await r.json();if(j&&j.settings){window.lastAdsbSettings=j.settings;applySettings(j.settings)}}catch(e){console.warn('v316 ADS-B settings load failed',e)}}
  let saveTimer=null;
  window.saveAdsbSettings=async function(showStatus=true){try{ensureMenu();const payload=values();if(payload.center_lat==null||payload.center_lon==null){status('Set ADS-B center.',true);return {ok:false,error:'Set ADS-B center.'}}const r=await fetch('/api/tak-map/adsb-settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const j=await r.json();if(!j||j.ok===false)throw new Error((j&&j.error)||'Save failed');window.lastAdsbSettings=j.settings||payload;applySettings(window.lastAdsbSettings);if(showStatus!==false)status('Saved');restartPolling();return j}catch(e){status(String(e&&e.message||e),true);return {ok:false,error:String(e&&e.message||e)}}};
  function saveSoon(delay=450){clearTimeout(saveTimer);saveTimer=setTimeout(()=>{try{window.saveAdsbSettings(false)}catch(_){}},delay)}
  function restartPolling(){try{const ctl=window.TakMapControllers&&window.TakMapControllers.adsb;const sec=clamp(($('adsbUpdateInterval')||{}).value,1,300,5);if(ctl&&ctl.refreshTimer)clearInterval(ctl.refreshTimer);if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer);if(ctl){ctl.refreshTimer=setInterval(function(){try{if(!localDisabled())window.refreshAdsb&&window.refreshAdsb();else updateBanner(0)}catch(_){}},sec*1000);window.adsbRefreshTimer=ctl.refreshTimer}if(!localDisabled())setTimeout(()=>{try{window.refreshAdsb&&window.refreshAdsb()}catch(_){}},75);else clearAircraft()}catch(e){console.warn('v316 ADS-B polling restart failed',e)}}
  window.useMapCenterForAdsb=function(){try{ensureMenu();const m=mapObj();if(!m)return status('Map not ready.',true);const c=m.getCenter();writeCenter(c.lat,c.lng);if($('adsbCenterSource'))$('adsbCenterSource').value='map_center';status('Map center set');saveSoon(100)}catch(e){status(String(e&&e.message||e),true)}};
  function bindFollowMap(){try{const m=mapObj();if(!m||m._v316AdsbFollowBound)return;if(m.on){m.on('moveend',function(){try{if(source()==='follow_map_center'){const c=m.getCenter();writeCenter(c.lat,c.lng);saveSoon(250)}}catch(_){}});m._v316AdsbFollowBound=true}}catch(_){} }
  function bind(){try{const t=$('adsbToggleBtn');if(t&&!t.dataset.v316Bound){t.dataset.v316Bound='1';t.addEventListener('click',window.toggleTakMapAdsbLocal)}['Civil','Military','Govt','Unknown'].forEach(k=>{const el=$('adsbFilter'+k);if(el&&!el.dataset.v316Bound){el.dataset.v316Bound='1';const v=localStorage.getItem('takmap.adsb.filter.'+k.toLowerCase());if(v!=null)el.checked=v!=='0';el.addEventListener('change',()=>{try{localStorage.setItem('takmap.adsb.filter.'+k.toLowerCase(),el.checked?'1':'0')}catch(_){}try{window.drawAircraft&&window.drawAircraft(window.lastAircraft||[])}catch(_){}})}});['adsbRadiusMiles','adsbUpdateInterval','adsbCenterSource','adsbCenterLatLon'].forEach(id=>{const el=$(id);if(el&&!el.dataset.v316Bound){el.dataset.v316Bound='1';el.addEventListener('change',()=>{if(id==='adsbCenterLatLon'){const c=readCenterText();if(c)writeCenter(c.lat,c.lon)}if(id==='adsbUpdateInterval')restartPolling();saveSoon(500)});if(id==='adsbCenterLatLon')el.addEventListener('input',()=>{const c=readCenterText();if(c)writeCenter(c.lat,c.lon)})}});bindFollowMap()}catch(e){console.warn('v316 ADS-B bind failed',e)}}
  function installRefreshObserver(){try{const ctl=window.TakMapControllers&&window.TakMapControllers.adsb;if(!ctl||ctl._v316Observed)return;if(!ctl._v316LastListDesc){let val=ctl.lastList;Object.defineProperty(ctl,'lastList',{configurable:true,get(){return val},set(v){val=Array.isArray(v)?v:[];updateBanner(val.length)}});ctl._v316LastListDesc=true}ctl._v316Observed=true}catch(_){} }
  function viewshedSvg(){return '<svg viewBox="0 0 24 24"><path d="M3 12s3.4-6 9-6 9 6 9 6-3.4 6-9 6-9-6-9-6Z"/><circle cx="12" cy="12" r="2.4"/><path d="M12 3v3"/><path d="M12 18v3"/><path d="M3 12h3"/><path d="M18 12h3"/></svg>'}
  function ensureViewshedButton(){try{const bar=$('floatingMapToolbar');if(!bar)return;let btn=$('toolViewshed');if(!btn){btn=document.createElement('button');btn.id='toolViewshed';btn.className='tool-btn';btn.title='Viewshed';const anchor=$('tool3d')||$('toolClearHidden')||$('toolFit');if(anchor&&anchor.parentElement===bar)bar.insertBefore(btn,anchor);else bar.appendChild(btn)}btn.type='button';btn.innerHTML=viewshedSvg()+'<span class="tool-label">Viewshed</span>';btn.onclick=function(ev){try{ev&&ev.preventDefault&&ev.preventDefault();ev&&ev.stopPropagation&&ev.stopPropagation()}catch(_){}try{if(typeof window.openTakMapViewshed==='function')return window.openTakMapViewshed(ev);if(typeof window.toggleViewshedModule==='function')return window.toggleViewshedModule(true);const panel=$('viewshedModule')||qs('.viewshed-module,.viewshed-panel');if(panel){panel.style.display='block';panel.classList.add('active','open')}}catch(e){console.warn('v316 Viewshed open failed',e)}}}catch(e){console.warn('v316 Viewshed button restore failed',e)}}
  function boot(){ensureMenu();ensureStatusBar();ensureViewshedButton();installRefreshObserver();bind();updateToggleButton();updateBanner((window.TakMapControllers&&window.TakMapControllers.adsb&&Array.isArray(window.TakMapControllers.adsb.lastList))?window.TakMapControllers.adsb.lastList.length:(Array.isArray(window.lastAircraft)?window.lastAircraft.length:0));loadSettings();if(localDisabled())clearAircraft();}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
  [350,1000,2500,5000,9000].forEach(ms=>setTimeout(boot,ms));
  setInterval(function(){try{ensureStatusBar();ensureViewshedButton();updateToggleButton();installRefreshObserver()}catch(_){}},3000);
})();
</script>'''
        _script = _script.replace('__V316_MENU__', _menu.replace('`','\\`').replace('\\','\\\\').replace('${','\\${'))
        _html = _html.replace('</body>', _script+'</body>', 1) if '</body>' in _html else _html+_script
        _html = _html.replace("async function refreshAdsb(){if(ADSB.busy)return ADSB.lastList;", "async function refreshAdsb(){if(localStorage.getItem('takmap.adsb.localDisabled')==='1'){try{if(ADSB.layer&&ADSB.markers){ADSB.markers.forEach(function(m){try{ADSB.layer.removeLayer(m)}catch(_){}});ADSB.markers.clear();ADSB.data&&ADSB.data.clear&&ADSB.data.clear();ADSB.lastList=[];window.lastAircraft=[];updateStatus(0)}}catch(_){}return []}if(ADSB.busy)return ADSB.lastList;")
        return _v316_versions(_html)

    TAK_MAP_HTML = _v316_restore(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v316_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v316_versions(LOGIN_HTML)
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML

    _v316_prev_get = Handler.do_GET
    def _v316_route_get(self):
        parsed = urlparse(self.path)
        if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
            if parsed.path in ('/', '/index.html', '/tak-map', '/tak-map/'):
                if not self._tak_map_auth_ok():
                    return self._redirect('/tak-map/login')
                return self._send_html(TAK_MAP_HTML)
            if parsed.path in ('/login', '/tak-map/login'):
                if self._tak_map_auth_ok():
                    return self._redirect('/tak-map')
                return self._send_html(TAK_MAP_LOGIN_HTML)
        return _v316_prev_get(self)
    Handler.do_GET = _v316_route_get
except Exception as _v316_exc:
    try: print('v316 ADS-B controls/status restore failed:', _v316_exc)
    except Exception: pass
# --- end TAK Map v316 ADS-B controls/status + Viewshed toolbar restore ---


# --- TAK Map v317 ADS-B server-proxy source + live controls cleanup ---
try:
    import re as _v317_re
    _V317_AIRPLANES_CACHE={}
    _V317_AIRPLANES_LOCK=threading.Lock()

    def _v317_versions(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v317_re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v317</span>', _html)
        _html = _v317_re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v317</div>', _html)
        _html = _v317_re.sub(r'const\s+V\s*=\s*["\']v\d+["\']', "const V='v317'", _html)
        _html = _v317_re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v317', _html)
        _html = _v317_re.sub(r'TAK-Map/1\.1\.0 v\d+', 'TAK-Map/1.1.0 v317', _html)
        for _old in ('v316','v315','v314','v313','v312','v311','v310','v309'):
            _html = _html.replace(_old + 'AdsbSingleOwnerPatch', 'v317AdsbSingleOwnerPatch')
            _html = _html.replace("window.__takMapAdsbSingleOwner='"+_old+"'", "window.__takMapAdsbSingleOwner='v317'")
            _html = _html.replace("window.__takMapAdsbSingleOwner = '"+_old+"'", "window.__takMapAdsbSingleOwner = 'v317'")
            _html = _html.replace("version:'"+_old+"'", "version:'v317'")
            _html = _html.replace('version:"'+_old+'"', 'version:"v317"')
            _html = _html.replace('__'+_old+'AdsbLegacySrcGuard', '__v317AdsbLegacySrcGuard')
            _html = _html.replace(_old + ' blocked legacy ADS-B icon downgrade', 'v317 blocked legacy ADS-B icon downgrade')
            _html = _html.replace(_old + ' legacy src guard failed', 'v317 legacy src guard failed')
            _html = _html.replace(_old + ' ignored legacy ADS-B', 'v317 ignored legacy ADS-B')
            _html = _html.replace(_old + ' ADS-B settings load failed', 'v317 ADS-B settings load failed')
            _html = _html.replace(_old + ' ADS-B polling restart failed', 'v317 ADS-B polling restart failed')
            _html = _html.replace(_old + ' ADS-B bind failed', 'v317 ADS-B bind failed')
        _html = _html.replace('v316AdsbControlsRuntime', 'v317AdsbControlsRuntime')
        _html = _html.replace('v316AdsbControlsStyle', 'v317AdsbControlsStyle')
        _html = _html.replace('adsb-v316-', 'adsb-v317-').replace('.adsb-v316-', '.adsb-v317-')
        _html = _html.replace('v316', 'v317')
        return _html

    def _v317_patch_html(_html):
        if not isinstance(_html, str):
            return _html
        # Remove the manual Refresh ADS-B button; live controls now save/restart/refresh automatically.
        _html = _html.replace('<button class="layer-button" type="button" onclick="refreshAdsb()">Refresh ADS-B</button>', '')
        # Make the single ADS-B owner pass the current UI center/radius to the backend endpoint instead of relying
        # on stale saved settings. This keeps the browser talking only to /api/tak-map/adsb while still supporting
        # Follow Map Center and manual center changes live.
        _endpoint_fn = r"""function adsbEndpoint(){try{let src=String((byId('adsbCenterSource')||{}).value||'manual');let m=mapObj();if((src==='map_center'||src==='follow_map_center')&&m&&m.getCenter){let c=m.getCenter();let el=byId('adsbCenterLatLon');if(el)el.value=Number(c.lat).toFixed(6)+', '+Number(c.lng).toFixed(6)}let txt=String((byId('adsbCenterLatLon')||{}).value||'');let mm=txt.match(/(-?\d+(?:\.\d+)?)\s*[,\s]+\s*(-?\d+(?:\.\d+)?)/);let radius=Number((byId('adsbRadiusMiles')||{}).value||((window.lastAdsbSettings||{}).radius_miles)||50);if(mm)return '/api/tak-map/adsb?center_lat='+encodeURIComponent(mm[1])+'&center_lon='+encodeURIComponent(mm[2])+'&radius_miles='+encodeURIComponent(Math.max(1,Math.min(250,Math.round(radius))))+'&_='+Date.now()}catch(_){}return '/api/tak-map/adsb?_='+Date.now()}"""
        if 'function adsbEndpoint(){' not in _html:
            _html = _html.replace("async function refreshAdsb(){if(localStorage.getItem('takmap.adsb.localDisabled')==='1'", _endpoint_fn + "\n  async function refreshAdsb(){if(localStorage.getItem('takmap.adsb.localDisabled')==='1'", 1)
        _html = _html.replace("fetch('/api/tak-map/adsb',{cache:'no-store'})", "fetch(adsbEndpoint(),{cache:'no-store'})")
        return _v317_versions(_html)

    def _v317_airplanes_url(settings):
        try:
            lat=float(settings.get('center_lat'))
            lon=float(settings.get('center_lon'))
        except Exception:
            return ''
        if not (-90 <= lat <= 90 and -180 <= lon <= 180):
            return ''
        try:
            radius=max(1, min(250, int(round(float(settings.get('radius_miles') or 50)))))
        except Exception:
            radius=50
        return f'https://api.airplanes.live/v2/point/{lat:.6f}/{lon:.6f}/{radius}'

    def _v317_cache_seconds(settings=None):
        try:
            env=float(os.environ.get('TAK_MAP_ADSB_CACHE_SECONDS','') or 0)
            if env > 0:
                return max(1.0, min(15.0, env))
        except Exception:
            pass
        try:
            sec=float((settings or {}).get('update_interval_seconds') or 2)
        except Exception:
            sec=2.0
        return max(1.0, min(5.0, sec))

    def _v317_fetch_airplanes(settings):
        url=_v317_airplanes_url(settings)
        if not url:
            return None, {'source':'airplanes.live server proxy','ok':False,'error':'ADS-B center not set.'}
        try:
            lat=round(float(settings.get('center_lat')),4); lon=round(float(settings.get('center_lon')),4)
            radius=max(1, min(250, int(round(float(settings.get('radius_miles') or 50)))))
            key=f'{lat:.4f},{lon:.4f},{radius}'
        except Exception:
            key=url
        now=time.time(); ttl=_v317_cache_seconds(settings)
        with _V317_AIRPLANES_LOCK:
            ent=_V317_AIRPLANES_CACHE.get(key)
            if ent and (now-float(ent.get('ts') or 0.0)) < ttl and ent.get('data') is not None:
                return ent.get('data'), {'source':'airplanes.live server proxy','url':url,'ok':True,'cached':True,'cache_seconds':ttl}
            try:
                data=_v270_json_url(url, timeout=10)
                _V317_AIRPLANES_CACHE[key]={'ts':time.time(),'data':data}
                if len(_V317_AIRPLANES_CACHE) > 64:
                    for k,_ in sorted(_V317_AIRPLANES_CACHE.items(), key=lambda kv: float(kv[1].get('ts') or 0.0))[:16]:
                        _V317_AIRPLANES_CACHE.pop(k, None)
                return data, {'source':'airplanes.live server proxy','url':url,'ok':True,'cached':False,'cache_seconds':ttl}
            except Exception as e:
                return None, {'source':'airplanes.live server proxy','url':url,'ok':False,'error':str(e)[:300]}

    def _v317_source_items(data):
        if isinstance(data, dict):
            if isinstance(data.get('ac'), list):
                return data.get('ac') or []
            if isinstance(data.get('aircraft'), list):
                return data.get('aircraft') or []
            if isinstance(data.get('data'), list):
                return data.get('data') or []
            if isinstance(data.get('items'), list):
                return data.get('items') or []
        if isinstance(data, list):
            return data
        return []

    def _v317_normalize_adsb_aircraft(item, settings):
        ac=_normalize_adsb_aircraft(item, 'Airplanes.live Server Proxy')
        if not ac:
            return None
        try:
            ac['owner_operator']=item.get('ownOp') or item.get('operator') or item.get('owner') or ac.get('owner_operator') or ''
            ac['ownOp']=item.get('ownOp') or ac.get('ownOp') or ''
            ac['category_raw']=item.get('category') or item.get('emitter_category') or ac.get('category_raw') or ''
            ac['emitter_category']=item.get('emitter_category') or item.get('category') or ''
        except Exception:
            pass
        try:
            if not _adsb_in_radius(ac, settings):
                return None
        except Exception:
            return None
        return ac

    def tak_map_adsb(query_settings=None):
        settings=_load_adsb_settings()
        if isinstance(query_settings, dict):
            qlat=_coerce_float(query_settings.get('center_lat'))
            qlon=_coerce_float(query_settings.get('center_lon'))
            if qlat is not None and qlon is not None and -90 <= qlat <= 90 and -180 <= qlon <= 180:
                settings['center_lat']=qlat; settings['center_lon']=qlon; settings['has_center']=True
            if query_settings.get('radius_miles') is not None:
                try:
                    settings['radius_miles']=max(1,min(250,int(round(float(query_settings.get('radius_miles'))))))
                except Exception:
                    pass
        settings['source_mode']='airplanes_live_server_proxy'
        if settings.get('center_lat') is not None and settings.get('center_lon') is not None:
            settings['has_center']=True
        stale_seconds=_adsb_stale_seconds(settings)
        data,note=_v317_fetch_airplanes(settings)
        raw_items=_v317_source_items(data)
        aircraft_by_id={}
        for item in raw_items:
            if not isinstance(item, dict):
                continue
            ac=_v317_normalize_adsb_aircraft(item, settings)
            if not ac:
                continue
            try:
                if ac.get('seen_seconds') is not None and float(ac.get('seen_seconds') or 999999) > stale_seconds:
                    continue
            except Exception:
                pass
            key=str(ac.get('id') or ac.get('hex') or ac.get('registration') or ac.get('callsign') or '').strip().lower()
            if not key:
                continue
            old=aircraft_by_id.get(key)
            def _rank(x):
                try: return float(x.get('seen_seconds'))
                except Exception: return 999999.0
            if old is None or _rank(ac) < _rank(old):
                aircraft_by_id[key]=ac
        final=list(aircraft_by_id.values())
        final.sort(key=lambda x:(float(x.get('range_miles') or 999999), str(x.get('callsign') or x.get('id') or '')))
        note=dict(note or {})
        note['raw_count']=len(raw_items)
        note['normalized_count']=len(final)
        return {'ok':bool(note.get('ok', True)), 'source_mode':'airplanes_live_server_proxy','aircraft':final,'count':len(final),'sources':[note],'stale_seconds':stale_seconds,'settings':settings}

    TAK_MAP_HTML = _v317_patch_html(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v317_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v317_versions(LOGIN_HTML)
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML

    _v317_prev_get = Handler.do_GET
    def _v317_route_get(self):
        parsed = urlparse(self.path)
        if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
            if parsed.path in ('/', '/index.html', '/tak-map', '/tak-map/'):
                if not self._tak_map_auth_ok():
                    return self._redirect('/tak-map/login')
                return self._send_html(TAK_MAP_HTML)
            if parsed.path in ('/login', '/tak-map/login'):
                if self._tak_map_auth_ok():
                    return self._redirect('/tak-map')
                return self._send_html(TAK_MAP_LOGIN_HTML)
        if parsed.path == '/api/tak-map/adsb':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            qs={}
            for key in ('center_lat','center_lon','radius_miles'):
                if key in q and q.get(key):
                    qs[key]=(q.get(key) or [''])[0]
            return self._send_json(tak_map_adsb(qs))
        return _v317_prev_get(self)
    Handler.do_GET = _v317_route_get
except Exception as _v317_exc:
    try: print('v317 ADS-B server-proxy patch failed:', _v317_exc)
    except Exception: pass
# --- end TAK Map v317 ADS-B server-proxy source + live controls cleanup ---


# --- TAK Map v318 ADS-B popup + aircraft label polish ---
try:
