  function addCss(){try{if(field('v298AdsbNoBlinkStyle'))return;const st=document.createElement('style');st.id='v298AdsbNoBlinkStyle';st.textContent=`
    .leaflet-marker-icon.v298-adsb-leaflet-marker{background:rgba(255,255,255,.001)!important;border:0!important;pointer-events:auto!important;}
