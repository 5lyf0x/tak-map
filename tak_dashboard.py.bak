    #localElevationDialog .local-elev-close{position:absolute!important;top:7px!important;right:8px!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;width:24px!important;height:24px!important;z-index:2922!important;}
    #localElevationDialog .local-elev-head{position:relative!important;padding-right:38px!important;}
    #localElevationDialog .local-elev-status.error{color:#ff8f83!important;font-weight:800!important;}
