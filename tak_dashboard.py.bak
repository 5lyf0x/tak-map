  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V})}catch(_){} }
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign))||'').trim().toLowerCase()}
  function norm(a){a=Object.assign({},a||{});if(!idOf(a))return null;const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return null;a.lat=lat;a.lon=lon;return a}
  function classText(a){let c=String((a&&a.category)||'').toLowerCase();if(c==='gov'||c==='government')c='govt';if(c==='mil')c='military';if(c==='unk')c='unknown';return ({govt:'Govt',military:'Military',civil:'Civil',unknown:'Unknown'}[c]||String(c||'Unknown'))}
