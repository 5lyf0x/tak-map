  function render(list){
    try{
      const layer=getLayer(); if(!layer)return;
      const arr=(Array.isArray(list)?list:[]).filter(a=>a&&Number.isFinite(Number(a.lat))&&Number.isFinite(Number(a.lon))&&idOf(a));
      try{window.lastAircraft=arr}catch(_){}
      try{window.v298StableAdsb=arr}catch(_){}
