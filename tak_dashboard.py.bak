  function addCss(){try{if(q('#v286AdsbPopupStatusStyle'))return;const st=document.createElement('style');st.id='v286AdsbPopupStatusStyle';st.textContent=`
    .leaflet-popup.adsb-object-popup .leaflet-popup-close-button,.leaflet-popup.adsb-v286-popup .leaflet-popup-close-button{display:none!important;visibility:hidden!important;pointer-events:none!important;}
    .leaflet-popup.adsb-v286-popup .leaflet-popup-content,.leaflet-popup.adsb-object-popup .leaflet-popup-content{margin:0!important;min-width:280px!important;max-width:min(360px,calc(100vw - 64px))!important;box-sizing:border-box!important;}
