  async function refreshStableAdsb(){if(updating)return stable;updating=true;try{const r=await fetch('/api/tak-map/adsb',{cache:'no-store'});const j=await r.json();const arr=healthyArray(j&&j.aircraft);const effective=setStable(arr,'fetch /api/tak-map/adsb');try{window.lastAdsbSettings=(j&&j.settings)||window.lastAdsbSettings}catch(_){}try{const st=field('adsbStatus');if(st)st.textContent=effective.length+' active'}catch(_){}if(typeof window.drawAircraft==='function')window.drawAircraft(effective);updateAdsbBanner();if(isAdsbDropdownOpen())renderAdsbDropdown();return effective}catch(e){try{const st=field('adsbStatus');if(st)st.textContent='error'}catch(_){}return stable}finally{updating=false}}
