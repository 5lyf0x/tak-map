k',point_count:pts.length,distance_miles:Number((meters/1609.344).toFixed(3)),distance_km:Number((meters/1000).toFixed(3)),distance_text:distText(meters)}}]};const file=new File([new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'})],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});if(!r.ok)throw new Error('HTTP '+r.status);try{if(typeof refreshLocalData==='function')await refreshLocalData()}catch(_){}try{if(typeof drawImportedObjects==='function')drawImportedObjects()}catch(_){}if(msg)msg.textContent='Saved to Local Data → Routes';setTimeout(()=>{div.remove();clearVisual()},500)}catch(e){if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}}}});setTimeout(()=>{try{(q('#adsbTrackRouteName')||q('[data-act="discard"]',div)).focus()}catch(_){}},30)}catch(e){console.warn('v307 ADS-B save dialog failed',e);clearVisual()}}
