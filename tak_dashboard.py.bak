</script>'''
    if 'id="v301AdsbTrackEventOwnerPatch"' not in TAK_MAP_HTML:
        TAK_MAP_HTML = TAK_MAP_HTML.replace('</body></html>', _v301_patch + '</body></html>')
except Exception as _v301_exc:
    try: print('v301 ADS-B track event owner patch failed:', _v301_exc)
    except Exception: pass
# --- end TAK Map v301 ADS-B tracking event ownership repair ---

# --- TAK Map v302 stabilization/controller cleanup build ---
try:
    # Release label remains 1.1.0; iteration marker advances to v302 only.
    import re as _re_v302
    def _v302_set_versions(_html):
        if not isinstance(_html, str):
            return _html
        _html = _re_v302.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v302', _html)
        _html = _re_v302.sub(r'TAK-Map/1\.1\.0 v\d+', 'TAK-Map/1.1.0 v302', _html)
        _html = _re_v302.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v302</span>', _html)
        _html = _re_v302.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v302</div>', _html)
        _html = _re_v302.sub(r"const\s+V\s*=\s*'v\d+'\s*;", "const V='v302';", _html)
        _html = _re_v302.sub(r'const\s+V\s*=\s*"v\d+"\s*;', 'const V="v302";', _html)
        _html = _re_v302.sub(r'>v\d+<', '>v302<', _html)
        return _html

    def _v302_remove_script(_html, _sid):
        return _re_v302.sub(r'<script[^>]*id=["\']' + _re_v302.escape(_sid) + r'["\'][^>]*>.*?</script>\s*', '', _html, flags=_re_v302.S)

    # Remove duplicate/conflicting historical ADS-B tracking scripts. Their behavior is replaced by the v302 controller.
    for _sid in (
        'v285AdsbClassTypeTrackPatch',
        'v286AdsbAuthoritativePopupStatusPatch',
        'v287AdsbStatusTrackSavePatch',
        'v297AdsbTrackRoutePatch',
        'v300AdsbTrackSaveDialogPatch',
        'v301AdsbTrackEventOwnerPatch',
    ):
        TAK_MAP_HTML = _v302_remove_script(TAK_MAP_HTML, _sid)

    _v302_controller = r'''<script id="v302StabilizedModuleControllers">
(function(){
  'use strict';
  const V='v302';
  const TRACK_LAYER='v302AdsbTrackLayer';
  const LABEL_LAYER='v302AdsbTrackDistanceLayer';
  const TRACK_COLOR='#ff6f2e';
  const POINT_LIMIT=2400;
  window.TakMapControllers = window.TakMapControllers || {};
  const controllers = window.TakMapControllers;
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function byId(id){try{return document.getElementById(id)}catch(_){return null}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function safeName(s){return String(s||'ADS-B Track').replace(/[\\/:*?"<>|]+/g,'-').replace(/\s+/g,' ').trim()||'ADS-B Track'}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V})}catch(_){}try{qa('.version-product').forEach(el=>{el.textContent='TAK Map'})}catch(_){}}
  function getLeafletMap(){try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(typeof map!=='undefined'&&map&&map.addLayer){window.takLeafletMap=map;return map}}catch(_){}try{if(window.map&&window.map.addLayer){window.takLeafletMap=window.map;return window.map}}catch(_){}return null}
  controllers.version={set:setIteration,iteration:V};
  controllers.map={getLeafletMap};

  const adsbState = window.TakMapAdsb = window.TakMapAdsb || {};
  adsbState.tracking = adsbState.tracking || {id:null,meta:null,points:[],timer:null,line:null,label:null};
  const tracking = adsbState.tracking;
  function normalizeId(v){return String(v||'').replace(/^ICAO-/i,'').trim().toLowerCase()}
  function idOf(a){try{return normalizeId(a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flight))}catch(_){return ''}}
  function titleOf(a){try{return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id||a.uid))||'ADS-B').replace(/^ICAO-/i,'').trim()||'ADS-B'}catch(_){return 'ADS-B'}}
  function aircraftList(){try{
    const sources=[window.v298StableAdsb,window._v296StableAdsb,window._v294StableAdsb,window.lastAircraft];
    for(const src of sources){if(Array.isArray(src)&&src.length)return src.filter(Boolean)}
  }catch(_){}return []}
  function findAircraft(id){id=normalizeId(id);return aircraftList().find(a=>idOf(a)===id)||null}
  function titleMatch(t){t=String(t||'').replace(/^ICAO-/i,'').trim().toLowerCase();if(!t)return null;return aircraftList().find(a=>titleOf(a).toLowerCase()===t||idOf(a)===t)||null}
  function idFromElement(el){try{
    if(!el)return '';
    let id=normalizeId(el.dataset&&el.dataset.adsbTrackId); if(id)return id;
    const row=el.closest&&el.closest('[data-adsb-id],[data-aircraft-id],[data-icao]');
    id=normalizeId(row&&(row.getAttribute('data-adsb-id')||row.getAttribute('data-aircraft-id')||row.getAttribute('data-icao'))); if(id)return id;
    const marker=el.closest&&el.closest('.leaflet-marker-icon');
    id=normalizeId(marker&&(marker.getAttribute('data-adsb-id')||marker.dataset&&marker.dataset.adsbId)); if(id)return id;
    const pop=el.closest&&el.closest('.leaflet-popup');
    const h=pop&&q('.adsb-popup h3,.feature-popup h3,h3',pop);
    const a=titleMatch(h&&h.textContent); id=idOf(a); if(id)return id;
    try{if(typeof selectedAircraftId!=='undefined'&&selectedAircraftId)return normalizeId(selectedAircraftId)}catch(_){}
  }catch(_){}return ''}
  function pointFrom(a){const lat=Number(a&&a.lat),lon=Number(a&&a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return null;let altVal=(a&&(a.altitude_ft??a.alt_baro??a.alt_geom));let alt=Number(altVal);if(!Number.isFinite(alt)||String(altVal).toLowerCase()==='ground')alt=0;return {lat,lon,alt,t:Date.now()}}
  function rad(x){return x*Math.PI/180}
  function distanceMeters(pts){let m=0;pts=pts||[];for(let i=1;i<pts.length;i++){const a=pts[i-1],b=pts[i];if(!a||!b)continue;const R=6371008.8,dLat=rad(b.lat-a.lat),dLon=rad(b.lon-a.lon),la1=rad(a.lat),la2=rad(b.lat);const h=Math.sin(dLat/2)**2+Math.cos(la1)*Math.cos(la2)*Math.sin(dLon/2)**2;m+=2*R*Math.asin(Math.min(1,Math.sqrt(h)));}return m}
  function distText(m){m=Number(m)||0;return (m/1609.344).toFixed(1)+'mi/'+(m/1000).toFixed(1)+'km'}
  function ensureLayers(){const m=getLeafletMap();if(!m||!window.L)return null;let g=window[TRACK_LAYER];if(!g){g=L.layerGroup().addTo(m);window[TRACK_LAYER]=g}else if(!m.hasLayer(g))g.addTo(m);let l=window[LABEL_LAYER];if(!l){l=L.layerGroup().addTo(m);window[LABEL_LAYER]=l}else if(!m.hasLayer(l))l.addTo(m);return {map:m,track:g,label:l}}
  function clearVisual(){try{const layers=ensureLayers();if(layers){layers.track.clearLayers();layers.label.clearLayers()}}catch(_){}tracking.line=null;tracking.label=null}
  function redrawTrack(){try{const layers=ensureLayers();if(!layers)return;layers.track.clearLayers();layers.label.clearLayers();const pts=tracking.points||[];const ll=pts.map(p=>[Number(p.lat),Number(p.lon)]).filter(p=>Number.isFinite(p[0])&&Number.isFinite(p[1]));if(ll.length>=2){tracking.line=L.polyline(ll,{color:TRACK_COLOR,weight:4,opacity:.98,lineCap:'round',lineJoin:'round',interactive:false}).addTo(layers.track);try{tracking.line.bringToFront()}catch(_){}}if(ll.length>=1){tracking.label=L.marker(ll[ll.length-1],{interactive:false,zIndexOffset:1800,icon:L.divIcon({className:'adsb-track-distance-label-wrap',html:'<div class="adsb-track-distance-label v302">'+esc(distText(distanceMeters(pts)))+'</div>',iconSize:[1,1],iconAnchor:[0,0]})}).addTo(layers.label)}}catch(e){try{console.warn('v302 ADS-B redraw failed',e)}catch(_){}}}
  function addPointFromAircraft(a){const p=pointFrom(a);if(!p)return false;const pts=tracking.points||(tracking.points=[]);const last=pts[pts.length-1];if(last&&Math.abs(last.lat-p.lat)<0.000002&&Math.abs(last.lon-p.lon)<0.000002&&p.t-last.t<1600){redrawTrack();return false}pts.push(p);if(pts.length>POINT_LIMIT)pts.splice(0,pts.length-POINT_LIMIT);redrawTrack();return true}
  function syncButtons(){try{qa('.adsb-track-btn').forEach(btn=>{let id=normalizeId(btn.dataset&&btn.dataset.adsbTrackId);if(!id){id=idFromElement(btn);if(id)btn.dataset.adsbTrackId=id}const on=!!(tracking.id&&id===tracking.id);btn.classList.toggle('active',on);btn.classList.toggle('tracking',on);btn.setAttribute('aria-pressed',on?'true':'false');btn.dataset.v302Tracking=on?'1':'0';const l=q('.adsb-track-light',btn);if(l){l.classList.toggle('active',on);l.dataset.v302Tracking=on?'1':'0'}})}catch(_){} }
  function tick(){try{if(!tracking.id)return;const a=findAircraft(tracking.id);if(a){tracking.meta=a;addPointFromAircraft(a)}syncButtons()}catch(_){} }
  function startTimer(){if(tracking.timer)return;tracking.timer=setInterval(tick,1000);setTimeout(tick,120)}
  function stopTimer(){if(tracking.timer){clearInterval(tracking.timer);tracking.timer=null}}
  function trackButtonHtml(id){const on=tracking.id&&normalizeId(id)===tracking.id;return '<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn'+(on?' active tracking':'')+'" data-adsb-track-id="'+esc(id)+'" aria-pressed="'+(on?'true':'false')+'"><span class="adsb-track-light '+(on?'active':'')+'"></span><span>Track</span></button></div>'}
  function patchPopup(el){try{if(!el)return;const content=q('.leaflet-popup-content',el)||el;let btn=q('.adsb-track-btn',content);let id=btn?idFromElement(btn):'';if(!id){const h=q('.adsb-popup h3,.feature-popup h3,h3',el);id=idOf(titleMatch(h&&h.textContent))}if(!id)return;if(!btn){content.insertAdjacentHTML('beforeend',trackButtonHtml(id));btn=q('.adsb-track-btn',content)}qa('.adsb-track-btn',content).forEach(b=>{b.dataset.adsbTrackId=id;b.onclick=function(ev){return handleTrackClick(ev,b)}});syncButtons()}catch(e){try{console.warn('v302 popup patch failed',e)}catch(_){}}}
  function patchOpenPopups(){try{qa('.leaflet-popup').forEach(patchPopup)}catch(_){} }
  function closeSaveDialog(){try{const old=byId('adsbTrackSaveDialog');if(old)old.remove()}catch(_){}clearVisual()}
  async function saveRoute(id,meta,pts,msg){const nameInput=byId('adsbTrackRouteName');const title=titleOf(meta||{id});const name=safeName((nameInput&&nameInput.value)||title+' ADS-B Track');const m=distanceMeters(pts);const feature={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(p=>[Number(p.lon),Number(p.lat),Number(p.alt)||0])},properties:{name,source:'TAK Map ADS-B',kind:'route',geometry:'route',route_type:'adsb_aircraft_track',callsign:(meta&&(meta.callsign||meta.flight||meta.registration))||'',hex:String((meta&&(meta.hex||meta.icao||meta.id))||id||'').toUpperCase(),start_time:new Date((pts[0]&&pts[0].t)||Date.now()).toISOString(),end_time:new Date((pts[pts.length-1]&&pts[pts.length-1].t)||Date.now()).toISOString(),point_count:pts.length,distance_miles:Number((m/1609.344).toFixed(3)),distance_km:Number((m/1000).toFixed(3)),distance_text:distText(m)}}]};const blob=new Blob([JSON.stringify(feature,null,2)],{type:'application/geo+json'});const file=new File([blob],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});let j={};try{j=await r.json()}catch(_){}if(!r.ok||j.ok===false)throw new Error(j.error||('HTTP '+r.status));try{if(typeof window.refreshLocalData==='function')await window.refreshLocalData()}catch(_){}try{if(typeof window.drawImportedObjects==='function')window.drawImportedObjects()}catch(_){}if(msg)msg.textContent='Saved';setTimeout(closeSaveDialog,450)}
  function showSaveDialog(id,meta,pts){try{const old=byId('adsbTrackSaveDialog');if(old)old.remove();pts=(pts||[]).slice();const m=distanceMeters(pts),title=titleOf(meta||{id});const stamp=new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');const def=safeName(title+' ADS-B Track '+stamp);const canSave=pts.length>=2;const div=document.createElement('div');div.id='adsbTrackSaveDialog';div.className='adsb-track-save-overlay v302';div.innerHTML='<div class="adsb-track-save-card v302" role="dialog" aria-modal="true" aria-label="Save ADS-B track"><button type="button" class="adsb-track-save-x" data-action="discard" aria-label="Close">×</button><div class="adsb-track-save-title">Save ADS-B Track</div><div class="adsb-track-save-sub">'+esc(title)+' · '+esc(distText(m))+' · '+esc(String(pts.length))+' pts</div><input id="adsbTrackRouteName" class="adsb-track-save-input" value="'+esc(def)+'" '+(canSave?'':'disabled')+' />'+(canSave?'':'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>')+'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div><div class="adsb-track-save-actions"><button type="button" class="layer-button" data-action="discard">Discard</button><button type="button" class="layer-button primary" data-action="save" '+(canSave?'':'disabled')+'>Save</button></div></div>';document.body.appendChild(div);const msg=byId('adsbTrackSaveMsg');div.addEventListener('click',ev=>{const a=ev.target&&ev.target.getAttribute&&ev.target.getAttribute('data-action');if(a==='discard'||ev.target===div){ev.preventDefault();closeSaveDialog();return}if(a==='save'){ev.preventDefault();if(!canSave)return;if(msg){msg.textContent='Saving…';msg.classList.remove('bad')}saveRoute(id,meta,pts,msg).catch(e=>{if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}});return}},true);div.addEventListener('keydown',ev=>{if(ev.key==='Escape')closeSaveDialog()});setTimeout(()=>{try{(byId('adsbTrackRouteName')||q('[data-action="discard"]',div)).focus()}catch(_){}},25)}catch(e){try{console.warn('v302 save dialog failed',e)}catch(_){}clearVisual()}}
  function startTracking(id){id=normalizeId(id);if(!id)return false;const a=findAircraft(id);tracking.id=id;tracking.meta=a||{id};tracking.points=[];closeSaveDialog();if(a)addPointFromAircraft(a);else redrawTrack();startTimer();syncButtons();patchOpenPopups();return true}
  function stopTracking(){const id=tracking.id,meta=tracking.meta,pts=(tracking.points||[]).slice();tracking.id=null;tracking.meta=null;tracking.points=[];stopTimer();syncButtons();patchOpenPopups();showSaveDialog(id,meta,pts);return false}
  function toggleTracking(id){id=normalizeId(id);if(!id)return false;try{if(tracking.id===id)return stopTracking();if(tracking.id){const old={id:tracking.id,meta:tracking.meta,pts:(tracking.points||[]).slice()};tracking.id=null;tracking.meta=null;tracking.points=[];stopTimer();syncButtons();showSaveDialog(old.id,old.meta,old.pts)}return startTracking(id)}catch(e){try{console.warn('v302 ADS-B toggle failed',e)}catch(_){}return false}}
  function handleTrackClick(ev,btn){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}const id=idFromElement(btn);if(id)toggleTracking(id);syncButtons();return false}catch(e){try{console.warn('v302 ADS-B track click failed',e)}catch(_){}return false}}
  function installEventOwner(){try{if(adsbState._v302OwnerBound)return;adsbState._v302OwnerBound=true;window.addEventListener('click',function(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(!btn)return;return handleTrackClick(ev,btn)},true)}catch(e){try{console.warn('v302 owner listener failed',e)}catch(_){}}}
  function installMapHooks(){try{const m=getLeafletMap();if(m&&!adsbState._v302PopupHooks){adsbState._v302PopupHooks=true;m.on('popupopen',ev=>setTimeout(()=>patchPopup(ev.popup&&ev.popup.getElement&&ev.popup.getElement()),0));m.on('popupclose',()=>setTimeout(syncButtons,0));}}catch(_){} }
  function addCss(){try{if(byId('v302StabilizedControllerStyle'))return;const st=document.createElement('style');st.id='v302StabilizedControllerStyle';st.textContent=`
    .adsb-track-btn,.adsb-track-btn *{pointer-events:auto!important;}
    .adsb-track-btn.active,.adsb-track-btn.tracking,.adsb-track-btn[data-v302-tracking="1"]{border-color:rgba(255,59,48,.82)!important;background:linear-gradient(180deg,rgba(255,59,48,.34),rgba(120,20,16,.27))!important;color:#fff!important;box-shadow:0 0 12px rgba(255,59,48,.34)!important;}
    .adsb-track-btn.active .adsb-track-light,.adsb-track-btn.tracking .adsb-track-light,.adsb-track-light.active,.adsb-track-light[data-v302-tracking="1"]{background:#ff3b30!important;border-color:#ff8a82!important;box-shadow:0 0 10px rgba(255,59,48,.9),inset 0 0 3px rgba(0,0,0,.45)!important;}
    .adsb-track-distance-label.v302{background:rgba(8,12,16,.94);border:1px solid rgba(255,111,46,.86);border-radius:999px;color:#ffe4d4;box-shadow:0 6px 18px rgba(0,0,0,.42),0 0 14px rgba(255,111,46,.25);font-size:11px;font-weight:950;letter-spacing:.02em;line-height:1;padding:3px 7px;white-space:nowrap;transform:translate(10px,-12px);}
    .adsb-track-save-overlay.v302{position:fixed;inset:0;z-index:4300;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.44);backdrop-filter:blur(3px);}
    .adsb-track-save-card.v302{position:relative;width:min(420px,calc(100vw - 28px));border:1px solid rgba(255,122,26,.50);border-radius:14px;background:linear-gradient(180deg,rgba(18,27,35,.985),rgba(8,12,18,.985));box-shadow:0 18px 50px rgba(0,0,0,.64),0 0 22px rgba(255,122,26,.14);padding:13px 14px 12px;color:#eef5f7;}
    .adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;margin:0;padding:0;line-height:1;font-size:18px;font-weight:900;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;cursor:pointer;}
    .adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px;}
    .adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750;}
    .adsb-track-save-input{width:100%;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750;outline:none;box-sizing:border-box;}
    .adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850;}.adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850;}.adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px;}
  `;document.head.appendChild(st)}catch(e){try{console.warn('v302 CSS failed',e)}catch(_){}}}
  function boot(){setIteration();addCss();installEventOwner();installMapHooks();patchOpenPopups();qa('.adsb-track-btn').forEach(btn=>{btn.onclick=function(ev){return handleTrackClick(ev,btn)}});syncButtons();tick()}
  adsbState.track={toggle:toggleTracking,start:startTracking,stop:stopTracking,syncButtons,patchOpenPopups,state:tracking,distText,distanceMeters};
  window.toggleAdsbTrack=toggleTracking;
  window.updateAdsbTrackFromStable=function(){try{tick();syncButtons();patchOpenPopups()}catch(_){} };
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
  [250,750,1600,3200,6400].forEach(ms=>setTimeout(boot,ms));
  setInterval(boot,1000);
})();
</script>'''

    if 'id="v302StabilizedModuleControllers"' not in TAK_MAP_HTML:
        TAK_MAP_HTML = TAK_MAP_HTML.replace('</body></html>', _v302_controller + '</body></html>')

    TAK_MAP_HTML = _v302_set_versions(TAK_MAP_HTML)
