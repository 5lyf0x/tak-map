function explicitSidc(o){const vals=[o?.sidc,o?.SIDC,o?.symbol_code,o?.symbolCode,o?.symbol,o?.mil2525,o?.milstd2525,o?.iconsetPath,o?.icon,o?.markerType,o?.category,o?.asset,o?.cot_type,o?.type];for(const v of vals){const c=cotTypeToSidc(v);if(c)return c;const s=normSidc(v);if(s.length>=10&&(s[0]==='S'||s[0]==='G'))return (s+'---------------').slice(0,15)}return ''}function affSlugFromMarker(o){const raw=String([o?.sidc,o?.SIDC,o?.symbol_code,o?.symbolCode,o?.type,o?.cot_type,o?.uid,o?.callsign,o?.name,o?.category,o?.source].filter(Boolean).join(' ')).toLowerCase();const s=explicitSidc(o);const a=s&&s.length>1?s[1]:'';if(a==='H')return'hostile';if(a==='N')return'neutral';if(a==='U')return'unknown';if(a==='F')return'friendly';if(/\ba-h-|hostile|enemy|red\b/.test(raw))return'hostile';if(/\ba-n-|neutral|green\b/.test(raw))return'neutral';if(/\ba-u-|unknown|suspect|gray|grey\b/.test(raw))return'unknown';return'friendly'}function mil2525CandidateExists(name){return MIL2525_ICON_FILES.has(String(name||'')+'.svg')?String(name)+'.svg':''}function firstMil2525Candidate(names){for(const n of names){const f=mil2525CandidateExists(n);if(f)return f}return ''}function generatedMil2525File(o){const sidc=explicitSidc(o);const sidcFile=sidcFileFromSidc(sidc);if(sidcFile)return sidcFile;const aff=affSlugFromMarker(o);const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.callsign,o?.name,o?.title,o?.category,o?.source,o?.filename].filter(Boolean).join(' ')).toLowerCase();const desc=assetDescriptor(o);let c=[];if(/civilian|civil|civ/.test(t)){if(/auto|car|sedan/.test(t))c.push(`${aff}-ground-equipment-civilian-automobile`,`${aff}-ground-equipment-sedan`);if(/suv/.test(t))c.push(`${aff}-ground-equipment-suv`);if(/pickup|truck/.test(t))c.push(`${aff}-ground-equipment-pickup`,`${aff}-ground-equipment-civilian-pickup`);c.push(`${aff}-ground-equipment-civilian-vehicle`)}if(/drone|uas|uav|quadcopter/.test(t))c.push(`${aff}-air-quadcopter`,`${aff}-air-drone-fixed-wing`,`${aff}-air-small-uav`);if(/heli|rotary/.test(t)||desc==='Helicopter')c.push(`${aff}-air-utility-helicopter`,`${aff}-air-civil-rotary-wing`,`${aff}-air-rotary-wing`);if(/aircraft|fixed|air\b|a-[fhnu]-a/.test(t)||desc==='Aircraft')c.push(`${aff}-air-civil-fixed-wing`,`${aff}-air-civil-aircraft`,`${aff}-air-generic`);if(/ship|boat|vessel|maritime|sea|surface/.test(t))c.push(`${aff}-sea-surface-civil-vessel`,`${aff}-sea-surface-patrol-boat`,`${aff}-sea-surface-generic`);if(/submarine|subsurface|uuv|diver/.test(t))c.push(`${aff}-subsurface-submarine`,`${aff}-subsurface-generic`);if(/space|satellite/.test(t))c.push(`${aff}-space-satellite`,`${aff}-space-generic`);if(desc==='Air defense')c.push(`${aff}-ground-unit-air-defense`,`${aff}-ground-equipment-sam-launcher`);if(desc==='Radar / sensor')c.push(`${aff}-ground-equipment-radar`,`${aff}-ground-equipment-sensor`);if(desc==='Artillery')c.push(`${aff}-ground-equipment-self-propelled-artillery`,`${aff}-ground-unit-artillery`,`${aff}-ground-unit-mortar`);if(desc==='Armor')c.push(`${aff}-ground-equipment-tank`,`${aff}-ground-unit-armor`,`${aff}-ground-equipment-armored-vehicle`);if(desc==='Vehicle')c.push(`${aff}-ground-equipment-ground-vehicle`,`${aff}-ground-equipment-cargo-truck`,`${aff}-ground-equipment-civilian-vehicle`);if(/a-[fhnu]-g-u-c-i|g-u-c-i|gpuci|infantry/.test(t))c.push(`${aff}-ground-unit-infantry`);if(/a-[fhnu]-g-u-c-a|g-u-c-a|gpuca|armor/.test(t))c.push(`${aff}-ground-unit-armor`);if(/a-[fhnu]-g-u-c-d|g-u-c-d|gpucd/.test(t))c.push(`${aff}-ground-unit-air-defense`);if(desc==='Ground unit')c.push(`${aff}-ground-unit-infantry`,`${aff}-ground-unit-combat`,`${aff}-ground-generic`);if(desc==='Logistics')c.push(`${aff}-ground-unit-supply`,`${aff}-ground-equipment-fuel-point`,`${aff}-ground-unit-transportation`);if(desc==='Sniper')c.push(`${aff}-ground-unit-sniper`,`${aff}-ground-unit-special-forces`);if(/medical|medevac|hospital|ambulance/.test(t))c.push(`${aff}-ground-unit-medical`,`${aff}-emergency-ems`,`${aff}-ground-equipment-ambulance`);if(/police|sheriff|law/.test(t))c.push(`${aff}-emergency-police`);if(/fire\b|firefighter/.test(t))c.push(`${aff}-emergency-fire`);if(/search.?and.?rescue|\bsar\b|rescue/.test(t))c.push(`${aff}-emergency-search-and-rescue`);if(/hazmat|hazard|warning|danger|alert/.test(t)||desc==='Hazard')c.push(`${aff}-emergency-hazmat`,`${aff}-ground-generic`);c.push(`${aff}-ground-generic`,'unknown-ground-generic','unknown-ground-equipment-ground-vehicle');return firstMil2525Candidate(c)}function mil2525IconHtml(o){const f=generatedMil2525File(o||{});if(f){const alt=esc((o?.sidc||o?.type||o?.callsign||o?.name||f));return `<div class="tak-icon-wrap"><img class="tak-mil2525-img" src="${mil2525IconFilePath(f)}" alt="${alt}"></div>`}return `<div class="tak-icon-wrap">${milShape(affKey(String([o?.type,o?.cot_type,o?.uid,o?.callsign,o?.name,o?.source].filter(Boolean).join(' '))),'', '')}</div>`}function dataSyncCategory(o){const g=String(o?.geometry||o?.kind||'').toLowerCase();const t=String([o?.type,o?.source,o?.uid,o?.callsign,o?.filename,o?.name].filter(Boolean).join(' ')).toLowerCase();if(g==='route'||/route|track|path|gpx/.test(t))return'Routes';if(g==='shape'||/shape|polygon|rectangle|circle|ellipse|area|polyline|freehand|corridor|sector/.test(t))return'Shapes / Areas';if(g==='other'||/file|package|attachment|zip|kmz|kml|geojson/.test(t))return'Files / Packages';if(o&&o.lat!=null&&o.lon!=null)return'Point Markers';return'Other / Unknown'}function routeShapeIconHtml(cat){const isRoute=cat==='Routes';const c=isRoute?'#ff8a2a':'#ffb000';const body=isRoute?`<path d="M7 24 C13 12 22 30 30 14" fill="none" stroke="${c}" stroke-width="3" stroke-linecap="round"/>`:`<rect x="7" y="9" width="22" height="20" rx="4" fill="rgba(255,176,0,.10)" stroke="${c}" stroke-width="2.5" stroke-dasharray="4 3"/>`;return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="36" height="40" viewBox="0 0 36 40">${body}<circle cx="18" cy="37" r="3" fill="${c}"/></svg></div>`}function dataSyncIcon(o){const cat=dataSyncCategory(o);if(cat==='Routes'||cat==='Shapes / Areas')return L.divIcon({className:'',html:routeShapeIconHtml(cat),iconSize:[36,40],iconAnchor:[18,22]});return L.divIcon({className:'',html:mil2525IconHtml(o),iconSize:[36,40],iconAnchor:[18,22]})}function isFiniteLatLon(lat,lon){lat=Number(lat);lon=Number(lon);return Number.isFinite(lat)&&Number.isFinite(lon)&&lat>=-90&&lat<=90&&lon>=-180&&lon<=180}function coordPair(x){if(Array.isArray(x)&&x.length>=2){const lat=Number(x[0]),lon=Number(x[1]);if(isFiniteLatLon(lat,lon))return [lat,lon]}else if(x&&typeof x==='object'){const lat=Number(x.lat??x.latitude);const lon=Number(x.lng??x.lon??x.longitude);if(isFiniteLatLon(lat,lon))return [lat,lon]}return null}function collectCoordPairs(value){const out=[];const walk=x=>{const p=coordPair(x);if(p){out.push(p);return}if(Array.isArray(x)){for(const y of x)walk(y)}};walk(value);return out}function routeCoords(o){return collectCoordPairs(o?.coords)}function shapeCoords(o){const c=o?.coords;if(!Array.isArray(c))return[];const direct=c.map(coordPair).filter(Boolean);if(direct.length===c.length&&direct.length>=3)return direct;const rings=[];for(const r of c){if(Array.isArray(r)){const pts=r.map(coordPair).filter(Boolean);if(pts.length>=3)rings.push(pts)}}if(rings.length)return rings.length===1?rings[0]:rings;return collectCoordPairs(c)}
function shapeAreaSqMeters(o){try{const pts=collectCoordPairs(o?.coords||o);if(!pts||pts.length<3)return 0;const lat0=pts.reduce((a,p)=>a+Number(p[0]||0),0)/pts.length;const lon0=pts.reduce((a,p)=>a+Number(p[1]||0),0)/pts.length;const R=6378137;const xy=pts.map(p=>{const lat=Number(p[0])*Math.PI/180,lon=Number(p[1])*Math.PI/180;return {x:R*(lon-lon0*Math.PI/180)*Math.cos(lat0*Math.PI/180),y:R*(lat-lat0*Math.PI/180)}});let a=0;for(let i=0,j=xy.length-1;i<xy.length;j=i++){a+=(xy[j].x*xy[i].y-xy[i].x*xy[j].y)}return Math.abs(a/2)}catch(e){return 0}}
function shapeAreaPopupRows(o){const m2=shapeAreaSqMeters(o);if(!m2)return'';const sqft=m2*10.7639104167;return `<b>Area</b><span>${Math.round(sqft).toLocaleString()} sq ft · ${Math.round(m2).toLocaleString()} sq m</span>`}
function objectCenter(o){if(o&&isFiniteLatLon(o.lat,o.lon))return [Number(o.lat),Number(o.lon)];const pts=collectCoordPairs(o?.coords);if(pts.length)return [pts.reduce((a,p)=>a+p[0],0)/pts.length,pts.reduce((a,p)=>a+p[1],0)/pts.length];return null}function layerPopupForObject(o,cat){if(cat==='Point Markers')return pointPopupHtml(o,cat);const name=o?.name||o?.callsign||o?.uid||o?.id||cat;const notes=popupNotes(o);const cen=objectCenter(o);const coordText=cen?formatCoords(cen[0],cen[1]):formatCoords(o?.lat,o?.lon);const assetRow=(cat==='Shapes / Areas')?shapeAreaPopupRows(o):`<b>Asset</b><span>${esc(assetDescriptor(o))}</span>`;return `<div class="feature-popup"><h3>${esc(name)}</h3><div class="kvp"><b>Name</b><span>${esc(name)}</span><b>Added</b><span>${esc(addedTime(o))}</span><b>Coordinates</b><span>${esc(coordText)}</span>${assetRow}<b>Category</b><span>${esc(cat)}</span>${notes?`<b>Notes</b><span>${esc(notes)}</span>`:''}</div>${popupEditForm({...o,lat:cen?cen[0]:o?.lat,lon:cen?cen[1]:o?.lon},cat||'Data Sync')}</div>`}function addObjectLayer(group,o,sourceKey){const cat=dataSyncCategory(o);let layer=null;const cen=objectCenter(o);try{if(cen&&(!isFiniteLatLon(o?.lat,o?.lon))){o.lat=cen[0];o.lon=cen[1]}if(cat==='Routes'){const pts=routeCoords(o);if(pts.length>=2){const dash=(o.lineStyle==='dashed'||o.style==='dashed'||o.line_style==='dashed'||o.route_style==='dashed')?'8,7':null;layer=L.polyline(pts,{color:(o.color||'#ff7a1a'),weight:3,opacity:.9,dashArray:dash}).bindPopup(layerPopupForObject(o,cat)).addTo(group);try{const hit=L.polyline(pts,{color:'#000',weight:16,opacity:0,interactive:true}).addTo(group);hit.bindPopup(layer.getPopup());hit.on('click',ev=>{try{L.DomEvent.stop(ev);layer.openPopup(ev.latlng)}catch(_){}});o.__hitLayer=hit}catch(_){}}}else if(cat==='Shapes / Areas'){const pts=shapeCoords(o);const flat=collectCoordPairs(pts);if(flat.length>=3)layer=L.polygon(pts,{color:'#ffb000',weight:2,fillOpacity:.18}).bindPopup(layerPopupForObject(o,cat)).addTo(group)}else if(cen){layer=L.marker(cen,{icon:dataSyncIcon(o)}).bindPopup(layerPopupForObject(o,cat)).addTo(group);layer.on('click',()=>map.panTo(cen,{animate:true}))}}catch(e){try{console.warn('Skipped invalid map object',o,e)}catch(_){}}if(layer){stabilizeLayerPopup(layer);o.__layer=layer;const center=cen||objectCenter(o);if(center)addSearchItem(sourceKey||'datasync',(sourceKey==='imported'?'Imported ':'Data Sync ')+cat,o.callsign||o.name||o.uid||o.id||cat,center[0],center[1],layer,o)}return layer}async function centerDataSyncIndex(idx){await autoSaveActivePopupEdit('switch-data-sync-item');const o=(lastDataSync?.objects||[])[Number(idx)];const cen=objectCenter(o);if(!o||!cen)return;map.panTo(cen,{animate:true});if(o.__layer){setTimeout(()=>{try{o.__layer.openPopup()}catch(e){}},180)}}async function openDataSyncItemEdit(idx,ev){if(ev)ev.stopPropagation();await centerDataSyncIndex(idx);setTimeout(()=>{try{const box=document.querySelector('.leaflet-popup .popup-edit');if(box){box.open=true;popupEditToggle(box);const first=popupEditInputs(box)[0];if(first)first.focus()}}catch(e){}},320)}async function deleteDataSyncItem(idx,ev){if(ev)ev.stopPropagation();idx=Number(idx);const o=(lastDataSync?.objects||[])[idx];if(!o)return;const label=o.callsign||o.name||o.uid||o.id||'Data Sync item';if(!confirm('Delete '+label+' from the TAK Map view?'))return;await autoSaveActivePopupEdit('delete-data-sync');try{const r=await fetch('/api/tak-map/popup-edit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({key:popupEditKey(o),source:o.source||'Data Sync',delete_item:true}),cache:'no-store'});const j=await apiJsonResponseAllowFalse(r);if(!j.ok)throw new Error(j.error||'delete failed');try{if(o.__layer)dataSyncLayer.removeLayer(o.__layer);if(map&&map.closePopup)map.closePopup()}catch(_){ }try{if(lastDataSync&&Array.isArray(lastDataSync.objects)){lastDataSync.objects=lastDataSync.objects.filter((_,i)=>i!==idx);drawDataSyncObjects(lastDataSync.objects);renderDataSyncRows()}}catch(_){ }await forceDataSyncSync('data-sync-delete');await refreshCot();await refreshImports();await refreshLocalData()}catch(e){alert('Delete failed: '+e)}}function drawDataSyncObjects(items){if(terrain3DActive){handleMapSearch();refreshTerrain3DObjects(false,'datasync');return}dataSyncLayer.clearLayers();clearSearchSource('datasync');if(!state.dataSync){handleMapSearch();refreshTerrain3DObjects(false,'datasync-off');return}for(let idx=0;idx<(items||[]).length;idx++){addObjectLayer(dataSyncLayer,items[idx],'datasync')}handleMapSearch();refreshTerrain3DObjects(false,'datasync')}function toggleDataSyncSection(kind){try{state.dataSyncCollapsed[kind]=!state.dataSyncCollapsed[kind];saveTakMapUiPrefs();renderDataSyncRows()}catch(e){try{console.warn('toggleDataSyncSection failed',e)}catch(_){}}}function renderDataSyncSection(kind,title,items,renderItem,limit){items=items||[];limit=limit||80;const collapsed=!!state.dataSyncCollapsed[kind];let html=`<div class="datasync-section ${collapsed?'collapsed':''}"><div class="datasync-section-title subgroup-title" onclick="toggleDataSyncSection('${kind}')" role="button" aria-expanded="${collapsed?'false':'true'}"><span class="toggle">${collapsed?'›':'⌄'}</span><span class="section-label">${esc(title)}</span><span class="chip">${items.length}</span></div><div class="datasync-section-list">`;html+=items.length?items.slice(0,limit).map(renderItem).join(''):`<div class="muted datasync-empty">None.</div>`;if(items.length>limit)html+=`<div class="muted datasync-empty">Showing ${limit} of ${items.length}.</div>`;html+='</div></div>';return html}function renderDataSyncRows(){const box=document.getElementById('dataSyncRows');if(!box||!lastDataSync)return;const missions=(lastDataSync.missions||[]);const objects=(lastDataSync.objects||[]);const packages=(lastDataSync.packages||[]);let html='';html+=renderDataSyncSection('missions','Missions',missions,m=>`<div class="sync-card"><b>${esc(missionNameFromAny(m))}</b><small>${esc(missionDisplayMeta(m))}</small></div>`,24);const groups={'Pointers':[],'Routes':[],'Shapes / Areas':[],'Files / Packages':[],'Other / Unknown':[]};for(let i=0;i<objects.length;i++){const o=objects[i];o.__idx=i;const cat=dataSyncCategory(o);const key=cat==='Point Markers'?'Pointers':cat;(groups[key]||groups['Other / Unknown']).push(o)}for(const p of packages){groups['Files / Packages'].push(p)}const objectCard=o=>{const idx=o.__idx;const label=o.callsign||o.uid||o.name||o.filename||o.id||'object';const meta=assetDescriptor(o)+(o.lat!=null?' · '+formatCoords(o.lat,o.lon):'');const actions=idx!=null?`<div class="sync-card-actions"><button class="layer-button" onclick="openDataSyncItemEdit(${idx},event)">Edit</button><button class="layer-button" onclick="deleteDataSyncItem(${idx},event)">Delete</button></div>`:'';return `<div class="sync-card sync-card-actionable" ${idx!=null?`onclick="centerDataSyncIndex(${idx})" style="cursor:pointer"`:''}><div class="sync-card-main"><b>${esc(label)}</b><small>${esc(meta)}</small></div>${actions}</div>`};html+=renderDataSyncSection('pointers','Pointers',groups['Pointers'],objectCard,80);html+=renderDataSyncSection('routes','Routes',groups['Routes'],objectCard,80);html+=renderDataSyncSection('shapes','Shapes / Areas',groups['Shapes / Areas'],objectCard,80);html+=renderDataSyncSection('files','Files / Packages',groups['Files / Packages'],objectCard,80);html+=renderDataSyncSection('other','Other / Unknown',groups['Other / Unknown'],objectCard,80);box.innerHTML=html}let lastImports=[];async function refreshImports(){try{const r=await fetch('/api/tak-map/imported',{cache:'no-store'});const j=await r.json();lastImports=j.imports||[];renderImportRows();drawImportedObjects()}catch(e){const box=document.getElementById('importRows');if(box)box.innerHTML='<div class="danger">Could not load imported files: '+esc(e)+'</div>'}}function toggleImportedObjects(on){state.imported=!!on;if(on){importedLayer.addTo(map);drawImportedObjects()}else{importedLayer.clearLayers();if(map.hasLayer(importedLayer))map.removeLayer(importedLayer)}}async function uploadImportFiles(){const inp=document.getElementById('importFileInput');if(!inp||!inp.files||!inp.files.length){alert('Choose one or more map files first.');return}const fd=new FormData();for(const f of inp.files)fd.append('files',f,f.name);const localBox=document.getElementById('localDataRows');const box=document.getElementById('importRows');if(localBox)localBox.innerHTML='<div class="muted">Adding local file...</div>';if(box)box.innerHTML='<div class="muted">Importing files...</div>';try{const r=await fetch('/api/tak-map/import',{method:'POST',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));inp.value='';lastImports=j.imports||lastImports;renderImportRows();await refreshLocalData();try{drawImportedObjects()}catch(drawErr){try{console.warn('Local data imported but map draw failed',drawErr)}catch(_){}}}catch(e){if(localBox)renderLocalDataRows('Import failed: '+e);if(box)box.innerHTML='<div class="danger">Import failed: '+esc(e)+'</div>'}}async function clearImportedFiles(){if(!confirm('Clear imported TAK Map files?'))return;await fetch('/api/tak-map/import-clear',{method:'POST'});lastImports=[];renderImportRows();drawImportedObjects()}function importedFeatures(){const out=[];for(const imp of lastImports||[]){(imp.features||[]).forEach((f,idx)=>{f.import_id=imp.id;f.import_name=imp.name;f.import_feature_index=idx;f.uploaded=imp.uploaded;f._local_id=(imp.id||imp.name)+':'+idx;out.push(f)})}const routeEnds=[];for(const f of out){const s=String(f.kind||f.geometry||f.geometry_type||f.type||'').toLowerCase();const coords=Array.isArray(f.coords)?f.coords:[];if((s.includes('route')||s.includes('track')||s.includes('linestring'))&&coords.length>=2){routeEnds.push(coords[0],coords[coords.length-1])}}function nearEndpoint(f){if(f.lat==null||f.lon==null)return false;const lat=Number(f.lat),lon=Number(f.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return false;const s=String(f.kind||f.geometry||f.geometry_type||f.type||'').toLowerCase();if(s.includes('route')||s.includes('linestring')||s.includes('track'))return false;const name=String(f.name||f.callsign||f.title||'').toLowerCase();const endpointName=/^(start|end|finish|route start|route end|start point|end point|begin|destination)$/i.test(name.trim())||name.includes('start')||name.includes('end');return routeEnds.some(pt=>Array.isArray(pt)&&Math.abs(Number(pt[0])-lat)<0.00010&&Math.abs(Number(pt[1])-lon)<0.00010&&(endpointName||true))}return out.filter(f=>!nearEndpoint(f))}function drawImportedObjects(){if(terrain3DActive){const c=document.getElementById('importedCount');if(c)c.textContent=String((importedFeatures?importedFeatures():[]).length);handleMapSearch();refreshTerrain3DObjects(false,'local');return}importedLayer.clearLayers();clearSearchSource('imported');if(!state.imported){handleMapSearch();refreshTerrain3DObjects(false,'local-off');return}let shown=0;for(const f of importedFeatures()){try{const lid=String(f._local_id||f.id||f.uid||f.name||'');if(lid&&state.local.hidden[lid])continue;if(addObjectLayer(importedLayer,f,'imported'))shown++}catch(e){try{console.warn('Skipped imported feature',f,e)}catch(_){}}}const c=document.getElementById('importedCount');if(c)c.textContent=String(shown);handleMapSearch();refreshTerrain3DObjects(false,'local')}function renderImportRows(){const box=document.getElementById('importRows');if(!box)return;const imports=lastImports||[];let html=`<div class="subgroup-title">Imported files <span class="chip">${imports.length}</span></div>`;if(!imports.length){box.innerHTML=html+'<div class="muted">No imported files yet.</div>';return}html+=imports.slice().reverse().map(imp=>`<div class="import-card"><b>${esc(imp.name)}</b><small>Points: ${esc(imp.counts?.point||0)} · Routes: ${esc(imp.counts?.route||0)} · Shapes: ${esc(imp.counts?.shape||0)} · Other: ${esc(imp.counts?.other||0)}</small></div>`).join('');box.innerHTML=html}


function renderOfflineSourceOptions(){updateOfflineSourceText()}function currentDownloadSource(){const id=activeBasemap||savedBasemap()||config?.default_basemap||'';const b=(config?.offline_download_sources||[]).find(s=>s.id===id);return b||null}function updateOfflineSourceText(){const el=document.getElementById('offlineSourceText');const src=currentDownloadSource();if(el)el.textContent=src?src.label:'Select an online no-key basemap';}function useCurrentViewForOffline(){if(!map){return}stopOfflineAreaDraw();const b=map.getBounds();offlineDownloadBounds={west:b.getWest(),south:b.getSouth(),east:b.getEast(),north:b.getNorth()};drawOfflineAreaRectangle(b);updateOfflineBoundsText();lastOfflineEstimate=null;estimateOfflineDownload(false)}function updateOfflineBoundsText(){const el=document.getElementById('offlineBoundsText');if(!el)return;if(!offlineDownloadBounds){el.innerHTML='No area selected yet.';return}el.innerHTML=`West: ${offlineDownloadBounds.west.toFixed(5)} &nbsp; South: ${offlineDownloadBounds.south.toFixed(5)}<br>East: ${offlineDownloadBounds.east.toFixed(5)} &nbsp; North: ${offlineDownloadBounds.north.toFixed(5)}`}function setOfflineBoundsFromLeafletBounds(lb){offlineDownloadBounds={west:lb.getWest(),south:lb.getSouth(),east:lb.getEast(),north:lb.getNorth()};updateOfflineBoundsText();lastOfflineEstimate=null;estimateOfflineDownload(false)}function drawOfflineAreaRectangle(lb){if(offlineAreaRect){try{map.removeLayer(offlineAreaRect)}catch(e){}}offlineAreaRect=L.rectangle(lb,{className:'offline-draw-rect',color:'#ff6f2e',weight:2,fillOpacity:.10}).addTo(map)}function clearOfflineArea(){offlineDownloadBounds=null;lastOfflineEstimate=null;updateOfflineBoundsText();const est=document.getElementById('offlineEstimate');if(est)est.textContent='Use Current View or Draw Area, then choose zoom range to estimate download size.';if(offlineAreaRect){try{map.removeLayer(offlineAreaRect)}catch(e){}offlineAreaRect=null}if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(e){}offlineDrawRect=null}stopOfflineAreaDraw()}function startOfflineAreaDraw(){if(!map)return;stopOfflineAreaDraw();offlineDrawing=true;offlineDrawStart=null;map.dragging.disable();const help=document.getElementById('offlineDrawHelp');if(help)help.style.display='block';map.getContainer().style.cursor='crosshair'}function stopOfflineAreaDraw(){offlineDrawing=false;offlineDrawStart=null;map.getContainer().style.cursor='';try{map.dragging.enable()}catch(e){}const help=document.getElementById('offlineDrawHelp');if(help)help.style.display='none'}function initOfflineAreaDrawing(){map.on('mousedown',e=>{if(!offlineDrawing)return;offlineDrawStart=e.latlng;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}}offlineDrawRect=L.rectangle(L.latLngBounds(offlineDrawStart,offlineDrawStart),{className:'offline-draw-rect',color:'#ff6f2e',weight:2,fillOpacity:.10}).addTo(map)});map.on('mousemove',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect)return;offlineDrawRect.setBounds(L.latLngBounds(offlineDrawStart,e.latlng))});map.on('mouseup',e=>{if(!offlineDrawing||!offlineDrawStart)return;const lb=L.latLngBounds(offlineDrawStart,e.latlng);stopOfflineAreaDraw();if(lb.getNorth()===lb.getSouth()||lb.getEast()===lb.getWest())return;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}offlineDrawRect=null}drawOfflineAreaRectangle(lb);setOfflineBoundsFromLeafletBounds(lb)});map.on('touchstart',e=>{if(!offlineDrawing||!e.latlng)return;offlineDrawStart=e.latlng;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}}offlineDrawRect=L.rectangle(L.latLngBounds(offlineDrawStart,offlineDrawStart),{className:'offline-draw-rect',color:'#ff6f2e',weight:2,fillOpacity:.10}).addTo(map)});map.on('touchmove',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect||!e.latlng)return;offlineDrawRect.setBounds(L.latLngBounds(offlineDrawStart,e.latlng))});map.on('touchend',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect)return;const lb=offlineDrawRect.getBounds();stopOfflineAreaDraw();drawOfflineAreaRectangle(lb);setOfflineBoundsFromLeafletBounds(lb)})}function offlinePayload(){const src=currentDownloadSource();let minz=parseInt(document.getElementById('offlineMinZoom')?.value||'8',10);let maxz=parseInt(document.getElementById('offlineMaxZoom')?.value||'13',10);if(!Number.isFinite(minz))minz=8;if(!Number.isFinite(maxz))maxz=13;if(maxz<minz){const t=minz;minz=maxz;maxz=t}return {source_id:src?.id||'',bounds:offlineDownloadBounds,min_zoom:minz,max_zoom:maxz,name:(document.getElementById('offlinePackName')?.value||'').trim()}}function fmtBytes(n){n=Number(n||0);if(n>1073741824)return (n/1073741824).toFixed(2)+' GB';if(n>1048576)return (n/1048576).toFixed(1)+' MB';if(n>1024)return (n/1024).toFixed(1)+' KB';return n+' B'}let offlineEstimateTimer=null;function scheduleOfflineEstimate(){if(!offlineDownloadBounds)return;clearTimeout(offlineEstimateTimer);offlineEstimateTimer=setTimeout(()=>estimateOfflineDownload(true),450)}async function estimateOfflineDownload(silent=false){const box=document.getElementById('offlineEstimate');try{updateOfflineSourceText();const payload=offlinePayload();const src=currentDownloadSource();if(!src)throw new Error('The current basemap cannot be downloaded. Select an online no-key ESRI/USGS basemap first.');if(!payload.bounds)throw new Error('Select an area first.');if(box&&!silent)box.textContent='Estimating tile count...';const r=await fetch('/api/tak-map/offline-estimate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));lastOfflineEstimate=j;const mapType=(src.group||'Basemap')+' · '+src.label;const msg=`${esc(mapType)}<br>${j.tile_count} tiles · estimated total download ${fmtBytes(j.estimated_bytes)} · limit ${j.max_tiles} tiles`+(j.allowed?'':' · reduce area or zoom range');if(box)box.innerHTML=`<span class="${j.allowed?'':'danger'}">${msg}</span>`;return j}catch(e){if(box&&!silent)box.innerHTML='<span class="danger">Estimate failed: '+esc(e)+'</span>';return null}}function previewOfflineZoom(){if(!map)return;let z=parseInt(document.getElementById('offlineMaxZoom')?.value||String(map.getZoom()),10);if(!Number.isFinite(z))z=map.getZoom();map.setZoom(z);updateZoomIndicator();scheduleOfflineEstimate()}async function startOfflineDownload(){const status=document.getElementById('offlineJobStatus');try{let est=lastOfflineEstimate;if(!est||!est.allowed)est=await estimateOfflineDownload();if(!est||!est.allowed)return;const payload=offlinePayload();if(status)status.textContent='Starting offline map download job...';const r=await fetch('/api/tak-map/offline-download',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));const nameInput=document.getElementById('offlinePackName');if(nameInput)nameInput.value='';clearOfflineArea();pollOfflineJob(j.job.id)}catch(e){if(status)status.innerHTML='<span class="danger">Download failed to start: '+esc(e)+'</span>'}}
async function controlOfflineJob(id,action){const status=document.getElementById('offlineJobStatus');try{const r=await fetch('/api/tak-map/offline-control',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,action})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));if(status)status.textContent=(action==='pause'?'Pause':'Cancel')+' requested. Saving downloaded tiles as a partial pack...';pollOfflineJob(id)}catch(e){if(status)status.innerHTML='<span class="danger">Offline download control failed: '+esc(e)+'</span>'}}async function resumeOfflineMap(id){const status=document.getElementById('offlineJobStatus');try{const r=await fetch('/api/tak-map/offline-resume',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));if(status)status.textContent='Resume started. Existing tiles will be skipped...';pollOfflineJob(j.job.id)}catch(e){if(status)status.innerHTML='<span class="danger">Resume failed: '+esc(e)+'</span>';else alert('Resume failed: '+e)}}

function capStatus(s){s=String(s||'');return s?s.charAt(0).toUpperCase()+s.slice(1):''}function etaFromJob(job){const total=Number(job.tile_count||0),done=Number(job.done||0);if(!total||!done||done>=total)return'';const t=Date.parse(job.started||job.created||'');if(!Number.isFinite(t))return'';const elapsed=Math.max(1,(Date.now()-t)/1000);const rate=done/elapsed;if(rate<=0)return'';let s=Math.max(0,Math.round((total-done)/rate));const h=Math.floor(s/3600);s%=3600;const m=Math.floor(s/60);const sec=s%60;if(h)return`ETA ${h}h ${String(m).padStart(2,'0')}m`;return`ETA ${m}m ${String(sec).padStart(2,'0')}s`}async function pollOfflineJob(id){if(offlineJobTimer)clearTimeout(offlineJobTimer);const status=document.getElementById('offlineJobStatus');try{const r=await fetch('/api/tak-map/offline-jobs?id='+encodeURIComponent(id),{cache:'no-store'});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));const job=j.job||{};const total=Number(job.tile_count||0),done=Number(job.done||0),saved=Number(job.saved||0),failed=Number(job.failed||0);const pct=total?Math.min(100,Math.round(done/total*100)):0;const label=capStatus(job.status||'running');const eta=etaFromJob(job);const controls=(job.status==='running'||job.status==='queued')?`<br><button class="layer-button" onclick="controlOfflineJob('${esc(id)}','pause')">Pause</button> <button class="layer-button" onclick="controlOfflineJob('${esc(id)}','cancel')">Cancel / save partial</button>`:'';if(status)status.innerHTML=`${esc(label)} · ${pct}% · ${done}/${total} checked · saved ${saved} · failed ${failed}${eta?' · '+esc(eta):''}<br>${esc(job.message||'')}${controls}`;updateTopBannerCached();if(['done','paused','canceled','error'].includes(job.status)){await refreshOfflineMaps(true);updateTopBanner();return}offlineJobTimer=setTimeout(()=>pollOfflineJob(id),2500)}catch(e){if(status)status.innerHTML='<span class="danger">Could not read offline job status: '+esc(e)+'</span>'}}
function offlineBasemapEntry(m){return {id:'offline_'+m.id,label:'Offline · '+(m.name||m.filename||'Map Pack'),group:'Offline Maps',type:'mbtiles',url:'/api/tak-map/offline-tile/'+encodeURIComponent(m.id)+'/{z}/{x}/{y}.png',attribution:m.attribution||'Offline MBTiles',minZoom:m.min_zoom||0,maxZoom:m.max_zoom||19,format:m.format||''}}function applyOfflineBasemaps(){if(!config)return;config.basemaps=(config.basemaps||[]).filter(b=>String(b.group||'')!=='Offline Maps');for(const m of offlineMaps||[]){config.basemaps.push(offlineBasemapEntry(m))}}async function refreshOfflineMaps(render=true){try{const r=await fetch('/api/tak-map/offline-maps',{cache:'no-store'});const ct=(r.headers.get('content-type')||'').toLowerCase();if(!r.ok)throw new Error('HTTP '+r.status);if(!ct.includes('application/json'))throw new Error('Offline Maps API returned non-JSON');const j=await r.json();offlineMaps=j.maps||[];applyOfflineBasemaps();if(render){renderOfflineMapRows();renderBasemaps()}}catch(e){const box=document.getElementById('offlineMapRows');if(box)box.innerHTML='<div class="danger">Could not load offline maps: '+esc(e)+'</div>'}}async function uploadOfflineMaps(){const inp=document.getElementById('offlineMapInput');if(!inp||!inp.files||!inp.files.length){alert('Choose one or more .mbtiles files first.');return}const fd=new FormData();for(const f of inp.files)fd.append('files',f,f.name);const box=document.getElementById('offlineMapRows');if(box)box.innerHTML='<div class="muted">Importing offline map pack...</div>';try{const r=await fetch('/api/tak-map/offline-upload',{method:'POST',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));inp.value='';offlineMaps=j.maps||[];applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps()}catch(e){if(box)box.innerHTML='<div class="danger">Offline map import failed: '+esc(e)+'</div>'}}async function deleteOfflineMap(id){if(!confirm('Delete this offline map pack from the TAK server?'))return;try{const r=await fetch('/api/tak-map/offline-delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));offlineMaps=j.maps||[];applyOfflineBasemaps();if(activeBasemap==='offline_'+id){setBasemap(config.default_basemap||'esri_topo')}renderOfflineMapRows();renderBasemaps()}catch(e){alert('Delete failed: '+e)}}async function ensureOfflinePackage(id){try{const r=await fetch('/api/tak-map/offline-eud-package',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id})});const j=await r.json();if(j.maps){offlineMaps=j.maps;applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps()}return j}catch(e){return {ok:false,error:String(e)}}}
function titleCaseStatus(s){return String(s||'').toLowerCase().replace(/\b\w/g,c=>c.toUpperCase())}function renderOfflineMapRows(){const box=document.getElementById('offlineMapRows');if(!box)return;const maps=offlineMaps||[];let html=`<div class="subgroup-title offline-packs-title"><span>Offline Map Packs</span><span class="chip">${maps.length}</span></div>`;if(!maps.length){box.innerHTML=html+'<div class="muted">No offline map packs yet. Download a pack from the current basemap or import MBTiles.</div>';return}html+=maps.map(m=>{const size=m.size_bytes?((m.size_bytes/1048576).toFixed(m.size_bytes>104857600?0:1)+' MB'):'unknown size';const zoom=(m.min_zoom!=null&&m.max_zoom!=null)?`z${m.min_zoom}–z${m.max_zoom}`:'zoom unknown';const fmt=(m.format||'format unknown').toUpperCase();const req=Number(m.requested_tile_count||m.tile_count||0);const got=Number(m.tile_count||0);const failed=Number(m.failed_tile_count||0);const remaining=Number(m.remaining_tile_count!=null?m.remaining_tile_count:Math.max(0,req-got));const rawStatus=m.partial||m.resume_available?`Partial · ${got}/${req||got} Tiles · ${remaining} Remaining · ${failed} Failed`:`Complete · ${got} Tiles${failed?` · ${failed} Failed`:''}`;const status=titleCaseStatus(rawStatus);const statusChip=(m.partial||m.resume_available)?'<span class="chip offline-status-chip">Partial</span>':'<span class="chip good offline-status-chip">Complete</span>';const resume=(m.resume_available||m.partial)?`<button class="layer-button" onclick="resumeOfflineMap('${esc(m.id)}')">Resume Download</button>`:'';return `<div class="offline-card"><div class="offline-card-title"><b>${esc(m.name||m.filename||'Offline map')}</b>${statusChip}</div><small>${esc(fmt)} · ${esc(zoom)} · ${esc(size)}<br>${esc(status)}${m.source_label?' · '+esc(m.source_label):''}</small><div class="row"><button class="layer-button" onclick="setBasemap('offline_${esc(m.id)}')">Apply</button>${resume}<button class="layer-button" onclick="openSendOfflineMap('${esc(m.id)}')">Send</button><button class="layer-button" onclick="deleteOfflineMap('${esc(m.id)}')">Delete</button></div></div>`}).join('');box.innerHTML=html}
async function apiJsonResponse(r){
  const txt=await r.text();
  let j=null;
  try{j=txt?JSON.parse(txt):{};}catch(e){
    throw new Error('HTTP '+r.status+' returned non-JSON: '+txt.slice(0,220).replace(/\s+/g,' '));
  }
  if(!r.ok||!j.ok)throw new Error(j.error||j.message||('HTTP '+r.status));
  return j;
}
async function apiJsonResponseAllowFalse(r){
  const txt=await r.text();
  let j=null;
  try{j=txt?JSON.parse(txt):{};}catch(e){
    throw new Error('HTTP '+r.status+' returned non-JSON: '+txt.slice(0,220).replace(/\s+/g,' '));
  }
  if(!r.ok)throw new Error(j.error||j.message||('HTTP '+r.status));
  return j;
}
function dashboardHttpsOrigin(){
  if(location.protocol==='https:')return location.origin;
  return 'https://'+location.hostname+':9443';
}
let sendEudTargets=[];let sendMissionTargets=[];let activeLocalSendKind='';let activeLocalSendIds=[];
function formatAge(seconds){seconds=Number(seconds);if(!Number.isFinite(seconds))return'unknown';if(seconds<60)return Math.max(0,Math.round(seconds))+'s ago';if(seconds<3600)return Math.round(seconds/60)+'m ago';return Math.round(seconds/3600)+'h ago'}
function sendCoordLine(e){if(e.lat==null||e.lon==null)return'Location: unavailable';return'at '+Number(e.lat).toFixed(7)+', '+Number(e.lon).toFixed(7)+' - '+formatAge(e.location_age_seconds)}
function onlineSendTarget(e){const st=String(e.status||'').toLowerCase();const age=Number(e.location_age_seconds);return st==='online'||(Number.isFinite(age)&&age<=180)}
function validSendTarget(e){const blob=String([e.kind,e.source,e.type,e.client,e.client_label,e.callsign,e.uid].filter(Boolean).join(' ')).toLowerCase();if(blob.includes('ads-b')||blob.includes('adsb')||blob.includes('aircraft')||blob.includes('icao')||blob.includes('webform')||blob.includes('webform-gw')||blob.includes('tak-dashboard')||blob.includes('cot:')||blob.includes('server_gps'))return false;const cs=String(e.callsign||'').trim().toLowerCase();if(!cs||cs==='webform'||cs.startsWith('webform')||cs.includes('ads-b')||cs.includes('aircraft'))return false;return true}
function missionNameFromRow(m){return String(m.name||m.mission_name||m.missionName||m.uid||m.guid||'').trim()}
function updateSendSelectedCount(){const f=document.getElementById('sendFooterCount');const b=document.getElementById('sendConfirmBtn');if(activeSendMode==='live-basemap'||activeSendMode==='offline'||activeSendMode==='local-data-publish'){const sel=document.getElementById('sendMissionSelect');const mission=(sel&&sel.value)||'';if(f)f.textContent=mission?'Data Sync Mission: '+mission:'Select a Data Sync Mission';if(b)b.textContent='Publish';return}const total=sendEudTargets.length;let sel=0;document.querySelectorAll('[data-send-eud]').forEach(cb=>{if(cb.checked)sel++});if(f)f.textContent=total+' online EUD'+(total===1?'':'s')+' found';if(b)b.textContent='Send ('+sel+')'}
function sendModalBackdrop(ev){if(ev.target&&ev.target.id==='sendModal')closeSendModal()}
function closeSendModal(){const el=document.getElementById('sendModal');if(el)el.classList.remove('active');activeSendMapId='';activeSendBasemapId='';activeSendMode='offline';sendEudTargets=[];sendMissionTargets=[]}
async function loadSendTargets(){const rows=document.getElementById('sendEudRows');const status=document.getElementById('sendStatus');try{if(rows)rows.innerHTML='<div class="muted">Loading EUDs from OpenTAKServer...</div>';const r=await fetch('/api/tak-map/euds?send=1&online=1&fresh=1&_='+Date.now(),{cache:'no-store'});const j=await apiJsonResponse(r);sendEudTargets=(j.euds||[]).filter(e=>validSendTarget(e)&&onlineSendTarget(e));if(rows){rows.innerHTML=sendEudTargets.length?sendEudTargets.map((e,i)=>`<label class="send-eud-row"><input type="checkbox" data-send-eud="${i}" onchange="updateSendSelectedCount()"><span class="send-eud-main"><b>${esc(e.callsign||'EUD')}</b><small>${esc(sendCoordLine(e))}</small><small>Team: ${esc(e.team||'unknown')}</small></span><span><span class="send-eud-client">${esc(e.client_label||e.client||'ATAK')}</span><br><span class="send-eud-status">${esc(e.status||'Recent')}</span></span></label>`).join(''):'<div class="muted">No online EUDs were detected. Confirm the EUD is connected and has reported location within the last 3 minutes.</div>'}if(status)status.textContent='';updateSendSelectedCount()}catch(e){sendEudTargets=[];if(rows)rows.innerHTML='<div class="danger">Could not load EUDs: '+esc(e)+'</div>';if(status)status.textContent='';updateSendSelectedCount()}}
async function loadSendMissions(preferred){const rows=document.getElementById('sendEudRows');const status=document.getElementById('sendStatus');const preferredName=preferred||'';try{if(rows)rows.innerHTML='<div class="muted">Loading Data Sync Missions...</div>';let missions=[];try{const r=await fetch('/api/tak-map/data-sync?_='+Date.now(),{cache:'no-store'});const j=await apiJsonResponse(r);missions=(j.missions||[]).map(m=>({name:missionNameFromRow(m),guid:m.guid||'',raw:m})).filter(m=>m.name)}catch(e){missions=[]}sendMissionTargets=missions;const selectedName=(preferredName&&missions.some(m=>m.name===preferredName))?preferredName:(missions[0]?.name||'');const opts=missions.map(m=>`<option value="${esc(m.name)}" ${m.name===selectedName?'selected':''}>${esc(m.name)}</option>`).join('');if(rows)rows.innerHTML=`<div class="send-map-summary"><b>Data Sync Mission/Feed</b><br><small>Publish this package into an existing Data Sync Mission. EUDs must have Data Sync installed and be subscribed to the selected mission/feed.</small><br>${missions.length?`<select id="sendMissionSelect" class="select" onchange="updateSendSelectedCount()">${opts}</select>`:'<div class="danger">No Data Sync Missions found. Create or subscribe to a mission/feed in ATAK Data Sync first.</div>'}</div>`;if(status)status.textContent='';updateSendSelectedCount()}catch(e){if(rows)rows.innerHTML='<div class="danger">Could not load missions: '+esc(e)+'</div>';if(status)status.textContent='';updateSendSelectedCount()}}
function selectedMissionName(){const sel=document.getElementById('sendMissionSelect');return (sel&&sel.value)?sel.value:''}
function openSendOfflineMap(id){activeSendMode='offline';activeSendMapId=id;const m=(offlineMaps||[]).find(x=>String(x.id)===String(id))||{};const modal=document.getElementById('sendModal');const title=document.querySelector('#sendModal h3');const name=document.getElementById('sendMapName');const details=document.getElementById('sendMapDetails');const status=document.getElementById('sendStatus');if(title)title.textContent='Publish Offline Map';if(name)name.textContent='Publish this offline map package to a Data Sync Mission/Feed.';const mb=((Number(m.package_size_bytes||m.size_bytes||0))/(1024*1024));const sizeTxt=mb>0?mb.toFixed(mb>=10?1:2)+' MB':'Unknown size';const zmin=(m.min_zoom??m.minZoom??'—');const zmax=(m.max_zoom??m.maxZoom??'—');const base=m.source_label||m.source_basemap_label||m.basemap_label||m.source_basemap||m.basemap||m.source_id||'Unknown basemap';if(details)details.innerHTML=`<div class="send-map-summary"><b>${esc(m.name||m.filename||'Offline map')}</b><br>Basemap: ${esc(base)}<br>Size: ${esc(sizeTxt)}<br>Zoom levels: ${esc(zmin)}–${esc(zmax)}</div>`;if(status)status.textContent='';if(modal)modal.classList.add('active');loadSendMissions('')}
function openSendLiveBasemapSource(){activeSendMode='live-basemap';activeSendMapId='';activeSendBasemapId=activeBasemap;const b=basemapById(activeBasemap)||{};const modal=document.getElementById('sendModal');const title=document.querySelector('#sendModal h3');const name=document.getElementById('sendMapName');const details=document.getElementById('sendMapDetails');const status=document.getElementById('sendStatus');if(title)title.textContent='Publish Basemap';if(name)name.textContent='Publish an ATAK mapsource XML for '+(b.label||'current basemap')+' to a Data Sync Mission/Feed.';if(details)details.innerHTML='';if(status)status.textContent='';if(modal)modal.classList.add('active');loadSendMissions('')}
async function pollSendStatus(sendId){const status=document.getElementById('sendStatus');if(!sendId)return;let tries=0;const tick=async()=>{tries++;try{const r=await fetch('/api/tak-map/offline-send-status?id='+encodeURIComponent(sendId),{cache:'no-store'});const j=await apiJsonResponse(r);if(j.ok){const delivered=Number(j.delivered||0);const total=(j.targets||[]).length;if(status)status.textContent='Sent fileshare request. Delivered '+delivered+' of '+total+' EUD(s).';if(total&&delivered>=total){offlineMaps=(await (await fetch('/api/tak-map/offline-maps',{cache:'no-store'})).json()).maps||offlineMaps;renderOfflineMapRows();return}}}catch(e){}if(tries<12)setTimeout(tick,2500)};setTimeout(tick,1800)}
async function confirmSendOfflineMap(){const status=document.getElementById('sendStatus');try{const mission=selectedMissionName();if(activeSendMode==='local-data-publish'){if(!mission){if(status)status.innerHTML='<span class="danger">Select a Data Sync Mission.</span>';return}if(status)status.textContent='Publishing local data package to Data Sync Mission...';const r=await fetch('/api/tak-map/local-data-mission-publish',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ids:activeLocalSendIds,kind:activeLocalSendKind,missionName:mission,serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);if(status){const diag=j.diag_paths&&j.diag_paths.json?(' Diagnostics: '+j.diag_paths.json):'';status.textContent=(j.message||j.error||'Local Data publish finished.')+diag}if(j.ok){forceDataSyncSync('mission-publish-local-data')}return}if(!mission){if(status)status.innerHTML='<span class="danger">Select a Data Sync Mission.</span>';return}if(activeSendMode==='live-basemap'){if(status)status.textContent='Publishing basemap package to Data Sync Mission...';const r=await fetch('/api/tak-map/live-basemap-source-mission-publish',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({basemap_id:activeSendBasemapId,missionName:mission,dashboardOrigin:dashboardHttpsOrigin(),serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);if(status){const diag=j.diag_paths&&j.diag_paths.json?(' Diagnostics: '+j.diag_paths.json):'';status.textContent=(j.message||j.error||'Mission publish finished.')+diag}if(j.ok){forceDataSyncSync('mission-publish-basemap')}return}if(!activeSendMapId)return;if(status)status.textContent='Publishing offline map package to Data Sync Mission...';const r=await fetch('/api/tak-map/offline-mission-publish',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:activeSendMapId,missionName:mission,serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);offlineMaps=j.maps||offlineMaps;applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps();if(status){const diag=j.diag_paths&&j.diag_paths.json?(' Diagnostics: '+j.diag_paths.json):'';status.textContent=(j.message||j.error||'Mission publish finished.')+diag}if(j.ok){forceDataSyncSync('mission-publish-offline')}}catch(e){if(status)status.innerHTML='<span class="danger">Publish failed: '+esc(e)+'</span>'}}
function openLocalDataSend(kind,ids){activeSendMode='local-data';activeLocalSendKind=kind;activeLocalSendIds=ids.slice();const modal=document.getElementById('sendModal');const title=document.querySelector('#sendModal h3');const name=document.getElementById('sendMapName');const details=document.getElementById('sendMapDetails');const status=document.getElementById('sendStatus');if(title)title.textContent='Send Local Data';if(name)name.textContent='Select EUDs to receive '+ids.length+' '+kind+' item(s).';if(details)details.innerHTML='<div class="send-map-summary">Type: '+esc(kind)+'<br>Selected: '+esc(ids.length)+'</div>';if(status)status.textContent='';if(modal)modal.classList.add('active');loadSendTargets()}
function localDataKindForFeature(f){const s=String(f?.kind||f?.geometry||f?.geometry_type||f?.type||'').toLowerCase();if(s.includes('route')||s.includes('track')||s.includes('linestring')||s.includes('line string'))return'routes';if(s.includes('polygon')||s.includes('shape')||s.includes('area')||s.includes('rectangle')||s.includes('ellipse')||s.includes('circle'))return'shapes';return'points'}function localDataSets(){const sets={routes:[],points:[],shapes:[]};try{for(const f of importedFeatures()){const id=String(f._local_id||f.id||f.uid||f.name||('local-'+Math.random())).trim();const kind=localDataKindForFeature(f);const item={id,name:String(f.name||f.callsign||f.title||f.uid||id),source:String(f.import_name||f.source||'Imported'),shown:state.local.hidden[id]?false:true,feature:f};sets[kind].push(item)}}catch(e){try{console.warn('localDataSets failed',e)}catch(_){}}return sets}function selectedLocal(kind){try{return Object.keys(state.local[kind]||{}).filter(id=>!!state.local[kind][id])}catch(e){return[]}}function localTypeLabel(kind,count){const base={points:'point',routes:'route',shapes:'shape'}[kind]||'item';return count===1?base:base+'s'}function localSelectedLabel(kind,count){return count+' '+localTypeLabel(kind,count)+' selected'}function toggleLocalSection(kind){try{state.localCollapsed[kind]=!state.localCollapsed[kind];saveTakMapUiPrefs();renderLocalDataRows()}catch(e){try{console.warn('toggleLocalSection failed',e)}catch(_){}}}function unselectLocalSection(kind,ev){try{if(ev)ev.stopPropagation();state.local[kind]={};renderLocalDataRows()}catch(e){}}function toggleLocalItem(kind,id,on){try{state.local[kind]=state.local[kind]||{};state.local[kind][id]=!!on;renderLocalDataRows()}catch(e){try{console.warn('toggleLocalItem failed',e)}catch(_){}}}function localDataFeatureById(id){try{return importedFeatures().find(f=>String(f._local_id||f.id||f.uid||f.name)===String(id))||null}catch(e){return null}}function localDataExportFilename(kind,feats){try{let base='tak-map-local-'+kind;if((feats||[]).length===1){const f=feats[0]||{};base=String(f.name||f.callsign||f.title||f.uid||base)}else if((feats||[]).length>1){base='tak-map-local-'+localTypeLabel(kind,(feats||[]).length)+'-'+(feats||[]).length+'-items'}base=base.replace(/[\/:*?"<>|]+/g,'-').replace(/\n+/g,' ').trim();base=base.replace(/\.(kml|kmz|gpx|geojson|json|zip)$/i,'').trim();base=base.replace(/[. ]+$/,'')||('tak-map-local-'+kind);return base+'.geojson'}catch(e){return 'tak-map-local-'+kind+'.geojson'}}function downloadLocalData(kind,ids){try{const feats=(ids||[]).map(localDataFeatureById).filter(Boolean);const gj={type:'FeatureCollection',features:feats.map(f=>{let geom=null;const coords=Array.isArray(f.coords)?f.coords:null;if(coords&&coords.length){const k=localDataKindForFeature(f);if(k==='points')geom={type:'Point',coordinates:[Number(f.lon),Number(f.lat)]};else if(k==='routes')geom={type:'LineString',coordinates:coords.map(c=>[Number(c[1]??c.lon),Number(c[0]??c.lat)]).filter(c=>Number.isFinite(c[0])&&Number.isFinite(c[1]))};else geom={type:'Polygon',coordinates:[coords.map(c=>[Number(c[1]??c.lon),Number(c[0]??c.lat)]).filter(c=>Number.isFinite(c[0])&&Number.isFinite(c[1]))]}}else if(f.lat!=null&&f.lon!=null){geom={type:'Point',coordinates:[Number(f.lon),Number(f.lat)]}}return{type:'Feature',geometry:geom,properties:{name:f.name||f.callsign||f.title||'',source:f.import_name||f.source||'',kind:kind}}}).filter(x=>x.geometry)};if(!gj.features.length){alert('No exportable geometry found for the selected item(s).');return}const blob=new Blob([JSON.stringify(gj,null,2)],{type:'application/geo+json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=localDataExportFilename(kind,feats);document.body.appendChild(a);a.click();setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove()},500)}catch(e){alert('Export failed: '+e)}}function localDataPublishTitle(kind,ids){const map={points:'Point',routes:'Route',shapes:'Shape'};const one=(ids||[]).length===1;return 'Publish '+(one?(map[kind]||'Item'):(map[kind]||'Item')+'s')+' to Data Sync/Mission'}
function openLocalDataPublish(kind,ids){activeSendMode='local-data-publish';activeLocalSendKind=kind;activeLocalSendIds=(ids||[]).slice();const modal=document.getElementById('sendModal');const title=document.querySelector('#sendModal h3');const name=document.getElementById('sendMapName');const details=document.getElementById('sendMapDetails');const status=document.getElementById('sendStatus');if(title)title.textContent=localDataPublishTitle(kind,ids);if(name)name.textContent='Publish '+ids.length+' selected local '+kind+' item(s) into a Data Sync Mission.';if(details)details.innerHTML='<div class="send-map-summary">Type: '+esc(kind)+'<br>Selected: '+esc(ids.length)+'<br><small>This creates a TAK Mission Package containing KML and GeoJSON for the selected local item(s).</small></div>';if(status)status.textContent='';if(modal)modal.classList.add('active');loadSendMissions()}
function centerLocalItem(kind,id,ev){if(ev)ev.stopPropagation();const f=localDataFeatureById(id);const cen=objectCenter(f);if(!f||!cen){alert('No valid coordinates found for this local item.');return}try{map.panTo(cen,{animate:true});if(f.__layer){setTimeout(()=>{try{f.__layer.openPopup()}catch(e){}},160)}}catch(e){try{console.warn('centerLocalItem failed',e)}catch(_){}}}
function centerSelectedLocal(kind,ids){const pts=[];for(const id of (ids||[])){const f=localDataFeatureById(id);const cen=objectCenter(f);if(cen)pts.push(cen)}if(!pts.length){alert('No valid coordinates found for the selected item(s).');return}try{if(pts.length===1)map.panTo(pts[0],{animate:true});else map.fitBounds(L.latLngBounds(pts).pad(.22))}catch(e){try{console.warn('centerSelectedLocal failed',e)}catch(_){}}}
async function localDataAction(kind,action){const ids=selectedLocal(kind);if(!ids.length){alert('Select one or more '+localTypeLabel(kind,2)+' first.');return}if(action==='goto'){centerSelectedLocal(kind,ids);return}if(action==='hide'||action==='show'){for(const id of ids){state.local.hidden[id]=(action==='hide')}renderLocalDataRows();drawImportedObjects();return}if(action==='export'){downloadLocalData(kind,ids);return}if(action==='publish'){openLocalDataPublish(kind,ids);return}if(action==='delete'){if(!confirm('Delete '+localSelectedLabel(kind,ids.length)+'?'))return;try{const r=await fetch('/api/tak-map/local-data-delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ids})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));lastImports=j.imports||lastImports;state.local[kind]={};renderLocalDataRows();drawImportedObjects();return}catch(e){alert('Delete failed: '+e);return}}}
function renderLocalActions(kind,items){const ids=selectedLocal(kind);if(!ids.length)return'';const allHidden=ids.every(id=>!!state.local.hidden[id]);const hideShow=allHidden?'Show':'Hide';return `<div class="local-actions ${kind}"><div class="local-actions-top"><span id="localActionCount_${kind}" class="muted local-selected-count">${esc(localSelectedLabel(kind,ids.length))}</span></div><div class="local-action-buttons"><button class="layer-button" onclick="localDataAction('${kind}','goto')">Go To</button><button class="layer-button" onclick="localDataAction('${kind}','publish')">Publish</button><button class="layer-button" onclick="localDataAction('${kind}','export')">Export</button><button class="layer-button" onclick="localDataAction('${kind}','${hideShow.toLowerCase()}')">${hideShow}</button><button class="layer-button" onclick="localDataAction('${kind}','delete')">Delete</button></div></div>`}
function renderLocalSection(kind,title,items){const collapsed=!!state.localCollapsed[kind];let html=`<div class="local-section ${collapsed?'collapsed':''}"><div class="subgroup-title local-section-title" onclick="toggleLocalSection('${kind}')"><span class="subgroup-label"><span class="toggle">${collapsed?'›':'⌄'}</span>${esc(title)}</span><span class="chip">${items.length}</span><button class="layer-button unselect-local-btn" onclick="unselectLocalSection('${kind}',event)">Unselect All</button></div><div class="local-data-list">`;html+=items.length?items.slice(0,120).map(it=>{const checked=state.local[kind][it.id]?'checked':'';const vis=it.shown===false?'hidden':'shown';const colorCtl='';const coords=(kind==='points'&&it.lat!=null&&it.lon!=null)?formatCoords(it.lat,it.lon):'';const meta=coords||((it.source||'Local Data')+' · '+vis);return`<div class="local-data-row ${checked?'selected-local':''} ${vis==='hidden'?'hidden-local':''}"><label class="local-data-main"><input type="checkbox" ${checked} onchange="toggleLocalItem('${kind}','${esc(it.id)}',this.checked)"><span><b>${esc(it.name)}</b><small>${esc(meta)}</small></span></label><button class="layer-button local-goto-btn" onclick="centerLocalItem('${kind}','${esc(it.id)}',event)">Go To</button>${colorCtl}</div>`}).join(''):'<div class="muted" style="padding:8px">No local '+esc(title.toLowerCase())+' yet.</div>';html+=`</div>${renderLocalActions(kind,items)}</div>`;return html}function triggerLocalAdd(kind){const inp=document.getElementById('importFileInput');if(inp){inp.dataset.localKind=kind;inp.value='';inp.click();return}alert('Import control is not available.')}async function refreshLocalData(){try{renderLocalDataRows();return {ok:true}}catch(e){renderLocalDataRows(String(e));return {ok:false,error:String(e)}}}
function renderLocalDataRows(err){const box=document.getElementById('localDataRows');if(!box)return;const sets=localDataSets();const total=sets.routes.length+sets.points.length+sets.shapes.length;const chip=document.getElementById('localDataCount');if(chip)chip.textContent=String(total);let html='';if(err)html+='<div class="danger">'+esc(err)+'</div>';html+=`<div class="local-add-grid"><button class="layer-button" onclick="triggerLocalAdd('points')">+ Add Point</button><button class="layer-button" onclick="triggerLocalAdd('routes')">+ Add Route</button><button class="layer-button" onclick="triggerLocalAdd('shapes')">+ Add Shape</button></div>`;html+=renderLocalSection('points','Points',sets.points);html+=renderLocalSection('routes','Routes',sets.routes);html+=renderLocalSection('shapes','Shapes',sets.shapes);box.innerHTML=html}function renderRouteRows(){renderLocalDataRows()}function toggleRoute(idx,on){const r=(lastRoutes||[])[idx];if(!r)return;state.routes[r.path]=on;if(!on&&routeLayers[r.path]){map.removeLayer(routeLayers[r.path]);delete routeLayers[r.path];return}if(on){alert('Route file listing is active. Direct overlay rendering will be wired to Local Data actions.')}}
let lastAircraft=[];function refreshAdsbIntervalSeconds(){const s=(window.lastAdsbSettings||config?.adsb?.settings||{});const n=Number(s.update_interval_seconds||s.update_interval||5);return Number.isFinite(n)?Math.max(1,Math.min(300,Math.round(n))):5}function scheduleAdsbRefreshTimer(){try{if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer);const sec=refreshAdsbIntervalSeconds();window.adsbRefreshTimer=setInterval(()=>{if(state.live.adsb_aircraft)refreshAdsb()},sec*1000)}catch(e){}}async function refreshAdsb(){if(state.live.adsb_aircraft===false)return;try{const r=await fetch('/api/tak-map/adsb',{cache:'no-store'});const j=await r.json();window.lastAdsbSettings=j.settings||window.lastAdsbSettings||config?.adsb?.settings||{};document.getElementById('adsbStatus').textContent=(j.aircraft||[]).length+' active';if(lastBanner){lastBanner.adsb_aircraft=(j.aircraft||[]).length;renderTopBanner(lastBanner)}lastAircraft=j.aircraft||[];drawAircraft(lastAircraft)}catch(e){document.getElementById('adsbStatus').textContent='error'}}function aircraftIsMilitary(ac){const blob=String([ac?.type,ac?.category,ac?.uid,ac?.id,ac?.callsign,ac?.source,ac?.description,ac?.aircraft_type].filter(Boolean).join(' ')).toLowerCase();return blob.includes('a-f-a')||blob.includes('military')||blob.includes('mil-')||blob.includes('usaf')||blob.includes('usn')||blob.includes('usmc')||blob.includes('army')||blob.includes('navy')||blob.includes('afsoc')||blob.includes('viper')||blob.startsWith('rch')}function aircraftIsHelicopter(ac){const blob=String([ac?.type,ac?.category,ac?.aircraft_type,ac?.description,ac?.emitter_category,ac?.uid,ac?.id,ac?.callsign,ac?.source].filter(Boolean).join(' ')).toLowerCase();if(blob.includes('helicopter')||blob.includes('rotor')||blob.includes('rotary')||blob.includes('gyro')||blob.includes('helo'))return true;if(/\b(a7|b7|h1|h2|h3|h4|h5|h6|h7|h8|h9)\b/.test(blob))return true;if(/\b(r22|r44|r66|h60|uh60|mh60|ch47|ah64|as50|ec35|ec45|b407|b412|s76|s92|bell|robinson)\b/.test(blob))return true;return false}function aircraftIsStale(ac){const s=Number(ac?.seen_seconds);const stale=Number((window.lastAdsbSettings||{}).stale_seconds||refreshAdsbIntervalSeconds()+1);return Number.isFinite(s)&&s>stale}function aircraftIcon(ac){const label=esc(ac.callsign||ac.id||'');const military=aircraftIsMilitary(ac);const heli=aircraftIsHelicopter(ac);const stale=aircraftIsStale(ac);const selected=ac.id===selectedAircraftId?' selected':'';const deg=Number.isFinite(Number(ac.track_deg))?Number(ac.track_deg):0;const color=stale?'#87909a':(military?'#2386ff':'#8bd742');const cls=(military?'aircraft-military':'aircraft-civil')+(heli?' aircraft-rotor':' aircraft-fixed')+(stale?' aircraft-stale':'');const ring=military?`<circle cx="22" cy="22" r="16.4" fill="rgba(5,8,12,.86)" stroke="currentColor" stroke-width="4.2" stroke-dasharray="9 4"/>`:`<circle cx="22" cy="22" r="15.8" fill="rgba(5,8,12,.84)" stroke="currentColor" stroke-width="2.8"/><circle cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".45"/>`;const glyph=heli?`<path d="M5 14 H39" stroke="#f5f7f9" stroke-width="3.4" stroke-linecap="round"/><path d="M22 6 V28" stroke="#f5f7f9" stroke-width="2.7" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.5" ry="5.4" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".7"/><path d="M12 34 H32 M22 30 V37" stroke="#f5f7f9" stroke-width="2.35" stroke-linecap="round"/>`:(military?`<path d="M22 5 L27 23 L38 29 L27 30 L23 41 L21 41 L17 30 L6 29 L17 23 Z" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".75"/><path d="M22 30 L14 39 M22 30 L30 39" stroke="#f5f7f9" stroke-width="2.2" stroke-linecap="round"/>`:`<path d="M22 6 L25 22 L36 27 L25 29 L22 40 L19 29 L8 27 L19 22 Z" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".7"/><path d="M22 30 L16 39 M22 30 L28 39" stroke="#f5f7f9" stroke-width="2.05" stroke-linecap="round"/>`);return L.divIcon({className:'',html:`<div class="aircraft-wrap ${cls}" style="color:${color}"><svg class="aircraft-glyph${selected}" width="40" height="50" viewBox="0 0 44 54">${ring}<g transform="rotate(${deg} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="currentColor"/>${glyph}</g><circle cx="22" cy="50" r="3.2" fill="currentColor"/></svg><div class="aircraft-label">${label}</div></div>`,iconSize:[96,60],iconAnchor:[48,25]})}function adsbCourse(ac){const keys=['track_deg','track','course','course_deg','cog','true_track','nav_heading'];for(const k of keys){const v=Number(ac&&ac[k]);if(Number.isFinite(v))return {deg:((v%360)+360)%360,source:k,headingOnly:false}}const h=Number(ac&&ac.heading_deg);if(Number.isFinite(h))return {deg:((h%360)+360)%360,source:'heading_deg',headingOnly:true};return {deg:null,source:'none',headingOnly:false}}function adsbGroundSpeed(ac){for(const k of ['groundspeed_kt','gs_kt','speed_kt','ground_speed','gs']){const v=Number(ac&&ac[k]);if(Number.isFinite(v)&&v>0)return {kt:v,source:k}}return {kt:0,source:'none'}}function adsbPopupHtml(ac){const crs=adsbCourse(ac);const gs=adsbGroundSpeed(ac);return `<div class="feature-popup adsb-popup"><h3>${esc(ac.callsign||ac.id||'ADS-B aircraft')}</h3><div class="kvp"><b>ICAO/UID</b><span>${esc(ac.id||'—')}</span><b>Class</b><span>${aircraftIsMilitary(ac)?'Friendly military':'Civil / commercial'} · ${aircraftIsHelicopter(ac)?'Helicopter':'Airplane'}</span><b>Altitude</b><span>${esc(ac.altitude_ft??'—')} ft</span><b>Groundspeed</b><span>${esc(gs.kt||'—')} kt</span><b>Track/Course</b><span>${crs.deg==null?'No track/course':esc(Math.round(crs.deg)+'° from '+crs.source+(crs.headingOnly?' (heading only)':''))}</span><b>Coordinates</b><span>${esc(formatCoords(ac.lat,ac.lon))}</span><b>Source</b><span>${esc(ac.source||'ADS-B')}</span><b>Updated</b><span>${esc(ac.updated||'—')}</span></div></div>`}function drawAircraft(items){if(terrain3DActive){return}aircraftLayer.clearLayers();clearSearchSource('aircraft');for(const ac of items){if(ac.lat==null||ac.lon==null)continue;const m=L.marker([ac.lat,ac.lon],{icon:aircraftIcon(ac)}).addTo(aircraftLayer);m.bindPopup(adsbPopupHtml(ac));m.on('click',()=>{selectedAircraftId=ac.id;setTimeout(()=>{try{m.openPopup()}catch(e){}},0)});addSearchItem('aircraft','ADS-B '+(aircraftIsMilitary(ac)?'military':'civil'),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}handleMapSearch()}function eudIconHtml(){return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="30" height="40" viewBox="0 0 30 40"><rect x="6" y="3" width="18" height="30" rx="3.5" fill="rgba(10,16,22,.90)" stroke="#2386ff" stroke-width="2.6"/><rect x="10" y="8" width="10" height="18" rx="1.5" fill="rgba(35,134,255,.08)" stroke="rgba(35,134,255,.35)" stroke-width="1"/><circle cx="15" cy="29" r="1.6" fill="#2386ff"/><circle cx="15" cy="37" r="3" fill="#2386ff"/></svg></div>`}function webformIconHtml(){return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="34" height="42" viewBox="0 0 34 42"><rect x="7" y="8" width="20" height="25" rx="3" fill="rgba(14,10,22,.90)" stroke="#b56cff" stroke-width="2.7"/><path d="M13 8 V5 H21 V8" fill="none" stroke="#b56cff" stroke-width="2.7" stroke-linecap="round"/><path d="M12 16 l2 2 5-5 M12 22 l2 2 5-5 M12 28 l2 2 5-5" fill="none" stroke="#b56cff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/><circle cx="17" cy="39" r="3" fill="#b56cff"/></svg></div>`}function serverGpsIconHtml(){return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="38" height="45" viewBox="0 0 38 45"><path d="M12 8 q7-6 14 0" fill="none" stroke="#8bd742" stroke-width="2.1" stroke-linecap="round" opacity=".9"/><path d="M15 12 q4-3.4 8 0" fill="none" stroke="#8bd742" stroke-width="2" stroke-linecap="round" opacity=".9"/><rect x="7" y="14" width="24" height="23" rx="3" fill="rgba(11,18,12,.94)" stroke="#8bd742" stroke-width="2.7"/><text x="19" y="27" text-anchor="middle" font-size="6.7" font-weight="900" fill="#8bd742" font-family="system-ui,Arial">SERVER</text><circle cx="13" cy="32" r="1.5" fill="#8bd742"/><circle cx="19" cy="32" r="1.5" fill="#8bd742"/><circle cx="25" cy="32" r="1.5" fill="#8bd742"/><circle cx="19" cy="42" r="3" fill="#8bd742"/></svg></div>`}function takIcon(kind,m){kind=String(kind||'cot').toLowerCase();if(kind==='eud')return L.divIcon({className:'',html:eudIconHtml(),iconSize:[30,40],iconAnchor:[15,32]});if(kind==='webform')return L.divIcon({className:'',html:webformIconHtml(),iconSize:[34,42],iconAnchor:[17,33]});if(kind==='server_gps'||kind==='server-gps'||kind==='gps')return L.divIcon({className:'',html:serverGpsIconHtml(),iconSize:[38,45],iconAnchor:[19,37]});return L.divIcon({className:'',html:mil2525IconHtml(m||{}),iconSize:[36,40],iconAnchor:[18,22]})}async function refreshCot(){try{const r=await fetch('/api/tak-map/cot',{cache:'no-store'});const j=await r.json();lastTakMarkers=j.markers||[];let eudCount=0;if(terrain3DActive){for(const m of (j.markers||[])){if((m.kind||'cot')==='eud')eudCount++}document.getElementById('eudStatus').textContent=String(eudCount);if(lastBanner){lastBanner.euds_connected=eudCount;renderTopBanner(lastBanner)}refreshTerrain3DObjects(false,'cot');return}takMarkerLayer.clearLayers();clearSearchSource('tak');for(const m of (j.markers||[])){const kind=m.kind||'cot';if(kind==='eud')eudCount++;if(kind==='eud'&&state.live.euds===false)continue;if(kind==='server_gps'&&state.live.server_gps===false)continue;if(kind!=='eud'&&kind!=='server_gps'&&state.live.cot_markers===false)continue;if(m.lat==null||m.lon==null)continue;const popup=(kind==='eud'||kind==='webform'||kind==='server_gps')?basicMarkerPopupHtml(m,kind):pointPopupHtml(m,'Point Markers');const layer=L.marker([m.lat,m.lon],{icon:takIcon(kind,m)}).bindPopup(popup).addTo(takMarkerLayer);stabilizeLayerPopup(layer);addSearchItem('tak',kind,m.callsign||m.uid||m.id||kind,m.lat,m.lon,layer,m)}document.getElementById('eudStatus').textContent=String(eudCount);if(lastBanner){lastBanner.euds_connected=eudCount;renderTopBanner(lastBanner)}handleMapSearch();refreshTerrain3DObjects()}catch(e){document.getElementById('eudStatus').textContent='error'}}async function updateTopBanner(){try{const r=await fetch('/api/tak-map/status-banner',{cache:'no-store'});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));lastBanner=j;renderTopBanner(j)}catch(e){renderTopBanner({tak_server:'Offline',internet:'Disconnected',euds_connected:'?',adsb_aircraft:'?',downloads:{active:0}})}}function updateTopBannerCached(){if(lastBanner)renderTopBanner(lastBanner)}function bannerDot(id,cls){const el=document.getElementById(id);if(!el)return;cls=cls||'unknown';el.className='status-dot '+cls;el.title=({good:'Online / OK',warn:'Warning or active work in progress',bad:'Offline / error',unknown:'Unknown / inactive'}[cls]||cls)}function titleWords(s){return String(s??'').replace(/\b\w/g,c=>c.toUpperCase())}function shortUid(v){v=String(v||'').trim();if(!v)return'';if(/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v))return v.slice(0,8)+'...'+v.slice(-4);return v.length>18?v.slice(0,10)+'...'+v.slice(-6):v}function statusItemLabel(o){const label=String(o?.callsign||o?.name||o?.title||'').trim();if(label)return label;const uid=String(o?.uid||o?.id||'').trim();if(uid)return 'Unknown CoT Sensor';return'Unknown'}function statusItemSub(o){const label=statusItemLabel(o);const bits=[];if(o?.mission)bits.push('Mission '+String(o.mission));if(o?.type)bits.push(String(o.type));const uid=String(o?.uid||o?.id||'').trim();if(uid&&uid!==label)bits.push(shortUid(uid));if(o?.source)bits.push(String(o.source));return bits.filter(Boolean).slice(0,3).join(' · ')}function adsbIdent(a){return String(a?.icao||a?.hex||a?.id||a?.uid||a?.callsign||'Aircraft').replace(/^icao-/i,'').trim()||'Aircraft'}function adsbAltText(a){const n=Number(a?.altitude_ft);return Number.isFinite(n)?(Math.round(n)+' ft'):'—'}function adsbRangeText(a){const n=Number(a?.range_miles);return Number.isFinite(n)?(n.toFixed(2)+' mi'):'—'}function statusDropdownRows(type){if(type==='euds')return (lastTakMarkers||[]).filter(m=>String(m.kind||'').toLowerCase()==='eud').map(m=>({name:statusItemLabel(m),sub:statusItemSub(m)}));if(type==='nontak')return (lastTakMarkers||[]).filter(m=>{const k=String(m.kind||'').toLowerCase();if(['eud','server_gps','server-gps','webform','aircraft','datasync'].includes(k))return false;if(m.mission||m.is_mission_object)return false;return true}).map(m=>({name:statusItemLabel(m),sub:statusItemSub(m)}));if(type==='adsb')return (lastAircraft||[]).map(a=>({icao:adsbIdent(a),alt:adsbAltText(a),range:adsbRangeText(a)}));return []}function statusDropdownTitle(type){return type==='euds'?'EUD Callsigns':(type==='nontak'?'Non-TAK Sensors':'ADS-B Aircraft')}function renderStatusDropdown(type){const box=document.getElementById('statusDropdown');if(!box)return;const rows=statusDropdownRows(type);box.classList.toggle('adsb-table',type==='adsb');let html='<div class="status-dropdown-title">'+esc(statusDropdownTitle(type))+'</div>';if(!rows.length)html+='<div class="status-dropdown-empty">No items currently listed.</div>';else if(type==='adsb'){html+='<div class="status-adsb-head"><span>ICAO</span><span>Altitude</span><span>From Center Point</span></div>'+rows.map(r=>'<div class="status-adsb-row"><span class="status-adsb-icao">'+esc(r.icao)+'</span><span class="status-adsb-alt">'+esc(r.alt)+'</span><span class="status-adsb-range">'+esc(r.range)+'</span></div>').join('')}else html+=rows.map(r=>'<div class="status-dropdown-row"><span class="status-dropdown-name">'+esc(r.name)+'</span><span class="status-dropdown-sub">'+esc(r.sub||'')+'</span></div>').join('');box.innerHTML=html;box.dataset.type=type}function positionStatusDropdown(type,ev){const box=document.getElementById('statusDropdown');if(!box)return;const trigger=ev?.currentTarget||document.getElementById(type==='euds'?'bannerEudsItem':type==='nontak'?'bannerNonTakItem':'bannerAdsbItem');if(!trigger)return;const r=trigger.getBoundingClientRect();box.style.left='0px';box.style.top='0px';box.classList.add('active');const bw=box.offsetWidth||260;const bh=box.offsetHeight||220;let left=r.left;let top=r.bottom+8;left=Math.max(8,Math.min(left,window.innerWidth-bw-8));top=Math.max(8,Math.min(top,window.innerHeight-bh-8));box.style.left=left+'px';box.style.top=top+'px'}function toggleStatusDropdown(type,ev){try{ev&&ev.stopPropagation&&ev.stopPropagation();const box=document.getElementById('statusDropdown');if(!box)return;if(box.classList.contains('active')&&box.dataset.type===type){box.classList.remove('active');return}renderStatusDropdown(type);positionStatusDropdown(type,ev)}catch(e){}}function updateOpenStatusDropdown(){const box=document.getElementById('statusDropdown');if(box&&box.classList.contains('active'))renderStatusDropdown(box.dataset.type||'')}document.addEventListener('click',e=>{const box=document.getElementById('statusDropdown');if(!box||!box.classList.contains('active'))return;if(box.contains(e.target)||e.target.closest('.status-dropdown-trigger'))return;box.classList.remove('active')});window.addEventListener('resize',()=>{const box=document.getElementById('statusDropdown');if(box)box.classList.remove('active')});function renderTopBanner(j){const e=document.getElementById('bannerEuds');const eudCount=j.euds_connected??0;if(e)e.textContent=String(eudCount)+' Connected';bannerDot('bannerEudsDot',Number(eudCount)>0?'good':'unknown');const tak=String(j.tak_server||'Unknown');const t=document.getElementById('bannerTak');if(t)t.textContent=titleWords(tak);bannerDot('bannerTakDot',/online|up|running/i.test(tak)?'good':/check|unknown/i.test(tak)?'unknown':'bad');const internet=String(j.internet||'Unknown');const inet=document.getElementById('bannerInternet');if(inet)inet.textContent=titleWords(internet);bannerDot('bannerInternetDot',/connected|online|up/i.test(internet)?'good':/dns|limited|degraded/i.test(internet)?'warn':/unknown|check/i.test(internet)?'unknown':'bad');const a=document.getElementById('bannerAdsb');const aircraft=Number(j.adsb_aircraft??0);if(a)a.textContent=aircraft+' Aircraft';bannerDot('bannerAdsbDot',aircraft>0?'good':'unknown');const d=document.getElementById('bannerDownloads');if(d){const dl=j.downloads||{};d.textContent=Number(dl.active||0)?titleWords(dl.active+' Active'+(dl.eta?' · '+dl.eta:'')):'0 Active';bannerDot('bannerDownloadsDot',Number(dl.active||0)>0?'warn':'unknown')}updateOpenStatusDropdown()}function fitVisible(){const pts=[];const addLayer=l=>{try{if(l.getLatLng)pts.push(l.getLatLng());else if(l.getBounds){const b=l.getBounds();if(b&&b.isValid&&b.isValid()){pts.push(b.getSouthWest(),b.getNorthEast())}}}catch(e){}};[aircraftLayer,takMarkerLayer,dataSyncLayer,importedLayer].forEach(g=>{try{g.eachLayer(addLayer)}catch(e){}});if(pts.length){const b=L.latLngBounds(pts);const sz=map.getSize();map.fitBounds(b,{padding:[Math.max(18,Math.round(sz.x*.07)),Math.max(18,Math.round(sz.y*.07))]})}else alert('No visible map items to fit yet.')}
/* v228 queued behavior overrides */
(function(){
  try{
    if(window.L && L.Layer && L.Layer.prototype && !L.Layer.prototype._takV225BindPopupPatched){
      const orig=L.Layer.prototype.bindPopup;
      L.Layer.prototype.bindPopup=function(content,options){
        const opts=Object.assign({autoPan:false,keepInView:false,autoClose:false,closeOnClick:false},options||{});
        const ret=orig.call(this,content,opts);
        try{ if(this._openPopup) this.off('click',this._openPopup,this); }catch(e){}
        return ret;
      };
      L.Layer.prototype._takV225BindPopupPatched=true;
    }
  }catch(e){}
})();
function mapToolSuppressesObjectPopups(){return activeMapTool==='coords'||activeMapTool==='measure'}
function clampLeafletPopupToMap(popup){try{if(!popup||!map)return;const el=popup.getElement&&popup.getElement();const mc=map.getContainer&&map.getContainer();if(!el||!mc)return;el.style.marginLeft='';el.style.marginTop='';const pad=8;const mr=mc.getBoundingClientRect();const r=el.getBoundingClientRect();let dx=0,dy=0;if(r.left<mr.left+pad)dx=(mr.left+pad)-r.left;if(r.right>mr.right-pad)dx=(mr.right-pad)-r.right;if(r.top<mr.top+pad)dy=(mr.top+pad)-r.top;if(r.bottom>mr.bottom-pad)dy=(mr.bottom-pad)-r.bottom;el.style.marginLeft=dx?dx+'px':'';el.style.marginTop=dy?dy+'px':''}catch(e){}}
function stabilizeLayerPopup(layer){try{if(!layer||!layer.on)return layer;let anchor=null;const prep=()=>{try{const p=layer.getPopup&&layer.getPopup();if(p&&p.options){p.options.autoPan=false;p.options.keepInView=false;p.options.autoClose=false;p.options.closeOnClick=false}}catch(e){}};const openAnchored=()=>{try{if(mapToolSuppressesObjectPopups())return;if(window._takPinnedPopupLayer&&window._takPinnedPopupLayer!==layer)return;if(!anchor)anchor=layerPopupAnchor(layer);prep();if(layer.openPopup){if(anchor)layer.openPopup(anchor);else layer.openPopup()}setTimeout(()=>{try{clampLeafletPopupToMap(layer.getPopup&&layer.getPopup())}catch(_){ }},0)}catch(e){}};prep();layer.on('mouseover',()=>{if(mapToolSuppressesObjectPopups())return;if(window._takPinnedPopupLayer&&window._takPinnedPopupLayer!==layer)return;if(!layer.isPopupOpen||!layer.isPopupOpen())openAnchored()});layer.on('mouseout',()=>{setTimeout(()=>closeUnpinnedPopup(layer),120)});layer.on('click',ev=>{try{if(mapToolSuppressesObjectPopups())return;if(window._takPinnedPopupLayer&&window._takPinnedPopupLayer!==layer){const old=window._takPinnedPopupLayer;old._takPopupPinned=false;if(old.closePopup)old.closePopup()}layer._takPopupPinned=true;window._takPinnedPopupLayer=layer;openAnchored();if(ev&&ev.originalEvent)L.DomEvent.stop(ev.originalEvent)}catch(e){}});layer.on('popupopen',e=>{try{if(mapToolSuppressesObjectPopups()&&!layer._takPopupPinned){if(layer.closePopup)layer.closePopup();return}const p=e.popup;prep();if(!anchor)anchor=layerPopupAnchor(layer);if(p&&anchor&&p.setLatLng)p.setLatLng(anchor);setTimeout(()=>clampLeafletPopupToMap(p),0);const el=p&&p.getElement&&p.getElement();if(!el)return;el.addEventListener('mouseenter',()=>{layer._takPopupHover=true});el.addEventListener('mouseleave',()=>{layer._takPopupHover=false;setTimeout(()=>{if(!layer._takPopupHover)closeUnpinnedPopup(layer)},180)});el.addEventListener('click',ev=>ev.stopPropagation());}catch(x){}})}catch(e){}return layer}
function measurePopupPositionDefault(el){try{if(!map||!el||el.dataset.moved==='1')return;const r=map.getContainer().getBoundingClientRect();const h=el.offsetHeight||140;el.style.left=(r.left+8)+'px';el.style.top=(r.bottom-h-8)+'px';el.style.right='auto';el.style.bottom='auto'}catch(e){}}
function ensureMeasurePopupDock(){let el=document.getElementById('measurePopupDock');if(el)return el;el=document.createElement('div');el.id='measurePopupDock';el.className='measure-popup-dock';el.style.display='none';document.body.appendChild(el);let drag=null;el.addEventListener('pointerdown',ev=>{if(ev.target&&String(ev.target.tagName||'').toLowerCase()==='button')return;drag={x:ev.clientX,y:ev.clientY,left:el.getBoundingClientRect().left,top:el.getBoundingClientRect().top};try{el.setPointerCapture(ev.pointerId)}catch(_){ }ev.preventDefault()});el.addEventListener('pointermove',ev=>{if(!drag)return;const r=map&&map.getContainer?map.getContainer().getBoundingClientRect():{left:0,top:86,right:innerWidth,bottom:innerHeight};const nx=Math.max(r.left+4,Math.min(r.right-80,drag.left+ev.clientX-drag.x));const ny=Math.max(r.top+4,Math.min(r.bottom-50,drag.top+ev.clientY-drag.y));el.dataset.moved='1';el.style.left=nx+'px';el.style.top=ny+'px';el.style.right='auto';el.style.bottom='auto'});el.addEventListener('pointerup',()=>{drag=null});el.addEventListener('pointercancel',()=>{drag=null});return el}
function updateMeasurePopupDock(){const el=ensureMeasurePopupDock();const seg=measureSegments();if(activeMapTool!=='measure'||seg.length<1){el.style.display='none';return}el.innerHTML=measureSummaryHtml();el.style.display='block';measurePopupPositionDefault(el)}
function measureSummaryHtml(){const seg=measureSegments();const total=seg.reduce((a,s)=>a+s.m,0);let html='<div class="measure-popup-box" style="color:'+esc(measureTextColor)+'"><h3>Measure Path</h3>';seg.forEach((s,i)=>{html+='<div class="measure-popup-row"><span>Segment '+(i+1)+'</span><span>'+fmtDistance(s.m,'imperial')+' · '+fmtDistance(s.m,'metric')+'</span></div>'});html+='<div class="measure-popup-total">Total: '+(total/1609.344).toFixed(2)+' mi · '+Math.round(total*3.280839895).toLocaleString()+' ft · '+(total/1000).toFixed(2)+' km · '+Math.round(total).toLocaleString()+' m</div></div>';return html}
let measurePolylineLayer=null;let measureSegLabelLayers=[];
function redrawMeasureLabelsOnly(){try{for(const l of measureSegLabelLayers){try{measureLayer.removeLayer(l)}catch(_){}}measureSegLabelLayers=[];if(!measureLayer||measurePoints.length<2)return;measureSegments().forEach((s,i)=>{const mid=L.latLng((s.a.lat+s.b.lat)/2,(s.a.lng+s.b.lng)/2);const label=L.marker(mid,{interactive:false,zIndexOffset:10030,icon:L.divIcon({className:'',html:'<div class="measure-seg-label" style="color:'+esc(measureTextColor)+'">'+esc(fmtDistance(s.m,measureUnitsMode))+'</div>',iconAnchor:[0,0]})}).addTo(measureLayer);measureSegLabelLayers.push(label)})}catch(e){}}
function drawMeasure(){if(!measureLayer||!map)return;measureLayer.clearLayers();measurePolylineLayer=null;measureSegLabelLayers=[];if(!measurePoints.length){updateMeasurePopupDock();return}if(measurePoints.length>=2){measurePolylineLayer=L.polyline(measurePoints,{color:measureLineColor||'#b9c4c9',weight:3,opacity:.86,dashArray:measureLocked?'6 6':null,interactive:false}).addTo(measureLayer);redrawMeasureLabelsOnly()}for(let i=0;i<measurePoints.length;i++){const p=measurePoints[i];const marker=L.marker(p,{interactive:true,draggable:!measureLocked,zIndexOffset:10040,icon:L.divIcon({className:'',html:'<div class="measure-point-dot" style="border-color:#071014;background:'+esc(measureLineColor)+'"></div>',iconSize:[14,14],iconAnchor:[7,7]})}).addTo(measureLayer);marker.on('click',ev=>{try{L.DomEvent.stop(ev)}catch(_){}});marker.on('dragstart',()=>{measureDragIndex=i});marker.on('drag',ev=>{if(measureDragIndex===i){measurePoints[i]=ev.target.getLatLng();if(measurePolylineLayer)measurePolylineLayer.setLatLngs(measurePoints);redrawMeasureLabelsOnly();updateMeasurePopupDock()}});marker.on('dragend',ev=>{measurePoints[i]=ev.target.getLatLng();measureDragIndex=null;if(measurePolylineLayer)measurePolylineLayer.setLatLngs(measurePoints);redrawMeasureLabelsOnly();updateMeasurePopupDock()})}updateMeasurePopupDock()}
function setMeasureLineColor(v){measureLineColor=String(v||'#b9c4c9');measureTextColor=measureLineColor;drawMeasure()}
function setMeasureTextColor(v){setMeasureLineColor(v)}
function measureClear(){measurePoints=[];measureLocked=false;drawMeasure();updateToolUi()}
function updateToolUi(){try{['Move','Coords','Measure'].forEach(n=>{const el=document.getElementById('tool'+n);if(el)el.classList.remove('active')});const mapEl={move:'toolMove',coords:'toolCoords',measure:'toolMeasure'}[activeMapTool]||'toolMove';const active=document.getElementById(mapEl);if(active)active.classList.add('active');const main=document.getElementById('floatingMapToolbar');if(main)main.style.display='block';const cr=document.getElementById('coordReadout');if(cr)cr.classList.toggle('active',activeMapTool==='coords');const cm=document.getElementById('coordsMiniToolbar');if(cm)cm.classList.toggle('active',activeMapTool==='coords');const mm=document.getElementById('measureMiniToolbar');if(mm)mm.classList.toggle('active',activeMapTool==='measure');if(map&&map.getContainer){const c=map.getContainer();c.classList.toggle('coords-tool-active',activeMapTool==='coords');c.classList.toggle('measure-tool-active',activeMapTool==='measure')}if(activeMapTool==='coords')updateCoordReadout(pinnedCoordinate||lastPointerLatLng,!!pinnedCoordinate);if(activeMapTool==='measure')drawMeasure();else updateMeasurePopupDock()}catch(e){try{console.warn('updateToolUi failed',e)}catch(_){}}}
function shapeAreaPopupRows(o){const m2=shapeAreaSqMeters(o);if(!m2)return'';const sqft=m2*10.7639104167;const acres=m2/4046.8564224;const ha=m2/10000;return `<b>Area</b><span>${Math.round(sqft).toLocaleString()} sq ft · ${Math.round(m2).toLocaleString()} sq m · ${acres.toFixed(2)} acres · ${ha.toFixed(2)} ha</span>`}
function collectAltValues(x,out){out=out||[];try{if(Array.isArray(x)){if(x.length>=3&&Number.isFinite(Number(x[2])))out.push(Number(x[2]));for(const y of x)collectAltValues(y,out)}else if(x&&typeof x==='object'){for(const k of ['alt','altitude','hae','height','elevation','ele']){if(Number.isFinite(Number(x[k])))out.push(Number(x[k]))}for(const k of ['coords','coordinates','geometry','properties'])if(x[k])collectAltValues(x[k],out)}}catch(e){}return out}
function formatAltMeters(m){m=Number(m);if(!Number.isFinite(m))return'—';return Math.round(m*3.280839895).toLocaleString()+' ft / '+Math.round(m).toLocaleString()+' m'}
function shapeAltPopupRows(o){const vals=collectAltValues(o,[]).filter(v=>Number.isFinite(v));if(!vals.length)return'';const hi=Math.max(...vals),lo=Math.min(...vals);return `<b>High Alt:</b><span>${esc(formatAltMeters(hi))}</span><b>Low Alt:</b><span>${esc(formatAltMeters(lo))}</span>`}
function layerPopupForObject(o,cat){if(cat==='Point Markers')return pointPopupHtml(o,cat);const name=o?.name||o?.callsign||o?.uid||o?.id||cat;const notes=popupNotes(o);const cen=objectCenter(o);const coordText=cen?formatCoords(cen[0],cen[1]):formatCoords(o?.lat,o?.lon);let centerRow=cat==='Shapes / Areas'?`<b>Center Point</b><span>${esc(coordText)}</span>`:`<b>Coordinates</b><span>${esc(coordText)}</span>`;const assetRow=(cat==='Shapes / Areas')?(shapeAreaPopupRows(o)+shapeAltPopupRows(o)):`<b>Asset</b><span>${esc(assetDescriptor(o))}</span>`;return `<div class="feature-popup"><h3>${esc(name)}</h3><div class="kvp"><b>Name</b><span>${esc(name)}</span><b>Added</b><span>${esc(addedTime(o))}</span>${centerRow}${assetRow}<b>Category</b><span>${esc(cat)}</span>${notes?`<b>Notes</b><span>${esc(notes)}</span>`:''}</div>${popupEditForm({...o,lat:cen?cen[0]:o?.lat,lon:cen?cen[1]:o?.lon},cat||'Data Sync')}</div>`}
function centerLocalItem(kind,id,ev){if(ev)ev.stopPropagation();const f=localDataFeatureById(id);const cen=objectCenter(f);if(!f||!cen){alert('No valid coordinates found for this local item.');return}try{map.setView(cen,Math.max(map.getZoom(),15),{animate:true});if(f.__layer){setTimeout(()=>{try{f.__layer._takPopupPinned=true;window._takPinnedPopupLayer=f.__layer;f.__layer.openPopup(cen)}catch(e){}},180)}}catch(e){try{console.warn('centerLocalItem failed',e)}catch(_){}}}
function centerSelectedLocal(kind,ids){const pts=[];for(const id of (ids||[])){const f=localDataFeatureById(id);const cen=objectCenter(f);if(cen)pts.push(cen)}if(!pts.length){alert('No valid coordinates found for the selected item(s).');return}try{if(pts.length===1)map.setView(pts[0],Math.max(map.getZoom(),15),{animate:true});else{const b=L.latLngBounds(pts);const sz=map.getSize();map.fitBounds(b,{padding:[Math.max(18,Math.round(sz.x*.07)),Math.max(18,Math.round(sz.y*.07))]})}}catch(e){try{console.warn('centerSelectedLocal failed',e)}catch(_){}}}
function exportAllData(){try{const inc=id=>!!document.getElementById('export'+id)?.checked;const payload={exported_at:new Date().toISOString(),version:'v233',sections:{}};if(inc('DataSync'))payload.sections.data_sync=lastDataSync||{};if(inc('LocalData'))payload.sections.local_data={imports:lastImports||[],features:importedFeatures?importedFeatures():[]};if(inc('Basemaps'))payload.sections.added_basemap_files=loadCustomBasemaps?loadCustomBasemaps():[];if(inc('OfflineMaps'))payload.sections.offline_maps=offlineMaps||[];if(inc('External'))payload.sections.external_source_files=config?.external_layers||[];const blob=new Blob([JSON.stringify(payload,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='tak-map-export-all-data-'+new Date().toISOString().replace(/[:.]/g,'-')+'.json';document.body.appendChild(a);a.click();setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove()},1000)}catch(e){alert('Export All Data failed: '+e)}}
function takV225PostInit(){try{document.addEventListener('keydown',ev=>{if(ev.key==='Escape'&&activeMapTool!=='move'){setActiveMapTool('move');try{ev.preventDefault()}catch(_){}}});if(map){map.on('popupopen',e=>{try{if(mapToolSuppressesObjectPopups()){if(e.popup&&e.popup._source&&e.popup._source.closePopup)e.popup._source.closePopup();return}clampLeafletPopupToMap(e.popup)}catch(_){}});map.on('move zoom resize',()=>{try{const p=map._popup;if(p)clampLeafletPopupToMap(p);measurePopupPositionDefault(document.getElementById('measurePopupDock'))}catch(_){}})}}catch(e){}}
const _takV225Init=init;init=async function(){const out=await _takV225Init.apply(this,arguments);takV225PostInit();return out};
