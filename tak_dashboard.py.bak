  function patchPopup(el){try{if(!el||!q('.adsb-popup,.feature-popup',el))return;const content=q('.leaflet-popup-content',el)||el;let id='';const btn=q('.adsb-track-btn',content);if(btn)id=String(btn.dataset.adsbTrackId||'').toLowerCase();if(!id){const title=(q('.adsb-popup h3,.feature-popup h3',el)?.textContent||'').trim().toLowerCase();const a=aircraftList().find(x=>titleOf(x).toLowerCase()===title||idOf(x)===title);id=idOf(a)}if(!id)return;if(!q('.adsb-track-btn',content))content.insertAdjacentHTML('beforeend',trackButtonHtml(id));qa('.adsb-track-btn',content).forEach(b=>{b.dataset.adsbTrackId=id;b.onclick=function(ev){try{ev&&ev.preventDefault&&ev.preventDefault();ev&&ev.stopPropagation&&ev.stopPropagation();ev&&ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}catch(_){}window.toggleAdsbTrack(id);return false}});syncButtons()}catch(_){} }
  function patchOpenPopups(){try{qa('.leaflet-popup').forEach(patchPopup)}catch(_){} }
  function closeDialog(){try{const old=field('adsbTrackSaveDialog');if(old)old.remove()}catch(_){} clearVisual(); }
  function saveDialog(id,meta,pts){
    try{
      const old=field('adsbTrackSaveDialog');if(old)old.remove();
      pts=(pts||[]).slice();const m=meters(pts);const title=titleOf(meta||{id});const stamp=new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');const def=clean(title+' ADS-B Track '+stamp);const canSave=pts.length>=2;
      const div=document.createElement('div');div.id='adsbTrackSaveDialog';div.className='adsb-track-save-overlay v300';
      div.innerHTML='<div class="adsb-track-save-card v300" role="dialog" aria-modal="true" aria-label="Save ADS-B track">'
        +'<button type="button" class="adsb-track-save-x" data-action="discard" aria-label="Close">×</button>'
        +'<div class="adsb-track-save-title">Save ADS-B Track</div>'
