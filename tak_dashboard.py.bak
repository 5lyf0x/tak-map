        _base_adsb = r'''function iconFor(a){
    const s=stableAdsbState(a);
    const p=s.category==='military'?'mil':s.category==='govt'?'gov':s.category==='unknown'?'unk':'civ';
    return `/assets/adsb/adsb_${p}_${s.is_helo?'helo':'fixed'}.png`;
  }
  const adsbStableById=new Map();
  const adsbTrackState=window.takMapAdsbTrackState||{id:null,meta:null,points:[],trackLayer:null,labelLayer:null,line:null,label:null};
  window.takMapAdsbTrackState=adsbTrackState;
  function adsbId(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.callsign||a.registration))||'').trim().toLowerCase()}
  function adsbClassPriority(c){return c==='military'?4:c==='govt'?3:c==='civil'?2:c==='unknown'?1:0}
  function detectAdsbCategory(a){
    const raw=String((a&&a.category)||'').toLowerCase();
    if(raw==='military'||raw==='mil')return 'military';
    if(raw==='govt'||raw==='government'||raw==='public')return 'govt';
