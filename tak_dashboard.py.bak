sb-table{min-width:330px;max-width:min(430px,calc(100vw - 24px));padding:8px}.status-dropdown-title{font-weight:900;text-transform:uppercase;letter-spacing:.08em;color:#c8d2da;margin:2px 4px 7px}.status-dropdown-row{display:flex;justify-content:space-between;gap:10px;padding:6px 7px;border-bottom:1px solid rgba(255,255,255,.055);border-radius:8px}.status-dropdown-row:last-child{border-bottom:0}.status-dropdown-row:hover{background:rgba(255,255,255,.05)}.status-dropdown-name{font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.status-dropdown-sub{color:var(--muted);font-size:.68rem;white-space:nowrap}.status-dropdown-empty{color:var(--muted);padding:8px 7px}.status-adsb-head,.status-adsb-row{display:grid;grid-template-columns:minmax(96px,1fr) 82px 116px;gap:8px;align-items:center;padding:6px 7px}.status-adsb-head{position:sticky;top:-8px;z-index:2;margin:0 -2px 3px;border-bottom:1px solid rgba(255,255,255,.12);background:rgba(8,13,18,.96);color:#ffd9c5;font-size:.66rem;font-weight:900;text-transform:uppercase;letter-spacing:.07em}.status-adsb-row{border-bottom:1px solid rgba(255,255,255,.055);border-radius:8px}.status-adsb-row:hover{background:rgba(255,255,255,.05)}.status-adsb-row span{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.status-adsb-icao{font-weight:850}.status-adsb-alt,.status-adsb-range{color:var(--muted);text-align:right}.map-status-banner .status-dot{width:9px;height:9px;border-radius:999px;background:var(--muted);box-shadow:0 0 7px rgba(141,160,173,.45);flex:0 0 auto}.map-status-banner .status-dot.good{background:var(--good);box-shadow:0 0 8px rgba(57,217,138,.78)}.map-status-banner .status-dot.warn{background:var(--warn);box-shadow:0 0 8px rgba(255,204,102,.70)}.map-status-banner .status-dot.bad{background:var(--bad);box-shadow:0 0 8px rgba(255,95,87,.70)}.map-status-banner .status-dot.unknown{background:var(--muted);box-shadow:0 0 6px rgba(141,160,173,.42)}.map-status-banner b{color:#fff}.sidebar.collap