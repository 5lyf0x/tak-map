    def _v318_patch_html(_html):
        if not isinstance(_html, str):
            return _html
        _popup = """function speedText(a){const kt=n(a&&((a.speed_kt??a.gs??a.speed??a.groundspeed)));if(kt==null)return '—';return Math.round(kt).toLocaleString()+' kt'}
  function headingText(a){const hd=n(a&&((a.track_deg??a.track??a.true_heading??a.mag_heading??a.heading)));if(hd==null)return '—';return Math.round(hd)+'°'}
  function ownerText(a){let s=String((a&&(a.owner_operator||a.ownOp||a.operator||a.owner))||'').trim();return s||'—'}
  function popupHtml(a){const id=idOf(a),st=stableState(a),name=titleOf(a,id),owner=ownerText(a),heading=headingText(a);let rows='';rows+='<div><b>Class</b><span>'+esc(classLabel(st.classKey))+'</span></div>';rows+='<div><b>Type</b><span>'+esc(typeLabel(st))+'</span></div>';rows+='<div><b>Speed</b><span>'+esc(speedText(a))+'</span></div>';rows+='<div><b>Altitude</b><span>'+esc(altText(a))+'</span></div>';rows+='<div><b>Range</b><span>'+esc(rangeText(a))+' mi</span></div>';if(heading!=='—')rows+='<div><b>Heading</b><span>'+esc(heading)+'</span></div>';rows+='<div class=\"adsb-pop-wide\"><b>Owner/Op</b><span>'+esc(owner)+'</span></div>';return '<div class=\"adsb-popup adsb-pro-popup v318\" data-adsb-id=\"'+esc(id)+'\"><div class=\"adsb-pop-head\"><div><div class=\"adsb-pop-title\">'+esc(name)+'</div><div class=\"adsb-pop-sub\">'+esc(classLabel(st.classKey))+' · '+esc(typeLabel(st))+'</div></div></div><div class=\"adsb-pop-grid\">'+rows+'</div><div class=\"adsb-track-row\">'+trackButtonHtml(a)+'</div></div>'}"""
        _html = _v318_re.sub(r'function popupHtml\(a\)\{.*?\n  function updateMarkerDom', _popup + '\n  function updateMarkerDom', _html, count=1, flags=_v318_re.S)
        _html = _html.replace("function iconFor(a){return L.divIcon({className:'adsb-v317-marker',iconSize:[96,60],iconAnchor:[48,24],popupAnchor:[0,-20],html:markerHtml(a)})}", "function iconFor(a){return L.divIcon({className:'adsb-v318-marker',iconSize:[72,58],iconAnchor:[36,24],popupAnchor:[0,-24],html:markerHtml(a)})}")
        _html = _html.replace("function iconFor(a){return L.divIcon({className:'adsb-v318-marker',iconSize:[96,60],iconAnchor:[48,24],popupAnchor:[0,-20],html:markerHtml(a)})}", "function iconFor(a){return L.divIcon({className:'adsb-v318-marker',iconSize:[72,58],iconAnchor:[36,24],popupAnchor:[0,-24],html:markerHtml(a)})}")
        _style = """
<script id=\"v318AdsbPopupLabelPolish\">
(function(){
  const V='v318';
  function addCss(){
    if(document.getElementById('v318AdsbPopupLabelStyle'))return;
    const st=document.createElement('style');
