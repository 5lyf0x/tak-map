  window.renderMilPicker=function(){try{v234EnsureMilRows&&v234EnsureMilRows();const icons=(window.v233MilIcons||[]).filter(i=>i&&i.name&&i.sidc&&i.label!=='?'&&!String(i.name).includes('placeholder'));window.v233MilFilter=window.v233MilFilter||{affil:'Friendly',domain:'Ground',cat:''};const f=window.v233MilFilter;const q=String(document.getElementById('milSearch')?.value||'').toLowerCase();const affils=['Friendly','Hostile','Neutral','Unknown'];const domains=['Ground','Air','Sea Surface','Subsurface','Space'];const ac=document.getElementById('milAffilChips');if(ac){ac.classList.add('even-chip-row');ac.innerHTML=affils.map(a=>`<button class="mil-chip ${f.affil===a?'active':''}" onclick="v233MilFilter.affil='${a}';v233MilFilter.cat='';renderMilPicker()">${a}</button>`).join('')}let dc=document.getElementById('milDomainChips');if(!dc&&ac){ac.insertAdjacentHTML('afterend','<div class="mil-chips mil-domain-row even-chip-row" id="milDomainChips"></div>');dc=document.getElementById('milDomainChips')}if(dc){dc.classList.add('even-chip-row');dc.innerHTML=domains.map(d=>`<button class="mil-chip ${f.domain===d?'active':''}" onclick="v233MilFilter.domain='${d}';v233MilFilter.cat='';renderMilPicker()">${d}</button>`).join('')}const cats=Array.from(new Set(icons.filter(i=>sidcAffil(i)===(f.affil||'Friendly')&&sidcDomain(i)===(f.domain||'Ground')).map(milCat))).sort();const cc=document.getElementById('milCats');if(cc)cc.innerHTML='<button class="mil-cat '+(!f.cat?'active':'')+'" onclick="v233MilFilter.cat=\'\';renderMilPicker()">ALL</button>'+cats.map(c=>`<button class="mil-cat ${f.cat===c?'active':''}" onclick="v233MilFilter.cat='${c}'">${String(c).replace(/-/g,' ').toUpperCase()}</button>`).join('');let list=icons.filter(i=>sidcAffil(i)===(f.affil||'Friendly')&&sidcDomain(i)===(f.domain||'Ground')&&(!f.cat||milCat(i)===f.cat));if(q)list=list.filter(i=>String([i.name,i.label,i.sidc].join(' ')).toLowerCase().includes(q));list=list.slice(0,240);const g=document.getElementById('milGrid');if(g)g.innerHTML=list.map(i=>`<div class="mil-icon-card ${(window.v233MilSelected&&window.v233MilSelected.name===i.name)?'selected':''}" title="${E(i.name)}" onclick="v236SelectMil('${encodeURIComponent(i.name)}')"><img src="/mil2525/svg/${E(i.name)}.svg" onerror="this.closest('.mil-icon-card').style.display='none'"></div>`).join('');const sel=window.v233MilSelected;const pr=document.getElementById('milPreview');if(pr)pr.innerHTML=sel?`<img src="/mil2525/svg/${E(sel.name)}.svg" onerror="this.style.display='none'">`:'';const sn=document.getElementById('milSelectedName');if(sn)sn.textContent=sel?(sel.label||sel.name):'No symbol selected';const sm=document.getElementById('milSelectedMeta');if(sm)sm.textContent=sel?`${sidcAffil(sel)} · ${sidcDomain(sel)} · ${sel.sidc||''}`:'Choose affiliation, domain, and symbol.';const det=document.getElementById('milDetails');if(det)det.textContent=sel?`Symbol: ${sel.sidc||''} · ${sel.name}`:`${list.length} symbols shown`}catch(e){}}
  function injectCss(){try{if(document.getElementById('v236Style'))return;document.head.insertAdjacentHTML('beforeend',`<style id="v236Style">.compact-icon-toolbar{width:max-content!important;max-width:360px}.compact-icon-toolbar .tool-label,.draw-icon-menu .tool-label{display:none!important}.draw-icon-menu{display:grid!important;grid-template-columns:repeat(3,34px);gap:5px;width:max-content!important;min-width:0!important;padding:6px!important}.draw-icon-menu button{width:34px;height:34px;padding:6px!important;display:grid;place-items:center}.draw-icon-menu svg,.compact-icon-toolbar svg{width:20px;height:20px}.tool-submenu{max-width:190px}.tak-floating-panel .panel-grid.compact{grid-template-columns:1fr 1fr}.draw-options-panel{width:300px}.route-prefix-row{display:none!important}.tiny-ok{margin-left:6px;padding:3px 7px;border-radius:6px;border:1px solid rgba(255,122,34,.35);background:rgba(255,122,34,.13);color:#ffd0b2;font-size:.65rem}.mil-search{height:24px!important;min-height:24px!important;padding:3px 8px!important;font-size:.7rem!important;max-width:150px!important}.mil-affil-row,.mil-domain-row,.even-chip-row{display:grid!important;grid-auto-flow:column;grid-auto-columns:1fr;gap:5px;width:100%}.even-chip-row .mil-chip{width:100%;text-align:center;padding-left:4px!important;padding-right:4px!important}.mil-cat{text-transform:uppercase}.leaflet-interactive.route-hit-buffer{stroke-width:16px!important;stroke-opacity:0!important}</style>`)}catch(e){}}
