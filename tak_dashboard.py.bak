  async function loadLocalElevationTilesV292(){const st=localElevStateV292();if(st.loaded)return st;if(st.loading)return st.loading;st.loading=(async()=>{try{const db=await openLocalElevDbV292();st.tiles=new Map();await new Promise((resolve,reject)=>{const tx=db.transaction(['tiles'],'readonly');const req=tx.objectStore('tiles').openCursor();req.onsuccess=e=>{const cur=e.target.result;if(cur){const t=cur.value;if(t&&t.id)addTileToState(st,t);cur.continue()}else resolve()};req.onerror=()=>reject(req.error||new Error('IndexedDB cursor failed'));tx.oncomplete=()=>{try{db.close()}catch(_){}}});st.meta=uniqueTiles(st).map(localElevMetaFor);st.loaded=true;st.loading=null;updateLocalElevationUiV292();return st}catch(e){console.warn('local elevation load failed',e);st.loaded=true;st.loading=null;setElevStatus('Local elevation load failed: '+String(e&&e.message||e),true);return st}})();return st.loading}
  window.loadLocalElevationTiles=loadLocalElevationTilesV292;
