      state.markers.forEach((row,id)=>{window.v298AircraftLayersById[id]=row.marker});
      window.v240AircraftLayersById=window.v298AircraftLayersById;window.v238AircraftLayersById=window.v298AircraftLayersById;window.v236AircraftLayersById=window.v298AircraftLayersById;
      try{if(typeof window.handleMapSearch==='function')window.handleMapSearch()}catch(_){}
      try{if(typeof window.updateAdsbTrackFromStable==='function')window.updateAdsbTrackFromStable()}catch(_){}
      state.lastDrawAt=Date.now(); state.lastIds=arr.map(idOf).sort().join('|');
    }catch(e){try{console.warn('v298 ADS-B no-blink render failed',e)}catch(_){}}
  }
