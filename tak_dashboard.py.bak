  function titleText(a){return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.id))||'ADS-B').trim()||'ADS-B'}
  function altText(a){let v=a&&(a.altitude_ft??a.alt_baro??a.alt_geom);if(String(v).toLowerCase()==='ground')return 'Ground';v=Number(v);return Number.isFinite(v)?Math.round(v).toLocaleString()+' ft':'—'}
  function rangeText(a){let v=a&&(a.range_miles??a.range);v=Number(v);return Number.isFinite(v)?v.toFixed(1)+' mi':'—'}
