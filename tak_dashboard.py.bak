    _v309_script = r"""<script id="v309AdsbOwnerPatch">
(function(){
  'use strict';
  const V='v309';
  const CTL=window.TakMapControllers=window.TakMapControllers||{};
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function byId(id){try{return document.getElementById(id)}catch(_){return null}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]})}
  function n(v){v=Number(v);return Number.isFinite(v)?v:null}
  function mapObj(){try{if(typeof map!=='undefined'&&map&&map.addLayer){window.map=map;window.takLeafletMap=map;return map}}catch(_){}try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(window.map&&window.map.addLayer){window.takLeafletMap=window.map;return window.map}}catch(_){}return null}
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flight))||'').trim().toLowerCase()}
  function titleOf(a,id){return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id))||id||'ADS-B Aircraft').trim()||'ADS-B Aircraft'}
  function blob(a){try{return [a&&a.category,a&&a.category_raw,a&&a.emitter_category,a&&a.adsb_category,a&&a.type,a&&a.aircraft_type,a&&a.description,a&&a.desc,a&&a.model,a&&a.t,a&&a.callsign,a&&a.flight,a&&a.registration,a&&a.owner_operator,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.source].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function rawClass(a){const b=blob(a);const c=String((a&&(a.aircraft_class||a.category_class||a.classification||a.category))||'').toLowerCase();if(a&&(a.is_military===true||a.military===true))return 'mil';if(/\b(MIL|MILITARY|USAF|USN|USMC|ARMY|NAVY|RCH|REACH)\b/i.test(b)||/mil/.test(c))return 'mil';if(a&&(a.is_govt===true||a.govt===true))return 'gov';if(/\b(LAW ENFORCEMENT|POLICE|SHERIFF|STATE POLICE|HIGHWAY PATROL|CHP|CAL FIRE|CALFIRE|FIRE DEPT|FIRE DEPARTMENT|PUBLIC SAFETY|EMS|RESCUE|USFS|FOREST SERVICE|MEDICAL|HOSPITAL|RESPONSE|FEMA|DHS|CBP|CUSTOMS|BORDER PATROL|DEA|FBI|NOAA|NASA|NPS|USCG|COAST GUARD)\b/i.test(b)||/gov/.test(c))return 'gov';if(a&&(a.is_unknown===true))return 'unk';if(/unknown/.test(c))return 'unk';return 'civ'}
  const classRank={unk:0,civ:1,gov:2,mil:3};
  function shapeEvidence(a){const b=blob(a);if(a&&(a.is_helo===true||a.is_rotor===true||a.rotorcraft===true))return 'helo';if(/\b(A7|ROTOR|ROTORCRAFT|ROTARY|HELICOPTER|HELI|HELO|GYRO|H60|UH60|MH60|HH60|SH60|CH47|AH64|OH58|CH53|UH1|UH72|V22|B206|B407|B412|B429|B505|R22|R44|R66|S76|S92|AS50|AS350|AS355|EC35|EC45|EC120|EC130|EC135|EC145|H125|H135|H145|BELL|ROBINSON)\b/i.test(b))return 'helo';if(/\b(FIXED WING|FIXED-WING|AIRPLANE|AEROPLANE|JET|TURBOPROP|GLIDER|ULTRALIGHT)\b/i.test(b))return 'fixed';return null}
  const stableById=new Map();
  function stableState(a){const id=idOf(a);let s=id?stableById.get(id):null;if(!s){s={classKey:'unk',shape:'fixed',lastSeen:0};if(id)stableById.set(id,s)}const rc=rawClass(a);if(classRank[rc]>=classRank[s.classKey] || (s.classKey==='unk'&&rc))s.classKey=rc;const ev=shapeEvidence(a);if(ev==='helo')s.shape='helo';else if(!s.shape&&ev)s.shape=ev;else if(s.shape!=='helo'&&ev==='fixed')s.shape='fixed';s.lastSeen=Date.now();return s}
  function iconPath(a){const s=stableState(a);const cls=s.classKey==='mil'?'mil':s.classKey==='gov'?'gov':s.classKey==='unk'?'unk':'civ';return '/assets/adsb/adsb_'+cls+'_'+(s.shape==='helo'?'helo':'fixed')+'.png'}
  function classLabel(k){return k==='mil'?'Military':k==='gov'?'Govt':k==='unk'?'Unknown':'Civil'}
  function altText(a){let v=a&&(a.altitude_ft??a.alt_baro??a.alt_geom??a.alt);if(String(v).toLowerCase()==='ground')return 'Ground';v=n(v);return v==null?'—':Math.round(v).toLocaleString()+' ft'}
  function speedText(a){let v=a&&(a.speed_kt??a.gs??a.speed);v=n(v);return v==null?'—':Math.round(v)+' kt'}
  function trackText(a){let v=a&&(a.track_deg??a.track??a.heading);v=n(v);return v==null?'—':Math.round(v)+'°'}
  function rangeText(a){let v=a&&(a.range_miles??a.range);v=n(v);return v==null?'—':v.toFixed(1)+' mi'}
  const ADSB=CTL.adsb={version:V,markers:new Map(),data:new Map(),lastList:[],lastGoodAt:0,refreshTimer:null,busy:false,tracking:{id:null,meta:null,points:[],layer:null,label:null}};
  function normalizeList(input){const arr=Array.isArray(input)?input:(Array.isArray(window.lastAircraft)?window.lastAircraft:[]);return arr.map(function(a){a=Object.assign({},a||{});a.lat=n(a.lat);a.lon=n(a.lon);return a}).filter(function(a){return a.lat!=null&&a.lon!=null&&idOf(a)})}
  function filters(){const f={civ:true,mil:true,gov:true,unk:true};try{if(byId('adsbFilterCivil'))f.civ=byId('adsbFilterCivil').checked!==false;if(byId('adsbFilterMilitary'))f.mil=byId('adsbFilterMilitary').checked!==false;if(byId('adsbFilterGovt'))f.gov=byId('adsbFilterGovt').checked!==false;if(byId('adsbFilterUnknown'))f.unk=byId('adsbFilterUnknown').checked!==false}catch(_){}return f}
  function filtered(rows){const f=filters();return (rows||[]).filter(function(a){return f[stableState(a).classKey]!==false})}
  function ensureLayer(){const m=mapObj();if(!m||!window.L)return null;if(!ADSB.layer){ADSB.layer=L.layerGroup().addTo(m)}try{if(typeof aircraftLayer!=='undefined'&&aircraftLayer&&aircraftLayer.clearLayers)aircraftLayer.clearLayers()}catch(_){}return ADSB.layer}
  function popupHtml(a){const id=esc(idOf(a));const st=stableState(a);const rows=[['Class',classLabel(st.classKey)],['Type',st.shape==='helo'?'Helicopter':'Airplane'],['Alt',altText(a)],['Speed',speedText(a)],['Track',trackText(a)],['Range',rangeText(a)],['Owner/Op',a.owner_operator||a.ownOp||a.operator||a.owner||'']].filter(function(r){return r[1]&&r[1]!=='—'});return '<div class="feature-popup adsb-popup" data-adsb-id="'+id+'"><h3>'+esc(titleOf(a,id))+'</h3><div class="kvp">'+rows.map(function(r){return '<b>'+esc(r[0])+'</b><span>'+esc(r[1])+'</span>'}).join('')+'</div><div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn" data-adsb-track-id="'+id+'"><span class="adsb-track-light"></span><span class="adsb-track-text">Track</span></button></div></div>'}
  function markerHtml(a){const id=esc(idOf(a));const rot=n(a.track_deg??a.track??a.heading)||0;const label=esc(titleOf(a,id));return '<div class="adsb-v309-hitbox" data-adsb-id="'+id+'"><img draggable="false" src="'+esc(iconPath(a))+'" style="transform:rotate('+rot+'deg)" alt=""><span class="aircraft-label">'+label+'</span></div>'}
  function iconFor(a){if(!window.L)return null;return L.divIcon({className:'adsb-v309-marker',iconSize:[96,60],iconAnchor:[48,24],popupAnchor:[0,-20],html:markerHtml(a)})}
  function publishMaps(){try{const obj={};ADSB.markers.forEach(function(v,k){obj[k]=v});window.v309AircraftLayersById=obj;window.v240AircraftLayersById=obj;window.v238AircraftLayersById=obj;window.v236AircraftLayersById=obj}catch(_){} }
  function renderAircraft(input){const layer=ensureLayer();if(!layer)return [];let rows=filtered(normalizeList(input));const now=Date.now();if(rows.length){ADSB.lastList=rows.slice();ADSB.lastGoodAt=now}else if(ADSB.lastList.length && now-ADSB.lastGoodAt<120000){rows=ADSB.lastList.slice()}window.lastAircraft=rows;const seen=new Set();rows.forEach(function(a){const id=idOf(a);seen.add(id);ADSB.data.set(id,a);let mk=ADSB.markers.get(id);const ll=[a.lat,a.lon];if(!mk){mk=L.marker(ll,{icon:iconFor(a),zIndexOffset:900,interactive:true,riseOnHover:true}).addTo(layer);ADSB.markers.set(id,mk);mk.on('click',function(ev){try{L.DomEvent.stop(ev)}catch(_){}try{mk.openPopup();setTimeout(syncButtons,20)}catch(_){}});mk.on('popupopen',function(){setTimeout(syncButtons,20)});}else{mk.setLatLng(ll);const el=mk.getElement&&mk.getElement();const img=el&&el.querySelector&&el.querySelector('img');const lab=el&&el.querySelector&&el.querySelector('.aircraft-label');const want=iconPath(a);if(img){try{if(!(String(img.getAttribute('src')||'').endsWith(want)))img.src=want;img.style.transform='rotate('+((n(a.track_deg??a.track??a.heading)||0))+'deg)'}catch(_){}}else{try{mk.setIcon(iconFor(a))}catch(_){}}if(lab)lab.textContent=titleOf(a,id)}try{mk._takAdsbAircraft=a;mk._takAdsbId=id;if(!mk.isPopupOpen())mk.bindPopup(popupHtml(a),{className:'adsb-v309-popup adsb-object-popup',autoPan:false,closeButton:false});else mk.setPopupContent(popupHtml(a))}catch(_){}if(ADSB.tracking.id===id)addTrackPoint(a)});ADSB.markers.forEach(function(mk,id){if(!seen.has(id)){const st=stableById.get(id);if(!st||Date.now()-st.lastSeen>120000){try{layer.removeLayer(mk)}catch(_){}ADSB.markers.delete(id);ADSB.data.delete(id)}}});publishMaps();updateStatus(rows.length);syncButtons();return rows}
  function updateStatus(count){try{const x=Number(count)||0;if(byId('adsbStatus'))byId('adsbStatus').textContent=x+' active';if(byId('bannerAdsb'))byId('bannerAdsb').textContent=x+' Aircraft';if(byId('bannerAdsbDot'))byId('bannerAdsbDot').className='status-dot '+(x>0?'good':'unknown')}catch(_){} }
  async function refreshAdsb(){if(ADSB.busy)return ADSB.lastList;ADSB.busy=true;try{const r=await fetch('/api/tak-map/adsb',{cache:'no-store'});const j=await r.json();try{window.lastAdsbSettings=(j&&j.settings)||window.lastAdsbSettings}catch(_){}return renderAircraft(j&&j.aircraft||[])}catch(e){console.warn('v309 ADS-B refresh failed',e);return renderAircraft([])}finally{ADSB.busy=false}}
  function startPolling(){try{if(ADSB.refreshTimer)clearInterval(ADSB.refreshTimer);let sec=Number((byId('adsbUpdateInterval')||{}).value||5);if(!Number.isFinite(sec)||sec<1)sec=5;ADSB.refreshTimer=setInterval(refreshAdsb,sec*1000);setTimeout(refreshAdsb,300)}catch(_){} }
  function distMeters(pts){let m=0;for(let i=1;i<(pts||[]).length;i++){const a=pts[i-1],b=pts[i];try{if(window.L&&L.latLng)m+=L.latLng(a.lat,a.lon).distanceTo(L.latLng(b.lat,b.lon));else{const R=6371000,rad=Math.PI/180,p1=a.lat*rad,p2=b.lat*rad,dp=(b.lat-a.lat)*rad,dl=(b.lon-a.lon)*rad,h=Math.sin(dp/2)**2+Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;m+=2*R*Math.atan2(Math.sqrt(h),Math.sqrt(1-h))}}catch(_){}}return m}
  function distText(m){return (m/1609.344).toFixed(1)+'mi/'+(m/1000).toFixed(1)+'km'}
  function ensureTrackVisual(){const m=mapObj();if(!m||!window.L)return false;const t=ADSB.tracking;if(!t.layer)t.layer=L.polyline([],{color:'#ff4b2b',weight:4,opacity:.95,lineCap:'round',lineJoin:'round',interactive:false}).addTo(m);if(!t.label)t.label=L.marker([0,0],{interactive:false,icon:L.divIcon({className:'adsb-track-distance-label',html:'0.0mi/0.0km',iconSize:null,iconAnchor:[-10,10]})}).addTo(m);return true}
  function drawTrack(){const t=ADSB.tracking;if(!t.id||!ensureTrackVisual())return;const latlngs=t.points.map(function(p){return [p.lat,p.lon]});try{t.layer.setLatLngs(latlngs);if(latlngs.length){t.label.setLatLng(latlngs[latlngs.length-1]);t.label.setIcon(L.divIcon({className:'adsb-track-distance-label',html:distText(distMeters(t.points)),iconSize:null,iconAnchor:[-10,10]}))}}catch(_){} }
  function addTrackPoint(a){const t=ADSB.tracking;if(!t.id||!a||idOf(a)!==t.id)return;const lat=n(a.lat),lon=n(a.lon);if(lat==null||lon==null)return;const last=t.points[t.points.length-1];if(last&&Math.abs(last.lat-lat)<1e-7&&Math.abs(last.lon-lon)<1e-7)return;t.meta=Object.assign({},t.meta||{},a);t.points.push({lat,lon,alt:n(a.altitude_ft??a.alt_baro??a.alt_geom)||0,t:Date.now()});drawTrack()}
  function clearTrackVisual(){const t=ADSB.tracking;try{const m=mapObj();if(m&&t.layer)m.removeLayer(t.layer);if(m&&t.label)m.removeLayer(t.label)}catch(_){}t.layer=null;t.label=null}
  function startTrack(id){id=String(id||'').toLowerCase();const a=ADSB.data.get(id)||normalizeList().find(function(x){return idOf(x)===id});if(!id||!a)return false;if(ADSB.tracking.id&&ADSB.tracking.id!==id)stopTrack(false);ADSB.tracking.id=id;ADSB.tracking.meta=a;ADSB.tracking.points=[];clearTrackVisual();addTrackPoint(a);syncButtons();return true}
  function stopTrack(showDialog){const t=ADSB.tracking;if(!t.id)return false;const id=t.id,meta=t.meta,pts=t.points.slice();t.id=null;t.meta=null;t.points=[];syncButtons();if(showDialog!==false)saveDialog(id,meta,pts);else clearTrackVisual();return true}
  function toggleTrack(id){id=String(id||'').toLowerCase();if(!id)return false;if(ADSB.tracking.id===id)return stopTrack(true);return startTrack(id)}
  function syncButtons(){try{const id=ADSB.tracking.id;qa('.adsb-track-btn').forEach(function(b){const on=String(b.dataset.adsbTrackId||'').toLowerCase()===id;b.classList.toggle('active',on);b.classList.toggle('tracking',on);b.setAttribute('aria-pressed',on?'true':'false');b.dataset.adsbTracking=on?'1':'0';const t=q('.adsb-track-text',b);if(t)t.textContent=on?'Untrack':'Track';const l=q('.adsb-track-light',b);if(l)l.classList.toggle('active',on)})}catch(_){} }
  function saveDialog(id,meta,pts){try{const old=byId('adsbTrackSaveDialog');if(old)old.remove();const meters=distMeters(pts);const title=titleOf(meta,id);const stamp=new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');const def=(title+' ADS-B Track '+stamp).replace(/[^A-Za-z0-9_. -]+/g,'_').trim();const can=(pts||[]).length>=2;const div=document.createElement('div');div.id='adsbTrackSaveDialog';div.className='adsb-track-save-overlay';div.innerHTML='<div class="adsb-track-save-card" role="dialog" aria-modal="true"><button type="button" class="adsb-track-save-x" data-act="discard">×</button><div class="adsb-track-save-title">Save ADS-B Track</div><div class="adsb-track-save-sub">'+esc(title)+' · '+esc(distText(meters))+' · '+String((pts||[]).length)+' pts</div><input id="adsbTrackRouteName" class="adsb-track-save-input" value="'+esc(def)+'" '+(can?'':'disabled')+'>'+(can?'':'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>')+'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div><div class="adsb-track-save-actions"><button type="button" class="layer-button" data-act="discard">Discard</button><button type="button" class="layer-button primary" data-act="save" '+(can?'':'disabled')+'>Save</button></div></div>';document.body.appendChild(div);const msg=byId('adsbTrackSaveMsg');div.addEventListener('click',async function(ev){const act=ev.target&&ev.target.getAttribute&&ev.target.getAttribute('data-act');if(act==='discard'||ev.target===div){ev.preventDefault();div.remove();clearTrackVisual();return}if(act==='save'&&can){ev.preventDefault();try{if(msg)msg.textContent='Saving…';const name=String((byId('adsbTrackRouteName')||{}).value||def).replace(/[^A-Za-z0-9_. -]+/g,'_').trim()||def;const fc={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(function(p){return [p.lon,p.lat,p.alt||0]})},properties:{name:name,kind:'route',geometry:'route',source:'TAK Map ADS-B',route_type:'adsb_aircraft_track',point_count:pts.length,distance_miles:Number((meters/1609.344).toFixed(3)),distance_km:Number((meters/1000).toFixed(3)),distance_text:distText(meters)}}]};const file=new File([new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'})],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});if(!r.ok)throw new Error('HTTP '+r.status);try{if(typeof refreshLocalData==='function')await refreshLocalData()}catch(_){}if(msg)msg.textContent='Saved to Local Data → Routes';setTimeout(function(){div.remove();clearTrackVisual()},550)}catch(e){if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}}}})}catch(e){console.warn('v309 save dialog failed',e);clearTrackVisual()}}
  function onTrackClick(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(!btn)return;ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation();toggleTrack(btn.dataset.adsbTrackId||'')}
  function openAdsbDropdown(ev){try{const box=byId('statusDropdown');if(!box)return;const rows=ADSB.lastList.slice().sort(function(a,b){return titleOf(a).localeCompare(titleOf(b))});box.innerHTML='<div class="status-dropdown-title">ADS-B Aircraft</div><div class="status-adsb-head v309"><b>Aircraft</b><b>Class</b><b>Type</b><b>Alt</b><b>mi→Center</b></div>'+rows.map(function(a){const id=esc(idOf(a));const st=stableState(a);return '<button type="button" class="status-adsb-row v309" data-adsb-focus="'+id+'"><span>'+esc(titleOf(a,id))+'</span><span>'+esc(classLabel(st.classKey))+'</span><span>'+esc(st.shape==='helo'?'Heli':'Fixed')+'</span><span>'+esc(altText(a))+'</span><span>'+esc(rangeText(a))+'</span></button>'}).join('');box.classList.add('active');if(ev){const r=ev.currentTarget.getBoundingClientRect();box.style.left=Math.max(8,Math.min(window.innerWidth-360,r.left))+'px';box.style.top=Math.max(54,r.bottom+8)+'px'}}catch(_){} }
  function focusAircraft(id){try{id=decodeURIComponent(String(id||'')).toLowerCase();const a=ADSB.data.get(id);const mk=ADSB.markers.get(id);const m=mapObj();if(a&&m)m.setView([a.lat,a.lon],Math.max(m.getZoom(),13),{animate:true});if(mk)setTimeout(function(){try{mk.openPopup();syncButtons()}catch(_){}},180)}catch(_){} }
  function openViewshed(ev){try{if(ev){ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation()} if(typeof window.toggleViewshedModule==='function'){try{window.toggleViewshedModule(true)}catch(_){}}let panel=byId('viewshedModule')||byId('viewshedPanel')||q('.viewshed-module,.viewshed-panel,#viewshedControl,.viewshed-control');if(!panel){const candidates=qa('div,section,aside').filter(function(el){return /viewshed/i.test(String(el.id+' '+el.className+' '+(el.getAttribute('aria-label')||'')))});panel=candidates[0]||null}if(panel){panel.style.display='block';panel.style.visibility='visible';panel.style.opacity='1';panel.classList.add('active','open');panel.classList.remove('collapsed','minimized','hidden');const bar=byId('floatingToolbar')||q('.floating-toolbar');const bw=panel.offsetWidth||360,bh=panel.offsetHeight||420;let left=(window.innerWidth-bw-18),top=90;if(bar){const r=bar.getBoundingClientRect();left=r.left-bw-12;top=Math.max(72,r.top)}left=Math.max(8,Math.min(left,window.innerWidth-bw-8));top=Math.max(64,Math.min(top,window.innerHeight-bh-8));panel.style.position='fixed';panel.style.left=left+'px';panel.style.top=top+'px';panel.style.right='auto';panel.style.bottom='auto';panel.style.zIndex='4200';}}catch(e){console.warn('v309 Viewshed open failed',e)}}
  function ownGlobals(){window.refreshAdsb=refreshAdsb;window.drawAircraft=renderAircraft;window.aircraftIcon=iconFor;window.adsbPopupHtml=popupHtml;window.focusAdsbAircraft=focusAircraft;window.toggleAdsbTrack=toggleTrack;window.v309ToggleAdsbTrack=toggleTrack;window.updateAdsbTrackPoint=addTrackPoint;window.syncAdsbTrackButtons=syncButtons;window.openTakMapViewshed=openViewshed;try{refreshAdsb=window.refreshAdsb;drawAircraft=window.drawAircraft;aircraftIcon=window.aircraftIcon;adsbPopupHtml=window.adsbPopupHtml;focusAdsbAircraft=window.focusAdsbAircraft}catch(_){} }
  function addCss(){if(byId('v309AdsbViewshedStyle'))return;const st=document.createElement('style');st.id='v309AdsbViewshedStyle';st.textContent='.adsb-v309-marker{background:transparent!important;border:0!important}.adsb-v309-hitbox{width:96px;height:60px;display:flex;align-items:center;justify-content:center;position:relative;pointer-events:auto}.adsb-v309-hitbox img{width:42px;height:42px;object-fit:contain;display:block;pointer-events:none}.adsb-v309-hitbox .aircraft-label{position:absolute;left:50%;top:43px;transform:translateX(-50%);background:rgba(5,8,12,.86);border:1px solid rgba(255,255,255,.12);border-radius:999px;color:#eaf2f5;font-size:10px;font-weight:900;padding:2px 6px;white-space:nowrap}.adsb-track-btn.active,.adsb-track-btn.tracking,.adsb-track-btn[data-adsb-tracking="1"]{color:#fff!important;border-color:rgba(255,90,70,.95)!important;background:linear-gradient(180deg,rgba(255,59,48,.40),rgba(120,20,16,.34))!important;box-shadow:0 0 12px rgba(255,59,48,.34)!important}.adsb-track-light{display:inline-block;width:8px;height:8px;border-radius:50%;background:#44515a;margin-right:6px}.adsb-track-light.active{background:#ff3b30!important;box-shadow:0 0 10px rgba(255,59,40,.9)}.adsb-track-distance-label{background:rgba(8,12,16,.92);border:1px solid rgba(255,111,46,.80);border-radius:999px;color:#ffe4d4;box-shadow:0 6px 18px rgba(0,0,0,.38),0 0 14px rgba(255,111,46,.22);font-size:11px;font-weight:900;letter-spacing:.02em;line-height:1;padding:3px 7px;white-space:nowrap}.adsb-track-save-overlay{position:fixed;inset:0;z-index:4300;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.42);backdrop-filter:blur(3px)}.adsb-track-save-card{position:relative;width:min(420px,calc(100vw - 28px));border:1px solid rgba(255,122,26,.42);border-radius:14px;background:linear-gradient(180deg,rgba(18,27,35,.98),rgba(8,12,18,.98));box-shadow:0 18px 50px rgba(0,0,0,.60),0 0 22px rgba(255,122,26,.13);padding:13px 14px 12px;color:#eef5f7}.adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;font-size:18px;font-weight:900}.adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px}.adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750}.adsb-track-save-input{width:100%;box-sizing:border-box;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750}.adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850}.adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850}.adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px}.status-adsb-head.v309,.status-adsb-row.v309{display:grid;grid-template-columns:minmax(112px,1.5fr) 72px 62px 82px 92px;gap:8px;align-items:center}.status-adsb-row.v309{width:100%;border:0;border-top:1px solid rgba(255,255,255,.07);background:transparent;color:inherit;text-align:left;padding:7px 4px}.status-adsb-row.v309:hover{background:rgba(255,111,46,.10)}';document.head.appendChild(st)}
  function version(){try{qa('.iteration-chip,.iteration-marker').forEach(function(el){el.textContent=V});qa('.version-product,.sidebar-version-title').forEach(function(el){if(/dashboard/i.test(el.textContent||''))el.textContent='TAK Map'})}catch(_){} }
  function boot(){addCss();version();ownGlobals();try{if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer)}catch(_){}try{if(typeof aircraftLayer!=='undefined'&&aircraftLayer&&aircraftLayer.clearLayers)aircraftLayer.clearLayers()}catch(_){}startPolling();renderAircraft(ADSB.lastList.length?ADSB.lastList:(Array.isArray(window.lastAircraft)?window.lastAircraft:[]));}
  window.addEventListener('click',function(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(btn)return onTrackClick(ev);const foc=ev.target&&ev.target.closest&&ev.target.closest('[data-adsb-focus]');if(foc){ev.preventDefault();focusAircraft(foc.dataset.adsbFocus)}const adsbBtn=ev.target&&ev.target.closest&&ev.target.closest('#bannerAdsbItem');if(adsbBtn){ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation();const box=byId('statusDropdown');if(box&&box.classList.contains('active')&&box.dataset.v309AdsbOpen==='1'){box.classList.remove('active');box.dataset.v309AdsbOpen='0'}else{openAdsbDropdown(ev);if(box)box.dataset.v309AdsbOpen='1'}}const vs=ev.target&&ev.target.closest&&ev.target.closest('#toolViewshed,[data-tool="viewshed"],button[title="Viewshed"],button[onclick*="Viewshed"]');if(vs)return openViewshed(ev)},true);
  document.addEventListener('keydown',function(ev){if(ev.key==='Escape'){const box=byId('statusDropdown');if(box){box.classList.remove('active');box.dataset.v309AdsbOpen='0'}}});
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',function(){setTimeout(boot,160)},{once:true});else setTimeout(boot,160);
  [600,1600,3200,6000].forEach(function(ms){setTimeout(function(){version();ownGlobals();syncButtons();},ms)});
})();
</script>"""
    def _v309_install(_html):
        _html = _v309_strip_adsb_owners(_html)
        _html = _v309_remove_script_block(_html, 'v309AdsbOwnerPatch')
        _html = _html.replace('</body>', _v309_script + '</body>') if '</body>' in _html else _html + _v309_script
        _html = _v309_versions(_html)
        return _html
    TAK_MAP_HTML = _v309_install(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v309_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v309_versions(LOGIN_HTML)
except Exception as _v309_exc:
    try: print('v309 ADS-B ownership reset failed:', _v309_exc)
    except Exception: pass
# --- end TAK Map v309 ADS-B ownership reset + Viewshed targeted patch ---


# --- TAK Map v310 ADS-B single-layer stable marker + tracking patch ---
try:
    import re as _v310_re
    def _v310_remove_script_block(_html, _sid):
        return _v310_re.sub(r'<script[^>]*id=["\']'+_v310_re.escape(_sid)+r'["\'][^>]*>.*?</script>\s*', '', _html, count=0, flags=_v310_re.S)
    def _v310_versions(_html):
        _html = _v310_re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v310</span>', _html)
        _html = _v310_re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v310</div>', _html)
        _html = _v310_re.sub(r'const\s+V\s*=\s*["\']v\d+["\']', "const V='v310'", _html)
        _html = _v310_re.sub(r'>v\d+<', '>v310<', _html)
        _html = _html.replace('TAK Server Dashboard</div><div class="version-row">', 'TAK Map</div><div class="version-row">')
        return _html
    _v310_script = r"""<script id="v310AdsbSingleLayerOwnerPatch">
(function(){
  'use strict';
  const V='v310';
  const CTL=window.TakMapControllers=window.TakMapControllers||{};
  const ADSB=CTL.adsb={version:V,markers:new Map(),data:new Map(),lastList:[],lastGoodAt:0,stable:new Map(),busy:false,refreshTimer:null,layer:null,tracking:{id:null,meta:null,points:[],line:null,label:null,layer:null,labelLayer:null}};
  const CLASS_PRIORITY={unknown:0,civil:1,govt:2,military:3};
  const STALE_MS=90000;
  const TRACK_COLOR='#ff6f2e';
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function byId(id){try{return document.getElementById(id)}catch(_){return null}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]})}
  function n(v){v=Number(v);return Number.isFinite(v)?v:null}
  function mapObj(){try{if(typeof map!=='undefined'&&map&&map.addLayer){window.map=map;window.takLeafletMap=map;return map}}catch(_){}try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(window.map&&window.map.addLayer){window.takLeafletMap=window.map;return window.map}}catch(_){}return null}
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flight))||'').trim().toLowerCase()}
  function titleOf(a,id){return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id))||id||'ADS-B Aircraft').trim()||'ADS-B Aircraft'}
  function blob(a){try{return [a&&a.category,a&&a.category_raw,a&&a.emitter_category,a&&a.adsb_category,a&&a.type,a&&a.aircraft_type,a&&a.description,a&&a.desc,a&&a.model,a&&a.t,a&&a.callsign,a&&a.flight,a&&a.registration,a&&a.owner_operator,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.source].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function evidenceClass(a){const b=blob(a);if(/\b(MILITARY|USAF|USN|USMC|ARMY|NAVY|AIR FORCE|COAST GUARD|AFSOC|RCH|REACH|VIPER)\b/.test(b)||/\bA-F-A\b/.test(b))return 'military';if(/\b(GOV|GOVT|GOVERNMENT|PUBLIC SAFETY|POLICE|SHERIFF|FIRE DEPT|FIRE DEPARTMENT|EMS|RESCUE|CHP|CAL FIRE|USFS|MEDICAL|HOSPITAL|RESPONSE|LAW ENFORCEMENT|LAPD|PD|FD)\b/.test(b))return 'govt';if(/\b(CIVIL|CIVILIAN|PRIVATE|BUSINESS|COMMERCIAL|AIRLINE|GENERAL AVIATION)\b/.test(b))return 'civil';return 'unknown'}
  function evidenceHelo(a){const b=blob(a);return /\b(HELICOPTER|HELI|HELO|ROTOR|ROTORCRAFT|ROTARY|GYRO)\b/.test(b)||/\b(R22|R44|R66|H60|UH60|MH60|SH60|HH60|CH47|AH64|AS50|AS350|EC35|EC45|EC135|EC145|B407|B412|S76|S92|BELL|ROBINSON|SIKORSKY|EUROCOPTER|AIRBUS HELICOPTERS)\b/.test(b)||/\bH[1-9]\b/.test(b)}
  function stableState(a){const id=idOf(a);let st=ADSB.stable.get(id);if(!st){st={id,shape:null,classKey:'unknown',lastSeen:0,iconPath:''};ADSB.stable.set(id,st)}st.lastSeen=Date.now();if(evidenceHelo(a))st.shape='helo';else if(!st.shape)st.shape='fixed';const c=evidenceClass(a);if(CLASS_PRIORITY[c]>CLASS_PRIORITY[st.classKey])st.classKey=c;else if(st.classKey==='unknown'&&c!=='unknown')st.classKey=c;return st}
  function iconPathForState(st){const cls=st.classKey==='military'?'mil':(st.classKey==='govt'?'gov':'civ');const shape=st.shape==='helo'?'helo':'fixed';return '/assets/adsb/adsb_'+cls+'_'+shape+'.png'}
  function iconPath(a){const st=stableState(a);st.iconPath=iconPathForState(st);return st.iconPath}
  function normalizeList(input){let arr=[];if(Array.isArray(input))arr=input;else if(input&&Array.isArray(input.aircraft))arr=input.aircraft;else if(window.lastAircraft&&Array.isArray(window.lastAircraft))arr=window.lastAircraft;return arr.map(function(a){a=Object.assign({},a||{});const lat=n(a.lat??a.latitude),lon=n(a.lon??a.lng??a.longitude);const id=idOf(a);if(!id||lat==null||lon==null)return null;a.id=id;a.lat=lat;a.lon=lon;return a}).filter(Boolean)}
  function filtered(input){return normalizeList(input).filter(function(a){return Number.isFinite(a.lat)&&Number.isFinite(a.lon)})}
  function ensureLayer(){const m=mapObj();if(!m||!window.L)return null;if(!ADSB.layer){try{if(typeof aircraftLayer!=='undefined'&&aircraftLayer&&aircraftLayer.addTo)ADSB.layer=aircraftLayer}catch(_){}if(!ADSB.layer)ADSB.layer=L.layerGroup()}try{if(!m.hasLayer(ADSB.layer))ADSB.layer.addTo(m)}catch(_){try{ADSB.layer.addTo(m)}catch(__){}}return ADSB.layer}
  function classLabel(k){return k==='military'?'Military':k==='govt'?'Govt':k==='civil'?'Civil':'Unknown'}
  function typeLabel(st){return st&&st.shape==='helo'?'Helicopter':'Fixed-wing'}
  function altText(a){const ft=n(a.alt_ft??a.altitude_ft??a.alt_baro);return ft==null?'—':Math.round(ft).toLocaleString()+' ft'}
  function rangeText(a){try{const m=mapObj();if(!m)return '—';const c=m.getCenter();const d=m.distance(c,[a.lat,a.lon])/1609.344;return Number.isFinite(d)?d.toFixed(1):'—'}catch(_){return '—'}}
  function markerHtml(a){const id=idOf(a),st=stableState(a),deg=n(a.track_deg??a.track??a.heading)||0,label=titleOf(a,id),path=iconPathForState(st);return '<div class="adsb-v310-hitbox" data-adsb-id="'+esc(id)+'"><img src="'+esc(path)+'" data-adsb-img="1" style="transform:rotate('+deg+'deg)" alt=""/><span class="aircraft-label">'+esc(label)+'</span></div>'}
  function iconFor(a){return L.divIcon({className:'adsb-v310-marker',iconSize:[96,60],iconAnchor:[48,24],popupAnchor:[0,-20],html:markerHtml(a)})}
  function trackButtonHtml(a){const id=idOf(a);const active=ADSB.tracking.id===id;return '<button type="button" class="layer-button adsb-track-btn '+(active?'active tracking':'')+'" data-adsb-track-id="'+esc(id)+'" aria-pressed="'+(active?'true':'false')+'" onclick="event.preventDefault();event.stopPropagation();return window.toggleAdsbTrack&&window.toggleAdsbTrack(this.dataset.adsbTrackId)"><span class="adsb-track-light '+(active?'active':'')+'"></span><span class="adsb-track-text">Track</span></button>'}
  function popupHtml(a){const id=idOf(a),st=stableState(a);return '<div class="adsb-popup v310" data-adsb-id="'+esc(id)+'"><h3>'+esc(titleOf(a,id))+'</h3><div class="kvp"><b>Class</b><span>'+esc(classLabel(st.classKey))+'</span><b>Type</b><span>'+esc(typeLabel(st))+'</span><b>Altitude</b><span>'+esc(altText(a))+'</span><b>Range</b><span>'+esc(rangeText(a))+' mi</span></div><div class="adsb-track-row">'+trackButtonHtml(a)+'</div></div>'}
  function updateMarkerDom(mk,a){const el=mk&&mk.getElement&&mk.getElement();if(!el)return false;const st=stableState(a);const img=q('[data-adsb-img]',el);const lab=q('.aircraft-label',el);const path=iconPathForState(st);const deg=n(a.track_deg??a.track??a.heading)||0;if(img){if(!String(img.getAttribute('src')||'').endsWith(path))img.setAttribute('src',path);img.style.transform='rotate('+deg+'deg)'}else return false;if(lab)lab.textContent=titleOf(a,idOf(a));return true}
  function publishMaps(){try{const obj={};ADSB.markers.forEach(function(v,k){obj[k]=v});window.v310AircraftLayersById=obj;window.v309AircraftLayersById=obj;window.v298AircraftLayersById=obj;window.v240AircraftLayersById=obj;window.v238AircraftLayersById=obj;window.v236AircraftLayersById=obj}catch(_){}}
  function renderAircraft(input){const layer=ensureLayer();if(!layer)return [];let rows=filtered(input);const now=Date.now();if(rows.length){ADSB.lastList=rows.slice();ADSB.lastGoodAt=now}else if(ADSB.lastList.length&&now-ADSB.lastGoodAt<120000){rows=ADSB.lastList.slice()}window.lastAircraft=rows;const seen=new Set();rows.forEach(function(a){const id=idOf(a);seen.add(id);ADSB.data.set(id,a);stableState(a);let mk=ADSB.markers.get(id);const ll=[a.lat,a.lon];if(!mk){mk=L.marker(ll,{icon:iconFor(a),zIndexOffset:900,interactive:true,riseOnHover:true}).addTo(layer);ADSB.markers.set(id,mk);mk.on('click',function(ev){try{L.DomEvent.stop(ev)}catch(_){}try{mk.openPopup();setTimeout(syncButtons,20)}catch(_){}});mk.on('mouseover',function(){try{mk.openPopup();setTimeout(syncButtons,20)}catch(_){}});mk.on('popupopen',function(){setTimeout(syncButtons,20)});}else{try{mk.setLatLng(ll)}catch(_){}if(!updateMarkerDom(mk,a)){try{mk.setIcon(iconFor(a))}catch(_){}}}try{mk._takAdsbId=id;mk._takAdsbAircraft=a;mk._adsbData=a;mk._v310LastSeen=now;if(mk.isPopupOpen&&mk.isPopupOpen())mk.setPopupContent(popupHtml(a));else mk.bindPopup(popupHtml(a),{className:'adsb-v310-popup adsb-object-popup',autoPan:false,closeButton:false})}catch(_){}if(ADSB.tracking.id===id)addTrackPoint(a)});ADSB.markers.forEach(function(mk,id){if(seen.has(id))return;const age=now-Number((mk&&mk._v310LastSeen)||0);if(age>STALE_MS){try{layer.removeLayer(mk)}catch(_){}ADSB.markers.delete(id);ADSB.data.delete(id)}});publishMaps();updateStatus(rows.length);syncButtons();return rows}
  async function refreshAdsb(){if(ADSB.busy)return ADSB.lastList;ADSB.busy=true;try{const r=await fetch('/api/tak-map/adsb',{cache:'no-store'});const j=await r.json();try{window.lastAdsbSettings=(j&&j.settings)||window.lastAdsbSettings}catch(_){}return renderAircraft((j&&j.aircraft)||[])}catch(e){console.warn('v310 ADS-B refresh failed',e);return renderAircraft([])}finally{ADSB.busy=false}}
  function updateStatus(count){try{const s=byId('adsbStatus');if(s)s.textContent=String(count||0)+' active'}catch(_){}try{const b=byId('bannerAdsb');if(b)b.textContent=String(count||0)+' Aircraft'}catch(_){} }
  function startPolling(){try{if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer);if(ADSB.refreshTimer)clearInterval(ADSB.refreshTimer);let sec=Number((byId('adsbUpdateInterval')||{}).value||((window.lastAdsbSettings||{}).update_interval_seconds)||5);if(!Number.isFinite(sec)||sec<1)sec=5;ADSB.refreshTimer=setInterval(refreshAdsb,sec*1000);window.adsbRefreshTimer=ADSB.refreshTimer;setTimeout(refreshAdsb,250)}catch(e){console.warn('v310 polling failed',e)}}
  function distMeters(pts){let d=0;try{const m=mapObj();for(let i=1;i<pts.length;i++)d+=m?m.distance([pts[i-1].lat,pts[i-1].lon],[pts[i].lat,pts[i].lon]):0}catch(_){}return d}
  function distText(m){return (m/1609.344).toFixed(1)+'mi/'+(m/1000).toFixed(1)+'km'}
  function ensureTrackLayers(){const m=mapObj();if(!m||!window.L)return false;if(!ADSB.tracking.layer)ADSB.tracking.layer=L.layerGroup().addTo(m);if(!ADSB.tracking.labelLayer)ADSB.tracking.labelLayer=L.layerGroup().addTo(m);return true}
  function clearTrackVisual(){const t=ADSB.tracking;try{if(t.layer)t.layer.clearLayers();if(t.labelLayer)t.labelLayer.clearLayers()}catch(_){}t.line=null;t.label=null}
  function redrawTrack(){const t=ADSB.tracking;if(!ensureTrackLayers())return;try{t.layer.clearLayers();t.labelLayer.clearLayers();const ll=t.points.map(function(p){return [p.lat,p.lon]}).filter(function(p){return Number.isFinite(p[0])&&Number.isFinite(p[1])});if(ll.length>=2)t.line=L.polyline(ll,{color:TRACK_COLOR,weight:4,opacity:.96,lineCap:'round',lineJoin:'round',interactive:false}).addTo(t.layer);if(ll.length){t.label=L.marker(ll[ll.length-1],{interactive:false,zIndexOffset:1800,icon:L.divIcon({className:'adsb-track-distance-label-wrap',iconSize:[1,1],iconAnchor:[0,0],html:'<div class="adsb-track-distance-label">'+esc(distText(distMeters(t.points)))+'</div>'})}).addTo(t.labelLayer)}}catch(e){console.warn('v310 redraw track failed',e)}}
  function addTrackPoint(a){if(!a||!ADSB.tracking.id)return;const id=idOf(a);if(id!==ADSB.tracking.id)return;const lat=n(a.lat),lon=n(a.lon);if(lat==null||lon==null)return;const pts=ADSB.tracking.points;const last=pts[pts.length-1];if(last&&Math.abs(last.lat-lat)<0.000001&&Math.abs(last.lon-lon)<0.000001)return;pts.push({lat,lon,t:Date.now(),alt_ft:a.alt_ft??a.altitude_ft??a.alt_baro??null});if(pts.length>3000)pts.splice(0,pts.length-3000);ADSB.tracking.meta=a;redrawTrack();syncButtons()}
  function syncButtons(){try{qa('.adsb-track-btn').forEach(function(btn){let id=String(btn.dataset.adsbTrackId||btn.getAttribute('data-adsb-track-id')||'').toLowerCase();const on=!!(ADSB.tracking.id&&id===ADSB.tracking.id);btn.classList.toggle('active',on);btn.classList.toggle('tracking',on);btn.dataset.adsbTracking=on?'1':'0';btn.setAttribute('aria-pressed',on?'true':'false');const l=q('.adsb-track-light',btn);if(l)l.classList.toggle('active',on)})}catch(_){}}
  function safeName(s){return String(s||'ADS-B Track').replace(/[\\/:*?"<>|]+/g,'-').replace(/\s+/g,' ').trim()||'ADS-B Track'}
  async function saveRoute(name,id,meta,pts,msg){const m=distMeters(pts);const coords=pts.map(function(p){return [p.lon,p.lat,p.alt_ft||0]});const fc={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:coords},properties:{name:name,kind:'route',route_type:'adsb_aircraft_track',source:'TAK Map ADS-B',hex:String(id||'').toUpperCase(),callsign:titleOf(meta,id),point_count:pts.length,distance_miles:Number((m/1609.344).toFixed(3)),distance_km:Number((m/1000).toFixed(3)),distance_text:distText(m)}}]};const file=new File([new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'})],safeName(name)+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});if(!r.ok)throw new Error('HTTP '+r.status);try{if(typeof refreshLocalData==='function')await refreshLocalData()}catch(_){}if(msg)msg.textContent='Saved to Local Data → Routes'}
  function closeSaveDialog(){const d=byId('adsbTrackSaveDialog');if(d)d.remove()}
  function showSaveDialog(id,meta,pts){try{closeSaveDialog();pts=(pts||[]).slice();const meters=distMeters(pts);const name=safeName(titleOf(meta,id)+' ADS-B Track '+new Date().toISOString().slice(0,19).replace(/[T:]/g,'-'));const can=pts.length>=2;const div=document.createElement('div');div.id='adsbTrackSaveDialog';div.className='adsb-track-save-overlay';div.innerHTML='<div class="adsb-track-save-card" role="dialog" aria-modal="true"><button type="button" class="adsb-track-save-x" data-action="discard">×</button><div class="adsb-track-save-title">Save ADS-B Track</div><div class="adsb-track-save-sub">'+esc(titleOf(meta,id))+' · '+esc(distText(meters))+' · '+esc(String(pts.length))+' pts</div><input id="adsbTrackRouteName" class="adsb-track-save-input" value="'+esc(name)+'" '+(can?'':'disabled')+' />'+(can?'':'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>')+'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div><div class="adsb-track-save-actions"><button type="button" class="layer-button" data-action="discard">Discard</button><button type="button" class="layer-button primary" data-action="save" '+(can?'':'disabled')+'>Save</button></div></div>';document.body.appendChild(div);div.addEventListener('click',function(ev){const a=ev.target&&ev.target.getAttribute&&ev.target.getAttribute('data-action');if(a==='discard'||ev.target===div){ev.preventDefault();closeSaveDialog();clearTrackVisual();return}if(a==='save'&&can){ev.preventDefault();const msg=byId('adsbTrackSaveMsg');if(msg)msg.textContent='Saving…';saveRoute((byId('adsbTrackRouteName')||{}).value||name,id,meta,pts,msg).then(function(){setTimeout(function(){closeSaveDialog();clearTrackVisual()},650)}).catch(function(e){if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}})}});setTimeout(function(){try{(byId('adsbTrackRouteName')||q('[data-action="discard"]',div)).focus()}catch(_){}},20)}catch(e){console.warn('v310 save dialog failed',e);clearTrackVisual()}}
  function toggleTrack(id){id=String(id||'').trim().toLowerCase();if(!id)return false;const t=ADSB.tracking;if(t.id===id){const pts=t.points.slice(),meta=t.meta||ADSB.data.get(id)||{id:id};t.id=null;t.meta=null;t.points=[];syncButtons();showSaveDialog(id,meta,pts);return false}clearTrackVisual();t.id=id;t.points=[];t.meta=ADSB.data.get(id)||{id:id};const a=ADSB.data.get(id);if(a)addTrackPoint(a);syncButtons();return false}
  function openAdsbDropdown(ev){try{const box=byId('statusDropdown');if(!box)return;const rows=ADSB.lastList.slice().sort(function(a,b){return titleOf(a).localeCompare(titleOf(b))});box.innerHTML='<div class="status-dropdown-title">ADS-B Aircraft</div><div class="status-adsb-head v310"><b>Aircraft</b><b>Class</b><b>Type</b><b>Alt</b><b>mi→Center</b></div>'+rows.map(function(a){const id=esc(idOf(a));const st=stableState(a);return '<button type="button" class="status-adsb-row v310" data-adsb-focus="'+id+'"><span>'+esc(titleOf(a,id))+'</span><span>'+esc(classLabel(st.classKey))+'</span><span>'+esc(st.shape==='helo'?'Heli':'Fixed')+'</span><span>'+esc(altText(a))+'</span><span>'+esc(rangeText(a))+'</span></button>'}).join('');box.classList.add('active');if(ev){const r=ev.currentTarget.getBoundingClientRect();box.style.left=Math.max(8,Math.min(window.innerWidth-360,r.left))+'px';box.style.top=Math.max(54,r.bottom+8)+'px';box.dataset.v310AdsbOpen='1'}}catch(_){} }
  function focusAircraft(id){try{id=decodeURIComponent(String(id||'')).toLowerCase();const a=ADSB.data.get(id);const mk=ADSB.markers.get(id);const m=mapObj();if(a&&m)m.setView([a.lat,a.lon],Math.max(m.getZoom(),13),{animate:true});if(mk)setTimeout(function(){try{mk.openPopup();syncButtons()}catch(_){}},150)}catch(_){} }
  function openViewshed(ev){try{if(ev){ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){}} if(typeof window.toggleViewshedModule==='function'){try{window.toggleViewshedModule(true)}catch(_){}}let panel=byId('viewshedModule')||byId('viewshedPanel')||q('.viewshed-module,.viewshed-panel,#viewshedControl,.viewshed-control');if(!panel){const candidates=qa('div,section,aside').filter(function(el){return /viewshed/i.test(String(el.id+' '+el.className+' '+(el.getAttribute('aria-label')||'')))});panel=candidates[0]||null}if(panel){panel.style.display='block';panel.style.visibility='visible';panel.style.opacity='1';panel.classList.add('active','open');panel.classList.remove('collapsed','minimized','hidden');const bar=byId('floatingToolbar')||q('.floating-toolbar');const bw=panel.offsetWidth||360,bh=panel.offsetHeight||420;let left=(window.innerWidth-bw-18),top=90;if(bar){const r=bar.getBoundingClientRect();left=r.left-bw-12;top=Math.max(72,r.top)}left=Math.max(8,Math.min(left,window.innerWidth-bw-8));top=Math.max(64,Math.min(top,window.innerHeight-bh-8));panel.style.position='fixed';panel.style.left=left+'px';panel.style.top=top+'px';panel.style.right='auto';panel.style.bottom='auto';panel.style.zIndex='4200'}}catch(e){console.warn('v310 Viewshed open failed',e)}}
  function ownGlobals(){window.refreshAdsb=refreshAdsb;window.drawAircraft=renderAircraft;window.aircraftIcon=iconFor;window.adsbPopupHtml=popupHtml;window.focusAdsbAircraft=focusAircraft;window.toggleAdsbTrack=toggleTrack;window.updateAdsbTrackPoint=addTrackPoint;window.syncAdsbTrackButtons=syncButtons;window.openTakMapViewshed=openViewshed;try{refreshAdsb=window.refreshAdsb;drawAircraft=window.drawAircraft;aircraftIcon=window.aircraftIcon;adsbPopupHtml=window.adsbPopupHtml;focusAdsbAircraft=window.focusAdsbAircraft}catch(_){} }
  function addCss(){if(byId('v310AdsbViewshedStyle'))return;const st=document.createElement('style');st.id='v310AdsbViewshedStyle';st.textContent='.adsb-v310-marker{background:transparent!important;border:0!important}.adsb-v310-hitbox{width:96px;height:60px;display:flex;align-items:center;justify-content:center;position:relative;pointer-events:auto}.adsb-v310-hitbox img{width:42px;height:42px;object-fit:contain;display:block;pointer-events:none}.adsb-v310-hitbox .aircraft-label{position:absolute;left:50%;top:43px;transform:translateX(-50%);background:rgba(5,8,12,.86);border:1px solid rgba(255,255,255,.12);border-radius:999px;color:#eaf2f5;font-size:10px;font-weight:900;padding:2px 6px;white-space:nowrap}.adsb-track-btn.active,.adsb-track-btn.tracking,.adsb-track-btn[data-adsb-tracking="1"]{color:#fff!important;border-color:rgba(255,90,70,.95)!important;background:linear-gradient(180deg,rgba(255,59,48,.40),rgba(120,20,16,.34))!important;box-shadow:0 0 12px rgba(255,59,48,.34)!important}.adsb-track-light{display:inline-block;width:8px;height:8px;border-radius:50%;background:#44515a;margin-right:6px}.adsb-track-light.active{background:#ff3b30!important;box-shadow:0 0 10px rgba(255,59,40,.9)}.adsb-track-distance-label{background:rgba(8,12,16,.92);border:1px solid rgba(255,111,46,.80);border-radius:999px;color:#ffe4d4;box-shadow:0 6px 18px rgba(0,0,0,.38),0 0 14px rgba(255,111,46,.22);font-size:11px;font-weight:900;letter-spacing:.02em;line-height:1;padding:3px 7px;white-space:nowrap}.adsb-track-save-overlay{position:fixed;inset:0;z-index:4300;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.42);backdrop-filter:blur(3px)}.adsb-track-save-card{position:relative;width:min(420px,calc(100vw - 28px));border:1px solid rgba(255,122,26,.42);border-radius:14px;background:linear-gradient(180deg,rgba(18,27,35,.98),rgba(8,12,18,.98));box-shadow:0 18px 50px rgba(0,0,0,.60),0 0 22px rgba(255,122,26,.13);padding:13px 14px 12px;color:#eef5f7}.adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;font-size:18px;font-weight:900}.adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px}.adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750}.adsb-track-save-input{width:100%;box-sizing:border-box;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750}.adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850}.adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850}.adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px}.status-adsb-head.v310,.status-adsb-row.v310{display:grid;grid-template-columns:minmax(112px,1.5fr) 72px 62px 82px 92px;gap:8px;align-items:center}.status-adsb-row.v310{width:100%;border:0;border-top:1px solid rgba(255,255,255,.07);background:transparent;color:inherit;text-align:left;padding:7px 4px}.status-adsb-row.v310:hover{background:rgba(255,111,46,.10)}';document.head.appendChild(st)}
  function version(){try{qa('.iteration-chip,.iteration-marker').forEach(function(el){el.textContent=V});qa('.version-product,.sidebar-version-title').forEach(function(el){if(/dashboard/i.test(el.textContent||''))el.textContent='TAK Map'})}catch(_){} }
  function boot(){addCss();version();ownGlobals();startPolling();renderAircraft(ADSB.lastList.length?ADSB.lastList:(Array.isArray(window.lastAircraft)?window.lastAircraft:[]));}
  window.addEventListener('click',function(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(btn){ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation();toggleTrack(btn.dataset.adsbTrackId||btn.getAttribute('data-adsb-track-id')||'');return false}const foc=ev.target&&ev.target.closest&&ev.target.closest('[data-adsb-focus]');if(foc){ev.preventDefault();focusAircraft(foc.dataset.adsbFocus)}const adsbBtn=ev.target&&ev.target.closest&&ev.target.closest('#bannerAdsbItem');if(adsbBtn){ev.preventDefault();ev.stopPropagation();ev.stopImmediatePropagation();const box=byId('statusDropdown');if(box&&box.classList.contains('active')&&box.dataset.v310AdsbOpen==='1'){box.classList.remove('active');box.dataset.v310AdsbOpen='0'}else{openAdsbDropdown(ev)}}const vs=ev.target&&ev.target.closest&&ev.target.closest('#toolViewshed,[data-tool="viewshed"],button[title="Viewshed"],button[onclick*="Viewshed"]');if(vs)return openViewshed(ev)},true);
  document.addEventListener('keydown',function(ev){if(ev.key==='Escape'){const box=byId('statusDropdown');if(box){box.classList.remove('active');box.dataset.v310AdsbOpen='0'}}});
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',function(){setTimeout(boot,160)},{once:true});else setTimeout(boot,160);
  [600,1600,3200,6000].forEach(function(ms){setTimeout(function(){version();ownGlobals();syncButtons();},ms)});
})();
</script>"""
    def _v310_install(_html):
        _html = _v310_remove_script_block(_html, 'v309AdsbOwnerPatch')
        _html = _v310_remove_script_block(_html, 'v308ViewshedOpenPatch')
        _html = _html.replace('ADS-B is owned by v309AdsbOwnerPatch', 'ADS-B is owned by v310AdsbSingleLayerOwnerPatch')
        _html = _html.replace('window.refreshAdsb=async function(){return []}', 'window.v310RemovedLegacyRefreshAdsb=async function(){return []}')
        _html = _html.replace('</body>', _v310_script + '</body>') if '</body>' in _html else _html + _v310_script
        return _v310_versions(_html)
    TAK_MAP_HTML = _v310_install(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v310_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v310_versions(LOGIN_HTML)
except Exception as _v310_exc:
    try: print('v310 ADS-B stable single-layer patch failed:', _v310_exc)
    except Exception: pass
# --- end TAK Map v310 ADS-B single-layer stable marker + tracking patch ---

# --- TAK Map v311 ADS-B empty-refresh guard + track pointer fix + safe map binding ---
try:
    import re as _v311_re
    def _v311_versions(_html):
        _html = _v311_re.sub(r"const V='v\d+'", "const V='v311'", _html)
        _html = _html.replace('iteration-chip">v310', 'iteration-chip">v311')
        _html = _html.replace('iteration-marker">v310', 'iteration-marker">v311')
        _html = _html.replace('tak-map-version">v310', 'tak-map-version">v311')
        _html = _html.replace('>v310<', '>v311<')
        _html = _html.replace('_v310LastSeen', '_v311LastSeen')
        _html = _html.replace('v310RemovedLegacyRefreshAdsb', 'v311RemovedLegacyRefreshAdsb')
        return _html
    def _v311_remove_script_block(_html, _script_id):
        return _v311_re.sub(r'\n?<script id="' + _v311_re.escape(_script_id) + r'">.*?</script>', '', _html, flags=_v311_re.S)
    def _v311_safe_map_bindings(_html):
        _html = _html.replace(
            "if(window.map&&map.on)map.on('popupopen',ev=>setTimeout(()=>cleanPopup(ev.popup&&ev.popup.getElement&&ev.popup.getElement()),0));",
            "const m=(window.takLeafletMap||window.map);if(m&&m.on)m.on('popupopen',ev=>setTimeout(()=>cleanPopup(ev.popup&&ev.popup.getElement&&ev.popup.getElement()),0));"
        )
        _html = _html.replace(
            "try{forcePopupClose=true; if(window.map&&popup) map.closePopup(popup); else if(window.map) map.closePopup();}",
            "try{forcePopupClose=true; const m=(window.takLeafletMap||window.map); if(m&&popup) m.closePopup(popup); else if(m) m.closePopup();}"
        )
        _old = """function bindMap(){
    try{
      if(!window.map || window._v283MapPopupBound) return;
      window._v283MapPopupBound=true;
      map.on('popupopen',ev=>{
        try{if(activePopup && activePopup!==ev.popup) closePopupSafe(activePopup);}catch(_){ }
        activePopup=ev.popup;
        setTimeout(()=>bindPopupProtection(ev.popup),0);
      });
      map.on('popupclose',ev=>{try{if(activePopup===ev.popup) activePopup=null;}catch(_){ }});
      map.on('click',()=>{try{closePopupSafe(activePopup);}catch(_){ }});
    }catch(_){ }
  }"""
        _new = """function bindMap(){
    try{
      const m=(window.takLeafletMap||window.map);
      if(!m || !m.on || window._v283MapPopupBound) return;
      window._v283MapPopupBound=true;
      m.on('popupopen',ev=>{
        try{if(activePopup && activePopup!==ev.popup) closePopupSafe(activePopup);}catch(_){ }
        activePopup=ev.popup;
        setTimeout(()=>bindPopupProtection(ev.popup),0);
      });
      m.on('popupclose',ev=>{try{if(activePopup===ev.popup) activePopup=null;}catch(_){ }});
      m.on('click',()=>{try{closePopupSafe(activePopup);}catch(_){ }});
    }catch(e){try{console.warn('v311 safe popup map bind skipped',e)}catch(_){}}
  }"""
        _html = _html.replace(_old, _new)
        return _html
    _v311_script = '<script id="v311AdsbSingleLayerOwnerPatch">' + '\n\n(function(){\n  \'use strict\';\n  const V=\'v311\';\n  const CTL=window.TakMapControllers=window.TakMapControllers||{};\n  const ADSB=CTL.adsb={version:V,markers:new Map(),data:new Map(),lastList:[],lastGoodAt:0,stable:new Map(),busy:false,refreshTimer:null,layer:null,tracking:{id:null,meta:null,points:[],line:null,label:null,layer:null,labelLayer:null}};\n  const CLASS_PRIORITY={unknown:0,civil:1,govt:2,military:3};\n  const STALE_MS=90000;\n  const TRACK_COLOR=\'#ff6f2e\';\n  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}\n  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}\n  function byId(id){try{return document.getElementById(id)}catch(_){return null}}\n  function esc(s){return String(s==null?\'\':s).replace(/[&<>"\']/g,function(c){return {\'&\':\'&amp;\',\'<\':\'&lt;\',\'>\':\'&gt;\',\'"\':\'&quot;\',"\'":\'&#39;\'}[c]})}\n  function n(v){v=Number(v);return Number.isFinite(v)?v:null}\n  function mapObj(){try{if(typeof map!==\'undefined\'&&map&&map.addLayer){window.map=map;window.takLeafletMap=map;return map}}catch(_){}try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(window.map&&window.map.addLayer){window.takLeafletMap=window.map;return window.map}}catch(_){}return null}\n  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flight))||\'\').trim().toLowerCase()}\n  function titleOf(a,id){return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id))||id||\'ADS-B Aircraft\').trim()||\'ADS-B Aircraft\'}\n  function blob(a){try{return [a&&a.category,a&&a.category_raw,a&&a.emitter_category,a&&a.adsb_category,a&&a.type,a&&a.aircraft_type,a&&a.description,a&&a.desc,a&&a.model,a&&a.t,a&&a.callsign,a&&a.flight,a&&a.registration,a&&a.owner_operator,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.source].filter(Boolean).join(\' \').toUpperCase()}catch(_){return \'\'}}\n  function evidenceClass(a){const b=blob(a);if(/\\b(MILITARY|USAF|USN|USMC|ARMY|NAVY|AIR FORCE|COAST GUARD|AFSOC|RCH|REACH|VIPER)\\b/.test(b)||/\\bA-F-A\\b/.test(b))return \'military\';if(/\\b(GOV|GOVT|GOVERNMENT|PUBLIC SAFETY|POLICE|SHERIFF|FIRE DEPT|FIRE DEPARTMENT|EMS|RESCUE|CHP|CAL FIRE|USFS|MEDICAL|HOSPITAL|RESPONSE|LAW ENFORCEMENT|LAPD|PD|FD)\\b/.test(b))return \'govt\';if(/\\b(CIVIL|CIVILIAN|PRIVATE|BUSINESS|COMMERCIAL|AIRLINE|GENERAL AVIATION)\\b/.test(b))return \'civil\';return \'unknown\'}\n  function evidenceHelo(a){const b=blob(a);return /\\b(HELICOPTER|HELI|HELO|ROTOR|ROTORCRAFT|ROTARY|GYRO)\\b/.test(b)||/\\b(R22|R44|R66|H60|UH60|MH60|SH60|HH60|CH47|AH64|AS50|AS350|EC35|EC45|EC135|EC145|B407|B412|S76|S92|BELL|ROBINSON|SIKORSKY|EUROCOPTER|AIRBUS HELICOPTERS)\\b/.test(b)||/\\bH[1-9]\\b/.test(b)}\n  function stableState(a){const id=idOf(a);let st=ADSB.stable.get(id);if(!st){st={id,shape:null,classKey:\'unknown\',lastSeen:0,iconPath:\'\'};ADSB.stable.set(id,st)}st.lastSeen=Date.now();if(evidenceHelo(a))st.shape=\'helo\';else if(!st.shape)st.shape=\'fixed\';const c=evidenceClass(a);if(CLASS_PRIORITY[c]>CLASS_PRIORITY[st.classKey])st.classKey=c;else if(st.classKey===\'unknown\'&&c!==\'unknown\')st.classKey=c;return st}\n  function iconPathForState(st){const cls=st.classKey===\'military\'?\'mil\':(st.classKey===\'govt\'?\'gov\':\'civ\');const shape=st.shape===\'helo\'?\'helo\':\'fixed\';return \'/assets/adsb/adsb_\'+cls+\'_\'+shape+\'.png\'}\n  function iconPath(a){const st=stableState(a);st.iconPath=iconPathForState(st);return st.iconPath}\n  function normalizeList(input){let arr=[];if(Array.isArray(input))arr=input;else if(input&&Array.isArray(input.aircraft))arr=input.aircraft;else if(window.lastAircraft&&Array.isArray(window.lastAircraft))arr=window.lastAircraft;return arr.map(function(a){a=Object.assign({},a||{});const lat=n(a.lat??a.latitude),lon=n(a.lon??a.lng??a.longitude);const id=idOf(a);if(!id||lat==null||lon==null)return null;a.id=id;a.lat=lat;a.lon=lon;return a}).filter(Boolean)}\n  function filtered(input){return normalizeList(input).filter(function(a){return Number.isFinite(a.lat)&&Number.isFinite(a.lon)})}\n  function ensureLayer(){const m=mapObj();if(!m||!window.L)return null;if(!ADSB.layer){try{if(typeof aircraftLayer!==\'undefined\'&&aircraftLayer&&aircraftLayer.addTo)ADSB.layer=aircraftLayer}catch(_){}if(!ADSB.layer)ADSB.layer=L.layerGroup()}try{if(!m.hasLayer(ADSB.layer))ADSB.layer.addTo(m)}catch(_){try{ADSB.layer.addTo(m)}catch(__){}}return ADSB.layer}\n  function classLabel(k){return k===\'military\'?\'Military\':k===\'govt\'?\'Govt\':k===\'civil\'?\'Civil\':\'Unknown\'}\n  function typeLabel(st){return st&&st.shape===\'helo\'?\'Helicopter\':\'Fixed-wing\'}\n  function altText(a){const ft=n(a.alt_ft??a.altitude_ft??a.alt_baro);return ft==null?\'—\':Math.round(ft).toLocaleString()+\' ft\'}\n  function rangeText(a){try{const m=mapObj();if(!m)return \'—\';const c=m.getCenter();const d=m.distance(c,[a.lat,a.lon])/1609.344;return Number.isFinite(d)?d.toFixed(1):\'—\'}catch(_){return \'—\'}}\n  function markerHtml(a){const id=idOf(a),st=stableState(a),deg=n(a.track_deg??a.track??a.heading)||0,label=titleOf(a,id),path=iconPathForState(st);return \'<div class="adsb-v311-hitbox" data-adsb-id="\'+esc(id)+\'"><img src="\'+esc(path)+\'" data-adsb-img="1" style="transform:rotate(\'+deg+\'deg)" alt=""/><span class="aircraft-label">\'+esc(label)+\'</span></div>\'}\n  function iconFor(a){return L.divIcon({className:\'adsb-v311-marker\',iconSize:[96,60],iconAnchor:[48,24],popupAnchor:[0,-20],html:markerHtml(a)})}\n  function trackButtonHtml(a){const id=idOf(a);const active=ADSB.tracking.id===id;return \'<button type="button" class="layer-button adsb-track-btn \'+(active?\'active tracking\':\'\')+\'" data-adsb-track-id="\'+esc(id)+\'" aria-pressed="\'+(active?\'true\':\'false\')+\'" onclick="event.preventDefault();event.stopPropagation();retur