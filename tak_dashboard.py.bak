  function css(){if(q('#v307AdsbTrackStyle'))return;const st=document.createElement('style');st.id='v307AdsbTrackStyle';st.textContent=`
    .adsb-track-btn.v307-active,.adsb-track-btn.active,.adsb-track-btn.tracking,.adsb-track-btn[data-adsb-tracking="1"]{color:#fff!important;border-color:rgba(255,75,55,.98)!important;background:linear-gradient(180deg,rgba(255,60,45,.48),rgba(128,20,16,.40))!important;box-shadow:0 0 13px rgba(255,60,45,.34)!important;}
