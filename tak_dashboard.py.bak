/* v228 TAK Map floating toolbar, semi-transparent HUD, and measurement tools */
.zoom-indicator{position:fixed!important;right:14px!important;top:64px!important;z-index:850!important;display:inline-flex!important;align-items:center!important;justify-content:center!important;gap:7px!important;width:max-content!important;min-width:0!important;max-width:360px!important;height:42px!important;padding:0 16px!important;border:1px solid rgba(255,255,255,.10)!important;border-radius:16px!important;background:rgba(8,13,18,.90)!important;color:#d7e1e8!important;font-size:.76rem!important;font-weight:850!important;letter-spacing:.02em!important;text-align:center!important;white-space:nowrap!important;overflow:hidden!important;box-shadow:0 14px 34px rgba(0,0,0,.34)!important;backdrop-filter:none!important;text-shadow:none!important}.zoom-indicator::before{content:''!important;display:inline-block!important;width:9px!important;height:9px!important;margin-right:0!important;border-radius:999px!important;background:var(--good)!important;box-shadow:0 0 8px rgba(57,217,138,.78)!important;flex:0 0 auto!important}.local-actions{display:block!important;position:relative!important;bottom:auto!important;margin:0 8px 8px!important;border:1px solid rgba(53,69,86,.88)!important;border-radius:12px!important;background:rgba(9,16,24,.82)!important;padding:8px!important}.local-actions-top{display:block!important;margin:0 0 6px!important}.local-actions-top .chip{display:none!important}.local-actions .local-selected-count{font-size:.72rem!important;color:var(--muted)!important}.local-action-buttons{display:flex!important;justify-content:flex-start!important;align-items:center!important;flex-wrap:nowrap!important;gap:4px!important}.local-action-buttons .layer-button,.local-actions .layer-button{padding:4px 5px!important;font-size:.62rem!important;line-height:1.05!important;white-space:nowrap!important;min-width:0!important}.floating-toolbar-dock{position:fixed;right:14px;top:154px;z-index:875;display:flex;align-items:flex-start;gap:8px;user-select:none}.floating-map-toolbar,.map-mini-toolbar{border:1px solid rgba(53,69,86,.95);border-radius:14px;background:rgba(6,10,14,.90);box-shadow:0 18px 42px rgba(0,0,0,.46);padding:5px}.floating-map-toolbar{width:46px}.map-mini-toolbar{display:none;width:46px}.map-mini-toolbar.active{display:block}.toolbar-grip{height:14px;display:grid;place-items:center;color:#617680;font-size:16px;line-height:1;cursor:grab}.toolbar-grip:active{cursor:grabbing}.tool-btn{position:relative;width:34px;height:34px;margin:4px auto;display:grid;place-items:center;color:#9aaab1;background:#121d25;border:1px solid #334553;border-radius:10px;cursor:pointer;padding:0}.tool-btn svg{width:21px;height:21px;stroke:currentColor;fill:none;stroke-width:2.1;stroke-linecap:round;stroke-linejoin:round}.tool-btn:hover{border-color:#5b707a;background:#17252d;color:#c7d1d7}.tool-btn.active{border-color:#6c8089;background:rgba(155,170,178,.10);color:#d0d9de;box-shadow:0 0 0 1px rgba(200,213,219,.06),0 0 12px rgba(160,178,187,.08)}.tool-label{position:absolute;right:44px;top:50%;transform:translateY(-50%);background:rgba(6,10,14,.94);border:1px solid rgba(53,69,86,.9);border-radius:10px;padding:5px 8px;color:var(--text);font-size:.66rem;white-space:nowrap;opacity:0;pointer-events:none;transition:.12s ease}.tool-btn:hover .tool-label{opacity:1}.map-mini-toolbar .tool-label{right:44px}.map-tool-readout{display:none;position:fixed;top:112px;left:calc(396px + (100vw - 396px)/2);transform:translateX(-50%);z-index:865;align-items:center;gap:10px;padding:9px 13px;border:1px solid rgba(111,131,139,.60);border-radius:13px;background:rgba(6,10,14,.90);box-shadow:0 14px 34px rgba(0,0,0,.42);color:#c7d1d7;font-size:.76rem;font-weight:900;white-space:nowrap}.map-tool-readout.active{display:flex}.map-tool-readout .mode{color:#9aaab1;text-transform:uppercase;letter-spacing:.08em;font-size:.64rem}.map-tool-readout .pinned{color:#d4dde2;border-left:1px solid rgba(255,255,255,.14);padding-left:10px}.sidebar.collapsed~.map-tool-readout{left:50%}.measure-seg-label{border:1px solid rgba(155,170,178,.45);border-radius:999px;background:rgba(6,10,14,.82);color:#c6d0d5;font-size:.66rem;font-weight:850;padding:3px 6px;white-space:nowrap;box-shadow:0 8px 18px rgba(0,0,0,.32);opacity:.90}.measure-point-dot{width:12px;height:12px;border-radius:999px;background:#bac5ca;border:2px solid #071014;box-shadow:0 0 8px rgba(0,0,0,.5)}.measure-popup-box{width:248px;border:1px solid rgba(111,131,139,.56);border-radius:14px;background:rgba(6,10,14,.88);box-shadow:0 16px 38px rgba(0,0,0,.40);padding:10px;font-size:.72rem;color:#c7d1d7}.measure-popup-box h3{margin:0 0 7px;color:#d0d9de;font-size:.76rem;text-transform:uppercase;letter-spacing:.07em}.measure-popup-row{display:flex;justify-content:space-between;gap:8px;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.06);color:var(--muted)}.measure-popup-row b{color:#d2dce1}.measure-popup-total{margin-top:7px;padding-top:7px;border-top:1px solid rgba(155,170,178,.25);color:#d2dce1;font-weight:900}.toolbar-3d-placeholder{opacity:.92}
