      .leaflet-popup.adsb-v318-popup .leaflet-popup-content-wrapper,.leaflet-popup.adsb-object-popup .leaflet-popup-content-wrapper{background:linear-gradient(180deg,rgba(10,16,23,.96),rgba(4,8,13,.98))!important;border:1px solid rgba(255,255,255,.15)!important;border-radius:14px!important;box-shadow:0 18px 44px rgba(0,0,0,.58),0 0 24px rgba(255,111,46,.08)!important;backdrop-filter:blur(10px)!important;}
      .leaflet-popup.adsb-v318-popup .leaflet-popup-content{margin:0!important;min-width:300px!important;max-width:340px!important;}
