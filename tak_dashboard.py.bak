  }
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign))||'').trim().toLowerCase()}
  function titleOf(a){return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.id))||'ADS-B').trim()||'ADS-B'}
  function cleanFileName(s){return String(s||'ADS-B Track').replace(/[\/:*?"<>|]+/g,'-').replace(/\s+/g,' ').trim()||'ADS-B Track'}
  function aircraftList(){try{return (Array.isArray(window._v296StableAdsb)?window._v296StableAdsb:(Array.isArray(window._v294StableAdsb)?window._v294StableAdsb:(Array.isArray(window.lastAircraft)?window.lastAircraft:[]))).filter(Boolean)}catch(_){return []}}
  function findAircraft(id){id=String(id||'').toLowerCase();return aircraftList().find(a=>idOf(a)===id)||null}
  function asPoint(a){const lat=Number(a&&a.lat),lon=Number(a&&a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return null;return {lat:lat,lon:lon,alt:Number(a.altitude_ft??a.alt_baro??a.alt_geom)||0,t:Date.now()}}
  function rad(x){return x*Math.PI/180}
