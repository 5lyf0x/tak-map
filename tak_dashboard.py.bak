# --- v264 split-package role patch ---
# Release label remains 1.1.0; iteration marker is v264.
APP_ROLE = os.environ.get('TAK_DASH_APP_ROLE', 'map').strip().lower() or 'map'
try:
    # Remove cross-links between the split Dashboard and TAK Map packages.
    INDEX_HTML = INDEX_HTML.replace('<button class="privacy-toggle tak-map-top-btn" onclick="location.href=\'/tak-map/login\'">TAK Map</button>', '')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('<div class="brand">TAK Server Dashboard</div><a href="/">Return to Dashboard</a>', '<div class="brand">TAK Map</div>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace('<a href="/">Dashboard</a>', '')
    # Normalize visible iteration markers after the split.
    for _old in ('v263','v262','v261','v260','v259','v258','v257','v256','v255','v254','v253','v252','v251','v250','v249','v248','v247','v246','v245','v244','v243','v242','v241','v240','v239','v238','v236'):
        TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class="iteration-chip">{_old}</span>', '<span class="iteration-chip">v301</span>')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
        LOGIN_HTML = LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="login-version-marker"><span>v1.1.0</span><span>v264</span></div>')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="login-version-marker"><span>v1.1.0</span><span>v264</span></div>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace("const V='v301';", "const V='v301';")
    TAK_MAP_HTML = TAK_MAP_HTML.replace("console.warn('v263 boot failed',e)", "console.warn('v264 boot failed',e)")
except Exception as _split_html_e:
    print('v264 split HTML patch warning:', _split_html_e)

_v264_orig_get = Handler.do_GET
_v264_orig_post = Handler.do_POST

def _v264_is_takmap_path(path):
    return path == '/tak-map' or path == '/tak-map/login' or path.startswith('/api/tak-map/')

def _v264_split_get(self):
    parsed = urlparse(self.path)
    if APP_ROLE == 'dashboard':
        if _v264_is_takmap_path(parsed.path):
            if parsed.path.startswith('/api/'):
                return self._send_json({'ok': False, 'error': 'TAK Map is installed as a separate package/service.'}, 404)
            self.send_response(404); self.send_header('Content-Type','text/plain; charset=utf-8'); self.end_headers(); self.wfile.write(b'TAK Map is installed as a separate package/service.'); return
        return _v264_orig_get(self)
    if APP_ROLE == 'map':
        if parsed.path in ('/', '/index.html'):
            return self._redirect('/tak-map')
        if parsed.path == '/login':
            return self._redirect('/tak-map/login')
        return _v264_orig_get(self)
    return _v264_orig_get(self)

def _v264_split_post(self):
    parsed = urlparse(self.path)
    if APP_ROLE == 'dashboard' and parsed.path.startswith('/api/tak-map/'):
        return self._send_json({'ok': False, 'error': 'TAK Map is installed as a separate package/service.'}, 404)
    if APP_ROLE == 'map':
        # Convenience aliases for map-only deployments; the TAK Map UI still uses /api/tak-map/*.
        if parsed.path == '/api/login':
            return self._handle_tak_map_login()
        if parsed.path == '/api/logout':
            return self._handle_tak_map_logout()
    return _v264_orig_post(self)

Handler.do_GET = _v264_split_get
Handler.do_POST = _v264_split_post
# --- end v264 split-package role patch ---


# --- v266 split TAK Map cert setup + ADS-B control refinements ---
# Release label remains 1.1.0; iteration marker is v266.
def _v266_adsb_ots_job_control(action, session=None):
    action=str(action or '').strip().lower()
    if action not in ('disable','enable'):
        return {'ok':False,'error':'Invalid ADS-B OTS job action.'}
    out={'ok':False,'action':action,'attempted':True,'job_id':'','message':'','attempts':[]}
    try:
        api=_v245_login_ots_api(session, timeout_seconds=20)
        if not api.get('ok'):
            out['message']='OTS ADS-B job control failed: '+str(api.get('error') or 'OTS API login failed.')[:400]
            return out
        jobs, resp=_v245_list_scheduler_jobs(api)
        if jobs is None:
            out['message']='OTS ADS-B job control failed: could not list scheduler jobs.'
            out['attempts'].append({'step':'list_jobs','ok':False,'error':str(resp.get('error') or resp)[:500]})
            return out
        job=_v244_find_adsb_scheduler_job(jobs)
        if not job:
            out['message']='OTS ADS-B job control failed: Airplanes.live/ADS-B scheduled job was not found.'
            out['jobs_seen']=len(jobs)
            return out
        jid=_v244_job_id(job)
        out['job_id']=jid
        if not jid:
            out['message']='OTS ADS-B job control failed: ADS-B scheduler job has no id/name.'
            return out
        if action=='disable':
            attempts=[
                ('/scheduler/job/disable', {'job_id':jid}),
                ('/scheduler/job/pause', {'job_id':jid}),
                ('/scheduler/job/modify', {'job_id':jid,'enabled':False,'active':False,'disabled':True}),
            ]
        else:
            attempts=[
                ('/scheduler/job/enable', {'job_id':jid}),
                ('/scheduler/job/resume', {'job_id':jid}),
                ('/scheduler/job/modify', {'job_id':jid,'enabled':True,'active':True,'disabled':False}),
            ]
        for path,payload in attempts:
            r=_v244_ots_api_request(api,path,method='POST',payload=payload,timeout=18)
            out['attempts'].append({'path':path,'ok':bool(r.get('ok')),'status':r.get('status'),'error':str(r.get('error') or '')[:300]})
            if r.get('ok'):
                out['ok']=True
                out['message']='OTS ADS-B scheduler job '+('disabled' if action=='disable' else 'enabled')+'.'
                return out
        out['message']='OTS ADS-B job control did not confirm. Scheduler API may not support pause/disable on this OpenTAKServer version.'
        return out
    except Exception as e:
        out['message']='OTS ADS-B job control failed: '+str(e)
        out['traceback']=traceback.format_exc()[-1200:]
        return out

_v266_prev_get = Handler.do_GET
_v266_prev_post = Handler.do_POST

def _v266_map_get(self):
    parsed=urlparse(self.path)
    if APP_ROLE == 'map':
        if parsed.path == '/api/cert-status':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(get_cert_status())
        if parsed.path == '/ca-cert.crt':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            if not CA_CERT_FILE.exists():
                return self._send_json({'ok':False,'error':'CA certificate has not been generated yet.'},404)
            body=CA_CERT_FILE.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/x-x509-ca-cert'); self.send_header('Content-Disposition','attachment; filename="tak-local-ca.crt"'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
    return _v266_prev_get(self)

def _v266_map_post(self):
    parsed=urlparse(self.path)
    if APP_ROLE == 'map':
        if parsed.path == '/api/cert-setup':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            f=self._read_form(); extra=str(f.get('extra_sans',''))[:1000]; exclude=str(f.get('exclude_sans',''))[:1000]
            cmd=['sudo','/usr/local/sbin/tak-map-action','cert-setup',extra,exclude]
            r=run_cmd(cmd,60); r['command']='Generate TAK Map local HTTPS certificate'; return self._send_json(r)
        if parsed.path == '/api/tak-map/adsb-ots-job':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            payload=_read_json_body(self)
            return self._send_json(_v266_adsb_ots_job_control(payload.get('action'), self._tak_map_session()))
    return _v266_prev_post(self)

Handler.do_GET = _v266_map_get
Handler.do_POST = _v266_map_post

TAK_MAP_HTML = TAK_MAP_HTML.replace('<a href="/">Dashboard</a>', '')
for _old in ('v264','v263','v262','v261','v260','v259','v258','v257','v256','v255','v254','v253','v252','v251','v250','v249','v248','v247','v246','v245','v244','v243','v242','v241','v240','v239','v238','v236'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
