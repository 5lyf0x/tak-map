      const title=(q('.adsb-popup h3,.feature-popup h3',el)?.textContent||'').trim().toLowerCase();
      if(title){return normalizeAircraft(list.find(a=>String(a.callsign||a.registration||a.hex||a.id||'').trim().toLowerCase()===title)||null);}
