_v279_js = '/* v279: single-owner ADS-B menu + hard legacy ADS-B suppression */\n(function(){\n  const V=\'v279\';\n  const KEY=\'takmap.adsb.localDisabled\';\n  const $=id=>document.getElementById(id);\n  const qs=(s,r=document)=>r.querySelector(s);\n  const qsa=(s,r=document)=>Array.from(r.querySelectorAll(s));\n  const esc=s=>String(s==null?\'\':s).replace(/[&<>"\']/g,c=>({\'&\':\'&amp;\',\'<\':\'&lt;\',\'>\':\'&gt;\',\'"\':\'&quot;\',"\'":\'&#39;\'}[c]));\n  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};\n  let enabled=false, pollTimer=0, pollBusy=false, pollDebounce=0, workerSeq=0, interactionUntil=0;\n\n  function addCss(){try{if($(\'v279Style\'))return;document.head.insertAdjacentHTML(\'beforeend\',`<style id="v279Style">\n    .panel[data-collapse-key="adsbSettings"] .panel-body{contain:layout style!important;}\n    #adsbV279Menu{display:flex!important;flex-direction:column!important;gap:8px!important;margin:0!important;padding:0!important;min-width:0!important;}\n    #adsbV279Menu label{display:flex!important;flex-direction:column!important;gap:4px!important;margin:0!important;color:#aebfc6!important;font-size:.69rem!important;font-weight:850!important;text-transform:none!important;letter-spacing:.02em!important;min-width:0!important;}\n    #adsbV279Menu select,#adsbV279Menu input[type=text],#adsbV279Menu input[type=number]{width:100%!important;min-width:0!important;box-sizing:border-box!important;background:#0c171f!important;border:1px solid rgba(255,255,255,.13)!important;border-radius:10px!important;color:#edf6f8!important;padding:7px 9px!important;font-size:.76rem!important;outline:none!important;box-shadow:none!important;}\n    #adsbV279Menu .adsb-v279-toggle{width:100%!important;justify-content:center!important;margin:0!important;}\n    .adsb-v279-row{display:grid!important;grid-template-columns:minmax(0,1fr) minmax(0,1fr)!important;gap:8px!important;align-items:end!important;}\n    .adsb-v279-ac