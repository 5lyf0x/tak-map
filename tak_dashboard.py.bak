d:linear-gradient(180deg,rgba(18,27,35,.98),rgba(8,12,18,.98));box-shadow:0 18px 50px rgba(0,0,0,.60),0 0 22px rgba(255,122,26,.13);padding:13px 14px 12px;color:#eef5f7}.adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;font-size:18px;font-weight:900}.adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px}.adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750}.adsb-track-save-input{width:100%;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750;outline:none}.adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850}.adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850}.adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px}.mil-icon-grid,#milGrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(74px,1fr));gap:7px;max-height:360px;overflow:auto}.mil-icon-card{min-height:76px;border:1px solid rgba(255,255,255,.12);background:rgba(7,12,18,.72);border-radius:10px;color:#dce8ee;font-size:10px;font-weight:800;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;padding:5px}.mil-icon-card.selected{border-color:rgba(255,122,26,.85);box-shadow:0 0 0 2px rgba(255,122,26,.16)}.mil-icon-card img{width:36px;height:36px;object-fit:contain}.mil-chip{border:1px solid rgba(255,255,255,.12);border-radius:999px;background:rgba(255,255,255,.04);color:#d8e3e8;font-size:11px;padding:4px 8px;margin:2px}.mil-chip.active{border-color:rgba(255,122,26,.72);color:#fff;background:rgba(255,122,26,.18)}.mil-empty{color:#ffb6a8;font-weight:800;padding:10px}\';document.head.appendChild(st)}\n  function boot(){version();addCss();ownAdsbGlobals();try{renderAircraft(aircraftList())}catch(_){}patchOpenPopups();renderMil();viewshedPosition();}\n  if(document.readyState===\'loading\')document.addEventListener(\'DOMContentLoaded\',function(){setTimeout(boot,180)},{once:true});else setTimeout(boot,180);\n  [700,1600,3500,7000].forEach(function(ms){setTimeout(boot,ms)});setInterval(function(){version();ownAdsbGlobals();patchOpenPopups();syncTrackButtons();if(ADSB.tracking.id)updateTrackFromRows()},1200);\n})();\n</script>\n'
    TAK_MAP_HTML = TAK_MAP_HTML.replace('</body></html>', _v303_controller + '</body></html>')
    TAK_MAP_HTML = _v303_set_versions(TAK_MAP_HTML)
