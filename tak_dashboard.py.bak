  function bindButtonEvents(){if(window._v307AdsbTrackEvents)return;window._v307AdsbTrackEvents=true;const cap=true;const h=(kind)=>function(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(!btn)return;return handleButton(ev,btn,kind)};if(window.PointerEvent)window.addEventListener('pointerdown',h('pointer'),cap);else window.addEventListener('mousedown',h('mouse'),cap);window.addEventListener('touchstart',h('touch'),cap);window.addEventListener('click',h('click'),cap)}
