  function trackButtonHtml(id){const on=!!(state.id&&String(id||'').toLowerCase()===state.id);return '<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn'+(on?' active':'')+'" data-adsb-track-id="'+esc(id)+'" aria-pressed="'+(on?'true':'false')+'"><span class="adsb-track-light '+(on?'active':'')+'"></span><span>Track</span></button></div>'}
  function patchPopup(el){try{if(!el)return;const content=q('.leaflet-popup-content',el)||el;let btn=q('.adsb-track-btn',content);let id=btn?idFromButton(btn):'';if(!id){const h=q('.adsb-popup h3,.feature-popup h3,h3',el);id=idOf(titleMatch(h&&h.textContent))}if(!id)return;if(!btn){content.insertAdjacentHTML('beforeend',trackButtonHtml(id));btn=q('.adsb-track-btn',content)}qa('.adsb-track-btn',content).forEach(b=>{b.dataset.adsbTrackId=id;b.onclick=function(ev){return ownTrackClick(ev,b)}});syncButtons()}catch(e){try{console.warn('v301 patch popup failed',e)}catch(_){} }}
  function patchOpenPopups(){try{qa('.leaflet-popup').forEach(patchPopup)}catch(_){} }
  function closeDialog(){try{const old=field('adsbTrackSaveDialog');if(old)old.remove()}catch(_){}clearVisual()}
  function saveDialog(id,meta,pts){try{const old=field('adsbTrackSaveDialog');if(old)old.remove();pts=(pts||[]).slice();const m=meters(pts);const title=titleOf(meta||{id});const stamp=new Date().toISOString().slice(0,19).replace(/[T:]/g,'-');const def=clean(title+' ADS-B Track '+stamp);const canSave=pts.length>=2;const div=document.createElement('div');div.id='adsbTrackSaveDialog';div.className='adsb-track-save-overlay v301';div.innerHTML='<div class="adsb-track-save-card v301" role="dialog" aria-modal="true" aria-label="Save ADS-B track"><button type="button" class="adsb-track-save-x" data-action="discard" aria-label="Close">×</button><div class="adsb-track-save-title">Save ADS-B Track</div><div class="adsb-track-save-sub">'+esc(title)+' · '+esc(distText(m))+' · '+esc(String(pts.length))+' pts</div><input id="adsbTrackRouteName" class="adsb-track-save-input" value="'+esc(def)+'" '+(canSave?'':'disabled')+' />'+(canSave?'':'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>')+'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div><div class="adsb-track-save-actions"><button type="button" class="layer-button" data-action="discard">Discard</button><button type="button" class="layer-button primary" data-action="save" '+(canSave?'':'disabled')+'>Save</button></div></div>';document.body.appendChild(div);const msg=field('adsbTrackSaveMsg');async function doSave(){try{if(!canSave)return;const name=clean((field('adsbTrackRouteName')||{}).value||def);if(msg){msg.textContent='Saving…';msg.classList.remove('bad')}const feature={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(p=>[Number(p.lon),Number(p.lat),Number(p.alt)||0])},properties:{name,source:'TAK Map ADS-B',kind:'route',geometry:'route',route_type:'adsb_aircraft_track',callsign:(meta&&(meta.callsign||meta.flight||meta.registration))||'',hex:String((meta&&(meta.hex||meta.icao||meta.id))||id||'').toUpperCase(),start_time:new Date((pts[0]&&pts[0].t)||Date.now()).toISOString(),end_time:new Date((pts[pts.length-1]&&pts[pts.length-1].t)||Date.now()).toISOString(),point_count:pts.length,distance_miles:Number((m/1609.344).toFixed(3)),distance_km:Number((m/1000).toFixed(3)),distance_text:distText(m)}}]};const blob=new Blob([JSON.stringify(feature,null,2)],{type:'application/geo+json'});const file=new File([blob],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});let j={};try{j=await r.json()}catch(_){}if(!r.ok||j.ok===false)throw new Error(j.error||('HTTP '+r.status));try{if(typeof window.refreshLocalData==='function')await window.refreshLocalData()}catch(_){}try{if(typeof window.drawImportedObjects==='function')window.drawImportedObjects()}catch(_){}if(msg)msg.textContent='Saved';setTimeout(closeDialog,380)}catch(e){if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}}}div.addEventListener('click',ev=>{const a=ev.target&&ev.target.getAttribute&&ev.target.getAttribute('data-action');if(a==='discard'){ev.preventDefault();closeDialog();return}else if(a==='save'){ev.preventDefault();doSave();return}else if(ev.target===div){closeDialog();return}},true);div.addEventListener('keydown',ev=>{if(ev.key==='Escape')closeDialog()});setTimeout(()=>{try{(field('adsbTrackRouteName')||q('[data-action="discard"]',div)).focus()}catch(_){}},30)}catch(e){try{console.warn('v301 ADS-B save dialog failed',e)}catch(_){}clearVisual()}}
  function start(id){id=String(id||'').toLowerCase();const a=findAircraft(id);state.id=id;state.meta=a||{id};state.points=[];closeDialog();if(a)addPoint(a);else redraw();startTimer();syncButtons();patchOpenPopups();return true}
  function stop(){const id=state.id,meta=state.meta,pts=state.points.slice();state.id=null;state.meta=null;state.points=[];stopTimer();syncButtons();patchOpenPopups();saveDialog(id,meta,pts);return false}
  function toggle(id){id=String(id||'').replace(/^ICAO-/i,'').trim().toLowerCase();if(!id)return false;try{if(state.id===id)return stop();if(state.id){const old={id:state.id,meta:state.meta,pts:state.points.slice()};state.id=null;state.meta=null;state.points=[];stopTimer();syncButtons();saveDialog(old.id,old.meta,old.pts)}return start(id)}catch(e){try{console.warn('v301 toggle ADS-B track failed',e)}catch(_){}return false}}
  function ownTrackClick(ev,btn){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}const id=idFromButton(btn);if(id)toggle(id);syncButtons();return false}catch(e){try{console.warn('v301 ADS-B track click failed',e)}catch(_){}return false}}
  window.toggleAdsbTrack=toggle;
  window.updateAdsbTrackFromStable=function(){try{tick();syncButtons();patchOpenPopups()}catch(_){} };
  function addCss(){try{if(field('v301AdsbTrackStyle'))return;const st=document.createElement('style');st.id='v301AdsbTrackStyle';st.textContent=`
    .adsb-track-btn,.adsb-track-btn *{pointer-events:auto!important;}
    .adsb-track-btn.active,.adsb-track-btn.tracking{border-color:rgba(255,59,48,.75)!important;background:linear-gradient(180deg,rgba(255,59,48,.32),rgba(120,20,16,.25))!important;color:#fff!important;box-shadow:0 0 12px rgba(255,59,48,.34)!important;}
    .adsb-track-btn.active .adsb-track-light,.adsb-track-btn.tracking .adsb-track-light,.adsb-track-light.active,.adsb-track-light[data-v302-tracking="1"]{background:#ff3b30!important;border-color:#ff8a82!important;box-shadow:0 0 10px rgba(255,59,48,.9),inset 0 0 3px rgba(0,0,0,.45)!important;}
    .adsb-track-distance-label.v301{background:rgba(8,12,16,.92);border:1px solid rgba(255,111,46,.84);border-radius:999px;color:#ffe4d4;box-shadow:0 6px 18px rgba(0,0,0,.42),0 0 14px rgba(255,111,46,.25);font-size:11px;font-weight:950;letter-spacing:.02em;line-height:1;padding:3px 7px;white-space:nowrap;transform:translate(10px,-12px);}
    .adsb-track-save-overlay.v301{position:fixed;inset:0;z-index:4300;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.44);backdrop-filter:blur(3px);}
    .adsb-track-save-card.v301{position:relative;width:min(420px,calc(100vw - 28px));border:1px solid rgba(255,122,26,.50);border-radius:14px;background:linear-gradient(180deg,rgba(18,27,35,.985),rgba(8,12,18,.985));box-shadow:0 18px 50px rgba(0,0,0,.64),0 0 22px rgba(255,122,26,.14);padding:13px 14px 12px;color:#eef5f7;}
    .adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;margin:0;padding:0;line-height:1;font-size:18px;font-weight:900;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;cursor:pointer;}
    .adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px;}
    .adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750;}
    .adsb-track-save-input{width:100%;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750;outline:none;box-sizing:border-box;}
    .adsb-track-save-input:focus{border-color:rgba(255,122,26,.72);box-shadow:0 0 0 2px rgba(255,122,26,.12);}
    .adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850;}
    .adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850;}
    .adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px;}
  `;document.head.appendChild(st)}catch(e){try{console.warn('v301 CSS failed',e)}catch(_){}}}
  function installOwnerListeners(){try{if(window._v301TrackOwnerBound)return;window._v301TrackOwnerBound=true;const handler=function(ev){const b=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(!b)return;return ownTrackClick(ev,b)};window.addEventListener('click',handler,true)}catch(e){try{console.warn('v301 owner listener failed',e)}catch(_){}}}
  function patchButtons(){try{qa('.adsb-track-btn').forEach(b=>{const id=idFromButton(b);if(id)b.dataset.adsbTrackId=id;b.onclick=function(ev){return ownTrackClick(ev,b)}});syncButtons()}catch(_){} }
  function bindMap(){try{const m=getMap();if(m&&!window._v301PopupBound){window._v301PopupBound=true;m.on('popupopen',ev=>setTimeout(()=>patchPopup(ev.popup&&ev.popup.getElement&&ev.popup.getElement()),0));m.on('popupclose',()=>setTimeout(syncButtons,0));}}catch(_){} }
  function boot(){setIteration();addCss();installOwnerListeners();bindMap();patchOpenPopups();patchButtons();syncButtons();tick()}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,100),{once:true});else setTimeout(boot,100);
  [350,900,1800,3600,6500].forEach(ms=>setTimeout(boot,ms));
  setInterval(()=>{setIteration();boot()},1200);
