        _html = _v318_re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v318</span>', _html)
        _html = _v318_re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v318</div>', _html)
