  }
  function getLayer(){
    const m=getMap(); if(!m||!window.L)return null;
    try{if(typeof aircraftLayer!=='undefined'&&aircraftLayer){if(!m.hasLayer(aircraftLayer))aircraftLayer.addTo(m);return aircraftLayer;}}catch(_){}
    try{if(window.aircraftLayer){if(!m.hasLayer(window.aircraftLayer))window.aircraftLayer.addTo(m);return window.aircraftLayer;}}catch(_){}
    try{if(!window.v298AircraftLayer)window.v298AircraftLayer=L.layerGroup().addTo(m);return window.v298AircraftLayer;}catch(_){return null;}
  }
  function idOf(a){try{return String((a&&(a.id||a.hex||a.icao||a.uid||a.callsign||a.flight))||'').replace(/^ICAO-/i,'').trim().toLowerCase()}catch(_){return ''}}
  function titleOf(a){try{return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id||a.uid))||'Aircraft').replace(/^ICAO-/i,'').trim()||'Aircraft'}catch(_){return 'Aircraft'}}
  function trackOf(a){const n=Number(a&&a.track_deg);return Number.isFinite(n)?n:0}
  function iconUrl(a){try{if(typeof window.v239AdsbIconUrl==='function')return window.v239AdsbIconUrl(a)}catch(_){}try{if(typeof window.aircraftBillboardDataUrl==='function')return window.aircraftBillboardDataUrl(!!(window.aircraftIsMilitary&&window.aircraftIsMilitary(a)),!!(window.aircraftIsHelicopter&&window.aircraftIsHelicopter(a)),trackOf(a))}catch(_){}return ''}
  function iconClass(a,id){let cls='aircraft-wrap v240-adsb v298-adsb-marker';try{cls+=' '+((window.aircraftIsMilitary&&window.aircraftIsMilitary(a))?'aircraft-military':'aircraft-civil');}catch(_){cls+=' aircraft-civil'}try{cls+=' '+((window.aircraftIsHelicopter&&window.aircraftIsHelicopter(a))?'aircraft-rotor':'aircraft-fixed');}catch(_){cls+=' aircraft-fixed'}try{if(typeof selectedAircraftId!=='undefined'&&id&&selectedAircraftId===id)cls+=' selected'}catch(_){}return cls}
  function iconHtml(a,id){const url=iconUrl(a);const deg=trackOf(a);const label=esc(titleOf(a));return '<div class="'+iconClass(a,id)+'" data-adsb-id="'+esc(id)+'" style="pointer-events:auto;position:relative;width:96px;height:70px;min-width:96px;min-height:70px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(255,255,255,.001);border-radius:14px;">'+(url?'<img class="adsb-png-icon" src="'+esc(url)+'" style="transform:rotate('+deg+'deg)" alt="">':'<div class="aircraft-glyph" style="transform:rotate('+deg+'deg)"></div>')+'<div class="aircraft-label">'+label+'</div></div>'}
  function makeIcon(a,id){try{if(window.L&&typeof window.L.divIcon==='function')return L.divIcon({className:'v298-adsb-leaflet-marker',html:iconHtml(a,id),iconSize:[96,70],iconAnchor:[48,33]})}catch(_){}return null}
  function popupHtml(a){try{if(typeof window.adsbPopupHtml==='function')return window.adsbPopupHtml(a)}catch(_){}const rows=[['Class',a&&a.category],['Type',a&&(a.aircraft_type||a.type)],['Alt',a&&a.altitude_ft!=null?Math.round(Number(a.altitude_ft))+' ft':''],['Speed',a&&a.speed_kt!=null?Math.round(Number(a.speed_kt))+' kt':''],['Track',a&&a.track_deg!=null?Math.round(Number(a.track_deg))+'°':''],['Range',a&&a.range_miles!=null?Number(a.range_miles).toFixed(1)+' mi':''],['Owner/Op',a&&a.owner_operator],['Squawk',a&&a.squawk]].filter(r=>r[1]);return '<div class="feature-popup adsb-popup"><h3>'+esc(titleOf(a))+'</h3><div class="kvp">'+rows.map(r=>'<b>'+esc(r[0])+'</b><span>'+esc(r[1])+'</span>').join('')+'</div></div>'}
  function signature(a,id){return [iconUrl(a),titleOf(a),iconClass(a,id)].join('|')}
