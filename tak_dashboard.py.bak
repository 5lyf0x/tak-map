async function saveTopologyLayout(){const positions={};document.querySelectorAll('.topology-map-node').forEach(el=>{positions[el.dataset.nodeId]={x:parseFloat(el.style.left)||0,y:parseFloat(el.style.top)||0}});try{const r=await fetch('/api/topology-layout',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'save',positions})});const j=await r.json();if(j.ok){topologyManualPositions=j.layout||positions;topologyHasUnsavedLayout=false;topologySetLayoutState('Saved layout',false);const f=document.getElementById('topologyLayoutFoot');if(f)f.textContent='layout saved'}else alert(j.error||'Failed to save topology layout')}catch(e){alert('Failed to save topology layout: '+e)}}
function autoArrangeTopology(){topologyManualPositions={};document.querySelectorAll('.topology-map-node').forEach(el=>{const x=parseFloat(el.dataset.autoX)||0;const y=parseFloat(el.dataset.autoY)||0;el.style.left=x+'px';el.style.top=y+'px';topologyManualPositions[el.dataset.nodeId]={x,y}});topologyHasUnsavedLayout=true;topologySetLayoutState('Auto layout (unsaved)',false);updateTopologyLines()}
async function resetTopologyLayout(){try{const r=await fetch('/api/topology-layout',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'reset'})});const j=await r.json();if(j.ok){topologyManualPositions={};topologyHasUnsavedLayout=false;renderTopology(lastStatusPayload);topologySetLayoutState('Auto layout',false)}else alert(j.error||'Failed to reset topology layout')}catch(e){alert('Failed to reset topology layout: '+e)}}
let lastStatusPayload=null;let lastStatusRenderMs=0;function pctNumber(v){const n=Number(v);return Number.isFinite(n)?n:null}
function networkConnected(s){
  const inet=s.internet||{};
  if(String(inet.state||'').toUpperCase()==='UP')return true;
  const ifs=Array.isArray(s.interfaces)?s.interfaces:[];
  if(ifs.some(i=>{
    const ips=Array.isArray(i.ipv4)?i.ipv4:[];
    const st=String(i.operstate||'').toLowerCase();
    return ips.length>0 && !st.includes('down') && !st.includes('not detected');
  }))return true;
  const wifi=s.wifi||{};
  if(wifi.ip_address)return true;
  const lte=s.lte||{};
  const ls=String(lte.state||'').toLowerCase();
  if(ls.includes('connected')||ls.includes('ipv4'))return true;
  return false;
}
function computeAlerts(s){
  const alerts=[];
  const add=(level,text)=>alerts.push({level,text});
  const ws=s.warning_settings||{};
  const enabled=k=>ws[k]!==false;
  if(enabled('network')&&!networkConnected(s))add('bad','NO NETWORK CONNECTED');
  const required=s.required_services||['opentakserver','eud_handler_ssl','rabbitmq-server'];
  const sv=s.services||{};
  required.forEach(name=>{
    const svc=sv[name]||Object.values(sv).find(x=>x&&x.name===name);
    if(enabled('services')&&(!svc||String(svc.active||'').toLowerCase()!=='active'))add('bad',`${name} NOT ACTIVE`);
  });
  const temp=pctNumber((s.cpu||{}).current_c);
  if(enabled('cpu_temp')&&temp!==null&&temp>65)add('bad',`CPU TEMP ${temp} °C`);
  const ltePct=pctNumber((s.lte||{}).signal_quality_percent);
  if(enabled('lte_reception')&&ltePct!==null&&ltePct<30)add('bad',`4G RECEPTION ${ltePct}%`);
  const diskPct=pctNumber(((s.system_health||{}).disk||{}).used_percent);
  if(enabled('disk')&&diskPct!==null&&diskPct>=90)add('bad',`ROOT DISK CRITICAL ${diskPct}%`);
  else if(enabled('disk')&&diskPct!==null&&diskPct>=40)add('warn',`ROOT DISK ${diskPct}%`);
  const diagMb=pctNumber((s.diagnostics||{}).size_mb);
  if(enabled('diagnostics')&&diagMb!==null&&diagMb>300)add('warn',`DIAGNOSTICS ${diagMb} MB`);
  return alerts;
}
function renderAlerts(s){
  const banner=document.getElementById('alertBanner');
  if(!banner)return;
  const alerts=computeAlerts(s);
  const ws=s.warning_settings||{};
  if(ws.stale!==false&&lastStatusRenderMs&&Date.now()-lastStatusRenderMs>60000){
    const age=Math.floor((Date.now()-lastStatusRenderMs)/1000);
    alerts.push({level:'warn',text:`DASHBOARD DATA STALE ${age}s`});
  }
  if(!alerts.length){banner.className='alert-banner';banner.innerHTML='';return}
  const critical=alerts.some(a=>a.level==='bad');
  banner.className='alert-banner active '+(critical?'critical':'');
  banner.innerHTML=`<div class="alert-title">${critical?'SYSTEM WARNING':'SYSTEM NOTICE'}</div><div class="alert-items">${alerts.map(a=>`<span class="alert-pill ${esc(a.level)}">${esc(a.text)}</span>`).join('')}</div>`;
}

async function configAction(data){
  const r=await fetch('/api/config',{method:'POST',body:new URLSearchParams(data)});
  const j=await r.json().catch(()=>({ok:false,error:'Bad response'}));
  if(!j.ok){alert(j.error||'Config update failed');return}
  fetchStatus();
}
function addZtPeer(){
  const ip=document.getElementById('ztIpInput').value.trim();
  const callsign=document.getElementById('ztCallsignInput').value.trim();
  if(!ip){alert('Enter a ZeroTier peer IP/host first.');return}
  document.getElementById('ztIpInput').value='';
  document.getElementById('ztCallsignInput').value='';
  configAction({action:'add_zt',ip,callsign});
}
function removeZtPeer(ip){
  if(!confirm(`Remove ZeroTier peer ${ip}?`))return;
  configAction({action:'remove_zt',ip});
}
function addServiceMonitor(){
  const service=document.getElementById('serviceInput').value.trim();
  if(!service){alert('Enter a systemd service name first.');return}
  document.getElementById('serviceInput').value='';
  configAction({action:'add_service',service,required:'true'});
}
function removeServiceMonitor(service){
  if(!confirm(`Remove ${service} from monitoring?`))return;
  configAction({action:'remove_service',service});
}
function warningEnabled(settings,key){return !settings||settings[key]!==false}
function setWarning(key,enabled){configAction({action:'set_warning',key,enabled:enabled?'true':'false'})}
function setServiceBanner(service,enabled){configAction({action:'set_required_service',service,enabled:enabled?'true':'false'})}
function renderWarningToggles(s){
  const grid=document.getElementById('warningToggleGrid');
  if(!grid)return;
  const settings=s.warning_settings||{};
  const labels=s.warning_labels||{};
  const keys=['network','services','cpu_temp','lte_reception','disk','stale','diagnostics'];
  grid.innerHTML=keys.map(k=>`<label><input type="checkbox" ${warningEnabled(settings,k)?'checked':''} onchange="setWarning('${esc(k)}',this.checked)"> ${esc(labels[k]||k)}</label>`).join('');
  const off=keys.filter(k=>!warningEnabled(settings,k)).length;
  const el=document.getElementById('warningSummary');
  if(el){el.textContent=off?`${off} disabled`:'All enabled'}
}
const netHistory={down:[],up:[],maxPoints:60,maxAgeMs:5*60*1000};
function bpsNice(v){
  const n=Number(v)||0;
  if(n>=1000000000)return (n/1000000000).toFixed(n>=10000000000?0:1)+' Gbps';
  if(n>=1000000)return (n/1000000).toFixed(n>=10000000?0:1)+' Mbps';
  if(n>=1000)return (n/1000).toFixed(n>=10000?0:1)+' Kbps';
  return Math.round(n)+' bps';
}
function pushNetHistory(kind,value){
  const n=Number(value);const arr=netHistory[kind];if(!arr)return;
  const now=Date.now();arr.push({t:now,v:(Number.isFinite(n)&&n>=0?n:0)});
  while(arr.length>netHistory.maxPoints)arr.shift();
  while(arr.length>2 && now-arr[0].t>netHistory.maxAgeMs)arr.shift();
}
function historyWindowText(values){
  if(!values||values.length<2)return 'collecting samples';
  const span=Math.max(1,Math.round((values[values.length-1].t-values[0].t)/1000));
  if(span<90)return 'last '+span+' sec';
  return 'last '+Math.round(span/60)+' min';
}
function niceAxisMax(vals){
  const raw=Math.max(1,...vals);
  const padded=raw*1.25;
  const pow=Math.pow(10,Math.floor(Math.log10(padded)));
  const m=padded/pow;
  const nice=(m<=1?1:m<=2?2:m<=5?5:10)*pow;
  return Math.max(1,nice);
}
function drawNetHistory(canvasId,values,color){
  const canvas=document.getElementById(canvasId);if(!canvas)return;
  const rect=canvas.getBoundingClientRect();const dpr=window.devicePixelRatio||1;
  const w=Math.max(120,Math.floor(rect.width||300));const h=Math.max(48,Math.floor(rect.height||74));
  if(canvas.width!==Math.floor(w*dpr)||canvas.height!==Math.floor(h*dpr)){canvas.width=Math.floor(w*dpr);canvas.height=Math.floor(h*dpr)}
  const ctx=canvas.getContext('2d');if(!ctx)return;ctx.setTransform(dpr,0,0,dpr,0,0);ctx.clearRect(0,0,w,h);
  ctx.fillStyle='rgba(7,10,15,.34)';ctx.fillRect(0,0,w,h);
  ctx.strokeStyle='rgba(255,255,255,.055)';ctx.lineWidth=1;
  for(let i=1;i<3;i++){const y=Math.round(i*h/3)+.5;ctx.beginPath();ctx.moveTo(8,y);ctx.lineTo(w-8,y);ctx.stroke()}
  for(let i=1;i<5;i++){const x=Math.round(i*w/5)+.5;ctx.beginPath();ctx.moveTo(x,8);ctx.lineTo(x,h-8);ctx.stroke()}
  const pts=(values&&values.length)?values:[{t:Date.now(),v:0}];const vals=pts.map(p=>Number(p.v)||0);const max=niceAxisMax(vals);const pad=8;const chartH=h-22;const chartW=w-pad*2;const n=Math.max(pts.length,Math.min(netHistory.maxPoints,pts.length||1));const gap=2;const bw=Math.max(2,(chartW-gap*(netHistory.maxPoints-1))/netHistory.maxPoints);const start=netHistory.maxPoints-pts.length;
  ctx.fillStyle=color;
  pts.forEach((p,i)=>{const x=pad+(start+i)*(bw+gap);const bh=Math.max(2,(Number(p.v||0)/max)*chartH);const y=h-pad-bh;const r=Math.min(3,bw/2);if(ctx.roundRect){ctx.beginPath();ctx.roundRect(x,y,bw,bh,r);ctx.fill();}else{ctx.fillRect(x,y,bw,bh);}});
  ctx.fillStyle='rgba(142,160,173,.80)';ctx.font='10px system-ui, sans-serif';ctx.textAlign='right';ctx.fillText(bpsNice(max),w-8,12);
}
function renderNetHistory(bw){
  bw=bw||{};pushNetHistory('down',bw.download_bps);pushNetHistory('up',bw.upload_bps);
  const downText=bw.download||'unknown';const upText=bw.upload||'unknown';
  const dg=document.getElementById('netDownGraphValue');if(dg)dg.textContent=downText;
  const ug=document.getElementById('netUpGraphValue');if(ug)ug.textContent=upText;
  const dw=document.getElementById('netDownHistoryWindow');if(dw)dw.textContent=historyWindowText(netHistory.down);
  const uw=document.getElementById('netUpHistoryWindow');if(uw)uw.textContent=historyWindowText(netHistory.up);
  drawNetHistory('netDownHistory',netHistory.down,'rgba(57,217,138,.92)');
  drawNetHistory('netUpHistory',netHistory.up,'rgba(255,139,77,.92)');
}
function render(s){lastStatusPayload=s;lastStatusRenderMs=Date.now();renderWarningToggles(s);const dt=new Date(s.timestamp*1000);document.getElementById('topline').textContent=`${s.hostname||'pi'} · ${dt.toLocaleString()} · auto-refresh every 5 sec`;const inet=s.internet||{};const ib=document.getElementById('internetBadge');ib.className=clsForInternet(inet.state||'DOWN');ib.innerHTML=`<span class="dot"></span><span>${esc(inet.state||'UNKNOWN')}</span>`;document.getElementById('pingIp').textContent=boolText(inet.ping_ip);document.getElementById('dnsLookup').textContent=boolText(inet.dns_lookup);const bw=inet.bandwidth||{};document.getElementById('netIface').textContent=inet.route_interface||bw.route_interface||bw.interface||'unknown';document.getElementById('netDown').textContent=bw.download||'unknown';document.getElementById('netUp').textContent=bw.upload||'unknown';renderNetHistory(bw);
const l=s.lte||{};const lteStateEl=document.getElementById('lteState');if(lteStateEl){lteStateEl.textContent=l.state||'Not Detected';lteStateEl.className=lteStateClass(l.state);}const lb=document.getElementById('lteBars');lb.innerHTML=signalBarsHtml(l.signal_quality_percent,l.bars&&l.bars.count);lb.className='';document.getElementById('lteSignal').textContent=l.signal_quality_percent!=null?`${l.signal_quality_percent}%${l.signal_dbm!=null?' / '+l.signal_dbm+' dBm':''}`:'unknown';document.getElementById('lteTech').textContent=l.access_technology?String(l.access_technology).toUpperCase():'UNKNOWN';document.getElementById('lteOperator').textContent=l.operator||'unknown';document.getElementById('lteNote').textContent='';
const c=s.cpu||{};document.getElementById('cpuCurrent').textContent=c.current_c==null?'—':`${c.current_c} °C`;document.getElementById('cpuHigh').textContent=c.highest_24h_c==null?'—':`${c.highest_24h_c} °C`;document.getElementById('cpuHighTime').textContent=c.highest_24h_ts?formatTs(c.highest_24h_ts):'—';document.getElementById('cpuAvg').textContent=c.average_24h_c==null?'—':`${c.average_24h_c} °C`;document.getElementById('cpuLow').textContent=c.lowest_24h_c==null?'—':`${c.lowest_24h_c} °C`;document.getElementById('cpuFreq').textContent=c.frequency_mhz==null?'unknown':`${c.frequency_mhz} MHz`;document.getElementById('cpuSamples').textContent=c.samples_24h??'—';const h=s.system_health||{};document.getElementById('healthUptime').textContent=h.uptime||'unknown';document.getElementById('healthBoot').textContent=h.boot_time||'unknown';const health=s.system_health||{};const load=health.load_average||[];document.getElementById('healthLoad').textContent=load.length?`1m: ${fmtLoad(load[0])} / 5m: ${fmtLoad(load[1])} / 15m: ${fmtLoad(load[2])}`:'unknown';document.getElementById('healthRam').textContent=h.ram&&h.ram.text?h.ram.text:'unknown';document.getElementById('healthDisk').textContent=h.disk&&h.disk.text?h.disk.text:'unknown';const th=h.throttling||{};
const p=s.power||{};document.getElementById('powerVoltage').textContent=p.battery_voltage_v==null?'unknown':`${p.battery_voltage_v} V`;const hasCurrent=p.current_a!=null;document.querySelectorAll('.power-current-row').forEach(e=>e.style.display=hasCurrent?'':'none');document.getElementById('powerCurrent').textContent=hasCurrent?`${p.current_a} A${p.power_w!=null?' / '+p.power_w+' W':''}`:'';const hasRuntime=!!p.runtime_estimate;document.querySelectorAll('.power-runtime-row').forEach(e=>e.style.display=hasRuntime?'':'none');document.getElementById('powerRuntime').textContent=hasRuntime?p.runtime_estimate:'';
const dg=s.diagnostics||{};document.getElementById('diagSize').textContent=dg.size_mb!=null?`${dg.size_mb} MB`:'unknown';document.getElementById('diagFiles').textContent=dg.file_count!=null?dg.file_count:'unknown';const lat=s.network_latency||[];document.getElementById('latRows').innerHTML=lat.map(i=>`<tr><td data-label="Target">${esc(i.name)}</td><td data-label="Host/IP"><span class="sensitive">${esc(i.host)}</span></td><td data-label="Status">${statusPill(i.status,statusClassGeneric(i.status))}</td><td data-label="Latency">${i.latency_ms?esc(i.latency_ms)+' ms':'—'}</td><td data-label="Note">${esc(i.note||'')}</td></tr>`).join('');const neigh=sortedRows('neighbors',s.network_neighbors||[]);const nr=document.getElementById('neighborRows');if(nr&&!isEditingNeighborHostname()){nr.innerHTML=neigh.length?neigh.map(n=>{const id=safeInputId('neighborHost_',n.key);return`<tr><td data-label="Interface">${esc(n.interface||'unknown')}</td><td data-label="IP Address"><span class="sensitive">${esc(n.ip||'')}</span></td><td data-label="Hostname / Label"><input id="${esc(id)}" value="${esc(n.hostname||'')}" placeholder="Hostname/label" style="min-width:160px;max-width:240px"><span class="small"> ${n.hostname_source==='manual'?'Saved':(n.hostname_source==='auto'?'Auto':'')}</span></td><td data-label="MAC Address"><span class="sensitive">${esc(n.mac||'unknown')}</span></td><td data-label="State">${statusPill(n.state||'None',neighborStateClass(n.state))}</td><td data-label="Last Seen">${esc(formatTs(n.last_seen_ts))}</td><td data-label="Actions" class="actions-cell"><button class="primary mini-remove" onclick="saveNeighborHostname('${esc(n.key)}')">Save</button></td></tr>`}).join(''):'<tr><td data-label="Network Neighbors" colspan="7">No network neighbors found from ip neigh show.</td></tr>';};const ifs=s.interfaces||{};document.getElementById('ifaceRows').innerHTML=Object.values(ifs).map(i=>`<tr><td data-label="Interface">${esc(i.label||i.name)}</td><td data-label="State">${statusPill(String(i.operstate||'').toUpperCase(),interfaceStateClass(i.operstate))}</td><td data-label="IPv4"><span class="sensitive">${esc((i.ipv4||[]).join(', ')||'none')}</span></td></tr>`).join('');const w=s.wifi||{};document.getElementById('wifiSsid').textContent=w.ssid||'unknown';document.getElementById('wifiIp').textContent=w.ip_address||'unknown';document.getElementById('wifiMask').textContent=w.subnet_mask||'unknown';document.getElementById('wifiGateway').textContent=w.gateway||'unknown';const gwCap=w.gateway_capability||{};const gwCapEl=document.getElementById('wifiGatewayCapability');if(gwCapEl){const gwCapText=gwCap.status||w.radio_band||'Unknown';gwCapEl.innerHTML=esc(gwCapText).replace(/\n/g,'<br>');}const radioText=(w.radio_band&&w.radio_frequency_mhz)?`${w.radio_band} (${w.radio_frequency_mhz} MHz)`:(w.radio_band||'Unknown');const radioEl=document.getElementById('wifiRadioBand');if(radioEl)radioEl.textContent=radioText;const wb=document.getElementById('wifiBars');const wifiConnected=(w.connected===true)||!!w.ssid||!!w.ip_address;if(wifiConnected){wb.innerHTML=signalBarsHtml(w.signal_percent,w.bars&&w.bars.count);wb.className='';}else{wb.textContent='Not connected';wb.className='wifi-not-connected warn';}document.getElementById('wifiSignal').textContent=(wifiConnected&&w.signal_percent!=null&&w.signal_percent!=='')?` ${w.signal_percent}%`:'';
const usb=s.usb_devices||[];document.getElementById('usbRows').innerHTML=usb.map(i=>`<tr><td data-label="Device">${esc(i.device)}</td><td data-label="Status">${statusPill(i.status,statusClassGeneric(i.status))}</td><td data-label="Details">${esc(i.details||'')}</td></tr>`).join('');const z=sortedRows('zt',s.zerotier_devices||[]);document.getElementById('ztRows').innerHTML=z.length?z.map(i=>{const lat=i.latency_ms?` (${i.latency_ms} ms)`:'';return`<tr><td data-label="IP"><span class="sensitive">${esc(i.ip)}</span></td><td data-label="Callsign">${esc(i.callsign)}</td><td data-label="Status">${statusPill((i.status||'UNKNOWN')+lat,ztStatusClass(i))}</td><td data-label="Last active">${esc(formatLastActive(i.last_active_ts))}</td><td data-label="Actions" class="actions-cell"><button class="stop mini-remove" onclick="removeZtPeer('${esc(i.ip)}')">Remove</button></td></tr>`}).join(''):'<tr><td data-label="ZeroTier Clients" colspan="5">No ZeroTier clients configured. Add one above or set TAK_DASHBOARD_ZEROTIER_DEVICES in /etc/tak-server-dash.env.</td></tr>';const sv=s.services||{};const reqSet=new Set(s.required_services||[]);document.getElementById('svcRows').innerHTML=sortedRows('services',Object.values(sv)).map(x=>`<tr><td data-label="Service"><b>${esc(x.name)}</b></td><td data-label="Load">${esc(x.load)}</td><td data-label="Status">${statusPill(String(x.active||'').toUpperCase(),clsForSvc(x.active,x.load))}</td><td data-label="Substate">${esc(x.sub)}</td><td data-label="Enabled">${esc(x.enabled)}</td><td data-label="Banner" class="service-banner-cell"><label><input type="checkbox" ${reqSet.has(x.name)?'checked':''} onchange="setServiceBanner('${esc(x.name)}',this.checked)"> Alert</label></td><td data-label="Actions" class="actions-cell"><button class="start" onclick="svcAction('${esc(x.name)}','start')">Start</button><button class="stop" onclick="svcAction('${esc(x.name)}','stop')">Stop</button><button class="restart" onclick="svcAction('${esc(x.name)}','restart')">Restart</button><button class="stop mini-remove" onclick="removeServiceMonitor('${esc(x.name)}')">Remove</button></td></tr>`).join('');renderUploadMeta(s);renderCommandButtons(s);renderCommandHistory(s.command_history||{});updateSortHeaders();renderAlerts(s);const tm=document.getElementById('topologyModal');if(tm&&tm.classList.contains('open'))safeRenderTopology(s,false)}
function setOutputText(text){
  const value=String(text ?? '');
  const out=document.getElementById('output');
  if(out)out.textContent=value;
  const gpsOut=document.getElementById('gpsOutput');
  if(gpsOut&&(value.includes('Action: Pull Server GPS')||value.includes('Action: Push Server GPS')||value.includes('GPS')))gpsOut.textContent=value;
  if(!out){const hist=document.getElementById('commandHistoryOutput');if(hist&&(value.includes('Command:')||value.includes('Action:')))hist.textContent=value;}
}
function renderModemGps(j){
  const set=(id,val)=>{const el=document.getElementById(id);if(el)el.textContent=(val==null||val==='')?'—':String(val)};
  set('gpsStatus',j.ok?'GPS fix pulled':(j.status||'No GPS fix'));
  set('gpsLat',j.latitude!=null?Number(j.latitude).toFixed(7):'');
  set('gpsLon',j.longitude!=null?Number(j.longitude).toFixed(7):'');
  set('gpsAlt',j.altitude_m!=null?`${j.altitude_m} m`:'');
  set('gpsAccuracy',j.accuracy_m!=null?`${j.accuracy_m} m`:'');
  set('gpsSource',j.source||'unknown');
  set('gpsTime',j.utc_time||j.timestamp||'');
  if(j.push_status||j.destination){set('gpsPushStatus',j.push_status||`${j.destination?.host||''}:${j.destination?.port||''}`)}
  set('gpsNote',j.note||'');
}
function gpsDiagnosticsText(j, action){
  const attempts=Array.isArray(j.attempts)?j.attempts:[];
  let lines=[(j.ok?'OK':'FAILED'),'','Action: '+action,'Return code: '+(j.rc??''),'Source: '+(j.source||'unknown'),'Latitude: '+(j.latitude??''),'Longitude: '+(j.longitude??''),'Altitude: '+(j.altitude_m??''),'Accuracy: '+(j.accuracy_m??''),'Fix time: '+(j.utc_time||j.timestamp||''),'AT port / source: '+(j.at_port||j.port||''),'Command set: '+(j.command_set||''),'Poll command: '+(j.poll_command||''),'Poll count: '+(j.poll_count??''),'Wait window: '+(j.wait_seconds!=null?j.wait_seconds+'s':''),'GPS enabled for pull: '+(j.gps_was_enabled_for_pull??''),'GPS disable after pull: '+(j.gps_disable_after_pull??''),'Elapsed: '+(j.elapsed_seconds!=null?j.elapsed_seconds+'s':''),'Total timeout: '+(j.total_timeout_seconds!=null?j.total_timeout_seconds+'s':''),'','Note: '+(j.note||'')];
  if(j.destination){lines.splice(3,0,'Destination: '+(j.destination.host||'')+':'+(j.destination.port||'')+(j.destination.tls?' TLS':''));}
  if(j.callsign||j.uid){lines.push('', 'Callsign: '+(j.callsign||''), 'UID: '+(j.uid||''));}
  lines.push('', 'Attempts:');
  if(attempts.length){
    attempts.forEach((a,idx)=>{
      lines.push(`${idx+1}. ${a.method||'method'}: ${a.ok?'OK':'FAILED'}${a.rc!=null?' (rc '+a.rc+')':''}${a.note?' - '+a.note:''}`);
      if(a.stdout)lines.push('   stdout: '+String(a.stdout).replace(/\s+/g,' ').slice(0,600));
      if(a.stderr)lines.push('   stderr: '+String(a.stderr).replace(/\s+/g,' ').slice(0,600));
    });
  }else{
    lines.push('No detailed attempts were returned. This usually means the wrapper failed before probing GPS.');
  }
  if(j.stdout||j.stderr){
    lines.push('', 'Wrapper STDOUT:', j.stdout||'', '', 'Wrapper STDERR:', j.stderr||'');
  }
  return lines.join('\n');
}
async function fetchJsonOrDiagnostic(url, options){
  const r=await fetch(url, options||{});
  const text=await r.text();
  let j=null;
  try{j=JSON.parse(text)}catch(e){
    const snippet=(text||'').slice(0,1200);
    j={ok:false,status:'Dashboard endpoint returned non-JSON',source:'dashboard/nginx',note:`Expected JSON but received ${r.status} ${r.statusText || ''}. This usually means nginx timed out or the dashboard backend returned an HTML error page.`,http_status:r.status,http_status_text:r.statusText||'',stdout:snippet,stderr:'',attempts:[{method:'Dashboard GPS endpoint',ok:false,note:'Non-JSON response from '+url+'; first response bytes are shown in Wrapper STDOUT.',stdout:snippet}]};
  }
  if(!r.ok){j.ok=false;j.http_status=r.status;j.http_status_text=r.statusText||'';j.note=j.note||`HTTP ${r.status} ${r.statusText||''}`;}
  return j;
}
async function pullModemGps(){
  if(!confirm('Pull Server GPS now?\n\nThis temporarily enables modem GPS, displays the TAK server location locally in the dashboard, then disables modem GPS again. It does not publish the server location to TAK.'))return;
  renderModemGps({ok:false,status:'Pulling GPS...',note:'Waiting up to 5 minutes for modem/GNSS fix...'});
  const pushEl=document.getElementById('gpsPushStatus');if(pushEl)pushEl.textContent='Not pushed';
  try{
    const j=await fetchJsonOrDiagnostic('/api/modem-gps',{method:'POST'});
    renderModemGps(j);
    setOutputText(gpsDiagnosticsText(j, 'Pull Server GPS'));
  }catch(e){
    renderModemGps({ok:false,status:'GPS pull failed',note:String(e)});
    setOutputText('FAILED\n\nAction: Pull Server GPS\n\n'+String(e));
  }
}
async function pushModemGps(){
  if(!confirm('Push Server GPS to TAK Server now?\n\nThis temporarily enables modem GPS, pulls a fresh fix, publishes the TAK server location as a CoT marker, then disables modem GPS again. The marker expires after 5 minutes. Use only when you intentionally want the server location visible in TAK.'))return;
  renderModemGps({ok:false,status:'Pulling GPS for push...',push_status:'Push pending',note:'Waiting up to 5 minutes for modem/GNSS fix before CoT push...'});
  try{
    const j=await fetchJsonOrDiagnostic('/api/modem-gps-push',{method:'POST'});
    j.push_status=j.ok?'Pushed to TAK Server':'Push failed';
    renderModemGps(j);
    setOutputText(gpsDiagnosticsText(j, 'Push Server GPS to TAK Server'));
  }catch(e){
    renderModemGps({ok:false,status:'GPS push failed',push_status:'Push failed',note:String(e)});
    setOutputText('FAILED\n\nAction: Push Server GPS to TAK Server\n\n'+String(e));
  }
}
async function postForm(url,data){const r=await fetch(url,{method:'POST',body:new URLSearchParams(data)});const j=await r.json();setOutputText((j.ok?'OK':'FAILED')+'\n\nCommand: '+(j.command||'')+'\nReturn code: '+(j.rc??'')+'\n\nSTDOUT:\n'+(j.stdout||'')+'\n\nSTDERR:\n'+(j.stderr||''));fetchStatus()}function svcAction(s,a){if(!confirm(`${a.toUpperCase()} ${s}?`))return;postForm('/api/service',{service:s,action:a})}async function runDiagnostics(){if(!confirm('Generate diagnostics bundle on the TAK server?'))return;const r=await fetch('/api/diagnostics',{method:'POST'});const j=await r.json();let t=(j.ok?'OK':'FAILED')+'\n\nCommand: '+(j.command||'')+'\nReturn code: '+(j.rc??'')+'\n\nSTDOUT:\n'+(j.stdout||'')+'\n\nSTDERR:\n'+(j.stderr||'');if(j.download_url){t+='\n\nDownload: '+j.download_url;window.location.href=j.download_url}setOutputText(t);fetchStatus()}async function clearDiagnostics(){if(!confirm('Clear old diagnostics bundles on the TAK server?'))return;const r=await fetch('/api/diagnostics/clear',{method:'POST'});const t=await r.text();setOutputText(t);fetchStatus()}function systemAction(action){const labels={'reboot':'REBOOT','shutdown':'SHUT DOWN','lock-screen':'LOCK THE SERVER SCREEN'};const verb=labels[action]||String(action).toUpperCase();const msg=action==='lock-screen'?'Lock the local graphical screen on the TAK server now?\n\nThis affects the monitor/desktop attached to the server, not the computer viewing this webpage.':`${verb} the Raspberry Pi TAK server now?\n\nThis affects the server running the dashboard, not the computer viewing this page.`;if(!confirm(msg))return;postForm('/api/system',{action})}async function logoutDashboard(){try{await fetch('/api/logout',{method:'POST'});}catch(e){}location.href='/login'}function applyPrivacyMode(mode){const privateMode=mode==='privacy';document.body.classList.toggle('privacy',privateMode);const btn=document.getElementById('privacyToggle');if(btn){btn.textContent=privateMode?'Normal Mode':'Privacy Mode'}const modeText=document.getElementById('privacyModeText');if(modeText){modeText.textContent=privateMode?'MODE: PRIVACY':'MODE: NORMAL'}localStorage.setItem('takDashboardPrivacyMode',privateMode?'privacy':'normal')}function togglePrivacyMode(){const privateMode=document.body.classList.contains('privacy');applyPrivacyMode(privateMode?'normal':'privacy')}applyPrivacyMode('privacy');function sectionKey(title){return String(title||'').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')}function getSectionPrefs(){try{return JSON.parse(localStorage.getItem('takDashboardSectionPrefs')||'{}')}catch(e){return {}}}function saveSectionPrefs(prefs){localStorage.setItem('takDashboardSectionPrefs',JSON.stringify(prefs))}function updateSectionSummary(){const sections=[...document.querySelectorAll('main > section.card')].filter(sec=>sec.id!=='sectionControlsCard');const hidden=sections.filter(sec=>sec.style.display==='none').length;const el=document.getElementById('sectionSummary');if(el){el.textContent=hidden?`${hidden} hidden`:'All visible'}}function setupSectionToggles(){const grid=document.getElementById('sectionToggleGrid');if(!grid)return;const prefs=getSectionPrefs();const sections=[...document.querySelectorAll('main > section.card')].filter(sec=>sec.id!=='sectionControlsCard');grid.innerHTML='';sections.forEach(sec=>{const h=sec.querySelector('h2');if(!h)return;const title=h.textContent.trim();const key=sectionKey(title);const checked=prefs[key]!==false;sec.style.display=checked?'':'none';const label=document.createElement('label');const cb=document.createElement('input');cb.type='checkbox';cb.checked=checked;cb.addEventListener('change',()=>{const p=getSectionPrefs();p[key]=cb.checked;saveSectionPrefs(p);sec.style.display=cb.checked?'':'none';updateSectionSummary()});label.appendChild(cb);label.appendChild(document.createTextNode(title));grid.appendChild(label)});updateSectionSummary()}document.addEventListener('click',e=>{for(const id of ['sectionDetails','warningDetails']){const d=document.getElementById(id);if(d&&d.open&&!d.contains(e.target)){d.open=false}}});setupSectionToggles();setupNeighborIpv6Toggle();fetchStatus();setInterval(fetchStatus,15000);setInterval(()=>{if(lastStatusPayload)renderAlerts(lastStatusPayload)},15000)


</script></body></html>'''


LOGIN_HTML=r'''<!doctype html><html lang="en"><head><meta charset="utf-8"><title>TAK Server Dash Login</title><meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"><style>
:root{--bg:#06080b;--panel:#101720;--line:#2d3b44;--text:#eef5f7;--muted:#91a4af;--accent:#ff7a1a;--accent2:#ffc266;--bad:#ff4f4f;--good:#39d98a}*{box-sizing:border-box}html,body{min-height:100%;margin:0}body{font-family:Arial,Helvetica,sans-serif;color:var(--text);background:radial-gradient(circle at 50% 48%,rgba(255,122,26,.16),transparent 18%),linear-gradient(rgba(3,6,9,.58),rgba(3,6,9,.88)),url('/lockscreen-bg.png') center/cover no-repeat fixed;display:flex;align-items:center;justify-content:center;padding:18px}.login-card-wrap{transform:translateY(15vh);width:min(440px,100%)}.login-card{width:100%;background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.02)),rgba(10,15,21,.88);border:1px solid rgba(255,122,26,.42);border-radius:18px;padding:24px;box-shadow:0 0 42px rgba(0,0,0,.55),0 0 28px rgba(255,92,20,.12);backdrop-filter:blur(8px)}.brand{font-size:.78rem;letter-spacing:.18em;text-transform:uppercase;color:var(--accent2);font-weight:900;margin-bottom:8px}.title{font-size:1.5rem;text-transform:uppercase;letter-spacing:.07em;font-weight:900;margin:0 0 6px}.sub{color:var(--muted);font-size:.92rem;line-height:1.4;margin:0 0 18px}.notice{border:1px solid rgba(255,122,26,.32);background:rgba(255,122,26,.08);border-radius:12px;padding:10px 12px;color:#ffd7ba;font-size:.82rem;line-height:1.35;margin-bottom:16px}.login-note{margin:8px 0 14px;color:#ffbf8a;font-size:.78rem;line-height:1.35;letter-spacing:.02em}label{display:block;color:var(--muted);font-size:.75rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin:12px 0 6px}input{width:100%;border:1px solid var(--line);background:rgba(0,0,0,.38);color:var(--text);border-radius:12px;padding:12px 12px;font-size:1rem;outline:none}input:focus{border-color:rgba(255,122,26,.8);box-shadow:0 0 0 3px rgba(255,122,26,.14)}button{width:100%;margin-top:16px;border:1px solid rgba(255,122,26,.85);background:linear-gradient(180deg,#ff8a2a,#a43b0a);color:white;border-radius:12px;padding:12px 14px;font-weight:900;text-transform:uppercase;letter-spacing:.08em;cursor:pointer}button:disabled{opacity:.65;cursor:wait}.error{display:none;margin-top:12px;border:1px solid rgba(255,79,79,.55);background:rgba(255,79,79,.1);color:#ffd0d0;border-radius:10px;padding:10px 12px;font-size:.88rem}.foot{display:flex;gap:10px;justify-content:space-between;align-items:center;margin-top:14px;color:var(--muted);font-size:.78rem}.foot a{color:#ffd0b0;text-decoration:none}.foot a:hover{text-decoration:underline}.iteration-marker{color:rgba(145,164,175,.45);font-size:.72rem;line-height:1;padding:8px 12px;text-align:center;user-select:text;position:fixed;bottom:0;left:50%;transform:translateX(-50%)}@media(max-width:520px){body{align-items:flex-start;padding-top:52px}.login-card-wrap{transform:translateY(8vh)}.login-card{padding:18px}.title{font-size:1.2rem}}
.route-color-input{width:28px;height:24px;padding:0;border:1px solid rgba(255,122,34,.45);border-radius:6px;background:#101820}.hidden-local{opacity:.45}.send-map-summary{border:1px solid rgba(255,122,34,.28);background:rgba(255,122,34,.07);border-radius:10px;padding:8px;margin-top:8px;font-size:.72rem;line-height:1.35}.send-map-summary b{color:#ffd0b2}.local-data-list{max-height:190px;overflow:auto}.local-actions{position:sticky;bottom:0;background:rgba(10,16,22,.96);backdrop-filter:blur(8px);z-index:3}.relief-controls .chip.overlay-chip{display:none}.local-section .subgroup-title{font-weight:900;letter-spacing:.045em;text-transform:uppercase}.local-data-row b{font-weight:780}.local-actions{position:sticky;bottom:0;background:rgba(12,17,21,.96);border-top:1px solid rgba(255,255,255,.08)}</style></head><body><div class="login-card-wrap"><form class="login-card" id="loginForm" autocomplete="off"><div class="brand">TAK Server Dashboard</div><h1 class="title">Authorized Access</h1><p class="sub">Sign in with local Pi OS admin account.</p><div class="notice">Authorized users only. This system is secured and monitored. Dashboard sessions expire after 12 hours.</div><label for="computer">Username</label><input id="computer" name="computer" autocomplete="off" autocapitalize="none" spellcheck="false" autofocus required><label for="technology">Password</label><input id="technology" name="technology" type="password" autocomplete="new-password" autocapitalize="none" spellcheck="false" required><div class="login-note">Do not save this password on shared devices.</div><button id="loginButton" type="submit">Login</button><div class="error" id="errorBox"></div><div class="foot"><span>HTTPS required</span><span>Authorized users only</span></div></form></div><script>
const form=document.getElementById('loginForm');const err=document.getElementById('errorBox');const btn=document.getElementById('loginButton');function showError(t){err.textContent=t;err.style.display='block'}form.addEventListener('submit',async(e)=>{e.preventDefault();err.style.display='none';btn.disabled=true;btn.textContent='Checking...';try{const r=await fetch('/api/login',{method:'POST',body:new URLSearchParams({computer:document.getElementById('computer').value,technology:document.getElementById('technology').value})});let j={};try{j=await r.json()}catch(_){j={error:'Login failed. Server did not return JSON.'}}if(!r.ok||!j.ok){showError(j.error||('Login failed. HTTP '+r.status));btn.disabled=false;btn.textContent='Login';return}const next=new URLSearchParams(location.search).get('next')||'/';location.href=next.startsWith('/')?next:'/'}catch(ex){showError(String(ex));btn.disabled=false;btn.textContent='Login'}});
</script><div class="iteration-marker">v301</div></body></html>'''



# --- v236 online EUD and ADS-B restore/refinement ---
_v236_prev_tak_map_euds = tak_map_euds
_v236_prev_tak_map_adsb = tak_map_adsb

def _v236_online_eud_seconds():
    try:
        return max(15, int(os.environ.get('TAK_DASH_EUD_ONLINE_SECONDS', '45')))
    except Exception:
        return 45

def _v236_good_callsign(value):
    v=str(value or '').strip()
    if not v:
        return ''
    if _v233_uid_like(v):
        return ''
    if v.lower() in ('none','null','unknown','tak client','webform','tak-dashboard'):
        return ''
    if re.search(r'\bATAK\b|\bWinTAK\b|\biTAK\b|\d+\.\d+\.\d+', v, re.I):
        return ''
    return v

def _v236_event_attr(row, name):
    try:
        for txt in _row_text_values(row or {}):
            if '<event' not in txt: continue
            m=re.search(r'<event\b[^>]*\b'+re.escape(name)+r'=["\']([^"\']+)["\']', txt, re.I)
            if m: return m.group(1)
    except Exception:
        pass
    return ''

def _v236_row_age_seconds(row, prefer_stale=False):
    row=row or {}
    keys=('stale','stale_time') if prefer_stale else ('time','timestamp','start','updated','update_time','last_seen')
    for k in keys:
        v=_row_ci_get(row, (k,), '')
        if v:
            a=_age_seconds_from_value(v)
            if a is not None: return a
    for k in (('stale',) if prefer_stale else ('time','start','stale')):
        v=_v236_event_attr(row, k)
        if v:
            a=_age_seconds_from_value(v)
            if a is not None: return a
    return None

def _v236_callsign_lookup(limit=2500):
    out={}
    try:
        uris,_errs=_candidate_ots_pg_uris()
        for uri in uris[:2]:
            rows,err=_pg_table_rows(uri,'cot',limit)
            if err: continue
            for row in rows or []:
                if not isinstance(row,dict): continue
                xml=str(row.get('xml') or '')
                parsed=_parse_cot_text_fields(row); extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('creator_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                cs=_v236_good_callsign(extra.get('callsign') or parsed.get('callsign') or row.get('sender_callsign') or parsed.get('creator_callsign'))
                if uid and cs:
                    out[uid.lower()]=cs
            if out: break
    except Exception:
        pass
    return out

def tak_map_euds():
    """v236: use live CoT TAKV rows as the online EUD source and display real callsigns."""
    euds={}; notes=[]; online_sec=_v236_online_eud_seconds(); lookup={}
    try: lookup=_v236_callsign_lookup()
    except Exception: lookup={}
    try:
        pg_uris,cfg_errors=_candidate_ots_pg_uris()
        if cfg_errors: notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
        for uri in pg_uris[:2]:
            rows,err=_pg_table_rows(uri,'cot',2500)
            if err:
                notes.append({'source':'postgres:cot','ok':False,'error':err[:180]}); continue
            notes.append({'source':'postgres:cot','ok':True,'rows':len(rows)})
            for row in rows or []:
                if not isinstance(row,dict): continue
                xml=str(row.get('xml') or '')
                if '<takv' not in xml.lower() and not str(row.get('version') or row.get('client') or '').strip():
                    continue
                parsed=_parse_cot_text_fields(row); typ=str(row.get('type') or parsed.get('type') or '')
                if _is_mission_cot_fields(parsed,row): continue
                if _is_aircraft_type(typ,row.get('uid'),row.get('sender_callsign')) or typ.startswith('b-f-t') or typ.startswith('b-t-f'): continue
                extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                cs=_v236_good_callsign(extra.get('callsign') or parsed.get('callsign') or row.get('sender_callsign') or lookup.get(uid.lower()))
                if not uid and not cs: continue
                lat=_coerce_float(parsed.get('lat')); lon=_coerce_float(parsed.get('lon'))
                age=_v236_row_age_seconds(row, False)
                if age is None or age > online_sec:
                    continue
                e={'uid':uid,'callsign':cs or (('UID '+uid[:10]+'...') if uid else 'TAK Client'),
                   'client':extra.get('client') or str(row.get('client') or ''),'version':extra.get('version') or str(row.get('version') or ''),
                   'client_label':' '.join([extra.get('client') or str(row.get('client') or ''), extra.get('version') or str(row.get('version') or '')]).strip(),
                   'team':extra.get('team') or '', 'lat':lat, 'lon':lon, 'updated':str(row.get('time') or row.get('timestamp') or row.get('start') or ''),
                   'location_age_seconds':age, 'status':'Online', 'source':'cot', 'type':typ}
                key=(uid or cs).lower()
                old=euds.get(key)
                if old is None or float(e.get('location_age_seconds') or 999999) < float(old.get('location_age_seconds') or 999999):
                    euds[key]=e
            if euds: break
    except Exception as ex:
        notes.append({'source':'v236-euds','ok':False,'error':str(ex)[:180]})
    # Fallback only if no live CoT clients were found.
    if not euds:
        try:
            data=_v236_prev_tak_map_euds() or {'euds':[]}
            for e in data.get('euds') or []:
                uid=str(e.get('uid') or '').strip(); best=lookup.get(uid.lower()) if uid else ''
                if best: e['callsign']=best
                cs=_v236_good_callsign(e.get('callsign'))
                age=e.get('location_age_seconds')
                try: age=float(age)
                except Exception: age=None
                if not cs or age is None or age>online_sec: continue
                e['callsign']=cs; e['status']='Online'; e['location_age_seconds']=age
                euds[(uid or cs).lower()]=e
        except Exception:
            pass
    out=list(euds.values())
    out.sort(key=lambda x:(str(x.get('callsign') or '').lower(), float(x.get('location_age_seconds') or 999999)))
    return {'ok':True,'euds':out,'sources':notes,'online_only':True,'online_seconds':online_sec}

def _v236_adsb_fresh(ac, stale_seconds, ots_grace=None):
    if not isinstance(ac,dict): return False
    try:
        lat=float(ac.get('lat')); lon=float(ac.get('lon'))
        if not (-90<=lat<=90 and -180<=lon<=180) or (abs(lat)<0.000001 and abs(lon)<0.000001): return False
        ac['lat']=lat; ac['lon']=lon
    except Exception:
        return False
    seen=ac.get('seen_seconds')
    try:
        if seen is not None and float(seen)>float(stale_seconds): return False
    except Exception:
        pass
    # OTS CoT rows often do not carry dump1090/readsb `seen` values. Use a small
    # grace window keyed off the requested update interval so valid aircraft do not
    # disappear between OTS writes, while still aging stale rows out quickly.
    updated=ac.get('updated') or ac.get('time') or ac.get('timestamp') or ac.get('start') or ''
    if seen is None and updated:
        age=_age_seconds_from_value(updated)
        if age is not None and age>float(ots_grace or stale_seconds): return False
    return True

def tak_map_adsb():
    data=(globals().get('_v233_tak_map_adsb') or _v236_prev_tak_map_adsb)() or {'ok':True,'aircraft':[],'sources':[]}
    settings=data.get('settings') or _load_adsb_settings()
    stale_seconds=_adsb_stale_seconds(settings)
    try:
        interval=int(settings.get('update_interval_seconds') or max(1, stale_seconds-1))
    except Exception:
        interval=5
    ots_grace=max(stale_seconds, min(90, interval*3 + 2))
    seen={}; aircraft=[]
    for ac in data.get('aircraft') or []:
        if not _v236_adsb_fresh(ac, stale_seconds, ots_grace): continue
        if not _adsb_in_radius(ac, settings): continue
        key=str(ac.get('id') or ac.get('icao') or ac.get('uid') or ac.get('callsign') or '').strip().lower()
        if not key: continue
        old=seen.get(key)
        def rank(x):
            try: return float(x.get('seen_seconds'))
            except Exception: return 999999
        if old is None or rank(ac)<rank(old): seen[key]=ac
    aircraft=list(seen.values())
    data['aircraft']=aircraft; data['count']=len(aircraft); data['stale_seconds']=stale_seconds; data['settings']=settings
    return data

TAK_MAP_LOGIN_HTML=r'''<!doctype html><html lang="en"><head><meta charset="utf-8"><title>TAK Map Login</title><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--bg:#06080b;--panel:#101720;--line:#2d3b44;--text:#eef5f7;--muted:#91a4af;--accent:#ff7a1a;--accent2:#ffc266;--bad:#ff4f4f}*{box-sizing:border-box}html,body{min-height:100%;margin:0}body{font-family:Arial,Helvetica,sans-serif;color:var(--text);background:radial-gradient(circle at 50% 44%,rgba(255,122,26,.13),transparent 24%),linear-gradient(rgba(3,6,9,.62),rgba(3,6,9,.88)),url('/lockscreen-bg.png') center/cover no-repeat fixed;padding:0}.topbar{height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 34px;background:rgba(4,8,12,.62);border-bottom:1px solid rgba(72,92,108,.65);backdrop-filter:blur(8px)}.topbar .brand{color:var(--muted);font-size:.9rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.topbar a{color:var(--text);text-decoration:none;font-size:.9rem;font-weight:850}.topbar a:hover{color:#fff;text-decoration:underline}.wrap{min-height:calc(100vh - 72px);display:flex;flex-direction:column;align-items:center;padding:28px 18px 18px}.logo{width:310px;height:310px;object-fit:contain;filter:drop-shadow(0 22px 34px rgba(0,0,0,.55));margin:0 0 18px}.card{width:min(510px,100%);background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)),rgba(10,16,22,.88);border:1px solid rgba(92,111,126,.9);border-radius:26px;padding:32px 50px 34px;box-shadow:0 0 42px rgba(0,0,0,.58),0 0 28px rgba(255,92,20,.10);backdrop-filter:blur(10px)}h1{margin:0 0 8px;text-align:center;font-size:2rem;letter-spacing:.02em}.sub{text-align:center;color:var(--muted);margin:0 0 24px;font-size:.95rem}.card label{display:block;margin:14px 0 7px;color:var(--muted);font-size:.78rem;font-weight:900;letter-spacing:.08em;text-transform:uppercase}.card input{width:100%;border:1px solid var(--line);background:rgba(0,0,0,.42);color:var(--text);border-radius:12px;padding:13px 14px;font-size:1.05rem;outline:none}.card input:focus{border-color:rgba(255,122,26,.82);box-shadow:0 0 0 3px rgba(255,122,26,.13)}button{width:100%;margin-top:18px;border:1px solid rgba(255,122,26,.86);background:linear-gradient(180deg,#ff8a2a,#a43b0a);color:#fff;border-radius:14px;padding:14px 16px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;cursor:pointer}.error{display:none;margin-top:14px;border:1px solid rgba(255,79,79,.55);background:rgba(255,79,79,.1);color:#ffd0d0;border-radius:12px;padding:10px 12px;font-size:.9rem}.foot{position:fixed;bottom:12px;left:0;right:0;text-align:center;color:rgba(145,164,175,.68);font-size:.76rem}@media(max-width:640px){.topbar{padding:0 16px}.logo{width:245px;height:245px}.wrap{padding-top:18px}.card{padding:24px 22px}h1{font-size:1.55rem}}
.route-color-input{width:28px;height:24px;padding:0;border:1px solid rgba(255,122,34,.45);border-radius:6px;background:#101820}.hidden-local{opacity:.45}.send-map-summary{border:1px solid rgba(255,122,34,.28);background:rgba(255,122,34,.07);border-radius:10px;padding:8px;margin-top:8px;font-size:.72rem;line-height:1.35}.send-map-summary b{color:#ffd0b2}.local-data-list{max-height:190px;overflow:auto}.local-actions{position:sticky;bottom:0;background:rgba(10,16,22,.96);backdrop-filter:blur(8px);z-index:3}.relief-controls .chip.overlay-chip{display:none}.local-section .subgroup-title{font-weight:900;letter-spacing:.045em;text-transform:uppercase}.local-data-row b{font-weight:780}.local-actions{position:sticky;bottom:0;background:rgba(12,17,21,.96);border-top:1px solid rgba(255,255,255,.08)}
.local-data-row b{font-size:.78rem;font-weight:720;line-height:1.18}.local-data-row small{font-size:.67rem;line-height:1.18}.local-section .subgroup-title{font-size:.79rem;font-weight:900;letter-spacing:.06em;color:#f0f4f6}.version-panel{padding:10px 12px;color:#8d9aa3}.version-panel .version-product{font-size:.68rem;color:#8d9aa3}.version-panel .version-row{display:flex;align-items:center;gap:8px;margin-top:3px}.version-panel .release-main{font-size:.86rem;font-weight:850;color:#edf3f6}.version-panel .iteration-chip{font-size:.62rem;font-weight:850;color:#9ba7af;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.045);border-radius:999px;padding:2px 7px}.route-scanner-warning{display:none!important}
</style></head><body><div class="topbar"><div class="brand">TAK Server Dashboard</div><a href="/">Return to Dashboard</a></div><main class="wrap"><img class="logo" src="/tak-map-logo.png" alt="TAK Map logo"><form class="card" id="takMapLoginForm" autocomplete="off"><h1>TAK Map Login</h1><p class="sub">OpenTAKServer admin login required</p><label for="username">Username</label><input id="username" name="username" autocomplete="off" autocapitalize="none" spellcheck="false" autofocus required><label for="password">Password</label><input id="password" name="password" type="password" autocomplete="new-password" autocapitalize="none" spellcheck="false" required><button id="takMapLoginButton" type="submit">Enter TAK Map</button><div class="error" id="takMapError"></div></form></main><div class="foot">TAK Map access</div><script>
const form=document.getElementById('takMapLoginForm');const err=document.getElementById('takMapError');const btn=document.getElementById('takMapLoginButton');function showError(t){err.textContent=t;err.style.display='block'}form.addEventListener('submit',async(e)=>{e.preventDefault();err.style.display='none';btn.disabled=true;btn.textContent='Checking...';try{const r=await fetch('/api/tak-map/login',{method:'POST',body:new URLSearchParams({username:document.getElementById('username').value,password:document.getElementById('password').value})});let j={};try{j=await r.json()}catch(_){j={error:'Login failed. Server did not return JSON.'}}if(!r.ok||!j.ok){showError(j.error||('Login failed. HTTP '+r.status));btn.disabled=false;btn.textContent='Enter TAK Map';return}try{sessionStorage.setItem('takMapLoginSync','1')}catch(_){} location.href='/tak-map'}catch(ex){showError(String(ex));btn.disabled=false;btn.textContent='Enter TAK Map'}});
</script></body></html>'''

TAK_MAP_HTML=r'''<!doctype html><html lang="en"><head><meta charset="utf-8"><title>TAK Map</title><meta name="viewport" content="width=device-width, initial-scale=1"><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"><style>
:root{--bg:#06090d;--panel:#101923;--panel2:#14202b;--text:#e9f0f5;--muted:#8da0ad;--line:#273642;--accent:#ff6f2e;--good:#39d98a;--warn:#ffcc66;--bad:#ff5f57}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}.topbar{height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 14px;border-bottom:1px solid var(--line);background:rgba(4,8,12,.92);position:fixed;top:0;left:0;right:0;z-index:900}.title{display:flex;align-items:center;gap:11px;text-transform:uppercase;font-weight:900;letter-spacing:.08em}.title img{width:42px;height:42px;object-fit:contain}.top-actions{display:flex;align-items:center;gap:8px}.top-actions a,.top-actions button,.layer-button{background:#1d2833;color:var(--text);border:1px solid #354556;border-radius:999px;padding:6px 9px;text-decoration:none;font-weight:800;cursor:pointer;font-size:.78rem;line-height:1.15}.top-actions a:hover,.top-actions button:hover,.layer-button:hover{border-color:var(--accent)}#map{position:fixed;top:86px;left:396px;right:0;bottom:0;background:#081018}.sidebar{position:fixed;top:86px;left:0;bottom:0;width:396px;overflow:auto;background:linear-gradient(180deg,rgba(12,19,27,.98),rgba(6,10,14,.98));border-right:1px solid var(--line);z-index:800;padding:12px;transition:transform .2s ease}.sidebar.collapsed{transform:translateX(-396px)}.sidebar.collapsed~#map{left:0}.panel{border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.035);padding:12px;margin-bottom:10px}.panel h2{margin:0 0 10px;font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:#c8d2da}.panel.collapsible h2{display:flex;align-items:center;justify-content:space-between;gap:8px;cursor:pointer;user-select:none}.panel-toggle{color:var(--accent);font-weight:1000}.panel.collapsed .panel-body{display:none}.panel.collapsed h2{margin-bottom:0}.zoom-indicator{position:fixed;right:14px;top:72px;z-index:700;min-width:312px;text-align:center;background:linear-gradient(180deg,rgba(255,255,255,.11),rgba(8,13,18,.90) 46%,rgba(4,8,12,.96));border:1px solid rgba(255,111,46,.38);border-radius:999px;color:#ffd9c5;padding:8px 14px;font-weight:900;letter-spacing:.025em;box-shadow:inset 0 1px 0 rgba(255,255,255,.18),inset 0 -1px 0 rgba(0,0,0,.62),0 14px 34px rgba(0,0,0,.42);backdrop-filter:blur(10px);text-shadow:0 1px 2px rgba(0,0,0,.9)}.zoom-indicator::before{content:'';display:inline-block;width:9px;height:9px;margin-right:8px;border-radius:999px;background:var(--good);box-shadow:0 0 7px rgba(57,217,138,.78)}.search-wrap{position:relative}.search,.select{width:100%;background:#091018;border:1px solid #334553;border-radius:10px;color:var(--text);padding:9px 10px}.search{padding-right:38px}.select{cursor:pointer}.search-clear{position:absolute;right:7px;top:7px;width:24px;height:24px;border-radius:999px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.05);color:var(--muted);font-weight:900;cursor:pointer}.search-clear:hover{color:var(--accent);border-color:rgba(255,111,46,.45)}.search-results{display:none;position:absolute;top:43px;left:0;right:0;z-index:1200;max-height:260px;overflow:auto;border:1px solid rgba(255,111,46,.38);border-radius:13px;background:rgba(6,10,14,.86);backdrop-filter:blur(10px);box-shadow:0 18px 40px rgba(0,0,0,.52);padding:6px}.search-result-item{display:flex;align-items:center;justify-content:space-between;gap:10px;width:100%;text-align:left;border:0;border-bottom:1px solid rgba(255,255,255,.055);background:transparent;color:var(--text);padding:8px 9px;border-radius:9px;cursor:pointer}.search-result-item:last-child{border-bottom:0}.search-result-item:hover{background:rgba(255,111,46,.13)}.search-result-item b{display:block;font-size:.82rem}.search-result-item small{display:block;color:var(--muted);font-size:.72rem}.search-result-chip{color:#ffd0b0;border:1px solid rgba(255,111,46,.35);border-radius:999px;padding:2px 6px;font-size:.66rem;white-space:nowrap}.sidebar,.sync-list,.search-results,.status-dropdown{scrollbar-width:thin;scrollbar-color:rgba(255,111,46,.62) rgba(255,255,255,.04)}.sidebar::-webkit-scrollbar,.sync-list::-webkit-scrollbar,.search-results::-webkit-scrollbar,.status-dropdown::-webkit-scrollbar{width:10px;height:10px}.sidebar::-webkit-scrollbar-track,.sync-list::-webkit-scrollbar-track,.search-results::-webkit-scrollbar-track,.status-dropdown::-webkit-scrollbar-track{background:rgba(255,255,255,.035);border-radius:999px}.sidebar::-webkit-scrollbar-thumb,.sync-list::-webkit-scrollbar-thumb,.search-results::-webkit-scrollbar-thumb,.status-dropdown::-webkit-scrollbar-thumb{background:linear-gradient(180deg,rgba(255,111,46,.75),rgba(255,204,102,.42));border-radius:999px;border:2px solid rgba(6,10,14,.92)}.search-dim{opacity:.24;filter:grayscale(.72)}.search-hit{filter:drop-shadow(0 0 12px rgba(255,111,46,.80))}.muted{color:var(--muted);font-size:.84rem}.danger{color:var(--bad);font-size:.84rem}.row{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.055)}.row:last-child{border-bottom:0}.row label{display:flex;align-items:center;gap:8px;min-width:0}.row span{min-width:0}.row small{display:block;color:var(--muted);font-size:.72rem;margin-top:1px}.row input{accent-color:var(--accent)}.chip{border:1px solid rgba(255,111,46,.4);background:rgba(255,111,46,.08);border-radius:999px;padding:3px 8px;color:#ffd0b0;font-size:.72rem;white-space:nowrap}.subgroup{margin-top:8px}.subgroup-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.09em;color:var(--muted);margin:8px 0 3px}.map-footer{display:none!important}.sidebar.collapsed~.map-footer{left:14px}.aircraft-wrap{display:flex;flex-direction:column;align-items:center;pointer-events:none}.aircraft-glyph{width:38px;height:48px;display:block;overflow:visible;filter:drop-shadow(0 0 10px rgba(0,0,0,.82))}.aircraft-glyph.selected{filter:drop-shadow(0 0 12px currentColor)