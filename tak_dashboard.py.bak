# --- begin v266 ADS-B settings compatibility fix ---
# Some split-package upgrade paths can leave the ADS-B settings route calling the
# newer two-argument form while an older one-argument implementation is still in
# scope.  Keep Save Filter / Apply to OTS tolerant of both forms.
_v266_prev_save_adsb_settings = _save_adsb_settings

def _save_adsb_settings(payload, session=None, *args, **kwargs):
    try:
        return _v266_prev_save_adsb_settings(payload, session=session)
    except TypeError as e:
        msg = str(e)
        if 'positional argument' in msg or 'unexpected keyword argument' in msg:
            return _v266_prev_save_adsb_settings(payload)
        raise
# --- end v266 ADS-B settings compatibility fix ---



