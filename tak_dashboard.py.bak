  async function importGeoTiffFile(file){if(file.size>HARD_MB*MB)throw new Error('file is over 1 GB; browser-side GeoTIFF import rejected');if(file.size>CONFIRM_MB*MB){if(!confirm(file.name+' is '+Math.round(file.size/MB)+' MB. Importing large DEMs can be slow. Continue?'))throw new Error('user canceled large GeoTIFF import')}else if(file.size>WARN_MB*MB){setElevStatus('Large file warning: '+file.name+' is '+Math.round(file.size/MB)+' MB. Import may take time.',false)}await ensureGeoTiffLibs();const buf=await file.arrayBuffer();const tiff=await window.GeoTIFF.fromArrayBuffer(buf);const image=await tiff.getImage();const width=image.getWidth(),height=image.getHeight();if(!(width>1&&height>1))throw new Error('GeoTIFF has invalid raster dimensions');if(image.getSamplesPerPixel&&image.getSamplesPerPixel()>1)throw new Error('multi-band GeoTIFF appears to be imagery; use DEM/elevation GeoTIFF only');if(hasSkewOrRotation(image))throw new Error('rotated/skewed GeoTIFF transforms are not supported');const geoKeys=image.getGeoKeys?image.getGeoKeys():{};let bbox=image.getBoundingBox?image.getBoundingBox():null;if(!bbox||bbox.length<4||!bbox.every(v=>Number.isFinite(Number(v))))throw new Error('GeoTIFF is missing readable georeferenced bounds');bbox=bbox.map(Number);let crsMode='geographic',proj4String='';if(isGeographicGeoTiff(image,geoKeys,bbox)){crsMode='geographic'}else{proj4String=geoKeysToProjString(geoKeys);if(!proj4String)throw new Error('unsupported GeoTIFF CRS/projection. Use USGS 3DEP DEM GeoTIFFs with readable geographic/projected CRS metadata.');crsMode='projected'}const noData=noDataFromImage(image);const ras=await image.readRasters({samples:[0],interleave:true});let src=Array.isArray(ras)?ras[0]:ras;if(!src||!src.length)throw new Error('GeoTIFF elevation band could not be read');const vals=new Float32Array(src.length);for(let i=0;i<src.length;i++){const v=Number(src[i]);vals[i]=Number.isFinite(v)?v:NaN;if(i%2000000===0)await new Promise(r=>setTimeout(r,0))}const tile={id:'geotiff|'+String(file.name||'').toLowerCase()+'|'+width+'x'+height+'|'+Date.now(),type:'USGS 3DEP GeoTIFF/COG DEM',sourceType:'geotiff',name:file.name,width,height,size:Math.max(width,height),buffer:vals.buffer,noData,bytes:file.size,imported:Date.now(),crsMode,proj4String,xMin:bbox[0],yMin:bbox[1],xMax:bbox[2],yMax:bbox[3]};const b4326=bbox4326FromSource(tile);tile.lat0=b4326[0];tile.lon0=b4326[1];tile.lat1=b4326[2];tile.lon1=b4326[3];if(!(tile.lat0>=-90.5&&tile.lat1<=90.5&&tile.lon0>=-180.5&&tile.lon1<=180.5))throw new Error('GeoTIFF WGS84 bounds are outside valid latitude/longitude range');await dbPutTile(tile);const st=localElevStateV292();addTileToState(st,tile);st.meta=uniqueTiles(st).map(localElevMetaFor);return tile}
  function valueOk(v,noData){if(!Number.isFinite(v))return false;if(Number.isFinite(noData)&&Math.abs(v-noData)<1e-6)return false;if(v<=-999999||v<=-32768)return false;return true}
  function sampleArrayBilinear(buffer,width,height,col,row,noData,kind){if(!(width>1&&height>1))return null;col=Math.max(0,Math.min(width-1,col));row=Math.max(0,Math.min(height-1,row));let c0=Math.floor(col),r0=Math.floor(row),c1=Math.min(width-1,c0+1),r1=Math.min(height-1,r0+1);const tx=col-c0,ty=row-r0;const vals=(kind==='geotiff')?new Float32Array(buffer):new Int16Array(buffer);function v(r,c){const n=Number(vals[r*width+c]);return valueOk(n,noData)?n:NaN}const v00=v(r0,c0),v10=v(r0,c1),v01=v(r1,c0),v11=v(r1,c1);const good=[v00,v10,v01,v11].filter(Number.isFinite);if(!good.length)return null;if(good.length<4)return good.reduce((a,b)=>a+b,0)/good.length;const a=v00*(1-tx)+v10*tx,b=v01*(1-tx)+v11*tx;return a*(1-ty)+b*ty}
  function sampleElevationTile(tile,lat,lng){try{lat=Number(lat);lng=Number(lng);if(!Number.isFinite(lat)||!Number.isFinite(lng)||!tile)return null;if(lat<Number(tile.lat0)-1e-9||lat>Number(tile.lat1)+1e-9||lng<Number(tile.lon0)-1e-9||lng>Number(tile.lon1)+1e-9)return null;let x,y;if(tile.crsMode==='projected'){if(!window.proj4||!tile.proj4String)return null;const p=window.proj4('WGS84',tile.proj4String,[lng,lat]);x=Number(p[0]);y=Number(p[1])}else{x=lng;y=lat}const width=Number(tile.width||tile.size),height=Number(tile.height||tile.size);const xMin=Number(tile.xMin!=null?tile.xMin:tile.lon0),xMax=Number(tile.xMax!=null?tile.xMax:tile.lon1),yMin=Number(tile.yMin!=null?tile.yMin:tile.lat0),yMax=Number(tile.yMax!=null?tile.yMax:tile.lat1);if(![x,y,xMin,xMax,yMin,yMax].every(Number.isFinite)||x<xMin-1e-9||x>xMax+1e-9||y<yMin-1e-9||y>yMax+1e-9)return null;const col=(x-xMin)/(xMax-xMin)*(width-1);const row=(yMax-y)/(yMax-yMin)*(height-1);return sampleArrayBilinear(tile.buffer,width,height,col,row,Number(tile.noData),tile.sourceType||tile.kind)}catch(_){return null}}
  function tileForLocalPointV292(lat,lng){try{const st=localElevStateV292();const tiles=uniqueTiles(st).filter(t=>sampleBoundsContains(t,lat,lng));if(!tiles.length)return null;tiles.sort((a,b)=>tileResolution(a)-tileResolution(b));return tiles[0]}catch(_){return null}}
  function sampleBoundsContains(t,lat,lng){lat=Number(lat);lng=Number(lng);return t&&Number.isFinite(lat)&&Number.isFinite(lng)&&lat>=Number(t.lat0)-1e-9&&lat<=Number(t.lat1)+1e-9&&lng>=Number(t.lon0)-1e-9&&lng<=Number(t.lon1)+1e-9}
  function tileResolution(t){const w=Math.max(2,Number(t.width||t.size)||2),h=Math.max(2,Number(t.height||t.size)||2);const dy=Math.abs((Number(t.lat1)-Number(t.lat0))/(h-1));const dx=Math.abs((Number(t.lon1)-Number(t.lon0))/(w-1));return Math.max(dx||999,dy||999)}
  function sourceSummary(used){const types={};used.forEach(id=>{try{const t=localElevStateV292().tiles.get(id);const typ=t&&(t.type||t.sourceType)||'Elevation';types[typ]=(types[typ]||0)+1}catch(_){}});const parts=Object.keys(types).map(k=>k+' '+types[k]);return parts.length?parts.join(' · '):'local elevation'}
  async function sampleElevationsLocalV292(points,opts){opts=opts||{};await loadLocalElevationTilesV292();const st=localElevStateV292();const pointCount=(typeof viewshedPointCount==='function')?viewshedPointCount(points):((points||[]).length||0);const out=new Float32Array(pointCount);let valid=0,min=Infinity,max=-Infinity,missing=0;const used=new Set();if(!uniqueTiles(st).length)return {ok:false,source:'Local elevation data unavailable: no local SRTM/DTED/GeoTIFF DEM files imported',elev:null};for(let i=0;i<pointCount;i++){const p=(typeof viewshedPointAt==='function')?viewshedPointAt(points,i):points[i];const tile=p?tileForLocalPointV292(p.lat,p.lng):null;let h=tile?sampleElevationTile(tile,p.lat,p.lng):null;if(Number.isFinite(h)){out[i]=h;valid++;used.add(tile.id);if(h<min)min=h;if(h>max)max=h}else{out[i]=0;missing++}if(i%25000===0&&field('viewshedStatus')){const pct=Math.min(99,Math.round((i/Math.max(1,pointCount))*100));field('viewshedStatus').textContent='Sampling elevation (Local DEM)... '+pct+'%'}if(i%50000===0)await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;const cov=Math.round((valid/Math.max(1,pointCount))*100);return {ok:valid>0,cached:false,source:'Local DEM · '+sourceSummary(used)+' · '+cov+'% coverage'+(spread<0.5?' · flat/low variation':''),elev:out,valid,spread,coverage:cov,missing}}
  window.importHgtFile=importHgtFileV292;window.importDtedFile=importDtedFile;window.importGeoTiffFile=importGeoTiffFile;window.sampleElevationsLocal=sampleElevationsLocalV292;window.tileForLocalPoint=tileForLocalPointV292;window.sampleLocalElevationAt=function(lat,lng){const t=tileForLocalPointV292(lat,lng);return t?sampleElevationTile(t,lat,lng):null};
  async function importLocalElevationFilesV292(files){ensureDialogV292();files=[...(files||[])];let ok=0,failed=[],warnings=[];const stat=field('localElevStatus');for(const f of files){const name=String(f.name||'');try{if(/\.hgt$/i.test(name)){if(stat)stat.textContent='Importing '+name+'...';await importHgtFileV292(f);ok++}
        else if(/\.(dt0|dt1|dt2)$/i.test(name)){if(stat)stat.textContent='Importing '+name+'...';await importDtedFile(f);ok++}
        else if(/\.(tif|tiff)$/i.test(name)){if(f.size>WARN_MB*MB)warnings.push(name+' is '+Math.round(f.size/MB)+' MB');if(stat)stat.textContent='Importing '+name+'...';await importGeoTiffFile(f);ok++}
        else if(/\.zip$/i.test(name)){failed.push(name+' — ZIP packages are not supported; extract/import direct elevation files')}
        else{failed.push(name+' — unsupported file type')}}catch(e){failed.push(name+' — '+String(e&&e.message||e))}await new Promise(r=>setTimeout(r,0))}
    const parts=['Imported '+ok+' elevation file'+(ok===1?'':'s')+'.'];if(warnings.length)parts.push('Warnings: '+warnings.join('; '));if(failed.length)parts.push('Failed files:\n- '+failed.join('\n- '));setElevStatus(parts.join('\n'),failed.length>0);updateLocalElevationUiV292(null,failed.length>0);return {ok,failed,warnings}}
  window.importLocalElevationFiles=importLocalElevationFilesV292;
  function fileSupported(name){return /\.(hgt|dt0|dt1|dt2|tif|tiff)$/i.test(String(name||''))}
  function localElevFileSupportLabelV292(name){name=String(name||'');if(/\.hgt$/i.test(name))return 'SRTM HGT · ready';if(/\.(dt0|dt1|dt2)$/i.test(name))return 'DTED · ready';if(/\.(tif|tiff)$/i.test(name))return 'USGS 3DEP GeoTIFF/COG DEM · ready';if(/\.zip$/i.test(name))return 'ZIP not supported; extract first';return 'unsupported'}
  window.localElevFileSupportLabel=localElevFileSupportLabelV292;
  function renderLocalElevationSelectedV292(){try{const box=field('localElevSelected');if(!box)return;const files=(localElevStateV292().pendingFiles||[]);if(!files.length){box.textContent='No selected files.';return}box.innerHTML=files.map(f=>{const name=String(f.name||'file'),label=localElevFileSupportLabelV292(name);const dim=fileSupported(name)?'':' style="color:#ff9b8a"';return `<div${dim}>- ${esc(name)} <span class="muted">(${esc(label)})</span></div>`}).join('')}catch(e){console.warn('render local elevation selected failed',e)}}
  window.renderLocalElevationSelected=renderLocalElevationSelectedV292;
  function updateLocalElevImportButtonV292(){try{const b=field('localElevImport');if(!b)return;const files=(localElevStateV292().pendingFiles||[]);const supported=files.filter(f=>fileSupported(f&&f.name)).length;b.disabled=!supported;b.textContent='Import'}catch(_){} }
  window.updateLocalElevImportButton=updateLocalElevImportButtonV292;
  function setElevStatus(msg,isError){try{const el=field('localElevStatus');if(!el)return;el.textContent=msg||'';el.classList.toggle('error',!!isError);el.classList.toggle('ok',!isError&&!!msg)}catch(_){} }
  function updateLocalElevationUiV292(msg,isError){try{const st=localElevStateV292();const list=field('localElevList');const tiles=uniqueTiles(st);if(field('localElevToolStatus'))field('localElevToolStatus').textContent='Local: '+tiles.length;if(msg!=null)setElevStatus(msg,isError);else if(field('localElevStatus')&&!field('localElevStatus').textContent)setElevStatus(tiles.length?('Loaded '+tiles.length+' local elevation file'+(tiles.length===1?'':'s')+'.'):'No local elevation data loaded yet.',false);if(list){list.innerHTML=tiles.length?tiles.map(t=>{const wh=(t.width||t.size||'?')+'×'+(t.height||t.size||'?');const bounds=(Number.isFinite(Number(t.lat0))&&Number.isFinite(Number(t.lon0)))?(' · '+Number(t.lat0).toFixed(4)+','+Number(t.lon0).toFixed(4)+' to '+Number(t.lat1).toFixed(4)+','+Number(t.lon1).toFixed(4)):'';return '<div>'+esc(t.name||t.id)+' · '+esc(t.type||'Elevation')+' · '+wh+bounds+'</div>'}).join(''):'<div>No local files indexed.</div>'}}catch(e){console.warn('update local elevation ui failed',e)} }
  window.updateLocalElevationUi=updateLocalElevationUiV292;
  function ensureDialogV292(){try{if(typeof ensureLocalElevationDialog==='function')ensureLocalElevationDialog();const d=field('localElevationDialog');if(!d)return;const head=q('.local-elev-head',d),close=field('localElevClose'),body=q('.local-elev-body',d);if(head){head.style.position='relative';head.style.paddingRight='38px'}if(close){close.setAttribute('type','button');close.setAttribute('aria-label','Close');close.textContent='×';close.onclick=closeDialog;close.addEventListener('click',closeDialog,true)}if(body&&!field('localElevCompatText')){body.insertAdjacentHTML('afterbegin','<div id="localElevCompatText" class="local-elev-compat"><b>'+esc(COMPAT)+'</b><br><span>'+esc(WARN)+'</span><br><span>'+esc(DIRECT)+'</span></div>')}const input=field('localElevFileInput');if(input){input.accept='.hgt,.dt0,.dt1,.dt2,.tif,.tiff';input.onchange=(ev)=>{const st=localElevStateV292();st.pendingFiles=[...(ev.target.files||[])];renderLocalElevationSelectedV292();updateLocalElevImportButtonV292();const supported=st.pendingFiles.filter(f=>fileSupported(f.name)).length;const unsupported=st.pendingFiles.length-supported;setElevStatus(st.pendingFiles.length?('Selected '+st.pendingFiles.length+' file'+(st.pendingFiles.length===1?'':'s')+'. '+supported+' importable, '+unsupported+' unsupported. Click Import to continue.'):'No selected files.',unsupported>0);ev.target.value='';};}
      const imp=field('localElevImport');if(imp){imp.textContent='Import';imp.onclick=async()=>{const st=localElevStateV292();await importLocalElevationFilesV292(st.pendingFiles||[]);st.pendingFiles=[];renderLocalElevationSelectedV292();updateLocalElevImportButtonV292();};}
      const choose=field('localElevChoose');if(choose)choose.textContent='Choose Files';const clear=field('localElevClear');if(clear)clear.textContent='Clear';const title=q('.local-elev-head h2',d);if(title)title.textContent='Add Elevation Data';const spans=qa('.local-elev-format-list span',d);const labels=['SRTM HGT (.hgt) · Ready','DTED (.dt0/.dt1/.dt2) · Ready','USGS 3DEP GeoTIFF/COG DEM (.tif/.tiff) · Ready','ZIP packages · Not supported'];spans.forEach((el,i)=>{if(labels[i])el.textContent=labels[i]});}catch(e){console.warn('v292 dialog ensure failed',e)} }
  function closeDialog(ev){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}}catch(_){}const d=field('localElevationDialog');if(d){d.classList.remove('active');d.style.display='none';d.style.visibility='hidden';d.style.opacity='0';d.style.pointerEvents='none'}return false}
  function centerDialogV292(){try{ensureDialogV292();const d=field('localElevationDialog');if(!d||!d.classList.contains('active'))return false;if(d.parentElement!==document.body)document.body.appendChild(d);d.style.position='fixed';d.style.inset='0';d.style.zIndex='2920';d.style.display='flex';d.style.alignItems='center';d.style.justifyContent='center';d.style.padding='16px';d.style.visibility='visible';d.style.opacity='1';d.style.pointerEvents='auto';const card=q('.local-elev-card',d),body=q('.local-elev-body',d),close=field('localElevClose');if(card){card.style.position='relative';card.style.left='auto';card.style.top='auto';card.style.right='auto';card.style.bottom='auto';card.style.margin='auto';card.style.width='min(500px, calc(100vw - 32px))';card.style.maxHeight='calc(100vh - 32px)';card.style.zIndex='2921'}if(body){body.style.maxHeight='calc(100vh - 80px)';body.style.overflowY='auto'}if(close){close.style.position='absolute';close.style.top='7px';close.style.right='8px';close.style.zIndex='2922';close.style.display='inline-flex'}return true}catch(e){console.warn('v292 center dialog failed',e);return false}}
  function addCss(){try{if(field('v292ElevationCompatStyle'))return;const st=document.createElement('style');st.id='v292ElevationCompatStyle';st.textContent=`
    #localElevationDialog .local-elev-compat{margin:0 0 8px!important;padding:7px 8px!important;border:1px solid rgba(255,111,46,.22)!important;border-radius:10px!important;background:rgba(255,111,46,.075)!important;color:#dce9ee!important;font-size:.64rem!important;line-height:1.28!important;}
