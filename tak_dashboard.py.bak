  function stableSetterInstall(){try{if(window._v294StableAircraftInstalled)return;let current=(Array.isArray(window.lastAircraft)?window.lastAircraft:[]).map(norm).filter(validAircraft);let lastGoodAt=current.length?Date.now():0;let suppressed=0;window._v294StableAircraftInstalled=true;Object.defineProperty(window,'lastAircraft',{configurable:true,enumerable:true,get(){return current},set(v){let arr=Array.isArray(v)?v.map(norm).filter(validAircraft):[];const prev=current.length, n=arr.length, now=Date.now();const adsbOff=(localStorage.getItem('takmap.adsb.localDisabled')==='1')||!!(window.state&&state.live&&state.live.adsb_aircraft===false);const suspicious=!adsbOff && prev>=AD_MIN_PREV && n<Math.max(3,Math.floor(prev*.25)) && (now-lastGoodAt)<AD_DROP_GRACE_MS;if(suspicious){suppressed++;window._v294LastSuppressedAdsb={count:n,previous:prev,at:now,suppressed};return}current=arr;if(n>0){lastGoodAt=now;suppressed=0}try{window._v294LastStableAdsbAt=lastGoodAt}catch(_){} }});}catch(e){console.warn('v294 stable ADS-B setter failed',e)} }
  function updateBanner(){try{const rows=filteredAircraft();const item=field('bannerAdsbItem');if(item){item.classList.add('status-dropdown-trigger');item.setAttribute('data-status-type','adsb');item.removeAttribute('onclick');item.onclick=null}const b=field('bannerAdsb');if(b)b.textContent=rows.length+' Aircraft';const d=field('bannerAdsbDot');if(d)d.className='status-dot '+(rows.length?'good':'unknown');try{if(window.lastBanner)window.lastBanner.adsb_aircraft=rows.length}catch(_){}return rows.length}catch(_){return 0}}
  function statusBox(){let box=field('statusDropdown');if(!box){box=document.createElement('div');box.id='statusDropdown';box.className='status-dropdown';document.body.appendChild(box)}return box}
  function closeDropdown(){const box=field('statusDropdown');if(!box)return;box.classList.remove('active','open');box.style.display='none';box.style.visibility='hidden'}
