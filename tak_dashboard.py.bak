  const trackLines=new Map();
  function q(sel,root=document){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root=document){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.registration||a.callsign))||'').trim().toLowerCase()}
  function classKey(v){const s=String(v||'').trim().toLowerCase();if(s==='gov'||s==='govt'||s==='government')return 'govt';if(s==='mil'||s==='military'||s.includes('military'))return 'military';if(s==='unk'||s==='unknown')return 'unknown';if(s==='civil'||s==='civilian'||s.includes('commercial'))return 'civil';return s||'unknown'}
  function classLabel(v){return ({govt:'Govt',military:'Military',civil:'Civil',unknown:'Unknown'}[classKey(v)]||'Unknown')}
  function classColor(v){return COLORS[classKey(v)]||COLORS.unknown}
  function textBlob(a){try{return [a&&a.category,a&&a.emitter_category,a&&a.t,a&&a.type,a&&a.aircraft_type,a&&a.desc,a&&a.description,a&&a.model,a&&a.flight,a&&a.callsign,a&&a.r,a&&a.registration,a&&a.ownOp,a&&a.operator,a&&a.owner].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function isHelicopter(a){
    const cat=String((a&&(a.category_raw||a.adsb_category||a.emitter_category||a.category_code||a.category))||'').trim().toUpperCase();
    if(cat==='A7') return true;
    if(a&&(a.is_helo===true||a.is_rotor===true||a.rotor===true)) return true;
    const b=textBlob(a);
    if(/\b(A7|ROTOR|ROTORCRAFT|ROTARY|HELICOPTER|HELI|HELO|GYRO)\b/.test(b)) return true;
    if(/\b(H60|UH60|MH60|HH60|SH60|CH47|AH64|OH58|CH53|UH1|UH72|V22|B206|B407|B412|B429|B505|R22|R44|R66|S76|S92|AS50|AS350|AS355|EC35|EC45|EC120|EC130|EC135|EC145|H125|H130|H135|H145|H155|AW109|AW119|AW139|AW169|AW189|MD50|MD52|MD60)\b/.test(b)) return true;
    if(/\b(BELL|ROBINSON|SIKORSKY|AIRBUS HELICOPTERS|EUROCOPTER|AGUSTA|LEONARDO HELICOPTERS)\b/.test(b)) return true;
    return false;
  }
  function normalizeAircraft(a){
    try{
      if(!a||typeof a!=='object')return a;
