_v276_js = '\n/* v276 ADS-B performance/layout, single transient drawing dialog, no broad boot loop */\n(function(){\n  const V=\'v276\';\n  const $=id=>document.getElementById(id);\n  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};\n  let refreshTimer=null, refreshBusy=false, refreshQueued=false, lastSearchRebuild=0;\n  function addCss(){try{if($(\'v276Style\'))return;const css=`\n    .aircraft-wrap,.aircraft-wrap.v270-adsb,.aircraft-wrap.v240-adsb,.leaflet-marker-icon .aircraft-wrap{filter:none!important;text-shadow:none!important;box-shadow:none!important;background:transparent!important;}\n    .aircraft-wrap::before,.aircraft-wrap::after,.aircraft-glyph::before,.aircraft-glyph::after,.adsb-png-icon::before,.adsb-png-icon::after{display:none!important;content:none!important;box-shadow:none!important;filter:none!important;}\n    .aircraft-glyph,.aircraft-glyph.selected,.adsb-png-icon,.aircraft-wrap img{filter:none!important;drop-shadow:none!important;box-shadow:none!important;text-shadow:none!important;outline:none!important;}\n    .aircraft-label{box-shadow:none!important;text-shadow:none!important;background:rgba(5,8,12,.86)!important;border:1px solid rgba(255,255,255,.10)!important;}\n    .leaflet-popup.adsb-object-popup .leaflet-popup-content-wrapper,.leaflet-popup.tak-object-popup .leaflet-popup-content-wrapper{background:linear-gradient(180deg,rgba(11,18,25,.98),rgba(5,9,14,.99))!important;color:#eaf2f5!important;border:1px solid rgba(255,255,255,.16)!important;border-radius:12px!important;box-shadow:0 14px 34px rgba(0,0,0,.56)!important;}\n    .leaflet-popup.adsb-object-popup .leaflet-popup-tip,.leaflet-popup.tak-object-popup .leaflet-popup-tip{background:rgba(7,12,18,.99)!important;border:1px solid rgba(255,255,255,.12)!important;box-shadow:none!important;}\n    #adsbV275CenterBlock{display:grid!important;gap:7px!important;margin:6px 0 8px!important;min-height:92px!important;contain:layout paint!important;}\n    #adsbV275CenterBlock .adsb-v275-row.top{grid-template-columns:1fr!important;}\n    #adsbV275CenterBlock .adsb-v275-row.actions{display:flex!important;justify-content:flex-start!important;align-items:center!important;gap:8px!important;}\n    #adsbV275CenterBlock .follow,#adsbFollowMapCenter,#adsbRefreshV275{display:none!important;}\n    #adsbV275CenterBlock select,#adsbV275CenterBlock input[type=text]{height:31px!important;min-height:31px!important;}\n    #adsbV270Menu button[onclick*="refreshAdsb"],#adsbV270Menu #adsbRefreshV275,#adsbTestBtn{display:none!important;}\n    .adsb-v276-stepper{display:grid!important;grid-template-columns:minmax(0,1fr) 24px!important;align-items:stretch!important;width:100%!important;background:#091018!important;border:1px solid #334553!important;border-radius:10px!important;overflow:hidden!important;}\n    .adsb-v276-stepper input[type=number]{border:0!important;background:transparent!important;border-radius:0!important;min-height:30px!important;padding:6px 8px!important;color:var(--text)!important;width:100%!important;appearance:textfield!important;-moz-appearance:textfield!important;}\n    .adsb-v276-stepper input[type=number]::-webkit-outer-spin-button,.adsb-v276-stepper input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none!important;margin:0!important;}\n    .adsb-v276-stepper-controls{display:grid!important;grid-template-rows:1fr 1fr!important;border-left:1px solid rgba(255,255,255,.11)!important;background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(0,0,0,.06))!important;}\n    .adsb-v276-stepper-controls button{width:24px!important;min-width:24px!important;height:15px!important;min-height:15px!important;margin:0!important;padding:0!important;border:0!important;border-radius:0!important;background:transparent!important;color:#a9bac4!important;font-size:9px!important;line-height:14px!important;font-weight:800!important;cursor:pointer!important;box-shadow:none!important;}\n    .adsb-v276-stepper-co