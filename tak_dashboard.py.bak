  function mapObj(){try{if(typeof map!=='undefined'&&map)return map}catch(_){}return window.map||window.takLeafletMap||null}
  function installPopupCloseGuard(){try{if(window.__v319AdsbPopupCloseGuard)return;window.__v319AdsbPopupCloseGuard=true;document.addEventListener('click',function(ev){const btn=ev.target&&ev.target.closest&&ev.target.closest('.leaflet-popup.adsb-object-popup .leaflet-popup-close-button,.leaflet-popup.adsb-v319-popup .leaflet-popup-close-button');if(!btn)return;ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){}try{const m=mapObj();if(m&&m.closePopup)m.closePopup()}catch(_){}return false},true)}catch(e){console.warn('v319 ADS-B popup close guard failed',e)}}
  function installDropdownFallback(){try{if(window.__v319AdsbDropdownFallback)return;window.__v319AdsbDropdownFallback=true;document.addEventListener('click',function(ev){const item=ev.target&&ev.target.closest&&ev.target.closest('#bannerAdsbItem');if(!item)return;setTimeout(function(){try{const box=byId('statusDropdown');if(!box||!box.classList.contains('active'))return;const r=item.getBoundingClientRect();const w=Math.min(560,Math.max(360,box.offsetWidth||360),(window.innerWidth||900)-16);box.style.minWidth=Math.min(500,w)+'px';box.style.maxWidth=w+'px';box.style.display='block';box.style.visibility='visible';box.style.left=Math.max(8,Math.min((window.innerWidth||900)-w-8,r.left))+'px';box.style.top=Math.max(54,r.bottom+8)+'px'}catch(_){}} ,0)},true)}catch(e){console.warn('v319 ADS-B dropdown fallback failed',e)}}

  function currentViewer(){try{return (typeof terrain3DViewer!=='undefined'&&terrain3DViewer)||window.terrain3DViewer||null}catch(_){return window.terrain3DViewer||null}}
  function localState(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};if(!(window.takLocalElevation.tiles instanceof Map))window.takLocalElevation.tiles=new Map();return window.takLocalElevation}
  function uniqueTiles(){try{return [...(localState().tiles||new Map()).values()].filter(function(v,i,a){return v&&v.id&&a.findIndex(function(x){return x&&x.id===v.id})===i})}catch(_){return []}}
  function tileBounds(t){try{let south=Number(t.lat0),north=Number(t.lat1),west=Number(t.lon0),east=Number(t.lon1);if(!Number.isFinite(south)||!Number.isFinite(west))return null;if(!Number.isFinite(north))north=south+1;if(!Number.isFinite(east))east=west+1;const ss=Math.max(-90,Math.min(south,north)),nn=Math.min(90,Math.max(south,north)),ww=Math.max(-180,Math.min(west,east)),ee=Math.min(180,Math.max(west,east));if(!(nn>ss&&ee>ww))return null;return {south:ss,north:nn,west:ww,east:ee}}catch(_){return null}}
  function sourceIsLocal(){return String(window.terrain3DElevationSource||localStorage.getItem('takMapTerrainElevationSource')||'streamed').toLowerCase()==='local'}
  async function ensureLocalTiles(){try{if(typeof window.loadLocalElevationTiles==='function')await window.loadLocalElevationTiles();if(uniqueTiles().some(function(t){return String(t.crsMode||'').toLowerCase()==='projected'&&t.proj4String})&&!window.proj4){await new Promise(function(res,rej){const s=document.createElement('script');s.src='/assets/vendor/proj4.js';s.onload=res;s.onerror=rej;document.head.appendChild(s)})}}catch(e){console.warn('v319 local elevation tile load failed',e)}return uniqueTiles()}
  function sampleLocal(lat,lon){try{const h=typeof window.sampleLocalElevationAt==='function'?window.sampleLocalElevationAt(lat,lon):null;const n=Number(h);return Number.isFinite(n)?n:null}catch(_){return null}}
  function localGridSize(){try{const qv=String((byId('terrain3dQuality')||{}).value||window.terrain3DQuality||'medium').toLowerCase();return qv==='high'?65:(qv==='low'?33:49)}catch(_){return 49}}
  function clearLocalMesh(){try{const viewer=currentViewer();const arr=window._v319LocalMeshPrimitives||[];if(viewer&&viewer.scene&&viewer.scene.primitives){arr.forEach(function(p){try{viewer.scene.primitives.remove(p)}catch(_){}})}window._v319LocalMeshPrimitives=[];try{viewer&&viewer.scene&&viewer.scene.requestRender&&viewer.scene.requestRender()}catch(_){}}catch(_){}}
  function setMeshChip(msg,bad){try{let chip=byId('terrain3dLocalMeshChip');const panel=q('.terrain3d-controls');if(panel&&!chip){chip=document.createElement('div');chip.id='terrain3dLocalMeshChip';chip.className='terrain3d-local-mesh-chip';panel.appendChild(chip)}if(chip){chip.textContent=msg||'';chip.classList.toggle('bad',!!bad)}}catch(_){}}
  function addTerrainCss(){try{if(byId('v319LocalTerrainStyle'))return;const st=document.createElement('style');st.id='v319LocalTerrainStyle';st.textContent='.terrain3d-local-mesh-chip{font-size:.62rem;color:#b7c7ce;line-height:1.25;margin-top:2px;white-space:normal;max-width:260px}.terrain3d-local-mesh-chip.bad{color:#ff9b8a!important}';document.head.appendChild(st)}catch(_){}}
  function makeTileMesh(Cesium,tile,idx,grid){const b=tileBounds(tile);if(!b)return null;const pos=[];const indices=[];let valid=0,min=Infinity,max=-Infinity;for(let r=0;r<grid;r++){const lat=b.north-(b.north-b.south)*(r/(grid-1));for(let c=0;c<grid;c++){const lon=b.west+(b.east-b.west)*(c/(grid-1));let h=sampleLocal(lat,lon);if(!Number.isFinite(h))h=0;else{valid++;if(h<min)min=h;if(h>max)max=h}const cart=Cesium.Cartesian3.fromDegrees(lon,lat,h);pos.push(cart.x,cart.y,cart.z)}}for(let r=0;r<grid-1;r++){for(let c=0;c<grid-1;c++){const i=r*grid+c;indices.push(i,i+1,i+grid,i+1,i+grid+1,i+grid)}}if(!valid)return null;const values=new Float64Array(pos);const ind=(values.length/3>65535)?new Uint32Array(indices):new Uint16Array(indices);const geom=new Cesium.Geometry({attributes:{position:new Cesium.GeometryAttribute({componentDatatype:Cesium.ComponentDatatype.DOUBLE,componentsPerAttribute:3,values:values})},indices:ind,primitiveType:Cesium.PrimitiveType.TRIANGLES,boundingSphere:Cesium.BoundingSphere.fromVertices(values)});const color=(Cesium.Color&&Cesium.Color.fromCssColorString?Cesium.Color.fromCssColorString('#ff6f2e').withAlpha(.32):undefined);const inst=new Cesium.GeometryInstance({geometry:geom,attributes:color?{color:Cesium.ColorGeometryInstanceAttribute.fromColor(color)}:{},id:'local-dem-mesh-v319-'+String(tile.id||idx)});const prim=new Cesium.Primitive({geometryInstances:inst,appearance:new Cesium.PerInstanceColorAppearance({flat:false,translucent:true,closed:false}),asynchronous:false});prim._takLocalDemMesh=true;prim._takValid=valid;prim._takMin=min;prim._takMax=max;return prim}
  async function renderLocalDemMesh(){try{const viewer=currentViewer();if(!viewer||!window.Cesium)return;const Cesium=window.Cesium;if(!sourceIsLocal()){clearLocalMesh();setMeshChip('');return}const tiles=await ensureLocalTiles();clearLocalMesh();if(!tiles.length){setMeshChip('Local DEM: no imported files',true);try{if(typeof window.terrainStatus==='function')window.terrainStatus('Terrain Mode · Local DEM selected · no imported elevation files found',true)}catch(_){}return}const grid=localGridSize();const prims=[];let validTiles=0;for(let i=0;i<tiles.length;i++){const prim=makeTileMesh(Cesium,tiles[i],i,grid);if(prim){viewer.scene.primitives.add(prim);prims.push(prim);validTiles++}if(i%2===0)await new Promise(function(r){setTimeout(r,0)})}window._v319LocalMeshPrimitives=prims;setMeshChip(validTiles?('Local DEM mesh: '+validTiles+'/'+tiles.length+' file'+(tiles.length===1?'':'s')+' rendered'):'Local DEM mesh: no valid samples found',!validTiles);try{if(typeof window.terrainStatus==='function')window.terrainStatus(validTiles?('Terrain Mode · Local DEM mesh · '+validTiles+' coverage area'+(validTiles===1?'':'s')+' · Outside coverage flat'):'Terrain Mode · Local DEM has no valid samples',!validTiles)}catch(_){}try{viewer.scene.globe.depthTestAgainstTerrain=false;viewer.scene.requestRender&&viewer.scene.requestRender()}catch(_){}}catch(e){console.warn('v319 render local DEM mesh failed',e);setMeshChip('Local DEM mesh failed: '+String(e&&e.message||e),true)}}
  function patchTerrainHooks(){try{if(window.__v319TerrainHooks)return;window.__v319TerrainHooks=true;const oldSet=window.setTerrain3DElevationSource;window.setTerrain3DElevationSource=function(v){let r;if(typeof oldSet==='function')r=oldSet.apply(this,arguments);else{window.terrain3DElevationSource=String(v||'streamed').toLowerCase();localStorage.setItem('takMapTerrainElevationSource',window.terrain3DElevationSource)}setTimeout(renderLocalDemMesh,80);setTimeout(renderLocalDemMesh,600);return r};const oldRefresh=window.refreshTerrain3DAll;if(typeof oldRefresh==='function'){window.refreshTerrain3DAll=function(){const r=oldRefresh.apply(this,arguments);setTimeout(renderLocalDemMesh,180);setTimeout(renderLocalDemMesh,1000);return r}}const oldQuality=window.setTerrain3DQuality;if(typeof oldQuality==='function'){window.setTerrain3DQuality=function(v){const r=oldQuality.apply(this,arguments);setTimeout(renderLocalDemMesh,180);return r}}const oldUi=window.updateLocalElevationUi;if(typeof oldUi==='function'){window.updateLocalElevationUi=function(){const r=oldUi.apply(this,arguments);setTimeout(renderLocalDemMesh,180);return r}}const oldEnsure=window.ensureTerrain3DViewer;if(typeof oldEnsure==='function'&&!oldEnsure.__v319Wrapped){const wrapped=async function(){const viewer=await oldEnsure.apply(this,arguments);setTimeout(renderLocalDemMesh,120);setTimeout(renderLocalDemMesh,800);return viewer};wrapped.__v319Wrapped=true;window.ensureTerrain3DViewer=wrapped}window.renderTakMapLocalTerrainMesh=renderLocalDemMesh}catch(e){console.warn('v319 terrain hook patch failed',e)}}
  function boot(){setVersion();installPopupCloseGuard();installDropdownFallback();addTerrainCss();patchTerrainHooks();if(sourceIsLocal())renderLocalDemMesh()}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',function(){setTimeout(boot,140)},{once:true});else setTimeout(boot,140);
  [700,1800,3600,7000].forEach(function(ms){setTimeout(boot,ms)});setInterval(function(){setVersion();if(sourceIsLocal())renderLocalDemMesh()},7000);
})();
</script>
'''
        if 'id="v319AdsbTerrainRuntimeFixes"' not in _html:
