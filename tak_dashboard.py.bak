        if not isinstance(_html, str):
            return _html
        _html = _v320_versions(_html)
        # Remove the manual ADS-B Save Filter control; settings now autosave/apply on update.
        _html = _v320_re.sub(r'<button\b[^>]*(?:saveAdsbSettings|Save Filter)[\s\S]*?</button>', '', _html, flags=_v320_re.I)
        _html = _v320_re.sub(r'<[^>]+>\s*Save\s+Filter\s*</[^>]+>', '', _html, flags=_v320_re.I)

        _runtime = r"""
<script id="v320PopupDrawingTerrainAdsbFixes">
(function(){
  'use strict';
  const V='v320';
  const d=document;
  function byId(id){try{return d.getElementById(id)}catch(_){return null}}
  function q(sel,root){try{return (root||d).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||d).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>\"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[c]})}
  function fmt(v){const n=Number(v);return Number.isFinite(n)?n.toFixed(6):''}
  function present(v){return v!==undefined&&v!==null&&String(v).trim()!==''}
  function isPointCat(cat){return /point/i.test(String(cat||''))}
  function isRouteCat(cat){return /route/i.test(String(cat||''))}
  function isShapeCat(cat){return /shape|area|polygon|rectangle|circle|ellipse/i.test(String(cat||''))}
  function getMap(){try{if(typeof map!=='undefined'&&map)return map}catch(_){}return window.map||window.takLeafletMap||null}
  function expose(name,fn){try{window[name]=fn}catch(_){}try{window.eval(name+'=window["'+name+'"]')}catch(_){} }
  function setVersion(){qa('.iteration-chip,.iteration-marker,[data-iteration]').forEach(function(el){try{el.textContent=V;el.setAttribute('data-iteration',V)}catch(_){}})}

  function classifySource(source){const s=String(source||'').toLowerCase();if(/data|sync|mission|collection/.test(s))return 'Data Sync';if(/import|local/.test(s))return 'Local Data';return source||'Map Data'}
  function sourceKey(o,source){return String((o&&(o.uid||o.id||o.key||o.name||o.title||o.callsign||o.label))||source||'object')}
  function localId(o){try{if(!o)return ''; if(o._local_id)return String(o._local_id); if(o.local_id)return String(o.local_id); if(o.import_id!==undefined&&o.import_feature_index!==undefined)return String(o.import_id)+':'+String(o.import_feature_index); if(o.import_name&&o.import_feature_index!==undefined)return String(o.import_name)+':'+String(o.import_feature_index)}catch(_){}return ''}
  function objectName(o){return (o&&(o.name||o.title||o.callsign||o.label||o.uid||o.id))||'Object'}
  function coordsText(o){try{if(!o)return '';let lat=o.lat,lon=o.lon;if((!Number.isFinite(Number(lat))||!Number.isFinite(Number(lon)))&&Array.isArray(o.coords)&&o.coords.length){lat=o.coords[0][0];lon=o.coords[0][1]}if((!Number.isFinite(Number(lat))||!Number.isFinite(Number(lon)))&&Array.isArray(o.points)&&o.points.length){lat=o.points[0].lat||o.points[0][0];lon=o.points[0].lon||o.points[0][1]}return fmt(lat)+(fmt(lat)&&fmt(lon)?', ':'')+fmt(lon)}catch(_){return ''}}
  function addedText(o){return (o&&(o.added||o.created||o.time||o.timestamp||o.uploaded||o.updated))||''}
  function notesText(o){return (o&&(o.notes||o.remarks||o.description||o.desc||o.comment))||''}
  function areaText(o){try{const a=o&&(o.area||o.area_m2||o.areaMeters||o.area_sq_m);const n=Number(a);if(!Number.isFinite(n)||n<=0)return '';return n>=1000000?(n/1000000).toFixed(2)+' km²':Math.round(n).toLocaleString()+' m²'}catch(_){return ''}}
  function pointCount(o){try{if(Array.isArray(o.points))return o.points.length;if(Array.isArray(o.coords))return o.coords.length;if(Array.isArray(o.coordinates))return o.coordinates.length}catch(_){}return ''}
  function row(k,v){if(!present(v))return '';return '<div><b>'+esc(k)+'</b><span>'+esc(v)+'</span></div>'}
  function basePopup(title,sub,rows,edit){return '<div class="tak-v320-popup adsb-pop"><div class="adsb-pop-title">'+esc(title||'Object')+'</div><div class="adsb-pop-sub">'+esc(sub||'')+'</div><div class="adsb-pop-grid">'+(rows||'')+'</div>'+(edit||'')+'</div>'}

  function popupEditFormV320(o,source){
    o=o||{};source=source||'object';
    const c=coordsText(o);const key=sourceKey(o,source);const lid=localId(o);
    const lat=fmt(o.lat||(Array.isArray(o.coords)&&o.coords[0]&&o.coords[0][0])||'');
    const lon=fmt(o.lon||(Array.isArray(o.coords)&&o.coords[0]&&o.coords[0][1])||'');
    return '<details class="popup-edit tak-v320-edit"><summary>Edit</summary><div class="tak-v320-edit-grid">'
      +'<label>Name<input name="name" value="'+esc(objectName(o))+'"></label>'
      +'<label>Lat/Lon<input name="latlon" value="'+esc(c)+'" placeholder="34.000000, -118.000000"></label>'
      +'<input type="hidden" name="lat" value="'+esc(lat)+'"><input type="hidden" name="lon" value="'+esc(lon)+'">'
      +'<label>Notes<textarea name="notes" rows="2">'+esc(notesText(o))+'</textarea></label>'
      +'</div><div class="tak-v320-edit-actions">'
      +'<button type="button" data-v320-popup-action="save" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Save</button>'
      +'<button type="button" data-v320-popup-action="cancel">Cancel</button>'
      +'<button type="button" class="danger" data-v320-popup-action="delete" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Delete</button>'
      +'</div></details>'
  }
  function pointPopupHtmlV320(o,cat){o=o||{};const rows=row('Affiliation',o.affiliation||o.team||o.group)+row('Added',addedText(o))+row('Coordinates',coordsText(o))+row('Battle Dimension',o.battle_dimension||o.dimension||o.battleDimension)+row('Notes',notesText(o));return basePopup(objectName(o),'Point',rows,popupEditFormV320(o,cat||'Point Markers'))}
  function layerPopupForObjectV320(o,cat){o=o||{};cat=cat||o.category||o.type||'Object';if(isPointCat(cat))return pointPopupHtmlV320(o,cat);let label=isRouteCat(cat)?'Route':(isShapeCat(cat)?'Shape':cat);const rows=row('Added',addedText(o))+row('Coordinates',coordsText(o))+row('Points',pointCount(o))+row('Area',areaText(o))+row('Category',cat)+row('Notes',notesText(o));return basePopup(objectName(o),label,rows,popupEditFormV320(o,cat))}
  function featurePopupHtmlV320(sourceName,props,extra){props=props||{};extra=extra||{};const title=props.name||props.title||props.Name||props.NAME||extra.name||sourceName||'Feature';const cat=props.category||props.Category||extra.category||sourceName||'Feature';const rows=row('Category',cat)+row('Coordinates',extra.coords||props.coordinates)+row('Notes',props.notes||props.description||props.desc||extra.notes);return basePopup(title, classifySource(sourceName), rows,'')}

  function installPopupOverrides(){
    expose('popupEditForm',popupEditFormV320);expose('pointPopupHtml',pointPopupHtmlV320);expose('layerPopupForObject',layerPopupForObjectV320);expose('featurePopupHtml',featurePopupHtmlV320);
    if(window.__v320PopupInstalled)return;window.__v320PopupInstalled=true;
    const css=d.createElement('style');css.id='v320PopupStyle';css.textContent=`
.leaflet-popup.tak-v320-object-popup .leaflet-popup-content-wrapper,.leaflet-popup.adsb-object-popup .leaflet-popup-content-wrapper{background:linear-gradient(180deg,rgba(13,27,34,.96),rgba(7,16,21,.96))!important;color:#dbe9ef!important;border:1px solid rgba(117,190,214,.34)!important;border-radius:14px!important;box-shadow:0 18px 40px rgba(0,0,0,.42)!important;backdrop-filter:blur(10px)!important}.leaflet-popup.tak-v320-object-popup .leaflet-popup-content{margin:0!important;min-width:230px!important;max-width:310px!important}.tak-v320-popup{font-size:.76rem;line-height:1.25;padding:10px 11px 9px}.tak-v320-popup .adsb-pop-title{font-size:.9rem;font-weight:700;color:#f4fbff;letter-spacing:.02em;margin:0 24px 2px 0}.tak-v320-popup .adsb-pop-sub{font-size:.68rem;color:#95aeb8;margin-bottom:7px}.tak-v320-popup .adsb-pop-grid{display:grid;gap:4px;margin-top:4px}.tak-v320-popup .adsb-pop-grid>div{display:grid;grid-template-columns:minmax(78px,.78fr) minmax(0,1.22fr);gap:8px;align-items:start;border-top:1px solid rgba(117,190,214,.12);padding-top:4px}.tak-v320-popup .adsb-pop-grid b{font-size:.62rem;text-transform:uppercase;letter-spacing:.06em;color:#8eb4c0;font-weight:600}.tak-v320-popup .adsb-pop-grid span{font-size:.72rem;color:#e8f5f8;word-break:break-word}.tak-v320-edit{margin-top:7px;border-top:1px solid rgba(117,190,214,.16);padding-top:5px}.tak-v320-edit summary{cursor:pointer;color:#9fd2e1;font-size:.7rem;text-transform:uppercase;letter-spacing:.08em}.tak-v320-edit-grid{display:grid;gap:5px;margin-top:6px}.tak-v320-edit label{display:grid;gap:2px;font-size:.62rem;color:#8fb0ba;text-transform:uppercase;letter-spacing:.055em}.tak-v320-edit input,.tak-v320-edit textarea{width:100%;box-sizing:border-box;background:rgba(4,11,15,.78);border:1px solid rgba(117,190,214,.28);border-radius:7px;color:#eaf6f8;font:inherit;font-size:.72rem;padding:5px 7px;outline:none;resize:vertical;max-height:60px}.tak-v320-edit-actions{display:flex;gap:5px;justify-content:flex-end;margin-top:7px}.tak-v320-edit-actions button{border:1px solid rgba(117,190,214,.28);background:rgba(10,26,34,.82);color:#dbe9ef;border-radius:7px;padding:4px 7px;font-size:.68rem;font-weight:500;cursor:pointer}.tak-v320-edit-actions button.danger{border-color:rgba(255,117,104,.38);color:#ffb0a8}.leaflet-popup.tak-v320-object-popup .leaflet-popup-close-button,.leaflet-popup.adsb-object-popup .leaflet-popup-close-button{position:absolute!important;right:9px!important;top:8px!important;width:20px!important;height:20px!important;line-height:18px!important;border:1px solid rgba(117,190,214,.35)!important;border-radius:50%!important;background:rgba(6,16,22,.78)!important;color:#dbe9ef!important;font-size:16px!important;text-align:center!important;text-decoration:none!important;display:block!important;z-index:50!important}.leaflet-popup.tak-v320-object-popup .leaflet-popup-tip,.leaflet-popup.adsb-object-popup .leaflet-popup-tip{background:rgba(7,16,21,.96)!important;border:1px solid rgba(117,190,214,.22)!important}`;d.head.appendChild(css);
    d.addEventListener('click',handlePopupClick,true);
    const m=getMap();if(m&&m.on){try{m.on('popupopen',function(ev){setTimeout(function(){markPopup(ev&&ev.popup)},0)})}catch(_){}}
  }
  function markPopup(popup){try{const el=(popup&&popup.getElement&&popup.getElement())||q('.leaflet-popup');if(!el)return;if(q('.tak-v320-popup,.adsb-pop',el))el.classList.add('tak-v320-object-popup','adsb-object-popup');const close=q('.leaflet-popup-close-button',el);if(close){close.innerHTML='×';close.setAttribute('aria-label','Close')}}catch(_){}}
  function closePopupFrom(el){try{const popEl=el&&el.closest&&el.closest('.leaflet-popup');const m=getMap();let p=null;if(m){try{m.eachLayer(function(layer){try{if(layer&&layer.getElement&&layer.getElement()===popEl)p=layer}catch(_){}})}catch(_){};if(!p&&m._popup)p=m._popup;if(p){try{m.removeLayer(p);return true}catch(_){try{if(window.L&&L.Layer&&L.Layer.prototype.remove)L.Layer.prototype.remove.call(p);return true}catch(__){}}}}if(popEl){popEl.remove();return true}}catch(_){}return false}
  function parseLatLon(form){try{const v=(form.querySelector('[name="latlon"]')||{}).value||'';const m=String(v).match(/(-?\d+(?:\.\d+)?)\s*[, ]+\s*(-?\d+(?:\.\d+)?)/);if(m){form.querySelector('[name="lat"]').value=m[1];form.querySelector('[name="lon"]').value=m[2]}}catch(_){} }
  async function postJson(url,payload){const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload||{})});let j={};try{j=await r.json()}catch(_){j={ok:r.ok}}if(!r.ok||j.ok===false)throw new Error(j.error||j.message||('HTTP '+r.status));return j}
  function refreshAfterPopup(){['forceDataSyncSync','refreshDataSync','refreshCot','refreshImports','refreshLocalData','loadLocalData','drawImportedObjects'].forEach(function(n){try{if(typeof window[n]==='function')window[n]()}catch(_){}})}
  async function handlePopupAction(btn){const action=btn.getAttribute('data-v320-popup-action');if(!action)return;const details=btn.closest('details.popup-edit');if(action==='cancel'){try{details&&details.removeAttribute('open')}catch(_){};return}const form=details||btn.closest('.tak-v320-popup')||d;parseLatLon(form);const key=btn.getAttribute('data-popup-key')||'';const source=btn.getAttribute('data-popup-source')||'object';const lid=btn.getAttribute('data-local-id')||'';if(action==='delete'){if(!confirm('Delete this item?'))return;if(lid){await postJson('/api/tak-map/local-data-delete',{ids:[lid]})}else{await postJson('/api/tak-map/popup-edit',{key:key,source:source,delete_item:true})}closePopupFrom(btn);refreshAfterPopup();return}if(action==='save'){const payload={key:key,source:source,name:(form.querySelector('[name="name"]')||{}).value||'',notes:(form.querySelector('[name="notes"]')||{}).value||'',lat:(form.querySelector('[name="lat"]')||{}).value||'',lon:(form.querySelector('[name="lon"]')||{}).value||''};await postJson('/api/tak-map/popup-edit',payload);closePopupFrom(btn);refreshAfterPopup();return}}
  function handlePopupClick(ev){const close=ev.target&&ev.target.closest&&ev.target.closest('.leaflet-popup .leaflet-popup-close-button,.leaflet-popup .adsb-v283-close');if(close){ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){};closePopupFrom(close);return false}const btn=ev.target&&ev.target.closest&&ev.target.closest('[data-v320-popup-action]');if(!btn)return;ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){};handlePopupAction(btn).catch(function(e){alert('Popup update failed: '+(e&&e.message||e))});return false}

  function removeSaveFilterButtons(){qa('button,input').forEach(function(el){try{const txt=(el.textContent||el.value||'').trim();const on=String(el.getAttribute('onclick')||'');if(/save\s*filter/i.test(txt)||/saveAdsbSettings/i.test(on)){el.remove()}}catch(_){}})}
  function adsbIds(){return ['adsbFilterCivil','adsbFilterMilitary','adsbFilterGovt','adsbFilterUnknown']}
  function saveAdsbSoon(){clearTimeout(window.__v320AdsbSaveTimer);window.__v320AdsbSaveTimer=setTimeout(function(){try{if(typeof window.saveAdsbSettings==='function')window.saveAdsbSettings(false)}catch(e){console.warn('v320 ADS-B autosave failed',e)}},220)}
  function redrawAdsbFiltered(){try{window.__takMapAdsbExplicitClear=true;window.__adsbForceClear=true;window.__takMapAllowExternalAdsbDraw=true;if(typeof window.drawAircraft==='function')window.drawAircraft(window.lastAircraft||[]);else if(typeof drawAircraft==='function')drawAircraft(window.lastAircraft||[])}catch(e){console.warn('v320 ADS-B redraw failed',e)}finally{setTimeout(function(){window.__takMapAdsbExplicitClear=false;window.__adsbForceClear=false;window.__takMapAllowExternalAdsbDraw=false},120)}}
  function bindAdsbAutosave(){if(window.__v320AdsbAutosaveBound)return;window.__v320AdsbAutosaveBound=true;adsbIds().forEach(function(id){const el=byId(id);if(!el)return;el.addEventListener('change',function(){try{localStorage.setItem('takMapAdsbFilter.'+id,el.checked?'1':'0')}catch(_){};redrawAdsbFiltered();saveAdsbSoon()},true)});['adsbRadius','adsbUpdateInterval','adsbSourceMode','adsbCenterLat','adsbCenterLon','adsbRange'].forEach(function(id){const el=byId(id);if(!el)return;['change','blur','input'].forEach(function(evt){el.addEventListener(evt,saveAdsbSoon,true)})})}

  function installDrawingFixes(){try{if(!byId('v320DrawingStyle')){const st=d.createElement('style');st.id='v320DrawingStyle';st.textContent=`#drawToolMenu,#drawMiniToolbar,#pointMiniToolbar,#routeMiniToolbar,#shapeMiniToolbar,#drawOptionsPanel{box-sizing:border-box!important;max-width:74px!important;padding:5px!important;gap:5px!important;overflow:visible!important}#drawToolMenu button,#drawMiniToolbar button,#pointMiniToolbar button,#routeMiniToolbar button,#shapeMiniToolbar button,#drawOptionsPanel button{box-sizing:border-box!important;width:42px!important;min-width:42px!important;height:42px!important;min-height:42px!important;margin:0!important;padding:0!important;border-radius:10px!important}.draw-submenu,.tool-submenu,.leaflet-draw-toolbar{max-width:58px!important;padding:5px!important;gap:5px!important}.draw-submenu button,.tool-submenu button,.leaflet-draw-toolbar a{width:42px!important;min-width:42px!important;height:42px!important}`;d.head.appendChild(st)}
      if(window.__v320DrawingHooks)return;window.__v320DrawingHooks=true;
      function drawingActive(){try{return String((typeof activeMapTool!=='undefined'?activeMapTool:window.activeMapTool)||'').toLowerCase()==='draw'||d.body.classList.contains('drawing-active')||d.body.classList.contains('tak-drawing-active')}catch(_){return false}}
      function setDrag(){const m=getMap();if(!m||!m.dragging)return;if(drawingActive()){try{m.dragging.disable()}catch(_){}}else{try{m.dragging.enable()}catch(_){}}}
      const oldSet=window.setActiveMapTool;if(typeof oldSet==='function'){window.setActiveMapTool=function(){const r=oldSet.apply(this,arguments);setTimeout(setDrag,0);setTimeout(setDrag,120);return r};try{window.eval('setActiveMapTool=window.setActiveMapTool')}catch(_){}}
      const oldStart=window.v233StartDraw;if(typeof oldStart==='function'){window.v233StartDraw=function(){try{const m=getMap();m&&m.dragging&&m.dragging.disable()}catch(_){};return oldStart.apply(this,arguments)}}
      ['pointerdown','mousedown','touchstart'].forEach(function(evt){const c=(getMap()&&getMap().getContainer&&getMap().getContainer())||byId('map');if(c)c.addEventListener(evt,function(){if(drawingActive())setDrag()},true)});setInterval(setDrag,600)
    }catch(e){console.warn('v320 drawing fix failed',e)}}

  function currentViewer(){try{return (typeof terrain3DViewer!=='undefined'&&terrain3DViewer)||window.terrain3DViewer||null}catch(_){return window.terrain3DViewer||null}}
  function sourceIsLocal(){return String(window.terrain3DElevationSource||localStorage.getItem('takMapTerrainElevationSource')||'streamed').toLowerCase()==='local'}
  function tileList(){try{const st=window.takLocalElevation||{};const t=st.tiles;if(t instanceof Map)return Array.from(t.values());if(Array.isArray(t))return t;return []}catch(_){return []}}
  function boundsOf(t){let s=Number(t.lat0),n=Number(t.lat1),w=Number(t.lon0),e=Number(t.lon1);if(!Number.isFinite(s)||!Number.isFinite(w))return null;if(!Number.isFinite(n))n=s+1;if(!Number.isFinite(e))e=w+1;return {s:Math.min(s,n),n:Math.max(s,n),w:Math.min(w,e),e:Math.max(w,e)}}
  async function ensureTiles(){try{if(typeof window.loadLocalElevationTiles==='function')await window.loadLocalElevationTiles()}catch(e){console.warn('v320 local tile load failed',e)}return tileList()}
  function clearBounds(viewer){try{(window.__v320LocalBounds||[]).forEach(function(ent){try{viewer.entities.remove(ent)}catch(_){}});window.__v320LocalBounds=[]}catch(_){}}
  async function renderLocalBounds(){try{const viewer=currentViewer();if(!viewer||!window.Cesium)return;clearBounds(viewer);if(!sourceIsLocal())return;const Cesium=window.Cesium;const tiles=await ensureTiles();const ents=[];tiles.forEach(function(t,i){const b=boundsOf(t);if(!b)return;const arr=[b.w,b.s,b.e,b.s,b.e,b.n,b.w,b.n,b.w,b.s];try{ents.push(viewer.entities.add({id:'tak-local-dem-bounds-v320-'+i,polyline:{positions:Cesium.Cartesian3.fromDegreesArray(arr),width:3,clampToGround:false,material:Cesium.Color.fromCssColorString('#ff6f2e')}}))}catch(_){}});window.__v320LocalBounds=ents;try{if(typeof window.renderTakMapLocalTerrainMesh==='function')window.renderTakMapLocalTerrainMesh()}catch(e){console.warn('v320 local terrain mesh call failed',e)}try{if(typeof window.terrainStatus==='function')window.terrainStatus(ents.length?('Terrain Mode · Local DEM · '+ents.length+' coverage border'+(ents.length===1?'':'s')+' shown'):'Terrain Mode · Local DEM selected · no local elevation coverage found',!ents.length)}catch(_){}try{viewer.scene&&viewer.scene.requestRender&&viewer.scene.requestRender()}catch(_){}}catch(e){console.warn('v320 local bounds render failed',e)}}
  function makeTerrainPanelDraggable(){try{if(!byId('v320TerrainStyle')){const st=d.createElement('style');st.id='v320TerrainStyle';st.textContent='.terrain3d-controls.v293-terrain-panel,.terrain3d-controls{top:112px!important;right:76px;left:auto}.terrain3d-controls.v320-dragged{right:auto!important}.terrain3d-panel-title,.terrain3d-controls h3,.terrain3d-controls .panel-title{cursor:grab!important;user-select:none!important}.terrain3d-panel-title:active,.terrain3d-controls h3:active,.terrain3d-controls .panel-title:active{cursor:grabbing!important}';d.head.appendChild(st)}const panel=q('.terrain3d-controls');if(!panel||panel.__v320Drag)return;if(!panel.style.top)panel.style.top='112px';const saved=localStorage.getItem('takMapTerrainPanelPos.v320');if(saved){try{const p=JSON.parse(saved);panel.style.left=p.left+'px';panel.style.top=p.top+'px';panel.style.right='auto';panel.classList.add('v320-dragged')}catch(_){}}const handle=q('.terrain3d-panel-title,.panel-title,h3',panel)||panel;panel.__v320Drag=true;handle.addEventListener('pointerdown',function(ev){if(ev.button!==undefined&&ev.button!==0)return;ev.preventDefault();const r=panel.getBoundingClientRect();const dx=ev.clientX-r.left,dy=ev.clientY-r.top;function move(e){let left=Math.max(6,Math.min(window.innerWidth-r.width-6,e.clientX-dx));let top=Math.max(56,Math.min(window.innerHeight-r.height-6,e.clientY-dy));panel.style.left=left+'px';panel.style.top=top+'px';panel.style.right='auto';panel.classList.add('v320-dragged')}function up(){d.removeEventListener('pointermove',move,true);d.removeEventListener('pointerup',up,true);try{const rr=panel.getBoundingClientRect();localStorage.setItem('takMapTerrainPanelPos.v320',JSON.stringify({left:Math.round(rr.left),top:Math.round(rr.top)}))}catch(_){}}d.addEventListener('pointermove',move,true);d.addEventListener('pointerup',up,true)},true)}catch(e){console.warn('v320 terrain panel drag failed',e)}}
  function installTerrainHooks(){try{makeTerrainPanelDraggable();if(window.__v320TerrainHooks)return;window.__v320TerrainHooks=true;const names=['setTerrain3DElevationSource','refreshTerrain3DAll','ensureTerrain3DViewer','setTerrain3DQuality','updateLocalElevationUi'];names.forEach(function(n){const old=window[n];if(typeof old==='function'&&!old.__v320Wrapped){const wrapped=function(){const r=old.apply(this,arguments);setTimeout(makeTerrainPanelDraggable,80);setTimeout(renderLocalBounds,180);setTimeout(renderLocalBounds,900);return r};wrapped.__v320Wrapped=true;window[n]=wrapped;try{window.eval(n+'=window["'+n+'"]')}catch(_){}}});setTimeout(renderLocalBounds,700);setInterval(function(){makeTerrainPanelDraggable();if(sourceIsLocal())renderLocalBounds()},5000)}catch(e){console.warn('v320 terrain hooks failed',e)}}

  function boot(){setVersion();installPopupOverrides();removeSaveFilterButtons();bindAdsbAutosave();installDrawingFixes();installTerrainHooks();qa('.leaflet-popup').forEach(function(el){if(q('.tak-v320-popup,.adsb-pop',el))el.classList.add('tak-v320-object-popup','adsb-object-popup')})}
  if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',function(){setTimeout(boot,120)},{once:true});else setTimeout(boot,120);
  [500,1500,3000,6500].forEach(function(ms){setTimeout(boot,ms)});setInterval(function(){setVersion();removeSaveFilterButtons()},3000);
})();
</script>
"""
        if 'id="v320PopupDrawingTerrainAdsbFixes"' not in _html:
            _html = _html.replace('</body>', _runtime + '</body>', 1) if '</body>' in _html else _html + _runtime
        return _v320_versions(_html)

    TAK_MAP_HTML = _v320_patch_html(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v320_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v320_versions(LOGIN_HTML)
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML
except Exception as _v320_exc:
    try: print('v320 popup/data/drawing/terrain/adsb patch failed:', _v320_exc)
    except Exception: pass
# --- end TAK Map v320 popup/data/drawing/terrain/adsb fixes ---


# --- TAK Map v321 Option C popup styling for Data Sync and Local Data ---
try:
    import re as _v321_re

    def _v321_versions(_html):
        if not isinstance(_html, str):
            return _html
        # Release label remains v1.1.0; only the iteration marker advances.
        for _old in ('v320','v319','v318','v317'):
            _html = _html.replace('TAK-Map/1.1.0 '+_old, 'TAK-Map/1.1.0 v321')
        _html = _v321_re.sub(r'(iteration\s*[=:]\s*["\'])v\d+(\1?)', lambda m: m.group(1)+'v321'+(m.group(2) if len(m.groups())>1 else ''), _html, flags=_v321_re.I)
        # Older runtime patch loops also set visible iteration chips. Point them at v321.
        _html = _html.replace("const V='v320';", "const V='v321';")
        _html = _html.replace('const V="v320";', 'const V="v321";')
        _html = _html.replace("const V='v319';", "const V='v321';")
        _html = _html.replace('const V="v319";', 'const V="v321";')
        return _html

    def _v321_patch_html(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v321_versions(_html)
        _runtime = r"""
<script id="v321OptionCDataPopupStyle">
(function(){
  'use strict';
  const V='v321';
  const d=document;
  function byId(id){try{return d.getElementById(id)}catch(_){return null}}
  function q(sel,root){try{return (root||d).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||d).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>\"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[c]})}
  function present(v){return v!==undefined&&v!==null&&String(v).trim()!==''&&String(v).trim()!=='—'}
  function fmt(v){const n=Number(v);return Number.isFinite(n)?n.toFixed(6):''}
  function getMap(){try{if(typeof map!=='undefined'&&map)return map}catch(_){}return window.map||window.takLeafletMap||null}
  function expose(name,fn){try{window[name]=fn}catch(_){}try{window.eval(name+'=window["'+name+'"]')}catch(_){} }
  function setVersion(){qa('.iteration-chip,.iteration-marker,[data-iteration]').forEach(function(el){try{el.textContent=V;el.setAttribute('data-iteration',V)}catch(_){}})}
  function cleanText(v){return String(v==null?'':v).trim()}
  function objectName(o){return cleanText(o&&(o.name||o.title||o.callsign||o.label||o.uid||o.id))||'Object'}
  function notesText(o){return cleanText(o&&(o.notes||o.remarks||o.description||o.desc||o.comment))}
  function addedText(o){return cleanText(o&&(o.added||o.created||o.time||o.timestamp||o.uploaded||o.updated))}
  function categoryText(o,cat){return cleanText((o&&(o.category||o.Category||o.kind||o.shape_type||o.geometry_type))||cat||'')}
  function isPointCat(cat,o){const b=(String(cat||'')+' '+String(o&&o.kind||'')+' '+String(o&&o.geometry||'')+' '+String(o&&o.geometry_type||'')).toLowerCase();return /point|marker/.test(b)&&!/route|line|shape|area|polygon/.test(b)}
  function isRouteCat(cat,o){const b=(String(cat||'')+' '+String(o&&o.kind||'')+' '+String(o&&o.geometry||'')+' '+String(o&&o.geometry_type||'')).toLowerCase();return /route|line|string|track|path/.test(b)}
  function isShapeCat(cat,o){const b=(String(cat||'')+' '+String(o&&o.kind||'')+' '+String(o&&o.geometry||'')+' '+String(o&&o.geometry_type||'')).toLowerCase();return /shape|area|polygon|rectangle|circle|ellipse|poly/.test(b)}
  function kindFor(o,cat){if(isRouteCat(cat,o))return 'Route';if(isShapeCat(cat,o))return 'Shape';return 'Point'}
  function sourceLabel(o,source){const b=String([source,o&&o.source,o&&o.source_table,o&&o.import_name,o&&o.filename,o&&o.collection,o&&o.mission].filter(Boolean).join(' ')).toLowerCase();if(/local|import|kml|kmz|gpx|geojson|shape|shapefile|file/.test(b))return 'Local Data';if(/data\s*sync|datasync|mission|collection|sync/.test(b))return 'Data Sync';if(/cot|point markers|open/i.test(String(source||'')))return 'Data Sync';return cleanText(source)||'Map Data'}
  function sourceKey(o,source){return String((o&&(o.uid||o.id||o.key||o.name||o.title||o.callsign||o.label))||source||'object')}
  function localId(o){try{if(!o)return ''; if(o._local_id)return String(o._local_id); if(o.local_id)return String(o.local_id); if(o.import_id!==undefined&&o.import_feature_index!==undefined)return String(o.import_id)+':'+String(o.import_feature_index); if(o.import_name&&o.import_feature_index!==undefined)return String(o.import_name)+':'+String(o.import_feature_index)}catch(_){}return ''}
  function pointArray(o){try{if(Array.isArray(o&&o.points))return o.points;if(Array.isArray(o&&o.coords))return o.coords;if(Array.isArray(o&&o.coordinates))return o.coordinates}catch(_){}return []}
  function firstCoord(o){try{let lat=o&&o.lat,lon=o&&o.lon;if(Number.isFinite(Number(lat))&&Number.isFinite(Number(lon)))return {lat:Number(lat),lon:Number(lon)};const pts=pointArray(o);if(pts.length){const p=pts[0];if(Array.isArray(p))return {lat:Number(p[0]),lon:Number(p[1])};return {lat:Number(p.lat),lon:Number(p.lon)}}}catch(_){}return {lat:NaN,lon:NaN}}
  function coordsText(o){const c=firstCoord(o);const la=fmt(c.lat),lo=fmt(c.lon);return la&&lo?la+', '+lo:''}
  function areaText(o){try{const raw=o&&(o.area||o.area_m2||o.areaMeters||o.area_sq_m||o.areaSqm);const n=Number(raw);if(!Number.isFinite(n)||n<=0)return '';if(n>=2589988)return (n/2589988).toFixed(2)+' sq mi';if(n>=1000000)return (n/1000000).toFixed(2)+' km²';if(n>=4046.86)return (n/4046.86).toFixed(2)+' acres';return Math.round(n).toLocaleString()+' m²'}catch(_){return ''}}
  function distanceText(o){try{const raw=o&&(o.distance||o.distance_m||o.length||o.length_m||o.lengthMeters);const n=Number(raw);if(!Number.isFinite(n)||n<=0)return '';if(n>=1609.344)return (n/1609.344).toFixed(2)+' mi';return Math.round(n).toLocaleString()+' m'}catch(_){return ''}}
  function pointCount(o){const pts=pointArray(o);return pts&&pts.length?String(pts.length):''}
  function battleDimension(o){return cleanText(o&&(o.battle_dimension||o.dimension||o.battleDimension))}
  function affiliation(o){return cleanText(o&&(o.affiliation||o.team||o.group||o.side))}
  function row(k,v){if(!present(v))return '';return '<div class="tak-v321-row"><b>'+esc(k)+'</b><span>'+esc(v)+'</span></div>'}
  function table(rows){return '<div class="tak-v321-table">'+(rows||'')+'</div>'}
  function popupChrome(title,sub,rows,edit,kind,source){return '<div class="tak-v321-popup" data-kind="'+esc(kind||'Object')+'" data-source="'+esc(source||'')+'"><div class="tak-v321-bar"></div><div class="tak-v321-inner"><div class="tak-v321-title">'+esc(title||'Object')+'</div><div class="tak-v321-sub">'+esc(sub||'')+'</div>'+table(rows||'')+(edit||'')+'</div></div>'}

  function popupEditFormV321(o,source,kind,cat){
    o=o||{};source=source||'object';kind=kind||kindFor(o,cat);cat=categoryText(o,cat);
    const c=coordsText(o), coord=firstCoord(o), key=sourceKey(o,source), lid=localId(o), showCategory=(kind==='Route'||kind==='Shape');
    let fields='<div class="tak-v321-edit-fields">';
    fields+='<label>Name<input name="name" value="'+esc(objectName(o))+'"></label>';
    if(showCategory)fields+='<label>Category<input name="category" value="'+esc(cat)+'" readonly></label>';
    fields+='<label>Lat/Lon<input name="latlon" value="'+esc(c)+'" placeholder="34.000000, -118.000000"></label>';
    fields+='<input type="hidden" name="lat" value="'+esc(fmt(coord.lat))+'"><input type="hidden" name="lon" value="'+esc(fmt(coord.lon))+'">';
    fields+='<label>Notes<textarea name="notes" rows="3">'+esc(notesText(o))+'</textarea></label>';
    fields+='</div>';
    return '<details class="popup-edit tak-v321-edit" onclick="event.stopPropagation()"><summary>Edit</summary>'+fields+'<div class="tak-v321-actions">'
      +'<button type="button" class="primary" data-v321-popup-action="save" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Save</button>'
      +'<button type="button" data-v321-popup-action="cancel">Cancel</button>'
      +'<button type="button" class="danger" data-v321-popup-action="delete" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Delete</button>'
      +'</div></details>';
  }

  function pointPopupHtmlV321(o,cat){
    o=o||{};const kind='Point', src=sourceLabel(o,cat), sub=kind+' · '+src;
    const rows=row('Affiliation',affiliation(o))+row('Added',addedText(o))+row('Lat/Lon',coordsText(o))+row('Battle Dimension',battleDimension(o))+row('Notes',notesText(o));
    return popupChrome(objectName(o),sub,rows,popupEditFormV321(o,cat||src,kind,cat),kind,src);
  }
  function layerPopupForObjectV321(o,cat){
    o=o||{};cat=cat||o.category||o.type||o.kind||'Object';const kind=kindFor(o,cat);if(kind==='Point')return pointPopupHtmlV321(o,cat);
    const src=sourceLabel(o,cat), sub=kind+' · '+src;
    let rows='';
    rows+=row('Category',categoryText(o,cat)||kind);
    rows+=row('Added',addedText(o));
    rows+=row('Lat/Lon',coordsText(o));
    rows+=row('Points',pointCount(o));
    if(kind==='Route')rows+=row('Distance',distanceText(o));
    if(kind==='Shape')rows+=row('Area',areaText(o));
    rows+=row('Notes',notesText(o));
    return popupChrome(objectName(o),sub,rows,popupEditFormV321(o,cat,kind,cat),kind,src);
  }
  function featurePopupHtmlV321(sourceName,props,extra){
    props=props||{};extra=extra||{};const merged=Object.assign({},props,extra);const title=props.name||props.title||props.Name||props.NAME||extra.name||sourceName||'Feature';
    const cat=props.category||props.Category||extra.category||sourceName||'Feature';const kind=kindFor(merged,cat);const src=sourceLabel(merged,sourceName);
    let rows='';
    if(kind!=='Point')rows+=row('Category',cat);
    rows+=row('Lat/Lon',extra.coords||props.coordinates||coordsText(merged));
    rows+=row('Points',pointCount(merged));
    if(kind==='Shape')rows+=row('Area',areaText(merged));
    if(kind==='Route')rows+=row('Distance',distanceText(merged));
    rows+=row('Notes',props.notes||props.description||props.desc||extra.notes);
    return popupChrome(title,kind+' · '+src,rows,(src==='Local Data'||src==='Data Sync')?popupEditFormV321(merged,sourceName,kind,cat):'',kind,src);
  }

  function installCss(){
    let st=byId('v321OptionCDataPopupCss');if(st)st.remove();st=d.createElement('style');st.id='v321OptionCDataPopupCss';st.textContent=`
.leaflet-popup.tak-v321-object-popup .leaflet-popup-content-wrapper{background:rgba(8,13,18,.97)!important;color:#e9f0f5!important;border:1px solid rgba(255,255,255,.18)!important;border-radius:12px!important;box-shadow:0 16px 38px rgba(0,0,0,.48)!important;overflow:hidden!important;backdrop-filter:blur(10px)!important;-webkit-backdrop-filter:blur(10px)!important}.leaflet-popup.tak-v321-object-popup .leaflet-popup-content{margin:0!important;width:auto!important;min-width:330px!important;max-width:min(410px,82vw)!important}.leaflet-popup.tak-v321-object-popup .leaflet-popup-tip{background:rgba(8,13,18,.97)!important;border:1px solid rgba(255,255,255,.16)!important}.leaflet-popup.tak-v321-object-popup .leaflet-popup-close-button{position:absolute!important;right:10px!important;top:9px!important;width:23px!important;height:23px!important;border-radius:999px!important;border:1px solid rgba(255,255,255,.22)!important;background:rgba(6,16,22,.82)!important;color:#e9f0f5!important;text-align:center!important;line-height:20px!important;font-size:17px!important;font-weight:900!important;text-decoration:none!important;z-index:50!important;box-shadow:0 3px 10px rgba(0,0,0,.35)!important;display:flex!important;align-items:center!important;justify-content:center!important;padding:0!important}.leaflet-popup.tak-v321-object-popup .leaflet-popup-close-button:hover{border-color:#ff6f2e!important;color:#fff!important;background:rgba(31,42,52,.96)!important}.tak-v321-popup{width:100%;min-width:330px;max-width:min(410px,82vw);background:rgba(8,13,18,.97);border-radius:12px;overflow:hidden;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}.tak-v321-bar{height:4px;background:linear-gradient(90deg,#ff6f2e,rgba(255,204,102,.82),rgba(117,190,214,.72))}.tak-v321-inner{padding:12px 13px 11px}.tak-v321-title{padding-right:34px;font-weight:900;color:#f7fbff;letter-spacing:.025em;font-size:.92rem;line-height:1.18;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.tak-v321-sub{color:#9fb2bc;font-size:.72rem;line-height:1.25;margin-top:3px}.tak-v321-table{display:table;width:100%;border-collapse:collapse;margin-top:9px}.tak-v321-row{display:table-row}.tak-v321-row b,.tak-v321-row span{display:table-cell;border-top:1px solid rgba(255,255,255,.07);padding:6px 0;vertical-align:top}.tak-v321-row b{width:92px;padding-right:11px;font-size:.64rem;text-transform:uppercase;letter-spacing:.06em;color:#91a8b3;font-weight:900;white-space:nowrap}.tak-v321-row span{font-size:.79rem;color:#edf8fb;line-height:1.32;overflow-wrap:anywhere}.tak-v321-edit{margin-top:10px;border-top:1px solid rgba(255,255,255,.08);padding-top:8px}.tak-v321-edit summary{cursor:pointer;color:#ffd0b0;font-size:.68rem;text-transform:uppercase;letter-spacing:.09em;font-weight:950;user-select:none}.tak-v321-edit-fields{display:grid;gap:8px;margin-top:8px}.tak-v321-edit-fields label{display:block;font-size:.62rem;letter-spacing:.075em;text-transform:uppercase;color:#91a8b3;font-weight:900}.tak-v321-edit-fields input,.tak-v321-edit-fields textarea{width:100%;box-sizing:border-box;background:rgba(4,10,15,.72);border:1px solid rgba(117,190,214,.24);border-radius:8px;color:#ecf7fa;padding:7px 9px;font-size:.76rem;font-family:inherit;outline:none;margin-top:3px}.tak-v321-edit-fields textarea{min-height:64px;max-height:150px;resize:vertical;line-height:1.3}.tak-v321-edit-fields input[readonly]{opacity:.82;background:rgba(4,10,15,.46)}.tak-v321-actions{display:flex;justify-content:flex-end;gap:7px;margin-top:10px;border-top:1px solid rgba(255,255,255,.08);padding-top:9px}.tak-v321-actions button{border:1px solid rgba(255,255,255,.15);background:rgba(18,32,42,.85);color:#e8f5f8;border-radius:9px;padding:6px 10px;font-size:.72rem;font-weight:850;cursor:pointer}.tak-v321-actions button.primary{border-color:rgba(255,111,46,.48);color:#ffd3bd;background:rgba(255,111,46,.12)}.tak-v321-actions button.danger{border-color:rgba(255,95,87,.36);color:#ffb2ad;background:rgba(255,95,87,.08)}@media(max-width:520px){.leaflet-popup.tak-v321-object-popup .leaflet-popup-content,.tak-v321-popup{min-width:min(330px,82vw)!important;max-width:82vw!important}.tak-v321-row b{width:82px}.tak-v321-inner{padding:11px}}
`;d.head.appendChild(st);
  }
  function markPopup(popup){try{const el=(popup&&popup.getElement&&popup.getElement())||q('.leaflet-popup:has(.tak-v321-popup)')||qa('.leaflet-popup').find(function(p){return q('.tak-v321-popup',p)});if(!el)return;if(q('.tak-v321-popup',el)){el.classList.add('tak-v321-object-popup');const close=q('.leaflet-popup-close-button',el);if(close){close.innerHTML='×';close.setAttribute('aria-label','Close')}}}catch(_){} }
  function closePopupFrom(el){try{const m=getMap();if(m){try{m.closePopup();return true}catch(_){}}const popEl=el&&el.closest&&el.closest('.leaflet-popup');if(popEl){popEl.remove();return true}}catch(_){}return false}
  function parseLatLon(form){try{const input=form.querySelector('[name="latlon"]');const v=input&&input.value||'';const m=String(v).match(/(-?\d+(?:\.\d+)?)\s*[, ]+\s*(-?\d+(?:\.\d+)?)/);if(m){const lat=form.querySelector('[name="lat"]'),lon=form.querySelector('[name="lon"]');if(lat)lat.value=m[1];if(lon)lon.value=m[2]}}catch(_){} }
  async function postJson(url,payload){const r=await fetch(url,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload||{}),cache:'no-store'});let j={};try{j=await r.json()}catch(_){j={ok:r.ok}}if(!r.ok||j.ok===false)throw new Error(j.error||j.message||('HTTP '+r.status));return j}
  function refreshAfterPopup(){['forceDataSyncSync','refreshDataSync','refreshCot','refreshImports','refreshLocalData','loadLocalData','drawImportedObjects'].forEach(function(n){try{if(typeof window[n]==='function')window[n]()}catch(_){}})}
  async function handlePopupAction(btn){const action=btn.getAttribute('data-v321-popup-action');if(!action)return;const details=btn.closest('details.popup-edit');if(action==='cancel'){try{details&&details.removeAttribute('open')}catch(_){};return}const form=details||btn.closest('.tak-v321-popup')||d;parseLatLon(form);const key=btn.getAttribute('data-popup-key')||'',source=btn.getAttribute('data-popup-source')||'object',lid=btn.getAttribute('data-local-id')||'';if(action==='delete'){if(!confirm('Delete this item?'))return;if(lid){await postJson('/api/tak-map/local-data-delete',{ids:[lid]})}else{await postJson('/api/tak-map/popup-edit',{key:key,source:source,delete_item:true})}closePopupFrom(btn);refreshAfterPopup();return}if(action==='save'){const payload={key:key,source:source,name:(form.querySelector('[name="name"]')||{}).value||'',notes:(form.querySelector('[name="notes"]')||{}).value||'',lat:(form.querySelector('[name="lat"]')||{}).value||'',lon:(form.querySelector('[name="lon"]')||{}).value||''};await postJson('/api/tak-map/popup-edit',payload);closePopupFrom(btn);refreshAfterPopup();return}}
  function installHandlers(){if(window.__v321PopupHandlers)return;window.__v321PopupHandlers=true;d.addEventListener('click',function(ev){const close=ev.target&&ev.target.closest&&ev.target.closest('.leaflet-popup.tak-v321-object-popup .leaflet-popup-close-button');if(close){ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){};closePopupFrom(close);return false}const btn=ev.target&&ev.target.closest&&ev.target.closest('[data-v321-popup-action]');if(!btn)return;ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){};handlePopupAction(btn).catch(function(e){alert('Popup update failed: '+(e&&e.message||e))});return false},true);const m=getMap();if(m&&m.on&&!window.__v321MapPopupOpenBound){window.__v321MapPopupOpenBound=true;try{m.on('popupopen',function(ev){setTimeout(function(){markPopup(ev&&ev.popup)},0)})}catch(_){}}}
  function installOverrides(){expose('popupEditForm',popupEditFormV321);expose('pointPopupHtml',pointPopupHtmlV321);expose('layerPopupForObject',layerPopupForObjectV321);expose('featurePopupHtml',featurePopupHtmlV321)}
  function boot(){setVersion();installCss();installOverrides();installHandlers();qa('.leaflet-popup').forEach(function(el){if(q('.tak-v321-popup',el)){el.classList.add('tak-v321-object-popup');const close=q('.leaflet-popup-close-button',el);if(close)close.innerHTML='×'}})}
  if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',function(){setTimeout(boot,140)},{once:true});else setTimeout(boot,140);
  [500,1500,3000,6500].forEach(function(ms){setTimeout(boot,ms)});setInterval(setVersion,2000);
})();
</script>
"""
        if 'id="v321OptionCDataPopupStyle"' not in _html:
            _html = _html.replace('</body>', _runtime + '</body>', 1) if '</body>' in _html else _html + _runtime
        return _v321_versions(_html)

    TAK_MAP_HTML = _v321_patch_html(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v321_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v321_versions(LOGIN_HTML)
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML
except Exception as _v321_exc:
    try: print('v321 Option C data/local popup patch failed:', _v321_exc)
    except Exception: pass
# --- end TAK Map v321 Option C popup styling ---

# --- TAK Map v322 ADS-B popup layout + Option C data popup coverage + local data live refresh ---
try:
    import re as _v322_re

    def _v322_versions(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v322_re.sub(r'TAK-Map/1\.1\.0\s+v\d+', 'TAK-Map/1.1.0 v322', _html)
        _html = _v322_re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v322', _html)
        _html = _v322_re.sub(r'(<span[^>]*class=["\'][^"\']*iteration-chip[^"\']*["\'][^>]*>)v\d+(</span>)', r'\1v322\2', _html, flags=_v322_re.I)
        _html = _v322_re.sub(r'(<[^>]+data-iteration=["\'])v\d+(["\'][^>]*>)', r'\1v322\2', _html, flags=_v322_re.I)
        _html = _v322_re.sub(r'const\s+V\s*=\s*(["\'])v\d+\1\s*;', "const V='v322';", _html)
        return _html

    def _v322_patch_html(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v322_versions(_html)
        # Remove the manual Local Data refresh control. Local-data changes are now pushed into the menu immediately.
        _html = _v322_re.sub(r'<button\b[^>]*onclick=["\']refreshLocalData\(\)["\'][^>]*>\s*Refresh\s+local\s+data\s*</button>', '', _html, flags=_v322_re.I)

        _adsb_popup = r'''function speedText(a){const kt=n(a&&((a.speed_kt??a.gs??a.speed??a.groundspeed)));if(kt==null)return '—';return Math.round(kt).toLocaleString()+' kt'}
function modelText(a){let s=String((a&&(a.model||a.aircraft_model||a.aircraft_type||a.t||a.type||a.desc||a.description))||'').trim();if(!s)return '';s=s.replace(/\s+/g,' ');if(s.length>34)s=s.slice(0,31)+'…';return s}
function speedModelText(a){const sp=speedText(a),mo=modelText(a);return mo?(sp+' · '+mo):sp}
function headingText(a){const hd=n(a&&((a.track_deg??a.track??a.true_heading??a.mag_heading??a.heading)));if(hd==null)return '—';return Math.round(hd)+'°'}
function ownerText(a){let s=String((a&&(a.owner_operator||a.ownOp||a.operator||a.owner))||'').trim();return s||'—'}
function popupHtml(a){const id=idOf(a),st=stableState(a),name=titleOf(a,id),owner=ownerText(a),heading=headingText(a);let rows='';rows+='<div><b>Class</b><span>'+esc(classLabel(st.classKey))+'</span></div>';rows+='<div><b>Type</b><span>'+esc(typeLabel(st))+'</span></div>';rows+='<div><b>Speed / Model</b><span>'+esc(speedModelText(a))+'</span></div>';rows+='<div><b>Heading</b><span>'+esc(heading)+'</span></div>';rows+='<div><b>Altitude</b><span>'+esc(altText(a))+'</span></div>';rows+='<div class="adsb-pop-wide"><b>Owner/Op</b><span>'+esc(owner)+'</span></div>';return '<div class="adsb-popup adsb-pro-popup v322" data-adsb-id="'+esc(id)+'"><div class="adsb-pop-head"><div><div class="adsb-pop-title">'+esc(name)+'</div><div class="adsb-pop-sub">'+esc(classLabel(st.classKey))+' · '+esc(typeLabel(st))+'</div></div></div><div class="adsb-pop-grid">'+rows+'</div><div class="adsb-track-row">'+trackButtonHtml(a)+'</div></div>'}
'''
        _html, _adsb_count = _v322_re.subn(r'function speedText\(a\)\{.*?\n\s*function updateMarkerDom', lambda _m: _adsb_popup + 'function updateMarkerDom', _html, count=1, flags=_v322_re.S)
        if not _adsb_count:
            # Older fallback ADS-B renderer.
            pass  # Primary v317+ ADS-B renderer was not found; leave older fallback renderer unchanged.


        _runtime = r'''
<script id="v322DataPopupCoverageAndLocalRefresh">
(function(){
  'use strict';
  const V='v322';
  const d=document;
  function byId(id){try{return d.getElementById(id)}catch(_){return null}}
  function q(sel,root){try{return (root||d).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||d).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>\"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[c]})}
  function clean(v){return String(v==null?'':v).trim()}
  function present(v){const s=clean(v);return s&&s!=='—'&&s.toLowerCase()!=='undefined'&&s.toLowerCase()!=='null'}
  function fmt(v){const n=Number(v);return Number.isFinite(n)?n.toFixed(6):''}
  function getMap(){try{if(typeof map!=='undefined'&&map)return map}catch(_){}return window.map||window.takLeafletMap||null}
  function expose(name,fn){try{window[name]=fn}catch(_){}try{window.eval(name+'=window["'+name+'"]')}catch(_){} }
  function setVersion(){qa('.iteration-chip,.iteration-marker,[data-iteration]').forEach(function(el){try{el.textContent=V;el.setAttribute('data-iteration',V)}catch(_){}})}
  function removeRefreshLocalButton(){qa('button').forEach(function(b){try{if(/refresh\s+local\s+data/i.test((b.textContent||'').trim()))b.remove()}catch(_){}})}
  function objectName(o){return clean(o&&(o.name||o.title||o.callsign||o.label||o.uid||o.id))||'Object'}
  function notesText(o){return clean(o&&(o.notes||o.remarks||o.description||o.desc||o.comment))}
  function addedText(o){return clean(o&&(o.added||o.created||o.time||o.timestamp||o.uploaded||o.updated))}
  function categoryText(o,cat){return clean((o&&(o.category||o.Category||o.kind||o.shape_type||o.geometry_type))||cat||'')}
  function kindBlob(o,cat){return String([cat,o&&o.kind,o&&o.geometry,o&&o.geometry_type,o&&o.type,o&&o.category].filter(Boolean).join(' ')).toLowerCase()}
  function isRoute(o,cat){return /route|line|string|track|path/.test(kindBlob(o,cat))}
  function isShape(o,cat){return /shape|area|polygon|rectangle|circle|ellipse|poly/.test(kindBlob(o,cat))&&!isRoute(o,cat)}
  function kindFor(o,cat){if(isRoute(o,cat))return 'Route';if(isShape(o,cat))return 'Shape';return 'Point'}
  function sourceLabel(o,source){const b=String([source,o&&o.source,o&&o.source_table,o&&o.import_name,o&&o.filename,o&&o.collection,o&&o.mission].filter(Boolean).join(' ')).toLowerCase();if(/local|import|kml|kmz|gpx|geojson|shape|shapefile|file/.test(b))return 'Local Data';if(/data\s*sync|datasync|mission|collection|sync/.test(b))return 'Data Sync';return clean(source)||'Data Sync'}
  function sourceKey(o,source){return String((o&&(o.uid||o.id||o.key||o.name||o.title||o.callsign||o.label))||source||'object')}
  function localId(o){try{if(!o)return '';if(o._local_id)return String(o._local_id);if(o.local_id)return String(o.local_id);if(o.import_id!==undefined&&o.import_feature_index!==undefined)return String(o.import_id)+':'+String(o.import_feature_index);if(o.import_name&&o.import_feature_index!==undefined)return String(o.import_name)+':'+String(o.import_feature_index)}catch(_){}return ''}
  function pointArray(o){try{if(Array.isArray(o&&o.points))return o.points;if(Array.isArray(o&&o.coords))return o.coords;if(Array.isArray(o&&o.coordinates))return o.coordinates;if(o&&o.geometry&&Array.isArray(o.geometry.coordinates))return o.geometry.coordinates}catch(_){}return []}
  function firstCoord(o){try{let lat=o&&o.lat,lon=o&&o.lon;if(Number.isFinite(Number(lat))&&Number.isFinite(Number(lon)))return {lat:Number(lat),lon:Number(lon)};const pts=pointArray(o);if(pts.length){let p=pts[0];if(Array.isArray(p)&&Array.isArray(p[0]))p=p[0];if(Array.isArray(p)){let a=Number(p[0]),b=Number(p[1]);if(Math.abs(a)>90&&Math.abs(b)<=90)return {lat:b,lon:a};return {lat:a,lon:b}}return {lat:Number(p.lat),lon:Number(p.lon)}}}catch(_){}return {lat:NaN,lon:NaN}}
  function coordsText(o){const c=firstCoord(o);const la=fmt(c.lat),lo=fmt(c.lon);return la&&lo?la+', '+lo:''}
  function areaText(o){try{const raw=o&&(o.area||o.area_m2||o.areaMeters||o.area_sq_m||o.areaSqm);const n=Number(raw);if(!Number.isFinite(n)||n<=0)return '';if(n>=2589988)return (n/2589988).toFixed(2)+' sq mi';if(n>=1000000)return (n/1000000).toFixed(2)+' km²';if(n>=4046.86)return (n/4046.86).toFixed(2)+' acres';return Math.round(n).toLocaleString()+' m²'}catch(_){return ''}}
  function distanceText(o){try{const raw=o&&(o.distance||o.distance_m||o.length||o.length_m||o.lengthMeters);const n=Number(raw);if(!Number.isFinite(n)||n<=0)return '';if(n>=1609.344)return (n/1609.344).toFixed(2)+' mi';return Math.round(n).toLocaleString()+' m'}catch(_){return ''}}
  function pointCount(o){const pts=pointArray(o);return pts&&pts.length?String(pts.length):''}
