    TAK_MAP_HTML = TAK_MAP_HTML.replace('>'+_old_iter+'<', '>v292<')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')
    LOGIN_HTML = LOGIN_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')


# --- TAK Map v293 elevation progress/removal + Terrain Mode UI + ADS-B dropdown close patch ---
try:
    # Release label remains 1.1.0; iteration marker advances to v293 only.
    for _old_iter in ('v292','v291','v290','v289','v288','v287','v286','v285','v284','v283','v282','v281','v280'):
        TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')
        TAK_MAP_HTML = TAK_MAP_HTML.replace('TAK-Map/1.1.0 '+_old_iter, 'TAK-Map/1.1.0 v301')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class="iteration-chip">{_old_iter}</span>', '<span class="iteration-chip">v301</span>')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class="iteration-marker">{_old_iter}</div>', '<div class="iteration-marker">v301</div>')
        TAK_MAP_HTML = TAK_MAP_HTML.replace('>'+_old_iter+'<', '>v293<')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('TAK-Map/1.1.0 '+_old_iter, 'TAK-Map/1.1.0 v301')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<span class="iteration-chip">{_old_iter}</span>', '<span class="iteration-chip">v301</span>')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<div class="iteration-marker">{_old_iter}</div>', '<div class="iteration-marker">v301</div>')
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('>'+_old_iter+'<', '>v293<')
        LOGIN_HTML = LOGIN_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')
        LOGIN_HTML = LOGIN_HTML.replace('TAK-Map/1.1.0 '+_old_iter, 'TAK-Map/1.1.0 v301')
        LOGIN_HTML = LOGIN_HTML.replace(f'<span class="iteration-chip">{_old_iter}</span>', '<span class="iteration-chip">v301</span>')
        LOGIN_HTML = LOGIN_HTML.replace(f'<div class="iteration-marker">{_old_iter}</div>', '<div class="iteration-marker">v301</div>')
        LOGIN_HTML = LOGIN_HTML.replace('>'+_old_iter+'<', '>v293<')

    # User-facing terminology only; function/class names remain unchanged.
