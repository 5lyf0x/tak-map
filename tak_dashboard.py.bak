      const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))continue;
      const ll=[lat,lon],url=iconFor(a),rot=Number(a.track_deg)||0,label=esc(a.callsign||a.registration||a.hex||'ADS-B');
      let m=markers.get(id);
      const html=`<div class="adsb-hitbox" data-adsb-id="${esc(id)}"><div class="aircraft-wrap"><img src="${esc(url)}" style="transform:rotate(${rot}deg)"><span class="aircraft-label">${label}</span></div></div>`;
      if(!m){
        const icon=L.divIcon({className:'adsb-v308-marker',iconSize:[96,60],iconAnchor:[48,24],html});
        m=L.marker(ll,{icon,zIndexOffset:900,interactive:true}).addTo(layer);
        m.bindPopup(popupHtml(a),{className:'adsb-v280-popup adsb-object-popup',autoPan:false,closeButton:false});
        m.on('mouseover',()=>{if(!pinnedAdsb)try{m.openPopup();setTimeout(syncAdsbTrackButtons,20)}catch(_){}});
        m.on('mouseout',()=>{if(!pinnedAdsb)try{m.closePopup()}catch(_){}});
        m.on('click',ev=>{try{L.DomEvent.stop(ev);pinnedAdsb=id;m.openPopup();setTimeout(syncAdsbTrackButtons,20)}catch(_){}});
        markers.set(id,m);
      }else{
        m.setLatLng(ll);
        const el=m.getElement&&m.getElement();
        const img=el&&el.querySelector&&el.querySelector('img');
        const lab=el&&el.querySelector&&el.querySelector('.aircraft-label');
        if(img){try{if(!String(img.getAttribute('src')||img.src||'').endsWith(url))img.src=url;img.style.transform=`rotate(${rot}deg)`;}catch(_){}}
        else{try{m.setIcon(L.divIcon({className:'adsb-v308-marker',iconSize:[96,60],iconAnchor:[48,24],html}))}catch(_){}}
        if(lab)lab.textContent=label;
        if(!m.isPopupOpen()||pinnedAdsb!==id){try{m.setPopupContent(popupHtml(a))}catch(_){}}
