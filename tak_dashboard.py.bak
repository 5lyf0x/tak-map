  function adsbIconUrl(ac){const mil=!!(typeof aircraftIsMilitary==='function'&&aircraftIsMilitary(ac));const heli=!!(typeof aircraftIsHelicopter==='function'&&aircraftIsHelicopter(ac));return mil?(heli?ADSB_ICON_PNG.mil_helo:ADSB_ICON_PNG.mil_fixed):(heli?ADSB_ICON_PNG.civ_helo:ADSB_ICON_PNG.civ_fixed)}
