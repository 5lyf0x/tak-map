  function scriptLoad(src){return new Promise((resolve,reject)=>{try{if(document.querySelector('script[src="'+src+'"]'))return setTimeout(resolve,0);const s=document.createElement('script');s.src=src;s.async=false;s.onload=()=>resolve();s.onerror=()=>reject(new Error('Could not load '+src));document.head.appendChild(s)}catch(e){reject(e)}})}
  async function ensureGeoTiffLibs(){if(!window.GeoTIFF)await scriptLoad('/assets/vendor/geotiff.js');if(!window.proj4)await scriptLoad('/assets/vendor/proj4.js');if(!window.geokeysToProj4)await scriptLoad('/assets/vendor/geotiff-geokeys-to-proj4.js');if(!window.GeoTIFF)throw new Error('bundled geotiff.js did not load');if(!window.proj4)throw new Error('bundled proj4.js did not load');}
