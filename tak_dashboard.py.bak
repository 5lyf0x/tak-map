    def _v313_install(_html):
        _script = _v313_extract_latest_owner(_html)
        for _sid in ('v312AdsbSingleOwnerPatch','v311AdsbSingleLayerOwnerPatch','v310AdsbSingleLayerOwnerPatch','v309AdsbOwnerPatch','v308ViewshedOpenPatch','v296AdsbStableLocalTerrainPatch','v294TerrainLocalCoverageAdsbStabilityPatch'):
            _html = _v313_remove_script_block(_html, _sid)
        # Remove legacy local-browser ADS-B owner blocks that generated the observed tak-map:691 icon changes.
        _html = _v313_re.sub(r'<script[^>]*>\s*/\*\s*v27[6-9][^*]*ADS-B.*?</script>\s*', '', _html, flags=_v313_re.S|_v313_re.I)
        _html = _html.replace('ADS-B is owned by v312AdsbSingleOwnerPatch', 'ADS-B is owned by v313AdsbSingleOwnerPatch')
        if _script:
            _html = _html.replace('</body>', _script + '</body>') if '</body>' in _html else _html + _script
        return _v313_versions(_html)
    TAK_MAP_HTML = _v313_install(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v313_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v313_versions(LOGIN_HTML)
except Exception as _v313_exc:
    try: print('v313 ADS-B single owner finalization failed:', _v313_exc)
    except Exception: pass
# --- end TAK Map v313 ADS-B single-owner finalization + visible iteration enforcement ---

# --- TAK Map v314 route finalization + visible iteration enforcement ---
try:
    import re as _v314_re
    def _v314_versions(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v314_re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v314</span>', _html)
        _html = _v314_re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v314</div>', _html)
        _html = _v314_re.sub(r'<span>v\d+</span>', lambda m: '<span>v314</span>' if 'login-version-marker' in _html[max(0,m.start()-120):m.start()] else m.group(0), _html)
        _html = _v314_re.sub(r'const\s+V\s*=\s*["\']v\d+["\']', "const V='v314'", _html)
        _html = _v314_re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v314', _html)
        _html = _v314_re.sub(r'TAK-Map/1\.1\.0 v\d+', 'TAK-Map/1.1.0 v314', _html)
        _html = _html.replace('v313AdsbSingleOwnerPatch', 'v314AdsbSingleOwnerPatch')
        _html = _html.replace("window.__takMapAdsbSingleOwner='v313'", "window.__takMapAdsbSingleOwner='v314'")
        _html = _html.replace("window.__takMapAdsbSingleOwner = 'v313'", "window.__takMapAdsbSingleOwner = 'v314'")
        _html = _html.replace("version:'v313'", "version:'v314'").replace('version:"v313"', 'version:"v314"')
        _html = _html.replace("version:V", "version:V")
        _html = _html.replace('__v313AdsbLegacySrcGuard', '__v314AdsbLegacySrcGuard')
        _html = _html.replace('v313 blocked legacy ADS-B icon downgrade', 'v314 blocked legacy ADS-B icon downgrade')
        # Final rendered HTML should not carry stale iteration strings; this is safe here because v314 runs after v313 has generated the active page.
        _html = _html.replace('v313', 'v314')
        _html = _html.replace('v313 legacy src guard failed', 'v314 legacy src guard failed')
        _html = _html.replace('v313 ignored legacy ADS-B', 'v314 ignored legacy ADS-B')
        return _html

    TAK_MAP_HTML = _v314_versions(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v314_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v314_versions(LOGIN_HTML)

    # Critical split-package correction: in map-only service mode, anything that reaches the
    # root page should receive the TAK Map page, not the old dashboard INDEX_HTML. This also
    # protects deployments where a reverse proxy rewrites /tak-map to /.
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML

    _v314_prev_get = Handler.do_GET
    def _v314_route_get(self):
        parsed = urlparse(self.path)
        if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
            if parsed.path in ('/', '/index.html', '/tak-map', '/tak-map/'):
                if not self._tak_map_auth_ok():
                    return self._redirect('/tak-map/login')
                return self._send_html(TAK_MAP_HTML)
            if parsed.path in ('/login', '/tak-map/login'):
                if self._tak_map_auth_ok():
                    return self._redirect('/tak-map')
                return self._send_html(TAK_MAP_LOGIN_HTML)
        return _v314_prev_get(self)
    Handler.do_GET = _v314_route_get
except Exception as _v314_exc:
    try: print('v314 route/version finalization failed:', _v314_exc)
    except Exception: pass
# --- end TAK Map v314 route finalization + visible iteration enforcement ---

# --- TAK Map v315 ADS-B menu restore + visible iteration enforcement ---
try:
    import re as _v315_re
    def _v315_versions(_html):
        if not isinstance(_html, str):
            return _html
