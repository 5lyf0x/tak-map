  async function importHgtFileV292(file){const loc=parseHgtNameV292(file.name);if(!loc)throw new Error('HGT filename must include tile origin like N34W118.hgt');const buf=await file.arrayBuffer();const samples=buf.byteLength/2;const size=Math.round(Math.sqrt(samples));if(size*size!==samples||![1201,3601].includes(size))throw new Error('unsupported HGT dimensions '+size+'×'+size);const dv=new DataView(buf);const vals=new Int16Array(samples);for(let i=0;i<samples;i++)vals[i]=dv.getInt16(i*2,false);const tile={id:'hgt|'+loc.lat0+'|'+loc.lon0+'|'+size,type:'SRTM HGT',sourceType:'hgt',name:file.name,lat0:loc.lat0,lon0:loc.lon0,lat1:loc.lat0+1,lon1:loc.lon0+1,width:size,height:size,size,buffer:vals.buffer,noData:-32768,bytes:buf.byteLength,imported:Date.now()};await dbPutTile(tile);const st=localElevStateV292();addTileToState(st,tile);st.meta=uniqueTiles(st).map(localElevMetaFor);return tile}
