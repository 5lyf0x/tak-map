t=objs.length+\' objects\';renderDataSyncRows();drawDataSyncObjects(objs);return j}catch(e){document.getElementById(\'dataSyncRows\').innerHTML=\'<div class="danger">Could not load Data Sync: \'+esc(e)+\'</div>\';return {ok:false,error:String(e)}}}function refreshDataSyncInterval(){try{const age=Date.now()-Number(lastDataSyncSuccessMs||0);if(lastDataSyncSuccessMs&&age<10000&&lastDataSyncSuccessReason!==\'interval\')return Promise.resolve({ok:true,skipped:true,age});return refreshDataSync(false,\'interval\')}catch(e){return Promise.resolve({ok:false,error:String(e)})}}async function forceDataSyncSync(reason){const statusEls=document.querySelectorAll(\'.popup-edit-status\');try{const j=await refreshDataSync(true,reason||\'force\');setTimeout(()=>refreshDataSync(true,(reason||\'force\')+\'-followup-1\'),750);setTimeout(()=>refreshDataSync(true,(reason||\'force\')+\'-followup-2\'),2000);setTimeout(()=>refreshDataSync(true,(reason||\'force\')+\'-followup-3\'),5000);return j}catch(e){return {ok:false,error:String(e)}}}function rowLabel(row){return row.name||row.mission_name||row.missionName||row.uid||row.guid||row.id||row.filename||\'item\'}function toggleDataSyncObjects(on){state.dataSync=!!on;if(on){dataSyncLayer.addTo(map);drawDataSyncObjects((lastDataSync||{}).objects||[])}else{dataSyncLayer.clearLayers();if(map.hasLayer(dataSyncLayer))map.removeLayer(dataSyncLayer)}}function affFromType(t){t=String(t||\'\').toLowerCase();if(t.includes(\'a-h-\')||t.includes(\'hostile\'))return\'Hostile\';if(t.includes(\'a-n-\')||t.includes(\'neutral\'))return\'Neutral\';if(t.includes(\'a-u-\')||t.includes(\'unknown\'))return\'Unknown\';return\'Friendly\'}function affKey(t){const a=affFromType(t);return a===\'Hostile\'?\'hostile\':a===\'Neutral\'?\'neutral\':a===\'Unknown\'?\'unknown\':\'friendly\'}function iconColor(aff){aff=String(aff||\'\').toLowerCase();return aff===\'hostile\'?\'#ff3b35\':(aff===\'neutral\'?\'#77b84a\':(aff===\'unknown\'?\'#a7adb4\':\'#2386ff\'))}function battleDimension(o){const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.source].filter(Boolean).join(\' \')).toLowerCase();if(/(-a-)|aircraft|air\\b|heli/.test(t))return\'Air\';if(/(-s-)|sea|surface|ship|boat|maritime/.test(t))return\'Sea surface\';if(/space|satellite/.test(t))return\'Space\';if(/subsurface|submarine/.test(t))return\'Subsurface\';return\'Ground\'}function assetDescriptor(o){if(o&&(o.asset_override||o.asset))return String(o.asset_override||o.asset);const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.callsign,o?.name,o?.title,o?.category,o?.source].filter(Boolean).join(\' \')).toLowerCase();if(/air.?defense|airdefense|\\bada\\b|sam\\b|surface.?to.?air|missile|anti.?air|a-[fhnu]-g-u-c-d|a-[fhnu]-g-u-c-v-a|g-u-c-d|g-u-c-v-a|gpucd|airdef|air_def|air-def/.test(t))return\'Air defense\';if(/sniper|shooter|precision/.test(t))return\'Sniper\';if(/logistic|supply|fuel|cache|resupply|medical|medevac/.test(t))return\'Logistics\';if(/radar|sensor|surveillance/.test(t))return\'Radar / sensor\';if(/artillery|mortar|cannon|howitzer/.test(t))return\'Artillery\';if(/armor|armou?r|tank|tracked|a-[fhnu]-g-u-c-a|g-u-c-a|gpuca|gpevat/.test(t))return\'Armor\';if(/vehicle|wheeled|truck|convoy/.test(t))return\'Vehicle\';if(/infantry|personnel|team|unit|ground|a-[fhnu]-g-u-c-i|g-u-c-i|gpuci/.test(t))return\'Ground unit\';if(/heli|rotary/.test(t))return\'Helicopter\';if(/air|aircraft|fixed/.test(t))return\'Aircraft\';if(/route|track|path|gpx/.test(t))return\'Route\';if(/shape|polygon|area|sector|circle|rectangle/.test(t))return\'Shape / area\';if(/hazard|warning|danger|alert/.test(t))return\'Hazard\';return\'Point marker\'}function popupEditInputs(box){try{return Array.from((box||document).querySelectorAll(\'input,textarea,select\')).filter(el=>!el.disabled&&!el.readOnly&&el.offsetParent!==null)}catch(e){return[]}}function markPopupEditDirty(el){try{const box=el.closest?el.closest(\'.popup-edit\'):el;if(box)box.dataset.dirty=\'1\'}catch(e){}}function popupEditKeyNav(ev){try{if(!ev|