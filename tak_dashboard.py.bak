    .adsb-track-btn.active .adsb-track-light,.adsb-track-light.active{background:#ff3b30!important;border-color:#ff8a82!important;box-shadow:0 0 9px rgba(255,59,48,.85),inset 0 0 3px rgba(0,0,0,.45)!important;}
  `;document.head.appendChild(st);}catch(_){ }}
