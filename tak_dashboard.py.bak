  function getTerrainPrepWorker(){try{if(window._v252TerrainPrepWorker)return window._v252TerrainPrepWorker;const blob=new Blob([terrainPrepWorkerCode()],{type:'text/javascript'});const w=new Worker(URL.createObjectURL(blob));window._v252TerrainPrepSeq=0;window._v252TerrainPrepJobs={};w.onmessage=function(ev){const d=ev.data||{},job=window._v252TerrainPrepJobs&&window._v252TerrainPrepJobs[d.id];if(job){delete window._v252TerrainPrepJobs[d.id];d.ok?job.resolve(d):job.reject(new Error(d.error||'Terrain prep worker failed'))}};window._v252TerrainPrepWorker=w;return w}catch(e){console.warn('Terrain prep worker unavailable',e);return null}}
  function runTerrainPrepWorker(items){const w=getTerrainPrepWorker();if(!w)return Promise.reject(new Error('Terrain prep worker unavailable'));const id=++window._v252TerrainPrepSeq;return new Promise((resolve,reject)=>{window._v252TerrainPrepJobs[id]={resolve,reject};w.postMessage({id,cmd:'plan',items});setTimeout(()=>{if(window._v252TerrainPrepJobs&&window._v252TerrainPrepJobs[id]){delete window._v252TerrainPrepJobs[id];reject(new Error('Terrain prep worker timed out'))}},45000)})}
  try{if(!window._v252TerrainRefreshWrapped&&typeof refreshTerrain3DObjects==='function'){
    const prevTerrainRefresh=refreshTerrain3DObjects;
    window.refreshTerrain3DObjects=refreshTerrain3DObjects=function(force,reason){try{
      if(!terrain3DActive||!terrain3DViewer||!window.Cesium)return prevTerrainRefresh(force,reason);
      const q=terrainQualitySettings(terrain3DQuality);
      if(terrain3DMoving&&q.deferWhileMoving)return prevTerrainRefresh(force,reason);
      const tak=(lastTakMarkers||[]).map((o,i)=>({source:'tak',idx:i,kind:o&&o.kind,lat:o&&o.lat,lon:o&&o.lon}));
