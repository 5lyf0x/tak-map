    #viewshedMinimized.viewshed-minimized{max-width:calc(100vw - 16px)!important;left:50%!important;right:auto!important;bottom:max(12px,env(safe-area-inset-bottom,0px))!important;}
    #localElevationDialog.local-elev-dialog.active{display:flex!important;visibility:visible!important;opacity:1!important;pointer-events:auto!important;}
  `;document.head.appendChild(st)}catch(_){}}
  function clampViewshedModule(resetIfBad){try{const m=q('#viewshedModule');if(!m||!m.classList.contains('active'))return false;const vw=Math.max(320,window.innerWidth||document.documentElement.clientWidth||320);const vh=Math.max(320,window.innerHeight||document.documentElement.clientHeight||320);const safe=8;let r=m.getBoundingClientRect();if(!r.width||!r.height)return false;if(r.width>vw-safe*2){m.style.width=(vw-safe*2)+'px';r=m.getBoundingClientRect()}const body=q('.viewshed-body',m);if(body){const head=q('.viewshed-head',m);const headH=head?head.getBoundingClientRect().height:42;body.style.maxHeight=Math.max(160,vh-headH-safe*2-4)+'px';body.style.overflowY='auto'}let left=r.left,top=r.top;const minVisible=48;const bad=!!resetIfBad||!Number.isFinite(left)||!Number.isFinite(top)||r.right<safe+minVisible||r.left>vw-safe-minVisible||r.bottom<safe+minVisible||r.top>vh-safe-minVisible;if(bad){left=Math.max(safe,vw-(r.width||264)-14);top=toolbarBottomY()}const maxLeft=Math.max(safe,vw-(r.width||264)-safe);const maxTop=Math.max(safe,vh-(r.height||260)-safe);left=Math.max(safe,Math.min(maxLeft,left));top=Math.max(safe,Math.min(maxTop,top));m.style.left=Math.round(left)+'px';m.style.top=Math.round(top)+'px';m.style.right='auto';return true}catch(e){try{console.warn('v289 viewshed clamp failed',e)}catch(_){}return false}}
  function scheduleViewshedClamp(reset){setTimeout(()=>clampViewshedModule(reset),0);setTimeout(()=>clampViewshedModule(false),120);setTimeout(()=>clampViewshedModule(false),350);setTimeout(()=>clampViewshedModule(false),900)}
  function bindViewshed(){try{const old=window.toggleViewshedModule;if(typeof old==='function'&&!old._v289Wrapped){window._v289BaseToggleViewshedModule=old;const wrapped=function(){const res=window._v289BaseToggleViewshedModule.apply(this,arguments);try{const m=q('#viewshedModule');const explicit=arguments.length?!!arguments[0]:(m&&m.classList.contains('active'));if(explicit)scheduleViewshedClamp(false)}catch(_){}return res};wrapped._v289Wrapped=true;window.toggleViewshedModule=wrapped}const btn=q('#toolViewshed');if(btn&&!btn.dataset.v289ViewshedBound){btn.dataset.v289ViewshedBound='1';btn.addEventListener('click',()=>scheduleViewshedClamp(false),true)}if(!window._v289ViewshedResizeBound){window._v289ViewshedResizeBound=true;window.addEventListener('resize',()=>scheduleViewshedClamp(false),{passive:true});window.addEventListener('orientationchange',()=>scheduleViewshedClamp(false),{passive:true})}}catch(e){try{console.warn('v289 viewshed bind failed',e)}catch(_){}}}
  function showLocalElevationDialog(){let d=q('#localElevationDialog');if(d){d.classList.add('active');d.style.visibility='visible';d.style.opacity='1';d.style.pointerEvents='auto';return true}return false}
  function bindLocalElevation(){try{const current=window.openLocalElevationDialog;if(typeof current==='function'&&!current._v289Wrapped&&!window._v289BaseOpenLocalElevationDialog)window._v289BaseOpenLocalElevationDialog=current;const safe=function(ev){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}}catch(_){}try{if(typeof window.localElevationBoot==='function')window.localElevationBoot()}catch(_){}try{const base=window._v289BaseOpenLocalElevationDialog;if(typeof base==='function'&&base!==safe)base.call(window)}catch(e){try{console.warn('v289 local elevation base open failed',e)}catch(_){}}setTimeout(showLocalElevationDialog,0);setTimeout(showLocalElevationDialog,160);return false};safe._v289Wrapped=true;window.openLocalElevationDialog=safe;const btn=q('#localElevAddBtn');if(btn){btn.onclick=safe;if(!btn.dataset.v289LocalElevBound){btn.dataset.v289LocalElevBound='1';btn.addEventListener('click',safe,true)}}}catch(e){try{console.warn('v289 local elevation bind failed',e)}catch(_){}}}
  function boot(){addCss();setIteration();bindViewshed();bindLocalElevation();scheduleViewshedClamp(false)}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
