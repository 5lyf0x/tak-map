  window.drawAircraft=function(items){if(terrain3DActive)return;aircraftLayer.clearLayers();window.v240AircraftLayersById={};window.v238AircraftLayersById=window.v240AircraftLayersById;window.v236AircraftLayersById=window.v240AircraftLayersById;try{clearSearchSource('aircraft')}catch(_){};(items||[]).forEach(ac=>{if(ac.lat==null||ac.lon==null)return;const id=adsbKey(ac);const m=L.marker([ac.lat,ac.lon],{icon:window.aircraftIcon(ac),autoPan:false}).addTo(aircraftLayer);window.v240AircraftLayersById[id]=m;m.bindPopup(window.adsbPopupHtml?window.adsbPopupHtml(ac):'',{autoPan:false,closeButton:true,className:'tak-object-popup adsb-object-popup'});try{if(typeof stabilizeLayerPopup==='function')stabilizeLayerPopup(m)}catch(_){}m.on('click',ev=>{try{L.DomEvent.stopPropagation(ev);selectedAircraftId=id;m.setIcon(window.aircraftIcon(ac));m.openPopup()}catch(_){}});try{addSearchItem('aircraft','ADS-B '+aircraftTypeLabel(ac),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}catch(_){}});try{handleMapSearch()}catch(_){}};
