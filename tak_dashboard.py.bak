put id="viewshedLon" class="viewshed-input" inputmode="decimal" placeholder="-118.000000"></div><div class="viewshed-row"><label>Height</label><input id="viewshedHeight" class="viewshed-input short" type="number" step="1" value="6"><select id="viewshedHeightUnit" class="viewshed-select"><option value="ft">ft</option><option value="m">m</option></select></div><div class="viewshed-row"><label>Radius</label><input id="viewshedRadius" class="viewshed-input short" type="number" min="1" step="0.1" value="2.0"><select id="viewshedRadiusUnit" class="viewshed-select"><option value="mi">mi</option><option value="ft">ft</option><option value="m">m</option><option value="km">km</option></select></div><div class="viewshed-row"><label>Quality</label><select id="viewshedQuality" class="viewshed-select quality"><option value="Ultra">Ultra</option><option value="High">High</option><option value="Medium">Medium</option><option value="Low">Low</option></select></div></div><div class="viewshed-section"><p class="viewshed-section-title">Style</p><div class="viewshed-row"><label>Visible</label><input id="viewshedVisibleColor" class="viewshed-color" type="color" value="#46d16c"><input id="viewshedVisibleOpacity" class="viewshed-range visible" type="range" min="0" max="100" value="68" title="Transparent → Opaque"></div><div class="viewshed-row"><label>Blocked</label><input id="viewshedBlockedColor" class="viewshed-color" type="color" value="#ef514d"><input id="viewshedBlockedOpacity" class="viewshed-range blocked" type="range" min="0" max="100" value="44" title="Transparent → Opaque"></div></div><div class="viewshed-btn-row"><button id="viewshedCalc" class="viewshed-btn">Calculate</button><button id="viewshedHideOverlay" class="viewshed-btn alt">Hide</button></div><button id="viewshedClearAll" class="viewshed-btn alt" style="width:100%;margin-top:6px">Clear All Viewsheds</button><div class="viewshed-row viewshed-elevation-source-row" style="margin-top:7px"><label>Elev</label><select id="vi