  function getWorker(){if(window._v278AdsbWorker)return window._v278AdsbWorker;const w=new Worker(URL.createObjectURL(new Blob([workerCode()],{type:'text/javascript'})));window._v278Seq=0;window._v278Jobs={};w.onmessage=ev=>{const d=ev.data||{},j=window._v278Jobs&&window._v278Jobs[d.id];if(!j)return;delete window._v278Jobs[d.id];d.ok?j.resolve(d):j.reject(new Error(d.error||'fetch failed'))};window._v278AdsbWorker=w;return w}
