'''
if 'id="v292ElevationCompatibilityPatch"' not in TAK_MAP_HTML:
    TAK_MAP_HTML = TAK_MAP_HTML.replace('</body></html>', _v292_elevation_compat_patch + '</body></html>')
# Keep static local elevation compatibility text/direct-file controls aligned with the v292 runtime patch.
TAK_MAP_HTML = TAK_MAP_HTML.replace('accept=".hgt,.dt0,.dt1,.dt2,.tif,.tiff,.zip"', 'accept=".hgt,.dt0,.dt1,.dt2,.tif,.tiff"')
