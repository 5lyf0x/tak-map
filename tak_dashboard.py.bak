  function findAircraft(id){id=String(id||'').toLowerCase();return aircraftList().find(a=>idOf(a)===id)||null}
  function pointFrom(a){const lat=Number(a&&a.lat),lon=Number(a&&a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return null;let alt=Number(a&&(a.altitude_ft??a.alt_baro??a.alt_geom));if(!Number.isFinite(alt)||String(a&&(a.altitude_ft??a.alt_baro??a.alt_geom)).toLowerCase()==='ground')alt=0;return {lat,lon,alt,t:Date.now()}}
  function rad(x){return x*Math.PI/180}
  function meters(pts){let m=0;pts=pts||[];for(let i=1;i<pts.length;i++){const a=pts[i-1],b=pts[i];if(!a||!b)continue;const R=6371008.8,dLat=rad(b.lat-a.lat),dLon=rad(b.lon-a.lon),la1=rad(a.lat),la2=rad(b.lat);const h=Math.sin(dLat/2)**2+Math.cos(la1)*Math.cos(la2)*Math.sin(dLon/2)**2;m+=2*R*Math.asin(Math.min(1,Math.sqrt(h)));}return m}
  function distText(m){m=Number(m)||0;return (m/1609.344).toFixed(1)+'mi/'+(m/1000).toFixed(1)+'km'}
  function ensureLayers(){const m=getMap();if(!m||!window.L)return null;let g=window[TRACK_LAYER];if(!g){g=L.layerGroup().addTo(m);window[TRACK_LAYER]=g}else if(!m.hasLayer(g))g.addTo(m);let l=window[LABEL_LAYER];if(!l){l=L.layerGroup().addTo(m);window[LABEL_LAYER]=l}else if(!m.hasLayer(l))l.addTo(m);return {map:m,track:g,label:l}}
  function clearVisual(){try{const layers=ensureLayers();if(layers){layers.track.clearLayers();layers.label.clearLayers()}state.line=null;state.label=null}catch(_){} }
  function syncButtons(){try{qa('.adsb-track-btn').forEach(btn=>{const id=String(btn.dataset.adsbTrackId||'').toLowerCase();const on=!!(state.id&&id===state.id);btn.classList.toggle('active',on);btn.setAttribute('aria-pressed',on?'true':'false');const light=q('.adsb-track-light',btn);if(light)light.classList.toggle('active',on)})}catch(_){} }
  function redraw(){try{const layers=ensureLayers();if(!layers)return;layers.track.clearLayers();layers.label.clearLayers();const ll=state.points.map(p=>[p.lat,p.lon]);if(ll.length>=2){state.line=L.polyline(ll,{color:COLOR,weight:4,opacity:.96,lineCap:'round',lineJoin:'round',interactive:false}).addTo(layers.track);try{state.line.bringToFront()}catch(_){}}if(ll.length>=1){const txt=distText(meters(state.points));state.label=L.marker(ll[ll.length-1],{interactive:false,zIndexOffset:1600,icon:L.divIcon({className:'adsb-track-distance-label-wrap',html:'<div class="adsb-track-distance-label v300">'+esc(txt)+'</div>',iconAnchor:[0,0]})}).addTo(layers.label)}syncButtons()}catch(e){try{console.warn('v300 ADS-B track redraw failed',e)}catch(_){} }}
  function addPoint(a){try{if(!state.id||!a||idOf(a)!==state.id)return false;const p=pointFrom(a);if(!p)return false;const pts=state.points;const last=pts[pts.length-1];if(last){const d=meters([last,p]);if(d<3)return false;}pts.push(p);if(pts.length>LIMIT)pts.splice(0,pts.length-LIMIT);redraw();return true}catch(_){return false}}
