  function boot(redraw){setVersion();removeRefreshLocalButton();installCss();patchLeaflet();installOverrides();installHandlers();installFetchHook();qa('.leaflet-popup').forEach(function(el){if(q('.tak-v322-popup,.tak-v321-popup,.tak-v320-popup,.feature-popup',el)){el.classList.add('tak-v322-object-popup');const close=q('.leaflet-popup-close-button',el);if(close)close.innerHTML='×'}});if(redraw)redrawExisting()}
  if(d.readyState==='loading')d.addEventListener('DOMContentLoaded',function(){setTimeout(function(){boot(false)},120)},{once:true});else setTimeout(function(){boot(false)},120);
  [[500,false],[1500,true],[3000,false],[6500,true]].forEach(function(item){setTimeout(function(){boot(item[1])},item[0])});setInterval(function(){setVersion();removeRefreshLocalButton()},2500);
})();
</script>
