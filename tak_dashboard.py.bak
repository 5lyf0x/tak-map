  function affiliation(o){return clean(o&&(o.affiliation||o.team||o.group||o.side))}
  function row(k,v){if(!present(v))return '';return '<div class="tak-v322-row"><b>'+esc(k)+'</b><span>'+esc(v)+'</span></div>'}
  function table(rows){return '<div class="tak-v322-table">'+(rows||'')+'</div>'}
  function popupChrome(title,sub,rows,edit,kind,source){return '<div class="tak-v322-popup" data-kind="'+esc(kind||'Object')+'" data-source="'+esc(source||'')+'"><div class="tak-v322-bar"></div><div class="tak-v322-inner"><div class="tak-v322-title">'+esc(title||'Object')+'</div><div class="tak-v322-sub">'+esc(sub||'')+'</div>'+table(rows||'')+(edit||'')+'</div></div>'}
  function editForm(o,source,kind,cat){o=o||{};source=source||sourceLabel(o,'object');kind=kind||kindFor(o,cat);cat=categoryText(o,cat);const c=coordsText(o),coord=firstCoord(o),key=sourceKey(o,source),lid=localId(o),showCategory=(kind==='Route'||kind==='Shape');let fields='<div class="tak-v322-edit-fields">';fields+='<label>Name<input name="name" value="'+esc(objectName(o))+'"></label>';if(showCategory)fields+='<label>Category<input name="category" value="'+esc(cat)+'" readonly></label>';fields+='<label>Lat/Lon<input name="latlon" value="'+esc(c)+'" placeholder="34.000000, -118.000000"></label>';fields+='<input type="hidden" name="lat" value="'+esc(fmt(coord.lat))+'"><input type="hidden" name="lon" value="'+esc(fmt(coord.lon))+'">';fields+='<label>Notes<textarea name="notes" rows="3">'+esc(notesText(o))+'</textarea></label></div>';return '<details class="popup-edit tak-v322-edit" onclick="event.stopPropagation()"><summary>Edit</summary>'+fields+'<div class="tak-v322-actions"><button type="button" class="primary" data-v322-popup-action="save" data-v321-popup-action="save" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Save</button><button type="button" data-v322-popup-action="cancel" data-v321-popup-action="cancel">Cancel</button><button type="button" class="danger" data-v322-popup-action="delete" data-v321-popup-action="delete" data-popup-key="'+esc(key)+'" data-popup-source="'+esc(source)+'" data-local-id="'+esc(lid)+'">Delete</button></div></details>'}
  function pointPopupHtmlV322(o,cat){o=o||{};const kind='Point',src=sourceLabel(o,cat),sub=kind+' · '+src;const rows=row('Affiliation',affiliation(o))+row('Added',addedText(o))+row('Lat/Lon',coordsText(o))+row('Battle Dim',battleDimension(o))+row('Notes',notesText(o));return popupChrome(objectName(o),sub,rows,editForm(o,src,kind,cat),kind,src)}
  function layerPopupForObjectV322(o,cat){o=o||{};cat=categoryText(o,cat);const kind=kindFor(o,cat),src=sourceLabel(o,cat);if(kind==='Point')return pointPopupHtmlV322(o,cat);let rows=row('Category',cat||kind)+row('Lat/Lon',coordsText(o))+row('Points',pointCount(o));if(kind==='Route')rows+=row('Distance',distanceText(o));if(kind==='Shape')rows+=row('Area',areaText(o));rows+=row('Added',addedText(o))+row('Notes',notesText(o));return popupChrome(objectName(o),kind+' · '+src,rows,editForm(o,src,kind,cat),kind,src)}
