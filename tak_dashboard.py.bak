inp.focus();inp.select();function commit(){const val=(inp.value||\'\').trim()||(\'View \'+(i+1));st.views[i].name=val;renderViewshedUi()}inp.addEventListener(\'blur\',commit,{once:true});inp.addEventListener(\'keydown\',e=>{if(e.key===\'Enter\'){e.preventDefault();inp.blur()}if(e.key===\'Escape\'){e.preventDefault();renderViewshedUi()}})}\n  function renderViewshedUi(){try{renderTabs();const v=activeVs();field(\'viewshedLat\').value=v.lat==null?\'\':Number(v.lat).toFixed(6);field(\'viewshedLon\').value=v.lon==null?\'\':Number(v.lon).toFixed(6);field(\'viewshedHeight\').value=v.height;field(\'viewshedHeightUnit\').value=v.heightUnit;field(\'viewshedRadius\').value=v.radius;field(\'viewshedRadiusUnit\').value=v.radiusUnit;v.quality=v.quality||autoViewshedQuality(v.radius,v.radiusUnit);if(field(\'viewshedQuality\'))field(\'viewshedQuality\').value=v.quality;field(\'viewshedVisibleColor\').value=v.visibleColor;field(\'viewshedBlockedColor\').value=v.blockedColor;field(\'viewshedVisibleOpacity\').value=Math.round((v.visibleOpacity??.68)*100);field(\'viewshedBlockedOpacity\').value=Math.round((v.blockedOpacity??.44)*100);if(field(\'viewshedElevationSource\'))field(\'viewshedElevationSource\').value=v.elevationSource||\'Auto\';if(field(\'viewshedAcceleration\'))field(\'viewshedAcceleration\').value=v.acceleration||\'Auto\';if(field(\'viewshedCacheElevation\'))field(\'viewshedCacheElevation\').checked=v.cacheElevation!==false;field(\'viewshedHideOverlay\').textContent=v.hidden?\'Show\':\'Hide\';setViewshedStatus(v.status||v.elevationStatus||\'Elevation: ready.\')}catch(_){} }\n  function readViewshedFields(changedId){try{const v=activeVs();const lat=Number(field(\'viewshedLat\').value),lon=Number(field(\'viewshedLon\').value);v.lat=Number.isFinite(lat)?lat:null;v.lon=Number.isFinite(lon)?lon:null;const oldRadius=v.radius,oldUnit=v.radiusUnit;v.height=clamp(field(\'viewshedHeight\').value,0,100000,6);v.heightUnit=field(\'viewshedHeightUnit\').value||\'ft\';v.radius=clamp(fie