# --- TAK Map v309 ADS-B ownership reset + Viewshed targeted patch ---
try:
    import re as _v309_re
    def _v309_remove_script_block(_html, _sid):
        return _v309_re.sub(r'<script[^>]*id=["\']'+_v309_re.escape(_sid)+r'["\'][^>]*>.*?</script>\s*', '', _html, count=0, flags=_v309_re.S)
    def _v309_strip_adsb_owners(_html):
        for _sid in (
            'v282Preflight',
            'v284AdsbPopupCloseClassPatch',
            'v288AdsbStatusSortGovtPatch',
            'v294TerrainLocalCoverageAdsbStabilityPatch',
            'v296AdsbStableLocalTerrainPatch',
