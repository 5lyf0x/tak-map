  function clearCoverageEntities(){try{const viewer=(typeof terrain3DViewer!=='undefined'&&terrain3DViewer)||window.terrain3DViewer;if(!viewer||!viewer.entities)return;const arr=window._v294TerrainCoverageEntities||[];arr.forEach(e=>{try{viewer.entities.remove(e)}catch(_){}});window._v294TerrainCoverageEntities=[];try{viewer.scene&&viewer.scene.requestRender&&viewer.scene.requestRender()}catch(_){}}catch(_){} }
  async function renderCoverageEntities(){try{const viewer=(typeof terrain3DViewer!=='undefined'&&terrain3DViewer)||window.terrain3DViewer;if(!viewer||!window.Cesium||!viewer.entities){setCoverageChip(uniqueTiles().length);return}clearCoverageEntities();const isLocal=String(window.terrain3DElevationSource||'streamed').toLowerCase()==='local';const tiles=await ensureLocalTiles();setCoverageChip(tiles.length);if(!isLocal||!tiles.length)return;const colors=[Cesium.Color.ORANGE,Cesium.Color.CYAN,Cesium.Color.LIME,Cesium.Color.YELLOW,Cesium.Color.MAGENTA,Cesium.Color.DEEPSKYBLUE];window._v294TerrainCoverageEntities=[];tiles.forEach((t,i)=>{try{const b=tileBounds(t);if(!b)return;const h=35+(i%5)*8;const coords=[b.west,b.south,h,b.east,b.south,h,b.east,b.north,h,b.west,b.north,h,b.west,b.south,h];const col=(colors[i%colors.length]||Cesium.Color.ORANGE).withAlpha(.95);const ent=viewer.entities.add({name:'Elevation coverage: '+String(t.name||t.id||'local'),polyline:{positions:Cesium.Cartesian3.fromDegreesArrayHeights(coords),width:4,material:col,clampToGround:false}});window._v294TerrainCoverageEntities.push(ent)}catch(e){console.warn('v294 coverage entity failed',e)}});try{viewer.scene&&viewer.scene.requestRender&&viewer.scene.requestRender()}catch(_){}}catch(e){console.warn('v294 render coverage failed',e)} }
