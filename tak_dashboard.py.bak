  function toolbarBottomY(){try{const tb=q('#floatingToolbarDock')||q('.floating-toolbar,.map-toolbar,.toolbar');if(tb){const r=tb.getBoundingClientRect();if(r&&Number.isFinite(r.bottom)&&r.bottom>0)return Math.max(80,Math.min(window.innerHeight-80,r.bottom+12));}}catch(_){}return 96}
  function addCss(){try{if(q('#v289ElevationViewshedStyle'))return;const st=document.createElement('style');st.id='v289ElevationViewshedStyle';st.textContent=`
    #viewshedModule.viewshed-module{max-width:calc(100vw - 16px)!important;max-height:calc(100vh - 16px)!important;overflow:hidden!important;box-sizing:border-box!important;}
