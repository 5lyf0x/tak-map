p">${milShape(affKey(String([o?.type,o?.cot_type,o?.uid,o?.callsign,o?.name,o?.source].filter(Boolean).join(\' \'))),\'\', \'\')}</div>`}function dataSyncCategory(o){const g=String(o?.geometry||o?.kind||\'\').toLowerCase();const t=String([o?.type,o?.source,o?.uid,o?.callsign,o?.filename,o?.name].filter(Boolean).join(\' \')).toLowerCase();if(g===\'route\'||/route|track|path|gpx/.test(t))return\'Routes\';if(g===\'shape\'||/shape|polygon|rectangle|circle|ellipse|area|polyline|freehand|corridor|sector/.test(t))return\'Shapes / Areas\';if(g===\'other\'||/file|package|attachment|zip|kmz|kml|geojson/.test(t))return\'Files / Packages\';if(o&&o.lat!=null&&o.lon!=null)return\'Point Markers\';return\'Other / Unknown\'}function routeShapeIconHtml(cat){const isRoute=cat===\'Routes\';const c=isRoute?\'#ff8a2a\':\'#ffb000\';const body=isRoute?`<path d="M7 24 C13 12 22 30 30 14" fill="none" stroke="${c}" stroke-width="3" stroke-linecap="round"/>`:`<rect x="7" y="9" width="22" height="20" rx="4" fill="rgba(255,176,0,.10)" stroke="${c}" stroke-width="2.5" stroke-dasharray="4 3"/>`;return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="36" height="40" viewBox="0 0 36 40">${body}<circle cx="18" cy="37" r="3" fill="${c}"/></svg></div>`}function dataSyncIcon(o){const cat=dataSyncCategory(o);if(cat===\'Routes\'||cat===\'Shapes / Areas\')return L.divIcon({className:\'\',html:routeShapeIconHtml(cat),iconSize:[36,40],iconAnchor:[18,22]});return L.divIcon({className:\'\',html:mil2525IconHtml(o),iconSize:[36,40],iconAnchor:[18,22]})}function isFiniteLatLon(lat,lon){lat=Number(lat);lon=Number(lon);return Number.isFinite(lat)&&Number.isFinite(lon)&&lat>=-90&&lat<=90&&lon>=-180&&lon<=180}function coordPair(x){if(Array.isArray(x)&&x.length>=2){const lat=Number(x[0]),lon=Number(x[1]);if(isFiniteLatLon(lat,lon))return [lat,lon]}else if(x&&typeof x===\'object\'){const lat=Number(x.lat??x.latitude);const lon=Number(x.lng??x.lon??x.longitude);if(isFiniteLatLon(lat,lon))return [lat,lon]}return null}function collectCoordPairs(value){const out=[];const walk=x=>{const p=coordPair(x);if(p){out.push(p);return}if(Array.isArray(x)){for(const y of x)walk(y)}};walk(value);return out}function routeCoords(o){return collectCoordPairs(o?.coords)}function shapeCoords(o){const c=o?.coords;if(!Array.isArray(c))return[];const direct=c.map(coordPair).filter(Boolean);if(direct.length===c.length&&direct.length>=3)return direct;const rings=[];for(const r of c){if(Array.isArray(r)){const pts=r.map(coordPair).filter(Boolean);if(pts.length>=3)rings.push(pts)}}if(rings.length)return rings.length===1?rings[0]:rings;return collectCoordPairs(c)}\nfunction shapeAreaSqMeters(o){try{const pts=collectCoordPairs(o?.coords||o);if(!pts||pts.length<3)return 0;const lat0=pts.reduce((a,p)=>a+Number(p[0]||0),0)/pts.length;const lon0=pts.reduce((a,p)=>a+Number(p[1]||0),0)/pts.length;const R=6378137;const xy=pts.map(p=>{const lat=Number(p[0])*Math.PI/180,lon=Number(p[1])*Math.PI/180;return {x:R*(lon-lon0*Math.PI/180)*Math.cos(lat0*Math.PI/180),y:R*(lat-lat0*Math.PI/180)}});let a=0;for(let i=0,j=xy.length-1;i<xy.length;j=i++){a+=(xy[j].x*xy[i].y-xy[i].x*xy[j].y)}return Math.abs(a/2)}catch(e){return 0}}\nfunction shapeAreaPopupRows(o){const m2=shapeAreaSqMeters(o);if(!m2)return\'\';const sqft=m2*10.7639104167;return `<b>Area</b><span>${Math.round(sqft).toLocaleString()} sq ft · ${Math.round(m2).toLocaleString()} sq m</span>`}\nfunction objectCenter(o){if(o&&isFiniteLatLon(o.lat,o.lon))return [Number(o.lat),Number(o.lon)];const pts=collectCoordPairs(o?.coords);if(pts.length)return [pts.reduce((a,p)=>a+p[0],0)/pts.length,pts.reduce((a,p)=>a+p[1],0)/pts.length];return null}function layerPopupForObject(o,cat){if(cat===\'Point Markers\')return pointPopupHtml(o,cat);const name=o?.name||o?.callsign||o?.uid||o?.id||cat;const notes=popupNotes(o);const cen=objectCenter(o);const coordText=cen?formatCoords(cen[0],cen[1]):formatCoords(o?.lat,o?.lon);const assetRow=(cat===\'Shapes / Areas\')?shapeAreaPopupRows(o):`<b>Asset</b><span>${esc(assetDescriptor(o))}</span>`;return `<div class="feature-popup"><h3>${esc(name)}</h3><div class="kvp"><b>Name</b><span>${esc(name)}</span><b>Added</b><span>${esc(addedTime(o))}</span><b>Coordinates</b><span>${esc(coordText)}</span>${assetRow}<b>Category</b><span>${esc(cat)}</span>${notes?`<b>Notes</b><span>${esc(notes)}</span>`:\'\'}</div>${popupEditForm({...o,lat:cen?cen[0]:o?.lat,lon:cen?cen[1]:o?.lon},cat||\'Data Sync\')}</div>`}function addObjectLayer(group,o,sourceKey){const cat=dataSyncCategory(o);let layer=null;const cen=objectCenter(o);try{if(cen&&(!isFiniteLatLon(o?.lat,o?.lon))){o.lat=cen[0];o.lon=cen[1]}if(cat===\'Routes\'){const pts=routeCoords(o);if(pts.length>=2){const dash=(o.lineStyle===\'dashed\'||o.style===\'dashed\'||o.line_style===\'dashed\'||o.route_style===\'dashed\')?\'8,7\':null;layer=L.polyline(pts,{color:(o.color||\'#ff7a1a\'),weight:3,opacity:.9,dashArray:dash}).bindPopup(layerPopupForObject(o,cat)).addTo(group);try{const hit=L.polyline(pts,{color:\'#000\',weight:16,opacity:0,interactive:true}).addTo(group);hit.bindPopup(layer.getPopup());hit.on(\'click\',ev=>{try{L.DomEvent.stop(ev);layer.openPopup(ev.latlng)}catch(_){}});o.__hitLayer=hit}catch(_){}}}else if(cat===\'Shapes / Areas\'){const pts=shapeCoords(o);const flat=collectCoordPairs(pts);if(flat.length>=3)layer=L.polygon(pts,{color:\'#ffb000\',weight:2,fillOpacity:.18}).bindPopup(layerPopupForObject(o,cat)).addTo(group)}else if(cen){layer=L.marker(cen,{icon:dataSyncIcon(o)}).bindPopup(layerPopupForObject(o,cat)).addTo(group);layer.on(\'click\',()=>map.panTo(cen,{animate:true}))}}catch(e){try{console.warn(\'Skipped invalid map object\',o,e)}catch(_){}}if(layer){stabilizeLayerPopup(layer);o.__layer=layer;const center=cen||objectCenter(o);if(center)addSearchItem(sourceKey||\'datasync\',(sourceKey===\'imported\'?\'Imported \':\'Data Sync \')+cat,o.callsign||o.name||o.uid||o.id||cat,center[0],center[1],layer,o)}return layer}async function centerDataSyncIndex(idx){await autoSaveActivePopupEdit(\'switch-data-sync-item\');const o=(lastDataSync?.objects||[])[Number(idx)];const cen=objectCenter(o);if(!o||!cen)return;map.panTo(cen,{animate:true});if(o.__layer){setTimeout(()=>{try{o.__layer.openPopup()}catch(e){}},180)}}async function openDataSyncItemEdit(idx,ev){if(ev)ev.stopPropagation();await centerDataSyncIndex(idx);setTimeout(()=>{try{const box=document.querySelector(\'.leaflet-popup .popup-edit\');if(box){box.open=true;popupEditToggle(box);const first=popupEditInputs(box)[0];if(first)first.focus()}}catch(e){}},320)}async function deleteDataSyncItem(idx,ev){if(ev)ev.stopPropagation();idx=Number(idx);const o=(lastDataSync?.objects||[])[idx];if(!o)return;const label=o.callsign||o.name||o.uid||o.id||\'Data Sync item\';if(!confirm(\'Delete \'+label+\' from the TAK Map view?\'))return;await autoSaveActivePopupEdit(\'delete-data-sync\');try{const r=await fetch(\'/api/tak-map/popup-edit\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({key:popupEditKey(o),source:o.source||\'Data Sync\',delete_item:true}),cache:\'no-store\'});const j=await apiJsonResponseAllowFalse(r);if(!j.ok)throw new Error(j.error||\'delete failed\');try{if(o.__layer)dataSyncLayer.removeLayer(o.__layer);if(map&&map.closePopup)map.closePopup()}catch(_){ }try{if(lastDataSync&&Array.isArray(lastDataSync.objects)){lastDataSync.objects=lastDataSync.objects.filter((_,i)=>i!==idx);drawDataSyncObjects(lastDataSync.objects);renderDataSyncRows()}}catch(_){ }await forceDataSyncSync(\'data-sync-delete\');await refreshCot();await refreshImports();await refreshLocalData()}catch(e){alert(\'Delete failed: \'+e)}}function drawDataSyncObjects(items){if(terrain3DActive){handleMapSearch();refreshTerrain3DObjects(false,\'datasync\');return}dataSyncLayer.clearLayers();clearSearchSource(\'datasync\');if(!state.dataSync){handleMapSearch();refreshTerrain3DObjects(false,\'datasync-off\');return}for(let idx=0;idx<(items||[]).length;idx++){addObjectLayer(dataSyncLayer,items[idx],\'datasync\')}handleMapSearch();refreshTerrain3DObjects(false,\'datasync\')}function toggleDataSyncSection(kind){try{state.dataSyncCollapsed[kind]=!state.dataSyncCollapsed[kind];saveTakMapUiPrefs();renderDataSyncRows()}catch(e){try{console.warn(\'toggleDataSyncSection failed\',e)}catch(_){}}}function renderDataSyncSection(kind,title,items,renderItem,limit){items=items||[];limit=limit||80;const collapsed=!!state.dataSyncCollapsed[kind];let html=`<div class="datasync-section ${collapsed?\'collapsed\':\'\'}"><div class="datasync-section-title subgroup-title" onclick="toggleDataSyncSection(\'${kind}\')" role="button" aria-expanded="${collapsed?\'false\':\'true\'}"><span class="toggle">${collapsed?\'›\':\'⌄\'}</span><span class="section-label">${esc(title)}</span><span class="chip">${items.length}</span></div><div class="datasync-section-list">`;html+=items.length?items.slice(0,limit).map(renderItem).join(\'\'):`<div class="muted datasync-empty">None.</div>`;if(items.length>limit)html+=`<div class="muted datasync-empty">Showing ${limit} of ${items.length}.</div>`;html+=\'</div></div>\';return html}function renderDataSyncRows(){const box=document.getElementById(\'dataSyncRows\');if(!box||!lastDataSync)return;const missions=(lastDataSync.missions||[]);const objects=(lastDataSync.objects||[]);const packages=(lastDataSync.packages||[]);let html=\'\';html+=renderDataSyncSection(\'missions\',\'Missions\',missions,m=>`<div class="sync-card"><b>${esc(missionNameFromAny(m))}</b><small>${esc(missionDisplayMeta(m))}</small></div>`,24);const groups={\'Pointers\':[],\'Routes\':[],\'Shapes / Areas\':[],\'Files / Packages\':[],\'Other / Unknown\':[]};for(let i=0;i<objects.length;i++){const o=objects[i];o.__idx=i;const cat=dataSyncCategory(o);const key=cat===\'Point Markers\'?\'Pointers\':cat;(groups[key]||groups[\'Other / Unknown\']).push(o)}for(const p of packages){groups[\'Files / Packages\'].push(p)}const objectCard=o=>{const idx=o.__idx;const label=o.