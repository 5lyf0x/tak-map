|green\\b/.test(raw))return\'neutral\';if(/\\ba-u-|unknown|suspect|gray|grey\\b/.test(raw))return\'unknown\';return\'friendly\'}function mil2525CandidateExists(name){return MIL2525_ICON_FILES.has(String(name||\'\')+\'.svg\')?String(name)+\'.svg\':\'\'}function firstMil2525Candidate(names){for(const n of names){const f=mil2525CandidateExists(n);if(f)return f}return \'\'}function generatedMil2525File(o){const sidc=explicitSidc(o);const sidcFile=sidcFileFromSidc(sidc);if(sidcFile)return sidcFile;const aff=affSlugFromMarker(o);const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.callsign,o?.name,o?.title,o?.category,o?.source,o?.filename].filter(Boolean).join(\' \')).toLowerCase();const desc=assetDescriptor(o);let c=[];if(/civilian|civil|civ/.test(t)){if(/auto|car|sedan/.test(t))c.push(`${aff}-ground-equipment-civilian-automobile`,`${aff}-ground-equipment-sedan`);if(/suv/.test(t))c.push(`${aff}-ground-equipment-suv`);if(/pickup|truck/.test(t))c.push(`${aff}-ground-equipment-pickup`,`${aff}-ground-equipment-civilian-pickup`);c.push(`${aff}-ground-equipment-civilian-vehicle`)}if(/drone|uas|uav|quadcopter/.test(t))c.push(`${aff}-air-quadcopter`,`${aff}-air-drone-fixed-wing`,`${aff}-air-small-uav`);if(/heli|rotary/.test(t)||desc===\'Helicopter\')c.push(`${aff}-air-utility-helicopter`,`${aff}-air-civil-rotary-wing`,`${aff}-air-rotary-wing`);if(/aircraft|fixed|air\\b|a-[fhnu]-a/.test(t)||desc===\'Aircraft\')c.push(`${aff}-air-civil-fixed-wing`,`${aff}-air-civil-aircraft`,`${aff}-air-generic`);if(/ship|boat|vessel|maritime|sea|surface/.test(t))c.push(`${aff}-sea-surface-civil-vessel`,`${aff}-sea-surface-patrol-boat`,`${aff}-sea-surface-generic`);if(/submarine|subsurface|uuv|diver/.test(t))c.push(`${aff}-subsurface-submarine`,`${aff}-subsurface-generic`);if(/space|satellite/.test(t))c.push(`${aff}-space-satellite`,`${aff}-space-generic`);if(desc===\'Air defense\')c.push(`${aff}-ground-unit-air-defense`,`${aff}-ground-equipment-sam-launcher`);if(desc===\'Radar / sensor\')c.push