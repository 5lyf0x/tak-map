    const draw=document.getElementById('drawMiniToolbar');
    if(draw&&!draw.dataset.v236Icons){draw.dataset.v236Icons='1';draw.classList.add('compact-icon-toolbar');draw.innerHTML=`<button class="tool-btn" onclick="v233FinishDraw()" title="Finish / Save Shape">${iconSvg('finish')}<span class="tool-label">Finish</span></button><button class="tool-btn" onclick="v233UndoDraw()" title="Undo Point">${iconSvg('undo')}<span class="tool-label">Undo</span></button><button class="tool-btn" onclick="v233ClearDraw()" title="Clear Shape">${iconSvg('clear')}<span class="tool-label">Clear</span></button><button class="tool-btn" onclick="v236OpenDrawOptions()" title="Shape Options">${iconSvg('options')}<span class="tool-label">Options</span></button><button class="tool-btn" onclick="setActiveMapTool('move')" title="Cancel">${iconSvg('cancel')}<span class="tool-label">Cancel</span></button>`}
    const menu=document.getElementById('drawToolMenu');
    if(menu&&!menu.dataset.v236Icons){menu.dataset.v236Icons='1';menu.classList.add('draw-icon-menu');menu.innerHTML=`<button title="Square" onclick="v233StartDraw('square')">${iconSvg('square')}</button><button title="Rectangle" onclick="v233StartDraw('rectangle')">${iconSvg('rect')}</button><button title="Circle" onclick="v233StartDraw('circle')">${iconSvg('circle')}</button><button title="Ellipse" onclick="v233StartDraw('ellipse')">${iconSvg('ellipse')}</button><button title="Polygon" onclick="v233StartDraw('polygon')">${iconSvg('poly')}</button><button title="Freehand Lasso" onclick="v233StartDraw('freehand')">${iconSvg('lasso')}</button>`}
  }catch(e){}}
  function ensureDrawPanel(){try{if(document.getElementById('drawOptionsPanel'))return;document.body.insertAdjacentHTML('beforeend',`<div id="drawOptionsPanel" class="tak-floating-panel draw-options-panel"><h3>Shape Options</h3><div class="panel-grid compact"><label class="wide">Name<input id="drawNameInput" placeholder="Shape name"></label><label>Color<input id="drawColorInput" type="color" value="#ff6f2e"></label><label>Line<input id="drawWeightInput" type="number" min="1" max="12" step="1" value="3"></label><label>Style<select id="drawLineStyleInput"><option value="solid">Solid</option><option value="dashed">Dashed</option></select></label><label>Fill<select id="drawFillInput"><option value="1">Filled</option><option value="0">Unfilled</option></select></label><label>Fill %<input id="drawFillOpacityInput" type="number" min="0" max="100" step="5" value="20"></label></div><div class="tak-floating-actions"><button onclick="v236CloseDrawOptions()">Close</button><button class="primary" onclick="v236ApplyDrawOptions()">Apply</button></div></div>`);['drawColorInput','drawWeightInput','drawLineStyleInput','drawFillInput','drawFillOpacityInput','drawNameInput'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener('input',()=>{v236ReadDrawOptions();v236RedrawDrawTemp()});if(el)el.addEventListener('change',()=>{v236ReadDrawOptions();v236RedrawDrawTemp()})})}catch(e){}}
  function drawOptions(){const st=window.v233DrawState=window.v233DrawState||{};st.color=st.color||'#ff6f2e';st.weight=Number(st.weight||3);st.lineStyle=st.lineStyle||'solid';st.fill=st.fill!==false;st.fillOpacity=Number(st.fillOpacity==null?0.20:st.fillOpacity);st.name=st.name||'';return st}
  window.v236OpenDrawOptions=function(){ensureDrawPanel();const st=drawOptions();try{document.getElementById('drawNameInput').value=st.name||'';document.getElementById('drawColorInput').value=st.color||'#ff6f2e';document.getElementById('drawWeightInput').value=st.weight||3;document.getElementById('drawLineStyleInput').value=st.lineStyle||'solid';document.getElementById('drawFillInput').value=st.fill===false?'0':'1';document.getElementById('drawFillOpacityInput').value=Math.round((st.fillOpacity==null?0.20:st.fillOpacity)*100)}catch(e){}const p=document.getElementById('drawOptionsPanel');if(p)p.classList.add('active')}
  window.v236CloseDrawOptions=function(){const p=document.getElementById('drawOptionsPanel');if(p)p.classList.remove('active')}
  window.v236ApplyDrawOptions=function(){v236ReadDrawOptions();v236RedrawDrawTemp();v236CloseDrawOptions()}
  function v236ReadDrawOptions(){const st=drawOptions();try{st.name=document.getElementById('drawNameInput')?.value||st.name||'';st.color=document.getElementById('drawColorInput')?.value||st.color||'#ff6f2e';st.weight=Math.max(1,Math.min(12,parseInt(document.getElementById('drawWeightInput')?.value||st.weight||3,10)||3));st.lineStyle=document.getElementById('drawLineStyleInput')?.value||st.lineStyle||'solid';st.fill=(document.getElementById('drawFillInput')?.value||'1')==='1';st.fillOpacity=Math.max(0,Math.min(1,(parseFloat(document.getElementById('drawFillOpacityInput')?.value||20)||0)/100));}catch(e){}return st}
  function latLngsFromCoords(coords){return coords.map(c=>L.latLng(c[1],c[0]))}
  function rectPoly235(a,b,square){let x1=a.lng,y1=a.lat,x2=b.lng,y2=b.lat;if(square){const dx=x2-x1,dy=y2-y1;const d=Math.max(Math.abs(dx),Math.abs(dy));x2=x1+(dx>=0?d:-d);y2=y1+(dy>=0?d:-d)}return [[x1,y1],[x2,y1],[x2,y2],[x1,y2],[x1,y1]]}
  function circlePoly235(c,e,ellipse){const pts=[];const lat=c.lat,lon=c.lng;const dx=e.lng-lon,dy=e.lat-lat;const rx=Math.abs(dx)||0.00001,ry=ellipse?(Math.abs(dy)||0.00001):(Math.sqrt(dx*dx+dy*dy)||0.00001);for(let i=0;i<72;i++){const a=Math.PI*2*i/72;pts.push([lon+Math.cos(a)*rx,lat+Math.sin(a)*ry])}pts.push(pts[0]);return pts}
  function drawCoordsFromState(){const st=drawOptions();const pts=st.points||[];const end=st.liveEnd;if(['rectangle','square'].includes(st.mode)&&pts.length&&end)return rectPoly235(pts[0],end,st.mode==='square');if(['circle','ellipse'].includes(st.mode)&&pts.length&&end)return circlePoly235(pts[0],end,st.mode==='ellipse');if(st.mode==='freehand'&&pts.length>1){const c=pts.map(llToCoord); if(c.length>2)c.push(c[0]); return c}if(st.mode==='polygon'&&pts.length){const arr=pts.slice(); if(end)arr.push(end); const c=arr.map(llToCoord); if(c.length>2)c.push(c[0]); return c}return pts.map(llToCoord)}
  window.v236RedrawDrawTemp=function(){try{const st=drawOptions(); if(typeof v234ClearTemp==='function')v234ClearTemp(st); else if(typeof v233ClearTemp==='function')v233ClearTemp(st); const coords=drawCoordsFromState(); if(!coords.length)return; const opt={color:st.color||'#ff6f2e',weight:st.weight||3,opacity:.94,dashArray:st.lineStyle==='dashed'?'8 7':null,fill:st.fill!==false,fillOpacity:st.fill===false?0:Math.max(0,Math.min(.8,st.fillOpacity==null?0.20:st.fillOpacity))}; if(['rectangle','square','circle','ellipse','freehand'].includes(st.mode) && coords.length>=3){st.layer=L.polygon(latLngsFromCoords(coords),opt).addTo(map)}else if(st.mode==='polygon'){st.layer=(coords.length>=3?L.polygon(latLngsFromCoords(coords),opt):L.polyline((st.points||[]).concat(st.liveEnd?[st.liveEnd]:[]),opt)).addTo(map)}else if(st.points&&st.points.length){st.layer=L.polyline(st.points,opt).addTo(map)}}catch(e){}}
  function hookDrawingEvents(){try{if(window.v236DrawingEventsInstalled||!map)return;window.v236DrawingEventsInstalled=true;map.on('mousedown',ev=>{try{const st=drawOptions(); if(activeMapTool!=='draw'||!['rectangle','square','circle','ellipse','freehand'].includes(st.mode))return; window.v236DrawMouseDown=true; window.v236SuppressClickUntil=Date.now()+550; st.points=[ev.latlng]; st.liveEnd=ev.latlng; if(st.mode==='freehand'){try{map.dragging.disable()}catch(_){}}; L.DomEvent.stop(ev); v236RedrawDrawTemp()}catch(e){}});map.on('mousemove',ev=>{try{const st=drawOptions(); if(activeMapTool==='draw'&&st.mode==='polygon'&&(st.points||[]).length){st.liveEnd=ev.latlng;v236RedrawDrawTemp();return} if(!window.v236DrawMouseDown||activeMapTool!=='draw')return; if(st.mode==='freehand'){st.points.push(ev.latlng)} else st.liveEnd=ev.latlng; v236RedrawDrawTemp()}catch(e){}});map.on('mouseup',ev=>{try{const st=drawOptions(); if(!window.v236DrawMouseDown)return; window.v236DrawMouseDown=false; if(activeMapTool==='draw'){if(st.mode!=='freehand')st.liveEnd=ev.latlng; v236RedrawDrawTemp()} try{map.dragging.enable()}catch(_){}}catch(e){}})}catch(e){}}
  const oldStart=window.v233StartDraw; window.v233StartDraw=function(mode){try{drawOptions(); window.v233DrawState.mode=mode; window.v233DrawState.points=[]; window.v233DrawState.liveEnd=null; if(typeof v234ClearTemp==='function')v234ClearTemp(window.v233DrawState); else if(typeof v233ClearTemp==='function')v233ClearTemp(window.v233DrawState); const m=document.getElementById('drawToolMenu');if(m)m.classList.remove('active'); ensureDrawPanel(); setActiveMapTool('draw'); v236OpenDrawOptions(); hookDrawingEvents();}catch(e){if(oldStart)oldStart(mode)}};
  window.v233DrawMapClick=function(ll){try{if(Date.now()<(window.v236SuppressClickUntil||0))return; const st=drawOptions(); if(['rectangle','square','circle','ellipse','freehand'].includes(st.mode))return; st.points=st.points||[]; st.points.push(ll); st.liveEnd=null; v236RedrawDrawTemp()}catch(e){}}
  window.v233UndoDraw=function(){const st=drawOptions();st.points=(st.points||[]).slice(0,-1);st.liveEnd=null;v236RedrawDrawTemp()};window.v233ClearDraw=function(){const st=drawOptions();st.points=[];st.liveEnd=null;if(typeof v234ClearTemp==='function')v234ClearTemp(st);else if(typeof v233ClearTemp==='function')v233ClearTemp(st)};
  window.v233FinishDraw=async function(){try{const st=v236ReadDrawOptions();let coords=drawCoordsFromState();if(coords.length<4){alert('Add or draw more points before finishing.');return}const name=(st.name||prompt('Shape name:',(st.mode||'Shape')+' '+new Date().toLocaleTimeString())||'Shape').trim()||'Shape';await uploadGeoJson(name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:{name,kind:'shape',shape_type:st.mode,color:st.color||'#ff6f2e',fill:st.fill!==false,fill_opacity:st.fillOpacity==null?0.20:st.fillOpacity,weight:st.weight||3,line_style:st.lineStyle||'solid',source:'TAK Map Drawing Tools'}});v233ClearDraw();v236CloseDrawOptions();setActiveMapTool('move')}catch(e){alert('Save shape failed: '+e)}};
  function v236StyleLocalObject(o,opt){try{const p=o?.properties||o||{};if(p.color)opt.color=p.color;if(p.weight||p.line_width)opt.weight=Number(p.weight||p.line_width)||opt.weight;if(p.line_style==='dashed'||p.lineStyle==='dashed'||p.style==='dashed')opt.dashArray='8 7';if('fill' in p)opt.fill=!(p.fill===false||p.fill==='0'||p.fill==='false');if(p.fill_opacity!=null||p.fillOpacity!=null)opt.fillOpacity=Number(p.fill_opacity??p.fillOpacity);return opt}catch(e){return opt}}
  const oldAddObject=window.addObjectLayer; if(oldAddObject&&!window.v236AddObjectWrapped){window.v236AddObjectWrapped=true; window.addObjectLayer=function(group,o,sourceKey){try{const p=o?.properties||{};o.lineStyle=o.lineStyle||o.line_style||p.line_style||p.lineStyle||p.style;o.style=o.style||o.lineStyle;o.color=o.color||p.color;o.weight=o.weight||p.weight; if((dataSyncCategory(o)==='Shapes / Areas')&&o.coords){/* original renderer may ignore styles; handled below if needed */}}catch(e){}return oldAddObject(group,o,sourceKey)}}
  const oldFinishRoute=window.v233FinishRoute; window.v233FinishRoute=async function(){try{const pts=window.v233RouteState?.points||[];if(pts.length<2){alert('Add at least two route points.');return}const name=(document.getElementById('routeNameInput')?.value||'Route '+new Date().toLocaleTimeString()).trim();const notes=document.getElementById('routeNotesInput')?.value||'';const method=document.getElementById('routeMethodInput')?.value||'Driving';const direction=document.getElementById('routeDirectionInput')?.value||'Infil';const routeType=document.getElementById('routeTypeInput')?.value||'Primary';const order=document.getElementById('routeOrderInput')?.value||'Ascending Check Points';const prefix=document.getElementById('routePrefixInput')?.value||'CP';const color=document.getElementById('routeColorInput')?.value||'#ff6f2e';const style=document.getElementById('routeStyleInput')?.value||window.v233RouteState?.style||'solid';await v233UploadGeoJson(name,{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(llToCoord)},properties:{name,kind:'route',source:'TAK Map Route Tool',notes,remarks:`Method: ${method}\nDirection: ${direction}\nRoute Type: ${routeType}\nOrder: ${order}\nPrefix: ${prefix}\nLine Style: ${style}\nNotes: ${notes}`,route_method:method,route_direction:direction,route_type:routeType,checkpoint_order:order,checkpoint_prefix:prefix,color,line_style:style,lineStyle:style,style,route_style:style,atak_cot_type:'b-m-r',atak_route_metadata:{method,direction,routetype:routeType,order,prefix,color,style}}});v233ClearRoute();v233ClosePanel('routeEditPanel');setActiveMapTool('move')}catch(e){if(oldFinishRoute)return oldFinishRoute(); else alert('Save route failed: '+e)}};
