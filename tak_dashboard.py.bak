        INDEX_HTML = TAK_MAP_HTML

    _v318_prev_get = Handler.do_GET
    def _v318_route_get(self):
        parsed = urlparse(self.path)
        if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
            if parsed.path in ('/', '/index.html', '/tak-map', '/tak-map/'):
                if not self._tak_map_auth_ok():
                    return self._redirect('/tak-map/login')
                return self._send_html(TAK_MAP_HTML)
            if parsed.path in ('/login', '/tak-map/login'):
                if self._tak_map_auth_ok():
                    return self._redirect('/tak-map')
                return self._send_html(TAK_MAP_LOGIN_HTML)
        return _v318_prev_get(self)
    Handler.do_GET = _v318_route_get
except Exception as _v318_exc:
