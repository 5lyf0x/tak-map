    if(point&&!point.dataset.v236Icons){point.dataset.v236Icons='1';point.classList.add('compact-icon-toolbar');point.innerHTML=`<button class="tool-btn" onclick="toggleMapTool('pointdropper')" title="Drop Point">${iconSvg('drop')}<span class="tool-label">Drop Point</span></button><button class="tool-btn" onclick="openMilPicker()" title="MIL-STD Icon">${iconSvg('icon')}<span class="tool-label">Icon</span></button><button class="tool-btn" onclick="v233OpenPointPanel()" title="Name">${iconSvg('name')}<span class="tool-label">Name</span></button><label class="tool-color" title="Color"><input type="color" value="${E((window.v233PointState||{}).color||'#ff6f2e')}" onchange="v233PointState.color=this.value"><span class="tool-label">Color</span></label><button class="tool-btn" onclick="v233OpenPointPanel()" title="Notes">${iconSvg('notes')}<span class="tool-label">Notes</span></button><button class="tool-btn" onclick="v233SavePoint()" title="Save Point">${iconSvg('save')}<span class="tool-label">Save</span></button>`}
    const route=document.getElementById('routeMiniToolbar');
