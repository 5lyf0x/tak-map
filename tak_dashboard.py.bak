  function workerCode(){return `const gov=['POLICE','SHERIFF','STATE POLICE','HIGHWAY PATROL','CHP','CAL FIRE','CALFIRE','FIRE','RESCUE','PUBLIC SAFETY','LAW ENFORCEMENT','EMS','MEDEVAC','USFS','FOREST SERVICE',' BLM','NIFC','FEMA','DHS','CBP','CUSTOMS','BORDER PATROL','DEA','FBI','MARSHAL','NASA','NOAA','NPS','PARK SERVICE','COAST GUARD','USCG','LIFE FLIGHT'];function text(o){return ['flight','callsign','r','registration','t','type','desc','description','ownOp','operator','owner','squawk','hex'].map(k=>o&&o[k]).filter(Boolean).join(' ').toUpperCase()}function cls(o){const flags=parseInt(o&& (o.dbFlags??o.dbflags) ||0)||0;if(flags&1)return 'military';const b=text(o);if(gov.some(x=>b.includes(x)))return 'govt';if(!String((o&& (o.hex||o.flight||o.r||o.t))||'').trim())return 'unknown';return 'civil'}function helo(o){const b=text(o);return /\\b(H|HEL|HELI|HELO|ROTOR)\\b/.test(b)||['B407','B412','B429','B206','R22','R44','R66','S76','S92','H135','H145','UH60','MH60','HH60','CH47','AH64'].some(x=>b.includes(x))}function dmi(a,b,c,d){const R=3958.7613,rad=Math.PI/180,x=(c-a)*rad,y=(d-b)*rad;const s=Math.sin(x/2)**2+Math.cos(a*rad)*Math.cos(c*rad)*Math.sin(y/2)**2;return 2*R*Math.atan2(Math.sqrt(s),Math.sqrt(1-s))}function norm(o,c){let lat=Number(o&&o.lat),lon=Number(o&&o.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180)return null;let alt=o.alt_baro;if(String(alt).toLowerCase()==='ground')alt=0;if(alt==null)alt=o.alt_geom??o.altitude;const category=cls(o),hex=String(o.hex||o.icao||'').trim().toUpperCase(),reg=String(o.r||o.registration||'').trim().toUpperCase(),flight=String(o.flight||o.callsign||'').trim(),id=hex||reg||flight||('aircraft-'+lat.toFixed(4)+'-'+lon.toFixed(4));const seen=o.seen_pos??o.seen;return {id,hex,icao:hex,registration:reg,callsign:flight||reg||hex||'ADS-B',flight,lat,lon,altitude_ft:alt,speed_kt:o.gs??o.speed,track_deg:o.track??o.true_heading??o.mag_heading,seen_seconds:seen,category,category_class:category,is