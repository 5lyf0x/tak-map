      .adsb-pop-grid>div{min-width:0;padding:5px 7px;border:1px solid rgba(255,255,255,.075);border-radius:9px;background:rgba(255,255,255,.035);}
      .adsb-pop-grid b{display:block;margin-bottom:2px;color:#ffcfb8;font-size:9px;line-height:10px;text-transform:uppercase;letter-spacing:.08em;font-weight:950;}
      .adsb-pop-grid span{display:block;min-width:0;color:#f2f7f9;font-size:12px;line-height:14px;font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
