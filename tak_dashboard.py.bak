        +'</div>';
      document.body.appendChild(div);
      const msg=field('adsbTrackSaveMsg');
      async function doSave(){try{if(!canSave)return;const name=clean((field('adsbTrackRouteName')||{}).value||def);if(msg){msg.textContent='Saving…';msg.classList.remove('bad')}const feature={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(p=>[Number(p.lon),Number(p.lat),Number(p.alt)||0])},properties:{name,source:'TAK Map ADS-B',kind:'route',geometry:'route',route_type:'adsb_aircraft_track',callsign:(meta&&(meta.callsign||meta.flight||meta.registration))||'',hex:String((meta&&(meta.hex||meta.icao||meta.id))||id||'').toUpperCase(),start_time:new Date((pts[0]&&pts[0].t)||Date.now()).toISOString(),end_time:new Date((pts[pts.length-1]&&pts[pts.length-1].t)||Date.now()).toISOString(),point_count:pts.length,distance_miles:Number((m/1609.344).toFixed(3)),distance_km:Number((m/1000).toFixed(3)),distance_text:distText(m)}}]};const blob=new Blob([JSON.stringify(feature,null,2)],{type:'application/geo+json'});const file=new File([blob],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});let j={};try{j=await r.json()}catch(_){}if(!r.ok||j.ok===false)throw new Error(j.error||('HTTP '+r.status));try{if(typeof window.refreshLocalData==='function')await window.refreshLocalData()}catch(_){}try{if(typeof window.drawImportedObjects==='function')window.drawImportedObjects()}catch(_){}if(msg)msg.textContent='Saved';setTimeout(closeDialog,380)}catch(e){if(msg){msg.textContent='Save failed: '+String(e&&e.message||e);msg.classList.add('bad')}}}
      div.addEventListener('click',ev=>{const a=ev.target&&ev.target.getAttribute&&ev.target.getAttribute('data-action');if(a==='discard'){ev.preventDefault();closeDialog();return}else if(a==='save'){ev.preventDefault();doSave();return}else if(ev.target===div){closeDialog();return}},true);
      div.addEventListener('keydown',ev=>{if(ev.key==='Escape')closeDialog()});
