  function trackLayer(){try{if(!window.L||!window.map)return null;let g=window[TRACK_LAYER];if(!g){g=L.layerGroup().addTo(map);window[TRACK_LAYER]=g}else if(!map.hasLayer(g))g.addTo(map);return g}catch(_){return null}}
