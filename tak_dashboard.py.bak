tant;background:rgba(31,42,52,.98)!important;}\n    `;\n    document.head.appendChild(st);\n  }\n  function patchLeaflet(){\n    try{\n      if(!window.L || window._v284PopupPatched) return;\n      window._v284PopupPatched=true;\n      if(L.Marker&&L.Marker.prototype&&L.Marker.prototype.bindPopup){\n        const oldBind=L.Marker.prototype.bindPopup;\n        L.Marker.prototype.bindPopup=function(content,opts){\n          const cls=opts&&opts.className?String(opts.className):\'\';\n          const isAdsb=/adsb/i.test(cls)||/adsb|ADS-B/i.test(String(content||\'\'));\n          const nopts=Object.assign({},opts||{});\n          if(isAdsb){nopts.closeButton=true;nopts.className=(cls?cls+\' \':\'\')+\'adsb-object-popup\';content=normalizeClassFieldHtml(content)}\n          return oldBind.call(this,content,nopts);\n        };\n      }\n      if(L.Popup&&L.Popup.prototype&&L.Popup.prototype.setContent){\n        const oldSet=L.Popup.prototype.setContent;\n        L.Popup.prototype.setContent=function(content){\n          try{const cls=this.options&&this.options.className?String(this.options.className):\'\';if(/adsb/i.test(cls)||/adsb|ADS-B/i.test(String(content||\'\')))content=normalizeClassFieldHtml(content)}catch(_){ }\n          return oldSet.call(this,content);\n        };\n      }\n    }catch(_){ }\n  }\n  function bindClose(){\n    if(window._v284PopupCloseBound) return;window._v284PopupCloseBound=true;\n    document.addEventListener(\'click\',function(ev){\n      const btn=ev.target&&ev.target.closest&&ev.target.closest(\'.leaflet-popup-close-button,.adsb-v284-close,.adsb-v283-close\');\n      if(!btn) return;\n      const el=btn.closest(\'.leaflet-popup\');\n      ev.preventDefault();ev.stopPropagation();if(ev.stopImmediatePropagation)ev.stopImmediatePropagation();\n      try{if(window.map)map.fire(\'click\',{originalEvent:ev})}catch(_){ }\n      hardClosePopup(findPopupFromElement(el),el);\n      return false;\n    },true);\n    if(window.map&&!window._v284PopupOpenBound){\n      window._v284PopupOpenBound=true;\n      try{map.on(\'popupopen\',()=>setTimeout(()=>normalizeOpenPopups(document),0));}catch(_){ }\n    }\n  }\n  function boot(){css();patchLeaflet();bindClose();normalizeOpenPopups(document);qa(\'.iteration-chip,.iteration-marker\').forEach(el=>{try{el.textContent=V}catch(_){}})}\n  if(document.readyState===\'loading\')document.addEventListener(\'DOMContentLoaded\',()=>setTimeout(boot,40),{once:true});else setTimeout(boot,40);\n  setTimeout(boot,700);\n})();\n</script>\n'
