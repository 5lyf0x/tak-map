        _html = _html.replace('.status-adsb-head.v314', '.status-adsb-head.v315').replace('.status-adsb-row.v314', '.status-adsb-row.v315')
        _html = _html.replace('v314', 'v315')
        return _html

    def _v315_restore_adsb_menu(_html):
        if not isinstance(_html, str):
            return _html
        _menu = '''<div id="adsbMenuHostV315" class="adsb-v315-menu"><div class="adsb-settings-grid"><label>Radius miles<input id="adsbRadiusMiles" class="adsb-radius-input" type="number" min="1" max="250" step="1" value="5" inputmode="numeric"></label><label>Update Interval (sec)<input id="adsbUpdateInterval" class="adsb-radius-input" type="number" min="1" max="300" step="1" value="5" inputmode="numeric"></label><label class="adsb-center-source-row">Center Source<select id="adsbCenterSource"><option value="manual">Manual</option><option value="map_center">Map Center</option></select></label><label>Center Lat<input id="adsbCenterLat" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="34.000000"></label><label>Center Lon<input id="adsbCenterLon" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="-118.000000"></label></div><div class="adsb-v315-filter-row"><label><input id="adsbFilterCivil" type="checkbox" checked> Civil</label><label><input id="adsbFilterMilitary" type="checkbox" checked> Military</label><label><input id="adsbFilterGovt" type="checkbox" checked> Govt</label><label><input id="adsbFilterUnknown" type="checkbox" checked> Unknown</label></div><div class="adsb-v315-actions"><button class="layer-button" type="button" onclick="useMapCenterForAdsb()">Use Map Center</button><button class="layer-button" type="button" onclick="saveAdsbSettings(false)">Save Filter</button><button class="layer-button" type="button" onclick="refreshAdsb()">Refresh ADS-B</button></div><div id="adsbSettingsStatus" class="muted" style="margin-top:7px"></div></div>'''
        _html = _html.replace('<div id="adsbMenuHostV282"></div>', _menu)
        _html = _v315_re.sub(r'(<div class="panel collapsible" data-collapse-key="adsbSettings"><h2 onclick="togglePanelCollapse\(this\)">ADS-B <span class="panel-toggle">▾</span></h2><div class="panel-body">)\s*</div>', r'\1'+_menu+'</div>', _html, count=1)
        _css = '''<style id="v315AdsbMenuStyle">.adsb-v315-menu{display:grid;gap:8px}.adsb-v315-filter-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:6px 10px;margin-top:2px}.adsb-v315-filter-row label{display:flex;align-items:center;gap:6px;color:var(--muted);font-size:.74rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em}.adsb-v315-actions{display:flex;flex-wrap:wrap;gap:7px;margin-top:2px}.adsb-v315-actions .layer-button{font-weight:700}</style>'''
        if 'v315AdsbMenuStyle' not in _html:
            _html = _html.replace('</head>', _css+'</head>', 1) if '</head>' in _html else _css+_html
        _script = r'''<script id="v315AdsbMenuRuntime">
(function(){
  'use strict';
  const V='v315';
  const $=id=>document.getElementById(id);
  const qs=s=>document.querySelector(s);
  const qsa=s=>Array.from(document.querySelectorAll(s));
  function clamp(v,min,max,def){v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def}
  function status(msg,bad){try{const n=$('adsbSettingsStatus');if(n){n.textContent=msg||'';n.classList.toggle('adsb-status-bad',!!bad);n.classList.toggle('adsb-status-ok',!bad)}}catch(_){}}
  function menuHtml(){return `<div id="adsbMenuHostV315" class="adsb-v315-menu"><div class="adsb-settings-grid"><label>Radius miles<input id="adsbRadiusMiles" class="adsb-radius-input" type="number" min="1" max="250" step="1" value="5" inputmode="numeric"></label><label>Update Interval (sec)<input id="adsbUpdateInterval" class="adsb-radius-input" type="number" min="1" max="300" step="1" value="5" inputmode="numeric"></label><label class="adsb-center-source-row">Center Source<select id="adsbCenterSource"><option value="manual">Manual</option><option value="map_center">Map Center</option></select></label><label>Center Lat<input id="adsbCenterLat" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="34.000000"></label><label>Center Lon<input id="adsbCenterLon" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="-118.000000"></label></div><div class="adsb-v315-filter-row"><label><input id="adsbFilterCivil" type="checkbox" checked> Civil</label><label><input id="adsbFilterMilitary" type="checkbox" checked> Military</label><label><input id="adsbFilterGovt" type="checkbox" checked> Govt</label><label><input id="adsbFilterUnknown" type="checkbox" checked> Unknown</label></div><div class="adsb-v315-actions"><button class="layer-button" type="button" onclick="useMapCenterForAdsb()">Use Map Center</button><button class="layer-button" type="button" onclick="saveAdsbSettings(false)">Save Filter</button><button class="layer-button" type="button" onclick="refreshAdsb()">Refresh ADS-B</button></div><div id="adsbSettingsStatus" class="muted" style="margin-top:7px"></div></div>`}
  function ensureMenu(){try{let body=qs('.panel[data-collapse-key="adsbSettings"] .panel-body');if(!body)return;let host=$('adsbMenuHostV315')||$('adsbMenuHostV282');if(!host||!body.querySelector('#adsbRadiusMiles')){body.innerHTML=menuHtml();}qsa('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v315 ADS-B menu ensure failed',e)}}
  function values(){let source=String(($('adsbCenterSource')||{}).value||'manual');let lat=$('adsbCenterLat')?.value,lon=$('adsbCenterLon')?.value;if(source==='map_center'&&window.map&&map.getCenter){const c=map.getCenter();lat=c.lat;lon=c.lng}return {radius_miles:clamp(($('adsbRadiusMiles')||{}).value,1,250,5),update_interval_seconds:clamp(($('adsbUpdateInterval')||{}).value,1,300,5),center_source:source,center_lat:lat,center_lon:lon}}
  function applySettings(s){try{s=s||{};if($('adsbRadiusMiles'))$('adsbRadiusMiles').value=String(clamp(s.radius_miles,1,250,5));if($('adsbUpdateInterval'))$('adsbUpdateInterval').value=String(clamp(s.update_interval_seconds,1,300,5));if($('adsbCenterSource'))$('adsbCenterSource').value=(s.center_source==='map_center')?'map_center':'manual';if($('adsbCenterLat')&&s.center_lat!=null)$('adsbCenterLat').value=Number(s.center_lat).toFixed(6);if($('adsbCenterLon')&&s.center_lon!=null)$('adsbCenterLon').value=Number(s.center_lon).toFixed(6)}catch(_){}}
  async function loadSettings(){try{const r=await fetch('/api/tak-map/adsb-settings',{cache:'no-store'});const j=await r.json();if(j&&j.settings){window.lastAdsbSettings=j.settings;applySettings(j.settings)}}catch(e){console.warn('v315 ADS-B settings load failed',e)}}
  function restartPolling(){try{const ctl=window.TakMapControllers&&window.TakMapControllers.adsb;const sec=clamp(($('adsbUpdateInterval')||{}).value,1,300,5);if(ctl&&ctl.refreshTimer)clearInterval(ctl.refreshTimer);if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer);if(ctl){ctl.refreshTimer=setInterval(function(){try{window.refreshAdsb&&window.refreshAdsb()}catch(_){}},sec*1000);window.adsbRefreshTimer=ctl.refreshTimer}setTimeout(function(){try{window.refreshAdsb&&window.refreshAdsb()}catch(_){}},75)}catch(e){console.warn('v315 ADS-B polling restart failed',e)}}
  window.saveAdsbSettings=async function(){try{ensureMenu();const payload=values();const r=await fetch('/api/tak-map/adsb-settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});const j=await r.json();if(!j||j.ok===false)throw new Error((j&&j.error)||'Save failed');window.lastAdsbSettings=j.settings||payload;applySettings(window.lastAdsbSettings);status('Saved');restartPolling();return j}catch(e){status(String(e&&e.message||e),true);return {ok:false,error:String(e&&e.message||e)}}};
  window.useMapCenterForAdsb=function(){try{ensureMenu();if(!window.map||!map.getCenter)return;const c=map.getCenter();if($('adsbCenterLat'))$('adsbCenterLat').value=Number(c.lat).toFixed(6);if($('adsbCenterLon'))$('adsbCenterLon').value=Number(c.lng).toFixed(6);if($('adsbCenterSource'))$('adsbCenterSource').value='map_center';status('Map center set');}catch(e){status(String(e&&e.message||e),true)}};
  function loadFilterState(){['Civil','Military','Govt','Unknown'].forEach(k=>{try{const el=$('adsbFilter'+k);const v=localStorage.getItem('takmap.adsb.filter.'+k.toLowerCase());if(el&&v!=null)el.checked=v!=='0'}catch(_){}})}
  function bind(){try{['Civil','Military','Govt','Unknown'].forEach(k=>{const el=$('adsbFilter'+k);if(el&&!el.dataset.v315Bound){el.dataset.v315Bound='1';el.addEventListener('change',()=>{try{localStorage.setItem('takmap.adsb.filter.'+k.toLowerCase(),el.checked?'1':'0')}catch(_){}try{window.drawAircraft&&window.drawAircraft(window.lastAircraft||[])}catch(_){}})}});['adsbRadiusMiles','adsbUpdateInterval','adsbCenterSource','adsbCenterLat','adsbCenterLon'].forEach(id=>{const el=$(id);if(el&&!el.dataset.v315Bound){el.dataset.v315Bound='1';el.addEventListener('change',()=>{if(id==='adsbUpdateInterval')restartPolling()})}})}catch(e){console.warn('v315 ADS-B bind failed',e)}}
  function boot(){ensureMenu();loadFilterState();bind();loadSettings();}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
  [500,1500,3500,7000].forEach(ms=>setTimeout(boot,ms));
})();
</script>'''
        _html = _v315_re.sub(r'<script[^>]*id=["\']v315AdsbMenuRuntime["\'][^>]*>.*?</script>\s*', '', _html, flags=_v315_re.S)
        _html = _html.replace('</body>', _script+'</body>', 1) if '</body>' in _html else _html+_script
        _old = "function filtered(input){return normalizeList(input).filter(function(a){return Number.isFinite(a.lat)&&Number.isFinite(a.lon)})}"
        _new = "function filtered(input){return normalizeList(input).filter(function(a){if(!Number.isFinite(a.lat)||!Number.isFinite(a.lon))return false;try{const st=stableState(a);const k=st.classKey==='military'?'Military':(st.classKey==='govt'?'Govt':(st.classKey==='unknown'?'Unknown':'Civil'));const el=byId('adsbFilter'+k);if(el&&el.checked===false)return false}catch(_){}return true})}"
        _html = _html.replace(_old, _new)
        return _html

    TAK_MAP_HTML = _v315_restore_adsb_menu(_v315_versions(TAK_MAP_HTML))
    TAK_MAP_LOGIN_HTML = _v315_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v315_versions(LOGIN_HTML)
    if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
        INDEX_HTML = TAK_MAP_HTML

    _v315_prev_get = Handler.do_GET
    def _v315_route_get(self):
        parsed = urlparse(self.path)
        if str(globals().get('APP_ROLE', 'map')).strip().lower() == 'map':
            if parsed.path in ('/', '/index.html', '/tak-map', '/tak-map/'):
                if not self._tak_map_auth_ok():
                    return self._redirect('/tak-map/login')
                return self._send_html(TAK_MAP_HTML)
            if parsed.path in ('/login', '/tak-map/login'):
                if self._tak_map_auth_ok():
                    return self._redirect('/tak-map')
                return self._send_html(TAK_MAP_LOGIN_HTML)
        return _v315_prev_get(self)
    Handler.do_GET = _v315_route_get
except Exception as _v315_exc:
    try: print('v315 ADS-B menu restore failed:', _v315_exc)
    except Exception: pass
# --- end TAK Map v315 ADS-B menu restore + visible iteration enforcement ---

