        +'<div class="adsb-track-save-title">Save ADS-B Track</div>'
        +'<div class="adsb-track-save-sub">'+esc(title)+' · '+esc(distanceText(m))+' · '+esc(String((pts||[]).length))+' pts</div>'
        +'<input id="adsbTrackRouteName" class="adsb-track-save-input" value="'+esc(defaultName)+'" '+(canSave?'':'disabled')+' />'
        +(canSave?'':'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>')
        +'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div>'
