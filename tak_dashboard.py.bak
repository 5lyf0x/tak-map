        if 'id="v322DataPopupCoverageAndLocalRefresh"' not in _html:
            _html = _html.replace('</body>', _runtime + '</body>', 1) if '</body>' in _html else _html + _runtime
        return _v322_versions(_html)

    TAK_MAP_HTML = _v322_patch_html(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v322_versions(TAK_MAP_LOGIN_HTML)
