  function renderDropdown(){const box=statusBox();const rows=filteredAircraft().sort(compareAircraft);const s=window.v294AdsbSort||{key:'aircraft',dir:1};const arrow=k=>s.key===k?(s.dir>0?' ▲':' ▼'):'';let html='<div class="status-dropdown-title">ADS-B Aircraft</div>';if(rows.length){html+='<div class="status-adsb-head v294"><button data-v294-sort="aircraft">Aircraft'+arrow('aircraft')+'</button><button data-v294-sort="class">Class'+arrow('class')+'</button><button data-v294-sort="type">Type'+arrow('type')+'</button><button data-v294-sort="alt">Alt'+arrow('alt')+'</button><button data-v294-sort="range">mi-&gt;Center'+arrow('range')+'</button></div>';html+=rows.map(a=>'<div class="status-adsb-row v294" data-adsb-id="'+esc(idOf(a))+'"><span class="status-adsb-icao">'+esc(fmtTitle(a))+'</span><span>'+esc(classLabel(a.category,a))+'</span><span>'+esc(a.is_helo?'Helicopter':'Airplane')+'</span><span class="status-adsb-alt">'+esc(fmtAlt(a))+'</span><span class="status-adsb-range">'+esc(fmtRange(a))+'</span></div>').join('')}else{html+='<div class="status-dropdown-empty">No aircraft currently listed.</div>';const sup=window._v294LastSuppressedAdsb;if(sup&&sup.previous>0)html+='<div class="status-dropdown-note v294">Holding previous aircraft list during a transient ADS-B refresh.</div>'}box.innerHTML=html;return box}
  function positionDropdown(ev){const box=statusBox(),item=field('bannerAdsbItem');const r=(ev&&ev.currentTarget&&ev.currentTarget.getBoundingClientRect&&ev.currentTarget.getBoundingClientRect())||(item&&item.getBoundingClientRect&&item.getBoundingClientRect());box.classList.add('active','open');box.style.display='block';box.style.visibility='visible';const w=Math.min(560,(window.innerWidth||800)-16);box.style.minWidth=Math.min(460,w)+'px';box.style.maxWidth=w+'px';if(r){box.style.left=Math.max(8,Math.min((window.innerWidth||800)-w-8,r.left))+'px';box.style.top=(r.bottom+8)+'px'}}
  function showDropdown(ev){updateBanner();renderDropdown();positionDropdown(ev)}
  function focusAircraft(id){try{id=String(id||'').toLowerCase();const a=filteredAircraft().find(x=>idOf(x)===id);if(!a||!window.map)return;const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return;map.setView([lat,lon],Math.max(map.getZoom(),13));setTimeout(()=>{try{map.eachLayer(layer=>{if(!layer||typeof layer.getLatLng!=='function'||typeof layer.openPopup!=='function')return;const lid=String(layer._v286AdsbId||layer._v285AdsbId||layer._adsbId||'').toLowerCase();const ll=layer.getLatLng&&layer.getLatLng();if(lid===id||(ll&&Math.abs(ll.lat-lat)<0.0005&&Math.abs(ll.lng-lon)<0.0005)){layer.openPopup();throw new Error('done')}})}catch(_){}} ,220)}catch(_){}}
  function patchAdsbUi(){try{if(window._v294AdsbUiPatched)return;window._v294AdsbUiPatched=true;stableSetterInstall();const oldRender=window.renderStatusDropdown;window.renderStatusDropdown=function(type){if(String(type||'').toLowerCase()==='adsb')return renderDropdown();return typeof oldRender==='function'?oldRender.apply(this,arguments):undefined};const oldToggle=window.toggleStatusDropdown;window.toggleStatusDropdown=function(type,ev){if(String(type||'').toLowerCase()==='adsb'){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}}catch(_){}if(isOpen()){closeDropdown();return false}showDropdown(ev);return false}return typeof oldToggle==='function'?oldToggle.apply(this,arguments):false};document.addEventListener('click',ev=>{try{const item=field('bannerAdsbItem'),box=field('statusDropdown');const t=ev.target;if(item&&item.contains(t)){ev.preventDefault();ev.stopPropagation();try{ev.stopImmediatePropagation()}catch(_){}if(isOpen())closeDropdown();else showDropdown({currentTarget:item});return false}const sort=t&&t.closest&&t.closest('[data-v294-sort]');if(sort){ev.preventDefault();ev.stopPropagation();const k=sort.getAttribute('data-v294-sort');const s=window.v294AdsbSort||{key:'aircraft',dir:1};window.v294AdsbSort=(s.key===k)?{key:k,dir:-s.dir}:{key:k,dir:1};renderDropdown();return false}const row=t&&t.closest&&t.closest('.status-adsb-row.v294[data-adsb-id]');if(row){ev.preventDefault();ev.stopPropagation();focusAircraft(row.getAttribute('data-adsb-id'));return false}if(box&&isOpen()&&!box.contains(t))closeDropdown()}catch(_){ }},true);document.addEventListener('keydown',ev=>{if(ev.key==='Escape'&&isOpen())closeDropdown()},true)}catch(e){console.warn('v294 ADS-B UI patch failed',e)} }
