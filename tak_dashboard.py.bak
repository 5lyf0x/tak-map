    .status-dropdown .status-adsb-head.v296,.status-dropdown .status-adsb-row.v296{grid-template-columns:minmax(112px,1.35fr) 72px 92px 82px 94px!important;}
    .terrain3d-local-mesh-chip{font-size:.62rem;color:#b7c7ce;line-height:1.25;margin-top:2px;white-space:normal;max-width:260px;}
