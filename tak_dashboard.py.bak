for _old_iter in ('v291','v290','v289','v288','v287','v286','v285','v284','v283','v282','v281','v280'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old_iter, 'TAKDashboard/v301')
