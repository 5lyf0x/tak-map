  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.registration||a.callsign))||'').trim().toLowerCase()}
  function textBlob(a){try{return [a&&a.category_raw,a&&a.adsb_category,a&&a.emitter_category,a&&a.category_code,a&&a.category,a&&a.t,a&&a.type,a&&a.aircraft_type,a&&a.desc,a&&a.description,a&&a.model,a&&a.flight,a&&a.callsign,a&&a.r,a&&a.registration,a&&a.ownOp,a&&a.operator,a&&a.owner].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function classKey(v,a){const s=String(v||'').trim().toLowerCase();if(s==='gov'||s==='govt'||s==='government'||s.includes('government'))return 'govt';if(s==='mil'||s==='military'||s.includes('military'))return 'military';if(s==='unk'||s==='unknown')return 'unknown';if(s==='civil'||s==='civilian'||s.includes('commercial'))return 'civil';const b=textBlob(a||{});if(/\b(LAPD|POLICE|SHERIFF|PUBLIC\s+SAFETY|EMS|RESCUE|CHP|CAL\s*FIRE|USFS|MEDICAL|HOSPITAL|RESPONSE|LAW\s+ENFORCEMENT)\b|\bFIRE\s*(DEPT|DEPARTMENT)?\b|\b[A-Z]{1,5}\s*(PD|FD)\b|\b(PD|FD)\b/.test(b))return 'govt';return s||'unknown'}
  function classLabel(v,a){return ({govt:'Govt',military:'Military',civil:'Civil',unknown:'Unknown'}[classKey(v,a)]||'Unknown')}
