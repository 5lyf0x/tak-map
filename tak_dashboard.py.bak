# --- TAK Map v292 elevation compatibility / UI patch ---
_v292_elevation_compat_patch = r'''<script id="v292ElevationCompatibilityPatch">
(function(){
  'use strict';
  const V='v301';
  const COMPAT='Compatible: SRTM HGT, DTED DT0/DT1/DT2, USGS National Map / 3DEP DEM GeoTIFF/COG (.tif/.tiff)';
  const WARN='GeoTIFF support is for DEM/elevation GeoTIFFs, not imagery or topo-map GeoTIFFs.';
  const DIRECT='Direct files only. ZIP packages are not supported in this version.';
  const MB=1024*1024, WARN_MB=250, CONFIRM_MB=500, HARD_MB=1024;
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function field(id){try{return document.getElementById(id)}catch(_){return null}}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V});}catch(_){} }
  function uniqueTiles(st){try{return [...(st.tiles||new Map()).values()].filter((v,i,a)=>v&&v.id&&a.findIndex(x=>x&&x.id===v.id)===i)}catch(_){return []}}
  function localElevStateV292(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};if(!(window.takLocalElevation.tiles instanceof Map))window.takLocalElevation.tiles=new Map();return window.takLocalElevation}
  function localElevTileIdV292(lat0,lon0){return 'geo|'+Math.floor(Number(lat0))+'|'+Math.floor(Number(lon0))}
  function localElevMetaFor(t){return {id:t.id,name:t.name,type:t.type||t.sourceType||'Elevation',sourceType:t.sourceType||t.kind||'',lat0:t.lat0,lon0:t.lon0,lat1:t.lat1,lon1:t.lon1,width:t.width||t.size,height:t.height||t.size,size:t.size||Math.max(Number(t.width)||0,Number(t.height)||0),bytes:t.bytes||0,imported:t.imported||0}}
  function addTileToState(st,t){if(!t||!t.id)return;st.tiles.set(t.id,t);if(Number.isFinite(Number(t.lat0))&&Number.isFinite(Number(t.lon0)))st.tiles.set(localElevTileIdV292(t.lat0,t.lon0),t);}
  async function openLocalElevDbV292(){if(typeof openLocalElevDb==='function')return openLocalElevDb();return new Promise((resolve,reject)=>{try{const req=indexedDB.open('takmapLocalElevationV1',1);req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains('tiles'))db.createObjectStore('tiles',{keyPath:'id'});};req.onsuccess=()=>resolve(req.result);req.onerror=()=>reject(req.error||new Error('IndexedDB open failed'))}catch(e){reject(e)}})}
