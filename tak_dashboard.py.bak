  function classLabel(v){return ({govt:'Govt',military:'Military',civil:'Civil',unknown:'Unknown'}[classKey(v)]||'Unknown')}
  function textBlob(a){try{return [a&&a.category_raw,a&&a.adsb_category,a&&a.emitter_category,a&&a.category_code,a&&a.category,a&&a.t,a&&a.type,a&&a.aircraft_type,a&&a.desc,a&&a.description,a&&a.model,a&&a.flight,a&&a.callsign,a&&a.r,a&&a.registration,a&&a.ownOp,a&&a.operator,a&&a.owner].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function isHelicopter(a){
    const cat=String((a&&(a.category_raw||a.adsb_category||a.emitter_category||a.category_code))||'').trim().toUpperCase();
    if(cat==='A7')return true;
    if(a&&(a.is_helo===true||a.is_rotor===true||a.rotor===true))return true;
    const b=textBlob(a);
    if(/A7/.test(b))return true;
    if(/(ROTOR|ROTORCRAFT|ROTARY|HELICOPTER|HELI|HELO|GYRO)/.test(b))return true;
    if(/(H60|UH60|MH60|HH60|SH60|CH47|AH64|OH58|CH53|UH1|UH72|V22|B206|B407|B412|B429|B505|R22|R44|R66|S76|S92|AS50|AS350|AS355|EC35|EC45|EC120|EC130|EC135|EC145|H125|H130|H135|H145|H155|AW109|AW119|AW139|AW169|AW189|MD50|MD52|MD60)/.test(b))return true;
    if(/(BELL|ROBINSON|SIKORSKY|AIRBUS HELICOPTERS|EUROCOPTER|AGUSTA|LEONARDO HELICOPTERS)/.test(b))return true;
    return false;
  }
  function normalize(a){try{if(!a||typeof a!=='object')return a;if(a.category_raw==null&&a.category&&/^A\d$/i.test(String(a.category)))a.category_raw=a.category;a.is_helo=!!isHelicopter(a);a.is_rotor=a.is_helo;a.aircraft_display_type=a.is_helo?'Helicopter':'Airplane';a.category=classKey(a.category);return a}catch(_){return a}}
  function findAircraftForMarker(marker, fallbackHtml){
    try{
      if(marker&&marker._v286AdsbAircraft)return normalize(marker._v286AdsbAircraft);
      const ll=marker&&marker.getLatLng&&marker.getLatLng();
      const list=Array.isArray(window.lastAircraft)?window.lastAircraft:[];
      if(ll){let best=null,bestD=Infinity;for(const raw of list){const a=normalize(raw);const la=Number(a&&a.lat),lo=Number(a&&a.lon);if(!Number.isFinite(la)||!Number.isFinite(lo))continue;const d=Math.abs(la-ll.lat)+Math.abs(lo-ll.lng);if(d<bestD){best=a;bestD=d;}}if(best&&bestD<0.03){marker._v286AdsbAircraft=best;marker._v286AdsbId=idOf(best);return best;}}
      const html=String(fallbackHtml||'');const m=html.match(/<h3[^>]*>(.*?)<\/h3>/i);const title=m?m[1].replace(/<[^>]*>/g,'').trim().toLowerCase():'';
      if(title){const found=list.map(normalize).find(a=>String(a.callsign||a.registration||a.hex||a.id||'').trim().toLowerCase()===title);if(found){marker._v286AdsbAircraft=found;marker._v286AdsbId=idOf(found);return found;}}
    }catch(_){ }
    return null;
  }
  function rowHtml(label,value){if(value==null||value==='')return '';return `<b>${esc(label)}</b><span>${esc(value)}</span>`}
  function valueNum(v,unit){const n=Number(v);return Number.isFinite(n)?Math.round(n)+' '+unit:''}
  function buildPopup(a){
    a=normalize(a||{});
    const id=idOf(a);
    const active=!!(window._v286TrackedId&&id&&window._v286TrackedId===id);
    const title=a.callsign||a.registration||a.hex||a.id||'ADS-B Aircraft';
    const rows=[];
    rows.push(rowHtml('ICAO/UID',a.id||a.hex||a.icao||'—'));
    rows.push(rowHtml('Class',classLabel(a.category)));
