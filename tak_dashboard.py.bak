  const esc=s=>{try{return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}catch(_){return ''}};
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V});}catch(_){}}
  function getMap(){
    try{if(window.takLeafletMap&&window.takLeafletMap.eachLayer)return window.takLeafletMap;}catch(_){}
