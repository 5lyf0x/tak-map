    .leaflet-marker-icon.v298-adsb-leaflet-marker .adsb-png-icon{position:relative;z-index:1;max-width:64px;max-height:44px;filter:drop-shadow(0 0 10px rgba(0,0,0,.82));}
    .leaflet-marker-icon.v298-adsb-leaflet-marker .aircraft-label{position:relative;z-index:1;}
