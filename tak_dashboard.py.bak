  function addCss(){try{if(field('v300AdsbTrackSaveDialogStyle'))return;const st=document.createElement('style');st.id='v300AdsbTrackSaveDialogStyle';st.textContent=`
    .adsb-track-distance-label.v300{background:rgba(8,12,16,.90);border:1px solid rgba(255,111,46,.82);border-radius:999px;color:#ffe4d4;box-shadow:0 6px 18px rgba(0,0,0,.42),0 0 14px rgba(255,111,46,.24);font-size:11px;font-weight:950;letter-spacing:.02em;line-height:1;padding:3px 7px;white-space:nowrap;transform:translate(10px,-12px);}
    .adsb-track-save-overlay.v300{position:fixed;inset:0;z-index:4200;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.42);backdrop-filter:blur(3px);}
    .adsb-track-save-card.v300{position:relative;width:min(420px,calc(100vw - 28px));border:1px solid rgba(255,122,26,.48);border-radius:14px;background:linear-gradient(180deg,rgba(18,27,35,.98),rgba(8,12,18,.98));box-shadow:0 18px 50px rgba(0,0,0,.62),0 0 22px rgba(255,122,26,.14);padding:13px 14px 12px;color:#eef5f7;}
    .adsb-track-save-x{position:absolute;right:8px;top:7px;width:28px;height:28px;border-radius:9px;margin:0;padding:0;line-height:1;font-size:18px;font-weight:900;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.12);color:#c9d7de;cursor:pointer;}
    .adsb-track-save-title{font-size:.92rem;font-weight:950;letter-spacing:.08em;text-transform:uppercase;color:#fff;padding-right:34px;}
    .adsb-track-save-sub{margin-top:4px;color:#9fb0ba;font-size:.78rem;font-weight:750;}
    .adsb-track-save-input{width:100%;margin:10px 0 7px;padding:8px 9px;border-radius:9px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.28);color:#eef5f7;font-weight:750;outline:none;}
    .adsb-track-save-input:focus{border-color:rgba(255,122,26,.72);box-shadow:0 0 0 2px rgba(255,122,26,.12);}
    .adsb-track-save-error,.adsb-track-save-msg.bad{color:#ff9b8a;font-size:.76rem;font-weight:850;}
    .adsb-track-save-msg{min-height:16px;color:#8ff0b6;font-size:.76rem;font-weight:850;}
    .adsb-track-save-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:8px;}
  `;document.head.appendChild(st)}catch(e){try{console.warn('v300 CSS failed',e)}catch(_){}}}
  function bind(){try{if(!window._v300TrackClickBound){window._v300TrackClickBound=true;document.addEventListener('click',ev=>{const b=ev.target&&ev.target.closest&&ev.target.closest('.adsb-track-btn');if(!b)return;ev.preventDefault();ev.stopPropagation();if(ev.stopImmediatePropagation)ev.stopImmediatePropagation();window.toggleAdsbTrack(b.dataset.adsbTrackId);return false},true)}const m=getMap();if(m&&!window._v300PopupBound){window._v300PopupBound=true;m.on('popupopen',ev=>setTimeout(()=>patchPopup(ev.popup&&ev.popup.getElement&&ev.popup.getElement()),0));m.on('popupclose',()=>setTimeout(syncButtons,0));}}catch(e){try{console.warn('v300 bind failed',e)}catch(_){}}}
