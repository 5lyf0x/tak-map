  function syncTrackButtons(){try{qa('.adsb-track-btn').forEach(btn=>{const on=!!(trackedId&&String(btn.dataset.adsbTrackId||'').toLowerCase()===trackedId);btn.classList.toggle('active',on);const l=q('.adsb-track-light',btn);if(l)l.classList.toggle('active',on)})}catch(_){}}
  window.toggleAdsbTrack=function(id){id=String(id||'').toLowerCase();if(!id)return false;try{if(trackedId===id){trackedId=null;const line=trackLines.get(id);if(line&&window[TRACK_LAYER])window[TRACK_LAYER].removeLayer(line);trackLines.delete(id);trackPoints.delete(id);syncTrackButtons();return false}if(trackedId&&trackedId!==id){const old=trackedId;const line=trackLines.get(old);if(line&&window[TRACK_LAYER])window[TRACK_LAYER].removeLayer(line);trackLines.delete(old);trackPoints.delete(old)}trackedId=id;const a=stable.find(x=>idOf(x)===id);if(a)addTrackPointFromAircraft(a);syncTrackButtons();return true}catch(_){return false}}
  function trackButtonHtml(id){return '<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn'+(trackedId===id?' active':'')+'" data-adsb-track-id="'+esc(id)+'"><span class="adsb-track-light '+(trackedId===id?'active':'')+'"></span><span>Track</span></button></div>'}
  function patchPopupElement(el){try{if(!el||!q('.adsb-popup',el))return;let id='';const title=(q('.adsb-popup h3,.feature-popup h3',el)?.textContent||'').trim().toLowerCase();let a=null;if(title)a=stable.find(x=>titleText(x).toLowerCase()===title||idOf(x)===title);id=idOf(a);const content=q('.leaflet-popup-content',el)||el;if(id&&!q('.adsb-track-row',content))content.insertAdjacentHTML('beforeend',trackButtonHtml(id));const btn=q('.adsb-track-btn',content);if(btn&&id){btn.dataset.adsbTrackId=id;btn.onclick=function(ev){try{ev&&ev.preventDefault&&ev.preventDefault();ev&&ev.stopPropagation&&ev.stopPropagation()}catch(_){}window.toggleAdsbTrack(id);return false}}syncTrackButtons()}catch(_){}}
