  function redrawTrack(id){try{const g=trackLayer();if(!g||!id)return;const pts=trackPoints.get(id)||[];let line=trackLines.get(id);if(pts.length<2){if(line){g.removeLayer(line);trackLines.delete(id)}return}const a=stable.find(x=>idOf(x)===id);if(!line){line=L.polyline(pts,{color:classColor(a),weight:3,opacity:.9,lineCap:'round',lineJoin:'round',interactive:false}).addTo(g);trackLines.set(id,line)}else{line.setLatLngs(pts);line.setStyle({color:classColor(a)})}}catch(_){}}
