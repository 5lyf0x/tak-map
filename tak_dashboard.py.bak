TAK_MAP_HTML = TAK_MAP_HTML.replace('</script></body></html>', r'''

/* v266 TAK Map Cert Setup and clarified ADS-B controls */
(function(){
  const V='v301';
  function field(id){return document.getElementById(id)}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function css(){if(field('v266Style'))return;const st=document.createElement('style');st.id='v266Style';st.textContent=`
    .map-cert-btn{border-color:rgba(255,111,46,.45)!important;background:linear-gradient(180deg,rgba(255,111,46,.24),rgba(255,111,46,.10))!important;color:#fff!important;font-weight:850!important}
    .map-cert-modal-backdrop{display:none;position:fixed;z-index:2200;inset:0;background:rgba(0,0,0,.68);padding:18px;overflow:auto}.map-cert-modal-backdrop.active{display:block}.map-cert-modal{max-width:820px;margin:5vh auto;background:#111922;border:1px solid rgba(255,255,255,.14);border-radius:16px;padding:16px;box-shadow:0 22px 60px rgba(0,0,0,.65);color:#e9f3f6}.map-cert-modal-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}.map-cert-modal-head h2{margin:0;font-size:1rem;letter-spacing:.06em;text-transform:uppercase}.map-cert-grid{display:grid;grid-template-columns:1fr;gap:10px}.map-cert-grid textarea{width:100%;background:#101820;color:#e9f3f6;border:1px solid rgba(255,255,255,.14);border-radius:10px;padding:9px 10px}.map-cert-pill-row{display:flex;flex-wrap:wrap;gap:6px}.map-cert-pill{display:inline-flex;align-items:center;border:1px solid rgba(255,255,255,.14);border-radius:999px;padding:5px 8px;background:rgba(255,255,255,.025);font-size:.82rem}.map-cert-actions{display:flex;flex-wrap:wrap;gap:8px;align-items:center}.map-cert-output{max-height:220px;overflow:auto;white-space:pre-wrap;border:1px solid rgba(255,255,255,.10);border-radius:10px;padding:8px;background:rgba(0,0,0,.18)}.map-cert-primary{border-color:rgba(255,111,46,.45)!important;background:linear-gradient(180deg,rgba(255,111,46,.27),rgba(255,111,46,.12))!important}
    .adsb-v266-actions{grid-column:1/-1;display:none!important;grid-template-columns:1fr 1fr;gap:7px;margin:5px 0 2px}.adsb-v266-actions .layer-button{font-size:.70rem!important;padding:6px 8px!important}.adsb-local-off{opacity:.54!important}.adsb-v266-note{grid-column:1/-1;color:#9fb1b9;font-size:.64rem;line-height:1.25;margin:-2px 0 4px}.adsb-v266-sep{grid-column:1/-1;height:1px;background:rgba(255,255,255,.10);margin:4px 0}
  `;document.head.appendChild(st)}
  function ensureCert(){try{css();if(!field('mapCertSetupBtn')){const top=document.querySelector('.top-actions');if(top){const b=document.createElement('button');b.id='mapCertSetupBtn';b.className='map-cert-btn';b.type='button';b.textContent='Cert Setup';b.onclick=window.openMapCertSetup;const logout=[...top.querySelectorAll('button')].find(x=>/logout/i.test(x.textContent||''));top.insertBefore(b,logout||top.firstChild)}}if(!field('mapCertModal')){document.body.insertAdjacentHTML('beforeend',`<div id="mapCertModal" class="map-cert-modal-backdrop"><div class="map-cert-modal"><div class="map-cert-modal-head"><h2>HTTPS Certificate Setup</h2><button type="button" onclick="closeMapCertSetup()">Close</button></div><div class="map-cert-grid"><p class="muted">Generate a local TAK Map CA and HTTPS server certificate for the current Pi addresses. Cert Setup installs the nginx server certificate/key, reloads nginx, and makes the client CA available through the Download CA Certificate button.</p><div><div class="muted">Detected names / IPs included by default</div><div id="mapCertDetected" class="map-cert-pill-row"><span class="map-cert-pill">Loading...</span></div></div><div><div class="muted">Certificate expiration</div><div id="mapCertExpiryStatus" class="map-cert-pill-row"><span class="map-cert-pill">Loading...</span></div></div><div><div class="muted">Optional extra hostnames or IPs, one per line</div><textarea id="mapCertExtraSans" rows="4" placeholder="10.10.10.2&#10;takmap.local&#10;192.168.1.50"></textarea></div><div class="map-cert-actions"><button class="layer-button map-cert-primary" type="button" onclick="generateMapCertSetup()">Generate / Regenerate Certificate</button><a id="mapCertDownloadLink" href="/ca-cert.crt" style="display:none"><button class="layer-button" type="button">Download CA Certificate</button></a><button class="layer-button" type="button" onclick="refreshMapCertSetup()">Refresh</button></div><pre id="mapCertSetupOutput" class="map-cert-output muted">Open this popup and generate the certificate. Then use Download CA Certificate for each laptop, phone, or tablet that should trust TAK Map.</pre></div></div></div>`);field('mapCertModal').addEventListener('click',ev=>{if(ev.target===field('mapCertModal'))closeMapCertSetup()})}}catch(e){console.warn('cert ui failed',e)}}
  window.openMapCertSetup=function(){ensureCert();field('mapCertModal')?.classList.add('active');refreshMapCertSetup()}
  window.closeMapCertSetup=function(){field('mapCertModal')?.classList.remove('active')}
  window.refreshMapCertSetup=async function(){const out=field('mapCertSetupOutput');try{const r=await fetch('/api/cert-status',{cache:'no-store'});const j=await r.json();const det=field('mapCertDetected');if(det){const names=[...(j.detected_sans||j.names||j.detected||[])];det.innerHTML=(names.length?names:['No detected names yet']).map(x=>`<span class="map-cert-pill">${esc(x)}</span>`).join('')}const ex=field('mapCertExpiryStatus');if(ex){const exp=j.certificate||j.cert||j.expiry||{};const txt=(j.status||exp.status||exp.not_after||j.expires||'Unknown');ex.innerHTML=`<span class="map-cert-pill">${esc(txt)}</span>`}const link=field('mapCertDownloadLink');if(link)link.style.display=(j.ca_download_url||j.ca_exists||j.ca_cert_exists)?'inline-flex':'none';if(out)out.textContent=(j.message||'Certificate status refreshed.')+'\n'+(j.ca_download_url||'Generate certificate first, then use Download CA Certificate.')}catch(e){if(out)out.textContent='Certificate status failed: '+e}}
  window.generateMapCertSetup=async function(){const out=field('mapCertSetupOutput');try{if(out)out.textContent='Generating certificate...';const extra=field('mapCertExtraSans')?.value||'';const r=await fetch('/api/cert-setup',{method:'POST',body:new URLSearchParams({extra_sans:extra,exclude_sans:''})});const j=await r.json();if(out)out.textContent=(j.ok?'Certificate setup complete.':'Certificate setup failed.')+'\n\nSTDOUT:\n'+(j.stdout||'')+'\n\nSTDERR:\n'+(j.stderr||j.error||'');await refreshMapCertSetup()}catch(e){if(out)out.textContent='Certificate setup failed: '+e}}
  function localDisabled(){try{return localStorage.getItem('takmap.adsb.localDisabled')==='1'}catch(_){return false}}
  function setLocalDisabled(v){try{localStorage.setItem('takmap.adsb.localDisabled',v?'1':'0')}catch(_){} }
  function updateAdsbButtons(){try{const local=localDisabled();const b=field('adsbLocalToggleBtn');if(b){b.textContent=local?'Enable ADS-B':'Disable ADS-B';b.classList.toggle('adsb-local-off',local);b.title='TAK Map local ADS-B display only'}const ots=field('adsbOtsJobBtn');if(ots){const off=localStorage.getItem('takmap.adsb.otsJobDisabled')==='1';ots.textContent=off?'Enable OTS Job':'Disable OTS Job';ots.title='OpenTAKServer ADS-B scheduler/job control'}}catch(_){}}
  function ensureAdsbControls(){try{document.querySelectorAll('.adsb-v266-actions,#adsbLocalToggleBtn,#adsbOtsJobBtn').forEach(n=>{const row=n.closest&&n.closest('.adsb-v266-actions');(row||n).remove()})}catch(e){}}
  window.toggleTakMapAdsbLocal=function(){const off=!localDisabled();setLocalDisabled(off);try{if(state&&state.live)state.live.adsb_aircraft=!off}catch(_){};try{if(off&&window.aircraftLayer){aircraftLayer.clearLayers();if(map&&map.hasLayer(aircraftLayer))map.removeLayer(aircraftLayer)}}catch(_){};const box=field('adsbSettingsStatus');if(box)box.textContent=off?'TAK Map ADS-B display disabled locally. OTS ingest unchanged.':'TAK Map ADS-B display enabled locally.';updateAdsbButtons();if(!off){try{refreshAdsb()}catch(_){}}}
  window.toggleAdsbOtsJob=async function(){const btn=field('adsbOtsJobBtn'),box=field('adsbSettingsStatus');const currently=localStorage.getItem('takmap.adsb.otsJobDisabled')==='1';const action=currently?'enable':'disable';try{if(btn)btn.disabled=true;if(box)box.textContent=(action==='disable'?'Disabling':'Enabling')+' OTS ADS-B scheduler job...';const r=await fetch('/api/tak-map/adsb-ots-job',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action})});const j=await r.json();if(j.ok){localStorage.setItem('takmap.adsb.otsJobDisabled',action==='disable'?'1':'0');if(box)box.textContent=j.message||('OTS ADS-B job '+(action==='disable'?'disabled.':'enabled.'))}else{if(box)box.textContent=j.message||j.error||'OTS ADS-B job control failed.'}}catch(e){if(box)box.textContent='OTS ADS-B job control failed: '+e}finally{if(btn)btn.disabled=false;updateAdsbButtons()}}
  const oldRefresh=window.refreshAdsb;window.refreshAdsb=async function(){if(localDisabled()){try{if(window.aircraftLayer)aircraftLayer.clearLayers();const el=field('adsbStatus');if(el)el.textContent='disabled'}catch(_){}return []}return oldRefresh?oldRefresh.apply(this,arguments):[]}
  function boot(){try{ensureCert();ensureAdsbControls();updateAdsbButtons();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v266 ui boot failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,500));else setTimeout(boot,500);setTimeout(boot,1800);setInterval(()=>{try{ensureAdsbControls();updateAdsbButtons()}catch(_){}},5000);
})();
</script></body></html>''')
