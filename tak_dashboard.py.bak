      .adsb-track-light{width:8px!important;height:8px!important;margin-right:7px!important;}
    `;
    document.head.appendChild(st);
  }
  function boot(){try{addCss();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v318 ADS-B popup/label style failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',boot,{once:true});else boot();
  setTimeout(boot,500);setTimeout(boot,1800);setInterval(boot,5000);
})();
</script>
"""
        _html = _html.replace('</body>', _style + '</body>', 1) if '</body>' in _html else _html + _style
        return _v318_versions(_html)

    TAK_MAP_HTML = _v318_patch_html(TAK_MAP_HTML)
    TAK_MAP_LOGIN_HTML = _v318_versions(TAK_MAP_LOGIN_HTML)
