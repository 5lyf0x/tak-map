  `;document.head.appendChild(st)}catch(e){console.warn('v292 css failed',e)} }
  function wrapOpen(){try{const old=window.openLocalElevationDialog;if(typeof old==='function'&&!old._v292Wrapped){window._v292BaseOpenLocalElevationDialog=old;const wrapped=function(ev){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation();}}catch(_){}let res;try{res=window._v292BaseOpenLocalElevationDialog.apply(this,arguments)}catch(e){console.warn('base open failed',e)}ensureDialogV292();const d=field('localElevationDialog');if(d)d.classList.add('active');[0,40,140,320].forEach(ms=>setTimeout(centerDialogV292,ms));return res};wrapped._v292Wrapped=true;window.openLocalElevationDialog=wrapped}const btn=field('localElevAddBtn');if(btn){btn.onclick=window.openLocalElevationDialog;if(!btn.dataset.v292LocalElev){btn.dataset.v292LocalElev='1';btn.addEventListener('click',window.openLocalElevationDialog,true)}}}catch(e){console.warn('v292 wrap open failed',e)} }
  function patchGovtLaw(){try{const govRe=/\b(LAPD|POLICE|SHERIFF|PUBLIC\s+SAFETY|EMS|RESCUE|CHP|CAL\s*FIRE|USFS|MEDICAL|HOSPITAL|RESPONSE|LAW\s+ENFORCEMENT)\b|\bFIRE\s*(DEPT|DEPARTMENT)?\b|\b[A-Z]{1,5}\s*(PD|FD)\b|\b(PD|FD)\b/;window.v292IsGovtKeyword=function(a){const b=[a&&a.owner_operator,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.description,a&&a.desc,a&&a.callsign,a&&a.flight,a&&a.registration].filter(Boolean).join(' ').toUpperCase();return govRe.test(b)};if(typeof window.isGovtKeyword==='function')window.isGovtKeyword=window.v292IsGovtKeyword}catch(e){console.warn('v292 govt patch failed',e)} }
  function boot(){addCss();setIteration();ensureDialogV292();wrapOpen();patchGovtLaw();if(field('localElevationDialog')&&field('localElevationDialog').classList.contains('active'))centerDialogV292();loadLocalElevationTilesV292();}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
  [260,900,1800,3600,5600].forEach(ms=>setTimeout(boot,ms));
