lastAircraft=rows;const seen=new Set();rows.forEach(function(a){const id=idOf(a);seen.add(id);ADSB.data.set(id,a);stableState(a);let mk=ADSB.markers.get(id);const ll=[a.lat,a.lon];if(!mk){mk=L.marker(ll,{icon:iconFor(a),zIndexOffset:900,interactive:true,riseOnHover:true}).addTo(layer);ADSB.markers.set(id,mk);mk.on(\'click\',function(ev){try{L.DomEvent.stop(ev)}catch(_){}try{mk.openPopup();setTimeout(syncButtons,20)}catch(_){}});mk.on(\'mouseover\',function(){try{mk.openPopup();setTimeout(syncButtons,20)}catch(_){}});mk.on(\'popupopen\',function(){setTimeout(syncButtons,20)});}else{try{mk.setLatLng(ll)}catch(_){}if(!updateMarkerDom(mk,a)){try{mk.setIcon(iconFor(a))}catch(_){}}}try{mk._takAdsbId=id;mk._takAdsbAircraft=a;mk._adsbData=a;mk._v310LastSeen=now;if(mk.isPopupOpen&&mk.isPopupOpen())mk.setPopupContent(popupHtml(a));else mk.bindPopup(popupHtml(a),{className:\'adsb-v311-popup adsb-object-popup\',autoPan:false,closeButton:false})}catch(_){}if(ADSB.tracking.id===id)addTrackPoint(a)});ADSB.markers.forEach(function(mk,id){if(seen.has(id))return;const age=now-Number((mk&&mk._v310LastSeen)||0);if(age>STALE_MS){try{layer.removeLayer(mk)}catch(_){}ADSB.markers.delete(id);ADSB.data.delete(id)}});publishMaps();updateStatus(rows.length);syncButtons();return rows}\n  async function refreshAdsb(){if(ADSB.busy)return ADSB.lastList;ADSB.busy=true;try{const r=await fetch(\'/api/tak-map/adsb\',{cache:\'no-store\'});const j=await r.json();try{window.lastAdsbSettings=(j&&j.settings)||window.lastAdsbSettings}catch(_){}return renderAircraft((j&&j.aircraft)||[])}catch(e){console.warn(\'v311 ADS-B refresh failed\',e);if(ADSB.lastList&&ADSB.lastList.length)return renderAircraft(ADSB.lastList);return ADSB.lastList||[]}finally{ADSB.busy=false}}\n  function updateStatus(count){try{const s=byId(\'adsbStatus\');if(s)s.textContent=String(count||0)+\' active\'}catch(_){}try{const b=byId(\'bannerAdsb\');if(b)b.textContent=String(count||0)+\' Aircraft\'}catch(_){} }\n  function startPolling(){t