        ):
            _html = _v309_remove_script_block(_html, _sid)
        _html = _v309_re.sub(r'/\*\s*v282 stability cleanup: single ADS-B module, event-driven popups, no recurring repair loops\s*\*/\s*\(function\(\)\{.*?\}\)\(\);\s*(?=</script>)',
                             '/* v282 ADS-B owner removed by v309: ADS-B is owned by v309AdsbOwnerPatch. */\n',
                             _html, count=1, flags=_v309_re.S)
        _html = _v309_re.sub(r'function\s+wrapAdsbDraw\s*\(\)\s*\{.*?\}\s*(?=\s*function\s+restyleDrawingTools\s*\()',
                             'function wrapAdsbDraw(){try{window._v309RemovedLegacyAdsbDrawWrap=true}catch(_){}}\n',
