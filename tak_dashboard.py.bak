  function sampleSize(){try{const q=String(field('terrain3dQuality')&&field('terrain3dQuality').value||window.terrain3DQuality||'medium').toLowerCase();return q==='high'?65:(q==='low'?33:49)}catch(_){return 49}}
  function makeLocalTerrainProvider(){if(!window.Cesium)return null;const Cesium=window.Cesium;const width=sampleSize();const tilingScheme=new Cesium.GeographicTilingScheme();const errorEvent=new Cesium.Event();const ellipsoid=tilingScheme.ellipsoid;const xTiles=tilingScheme.getNumberOfXTilesAtLevel(0);const levelZeroError=(Cesium.TerrainProvider&&Cesium.TerrainProvider.getEstimatedLevelZeroGeometricErrorForAHeightmap)?Cesium.TerrainProvider.getEstimatedLevelZeroGeometricErrorForAHeightmap(ellipsoid,width,xTiles):(ellipsoid.maximumRadius*Math.PI*2/(width*xTiles));const cache=new Map();const provider={_takLocalDemTerrainProvider:true,_takLocalWidth:width,_takLocalProviderVersion:V,_tilingScheme:tilingScheme,_errorEvent:errorEvent,requestTileGeometry:function(x,y,level,request){const key=level+'/'+x+'/'+y+'/'+width;const hit=cache.get(key);if(hit)return hit;const prom=(async()=>{await ensureLocalTiles();const rect=tilingScheme.tileXYToRectangle(x,y,level);const deg=Cesium.Math.toDegrees;const r={west:deg(rect.west),south:deg(rect.south),east:deg(rect.east),north:deg(rect.north)};const tiles=uniqueTiles().filter(t=>rectIntersects(r,tileBounds(t)));const buffer=new Float32Array(width*width);let valid=0,min=Infinity,max=-Infinity;if(tiles.length){for(let row=0;row<width;row++){const lat=r.north-((r.north-r.south)*(row/(width-1)));for(let col=0;col<width;col++){const lon=r.west+((r.east-r.west)*(col/(width-1)));const h=sampleLocal(lat,lon);const v=Number.isFinite(h)?h:0;buffer[row*width+col]=v;if(Number.isFinite(h)){valid++;if(v<min)min=v;if(v>max)max=v}}if(row%12===0)await new Promise(res=>setTimeout(res,0))}}
        const structure={heightScale:1,heightOffset:0,elementsPerHeight:1,stride:1,elementMultiplier:1,isBigEndian:false};
        const data=new Cesium.HeightmapTerrainData({buffer:buffer,width:width,height:width,childTileMask:15,structure:structure,createdByUpsampling:false});
        try{data._takLocalValidSamples=valid;data._takLocalMin=min;data._takLocalMax=max}catch(_){}
        return data})().catch(e=>{try{errorEvent.raiseEvent(e)}catch(_){};console.warn('v295 local DEM terrain tile failed',e);return new Cesium.HeightmapTerrainData({buffer:new Float32Array(width*width),width:width,height:width,childTileMask:15,structure:{heightScale:1,heightOffset:0,elementsPerHeight:1,stride:1,elementMultiplier:1,isBigEndian:false}})});
      cache.set(key,prom);if(cache.size>220){try{cache.delete(cache.keys().next().value)}catch(_){}}return prom;},getLevelMaximumGeometricError:function(level){return levelZeroError/(1<<level)},getTileDataAvailable:function(x,y,level){return true},loadTileDataAvailability:function(x,y,level){return undefined}};
    Object.defineProperties(provider,{errorEvent:{get:function(){return errorEvent}},credit:{get:function(){return undefined}},tilingScheme:{get:function(){return tilingScheme}},ready:{get:function(){return true}},readyPromise:{get:function(){return Promise.resolve(true)}},hasWaterMask:{get:function(){return false}},hasVertexNormals:{get:function(){return false}},availability:{get:function(){return undefined}}});
    return provider}
  async function applyLocalTerrainMesh(){try{const viewer=currentViewer();if(!viewer||!window.Cesium)return;const src=sourceIsLocal()?'local':'streamed';if(src==='local'){
      const tiles=await ensureLocalTiles();const width=sampleSize();if(!window._v295LocalTerrainProvider||window._v295LocalTerrainProvider._takLocalWidth!==width){window._v295LocalTerrainProvider=makeLocalTerrainProvider()}
      if(window._v295LocalTerrainProvider){window._v294FlatTerrainProvider=window._v295LocalTerrainProvider;if(viewer.terrainProvider!==window._v295LocalTerrainProvider)viewer.terrainProvider=window._v295LocalTerrainProvider;terrainStatusMsg('Terrain Mode · Local DEM terrain · '+(tiles.length?tiles.length+' coverage area'+(tiles.length===1?'':'s'):'no local files')+' · Outside coverage flat',!tiles.length)}
    }else{
      const prior=window._v294StreamedTerrainProvider||window._v295StreamedTerrainProvider;if(prior&&viewer.terrainProvider!==prior)viewer.terrainProvider=prior;
    }
