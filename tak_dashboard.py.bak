  function syncTrackButtons(){try{qa('.adsb-track-btn').forEach(btn=>{const on=!!(state.id&&String(btn.dataset.adsbTrackId||'').toLowerCase()===state.id);btn.classList.toggle('active',on);btn.setAttribute('aria-pressed',on?'true':'false');btn.dataset.v302Tracking=on?'1':'0';const l=q('.adsb-track-light',btn);if(l){l.classList.toggle('active',on);l.dataset.v302Tracking=on?'1':'0'}})}catch(_){} }
  function trackButtonHtml(id){const on=state.id&&state.id===String(id||'').toLowerCase();return '<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn'+(on?' active':'')+'" data-adsb-track-id="'+esc(id)+'" aria-pressed="'+(on?'true':'false')+'"><span class="adsb-track-light '+(on?'active':'')+'"></span><span>Track</span></button></div>'}
  function patchPopup(el){try{if(!el||!q('.adsb-popup,.feature-popup',el))return;let id='';const title=(q('.adsb-popup h3,.feature-popup h3',el)?.textContent||'').trim().toLowerCase();let a=null;if(title)a=aircraftList().find(x=>titleOf(x).toLowerCase()===title||idOf(x)===title);id=idOf(a);if(!id)return;const content=q('.leaflet-popup-content',el)||el;if(!q('.adsb-track-btn',content))content.insertAdjacentHTML('beforeend',trackButtonHtml(id));qa('.adsb-track-btn',content).forEach(btn=>{btn.dataset.adsbTrackId=id;btn.onclick=function(ev){try{ev&&ev.preventDefault&&ev.preventDefault();ev&&ev.stopPropagation&&ev.stopPropagation();ev&&ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}catch(_){}window.toggleAdsbTrack(id);return false}});syncTrackButtons()}catch(_){} }
  function patchOpenPopups(){try{qa('.leaflet-popup').forEach(patchPopup)}catch(_){} }
  function saveDialog(id,meta,pts){
