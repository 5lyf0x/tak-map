        _html = _html.replace(
            '<button type="button" class="layer-button adsb-track-btn" data-adsb-track-id="${esc(id)}"><span class="adsb-track-light"></span><span class="adsb-track-text">Track</span></button>',
            '<button type="button" class="layer-button adsb-track-btn" data-adsb-track-id="${esc(id)}" onclick="event.preventDefault();event.stopPropagation();return window.toggleAdsbTrack&&window.toggleAdsbTrack(this.dataset.adsbTrackId)"><span class="adsb-track-light"></span><span class="adsb-track-text">Track</span></button>'
        )

        # Replace the source-level drawAircraft function with an in-place renderer. The old version
        # called setIcon on every refresh and removed absent markers immediately, which caused blinking
        # on short/tiny refreshes and while interacting with popups.
        _new_draw = r'''function drawAircraft(list){
    const layer=ensureLayer();if(!layer)return;
    let shown=filtered(Array.isArray(list)?list:[]).filter(a=>Number.isFinite(Number(a&&a.lat))&&Number.isFinite(Number(a&&a.lon))&&!!adsbId(a));
