  function placeViewshed(){
    const m=q('#viewshedModule'); if(!m)return false;
    const tb=toolbarRect();
    const margin=12, header=72;
    m.classList.add('active');
    m.style.display='block';m.style.visibility='visible';m.style.opacity='1';m.style.position='fixed';m.style.zIndex='2600';
    const w=Math.min(360, Math.max(292, Math.round(window.innerWidth*0.30)));
