  function arrays(){const out=[];try{if(Array.isArray(window.lastAircraft))out.push(window.lastAircraft)}catch(_){}try{if(Array.isArray(window.__v307LastAircraft))out.push(window.__v307LastAircraft)}catch(_){}try{if(Array.isArray(window.v296StableAircraft))out.push(window.v296StableAircraft)}catch(_){}try{if(window.TakMapAdsb&&Array.isArray(window.TakMapAdsb.aircraft))out.push(window.TakMapAdsb.aircraft)}catch(_){}return out}
  function findAircraft(id){id=String(id||'').toLowerCase();for(const arr of arrays()){for(const a of arr||[]){if(idOf(a)===id)return a}}return null}
