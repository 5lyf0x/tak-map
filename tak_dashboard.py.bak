def sanitize_service_name(name):
    name = str(name or "").strip()
    if not re.match(r"^[A-Za-z0-9_.@-]{1,120}$", name):
        return ""
    return name

def sanitize_host_value(host):
    host = str(host or "").strip()
    if not re.match(r"^[A-Za-z0-9_.:-]{1,160}$", host):
        return ""
    return host

def normalize_zt_devices(items):
    out = []
    seen = set()
    if not isinstance(items, list):
        return out
    for item in items:
        if not isinstance(item, dict):
            continue
        ip = sanitize_host_value(item.get("ip", ""))
        if not ip or ip in seen:
            continue
        callsign = str(item.get("callsign") or item.get("name") or ip).strip()[:80]
        out.append({"ip": ip, "callsign": callsign})
        seen.add(ip)
    return out

def sanitize_neighbor_hostname(value):
    value = re.sub(r"\s+", " ", str(value or "").strip())[:80]
    if not value:
        return ""
    if not re.match(r"^[A-Za-z0-9_.:()\[\]@#/+ -]{1,80}$", value):
        return ""
    return value

def make_neighbor_key(dev, ip):
    dev = str(dev or "").strip()
    ip = str(ip or "").strip()
    return f"{dev}|{ip}"

def normalize_neighbor_hostnames(items):
    out = {}
    if not isinstance(items, dict):
        return out
    for key, value in items.items():
        key = str(key or "").strip()[:180]
        label = sanitize_neighbor_hostname(value)
        if key and label:
            out[key] = label
    return out

def normalize_services(items):
    out = []
    seen = set()
    if not isinstance(items, list):
        return out
    for item in items:
        svc = sanitize_service_name(item)
        if svc and svc not in seen:
            out.append(svc)
            seen.add(svc)
    return out

def sanitize_command_label(label):
    label = re.sub(r"\s+", " ", str(label or "").strip())[:80]
    return label

def sanitize_command_text(command):
    command = str(command or "").replace("\x00", "").strip()
    command = command.replace("\r", " ").replace("\n", " ")
    command = re.sub(r"\s+", " ", command)
    return command[:1000]

def make_command_id(label, command):
    base = re.sub(r"[^a-z0-9]+", "-", (label or "command").lower()).strip("-") or "command"
    suffix = str(abs(hash(command)) % 100000)
    return (base[:40] + "-" + suffix)[:64]

def normalize_custom_commands(items):
    out = []
    seen = set()
    if not isinstance(items, list):
        return out
    for item in items:
        if not isinstance(item, dict):
            continue
        label = sanitize_command_label(item.get("label"))
        command = sanitize_command_text(item.get("command"))
        category = sanitize_command_label(item.get("category") or "Custom")[:80] or "Custom"
        description = re.sub(r"\s+", " ", str(item.get("description") or "Custom command.").strip())[:180] or "Custom command."
        if not label or not command:
            continue
        cid = str(item.get("id") or make_command_id(label, command)).strip()
        cid = re.sub(r"[^A-Za-z0-9_.-]+", "-", cid)[:80] or make_command_id(label, command)
        if cid in seen:
            cid = make_command_id(label, command + str(len(out)))
        out.append({"id": cid, "label": label, "category": category, "description": description, "command": command})
        seen.add(cid)
    return out


def default_command_ids():
    return {c.get("id") for c in normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS) if c.get("id")}

def is_default_command_id(cid):
    return str(cid or "") in default_command_ids()

def normalize_deleted_default_command_ids(items):
    valid = default_command_ids()
    out = []
    seen = set()
    if not isinstance(items, list):
        return out
    for item in items:
        cid = re.sub(r"[^A-Za-z0-9_.-]+", "-", str(item or "").strip())[:80]
        if cid and cid in valid and cid not in seen:
            out.append(cid)
            seen.add(cid)
    return out

def mark_command_kinds(commands):
    defaults = default_command_ids()
    out = []
    for c in normalize_custom_commands(commands):
        d = dict(c)
        d["kind"] = "default" if d.get("id") in defaults else "custom"
        out.append(d)
    return out


def sanitize_upload_destination_label(label):
    label = re.sub(r"\s+", " ", str(label or "").strip())[:80]
    if not label:
        return ""
    if not re.match(r"^[A-Za-z0-9_.:()\[\]@#/+ ,\\-]{1,80}$", label):
        return ""
    return label

def sanitize_upload_destination_path(path):
    path = str(path or "").replace("\x00", "").strip()[:240]
    if not path:
        return ""
    # Destination templates may be ~/..., /absolute/path, or a relative path
    # that will be resolved under the authenticated user's home folder.
    # Block shell/control characters; backend and helper still canonicalize paths.
    if re.search(r"[\r\n`$;&|<>]", path):
        return ""
    if not re.match(r"^[A-Za-z0-9_.:()\[\]@#/+ ,~=\\-]{1,240}$", path):
        return ""
    return path

def make_upload_destination_id(label, path):
    base = re.sub(r"[^a-z0-9]+", "-", (label or path or "upload").lower()).strip("-") or "upload"
    suffix = str(abs(hash(path or label)) % 100000)
    return (base[:40] + "-" + suffix)[:64]

DEFAULT_UPLOAD_DESTINATIONS = [
    {"id": "desktop", "label": "Desktop", "path": "~/Desktop"},
    {"id": "downloads", "label": "Downloads", "path": "~/Downloads"},
    {"id": "home", "label": "Home", "path": "~/"},
]

def normalize_upload_destinations(items):
    out = []
    seen = set()
    if not isinstance(items, list):
        items = []
    for item in items:
        if not isinstance(item, dict):
            continue
        label = sanitize_upload_destination_label(item.get("label"))
        path = sanitize_upload_destination_path(item.get("path"))
        if not label or not path:
            continue
        cid = str(item.get("id") or make_upload_destination_id(label, path)).strip()
        cid = re.sub(r"[^A-Za-z0-9_.-]+", "-", cid)[:80] or make_upload_destination_id(label, path)
        if cid in seen:
            cid = make_upload_destination_id(label, path + str(len(out)))
        out.append({"id": cid, "label": label, "path": path})
        seen.add(cid)
    if not out:
        out = [dict(x) for x in DEFAULT_UPLOAD_DESTINATIONS]
    return out

def migrate_upload_destinations(items, ensure_defaults=True):
    # v67: show default upload destinations as Label: path instead of using the path as the label.
    out = []
    seen = set()
    for item in normalize_upload_destinations(items):
        d = dict(item)
        if d.get("id") == "desktop":
            d["label"] = "Desktop"
            d["path"] = "~/Desktop"
        elif d.get("id") == "downloads":
            d["label"] = "Downloads"
            d["path"] = "~/Downloads"
        elif d.get("id") == "home":
            d["label"] = "Home"
            d["path"] = "~/"
        if d.get("id") in seen:
            d["id"] = make_upload_destination_id(d.get("label"), d.get("path") + str(len(out)))
        out.append(d)
        seen.add(d.get("id"))
    if ensure_defaults:
        existing = {d.get("id") for d in out}
        for default in DEFAULT_UPLOAD_DESTINATIONS:
            if default.get("id") not in existing:
                out.append(dict(default))
    return normalize_upload_destinations(out)

def migrate_custom_commands(commands, ensure_defaults=False):
    # v48: make the default Renew 4G DHCP button run the user-visible command directly.
    # v49: add compact Listening Ports as a default command on upgrade.
    # v89: refresh built-in/default command metadata on package upgrade, while preserving custom commands.
    out = []
    default_by_id = {d.get("id"): dict(d) for d in normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS)}
    for c in normalize_custom_commands(commands):
        if c.get("id") == "renew-4g-dhcp" or c.get("label") == "Renew 4G DHCP":
            c = dict(c)
            c["id"] = "renew-4g-dhcp"
            c["label"] = "Renew 4G DHCP"
            c["command"] = "sudo dhclient -v wwan0"
        if c.get("id") == "listening-ports" or c.get("label") == "Listening Ports":
            c = dict(c)
            c["id"] = "listening-ports"
            c["label"] = "Listening Ports"
            c["command"] = "sudo ss -H -ltnup | awk '{print $1, $5, $7}' | sort"
        if ensure_defaults and c.get("id") in default_by_id:
            c = dict(default_by_id[c.get("id")])
        out.append(c)
    if ensure_defaults:
        existing_ids = {c.get("id") for c in out}
        existing_labels = {c.get("label") for c in out}
        for default in normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS):
            if default.get("id") not in existing_ids and default.get("label") not in existing_labels:
                out.append(default)
    return out

def default_runtime_config():
    return {
        "config_version": CONFIG_VERSION,
        "zerotier_devices": normalize_zt_devices(ZEROTIER_DEVICES),
        "services": normalize_services(SERVICES),
        "required_services": normalize_services(REQUIRED_SERVICES),
        "warning_settings": dict(DEFAULT_WARNING_SETTINGS),
        "custom_commands": normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS),
        "deleted_default_command_ids": [],
        "neighbor_hostnames": {},
        "upload_destinations": normalize_upload_destinations(DEFAULT_UPLOAD_DESTINATIONS),
    }

def load_runtime_config():
    cfg = default_runtime_config()
    raw = load_json_file(CONFIG_FILE, {})
    if isinstance(raw, dict):
        raw_version = int(raw.get("config_version") or 1)
        if "zerotier_devices" in raw:
            cfg["zerotier_devices"] = normalize_zt_devices(raw.get("zerotier_devices"))
        if "services" in raw:
            services = normalize_services(raw.get("services"))
            if raw_version < 2:
                services = [s for s in services if s not in LEGACY_DEFAULT_SERVICES_TO_REMOVE]
            if services:
                cfg["services"] = services
        if "required_services" in raw:
            req = normalize_services(raw.get("required_services"))
            if raw_version < 2:
                req = [s for s in req if s not in LEGACY_DEFAULT_SERVICES_TO_REMOVE]
            cfg["required_services"] = req
        if "custom_commands" in raw:
            cfg["custom_commands"] = migrate_custom_commands(raw.get("custom_commands"), ensure_defaults=raw_version < CONFIG_VERSION)
        if "deleted_default_command_ids" in raw:
            cfg["deleted_default_command_ids"] = normalize_deleted_default_command_ids(raw.get("deleted_default_command_ids"))
        if "neighbor_hostnames" in raw:
            cfg["neighbor_hostnames"] = normalize_neighbor_hostnames(raw.get("neighbor_hostnames"))
        if "upload_destinations" in raw:
            cfg["upload_destinations"] = migrate_upload_destinations(raw.get("upload_destinations"), ensure_defaults=True)
        warnings = raw.get("warning_settings")
        if isinstance(warnings, dict):
            merged = dict(DEFAULT_WARNING_SETTINGS)
            for k in merged:
                if k in warnings:
                    merged[k] = bool(warnings[k])
            cfg["warning_settings"] = merged
        cfg["config_version"] = CONFIG_VERSION
    return cfg

def save_runtime_config(cfg):
    clean = default_runtime_config()
    clean["config_version"] = CONFIG_VERSION
    if isinstance(cfg, dict):
        clean["zerotier_devices"] = normalize_zt_devices(cfg.get("zerotier_devices", clean["zerotier_devices"]))
        services = normalize_services(cfg.get("services", clean["services"]))
        clean["services"] = services or normalize_services(SERVICES)
        req = normalize_services(cfg.get("required_services", clean["required_services"]))
        clean["required_services"] = req
        commands = migrate_custom_commands(cfg.get("custom_commands", clean["custom_commands"]), ensure_defaults=False)
        clean["custom_commands"] = commands
        clean["deleted_default_command_ids"] = normalize_deleted_default_command_ids(cfg.get("deleted_default_command_ids", clean.get("deleted_default_command_ids", [])))
        clean["neighbor_hostnames"] = normalize_neighbor_hostnames(cfg.get("neighbor_hostnames", clean["neighbor_hostnames"]))
        clean["upload_destinations"] = migrate_upload_destinations(cfg.get("upload_destinations", clean["upload_destinations"]), ensure_defaults=True)
        warnings = cfg.get("warning_settings", clean["warning_settings"])
        merged = dict(DEFAULT_WARNING_SETTINGS)
        if isinstance(warnings, dict):
            for k in merged:
                if k in warnings:
                    merged[k] = bool(warnings[k])
        clean["warning_settings"] = merged
    atomic_write_json(CONFIG_FILE, clean)
    return clean

def effective_zerotier_devices():
    return load_runtime_config().get("zerotier_devices", [])

def effective_services():
    return load_runtime_config().get("services", normalize_services(SERVICES))

def effective_required_services():
    cfg = load_runtime_config()
    # Empty list intentionally means no service-level banner warnings.
    return normalize_services(cfg.get("required_services", normalize_services(REQUIRED_SERVICES)))

def effective_custom_commands():
    cfg = load_runtime_config()
    hidden = set(normalize_deleted_default_command_ids(cfg.get("deleted_default_command_ids", [])))
    commands = migrate_custom_commands(cfg.get("custom_commands", normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS)), ensure_defaults=True)
    visible = [c for c in commands if not (c.get("id") in hidden and is_default_command_id(c.get("id")))]
    return mark_command_kinds(visible)

def effective_neighbor_hostnames():
    return load_runtime_config().get("neighbor_hostnames", {})

def effective_upload_destinations():
    return load_runtime_config().get("upload_destinations", normalize_upload_destinations(DEFAULT_UPLOAD_DESTINATIONS))

def warning_settings():
    return load_runtime_config().get("warning_settings", dict(DEFAULT_WARNING_SETTINGS))


def run_cmd(cmd,timeout=5):
    try:
        p=subprocess.run(cmd,stdout=subprocess.PIPE,stderr=subprocess.PIPE,text=True,timeout=timeout,check=False)
        return {'ok':p.returncode==0,'rc':p.returncode,'stdout':p.stdout.strip(),'stderr':p.stderr.strip(),'cmd':cmd}
    except FileNotFoundError:
        return {'ok':False,'rc':127,'stdout':'','stderr':f'Command not found: {cmd[0]}','cmd':cmd}
    except subprocess.TimeoutExpired:
        return {'ok':False,'rc':124,'stdout':'','stderr':f'Command timed out after {timeout}s','cmd':cmd}
    except Exception as e:
        return {'ok':False,'rc':1,'stdout':'','stderr':str(e),'cmd':cmd}

def label_interface(dev):
    dev = str(dev or '')
    if re.match(r'^eth[0-3]$', dev): return 'Ethernet'
    if re.match(r'^wlan[0-3]$', dev): return 'WiFi'
    if re.match(r'^wwan[0-3]$', dev): return '4G/5G LTE'
    if dev.startswith('zt'): return 'ZeroTier'
    return dev

def prefix_to_netmask(prefix):
    try:
        import ipaddress
        return str(ipaddress.IPv4Network(f'0.0.0.0/{int(prefix)}').netmask)
    except Exception: return ''

def get_ipv4_details(dev):
    r=run_cmd(['ip','-j','addr','show','dev',dev],3); out=[]
    if not r['ok']: return out
    try:
        for item in json.loads(r['stdout']):
            for a in item.get('addr_info',[]):
                if a.get('family')=='inet':
                    p=a.get('prefixlen'); ip=a.get('local','')
                    out.append({'address':ip,'prefixlen':p,'cidr':f'{ip}/{p}','netmask':prefix_to_netmask(p)})
    except Exception: pass
    return out

def get_ipv4s(dev): return [d['cidr'] for d in get_ipv4_details(dev)]
def get_zt_interfaces(): return sorted(p.name for p in Path('/sys/class/net').glob('zt*'))

def get_interface_status(dev):
    ipv4s = get_ipv4s(dev)
    mac = ""
    raw_operstate = "unknown"
    flags = []

    link = run_cmd(["ip", "-j", "link", "show", "dev", dev], timeout=3)
    if link["ok"]:
        try:
            data = json.loads(link["stdout"])
            if data:
                item = data[0]
                raw_operstate = str(item.get("operstate", "unknown")).lower()
                flags = item.get("flags", []) or []
                mac = item.get("address", "") or ""
        except Exception:
            pass

    if not mac:
        try:
            mac = Path(f"/sys/class/net/{dev}/address").read_text().strip()
        except Exception:
            pass

    # Field-friendly interface state:
    # Many wwan/tun interfaces report UNKNOWN even when they are usable.
    # If the interface has an IPv4 address, show it as connected.
    if ipv4s:
        status = "connected"
    else:
        flag_set = set(str(f).upper() for f in flags)
        if "LOWER_UP" in flag_set:
            status = "link-up"
        elif "UP" in flag_set:
            status = "up"
        elif raw_operstate and raw_operstate != "unknown":
            status = raw_operstate
        else:
            status = "down"

    return {
        "name": dev,
        "label": label_interface(dev),
        "ipv4": ipv4s,
        "operstate": status,
        "raw_operstate": raw_operstate,
        "flags": flags,
        "mac": mac,
    }


def get_interfaces():
    if INTERFACES == ['auto'] or not INTERFACES:
        skip_prefixes=('lo','docker','br-','veth','virbr')
        names=[]
        try:
            for p in sorted(Path('/sys/class/net').iterdir()):
                n=p.name
                if n == 'lo' or any(n.startswith(x) for x in skip_prefixes):
                    continue
                names.append(n)
        except Exception:
            names=['eth0','wlan0','wwan0']
    else:
        names=list(INTERFACES)
    for z in get_zt_interfaces():
        if z not in names:
            names.append(z)
    return {n:get_interface_status(n) for n in names}

def neighbor_interface_label(dev):
    dev = str(dev or "")
    if dev.startswith('zt'):
        return 'ZeroTier'
    if re.match(r'^wlan[0-3]$', dev):
        return 'WiFi'
    if re.match(r'^eth[0-3]$', dev):
        return 'Ethernet'
    if re.match(r'^wwan[0-3]$', dev):
        return '4G/5G LTE'
    return dev or 'unknown'

def normalize_neighbor_state(state):
    state = str(state or '').strip().upper()
    if not state:
        return 'None'
    if state == 'NOARP':
        return 'NOARP'
    mapping = {
        'REACHABLE': 'Reachable',
        'STALE': 'Stale',
        'DELAY': 'Delay',
        'INCOMPLETE': 'Incomplete',
        'PROBE': 'Probe',
        'FAILED': 'Failed',
        'NONE': 'None',
        'PERMANENT': 'Reachable',
    }
    return mapping.get(state, state.title())

def resolve_neighbor_hostname(ip):
    ip = str(ip or '').strip()
    if not ip:
        return ''
    # Local resolvers first. Keep timeouts short because this runs every refresh.
    for cmd in (
        ['getent', 'hosts', ip],
        ['bash', '-lc', f"command -v avahi-resolve-address >/dev/null 2>&1 && avahi-resolve-address {ip} 2>/dev/null || true"],
    ):
        r = run_cmd(cmd, 1)
        if r.get('ok') and r.get('stdout'):
            line = r['stdout'].splitlines()[0].strip()
            parts = line.split()
            if len(parts) >= 2:
                host = parts[1].rstrip('.')
                if host and host != ip:
                    return host[:80]
    return ''

def load_neighbor_last_seen():
    data = load_json_file(NEIGHBOR_LAST_SEEN_FILE, {})
    return data if isinstance(data, dict) else {}

def save_neighbor_last_seen(data):
    if isinstance(data, dict):
        # Keep file small by retaining most recent 300 entries.
        try:
            items = sorted(data.items(), key=lambda kv: int(kv[1] or 0), reverse=True)[:300]
            atomic_write_json(NEIGHBOR_LAST_SEEN_FILE, dict(items))
        except Exception:
            pass

def load_neighbor_host_cache():
    data = load_json_file(NEIGHBOR_HOST_CACHE_FILE, {})
    return data if isinstance(data, dict) else {}

def save_neighbor_host_cache(data):
    if isinstance(data, dict):
        try:
            # Keep most recent 500 entries.
            items = sorted(data.items(), key=lambda kv: int((kv[1] or {}).get('ts', 0)), reverse=True)[:500]
            atomic_write_json(NEIGHBOR_HOST_CACHE_FILE, dict(items))
        except Exception:
            pass

def resolve_neighbor_hostname_cached(key, ip, manual_label='', refresh_seconds=30):
    # Do not refresh auto hostnames when the user has already saved a label.
    # This keeps manual labels stable and avoids replacing user text while editing.
    if manual_label:
        return ''
    now = int(time.time())
    cache = load_neighbor_host_cache()
    item = cache.get(key) or cache.get(ip) or {}
    try:
        ts = int(item.get('ts', 0))
    except Exception:
        ts = 0
    if now - ts < refresh_seconds:
        return sanitize_neighbor_hostname(item.get('hostname', ''))
    hostname = sanitize_neighbor_hostname(resolve_neighbor_hostname(ip))
    cache[key] = {'hostname': hostname, 'ts': now}
    save_neighbor_host_cache(cache)
    return hostname

def load_gateway_halow_cache():
    data = load_json_file(GATEWAY_HALOW_CACHE_FILE, {})
    return data if isinstance(data, dict) else {}

def save_gateway_halow_cache(data):
    if isinstance(data, dict):
        try:
            items = sorted(data.items(), key=lambda kv: int((kv[1] or {}).get('checked_ts', 0)), reverse=True)[:50]
            atomic_write_json(GATEWAY_HALOW_CACHE_FILE, dict(items))
        except Exception:
            pass

def html_attr_values(tag):
    vals = []
    if not tag:
        return vals
    # Handles double-quoted, single-quoted, and unquoted HTML attributes.
    try:
        for m in re.finditer(r'([a-zA-Z_:][-a-zA-Z0-9_:.]*)\s*=\s*(?:"([^"]*)"|\'([^\']*)\'|([^\s>]+))', tag, flags=re.I | re.S):
            val = m.group(2) if m.group(2) is not None else (m.group(3) if m.group(3) is not None else m.group(4))
            if val:
                vals.append(val)
    except Exception:
        pass
    return vals

def html_attr_values(tag):
    vals = []
    if not tag:
        return vals
    # Handles double-quoted, single-quoted, and unquoted HTML attributes.
    try:
        for m in re.finditer(r'([a-zA-Z_:][-a-zA-Z0-9_:.]*)\s*=\s*(?:"([^"]*)"|\'([^\']*)\'|([^\s>]+))', tag, flags=re.I | re.S):
            val = m.group(2) if m.group(2) is not None else (m.group(3) if m.group(3) is not None else m.group(4))
            if val:
                vals.append(val)
    except Exception:
        pass
    return vals

def extract_gateway_source_text(html):
    # Search the raw source first. Then duplicate metadata/title/comment content
    # into a normalized text block so gateway product strings embedded in <meta>
    # attributes are easy to detect.
    if not html:
        return ''
    parts = [html]
    try:
        meta_tags = re.findall(r'<meta\b[^>]*>', html, flags=re.I | re.S)
        parts.extend(meta_tags)
        for tag in meta_tags:
            parts.extend(html_attr_values(tag))
            # Also keep the tag with punctuation removed, which helps when vendor
            # pages split Wi-Fi/HaLow strings with symbols or entities.
            parts.append(re.sub(r'[^A-Za-z0-9._:/ -]+', ' ', tag))
        parts.extend(re.findall(r'<title[^>]*>(.*?)</title>', html, flags=re.I | re.S))
        parts.extend(re.findall(r'<!--(.*?)-->', html, flags=re.S))
    except Exception:
        pass
    try:
        import html as html_lib
        parts = [html_lib.unescape(str(x)) for x in parts if x is not None and str(x) != '']
    except Exception:
        parts = [str(x) for x in parts if x is not None and str(x) != '']
    joined = '\n'.join(parts)
    # Add a collapsed version so patterns still match if source has newlines or
    # HTML entities between letters/words.
    collapsed = re.sub(r'\s+', ' ', joined)
    return joined + '\n' + collapsed

def infer_gateway_capabilities(current_band='Unknown', detected_capabilities=None):
    caps = []
    band = str(current_band or '').strip()
    if band and band.lower() != 'unknown':
        caps.append(band)
        # For the common HaLow gateway/AP case in this project, if the Pi is
        # currently connected on 2.4 GHz, treat 5.8 GHz WiFi as present too.
        if '2.4' in band:
            caps.append('5.8 GHz WiFi')
    for item in detected_capabilities or []:
        item = str(item or '').strip()
        if item and item.lower() not in ('unknown', 'not detected') and item not in caps:
            caps.append(item)
    return caps

def format_gateway_capability(current_band='Unknown', detected_capabilities=None):
    band = str(current_band or '').strip() or 'Unknown'
    caps = infer_gateway_capabilities(band, detected_capabilities)
    if not caps:
        return band
    return f'Current: {band}\nCapable: {", ".join(caps)}'

def gateway_capability_fallback(fallback_band='Unknown'):
    band = str(fallback_band or '').strip()
    if not band or band.lower() == 'unknown':
        band = 'Unknown'
    return {'status': format_gateway_capability(band, []), 'note': '', 'checked_ts': None, 'current_band': band, 'capabilities': infer_gateway_capabilities(band, [])}

def decode_http_body(raw, headers=None):
    if raw is None:
        return ''
    headers = headers or {}
    enc = ''
    try:
        enc = str(headers.get('Content-Encoding', '') or '').lower()
    except Exception:
        enc = ''
    try:
        if 'gzip' in enc:
            import gzip
            raw = gzip.decompress(raw)
        elif 'deflate' in enc:
            import zlib
            raw = zlib.decompress(raw)
    except Exception:
        pass
    for codec in ('utf-8', 'latin-1'):
        try:
            return raw.decode(codec, errors='ignore')
        except Exception:
            continue
    return str(raw)

def fetch_gateway_source(url):
    try:
        req = Request(url, headers={
            'User-Agent': 'Mozilla/5.0 (X11; Linux armv8) TAK-Server-Dash/1.0',
            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
            'Cache-Control': 'no-cache',
            'Pragma': 'no-cache',
            'Connection': 'close',
        })
        ctx = ssl._create_unverified_context() if url.lower().startswith('https://') else None
        with urlopen(req, timeout=4, context=ctx) as resp:
            raw = resp.read(300000)
            headers = getattr(resp, 'headers', {}) or {}
        text = decode_http_body(raw, headers)
        if text:
            return text
    except Exception:
        pass
    # Curl fallback catches embedded gateway pages that behave differently for
    # browser-like clients or redirects. It is intentionally read-only and local.
    try:
        r = run_cmd(['curl','-k','-L','--max-time','4','--connect-timeout','2','-A','Mozilla/5.0','-H','Cache-Control: no-cache',url], 6)
        if r.get('ok') and r.get('stdout'):
            return r.get('stdout','')
    except Exception:
        pass
    return ''

def detect_gateway_capabilities_from_source(text):
    source_text = extract_gateway_source_text(text)
    if not source_text:
        return [], []
    normalized = source_text.lower()
    compact = re.sub(r'[^a-z0-9]+', '', normalized)
    checks = [
        ('915 MHz HaLow', ['915mhz', '915 mhz', '902-928', '902 - 928', '902–928', '902 – 928'], r'915\s*mhz|902\s*[-–]\s*928\s*mhz'),
        ('Wi-Fi HaLow', ['halow', 'ha-low', 'wi-fi halow', 'wifi halow', '802.11ah', '802.11 ah', '80211ah', '802_11ah'], r'halo\s*w|wi[- ]?fi\s*[-/]?\s*halo\s*w|802\.?11\s*ah|80211ah|802_11ah'),
        ('Sub-GHz / S1G', ['s1g', 'sub-ghz', 'sub ghz', 'sub-g', 'sub g'], r'\bs1g\b|sub[- ]?ghz|sub[- ]?g'),
        ('2.4 GHz WiFi', ['2.4ghz', '2.4 ghz', '2.4g', '2.4 g', '2400mhz', '2400 mhz', '2412 mhz', '2437 mhz', '2462 mhz'], r'2\.4\s*ghz|2\.4\s*g\b|24\s*ghz|2400\s*mhz|24[0-9]{2}\s*mhz'),
        ('5.8 GHz WiFi', ['5.8ghz', '5.8 ghz', '5ghz', '5 ghz', '5g wifi', '5800mhz', '5800 mhz'], r'5(?:\.8)?\s*ghz|5\s*g\s*wifi|5[1-8][0-9]{2}\s*mhz'),
        ('6 GHz WiFi', ['6ghz', '6 ghz', '6e', 'wifi 6e', 'wi-fi 6e'], r'6\s*ghz|wi[- ]?fi\s*6e|\b6e\b'),
    ]
    found = []
    matched_terms = []
    for name, terms, pat in checks:
        hit = ''
        for term in terms:
            if term in normalized or re.sub(r'[^a-z0-9]+', '', term) in compact:
                hit = term
                break
        if not hit and re.search(pat, source_text, re.I):
            hit = pat
        if hit and name not in found:
            found.append(name)
            matched_terms.append(hit)
    # If the gateway advertises 2.4 GHz, also list 5.8 GHz as present for the
    # expected dual-band gateway class used with this dashboard.
    if '2.4 GHz WiFi' in found and '5.8 GHz WiFi' not in found:
        found.append('5.8 GHz WiFi')
        matched_terms.append('inferred from 2.4 GHz')
    return found, matched_terms

def detect_gateway_capability_from_source(text):
    caps, matched = detect_gateway_capabilities_from_source(text)
    return (caps[0], matched[0] if matched else '') if caps else ('', '')

def probe_gateway_halow_capability(gateway, fallback_band='Unknown'):
    host = clean_host_for_ping(gateway)
    current_band = str(fallback_band or '').strip() or 'Unknown'
    fallback = gateway_capability_fallback(current_band)
    if not host:
        return fallback
    now = int(time.time())
    cache = load_gateway_halow_cache()
    cached = cache.get(host)
    # Cache source-derived capability detections briefly. Current radio band is
    # still recalculated every status refresh and merged into the display.
    if isinstance(cached, dict) and now - int(cached.get('checked_ts', 0) or 0) < 30:
        cached_caps = cached.get('capabilities') or []
        if isinstance(cached_caps, list) and cached_caps:
            return {
                'status': format_gateway_capability(current_band, cached_caps),
                'note': '',
                'checked_ts': cached.get('checked_ts'),
                'current_band': current_band,
                'capabilities': infer_gateway_capabilities(current_band, cached_caps),
            }

    urls = []
    for scheme in ('http', 'https'):
        for path in ('/', '/index.html', '/login.html', '/cgi-bin/luci/'):
            urls.append(f'{scheme}://{host}{path}')

    capabilities = []
    matched = []
    checked_url = ''
    for url in urls:
        text = fetch_gateway_source(url)
        if not text:
            continue
        checked_url = url
        found_caps, found_matches = detect_gateway_capabilities_from_source(text)
        if found_caps:
            capabilities = found_caps
            matched = found_matches
            break

    result_caps = infer_gateway_capabilities(current_band, capabilities)
    result = {
        'status': format_gateway_capability(current_band, capabilities),
        'note': '',
        'checked_ts': now,
        'matched': ', '.join(matched),
        'url': checked_url,
        'current_band': current_band,
        'capabilities': result_caps,
    }
    # Cache source-derived capabilities and probe metadata. Even if no source
    # capability is found, the cached status is harmless because current_band is
    # merged at render time from live data.
    cache[host] = result
    save_gateway_halow_cache(cache)
    return result

def get_network_neighbors(include_ipv6=False):
    # IPv4 neighbors are shown by default to keep the field table compact.
    # When include_ipv6=True, include both IPv4 and IPv6 neighbors.
    r = run_cmd(['ip', 'neigh', 'show'] if include_ipv6 else ['ip', '-4', 'neigh', 'show'], 4)
    labels = effective_neighbor_hostnames()
    last_seen = load_neighbor_last_seen()
    now = int(time.time())
    rows = []
    if not r.get('ok') or not r.get('stdout'):
        return rows
    active_states = {'Reachable', 'NOARP', 'Stale', 'Delay', 'Probe'}
    for line in r['stdout'].splitlines():
        parts = line.split()
        if not parts:
            continue
        ip = parts[0]
        dev = ''
        mac = ''
        raw_state = ''
        for idx, part in enumerate(parts):
            if part == 'dev' and idx + 1 < len(parts):
                dev = parts[idx + 1]
            elif part == 'lladdr' and idx + 1 < len(parts):
                mac = parts[idx + 1]
        # State is usually the last token; keep the last all-caps state token if present.
        for part in reversed(parts):
            if re.match(r'^[A-Z_]+$', part):
                raw_state = part
                break
        state = normalize_neighbor_state(raw_state)
        key = make_neighbor_key(dev, ip)
        if state in active_states:
            last_seen[key] = now
        manual = labels.get(key) or labels.get(ip) or ''
        auto_host = resolve_neighbor_hostname_cached(key, ip, manual)
        hostname = manual or auto_host or ''
        rows.append({
            'key': key,
            'interface': neighbor_interface_label(dev),
            'raw_interface': dev,
            'ip': ip,
            'hostname': hostname,
            'hostname_source': 'manual' if manual else ('auto' if auto_host else ''),
            'mac': mac or 'unknown',
            'state': state,
            'last_seen_ts': last_seen.get(key),
        })
    save_neighbor_last_seen(last_seen)
    rows.sort(key=lambda x: (x.get('interface',''), x.get('ip','')))
    return rows

def get_gateway_for_dev(dev):
    r=run_cmd(['bash','-lc',f"nmcli -g IP4.GATEWAY device show {dev} 2>/dev/null | head -n1"],4)
    if r['ok'] and r['stdout'].strip(): return r['stdout'].strip()
    r=run_cmd(['bash','-lc',f"ip route | awk '/default .* dev {dev}/{{print $3; exit}}'"],3)
    if r['ok'] and r['stdout'].strip(): return r['stdout'].strip()
    det=get_ipv4_details(dev)
    if det:
        try:
            import ipaddress
            hosts=list(ipaddress.IPv4Interface(det[0]['cidr']).network.hosts())
            if hosts: return f'{hosts[0]} (inferred)'
        except Exception: pass
    return ''

def bars_from_percent(v):
    try: p=int(float(v))
    except Exception: return {'count':None,'text':'unknown'}
    c=0 if p<=0 else 1 if p<=20 else 2 if p<=40 else 3 if p<=60 else 4 if p<=80 else 5
    return {'count':c,'text':'▮'*c+'▯'*(5-c)}

def wifi_signal_percent():
    # 1) NetworkManager WiFi scan/list: connected row is marked with "*".
    cmds = [
        ['bash','-lc',"nmcli -t -f IN-USE,SIGNAL dev wifi list ifname wlan0 2>/dev/null | awk -F: '$1==\"*\"{print $2; exit}'"],
        ['bash','-lc',"nmcli -t -f IN-USE,SIGNAL dev wifi 2>/dev/null | awk -F: '$1==\"*\"{print $2; exit}'"],
        ['bash','-lc',"nmcli -t -f ACTIVE,SIGNAL dev wifi 2>/dev/null | awk -F: '$1==\"yes\"{print $2; exit}'"],
    ]
    for cmd in cmds:
        r=run_cmd(cmd,4)
        if r['ok'] and r['stdout'].strip():
            try:
                return str(max(0,min(100,int(float(r['stdout'].strip())))))
            except Exception:
                pass

    # 2) iw link: signal is usually dBm. Convert roughly: -90 dBm = 0%, -40 dBm = 100%.
    r=run_cmd(['bash','-lc',"iw dev wlan0 link 2>/dev/null | awk '/signal:/ {print $2; exit}'"],4)
    if r['ok'] and r['stdout'].strip():
        try:
            dbm=float(r['stdout'].strip())
            return str(max(0,min(100,int((dbm + 90) * 2))))
        except Exception:
            pass

    # 3) /proc/net/wireless: link quality usually out of 70.
    try:
        for line in Path('/proc/net/wireless').read_text().splitlines():
            if line.strip().startswith('wlan0:'):
                parts=line.replace(':',' ').split()
                if len(parts) >= 3:
                    quality=float(parts[2].strip('.'))
                    if quality <= 70:
                        return str(max(0,min(100,int((quality / 70.0) * 100))))
                    return str(max(0,min(100,int(quality))))
    except Exception:
        pass

    # 4) iwconfig fallback if wireless-tools is installed.
    r=run_cmd(['bash','-lc',"iwconfig wlan0 2>/dev/null"],4)
    if r['ok'] and r['stdout']:
        m=re.search(r'Link Quality=([0-9.]+)/([0-9.]+)', r['stdout'])
        if m:
            try:
                return str(max(0,min(100,int((float(m.group(1))/float(m.group(2))) * 100))))
            except Exception:
                pass
        m=re.search(r'Signal level=(-?[0-9.]+) dBm', r['stdout'])
        if m:
            try:
                dbm=float(m.group(1))
                return str(max(0,min(100,int((dbm + 90) * 2))))
            except Exception:
                pass
    return ''

def parse_wifi_frequency_mhz(text):
    text = str(text or '')
    # iw dev wlan0 link usually reports: freq: 2437
    # iw dev wlan0 info may report: channel 1 (2412 MHz)
    patterns = [r'\bfreq:\s*([0-9.]+)', r'\(([0-9.]+)\s*MHz\)']
    for pat in patterns:
        m = re.search(pat, text, re.I)
        if m:
            try:
                return float(m.group(1))
            except Exception:
                pass
    return None

def classify_wifi_band(freq_mhz):
    try:
        f = float(freq_mhz)
    except Exception:
        return 'Unknown'
    if 850 <= f <= 1000:
        return '915 MHz HaLow'
    if 2400 <= f <= 2500:
        return '2.4 GHz WiFi'
    if 4900 <= f <= 5900:
        return '5.8 GHz WiFi'
    if 5900 < f <= 7200:
        return '6 GHz WiFi'
    return f'{int(round(f))} MHz'

def get_wifi_radio_info(dev='wlan0'):
    out = {'frequency_mhz': None, 'band': 'Unknown', 'note': ''}
    combined = []
    for cmd in (
        ['iw','dev',dev,'link'],
        ['iw','dev',dev,'info'],
    ):
        r = run_cmd(cmd, 3)
        if r.get('ok') and r.get('stdout'):
            combined.append(r['stdout'])
    text = '\n'.join(combined)
    freq = parse_wifi_frequency_mhz(text)
    if freq is not None:
        out['frequency_mhz'] = int(round(freq))
        out['band'] = classify_wifi_band(freq)
        return out
    # If wlan0 is a wireless interface but freq is unavailable, keep it explicit.
    if text:
        out['note'] = 'Wireless link detected, frequency unavailable from iw.'
    else:
        out['note'] = 'No wlan0 radio frequency reported. USB/Ethernet-style gateways may not expose 2.4/5 GHz vs HaLow.'
    return out

def get_wifi_info():
    info={'ssid':'','device':'wlan0','ip_address':'','subnet_mask':'','gateway':'','gateway_capability':{'status':'Unknown','note':'No gateway detected.','checked_ts':None},'radio_band':'Unknown','radio_frequency_mhz':None,'radio_note':'','signal_percent':None,'bars':{'count':None,'text':'Not connected'},'connected':False}
    r=run_cmd(['iwgetid','wlan0','-r'],4)
    if r['ok'] and r['stdout'].strip(): info['ssid']=r['stdout'].strip()
    else:
        r=run_cmd(['bash','-lc',"nmcli -t -f ACTIVE,SSID dev wifi | awk -F: '$1==\"yes\"{print $2; exit}'"],4)
        if r['ok'] and r['stdout'].strip(): info['ssid']=r['stdout'].strip()
    d=get_ipv4_details('wlan0')
    if d:
        info['ip_address']=d[0].get('address',''); info['subnet_mask']=d[0].get('netmask','')
    info['gateway']=get_gateway_for_dev('wlan0')
    radio=get_wifi_radio_info('wlan0')
    info['radio_band']=radio.get('band','Unknown')
    info['radio_frequency_mhz']=radio.get('frequency_mhz')
    info['radio_note']=radio.get('note','')
    info['gateway_capability']=probe_gateway_halow_capability(info.get('gateway',''), info.get('radio_band','Unknown'))

    # If wlan0 has no active SSID and no IPv4 address, show a clean disconnected state.
    info['connected']=bool(info.get('ssid') or info.get('ip_address'))
    if info['connected']:
        sig=wifi_signal_percent()
        try:
            if sig not in ('', None):
                info['signal_percent']=int(float(sig))
                info['bars']=bars_from_percent(info['signal_percent'])
            else:
                info['signal_percent']=None
                info['bars']={'count':None,'text':'unknown'}
        except Exception:
            info['signal_percent']=None
            info['bars']={'count':None,'text':'unknown'}
    else:
        info['signal_percent']=None
        info['bars']={'count':None,'text':'Not connected'}
    return info



def format_bits_per_sec(bps):
    try:
        bps = float(bps)
    except Exception:
        return "unknown"
    units = ["bps", "Kbps", "Mbps", "Gbps"]
    val = bps
    unit = units[0]
    for unit in units:
        if val < 1000 or unit == units[-1]:
            break
        val /= 1000.0
    if unit == "bps":
        return f"{int(round(val))} {unit}"
    return f"{val:.2f} {unit}"

def get_internet_route_info():
    """Return the actual interface Linux would use for internet egress.

    Prefer `ip route get` because it evaluates policy routing, route metrics,
    and the selected source address for a real internet destination. Fall back
    to the default route table when route-get is unavailable.
    """
    info = {"interface": "", "gateway": "", "src": "", "target": "", "raw": ""}
    for target in ("1.1.1.1", "8.8.8.8"):
        r = run_cmd(["ip", "route", "get", target], timeout=3)
        if r["ok"] and r["stdout"].strip():
            line = r["stdout"].splitlines()[0].strip()
            m_dev = re.search(r"\bdev\s+(\S+)", line)
            if m_dev:
                info["interface"] = m_dev.group(1)
                info["target"] = target
                info["raw"] = line
                m_via = re.search(r"\bvia\s+(\S+)", line)
                if m_via:
                    info["gateway"] = m_via.group(1)
                m_src = re.search(r"\bsrc\s+(\S+)", line)
                if m_src:
                    info["src"] = m_src.group(1)
                return info
    r = run_cmd(["ip", "route", "show", "default"], timeout=3)
    if r["ok"]:
        for line in r["stdout"].splitlines():
            m_dev = re.search(r"\bdev\s+(\S+)", line)
            if m_dev:
                info["interface"] = m_dev.group(1)
                info["raw"] = line.strip()
                m_via = re.search(r"\bvia\s+(\S+)", line)
                if m_via:
                    info["gateway"] = m_via.group(1)
                return info
    return info


def format_route_interface(route_info):
    # Visible Internet Source line should be interface-only (wwan0/wlan0/eth0/etc).
    # Full route details remain available under internet.route for diagnostics/API users.
    dev = (route_info or {}).get("interface") or ""
    return dev or "unknown"


def get_default_route_device():
    return get_internet_route_info().get("interface", "")

def read_interface_counters(dev):
    if not dev:
        return None
    base = Path("/sys/class/net") / dev / "statistics"
    try:
        rx = int((base / "rx_bytes").read_text().strip())
        tx = int((base / "tx_bytes").read_text().strip())
        return {"rx_bytes": rx, "tx_bytes": tx}
    except Exception:
        return None

def get_bandwidth_status(route_info=None):
    route_info = route_info or get_internet_route_info()
    dev = route_info.get("interface", "")
    counters = read_interface_counters(dev)
    now = time.time()
    if not dev or counters is None:
        return {
            "interface": dev or "unknown",
            "route_interface": format_route_interface(route_info),
            "route": route_info,
            "download_bps": None,
            "upload_bps": None,
            "download": "unknown",
            "upload": "unknown",
            "note": "Interface counters unavailable.",
        }

    last = load_json_file(NET_RATE_FILE, {})
    if not isinstance(last, dict):
        last = {}
    last_for_dev = last.get(dev, {}) if isinstance(last.get(dev, {}), dict) else {}
    dt = now - float(last_for_dev.get("ts", 0) or 0)
    rx_prev = last_for_dev.get("rx_bytes")
    tx_prev = last_for_dev.get("tx_bytes")

    last[dev] = {
        "ts": now,
        "rx_bytes": counters["rx_bytes"],
        "tx_bytes": counters["tx_bytes"],
    }
    atomic_write_json(NET_RATE_FILE, last)

    if rx_prev is None or tx_prev is None or dt < 1:
        return {
            "interface": dev,
            "route_interface": format_route_interface(route_info),
            "route": route_info,
            "download_bps": None,
            "upload_bps": None,
            "download": "measuring",
            "upload": "measuring",
            "note": "Passive rate from interface byte counters. Updates after the next refresh.",
        }

    rx_delta = counters["rx_bytes"] - int(rx_prev)
    tx_delta = counters["tx_bytes"] - int(tx_prev)
    if rx_delta < 0 or tx_delta < 0:
        return {
            "interface": dev,
            "route_interface": format_route_interface(route_info),
            "route": route_info,
            "download_bps": None,
            "upload_bps": None,
            "download": "measuring",
            "upload": "measuring",
            "note": "Counter reset detected. Measuring again.",
        }

    down_bps = (rx_delta * 8.0) / dt
    up_bps = (tx_delta * 8.0) / dt

    return {
        "interface": dev,
        "route_interface": format_route_interface(route_info),
        "route": route_info,
        "download_bps": round(down_bps),
        "upload_bps": round(up_bps),
        "download": format_bits_per_sec(down_bps),
        "upload": format_bits_per_sec(up_bps),
        "note": "Live passive throughput on the system internet route interface. This is current usage, not a maximum speed test.",
    }


def get_internet_status():
    p=run_cmd(['ping','-c','1','-W','2','8.8.8.8'],4)
    d=run_cmd(['getent','hosts','google.com'],5)
    state='UP' if p['ok'] and d['ok'] else 'IP ONLY / DNS FAIL' if p['ok'] else 'DOWN'
    route_info = get_internet_route_info()
    return {
        'state': state,
        'ping_ip': p['ok'],
        'dns_lookup': d['ok'],
        'dns_result': d['stdout'] if d['ok'] else d['stderr'],
        'route': route_info,
        'route_interface': format_route_interface(route_info),
        'bandwidth': get_bandwidth_status(route_info),
    }


def read_text_file(path):
    try:
        return Path(path).read_text().strip()
    except Exception:
        return ""

def percent_from_dbm(dbm, weak=-115, strong=-75):
    try:
        dbm = float(dbm)
        pct = int(round(((dbm - weak) / (strong - weak)) * 100))
        return max(0, min(100, pct))
    except Exception:
        return None

def first_qmi_device():
    try:
        devices = sorted(str(p) for p in Path("/dev").glob("cdc-wdm*"))
        return devices[0] if devices else ""
    except Exception:
        return ""

def parse_qmi_signal(text):
    result = {"percent": None, "dbm": None, "tech": ""}
    if not text:
        return result

    # Prefer LTE RSRP when available. Fall back to RSSI/current signal.
    patterns = [
        ("rsrp", r"RSRP:.*?(-?\d+(?:\.\d+)?)\s*dBm", -120, -80),
        ("rssi", r"RSSI:.*?(-?\d+(?:\.\d+)?)\s*dBm", -110, -50),
        ("current", r"Current:.*?(-?\d+(?:\.\d+)?)\s*dBm", -110, -50),
    ]
    for _name, pattern, weak, strong in patterns:
        m = re.search(pattern, text, re.I | re.S)
        if m:
            result["dbm"] = float(m.group(1))
            result["percent"] = percent_from_dbm(result["dbm"], weak, strong)
            break

    mtech = re.search(r"Network\s+'([^']+)'", text, re.I)
    if mtech:
        result["tech"] = mtech.group(1).upper()
    return result

def parse_qmi_tech_and_operator(*texts):
    tech = ""
    operator = ""
    combined = "\n".join(t for t in texts if t)

    if re.search(r"LTE\s+service:.*?Status:\s*'available'", combined, re.I | re.S):
        tech = "LTE"
    elif re.search(r"Radio interfaces:\s*'([^']+)'", combined, re.I):
        radios = re.findall(r"Radio interfaces:\s*'([^']+)'", combined, re.I)
        tech = ", ".join(r.upper() for r in radios)
    elif "LTE" in combined.upper():
        tech = "LTE"

    for pattern in [
        r"Operator name:\s*'([^']+)'",
        r"Description:\s*'([^']+)'",
        r"Network description:\s*'([^']+)'",
    ]:
        m = re.search(pattern, combined, re.I)
        if m:
            operator = m.group(1)
            break

    return tech, operator

def get_qmi_status(qmi_dev):
    q = {
        "device": qmi_dev or "",
        "qmi_available": False,
        "qmi_network_status": "",
        "signal_percent": None,
        "signal_dbm": None,
        "tech": "",
        "operator": "",
        "note": "",
    }
    if not qmi_dev:
        q["note"] = "No /dev/cdc-wdm* QMI device found."
        return q

    if not shutil.which("qmicli"):
        q["note"] = "qmicli not installed; using wwan0/sysfs only."
        return q

    q["qmi_available"] = True

    sig = run_cmd(["qmicli", "-d", qmi_dev, "--nas-get-signal-strength"], 7)
    sysinfo = run_cmd(["qmicli", "-d", qmi_dev, "--nas-get-system-info"], 7)
    serving = run_cmd(["qmicli", "-d", qmi_dev, "--nas-get-serving-system"], 7)
    home = run_cmd(["qmicli", "-d", qmi_dev, "--nas-get-home-network"], 7)

    if sig["ok"]:
        parsed = parse_qmi_signal(sig["stdout"])
        q["signal_percent"] = parsed.get("percent")
        q["signal_dbm"] = parsed.get("dbm")
        q["tech"] = parsed.get("tech") or ""

    tech, operator = parse_qmi_tech_and_operator(
        sysinfo["stdout"] if sysinfo["ok"] else "",
        serving["stdout"] if serving["ok"] else "",
        home["stdout"] if home["ok"] else "",
    )
    if tech:
        q["tech"] = tech
    q["operator"] = operator

    if shutil.which("qmi-network"):
        qnet = run_cmd(["qmi-network", qmi_dev, "status"], 5)
        if qnet["ok"]:
            q["qmi_network_status"] = " ".join(qnet["stdout"].split())
        else:
            q["qmi_network_status"] = qnet["stderr"] or ""

    notes = []
    if not sig["ok"]:
        notes.append("qmicli signal query failed")
    if not sysinfo["ok"] and not serving["ok"]:
        notes.append("qmicli registration query failed")
    q["note"] = "; ".join(notes)
    return q


LTE_AT_CACHE = {"ts": 0, "port": "", "data": {}}

TECH_MAP = {
    "0": "GSM",
    "1": "GSM COMPACT",
    "2": "UMTS",
    "3": "EDGE",
    "4": "HSDPA",
    "5": "HSUPA",
    "6": "HSPA",
    "7": "LTE",
    "8": "EC-GSM-IOT",
    "9": "LTE CAT-M1",
    "10": "NB-IOT",
}

def serial_at_command(port, command, timeout=1.4):
    fd = None
    old = None
    try:
        fd = os.open(port, os.O_RDWR | os.O_NOCTTY | os.O_NONBLOCK)
        old = termios.tcgetattr(fd)
        attrs = termios.tcgetattr(fd)
        attrs[0] = attrs[0] & ~(termios.IGNBRK | termios.BRKINT | termios.PARMRK | termios.ISTRIP | termios.INLCR | termios.IGNCR | termios.ICRNL | termios.IXON)
        attrs[1] = attrs[1] & ~termios.OPOST
        attrs[2] = attrs[2] | termios.CLOCAL | termios.CREAD
        attrs[2] = attrs[2] & ~(termios.PARENB | termios.PARODD | termios.CSTOPB | termios.CSIZE)
        attrs[2] = attrs[2] | termios.CS8
        attrs[3] = attrs[3] & ~(termios.ECHO | termios.ECHONL | termios.ICANON | termios.ISIG | termios.IEXTEN)
        attrs[4] = termios.B115200
        attrs[5] = termios.B115200
        attrs[6][termios.VMIN] = 0
        attrs[6][termios.VTIME] = 0
        termios.tcsetattr(fd, termios.TCSANOW, attrs)
        termios.tcflush(fd, termios.TCIOFLUSH)
        os.write(fd, (command.strip() + "\r").encode("ascii", "ignore"))
        chunks = []
        end = time.time() + timeout
        while time.time() < end:
            r, _, _ = select.select([fd], [], [], 0.12)
            if fd in r:
                try:
                    data = os.read(fd, 4096)
                except BlockingIOError:
                    data = b""
                if data:
                    chunks.append(data)
                    text = b"".join(chunks).decode("utf-8", "ignore")
                    upper = text.upper()
                    if "\nOK" in upper or "\rOK" in upper or "\nERROR" in upper or "\rERROR" in upper:
                        break
        return b"".join(chunks).decode("utf-8", "ignore")
    except Exception as e:
        return f"ERROR: {e}"
    finally:
        try:
            if fd is not None and old is not None:
                termios.tcsetattr(fd, termios.TCSANOW, old)
        except Exception:
            pass
        try:
            if fd is not None:
                os.close(fd)
        except Exception:
            pass

def list_serial_candidates():
    try:
        ports = sorted(str(p) for p in Path('/dev').glob('ttyUSB*')) + sorted(str(p) for p in Path('/dev').glob('ttyACM*'))
        return ports[:12]
    except Exception:
        return []

def find_at_port():
    cached = LTE_AT_CACHE.get('port') or ''
    candidates = ([cached] if cached else []) + [p for p in list_serial_candidates() if p != cached]
    for port in candidates:
        if not port:
            continue
        out = serial_at_command(port, 'AT', 0.8)
        if re.search(r'(^|\r|\n)OK(\r|\n|$)', out, re.I):
            LTE_AT_CACHE['port'] = port
            return port
    return ''

def parse_csq(text):
    m = re.search(r'\+CSQ:\s*(\d+)\s*,\s*(\d+)', text, re.I)
    if not m:
        return {}
    rssi = int(m.group(1))
    out = {'csq': rssi}
    if 0 <= rssi <= 31:
        dbm = -113 + (2 * rssi)
        out['signal_dbm'] = dbm
        out['signal_percent'] = max(0, min(100, round((rssi / 31) * 100)))
    return out

def parse_cesq(text):
    m = re.search(r'\+CESQ:\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)', text, re.I)
    if not m:
        return {}
    vals = [int(x) for x in m.groups()]
    rxlev, ber, rscp, ecno, rsrq, rsrp = vals
    out = {'cesq': vals}
    if 0 <= rsrp <= 97:
        # 3GPP TS 27.007: RSRP = -140 dBm + value, 255 unknown
        dbm = -140 + rsrp
        out['rsrp_dbm'] = dbm
        out['signal_dbm'] = dbm
        out['signal_percent'] = max(0, min(100, round((dbm + 120) * 2.5)))
    if 0 <= rsrq <= 34:
        out['rsrq_db'] = round(-19.5 + 0.5 * rsrq, 1)
    return out

def parse_cops(text):
    m = re.search(r'\+COPS:\s*(\d+)\s*,\s*(\d+)\s*,\s*"?([^",\r\n]*)"?\s*(?:,\s*(\d+))?', text, re.I)
    if not m:
        return {}
    operator = (m.group(3) or '').strip()
    tech_code = (m.group(4) or '').strip()
    return {'operator': operator, 'tech': TECH_MAP.get(tech_code, tech_code)}

def parse_registration(text):
    statuses = []
    for name in ('CREG', 'CGREG', 'CEREG'):
        m = re.search(r'\+' + name + r':\s*(?:\d+\s*,\s*)?(\d+)', text, re.I)
        if m:
            code = m.group(1)
            label = {'0':'not registered','1':'registered home','2':'searching','3':'denied','4':'unknown','5':'registered roaming'}.get(code, code)
            statuses.append(f"{name}={label}")
    return ', '.join(statuses)

def get_at_lte_status():
    now = time.time()
    if LTE_AT_CACHE.get('data') and now - LTE_AT_CACHE.get('ts', 0) < 30:
        return LTE_AT_CACHE['data']
    out = {'available': False, 'port': '', 'operator': '', 'tech': '', 'signal_percent': None, 'signal_dbm': None, 'bars': None, 'note': ''}
    ports = list_serial_candidates()
    if not ports:
        out['note'] = 'No /dev/ttyUSB* or /dev/ttyACM* AT ports found.'
        LTE_AT_CACHE.update({'ts': now, 'data': out})
        return out
    port = find_at_port()
    if not port:
        out['note'] = 'No responsive AT command port found; check dialout permissions or modem serial mode.'
        LTE_AT_CACHE.update({'ts': now, 'data': out})
        return out
    out['available'] = True
    out['port'] = port
    csq_txt = serial_at_command(port, 'AT+CSQ', 1.2)
    cesq_txt = serial_at_command(port, 'AT+CESQ', 1.2)
    cops_txt = serial_at_command(port, 'AT+COPS?', 1.6)
    reg_txt = '\n'.join([
        serial_at_command(port, 'AT+CREG?', 1.0),
        serial_at_command(port, 'AT+CGREG?', 1.0),
        serial_at_command(port, 'AT+CEREG?', 1.0),
    ])
    csq = parse_csq(csq_txt)
    cesq = parse_cesq(cesq_txt)
    cops = parse_cops(cops_txt)
    # Prefer LTE RSRP from CESQ if available; fall back to CSQ RSSI.
    sig = cesq if cesq.get('signal_percent') is not None else csq
    if sig.get('signal_percent') is not None:
        out['signal_percent'] = sig['signal_percent']
        out['bars'] = bars_from_percent(sig['signal_percent'])
    if sig.get('signal_dbm') is not None:
        out['signal_dbm'] = sig['signal_dbm']
    if cops.get('operator'):
        out['operator'] = cops['operator']
    if cops.get('tech'):
        out['tech'] = cops['tech']
    notes = [f"AT serial={port}"]
    if csq.get('signal_dbm') is not None:
        notes.append(f"CSQ={csq.get('csq')} ({csq.get('signal_dbm')} dBm)")
    if cesq.get('rsrp_dbm') is not None:
        notes.append(f"RSRP={cesq.get('rsrp_dbm')} dBm")
    if cesq.get('rsrq_db') is not None:
        notes.append(f"RSRQ={cesq.get('rsrq_db')} dB")
    reg = parse_registration(reg_txt)
    if reg:
        notes.append(reg)
    out['note'] = ' · '.join(notes)
    LTE_AT_CACHE.update({'ts': now, 'data': out})
    return out


def get_lte_status():
    l = {
        "available": False,
        "state": "unknown",
        "access_technology": "",
        "operator": "",
        "signal_quality_percent": None,
        "signal_dbm": None,
        "bars": {"count": None, "text": "unknown"},
        "modem": "",
        "note": "",
    }

    wwan_ips = get_ipv4s("wwan0")
    iface = get_interface_status("wwan0")
    default_dev = get_default_route_device()
    carrier = read_text_file("/sys/class/net/wwan0/carrier")
    operstate = read_text_file("/sys/class/net/wwan0/operstate") or iface.get("raw_operstate", "unknown")
    svc = run_cmd(["systemctl", "is-active", "4gmodem"], 3)
    service_state = svc["stdout"].strip() if svc["ok"] else "unknown"

    qmi_dev = first_qmi_device()
    qmi = get_qmi_status(qmi_dev)
    at = get_at_lte_status()

    l["modem"] = qmi_dev or at.get("port") or "wwan0"
    l["available"] = bool(wwan_ips or qmi_dev or at.get("available") or carrier == "1")

    if qmi.get("signal_percent") is not None:
        l["signal_quality_percent"] = qmi["signal_percent"]
        l["signal_dbm"] = qmi.get("signal_dbm")
        l["bars"] = bars_from_percent(qmi["signal_percent"])
    elif at.get("signal_percent") is not None:
        l["signal_quality_percent"] = at["signal_percent"]
        l["signal_dbm"] = at.get("signal_dbm")
        l["bars"] = at.get("bars") or bars_from_percent(at["signal_percent"])

    if qmi.get("tech"):
        l["access_technology"] = str(qmi["tech"]).upper()
    elif at.get("tech"):
        l["access_technology"] = str(at["tech"]).upper()

    if qmi.get("operator"):
        l["operator"] = qmi["operator"]
    elif at.get("operator"):
        l["operator"] = at["operator"]

    qnet = (qmi.get("qmi_network_status") or "").lower()

    # Display states intentionally ordered from most usable to least usable.
    # Keep these labels stable for the dashboard UI/status styling.
    if wwan_ips and default_dev == "wwan0":
        l["state"] = "Connected"
    elif wwan_ips:
        l["state"] = "Connected (not default route)"
    elif "connected" in qnet or "started" in qnet:
        l["state"] = "Modem Connected"
    elif service_state == "active":
        l["state"] = "No IP/Default Route"
    elif carrier == "1":
        l["state"] = "Link Detected"
    elif qmi_dev or at.get("available"):
        l["state"] = "Modem Detected"
    elif iface.get("operstate") and iface.get("operstate") != "down":
        l["state"] = "Up/Dormant"
    else:
        l["state"] = "Not Detected"

    note_parts = [
        "Source: wwan0/sysfs + qmicli/qmi-network + AT serial fallback; ModemManager not used.",
        f"wwan0={operstate}",
        f"4gmodem={service_state}",
    ]
    if default_dev:
        note_parts.append(f"default route={default_dev}")
    if wwan_ips:
        note_parts.append("IPv4 present")
    if qmi.get("signal_dbm") is not None:
        note_parts.append(f"qmi signal={qmi['signal_dbm']} dBm")
    if qmi.get("qmi_network_status"):
        note_parts.append(f"qmi-network={qmi['qmi_network_status']}")
    if qmi.get("note"):
        note_parts.append(qmi["note"])
    if at.get("note"):
        note_parts.append(at["note"])

    l["note"] = ""
    return l

def get_service_status(svc):
    r=run_cmd(['systemctl','show',svc,'--no-pager','--property=LoadState,ActiveState,SubState,UnitFileState'],5)
    s={'name':svc,'load':'unknown','active':'unknown','sub':'unknown','enabled':'unknown'}
    if r['ok']:
        for line in r['stdout'].splitlines():
            if '=' in line:
                k,v=line.split('=',1)
                if k=='LoadState': s['load']=v
                elif k=='ActiveState': s['active']=v
                elif k=='SubState': s['sub']=v
                elif k=='UnitFileState': s['enabled']=v
    else: s.update({'load':'not-found','sub':r['stderr']})
    return s

def get_services(): return {s:get_service_status(s) for s in effective_services()}

def read_cpu_temp_c():
    for p in ['/sys/class/thermal/thermal_zone0/temp','/sys/class/hwmon/hwmon0/temp1_input']:
        try:
            v=float(Path(p).read_text().strip()); return round(v/1000 if v>1000 else v,1)
        except Exception: pass
    return None

def load_json_file(p,default):
    try: return json.loads(p.read_text())
    except Exception: return default

def sanitize_temp_history(raw, now=None, write_back=False):
    """Return only valid CPU temperature history samples.

    Older builds could leave malformed values in temp_history.json. One bad
    string/dict entry must never crash /api/status, because nginx reports that
    backend disconnect as HTTP 502. Keep the valid samples, discard anything
    malformed, and optionally write the repaired list back to disk.
    """
    now = float(now if now is not None else time.time())
    cutoff = now - 86400
    repaired = []
    if not isinstance(raw, list):
        raw = []
    for item in raw:
        if not isinstance(item, dict):
            continue
        ts = item.get('ts', item.get('time', item.get('timestamp')))
        temp = item.get('temp_c', item.get('temp', item.get('temperature')))
        try:
            ts = float(ts)
            temp = float(temp)
        except Exception:
            continue
        if not (math.isfinite(ts) and math.isfinite(temp)):
            continue
        if ts < cutoff:
            continue
        if temp < -40 or temp > 150:
            continue
        repaired.append({'ts': ts, 'temp_c': round(temp, 1)})
    repaired.sort(key=lambda x: x.get('ts', 0))
    if len(repaired) > 2000:
        repaired = repaired[-2000:]
    if write_back:
        try:
            atomic_write_json(TEMP_HISTORY_FILE, repaired)
        except Exception:
            pass
    return repaired

def json_safe(obj, seen=None, depth=0):
    """Return a JSON-serializable copy and break circular references.

    Some TAK Map send diagnostics include nested attempt/result objects. A circular
    reference here crashes json.dumps(), which causes the browser to receive an
    HTML traceback instead of JSON. Keep diagnostics useful, but always safe.
    """
    if seen is None:
        seen=set()
    if depth > 20:
        return '...truncated...'
    if obj is None or isinstance(obj, (str, int, float, bool)):
        return obj
    if isinstance(obj, (datetime, date)):
        try:
            return obj.isoformat()
        except Exception:
            return str(obj)
    if isinstance(obj, Path):
        return str(obj)
    if isinstance(obj, bytes):
        return obj[:256].decode('utf-8','replace')
    oid=id(obj)
    if oid in seen:
        return '[circular]'
    if isinstance(obj, dict):
        seen.add(oid)
        out={}
        for k,v in obj.items():
            try:
                key=str(k)
            except Exception:
                key='key'
            out[key]=json_safe(v, seen, depth+1)
        seen.discard(oid)
        return out
    if isinstance(obj, (list, tuple, set)):
        seen.add(oid)
        out=[json_safe(v, seen, depth+1) for v in list(obj)[:1000]]
        if len(obj) > 1000:
            out.append('...truncated...')
        seen.discard(oid)
        return out
    try:
        json.dumps(obj)
        return obj
    except Exception:
        return str(obj)

def atomic_write_json(p,data):
    DATA_DIR.mkdir(parents=True,exist_ok=True); tmp=p.with_suffix('.tmp'); tmp.write_text(json.dumps(json_safe(data))); tmp.replace(p)

def temp_sampler_loop():
    while True:
        try:
            t=read_cpu_temp_c(); now=time.time()
            if t is not None:
                h=sanitize_temp_history(load_json_file(TEMP_HISTORY_FILE,[]), now)
                h.append({'ts':now,'temp_c':t})
                h=sanitize_temp_history(h, now)
                atomic_write_json(TEMP_HISTORY_FILE,h)
        except Exception:
            pass
        time.sleep(60)

def read_cpu_freq_mhz():
    paths = [
        "/sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq",
        "/sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_cur_freq",
    ]
    for path in paths:
        try:
            raw = Path(path).read_text().strip()
            khz = float(raw)
            return round(khz / 1000.0)
        except Exception:
            pass
    return None


def get_cpu_info():
    current = read_cpu_temp_c()
    now = time.time()
    hist_raw = load_json_file(TEMP_HISTORY_FILE, [])
    recent = sanitize_temp_history(hist_raw, now, write_back=True)
    temps = [float(x["temp_c"]) for x in recent if isinstance(x, dict) and x.get("temp_c") is not None]

    high = max(temps, default=current)
    low = min(temps, default=current)
    avg = round(sum(temps) / len(temps), 1) if temps else current

    # Track when the 24h high occurred. If multiple samples share the same
    # highest value, use the most recent sample so the dashboard shows the
    # latest occurrence of that high temperature.
    high_ts = None
    if recent and high is not None:
        high_entries = [x for x in recent if x.get("temp_c") is not None and float(x.get("temp_c")) == float(high)]
        if high_entries:
            high_ts = max(float(x.get("ts", 0)) for x in high_entries)

    return {
        "current_c": current,
        "highest_24h_c": high,
        "highest_24h_ts": high_ts,
        "lowest_24h_c": low,
        "average_24h_c": avg,
        "samples_24h": len(recent),
        "frequency_mhz": read_cpu_freq_mhz(),
        "note": "24h stats begin collecting after dashboard installation/start.",
    }


def ping_zt_device(d):
    r=run_cmd(['ping','-n','-c','1','-W','1',d['ip']],3); lat=''
    if r['ok']:
        m=re.search(r'time=([0-9.]+)\s*ms',r['stdout']); lat=m.group(1) if m else ''
    return {'ip':d['ip'],'callsign':d['callsign'],'online':r['ok'],'status':'ONLINE' if r['ok'] else 'OFFLINE','latency_ms':lat}

def get_zerotier_connectivity():
    devices = effective_zerotier_devices()
    if not devices:
        return []
    last=load_json_file(ZT_LAST_ACTIVE_FILE,{}) if isinstance(load_json_file(ZT_LAST_ACTIVE_FILE,{}),dict) else {}; now=int(time.time()); byip={}
    with ThreadPoolExecutor(max_workers=min(8,len(devices))) as ex:
        fmap={ex.submit(ping_zt_device,d):d for d in devices}
        for fut in as_completed(fmap):
            d=fmap[fut]
            try: item=fut.result()
            except Exception as e: item={'ip':d['ip'],'callsign':d.get('callsign',d['ip']),'online':False,'status':'ERROR','latency_ms':'','error':str(e)}
            if item['online']: last[item['ip']]=now
            item['last_active_ts']=last.get(item['ip']); byip[item['ip']]=item
    atomic_write_json(ZT_LAST_ACTIVE_FILE,last)
    return [byip.get(d['ip'],{'ip':d['ip'],'callsign':d.get('callsign',d['ip']),'status':'UNKNOWN','latency_ms':'','last_active_ts':last.get(d['ip'])}) for d in devices]

def format_duration(sec):
    try: sec=int(sec)
    except Exception: return 'unknown'
    d,rem=divmod(sec,86400); h,rem=divmod(rem,3600); m,_=divmod(rem,60)
    return f'{d}d {h}h {m}m' if d else f'{h}h {m}m' if h else f'{m}m'

def parse_throttled(raw):
    try: val=int(raw.strip().split('=')[-1],16)
    except Exception: return {'raw':raw.strip() if raw else '','value':None,'status':'unknown','flags':['unable to parse']}
    meanings=[(0,'currently under-voltage'),(1,'currently frequency capped'),(2,'currently throttled'),(3,'currently soft temperature limit active'),(16,'under-voltage has occurred'),(17,'frequency capping has occurred'),(18,'throttling has occurred'),(19,'soft temperature limit has occurred')]
    flags=[label for bit,label in meanings if val & (1<<bit)]
    return {'raw':raw.strip(),'value':val,'status':'OK' if val==0 else 'CHECK','flags':flags if flags else ['none']}

def get_system_health():
    h={}
    try:
        up=float(Path('/proc/uptime').read_text().split()[0]); h['uptime']=format_duration(up); h['boot_time']=datetime.fromtimestamp(time.time()-up).strftime('%Y-%m-%d %H:%M:%S')
    except Exception: h['uptime']='unknown'; h['boot_time']='unknown'
    try: la=os.getloadavg(); h['load_average']=[round(float(la[0]),1), round(float(la[1]),1), round(float(la[2]),1)]
    except Exception: h['load_average']=[]
    mem={}
    try:
        for line in Path('/proc/meminfo').read_text().splitlines():
            if ':' in line:
                k,v=line.split(':',1); parts=v.strip().split()
                if parts and parts[0].isdigit(): mem[k]=int(parts[0])
    except Exception: pass
    if mem.get('MemTotal') and mem.get('MemAvailable') is not None:
        used=mem['MemTotal']-mem['MemAvailable']; pct=used/mem['MemTotal']*100; h['ram']={'text':f'{round(used/1024)} / {round(mem["MemTotal"]/1024)} MB ({pct:.1f}%)'}
    else: h['ram']={'text':'unknown'}
    try:
        du=shutil.disk_usage('/'); pct=du.used/du.total*100; h['disk']={'text':f'{du.used/(1024**3):.1f} / {du.total/(1024**3):.1f} GB ({pct:.1f}%)','used_percent':round(pct,1),'used_gb':round(du.used/(1024**3),1),'total_gb':round(du.total/(1024**3),1)}
    except Exception: h['disk']={'text':'unknown','used_percent':None}
    vc=run_cmd(['vcgencmd','get_throttled'],3); h['throttling']=parse_throttled(vc['stdout']) if vc['ok'] else {'raw':'','value':None,'status':'unknown','flags':['vcgencmd unavailable']}
    return h

def read_sysfs_power():
    base=Path('/sys/class/power_supply'); out=[]
    if not base.exists(): return out
    for s in sorted(base.iterdir()):
        item={'name':s.name}
        for k in ['type','status','capacity','voltage_now','current_now','power_now','energy_now','charge_now']:
            try: item[k]=(s/k).read_text().strip()
            except Exception: pass
        try:
            if 'voltage_now' in item: item['voltage_v']=round(float(item['voltage_now'])/1_000_000,2)
        except Exception: pass
        try:
            if 'current_now' in item: item['current_a']=round(float(item['current_now'])/1_000_000,2)
        except Exception: pass
        out.append(item)
    return out

def i2c_byte(bus,addr,reg):
    r=run_cmd(['i2cget','-y',str(bus),hex(addr),hex(reg),'b'],3)
    if not r['ok']: raise RuntimeError(r['stderr'] or r['stdout'] or 'i2cget failed')
    return int(r['stdout'].strip(),16)

def read_fuel_gauge():
    bus=int(os.environ.get('TAK_DASHBOARD_I2C_BUS','1')); addr=int(os.environ.get('TAK_DASHBOARD_FUEL_GAUGE_ADDR','0x36'),16)
    v=((i2c_byte(bus,addr,0x02)<<8)|i2c_byte(bus,addr,0x03))>>4
    soc=i2c_byte(bus,addr,0x04)+(i2c_byte(bus,addr,0x05)/256.0)
    return {'source':f'i2c bus {bus}, address 0x{addr:02x}','voltage_v':round(v*0.00125,3),'percent':round(soc,1)}


def read_hwmon_power_sensors():
    sensors = []
    try:
        for h in sorted(Path('/sys/class/hwmon').glob('hwmon*')):
            item = {'path': str(h), 'name': read_text_file(str(h / 'name')) or h.name}
            currents = []
            powers = []
            volts = []
            for p in h.glob('curr*_input'):
                try:
                    currents.append(float(p.read_text().strip()) / 1000.0)  # hwmon current is mA
                except Exception:
                    pass
            for p in h.glob('power*_input'):
                try:
                    powers.append(float(p.read_text().strip()) / 1000000.0)  # hwmon power is uW
                except Exception:
                    pass
            for p in h.glob('in*_input'):
                try:
                    volts.append(float(p.read_text().strip()) / 1000.0)  # hwmon voltage is mV
                except Exception:
                    pass
            if currents:
                item['current_a'] = round(max(currents), 3)
            if powers:
                item['power_w'] = round(max(powers), 3)
            # Only use voltage if it looks like a realistic supply/battery/input voltage.
            good_volts = [v for v in volts if 3.0 <= v <= 30.0]
            if good_volts:
                item['voltage_v'] = round(max(good_volts), 3)
            if 'current_a' in item or 'power_w' in item or 'voltage_v' in item:
                sensors.append(item)
    except Exception:
        pass
    return sensors

def read_vcgencmd_power():
    """Best-effort Raspberry Pi PMIC/input voltage reader.

    Raspberry Pi 5 exposes useful input rail values through:
      vcgencmd pmic_read_adc

    Different OS/firmware builds have slightly different spacing/labels, so this
    parser is intentionally loose and returns diagnostics even when it cannot
    parse a voltage. Voltage-only detection is useful here because many Pi power
    paths expose EXT5V/VBUS/BATT voltage but not input current.
    """
    out = {
        'current_a': None,
        'voltage_v': None,
        'power_w': None,
        'source': '',
        'note': '',
        'raw_stdout': '',
        'raw_stderr': '',
        'rc': None,
    }

    vcg = shutil.which('vcgencmd')
    for candidate in ('/usr/bin/vcgencmd', '/usr/local/bin/vcgencmd', '/opt/vc/bin/vcgencmd'):
        if not vcg and Path(candidate).exists():
            vcg = candidate
    if not vcg:
        out['note'] = 'vcgencmd not found'
        return out

    r = run_cmd([vcg, 'pmic_read_adc'], 8)
    out['rc'] = r.get('rc')
    out['raw_stdout'] = (r.get('stdout') or '')[:4000]
    out['raw_stderr'] = (r.get('stderr') or '')[:1000]
    stdout_preview = ' | '.join((r.get('stdout') or '').splitlines())[:700]
    stderr_preview = ' | '.join((r.get('stderr') or '').splitlines())[:400]
    if not r.get('ok') or not r.get('stdout'):
        out['note'] = (f"pmic_read_adc rc={r.get('rc')} stdout_len={len(r.get('stdout') or '')} "
                       f"stderr_len={len(r.get('stderr') or '')} stdout_preview={stdout_preview!r} stderr_preview={stderr_preview!r}")
        return out

    currents = []
    volts = []
    current_by_base = {}
    volt_by_base = {}

    def base_label(label):
        b = re.sub(r'_(A|V)$', '', label or '', flags=re.I)
        b = re.sub(r'_(CURRENT|VOLT|VOLTAGE)$', '', b, flags=re.I)
        return b.upper()

    # Example lines seen on Pi 5:
    #   EXT5V_V volt(24)=5.095000V
    #   3V3_SYS_A current(1)=0.126000A
    line_re = re.compile(r'^\s*([^\s:]+)\s+(current|volt)\s*\(\d+\)\s*=\s*([+-]?\d+(?:\.\d+)?)\s*([A-Za-z]+)?', re.I)
    for line in (r.get('stdout') or '').splitlines():
        m = line_re.search(line.strip())
        if not m:
            continue
        label, kind, value, unit = m.groups()
        try:
            val = float(value)
        except Exception:
            continue
        b = base_label(label)
        if kind.lower() == 'current':
            if 0 <= val <= 20:
                currents.append((label, b, val))
                current_by_base[b] = val
        else:
            if 0.5 <= val <= 30:
                volts.append((label, b, val))
                volt_by_base[b] = val

    def voltage_priority(item):
        label, b, v = item
        name = f'{label} {b}'.upper()
        # Prefer actual input/battery rails over internal 3.3/1.8/core rails.
        if re.search(r'(EXT5V|VBUS|USB|VIN|VSYS|V_SYS|5V_IN|INPUT)', name):
            return (100, v)
        if re.search(r'(BATT|BATTERY|VBAT|BAT)', name):
            return (90, v)
        if re.search(r'(^|_)5V($|_)', name) or 4.5 <= v <= 5.6:
            return (80, v)
        if re.search(r'(3V3_SYS|3V3|3\.3)', name):
            return (30, v)
        return (10, v)

    selected_voltage = None
    if volts:
        selected_voltage = sorted(volts, key=voltage_priority, reverse=True)[0]
        label, b, val = selected_voltage
        out['voltage_v'] = round(val, 3)
        out['source'] = f'vcgencmd pmic_read_adc ({label})'

    # Board rail estimate: sum rails where both current and voltage are exposed.
    rail_watts = []
    for b, cur in current_by_base.items():
        if b in volt_by_base:
            try:
                rail_watts.append(cur * volt_by_base[b])
            except Exception:
                pass
    if rail_watts:
        out['power_w'] = round(sum(rail_watts), 2)

    # If selected rail has a matched current, expose that current too.
    if selected_voltage:
        label, b, val = selected_voltage
        if b in current_by_base:
            out['current_a'] = round(current_by_base[b], 3)
            out['power_w'] = round(current_by_base[b] * val, 2)

    raw_preview = '; '.join((r.get('stdout') or '').splitlines()[:6])
    parsed_note = f"pmic_read_adc rc={r.get('rc')} parsed_voltages={len(volts)} parsed_currents={len(currents)}"
    if selected_voltage:
        parsed_note += f" selected_voltage={selected_voltage[0]}={selected_voltage[2]}V"
    if out.get('power_w') is not None:
        parsed_note += f" estimated_rail_power={out['power_w']}W"
    parsed_note += f" raw_preview={raw_preview[:500]}"
    out['note'] = parsed_note
    return out
def estimate_runtime_hours(percent=None, power_w=None):
    try:
        battery_wh = float(os.environ.get('TAK_DASHBOARD_BATTERY_WH', '0') or 0)
    except Exception:
        battery_wh = 0
    if battery_wh > 0 and percent is not None and power_w and power_w > 0:
        return (battery_wh * (float(percent) / 100.0)) / float(power_w)
    return None

def format_runtime_hours(hours):
    if hours is None:
        return ''
    try:
        h = float(hours)
        if h < 0:
            return ''
        if h < 1:
            return f"{round(h*60)} min"
        return f"{int(h)}h {round((h-int(h))*60)}m"
    except Exception:
        return ''


def read_float_file(path, scale=1.0):
    try:
        txt = Path(path).read_text().strip()
        if not txt:
            return None
        return float(txt) * float(scale)
    except Exception:
        return None


def read_env_power_overrides():
    """Optional override hooks for custom UPS/BMS integrations.

    Example file overrides:
      TAK_DASH_POWER_VOLTAGE_FILE=/path/to/voltage_now_microvolts
      TAK_DASH_POWER_VOLTAGE_SCALE=0.000001
      TAK_DASH_POWER_PERCENT_FILE=/path/to/capacity

    Example direct/static overrides:
      TAK_DASH_POWER_VOLTAGE_V=12.8
      TAK_DASH_POWER_PERCENT=87
      TAK_DASH_POWER_CURRENT_A=1.4
      TAK_DASH_POWER_WATTS=18
      TAK_DASH_POWER_SOURCE='External battery / UPS'
    """
    item = {'source': os.environ.get('TAK_DASH_POWER_SOURCE', 'env override').strip() or 'env override'}
    vfile = os.environ.get('TAK_DASH_POWER_VOLTAGE_FILE', '').strip()
    pfile = os.environ.get('TAK_DASH_POWER_PERCENT_FILE', '').strip()
    cfile = os.environ.get('TAK_DASH_POWER_CURRENT_FILE', '').strip()
    wfile = os.environ.get('TAK_DASH_POWER_WATTS_FILE', '').strip()
    try:
        vscale = float(os.environ.get('TAK_DASH_POWER_VOLTAGE_SCALE', '1') or 1)
    except Exception:
        vscale = 1.0
    try:
        cscale = float(os.environ.get('TAK_DASH_POWER_CURRENT_SCALE', '1') or 1)
    except Exception:
        cscale = 1.0
    try:
        wscale = float(os.environ.get('TAK_DASH_POWER_WATTS_SCALE', '1') or 1)
    except Exception:
        wscale = 1.0
    def env_float(name):
        raw = os.environ.get(name, '').strip()
        if not raw:
            return None
        try:
            return float(raw)
        except Exception:
            return None

    v = env_float('TAK_DASH_POWER_VOLTAGE_V')
    pct = env_float('TAK_DASH_POWER_PERCENT')
    cur = env_float('TAK_DASH_POWER_CURRENT_A')
    watts = env_float('TAK_DASH_POWER_WATTS')

    if v is None:
        v = read_float_file(vfile, vscale) if vfile else None
    if pct is None:
        pct = read_float_file(pfile, 1.0) if pfile else None
    if cur is None:
        cur = read_float_file(cfile, cscale) if cfile else None
    if watts is None:
        watts = read_float_file(wfile, wscale) if wfile else None
    if v is not None and 0.5 <= v <= 80:
        item['voltage_v'] = round(v, 3)
    if pct is not None and 0 <= pct <= 100:
        item['percent'] = round(pct, 1)
    if cur is not None:
        item['current_a'] = round(cur, 3)
    if watts is not None:
        item['power_w'] = round(watts, 3)
    return item if any(k in item for k in ('voltage_v','percent','current_a','power_w')) else None


def read_iio_power_sensors():
    """Read generic voltage/current sensors from Linux IIO when present.

    Some UPS/BMS HATs expose ADC channels through /sys/bus/iio instead of
    /sys/class/power_supply or hwmon. This is best-effort and conservative:
    it only reports realistic supply/battery voltages.
    """
    sensors = []
    try:
        for dev in sorted(Path('/sys/bus/iio/devices').glob('iio:device*')):
            name = read_text_file(str(dev / 'name')) or dev.name
            item = {'path': str(dev), 'name': name}
            volts = []
            currents = []
            # Some drivers expose already-scaled millivolt inputs.
            for inp in dev.glob('in_voltage*_input'):
                try:
                    volts.append(float(inp.read_text().strip()) / 1000.0)
                except Exception:
                    pass
            # Common IIO raw + scale pattern.
            for raw in dev.glob('in_voltage*_raw'):
                stem = raw.name[:-4]  # remove _raw
                try:
                    rv = float(raw.read_text().strip())
                    scale_path = dev / f'{stem}_scale'
                    scale = float(scale_path.read_text().strip()) if scale_path.exists() else 1.0
                    # IIO voltage scale is commonly mV per bit, so convert mV to V.
                    volts.append((rv * scale) / 1000.0)
                except Exception:
                    pass
            for inp in dev.glob('in_current*_input'):
                try:
                    currents.append(float(inp.read_text().strip()) / 1000.0)
                except Exception:
                    pass
            good_volts = [v for v in volts if 3.0 <= v <= 30.0]
            if good_volts:
                item['voltage_v'] = round(max(good_volts), 3)
            if currents:
                item['current_a'] = round(max(currents), 3)
            if 'voltage_v' in item or 'current_a' in item:
                sensors.append(item)
    except Exception:
        pass
    return sensors


def choose_sensor_with_voltage(sensors):
    if not sensors:
        return None
    def score(item):
        name = f"{item.get('name','')} {item.get('path','')}".lower()
        val = 0
        if item.get('voltage_v') is not None: val += 50
        if item.get('current_a') is not None: val += 20
        if item.get('power_w') is not None: val += 20
        if re.search(r'(battery|bms|ups|max17|max170|ina|ina2|ina219|ina226|pmic|power|usb|vbus|vin|supply)', name): val += 20
        if re.search(r'(core|cpu|soc|gpu|dram|temp|thermal)', name): val -= 40
        return val
    return sorted(sensors, key=score, reverse=True)[0]


def classify_power_source_by_voltage(voltage):
    try:
        v = float(voltage)
    except Exception:
        return 'unknown'
    return 'Wall/USB Powerbank' if v >= 4.05 else 'Lithium Battery'

def apply_power_source_label(p):
    p['source'] = classify_power_source_by_voltage(p.get('battery_voltage_v'))
    p['details'] = ''
    return p

def get_power_runtime():
    p={'available':False,'status':'unknown','source':'unknown','battery_percent':None,'battery_voltage_v':None,'current_a':None,'power_w':None,'runtime_estimate':'','details':'','supplies':[],'current_source':'','power_attempts':[]}
    attempts = p['power_attempts']

    override = read_env_power_overrides()
    if override:
        attempts.append({'method':'env override','ok':True,'note':str(override)})
        p['available'] = True
        p['status'] = 'Power Source Detected'
        p['source'] = override.get('source','env override')
        p['battery_percent'] = override.get('percent')
        p['battery_voltage_v'] = override.get('voltage_v')
        p['current_a'] = override.get('current_a')
        p['power_w'] = override.get('power_w')
        if p.get('power_w') is None and p.get('current_a') is not None and p.get('battery_voltage_v') is not None:
            try: p['power_w'] = round(float(p['current_a']) * float(p['battery_voltage_v']), 2)
            except Exception: pass
        p['runtime_estimate'] = format_runtime_hours(estimate_runtime_hours(p.get('battery_percent'), p.get('power_w')))
        return apply_power_source_label(p)

    supplies=read_sysfs_power(); p['supplies']=supplies
    attempts.append({'method':'sysfs power_supply','ok':bool(supplies),'note':f"{len(supplies)} supplies found"})
    # Prefer true batteries/UPS devices, but also accept any supply that exposes a usable voltage.
    candidates=[]
    for s in supplies:
        typ=s.get('type','').lower(); name=s.get('name','').lower()
        is_bat = typ in ('battery','ups') or 'bat' in name
        has_data = s.get('capacity') is not None or s.get('voltage_v') is not None or s.get('current_a') is not None or s.get('power_now') is not None
        if is_bat or has_data:
            score = (100 if is_bat else 0) + (20 if s.get('capacity') is not None else 0) + (15 if s.get('voltage_v') is not None else 0) + (10 if s.get('current_a') is not None else 0)
            candidates.append((score,s))
    if candidates:
        s=max(candidates,key=lambda x:x[0])[1]
        p.update({'available':True,'source':f"/sys/class/power_supply/{s.get('name')}",'status':s.get('status','Power Source Detected'),'details':'Read from Linux power_supply interface.'})
        if s.get('capacity'):
            try: p['battery_percent']=round(float(s['capacity']),1)
            except Exception: pass
        p['battery_voltage_v']=s.get('voltage_v')
        p['current_a']=s.get('current_a')
        if p['current_a'] is not None:
            p['current_source']=p['source']
        try:
            if s.get('power_now'):
                p['power_w']=round(float(s['power_now'])/1_000_000,2)
            elif p['current_a'] is not None and p['battery_voltage_v'] is not None:
                p['power_w']=round(float(p['current_a'])*float(p['battery_voltage_v']),2)
        except Exception:
            pass
        try:
            if s.get('energy_now') and s.get('power_now') and float(s['power_now']) > 0:
                hours=float(s['energy_now'])/float(s['power_now'])
                p['runtime_estimate']=format_runtime_hours(hours)
        except Exception:
            pass
        if not p['runtime_estimate']:
            p['runtime_estimate']=format_runtime_hours(estimate_runtime_hours(p['battery_percent'], p.get('power_w')))
        attempts.append({'method':'sysfs selected','ok':True,'note':f"selected {s.get('name')} type={s.get('type','unknown')} voltage={s.get('voltage_v')} percent={p.get('battery_percent')}"})
        return apply_power_source_label(p)

    try:
        fg=read_fuel_gauge()
        attempts.append({'method':'i2c fuel gauge','ok':True,'note':fg.get('source','')})
        p.update({'available':True,'source':fg['source'],'status':'Power Source Detected','battery_percent':fg['percent'],'battery_voltage_v':fg['voltage_v']})
        details=['Stats in this card are for an I2C fuel gauge if present.']
    except Exception as e:
        attempts.append({'method':'i2c fuel gauge','ok':False,'note':str(e)})
        details=[f'No standard power_supply battery found and I2C fuel gauge read failed: {e}']

    hw = read_hwmon_power_sensors()
    attempts.append({'method':'hwmon','ok':bool(hw),'note':f"{len(hw)} usable sensors found"})
    chosen = choose_sensor_with_voltage(hw)
    if chosen:
        p['available'] = True
        p['status'] = 'Power Source Detected'
        p['current_a'] = chosen.get('current_a')
        p['power_w'] = chosen.get('power_w')
        p['current_source'] = f"hwmon {chosen.get('name')}"
        p['source'] = p['current_source']
        if chosen.get('voltage_v') is not None:
            p['battery_voltage_v'] = chosen.get('voltage_v')
        details.append(f"Current/power/voltage from {p['current_source']}.")
    else:
        iio = read_iio_power_sensors()
        attempts.append({'method':'iio','ok':bool(iio),'note':f"{len(iio)} usable sensors found"})
        ichosen = choose_sensor_with_voltage(iio)
        if ichosen:
            p['available'] = True
            p['status'] = 'Power Source Detected'
            p['source'] = f"iio {ichosen.get('name')}"
            p['current_a'] = ichosen.get('current_a')
            p['current_source'] = p['source'] if p['current_a'] is not None else ''
            if ichosen.get('voltage_v') is not None:
                p['battery_voltage_v'] = ichosen.get('voltage_v')
            details.append(f"Voltage/current from {p['source']}.")
        else:
            vcg = read_vcgencmd_power()
            attempts.append({'method':'vcgencmd pmic_read_adc','ok':bool(vcg.get('current_a') is not None or vcg.get('voltage_v') is not None),'note':vcg.get('note') or str(vcg)})
            if vcg.get('current_a') is not None:
                p['available'] = True
                p['status'] = 'Power Source Detected'
                p['current_a'] = vcg.get('current_a')
                p['current_source'] = vcg.get('source') or 'vcgencmd pmic_read_adc'
                p['source'] = p['current_source']
                details.append(f"Current from {p['current_source']}.")
            if vcg.get('power_w') is not None:
                p['power_w'] = vcg.get('power_w')
            if p.get('battery_voltage_v') is None and vcg.get('voltage_v') is not None:
                p['available'] = True
                p['status'] = 'Power Source Detected'
                p['battery_voltage_v'] = vcg.get('voltage_v')
                p['source'] = vcg.get('source') or 'vcgencmd pmic_read_adc'

    if p.get('power_w') is None and p.get('current_a') is not None and p.get('battery_voltage_v') is not None:
        try:
            p['power_w'] = round(float(p['current_a']) * float(p['battery_voltage_v']), 2)
        except Exception:
            pass

    p['runtime_estimate'] = format_runtime_hours(estimate_runtime_hours(p.get('battery_percent'), p.get('power_w')))
    if p['runtime_estimate']:
        details.append('Runtime estimate uses TAK_DASHBOARD_BATTERY_WH and measured/estimated power draw.')
    elif p.get('current_a') is None:
        pass
    else:
        details.append('Current found, but runtime needs TAK_DASHBOARD_BATTERY_WH to estimate remaining time.')
    p['details']='; '.join([d for d in details if d])
    return apply_power_source_label(p)


def clean_host_for_ping(value):
    if not value:
        return ""
    m = re.search(r"(\d{1,3}(?:\.\d{1,3}){3})", str(value))
    return m.group(1) if m else str(value).strip()

def get_default_gateway():
    r = run_cmd(["ip", "route", "show", "default"], 3)
    if not r["ok"]:
        return {"gateway": "", "dev": ""}
    for line in r["stdout"].splitlines():
        m_gateway = re.search(r"\bvia\s+(\S+)", line)
        m_dev = re.search(r"\bdev\s+(\S+)", line)
        if m_gateway or m_dev:
            return {
                "gateway": m_gateway.group(1) if m_gateway else "",
                "dev": m_dev.group(1) if m_dev else "",
            }
    return {"gateway": "", "dev": ""}

def ping_latency_target(item):
    host = clean_host_for_ping(item.get("host", ""))
    if not host:
        return {
            "name": item.get("name", "unknown"),
            "host": item.get("host_label", ""),
            "status": item.get("empty_status", "UNKNOWN"),
            "latency_ms": "",
            "note": item.get("note", "No host available"),
        }
    r = run_cmd(["ping", "-n", "-c", "1", "-W", "1", host], 3)
    latency = ""
    if r["ok"]:
        m = re.search(r"time=([0-9.]+)\s*ms", r["stdout"])
        latency = m.group(1) if m else ""
    return {
        "name": item.get("name", host),
        "host": item.get("host_label", host),
        "status": "ONLINE" if r["ok"] else "OFFLINE",
        "latency_ms": latency,
        "note": item.get("note", ""),
    }

def get_local_zerotier_ips():
    local = set()
    try:
        for p in Path("/sys/class/net").iterdir():
            if p.name.startswith("zt"):
                for addr in get_ipv4s(p.name):
                    ip = str(addr).split("/")[0].strip()
                    if ip:
                        local.add(ip)
    except Exception:
        pass
    return local

def get_zerotier_fastest_latency():
    devices = effective_zerotier_devices()
    local_ips = get_local_zerotier_ips()

    candidates = []
    for d in devices:
        ip = d.get("ip", "")
        if not ip or ip in local_ips:
            continue
        candidates.append(d)

    if not candidates:
        return {
            "name": "ZeroTier",
            "host": "",
            "status": "No clients available",
            "latency_ms": "",
            "note": "No ZeroTier peers configured.",
        }

    results = []
    with ThreadPoolExecutor(max_workers=min(8, len(candidates))) as ex:
        fmap = {ex.submit(ping_latency_target, {
            "name": "ZeroTier",
            "host": d.get("ip", ""),
            "host_label": d.get("ip", ""),
            "note": d.get("callsign", ""),
        }): d for d in candidates}
        for fut in as_completed(fmap):
            d = fmap[fut]
            try:
                item = fut.result()
            except Exception:
                item = {
                    "name": "ZeroTier",
                    "host": d.get("ip", ""),
                    "status": "ERROR",
                    "latency_ms": "",
                    "note": d.get("callsign", ""),
                }
            item["callsign"] = d.get("callsign", "")
            results.append(item)

    online = []
    for item in results:
        try:
            if item.get("status") == "ONLINE" and item.get("latency_ms") not in ("", None):
                online.append((float(item["latency_ms"]), item))
        except Exception:
            pass

    if not online:
        return {
            "name": "ZeroTier",
            "host": "",
            "status": "No clients available",
            "latency_ms": "",
            "note": "No configured ZeroTier peer responded.",
        }

    best_latency, best = sorted(online, key=lambda x: x[0])[0]
    note = f"Fastest client: {best.get('callsign') or best.get('host')}"
    return {
        "name": "ZeroTier",
        "host": best.get("host", ""),
        "status": "ONLINE",
        "latency_ms": best.get("latency_ms", ""),
        "note": note,
    }

    candidates = []
    for d in ZEROTIER_DEVICES:
        ip = d.get("ip", "")
        if not ip or ip in local_ips:
            continue
        candidates.append(d)

    if not candidates:
        return {
            "name": "ZeroTier",
            "host": "",
            "status": "No clients available",
            "latency_ms": "",
            "note": "No other ZeroTier devices are configured or local device could not be separated.",
        }

    results = []
    with ThreadPoolExecutor(max_workers=min(8, len(candidates))) as ex:
        fmap = {ex.submit(ping_latency_target, {
            "name": "ZeroTier",
            "host": d.get("ip", ""),
            "host_label": d.get("ip", ""),
            "note": d.get("callsign", ""),
        }): d for d in candidates}
        for fut in as_completed(fmap):
            d = fmap[fut]
            try:
                item = fut.result()
            except Exception:
                item = {
                    "name": "ZeroTier",
                    "host": d.get("ip", ""),
                    "status": "ERROR",
                    "latency_ms": "",
                    "note": d.get("callsign", ""),
                }
            item["callsign"] = d.get("callsign", "")
            results.append(item)

    online = []
    for item in results:
        try:
            if item.get("status") == "ONLINE" and item.get("latency_ms") not in ("", None):
                online.append((float(item["latency_ms"]), item))
        except Exception:
            pass

    if not online:
        return {
            "name": "ZeroTier",
            "host": "",
            "status": "No clients available",
            "latency_ms": "",
            "note": "No other ZeroTier client responded.",
        }

    best_latency, best = sorted(online, key=lambda x: x[0])[0]
    note = f"Fastest client: {best.get('callsign') or best.get('host')}"
    return {
        "name": "ZeroTier",
        "host": best.get("host", ""),
        "status": "ONLINE",
        "latency_ms": best.get("latency_ms", ""),
        "note": note,
    }

def get_network_latency():
    rows = []

    rows.append(ping_latency_target({
        "name": "Internet",
        "host": os.environ.get("TAK_DASHBOARD_INTERNET_PING_TARGET", "1.1.1.1"),
        "note": "Public ping target.",
    }))

    wifi_gateway = clean_host_for_ping(get_gateway_for_dev("wlan0"))
    if wifi_gateway:
        rows.append(ping_latency_target({
            "name": "WiFi",
            "host": wifi_gateway,
            "note": "Gateway ping of current WiFi network.",
        }))
    else:
        rows.append({
            "name": "WiFi",
            "host": "",
            "status": "DISCONNECTED",
            "latency_ms": "",
            "note": "No wlan0 gateway detected.",
        })

    if HALOW_SSID_PREFIX:
        wifi = get_wifi_info()
        ssid = wifi.get("ssid", "") or ""
        if ssid.startswith(HALOW_SSID_PREFIX):
            halow_gateway = clean_host_for_ping(wifi.get("gateway") or get_gateway_for_dev("wlan0"))
            if halow_gateway:
                rows.append(ping_latency_target({
                    "name": "HaLow",
                    "host": halow_gateway,
                    "note": "Gateway ping if connected to configured HaLow/WiFi mesh SSID.",
                }))
            else:
                rows.append({
                    "name": "HaLow",
                    "host": "",
                    "status": "DISCONNECTED",
                    "latency_ms": "",
                    "note": "Configured HaLow/WiFi mesh SSID detected, but no gateway was found.",
                })
        else:
            rows.append({
                "name": "HaLow",
                "host": "",
                "status": "DISCONNECTED",
                "latency_ms": "",
                "note": "Set TAK_DASHBOARD_HALOW_SSID_PREFIX to monitor a HaLow/WiFi mesh SSID.",
            })

    rows.append(get_zerotier_fastest_latency())
    return rows


def usb_glob(pattern):
    try:
        return sorted(str(p) for p in Path("/dev").glob(pattern))
    except Exception:
        return []

def get_usb_storage_devices():
    r = run_cmd(["lsblk", "-ndo", "NAME,TRAN,TYPE,SIZE,MODEL"], 4)
    if not r["ok"]:
        return []
    devices = []
    for line in r["stdout"].splitlines():
        parts = line.split(None, 4)
        if len(parts) >= 3 and parts[1] == "usb":
            devices.append(line.strip())
    return devices

def summarize_lsusb(lines, max_items=5):
    if not lines:
        return "none"
    shown = lines[:max_items]
    extra = len(lines) - len(shown)
    text = " | ".join(shown)
    if extra > 0:
        text += f" | +{extra} more"
    return text

def get_usb_device_status():
    ls = run_cmd(["lsusb"], 4)
    usb_lines = ls["stdout"].splitlines() if ls["ok"] and ls["stdout"] else []

    qmi = usb_glob("cdc-wdm*")
    serial = usb_glob("ttyUSB*") + usb_glob("ttyACM*")
    hidraw = usb_glob("hidraw*")
    storage = get_usb_storage_devices()

    sdr_lines = [
        line for line in usb_lines
        if re.search(r"(RTL283|RTL2838|Realtek|NooElec|DVB-T|R820T|SDR)", line, re.I)
    ]
    modem_lines = [
        line for line in usb_lines
        if re.search(r"(Telit|Sierra|Quectel|Qualcomm|Fibocom|SIMCom|Novatel|Huawei|LTE|Modem)", line, re.I)
    ]

    rows = [
        {
            "device": "QMI modem",
            "status": "DETECTED" if qmi else "NOT FOUND",
            "details": ", ".join(qmi) if qmi else "No /dev/cdc-wdm* device found",
        },
        {
            "device": "4G/LTE USB modem",
            "status": "DETECTED" if modem_lines else "UNKNOWN",
            "details": summarize_lsusb(modem_lines) if modem_lines else "No obvious modem match in lsusb",
        },
        {
            "device": "RTL-SDR / ADS-B",
            "status": "DETECTED" if sdr_lines else "NOT FOUND",
            "details": summarize_lsusb(sdr_lines) if sdr_lines else "No RTL-SDR / ADS-B receiver match in lsusb",
        },
        {
            "device": "USB serial",
            "status": "DETECTED" if serial else "NOT FOUND",
            "details": ", ".join(serial) if serial else "No /dev/ttyUSB* or /dev/ttyACM* devices found",
        },
        {
            "device": "USB storage",
            "status": "DETECTED" if storage else "NOT FOUND",
            "details": " | ".join(storage) if storage else "No USB storage devices shown by lsblk",
        },
        {
            "device": "USB bus",
            "status": f"{len(usb_lines)} DEVICE(S)" if usb_lines else "UNKNOWN",
            "details": summarize_lsusb(usb_lines),
        },
    ]

    rows = [r for r in rows if r.get("device") not in ("QMI modem", "USB serial")]
    return rows



def get_dir_size_bytes(path):
    try:
        path = Path(path)
        if not path.exists():
            return 0
        total = 0
        for p in path.rglob("*"):
            try:
                if p.is_file():
                    total += p.stat().st_size
            except Exception:
                pass
        return total
    except Exception:
        return 0

def get_diagnostics_status():
    size_bytes = get_dir_size_bytes(DIAG_DIR)
    try:
        file_count = sum(1 for p in Path(DIAG_DIR).glob("*") if p.is_file())
    except Exception:
        file_count = 0
    return {"folder": str(DIAG_DIR), "size_bytes": size_bytes, "size_mb": round(size_bytes / (1024 * 1024), 2), "file_count": file_count}

def clear_diagnostics_folder():
    removed = 0
    freed = 0
    try:
        DIAG_DIR.mkdir(parents=True, exist_ok=True)
        for p in DIAG_DIR.iterdir():
            try:
                if p.is_file() or p.is_symlink():
                    try: freed += p.stat().st_size
                    except Exception: pass
                    p.unlink()
                    removed += 1
                elif p.is_dir():
                    freed += get_dir_size_bytes(p)
                    shutil.rmtree(p)
                    removed += 1
            except Exception:
                pass
        return True, f"Cleared {removed} diagnostics item(s), freed {round(freed/(1024*1024),2)} MB."
    except Exception as e:
        return False, f"Failed to clear diagnostics: {e}"

def prune_command_history(items):
    now = time.time()
    cutoff = now - (5 * 86400)
    out = []
    if isinstance(items, list):
        for item in items:
            try:
                ts = float(item.get('ts', 0))
            except Exception:
                ts = 0
            if ts >= cutoff:
                out.append(item)
    return out

def load_command_history():
    hist = prune_command_history(load_json_file(COMMAND_HISTORY_FILE, []))
    try:
        atomic_write_json(COMMAND_HISTORY_FILE, hist)
    except Exception:
        pass
    return hist

def append_command_history(entry):
    hist = load_command_history()
    hist.append(entry)
    hist = prune_command_history(hist)
    atomic_write_json(COMMAND_HISTORY_FILE, hist)
    return hist

def grouped_command_history():
    grouped = {}
    for item in load_command_history():
        day = item.get('date') or datetime.fromtimestamp(float(item.get('ts', 0) or 0)).strftime('%Y-%m-%d')
        grouped.setdefault(day, []).append(item)
    return dict(sorted(grouped.items(), reverse=True))

def run_remote_command(command_id):
    cid = str(command_id or '').strip()
    commands = {c.get('id'): c for c in effective_custom_commands()}
    c = commands.get(cid)
    if not c:
        return {'ok': False, 'rc': 2, 'stderr': 'Command button not found', 'stdout': '', 'command': '', 'label': ''}
    cmd = sanitize_command_text(c.get('command'))
    label = sanitize_command_label(c.get('label'))
    timeout = 90
    try:
        timeout = int(os.environ.get('TAK_DASHBOARD_COMMAND_TIMEOUT', '90') or 90)
    except Exception:
        timeout = 90
    timeout = max(5, min(timeout, 600))
    started = time.time()
    try:
        if is_default_command_id(cid):
            # Built-in/default commands run through the installed root helper.
            # This avoids raw sudo password prompts from the non-interactive dashboard service.
            helper_cmd = ['sudo', '-n', '/usr/local/sbin/tak-map-action', 'remote-default', cid]
            p = subprocess.run(helper_cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=timeout, check=False)
        else:
            p = subprocess.run(cmd, shell=True, executable='/bin/bash', stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True, timeout=timeout, check=False)
        stderr = (p.stderr or '').strip()
        if is_default_command_id(cid) and p.returncode != 0 and 'password' in stderr.lower() and 'sudo' in stderr.lower():
            stderr += '\n\nThe dashboard sudo helper is not configured for non-interactive default commands. Re-run sudo ./install.sh from the latest package to refresh /etc/sudoers.d/tak-server-dash.'
        res = {'ok': p.returncode == 0, 'rc': p.returncode, 'stdout': (p.stdout or '').strip()[-50000:], 'stderr': stderr[-50000:]}
    except subprocess.TimeoutExpired as e:
        res = {'ok': False, 'rc': 124, 'stdout': ((e.stdout or '') if isinstance(e.stdout, str) else '').strip()[-50000:], 'stderr': f'Command timed out after {timeout}s'}
    except Exception as e:
        res = {'ok': False, 'rc': 1, 'stdout': '', 'stderr': str(e)}
    finished = time.time()
    entry = {
        'ts': int(finished),
        'date': datetime.fromtimestamp(finished).strftime('%Y-%m-%d'),
        'time': datetime.fromtimestamp(finished).strftime('%H:%M:%S'),
        'label': label,
        'command': cmd,
        'rc': res.get('rc'),
        'ok': bool(res.get('ok')),
        'duration_sec': round(finished - started, 2),
        'stdout': res.get('stdout', ''),
        'stderr': res.get('stderr', ''),
    }
    append_command_history(entry)
    res.update({'command': cmd, 'label': label, 'history': grouped_command_history()})
    return res

def command_history_zip_bytes():
    grouped = grouped_command_history()
    bio = io.BytesIO()
    with zipfile.ZipFile(bio, 'w', zipfile.ZIP_DEFLATED) as zf:
        if not grouped:
            zf.writestr('no-command-history.txt', 'No command history available.\n')
        for day, entries in grouped.items():
            lines = []
            lines.append(f'TAK Server Dash command history: {day}')
            lines.append('')
            for item in entries:
                lines.append('=' * 72)
                lines.append(f"Time: {item.get('time', '')}")
                lines.append(f"Label: {item.get('label', '')}")
                lines.append(f"Command: {item.get('command', '')}")
                lines.append(f"Result: {'OK' if item.get('ok') else 'FAILED'}  RC: {item.get('rc', '')}  Duration: {item.get('duration_sec', '')}s")
                lines.append('')
                lines.append('STDOUT:')
                lines.append(item.get('stdout') or '')
                lines.append('')
                lines.append('STDERR:')
                lines.append(item.get('stderr') or '')
                lines.append('')
            zf.writestr(f'command-history-{day}.txt', '\n'.join(lines) + '\n')
    return bio.getvalue()


def sanitize_linux_username(value):
    value = str(value or '').strip()
    if not re.match(r'^[A-Za-z_][A-Za-z0-9_.-]{0,63}$', value):
        return ''
    return value

def sanitize_ots_username(value):
    value=str(value or '').strip()[:180]
    # OpenTAKServer can use usernames or email addresses. Keep this conservative
    # but less restrictive than a Linux account name.
    if not re.match(r'^[A-Za-z0-9_.@+-]{1,180}$', value):
        return ''
    return value

def safe_upload_filename(name):
    name = os.path.basename(str(name or '').replace('\\', '/'))
    name = name.replace('\x00', '')
    name = re.sub(r'[^A-Za-z0-9_.()@#+,-]+', '_', name).strip(' .')
    if not name:
        name = 'upload.bin'
    return name[:180]

def get_user_home(username):
    username = sanitize_linux_username(username)
    if not username:
        return None
    try:
        info = pwd.getpwnam(username)
        home = Path(info.pw_dir).resolve()
        return home
    except Exception:
        return None


def _dashboard_admin_groups():
    raw = os.environ.get('TAK_DASH_ADMIN_GROUPS', 'sudo,adm,wheel,admin')
    groups = []
    for item in re.split(r'[,\s]+', raw or ''):
        item = item.strip()
        if item and re.match(r'^[A-Za-z0-9_.@-]{1,80}$', item) and item not in groups:
            groups.append(item)
    return groups or ['sudo']


def is_dashboard_admin_user(username):
    """Return (ok, message, groups) for local Pi/Linux admin membership.

    Raspberry Pi OS admin accounts are normally members of the `sudo` group,
    but some builds/users rely on `adm`. Use multiple methods to resolve
    supplementary groups because Python's grp.getgrall() can be incomplete on
    some systems/NSS setups.
    """
    username = sanitize_linux_username(username)
    if not username:
        return False, 'Invalid username.', []
    try:
        pw = pwd.getpwnam(username)
    except Exception:
        return False, 'Server account was not found.', []

    wanted = set(_dashboard_admin_groups())
    user_groups = set()

    # Primary group from the passwd entry.
    try:
        primary = grp.getgrgid(pw.pw_gid).gr_name
        if primary:
            user_groups.add(primary)
    except Exception:
        pass

    # Supplementary groups from Python's group database.
    try:
        for g in grp.getgrall():
            if username in (g.gr_mem or []):
                user_groups.add(g.gr_name)
    except Exception:
        pass

    # Supplementary groups from the system `id` command. This is more reliable
    # on Raspberry Pi OS and NSS-backed systems than grp.getgrall() alone.
    try:
        r = subprocess.run(['id', '-nG', username], text=True, capture_output=True, timeout=5)
        if r.returncode == 0:
            for item in re.split(r'\s+', r.stdout.strip()):
                if item:
                    user_groups.add(item)
    except Exception:
        pass

    # Fallback to `groups USERNAME` if needed. Output may be "user : g1 g2".
    try:
        r = subprocess.run(['groups', username], text=True, capture_output=True, timeout=5)
        if r.returncode == 0:
            out = r.stdout.strip()
            if ':' in out:
                out = out.split(':', 1)[1]
            for item in re.split(r'\s+', out.strip()):
                if item:
                    user_groups.add(item)
    except Exception:
        pass

    matched = sorted(wanted.intersection(user_groups))
    if matched:
        return True, 'Admin group membership confirmed: ' + ', '.join(matched), sorted(user_groups)

    detected = ', '.join(sorted(user_groups)) if user_groups else 'none detected'
    allowed = ', '.join(sorted(wanted))
    return False, f'Dashboard access requires a local Pi OS admin account. Allowed admin groups: {allowed}. Detected groups for this user: {detected}.', sorted(user_groups)

def _configured_pam_services():
    raw = os.environ.get('TAK_DASH_PAM_SERVICE', 'tak-server-dash,sshd,login')
    services = []
    for item in re.split(r'[,\s]+', raw):
        item = item.strip()
        if item and re.match(r'^[A-Za-z0-9_.@-]{1,80}$', item) and item not in services:
            services.append(item)
    return services or ['tak-server-dash', 'sshd', 'login']


def authenticate_linux_user(username, password):
    username = sanitize_linux_username(username)
    password = str(password or '')
    if not username or not password:
        return False, 'Username and password are required.', None
    home = get_user_home(username)
    if not home:
        return False, 'Server account was not found.', None

    # Preferred path: run the PAM check through the root-owned dashboard
    # action helper. On many Debian/Raspberry Pi OS systems, pam_unix uses
    # unix_chkpwd and will reject arbitrary account checks from an unprivileged
    # service user. The helper receives the password on stdin, never as a
    # command-line argument, and prints only JSON.
    helper = '/usr/local/sbin/tak-map-action'
    try:
        proc = subprocess.run(
            ['sudo', helper, 'auth-user', username],
            input=password,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=20,
            check=False,
        )
        out = (proc.stdout or '').strip()
        if out:
            try:
                data = json.loads(out.splitlines()[-1])
                if data.get('ok'):
                    helper_home = data.get('home') or str(home)
                    return True, 'Authenticated.', helper_home
                helper_error = data.get('error') or 'PAM helper rejected login.'
            except Exception:
                helper_error = out[-300:]
        else:
            helper_error = (proc.stderr or '').strip()[-300:] or 'PAM helper did not return output.'
    except Exception as e:
        helper_error = str(e)

    # Fallback path for systems where the dashboard service user can perform
    # PAM checks directly. Keep this so custom deployments still work even if
    # sudo/helper auth is unavailable.
    # Debian/Raspberry Pi OS variants may expose either a modern `pam`
    # module or the older `PAM` module. Try both, and try a dashboard-specific
    # PAM service first so web login is not blocked by tty/login-oriented rules.
    module_found = False
    services = _configured_pam_services()

    try:
        import pam as pam_mod
        module_found = True
        for service in services:
            try:
                p = pam_mod.pam()
                if bool(p.authenticate(username, password, service=service)):
                    return True, 'Authenticated.', str(home)
            except TypeError:
                try:
                    if bool(pam_mod.authenticate(username, password)):
                        return True, 'Authenticated.', str(home)
                except Exception:
                    pass
            except Exception:
                pass
    except Exception:
        pass

    try:
        import PAM
        module_found = True

        def pam_conv_factory(secret):
            def pam_conv(auth, query_list, user_data):
                responses = []
                for query, query_type in query_list:
                    if query_type in (PAM.PAM_PROMPT_ECHO_ON, PAM.PAM_PROMPT_ECHO_OFF):
                        responses.append((secret, 0))
                    elif query_type == PAM.PAM_ERROR_MSG:
                        responses.append(('', 0))
                    elif query_type == PAM.PAM_TEXT_INFO:
                        responses.append(('', 0))
                    else:
                        responses.append(('', 0))
                return responses
            return pam_conv

        for service in services:
            try:
                auth = PAM.pam()
                auth.start(service)
                auth.set_item(PAM.PAM_USER, username)
                auth.set_item(PAM.PAM_CONV, pam_conv_factory(password))
                auth.authenticate()
                try:
                    auth.acct_mgmt()
                except Exception:
                    # Some minimal PAM service definitions may not include all account
                    # modules. Successful password authentication is enough for this
                    # upload-unlock use case.
                    pass
                return True, 'Authenticated.', str(home)
            except Exception:
                pass
    except Exception:
        pass

    if not module_found:
        return False, 'No usable Python PAM module found. Install python3-pam.', None
    return False, 'Login failed. PAM helper/direct PAM check did not accept the credentials. Last helper result: ' + (helper_error or 'unknown'), None

def cleanup_upload_sessions():
    now = time.time()
    with UPLOAD_SESSIONS_LOCK:
        expired = [tok for tok, sess in UPLOAD_SESSIONS.items() if sess.get('expires', 0) < now]
        for tok in expired:
            UPLOAD_SESSIONS.pop(tok, None)

def create_upload_session(username, home):
    cleanup_upload_sessions()
    token = secrets.token_urlsafe(32)
    with UPLOAD_SESSIONS_LOCK:
        UPLOAD_SESSIONS[token] = {'username': username, 'home': home, 'expires': time.time() + UPLOAD_SESSION_TTL_SECONDS}
    return token

def get_upload_session(token):
    cleanup_upload_sessions()
    token = str(token or '').strip()
    with UPLOAD_SESSIONS_LOCK:
        sess = UPLOAD_SESSIONS.get(token)
        if not sess:
            return None
        # sliding refresh while the upload section is actively used
        sess['expires'] = time.time() + UPLOAD_SESSION_TTL_SECONDS
        return dict(sess)

def cleanup_dashboard_sessions():
    now = time.time()
    with DASH_SESSIONS_LOCK:
        expired = [tok for tok, sess in DASH_SESSIONS.items() if sess.get('expires', 0) < now]
        for tok in expired:
            DASH_SESSIONS.pop(tok, None)

def create_dashboard_session(username, home):
    cleanup_dashboard_sessions()
    token = secrets.token_urlsafe(32)
    with DASH_SESSIONS_LOCK:
        DASH_SESSIONS[token] = {'username': username, 'home': str(home or ''), 'created': time.time(), 'expires': time.time() + DASH_SESSION_TTL_SECONDS}
    return token

def get_dashboard_session(token):
    cleanup_dashboard_sessions()
    token = str(token or '').strip()
    with DASH_SESSIONS_LOCK:
        sess = DASH_SESSIONS.get(token)
        if not sess:
            return None
        return dict(sess)

def destroy_dashboard_session(token):
    token = str(token or '').strip()
    if not token:
        return
    with DASH_SESSIONS_LOCK:
        DASH_SESSIONS.pop(token, None)

def cleanup_tak_map_sessions():
    now = time.time()
    with TAK_MAP_SESSIONS_LOCK:
        expired = [tok for tok, sess in TAK_MAP_SESSIONS.items() if sess.get('expires', 0) < now]
        for tok in expired:
            TAK_MAP_SESSIONS.pop(tok, None)

def create_tak_map_session(username, password=''):
    cleanup_tak_map_sessions()
    token = secrets.token_urlsafe(32)
    with TAK_MAP_SESSIONS_LOCK:
        # Store the OTS admin password only in memory for this TAK Map session so
        # the dashboard can call narrow OTS admin APIs such as Scheduler modify/run.
        # It is not persisted to disk and expires with the TAK Map session.
        TAK_MAP_SESSIONS[token] = {'username': username, 'password': str(password or ''), 'created': time.time(), 'expires': time.time() + TAK_MAP_SESSION_TTL_SECONDS}
    return token

def get_tak_map_session(token):
    cleanup_tak_map_sessions()
    token = str(token or '').strip()
    with TAK_MAP_SESSIONS_LOCK:
        sess = TAK_MAP_SESSIONS.get(token)
        if not sess:
            return None
        return dict(sess)

def destroy_tak_map_session(token):
    token = str(token or '').strip()
    if not token:
        return
    with TAK_MAP_SESSIONS_LOCK:
        TAK_MAP_SESSIONS.pop(token, None)

def _safe_equal_password(password, candidate):
    return bool(candidate) and secrets.compare_digest(str(password or ''), str(candidate or ''))

def _check_stdlib_werkzeug_hash(stored_hash, password):
    """Verify common Werkzeug hashes without requiring Werkzeug in system Python."""
    stored_hash = str(stored_hash or '')
    password = str(password or '')
    if not stored_hash or not password or '$' not in stored_hash:
        return False
    try:
        method, salt, hashval = stored_hash.split('$', 2)
        if method.startswith('pbkdf2:'):
            parts = method.split(':')
            if len(parts) < 3:
                return False
            hash_name = parts[1].replace('-', '')
            iterations = int(parts[2])
            derived = hashlib.pbkdf2_hmac(hash_name, password.encode(), salt.encode(), iterations)
            expected = bytes.fromhex(hashval)
            return secrets.compare_digest(derived, expected)
        if method.startswith('scrypt:'):
            parts = method.split(':')
            if len(parts) < 4:
                return False
            n, r, pp = int(parts[1]), int(parts[2]), int(parts[3])
            derived = hashlib.scrypt(password.encode(), salt=salt.encode(), n=n, r=r, p=pp)
            expected = bytes.fromhex(hashval)
            return secrets.compare_digest(derived, expected)
    except Exception:
        return False
    return False

def _ots_password_candidates(password):
    """Return raw + Flask-Security salted-HMAC password candidates.

    OpenTAKServer uses Flask-Security/Flask-Security-Too style password
    handling. In that stack the value stored in the database may be a Passlib
    hash of get_hmac(password), not a direct hash of password. SECURITY_PASSWORD_SALT
    from config.yml is therefore required for verification. Never log these
    values.
    """
    password=str(password or '')
    out=[]
    def add(v):
        v=str(v or '')
        if v and v not in out:
            out.append(v)
    add(password)
    salts=[]
    for name in ('SECURITY_PASSWORD_SALT','TAK_DASH_OTS_SECURITY_PASSWORD_SALT'):
        val=os.environ.get(name,'').strip()
        if val:
            salts.append(val)
    try:
        cfg, _errors = _load_ots_config_values()
        val=str(cfg.get('SECURITY_PASSWORD_SALT','') or '').strip()
        if val:
            salts.append(val)
    except Exception:
        pass
    for salt in salts:
        try:
            # Flask-Security's get_hmac(password) returns a Base64-encoded
            # HMAC-SHA512 digest, not a hex digest. Keep hex as a legacy
            # fallback, but prefer the Base64 candidate for OpenTAKServer.
            hm=hmac.new(str(salt).encode('utf-8'), password.encode('utf-8'), hashlib.sha512)
            add(base64.b64encode(hm.digest()).decode('ascii'))
            add(hm.hexdigest())
        except Exception:
            pass
    return out

def _check_werkzeug_password_hash(stored_hash, password):
    stored_hash = str(stored_hash or '')
    if not stored_hash or not password:
        return False
    for candidate in _ots_password_candidates(password):
        if _check_stdlib_werkzeug_hash(stored_hash, candidate):
            return True
        try:
            from werkzeug.security import check_password_hash
            if check_password_hash(stored_hash, candidate):
                return True
        except Exception:
            pass
        try:
            from passlib.hash import bcrypt, pbkdf2_sha256, pbkdf2_sha512, sha256_crypt, sha512_crypt, argon2
            for h in (bcrypt, pbkdf2_sha256, pbkdf2_sha512, sha256_crypt, sha512_crypt, argon2):
                try:
                    if h.verify(candidate, stored_hash):
                        return True
                except Exception:
                    pass
        except Exception:
            pass
    return False


def _candidate_ots_venv_python_paths():
    """Return likely OpenTAKServer virtualenv Python interpreters.

    OpenTAKServer may store Flask-Security/Passlib password hashes that the
    dashboard system Python cannot verify. When available, we ask the OTS venv
    Python to verify the hash using the same libraries OpenTAKServer uses.
    """
    paths=[]
    for name in ('TAK_DASH_OTS_PYTHON','TAK_DASH_OTS_VENV_PYTHON'):
        val=os.environ.get(name,'').strip()
        if val:
            paths.append(Path(val).expanduser())
    try:
        res=subprocess.run(['systemctl','show','-p','ExecStart','--value','opentakserver'], capture_output=True, text=True, timeout=3)
        exec_line=(res.stdout or '').strip()
        for m in re.finditer(r'(/[^\s;]+/(?:bin/)?opentakserver)(?:\s|$)', exec_line):
            exe=Path(m.group(1))
            if exe.name == 'opentakserver' and exe.parent.name == 'bin':
                paths.append(exe.parent/'python3')
                paths.append(exe.parent/'python')
    except Exception:
        pass
    try:
        res=subprocess.run(['systemctl','show','-p','WorkingDirectory','--value','opentakserver'], capture_output=True, text=True, timeout=3)
        wd=(res.stdout or '').strip()
        if wd and wd not in ('/','n/a'):
            owner=Path(wd).expanduser().parts[2] if str(wd).startswith('/home/') and len(Path(wd).parts) > 2 else ''
            if owner:
                paths.append(Path('/home')/owner/'.opentakserver_venv/bin/python3')
                paths.append(Path('/home')/owner/'.opentakserver_venv/bin/python')
    except Exception:
        pass
    try:
        home_root=Path('/home')
        if home_root.exists():
            for home in sorted(home_root.iterdir()):
                if home.is_dir():
                    paths.append(home/'.opentakserver_venv/bin/python3')
                    paths.append(home/'.opentakserver_venv/bin/python')
    except Exception:
        pass
    for pth in (Path('/opt/opentakserver/venv/bin/python3'), Path('/opt/opentakserver/venv/bin/python')):
        paths.append(pth)
    out=[]; seen=set()
    for path in paths:
        try:
            rp=path.resolve()
        except Exception:
            rp=path
        if str(rp) in seen:
            continue
        seen.add(str(rp))
        try:
            if path.exists() and os.access(str(path), os.X_OK):
                out.append(path)
        except Exception:
            pass
    return out

def _check_ots_venv_password_hash(stored_hash, password):
    """Verify an OTS password hash using the OpenTAKServer venv libraries.

    This is needed for Flask-Security/Passlib hashes that the dashboard system
    Python cannot verify. Password and hash are passed to the helper through
    stdin JSON, never argv, so they do not appear in process listings. Both
    raw password and Flask-Security SECURITY_PASSWORD_SALT HMAC candidates are
    tested.
    """
    stored_hash=str(stored_hash or '')
    password=str(password or '')
    if not stored_hash or not password:
        return False
    helper = """
import json, sys
stored = ''
candidates = []
try:
    data = json.loads(sys.stdin.read() or '{}')
    stored = str(data.get('hash') or '')
    candidates = [str(x) for x in (data.get('candidates') or []) if str(x)]
except Exception:
    pass
ok = False
if stored and candidates:
    for candidate in candidates:
        if ok:
            break
        try:
            from werkzeug.security import check_password_hash
            if check_password_hash(stored, candidate):
                ok = True
        except Exception:
            pass
        if not ok:
            try:
                from passlib.apps import custom_app_context
                if custom_app_context.verify(candidate, stored):
                    ok = True
            except Exception:
                pass
        if not ok:
            try:
                from passlib.context import CryptContext
                schemes = [
                    'bcrypt', 'pbkdf2_sha256', 'pbkdf2_sha512',
                    'sha256_crypt', 'sha512_crypt', 'argon2',
                    'django_pbkdf2_sha256', 'ldap_salted_sha1',
                ]
                ctx = CryptContext(schemes=schemes, deprecated='auto')
                if ctx.verify(candidate, stored):
                    ok = True
            except Exception:
                pass
        if not ok:
            try:
                from passlib.hash import bcrypt, pbkdf2_sha256, pbkdf2_sha512, sha256_crypt, sha512_crypt, argon2
                for h in (bcrypt, pbkdf2_sha256, pbkdf2_sha512, sha256_crypt, sha512_crypt, argon2):
                    try:
                        if h.verify(candidate, stored):
                            ok = True
                            break
                    except Exception:
                        pass
            except Exception:
                pass
print('OK' if ok else 'NO')
sys.exit(0 if ok else 1)
"""
    payload=json.dumps({'hash': stored_hash, 'candidates': _ots_password_candidates(password)})
    for py in _candidate_ots_venv_python_paths():
        try:
            res=subprocess.run([str(py), '-c', helper], input=payload, capture_output=True, text=True, timeout=10)
            lines=(res.stdout or '').strip().splitlines()
            if lines and lines[-1].strip() == 'OK':
                return True
        except Exception:
            pass
    return False


def _check_opentak_password_hash(stored_hash, password):
    """Verify an OpenTAKServer stored password hash.

    Try local Werkzeug-compatible verification first, then delegate to the OTS
    virtualenv for Flask-Security/Passlib hashes. This function is the single
    auth helper used by both PostgreSQL and SQLite paths.
    """
    stored_hash=str(stored_hash or '')
    password=str(password or '')
    if not stored_hash or not password:
        return False
    if _check_werkzeug_password_hash(stored_hash, password):
        return True
    if _check_ots_venv_password_hash(stored_hash, password):
        return True
    # Very old/dev deployments may store plaintext. Only allow that fallback
    # for values that do not look like recognized hash formats.
    if ('$' not in stored_hash and ':' not in stored_hash and len(stored_hash) < 256):
        return any(_safe_equal_password(c, stored_hash) for c in _ots_password_candidates(password))
    return False

def _read_simple_ots_config(path):
    vals={}
    try:
        text=Path(path).expanduser().read_text(errors='replace')
    except PermissionError:
        raise
    except Exception:
        return vals
    for line in text.splitlines():
        if not line or line.startswith((' ', '\t', '#', '-')):
            continue
        m=re.match(r'^([A-Za-z0-9_]+):\s*(.*)\s*$', line)
        if not m:
            continue
        key=m.group(1).strip()
        val=m.group(2).strip()
        if val in ('null','None','~'):
            val=''
        if len(val)>=2 and ((val[0]==val[-1]=='"') or (val[0]==val[-1]=="'")):
            val=val[1:-1]
        vals[key]=val
    return vals

def _candidate_ots_config_paths():
    """Return possible OpenTAKServer config files without recursive config loading.

    v117 accidentally called _load_ots_config_values() from here, while
    _load_ots_config_values() calls this function. That created the TAK Map
    login error: "maximum recursion depth exceeded". Keep this function
    strictly source-based: environment + systemd working directory + known
    non-root install locations.
    """
    paths=[]
    for name in ('TAK_DASH_OTS_CONFIG_PATHS','TAK_DASH_OTS_CONFIG_PATH','OTS_CONFIG_PATH'):
        raw=os.environ.get(name,'')
        for item in re.split(r'[,;]', raw or ''):
            item=item.strip()
            if item:
                paths.append(Path(item).expanduser())
    data_folder=os.environ.get('OTS_DATA_FOLDER','').strip()
    if data_folder:
        paths.append(Path(data_folder).expanduser()/'config.yml')
        paths.append(Path(data_folder).expanduser()/'config.yaml')
    try:
        res=subprocess.run(['systemctl','show','-p','WorkingDirectory','--value','opentakserver'], capture_output=True, text=True, timeout=3)
        wd=(res.stdout or '').strip()
        if wd and wd not in ('/','n/a'):
            paths.append(Path(wd).expanduser()/'config.yml')
            paths.append(Path(wd).expanduser()/'config.yaml')
    except Exception:
        pass
    for base in (Path('/etc/opentakserver'), Path('/etc/ots'), Path('/opt/opentakserver'), Path('/opt/OpenTAKServer'), Path('/srv/opentakserver')):
        paths.append(base/'config.yml')
        paths.append(base/'config.yaml')
    out=[]; seen=set()
    for p in paths:
        try:
            rp=p.resolve()
        except Exception:
            rp=p
        if str(rp) not in seen:
            seen.add(str(rp)); out.append(p)
    return out

def _load_ots_config_values():
    errors=[]
    for path in _candidate_ots_config_paths():
        try:
            if path.exists() and path.is_file():
                vals=_read_simple_ots_config(path)
                if vals:
                    vals['_config_path']=str(path)
                    return vals, errors
        except PermissionError as e:
            errors.append(f'Permission denied reading OpenTAKServer config {path}: {e}')
        except Exception as e:
            errors.append(f'Cannot read OpenTAKServer config {path}: {e}')
    return {}, errors

def _candidate_ots_pg_uris():
    uris=[]
    for name in ('TAK_DASH_OTS_POSTGRES_URI','TAK_DASH_OTS_DB_URI','SQLALCHEMY_DATABASE_URI'):
        val=os.environ.get(name,'').strip()
        if val:
            uris.append(val)
    cfg, cfg_errors = _load_ots_config_values()
    val=cfg.get('SQLALCHEMY_DATABASE_URI','').strip()
    if val:
        uris.append(val)
    out=[]; seen=set()
    for uri in uris:
        if not re.match(r'^(postgresql|postgres)\+', uri) and not re.match(r'^(postgresql|postgres)://', uri):
            continue
        norm=uri.replace('postgresql+psycopg://','postgresql://',1).replace('postgresql+psycopg2://','postgresql://',1).replace('postgres+psycopg://','postgresql://',1).replace('postgres://','postgresql://',1)
        if norm not in seen:
            seen.add(norm); out.append(norm)
    return out, cfg_errors

def _pg_parse_uri(uri):
    u=urlparse(uri)
    return {'host': u.hostname or '127.0.0.1', 'port': str(u.port or 5432), 'user': unquote(u.username or ''), 'password': unquote(u.password or ''), 'database': unquote((u.path or '').lstrip('/') or 'ots')}

def _pg_sql_literal(value):
    return "'" + str(value).replace("'", "''") + "'"

def _pg_ident(name):
    return '"' + str(name).replace('"','""') + '"'

def _pg_table_ref(schema, table):
    return _pg_ident(schema) + '.' + _pg_ident(table)

def _pg_query(uri, sql, timeout=8):
    if not shutil.which('psql'):
        return None, 'psql command is not installed; cannot verify OpenTAKServer PostgreSQL users.'
    cfg=_pg_parse_uri(uri)
    cmd=['psql','-X','-q','-t','-A','-F','\t','-h',cfg['host'],'-p',cfg['port'],'-U',cfg['user'],'-d',cfg['database'],'-w','-c',sql]
    env=os.environ.copy()
    if cfg.get('password'):
        env['PGPASSWORD']=cfg['password']
    try:
        res=subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, env=env)
    except Exception as e:
        return None, f'OpenTAKServer PostgreSQL query failed: {e}'
    if res.returncode != 0:
        err=(res.stderr or res.stdout or '').strip()
        err=re.sub(r'password=[^\s]+', 'password=REDACTED', err, flags=re.I)
        return None, 'OpenTAKServer PostgreSQL query failed: ' + (err[:300] or f'psql exit {res.returncode}')
    return [line for line in (res.stdout or '').splitlines() if line.strip()], ''

def _pg_tables(uri):
    sql="""select table_schema || E'\\t' || table_name
from information_schema.tables
where table_type='BASE TABLE'
  and table_schema not in ('pg_catalog','information_schema')
order by table_schema, table_name"""
    lines, err=_pg_query(uri, sql)
    if lines is None:
        return [], err
    out=[]
    for line in lines:
        parts=line.split('\t')
        if len(parts) >= 2:
            out.append((parts[0], parts[1]))
    return out, ''

def _pg_columns(uri, schema, table):
    sql=f"select column_name from information_schema.columns where table_schema={_pg_sql_literal(schema)} and table_name={_pg_sql_literal(table)} order by ordinal_position"
    lines, err=_pg_query(uri, sql)
    if lines is None:
        return [], err
    return [x.strip() for x in lines if x.strip()], ''

def _pg_rows_json(uri, sql):
    lines, err=_pg_query(uri, sql)
    if lines is None:
        return [], err
    rows=[]
    for line in lines:
        try:
            rows.append(json.loads(line))
        except Exception:
            pass
    return rows, ''


def _pg_exec(uri, sql, timeout=8):
    lines, err=_pg_query(uri, sql, timeout=timeout)
    return err == '', err

def _pg_first_value(uri, sql, timeout=8):
    lines, err=_pg_query(uri, sql, timeout=timeout)
    if lines is None:
        return None, err
    return (lines[0].strip() if lines else None), ''



def _candidate_ots_api_login_urls():
    """Return likely local OpenTAKServer /api/login URLs."""
    urls=[]
    for name in ('TAK_DASH_OTS_LOGIN_URLS','TAK_DASH_OTS_LOGIN_URL'):
        raw=os.environ.get(name,'')
        for item in re.split(r'[,;\s]+', raw or ''):
            item=item.strip()
            if item:
                urls.append(item)
    cfg, _errors = _load_ots_config_values()
    prefix=str(cfg.get('SECURITY_URL_PREFIX','/api') or '/api').strip() or '/api'
    if not prefix.startswith('/'):
        prefix='/' + prefix
    login_path=prefix.rstrip('/') + '/login'
    ports=[]
    for key in ('OTS_LISTENER_PORT','OTS_MARTI_HTTP_PORT'):
        val=str(cfg.get(key,'') or '').strip()
        if val and val.isdigit():
            ports.append(int(val))
    ports.extend([8081,8080])
    for port in ports:
        urls.append(f'http://127.0.0.1:{port}{login_path}')
    out=[]; seen=set()
    for url in urls:
        url=url.strip()
        if not url:
            continue
        if url.endswith('/'):
            url=url[:-1]
        if url not in seen:
            seen.add(url); out.append(url)
    return out

def _ots_api_login_attempt(url, username, password, as_json=True):
    """Try one OTS /api/login request. Return (matched, message)."""
    username=str(username or '')
    password=str(password or '')
    headers={'Accept':'application/json','User-Agent':'tak-server-dash/1'}
    if as_json:
        body=json.dumps({'username':username,'password':password}).encode('utf-8')
        headers['Content-Type']='application/json'
    else:
        body=urlencode({'username':username,'password':password}).encode('utf-8')
        headers['Content-Type']='application/x-www-form-urlencoded'
    try:
        req=Request(url, data=body, headers=headers, method='POST')
        with urlopen(req, timeout=8) as resp:
            status=getattr(resp, 'status', 200)
            raw=resp.read().decode('utf-8','replace')
            set_cookie='\n'.join(resp.headers.get_all('Set-Cookie') or [])
    except HTTPError as e:
        try:
            raw=e.read().decode('utf-8','replace')
        except Exception:
            raw=''
        return False, f'{url} returned HTTP {getattr(e,"code","")}: ' + (raw[:160].replace('\n',' ') or 'login rejected')
    except Exception as e:
        return False, f'{url} failed: {e}'
    if status < 200 or status >= 300:
        return False, f'{url} returned HTTP {status}'
    try:
        data=json.loads(raw or '{}')
    except Exception:
        return False, f'{url} did not return JSON'
    meta=data.get('meta') if isinstance(data,dict) else None
    resp_obj=data.get('response') if isinstance(data,dict) else None
    code = meta.get('code') if isinstance(meta,dict) else status
    if str(code) != '200':
        return False, f'{url} returned meta code {code}'
    has_csrf=isinstance(resp_obj,dict) and bool(resp_obj.get('csrf_token'))
    has_session_cookie=bool(re.search(r'(^|\n|;\s*)session=', set_cookie, re.I))
    has_xsrf_cookie=bool(re.search(r'XSRF-TOKEN=', set_cookie, re.I))
    if not (has_csrf or has_session_cookie or has_xsrf_cookie):
        return False, f'{url} returned JSON but no login token/cookie was detected'
    return True, f'OpenTAKServer accepted login at {url}'

def _ots_api_password_valid(username, password):
    """Use OpenTAKServer's own /api/login endpoint to verify the password."""
    errors=[]
    for url in _candidate_ots_api_login_urls():
        for as_json in (True, False):
            ok,msg=_ots_api_login_attempt(url, username, password, as_json=as_json)
            if ok:
                return True,msg
            errors.append(msg)
    return False, 'OpenTAKServer /api/login did not accept credentials. ' + ' | '.join(errors[:4])

def _pg_verify_opentak_admin_role(uri, username):
    """Verify username is active and has an admin/administrator role in OTS PostgreSQL."""
    username=str(username or '')
    sql = """select row_to_json(q) from (
select u.id, u.username, u.email, u.active, string_agg(r.name, ',') as roles
from \"user\" u
left join roles_users ru on ru.user_id = u.id
left join role r on r.id = ru.role_id
where lower(u.username)=lower({username_lit})
   or lower(coalesce(u.email,''))=lower({username_lit})
group by u.id, u.username, u.email, u.active
limit 1
) q""".format(username_lit=_pg_sql_literal(username))
    rows,err=_pg_rows_json(uri, sql)
    if not err and rows:
        row=rows[0]
        if str(row.get('active')).lower() in ('0','false','no','disabled'):
            return False, 'OpenTAKServer account exists but is disabled/inactive.'
        roles=str(row.get('roles') or '')
        if re.search(r'(^|,|\s)(admin|administrator|superuser)(,|\s|$)', roles, re.I):
            return True, 'OpenTAKServer administrator role verified from PostgreSQL.'
        return False, 'OpenTAKServer login accepted, but administrator role was not found.'
    tables,err=_pg_tables(uri)
    if err:
        return False, err
    col_cache={}
    def cols(schema, table):
        key=(schema,table)
        if key not in col_cache:
            col_cache[key]=_pg_columns(uri, schema, table)[0]
        return col_cache[key]
    for schema, table in tables:
        c=cols(schema,table); lc={x.lower():x for x in c}
        if not any(k in lc for k in ('username','email','name')):
            continue
        where=[]
        for k in ('username','email','name'):
            if k in lc:
                where.append(f'lower({_pg_ident(lc[k])}::text)=lower({_pg_sql_literal(username)})')
        if not where:
            continue
        q=f'select row_to_json(q) from (select * from {_pg_table_ref(schema,table)} where ' + ' OR '.join(where) + ' limit 5) q'
        rows,_err=_pg_rows_json(uri,q)
        for row in rows:
            for flag in ('active','is_active','enabled'):
                col=lc.get(flag)
                if col and str(row.get(col)).lower() in ('0','false','no','disabled'):
                    return False, 'OpenTAKServer account exists but is disabled/inactive.'
            for colname in ('admin','is_admin','is_superuser','superuser'):
                col=lc.get(colname)
                if col and str(row.get(col)).lower() in ('1','true','yes','admin','administrator'):
                    return True, 'OpenTAKServer admin flag verified from PostgreSQL.'
            for colname in ('role','roles','permission','permissions'):
                col=lc.get(colname)
                if col and re.search(r'admin|administrator|superuser', str(row.get(col)), re.I):
                    return True, 'OpenTAKServer admin role verified from PostgreSQL.'
    return False, 'OpenTAKServer account was not found or administrator role could not be verified.'

def _pg_authenticate_opentak_admin(uri, username, password):
    tables, err=_pg_tables(uri)
    if err:
        return False, err
    if not tables:
        return False, 'OpenTAKServer PostgreSQL database has no visible application tables.'
    col_cache={}
    def cols(schema, table):
        key=(schema,table)
        if key not in col_cache:
            col_cache[key]=_pg_columns(uri, schema, table)[0]
        return col_cache[key]
    user_tables=[]
    for schema, table in tables:
        c=[x.lower() for x in cols(schema, table)]
        if any(x in c for x in ('username','email','name')) and any('password' in x for x in c):
            user_tables.append((schema, table))
    for schema, table in user_tables:
        c=cols(schema, table)
        lc={x.lower():x for x in c}
        id_col=lc.get('id') or lc.get('uuid') or (c[0] if c else 'id')
        name_cols=[lc[x] for x in ('username','email','name') if x in lc]
        pass_cols=[x for x in c if 'password' in x.lower()]
        if not name_cols or not pass_cols:
            continue
        where=' OR '.join([f'lower({_pg_ident(x)}::text)=lower({_pg_sql_literal(username)})' for x in name_cols])
        sql=f'select row_to_json(q) from (select * from {_pg_table_ref(schema, table)} where {where} limit 5) q'
        rows, err=_pg_rows_json(uri, sql)
        if err:
            continue
        for row in rows:
            stored=''
            for pc in pass_cols:
                if row.get(pc):
                    stored=str(row.get(pc)); break
            if not _check_opentak_password_hash(stored, password):
                continue
            for flag in ('active','is_active','enabled'):
                col=lc.get(flag)
                if col and str(row.get(col)).lower() in ('0','false','no','disabled'):
                    return False, 'OpenTAKServer account exists but is disabled/inactive.'
            direct_admin=False
            for colname in ('admin','is_admin','is_superuser','superuser'):
                col=lc.get(colname)
                if col and str(row.get(col)).lower() in ('1','true','yes','admin','administrator'):
                    direct_admin=True
            for colname in ('role','roles','permission','permissions'):
                col=lc.get(colname)
                if col and re.search(r'admin|administrator|superuser', str(row.get(col)), re.I):
                    direct_admin=True
            if direct_admin:
                return True, 'OpenTAKServer admin verified from PostgreSQL database.'
            uid=row.get(id_col)
            admin_role=False
            for rs, rt in tables:
                rcols=cols(rs, rt); rlc={x.lower():x for x in rcols}; joined=' '.join(rcols).lower() + ' ' + rt.lower()
                if 'role' not in joined:
                    continue
                try:
                    if 'user_id' in rlc and 'role_id' in rlc:
                        for role_schema, role_table in tables:
                            rc=cols(role_schema, role_table); rcl={x.lower():x for x in rc}
                            if ('name' in rcl or 'description' in rcl) and 'id' in rcl and 'role' in role_table.lower():
                                q=f"""select row_to_json(rr) from (
select r.* from {_pg_table_ref(role_schema, role_table)} r
join {_pg_table_ref(rs, rt)} ur on r.{_pg_ident(rcl['id'])}::text=ur.{_pg_ident(rlc['role_id'])}::text
where ur.{_pg_ident(rlc['user_id'])}::text={_pg_sql_literal(uid)}
) rr"""
                                role_rows, _err=_pg_rows_json(uri, q)
                                for role in role_rows:
                                    if re.search(r'admin|administrator|superuser', ' '.join(str(v) for v in role.values()), re.I):
                                        admin_role=True
                    if any(k in rlc for k in ('username','email','user','user_name')) and any(k in rlc for k in ('role','role_name','name')):
                        user_col=next(rlc[k] for k in ('username','email','user','user_name') if k in rlc)
                        role_col=next(rlc[k] for k in ('role','role_name','name') if k in rlc)
                        q=f"""select row_to_json(q) from (select * from {_pg_table_ref(rs,rt)} where lower({_pg_ident(user_col)}::text)=lower({_pg_sql_literal(username)})) q"""
                        role_rows, _err=_pg_rows_json(uri, q)
                        for role in role_rows:
                            if re.search(r'admin|administrator|superuser', str(role.get(role_col,'')), re.I):
                                admin_role=True
                except Exception:
                    pass
            if admin_role:
                return True, 'OpenTAKServer admin role verified from PostgreSQL database.'
            return False, 'OpenTAKServer password verified, but admin role could not be verified.'
    return False, 'OpenTAKServer PostgreSQL account not found, password invalid, or password hash type could not be verified. Confirm the username is the OpenTAKServer admin username, usually administrator.'

def _candidate_ots_db_paths():
    paths=[]
    for item in env_list('TAK_DASH_OTS_DB_PATHS',''):
        paths.append(Path(item).expanduser())
    cfg, _cfg_errors = _load_ots_config_values()
    data_folder=(os.environ.get('OTS_DATA_FOLDER','').strip() or cfg.get('OTS_DATA_FOLDER','').strip())
    if data_folder:
        for name in ('ots.db','opentakserver.db','app.db','db.sqlite','database.db'):
            paths.append(Path(data_folder).expanduser()/name)
    for base in (Path('/var/lib/opentakserver'), Path('/opt/opentakserver'), Path('/opt/OpenTAKServer'), Path('/srv/opentakserver')):
        for name in ('ots.db','opentakserver.db','app.db','db.sqlite','database.db'):
            paths.append(base/name)
    try:
        for home in Path('/home').glob('*'):
            if home.is_dir():
                for rel in ('ots/ots.db','ots/opentakserver.db','.ots/ots.db','OpenTAKServer/ots.db'):
                    paths.append(home/rel)
    except Exception:
        pass
    out=[]
    seen=set()
    for p in paths:
        try:
            rp=p.resolve()
        except Exception:
            rp=p
        if str(rp) not in seen:
            seen.add(str(rp)); out.append(p)
    return out

def _sqlite_table_info(conn, table):
    try:
        return [dict(row) for row in conn.execute(f'PRAGMA table_info("{table}")')]
    except Exception:
        return []

def _sqlite_tables(conn):
    try:
        return [r[0] for r in conn.execute("select name from sqlite_master where type='table'")]
    except Exception:
        return []

def _readable_sqlite_file(path):
    """Return (is_file, error_message) without letting PermissionError crash login.

    The dashboard runs as the locked-down takserverdash service user. Some
    OpenTAKServer installs keep ots.db under a real user's home directory, so
    stat/open may raise PermissionError unless install.sh granted ACL access.
    """
    try:
        return (path.exists() and path.is_file()), ''
    except PermissionError as e:
        return False, f'Permission denied: {path} ({e})'
    except Exception as e:
        return False, f'Cannot inspect {path}: {e}'

def authenticate_opentak_admin(username, password):
    """Authenticate against likely OpenTAKServer account stores and require admin role.

    This is intentionally fail-closed: if the dashboard cannot verify both the
    password and admin-like role/status, TAK Map login is denied.
    """
    username=sanitize_ots_username(username)
    password=str(password or '')
    if not username or not password:
        return False, 'Username and password are required.'

    # Optional local API hook for deployments that expose an internal OTS admin auth endpoint.
    # Expected JSON response: {"ok": true, "admin": true}
    api=os.environ.get('TAK_DASH_OTS_ADMIN_AUTH_URL','').strip()
    if api:
        try:
            body=urlencode({'username':username,'password':password}).encode()
            req=Request(api, data=body, headers={'Content-Type':'application/x-www-form-urlencoded'}, method='POST')
            with urlopen(req, timeout=8) as resp:
                data=json.loads(resp.read().decode('utf-8','replace') or '{}')
            if data.get('ok') and (data.get('admin') is True or str(data.get('role','')).lower() in ('admin','administrator')):
                return True, 'OpenTAKServer admin verified through auth API.'
            return False, data.get('error') or 'OpenTAKServer auth API did not verify an admin account.'
        except Exception as e:
            return False, 'OpenTAKServer auth API failed closed: '+str(e)

    # Preferred path for PostgreSQL-backed OpenTAKServer: let OpenTAKServer's
    # own /api/login verify the password, then independently verify admin role
    # from PostgreSQL. This avoids duplicating Flask-Security hash internals.
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if pg_uris:
        api_ok, api_msg = _ots_api_password_valid(username, password)
        if api_ok:
            role_errors=[]
            for uri in pg_uris:
                role_ok, role_msg = _pg_verify_opentak_admin_role(uri, username)
                if role_ok:
                    return True, 'OpenTAKServer admin verified through /api/login and PostgreSQL role check.'
                role_errors.append(role_msg)
            return False, 'OpenTAKServer login accepted, but admin role check failed. ' + ' | '.join(role_errors[:3])
        # If API login is unavailable/rejected, keep the old direct PostgreSQL
        # hash verification path as a fallback for offline/non-web deployments.
        pg_errors=[]
        for uri in pg_uris:
            ok, msg = _pg_authenticate_opentak_admin(uri, username, password)
            if ok:
                return True, msg
            pg_errors.append(msg)
            if 'password verified' in msg.lower() or 'account exists but is disabled' in msg.lower():
                return False, msg
        return False, 'Could not verify OpenTAKServer PostgreSQL admin login. API: ' + api_msg + ' | DB fallback: ' + ' | '.join(pg_errors[:2])

    # Direct SQLite verification for older/common OTS/Flask-Security layouts.
    try:
        import sqlite3
    except Exception:
        return False, 'sqlite3 is not available; cannot verify OpenTAKServer users.'

    checked=[]
    inaccessible=[]
    for db_path in _candidate_ots_db_paths():
        is_file, stat_error = _readable_sqlite_file(db_path)
        if stat_error:
            inaccessible.append(stat_error)
            continue
        if not is_file:
            continue
        checked.append(str(db_path))
        try:
            uri='file:' + quote(str(db_path), safe='/') + '?mode=ro'
            conn=sqlite3.connect(uri, uri=True)
            conn.row_factory=sqlite3.Row
            tables=_sqlite_tables(conn)
            user_tables=[]
            for t in tables:
                cols=[c['name'].lower() for c in _sqlite_table_info(conn,t)]
                if any(c in cols for c in ('username','email','name')) and any('password' in c for c in cols):
                    user_tables.append(t)
            for ut in user_tables:
                info=_sqlite_table_info(conn,ut)
                cols=[c['name'] for c in info]
                lc={c.lower():c for c in cols}
                id_col=lc.get('id') or lc.get('uuid') or cols[0]
                name_cols=[lc[c] for c in ('username','email','name') if c in lc]
                pass_cols=[c for c in cols if 'password' in c.lower()]
                if not name_cols or not pass_cols:
                    continue
                where=' OR '.join([f'lower("{c}")=lower(?)' for c in name_cols])
                rows=list(conn.execute(f'select * from "{ut}" where {where}', [username]*len(name_cols)))
                for row in rows:
                    stored=''
                    for pc in pass_cols:
                        val=row[pc]
                        if val:
                            stored=str(val); break
                    if not _check_opentak_password_hash(stored, password):
                        continue
                    # Account must not be disabled when those columns are present.
                    for flag in ('active','is_active','enabled','confirmed_at'):
                        col=lc.get(flag)
                        if col and flag != 'confirmed_at' and str(row[col]).lower() in ('0','false','no','disabled'):
                            return False, 'OpenTAKServer account exists but is disabled/inactive.'
                    # Admin role can be direct column, direct role text, or role mapping table.
                    direct_admin=False
                    for colname in ('admin','is_admin','is_superuser','superuser'):
                        col=lc.get(colname)
                        if col and str(row[col]).lower() in ('1','true','yes','admin','administrator'):
                            direct_admin=True
                    for colname in ('role','roles','permission','permissions'):
                        col=lc.get(colname)
                        if col and re.search(r'admin|administrator|superuser', str(row[col]), re.I):
                            direct_admin=True
                    if direct_admin:
                        return True, 'OpenTAKServer admin verified from database.'
                    uid=row[id_col]
                    # Role association tables.
                    admin_role=False
                    for rt in tables:
                        rcols=[c['name'] for c in _sqlite_table_info(conn,rt)]
                        rlc={c.lower():c for c in rcols}
                        joined=' '.join(rcols).lower()
                        if 'role' not in joined:
                            continue
                        try:
                            # Flask-Security commonly: roles_users(user_id, role_id) + role(id,name)
                            if 'user_id' in rlc and 'role_id' in rlc:
                                for role_table in tables:
                                    rc=[c['name'] for c in _sqlite_table_info(conn,role_table)]
                                    rcl={c.lower():c for c in rc}
                                    if ('name' in rcl or 'description' in rcl) and 'id' in rcl and 'role' in role_table.lower():
                                        q=f'select rr.* from "{role_table}" rr join "{rt}" ur on rr."{rcl["id"]}"=ur."{rlc["role_id"]}" where ur."{rlc["user_id"]}"=?'
                                        for role in conn.execute(q,[uid]):
                                            if re.search(r'admin|administrator|superuser', ' '.join(str(role[k]) for k in role.keys()), re.I):
                                                admin_role=True
                            # Some schemas include username/role name in one table.
                            if any(k in rlc for k in ('username','email','user','user_name')) and any(k in rlc for k in ('role','role_name','name')):
                                user_col=next(rlc[k] for k in ('username','email','user','user_name') if k in rlc)
                                role_col=next(rlc[k] for k in ('role','role_name','name') if k in rlc)
                                q=f'select * from "{rt}" where lower("{user_col}")=lower(?)'
                                for role in conn.execute(q,[username]):
                                    if re.search(r'admin|administrator|superuser', str(role[role_col]), re.I):
                                        admin_role=True
                        except Exception:
                            pass
                    if admin_role:
                        return True, 'OpenTAKServer admin role verified from database.'
                    return False, 'OpenTAKServer password verified, but admin role could not be verified.'
        except Exception as e:
            inaccessible.append(f'Cannot read/verify {db_path}: {e}')
            continue
        finally:
            try:
                conn.close()
            except Exception:
                pass
    msg='Could not find/verify an OpenTAKServer user database.'
    if checked:
        msg += ' Checked: ' + ', '.join(checked[:5])
    else:
        msg += ' Set TAK_DASH_OTS_DB_PATHS or TAK_DASH_OTS_ADMIN_AUTH_URL if needed.'
    if inaccessible:
        msg += ' ' + ' | '.join(inaccessible[:3])
    return False, msg

def _login_key(username, client_ip):
    return (str(username or '').strip().lower() or '<blank>', str(client_ip or '').strip() or '<unknown>')

def login_lockout_status(username, client_ip):
    now = time.time()
    key = _login_key(username, client_ip)
    with DASH_LOGIN_FAILURES_LOCK:
        rec = DASH_LOGIN_FAILURES.get(key)
        if not rec:
            return False, 0, 0
        first = rec.get('first', now)
        count = int(rec.get('count', 0) or 0)
        if now - first >= DASH_LOGIN_FAIL_WINDOW_SECONDS:
            DASH_LOGIN_FAILURES.pop(key, None)
            return False, 0, 0
        if count >= DASH_LOGIN_FAIL_LIMIT:
            remaining = int(max(1, DASH_LOGIN_FAIL_WINDOW_SECONDS - (now - first)))
            return True, remaining, count
        return False, int(max(1, DASH_LOGIN_FAIL_WINDOW_SECONDS - (now - first))), count

def record_login_failure(username, client_ip):
    now = time.time()
    key = _login_key(username, client_ip)
    with DASH_LOGIN_FAILURES_LOCK:
        rec = DASH_LOGIN_FAILURES.get(key)
        if not rec or now - rec.get('first', now) >= DASH_LOGIN_FAIL_WINDOW_SECONDS:
            DASH_LOGIN_FAILURES[key] = {'first': now, 'count': 1}
        else:
            rec['count'] = int(rec.get('count', 0) or 0) + 1
            DASH_LOGIN_FAILURES[key] = rec

def clear_login_failures(username, client_ip):
    with DASH_LOGIN_FAILURES_LOCK:
        DASH_LOGIN_FAILURES.pop(_login_key(username, client_ip), None)

def resolve_upload_destination_preview(home, path_template):
    home = Path(home)
    path_template = sanitize_upload_destination_path(path_template)
    if not path_template:
        return ''
    if path_template == '~' or path_template == '~/':
        return str(home)
    if path_template.startswith('~/'):
        return str(home / path_template[2:])
    if path_template.startswith('/'):
        return path_template
    return str(home / path_template)

def upload_destinations_for_user(username, home):
    out = []
    for d in effective_upload_destinations():
        item = dict(d)
        item['resolved_path'] = resolve_upload_destination_preview(home, item.get('path',''))
        out.append(item)
    return out


def browse_upload_directory_for_session(sess, path_spec):
    path_spec = sanitize_upload_destination_path(path_spec or '~') or '~'
    cmd = ['sudo', '/usr/local/sbin/tak-map-action', 'browse-dirs', sess['username'], path_spec]
    r = run_cmd(cmd, 30)
    if not r.get('ok'):
        return {'ok': False, 'error': r.get('stderr') or r.get('stdout') or 'Failed to browse directory.'}
    try:
        data = json.loads(r.get('stdout') or '{}')
    except Exception:
        return {'ok': False, 'error': 'Bad browse response.'}
    if not data.get('ok'):
        return {'ok': False, 'error': data.get('error') or 'Browse failed.'}
    return data

def upload_security_status():
    return {
        'limit_mb': UPLOAD_LIMIT_MB,
        'allow_insecure_auth': ALLOW_INSECURE_UPLOAD_AUTH,
        'session_ttl_seconds': UPLOAD_SESSION_TTL_SECONDS,
        'destinations': effective_upload_destinations(),
    }

def cert_expiry_status_for_file(path):
    info={'exists': path.exists(), 'path': str(path), 'not_after': '', 'expires_at': None, 'days_remaining': None, 'status': 'missing', 'label': 'Not generated'}
    if not path.exists():
        return info
    r=run_cmd(['openssl','x509','-in',str(path),'-noout','-enddate'],5)
    raw=(r.get('stdout') or r.get('stderr') or '').strip()
    if raw.startswith('notAfter='):
        raw=raw.split('=',1)[1].strip()
    info['not_after']=raw
    try:
        dt=datetime.strptime(raw, '%b %d %H:%M:%S %Y %Z').replace(tzinfo=timezone.utc)
        now=datetime.now(timezone.utc)
        days=int((dt-now).total_seconds()//86400)
        info['expires_at']=dt.isoformat()
        info['days_remaining']=days
        if days < 0:
            info['status']='expired'; info['label']='Expired'
        elif days <= 14:
            info['status']='bad'; info['label']=f'Expires in {days} day(s)'
        elif days <= 45:
            info['status']='warn'; info['label']=f'Expires in {days} day(s)'
        else:
            info['status']='good'; info['label']=f'Valid · {days} day(s) left'
    except Exception:
        info['status']='unknown'; info['label']='Expiration unknown'
    return info

def get_cert_status():
    ips=[]
    r=run_cmd(['ip','-o','addr','show','scope','global'],3)
    if r.get('ok'):
        for line in (r.get('stdout') or '').splitlines():
            parts=line.split()
            if len(parts) >= 4 and '/' in parts[3]:
                ip=parts[3].split('/',1)[0].strip()
                if ip and ip not in ips:
                    ips.append(ip)
    hostname=run_cmd(['hostname'],2).get('stdout') or ''
    fqdn=run_cmd(['hostname','-f'],2).get('stdout') or hostname
    names=[]
    for n in [hostname, fqdn, 'tak-server-dash.local']:
        n=(n or '').strip()
        if n and n not in names:
            names.append(n)
    cert_info=''
    if SERVER_CERT_FILE.exists():
        r=run_cmd(['openssl','x509','-in',str(SERVER_CERT_FILE),'-noout','-subject','-issuer','-dates','-ext','keyUsage','-ext','extendedKeyUsage','-ext','subjectAltName'],5)
        cert_info=(r.get('stdout') or r.get('stderr') or '').strip()[:7000]
    return {
        'ok': True,
        'ips': ips,
        'names': names,
        'ca_exists': CA_CERT_FILE.exists(),
        'server_cert_exists': SERVER_CERT_FILE.exists(),
        'server_key_exists': SERVER_KEY_FILE.exists(),
        'ca_path': str(CA_CERT_FILE),
        'server_cert_path': str(SERVER_CERT_FILE),
        'server_key_path': str(SERVER_KEY_FILE),
        'ca_download_url': '/ca-cert.crt' if CA_CERT_FILE.exists() else '',
        'cert_info': cert_info,
        'cert_expiration': {
            'dashboard_server': cert_expiry_status_for_file(SERVER_CERT_FILE),
            'dashboard_ca': cert_expiry_status_for_file(CA_CERT_FILE),
        },
    }

def _status_fallback_for(key):
    if key in ('interfaces','zerotier_devices','custom_commands','command_history'):
        return []
    if key in ('network_neighbors','services','warning_settings','warning_labels','config','topology_scan','topology_layout','cpu','upload','wifi','internet','lte','system_health','power','network_latency','usb_devices','diagnostics'):
        return {}
    return None

def get_status(include_ipv6_neighbors=False):
    errors=[]
    def collect(key, func, default=None):
        try:
            return func()
        except Exception as e:
            errors.append({'component':key,'error':str(e)[:240]})
            try:
                print(f'get_status collector failed: {key}: {e}', file=sys.stderr)
                traceback.print_exc()
            except Exception:
                pass
            return _status_fallback_for(key) if default is None else default
    status={
        'timestamp':int(time.time()),
        'hostname':collect('hostname', lambda: run_cmd(['hostname'],2)['stdout'], ''),
        'interfaces':collect('interfaces', get_interfaces, []),
        'wifi':collect('wifi', get_wifi_info, {}),
        'internet':collect('internet', get_internet_status, {}),
        'lte':collect('lte', get_lte_status, {}),
        'system_health':collect('system_health', get_system_health, {}),
        'power':collect('power', get_power_runtime, {}),
        'network_latency':collect('network_latency', get_network_latency, {}),
        'network_neighbors':collect('network_neighbors', lambda: get_network_neighbors(include_ipv6_neighbors), {}),
        'usb_devices':collect('usb_devices', get_usb_device_status, {}),
        'diagnostics':collect('diagnostics', get_diagnostics_status, {}),
        'zerotier_devices':collect('zerotier_devices', get_zerotier_connectivity, []),
        'services':collect('services', get_services, {}),
        'required_services':collect('required_services', effective_required_services, []),
        'warning_settings':collect('warning_settings', warning_settings, {}),
        'warning_labels':WARNING_LABELS,
        'config':collect('config', load_runtime_config, {}),
        'custom_commands':collect('custom_commands', effective_custom_commands, []),
        'command_history':collect('command_history', grouped_command_history, []),
        'topology_scan':collect('topology_scan', lambda: load_json_file(TOPOLOGY_SCAN_CACHE_FILE,{}), {}),
        'topology_layout':collect('topology_layout', lambda: load_json_file(TOPOLOGY_LAYOUT_FILE,{}), {}),
        'cpu':collect('cpu', get_cpu_info, {}),
        'upload':collect('upload', upload_security_status, {}),
    }
    if errors:
        diag=status.get('diagnostics')
        if isinstance(diag, dict):
            diag['status_collector_errors']=errors
        else:
            status['diagnostics']={'status_collector_errors':errors}
    return status

