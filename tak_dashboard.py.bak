r_gps===false)continue;if(kind!==\'eud\'&&kind!==\'server_gps\'&&state.live.cot_markers===false)continue;if(m.lat==null||m.lon==null)continue;const popup=(kind===\'eud\'||kind===\'webform\'||kind===\'server_gps\')?basicMarkerPopupHtml(m,kind):pointPopupHtml(m,\'Point Markers\');const layer=L.marker([m.lat,m.lon],{icon:takIcon(kind,m)}).bindPopup(popup).addTo(takMarkerLayer);stabilizeLayerPopup(layer);addSearchItem(\'tak\',kind,m.callsign||m.uid||m.id||kind,m.lat,m.lon,layer,m)}document.getElementById(\'eudStatus\').textContent=String(eudCount);if(lastBanner){lastBanner.euds_connected=eudCount;renderTopBanner(lastBanner)}handleMapSearch();refreshTerrain3DObjects()}catch(e){document.getElementById(\'eudStatus\').textContent=\'error\'}}async function updateTopBanner(){try{const r=await fetch(\'/api/tak-map/status-banner\',{cache:\'no-store\'});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));lastBanner=j;renderTopBanner(j)}catch(e){renderTopBanner({tak_server:\'Offline\',internet:\'Disconnected\',euds_connected:\'?\',adsb_aircraft:\'?\',downloads:{active:0}})}}function updateTopBannerCached(){if(lastBanner)renderTopBanner(lastBanner)}function bannerDot(id,cls){const el=document.getElementById(id);if(!el)return;cls=cls||\'unknown\';el.className=\'status-dot \'+cls;el.title=({good:\'Online / OK\',warn:\'Warning or active work in progress\',bad:\'Offline / error\',unknown:\'Unknown / inactive\'}[cls]||cls)}function titleWords(s){return String(s??\'\').replace(/\\b\\w/g,c=>c.toUpperCase())}function shortUid(v){v=String(v||\'\').trim();if(!v)return\'\';if(/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v))return v.slice(0,8)+\'...\'+v.slice(-4);return v.length>18?v.slice(0,10)+\'...\'+v.slice(-6):v}function statusItemLabel(o){const label=String(o?.callsign||o?.name||o?.title||\'\').trim();if(label)return label;const uid=String(o?.uid||o?.id||\'\').trim();if(uid)return \'Unknown CoT Sensor\';return\'Unknown\'}function statusItemSub(o){const label=st