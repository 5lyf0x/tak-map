  }catch(_){ }}
  function updateOpenPopup(){try{const pop=window.map&&map._popup;if(!pop)return;const el=pop.getElement&&pop.getElement();if(!el||!q('.adsb-popup',el))return;const src=pop._source;const a=findAircraftForMarker(src,(q('.leaflet-popup-content',el)||el).innerHTML);if(a)pop.setContent(buildPopup(a));removeAdsbCloseButtons(el);}catch(_){ }}
  function removeAdsbCloseButtons(root=document){try{qa('.leaflet-popup.adsb-object-popup .leaflet-popup-close-button,.leaflet-popup.adsb-v286-popup .leaflet-popup-close-button,.leaflet-popup .adsb-v284-close,.leaflet-popup .adsb-v283-close',root).forEach(n=>n.remove())}catch(_){ }}
  function patchTrackToggle(){try{if(window._v286TrackWrapped)return;const old=window.toggleAdsbTrack;if(typeof old==='function'){window._v286TrackWrapped=true;window.toggleAdsbTrack=function(id){const res=old.apply(this,arguments);try{const key=String(id||'').toLowerCase();window._v286TrackedId=res?key:(window._v286TrackedId===key?null:window._v286TrackedId);setTimeout(updateOpenPopup,0);}catch(_){ }return res;};}}catch(_){ }}
  function ensureStatusItem(){try{const bar=q('#mapStatusBanner')||q('.map-status-banner');if(!bar)return null;let item=q('#bannerAdsbItem',bar);if(!item){item=document.createElement('span');item.id='bannerAdsbItem';item.className='status-item status-dropdown-trigger';item.setAttribute('data-status-type','adsb');item.innerHTML='<span class="status-dot unknown" id="bannerAdsbDot"></span><span id="bannerAdsb">0 Aircraft</span>';const before=q('#bannerDownloadsItem',bar)||q('#bannerEudItem',bar);if(before&&before.parentElement===bar)bar.insertBefore(item,before);else bar.appendChild(item);item.addEventListener('click',function(ev){try{if(typeof window.toggleStatusDropdown==='function')window.toggleStatusDropdown('adsb',ev);else if(typeof window.renderStatusDropdown==='function'){window.renderStatusDropdown('adsb');const d=q('#statusDropdown');if(d){d.classList.toggle('active');const r=item.getBoundingClientRect();d.style.left=Math.max(8,Math.min(window.innerWidth-340,r.left))+'px';d.style.top=(r.bottom+8)+'px';}}}catch(_){}});}return item;}catch(_){return null}}
  function filteredAircraftCount(){try{const list=Array.isArray(window.lastAircraft)?window.lastAircraft:[];const f={civil:true,military:true,govt:true,unknown:true};qa('#adsbV280Menu input[type="checkbox"][data-filter],#adsbV279Menu input[type="checkbox"][data-filter]').forEach(ch=>{f[ch.dataset.filter]=!!ch.checked});return list.map(normalize).filter(a=>f[classKey(a.category)]!==false).length}catch(_){return (Array.isArray(window.lastAircraft)?window.lastAircraft.length:0)}}
  function updateStatusItem(){try{const item=ensureStatusItem();if(!item)return;const n=filteredAircraftCount();const text=q('#bannerAdsb',item);if(text)text.textContent=n+' Aircraft';const dot=q('#bannerAdsbDot',item);if(dot){dot.className='status-dot '+(n>0?'good':'unknown');}}catch(_){ }}
