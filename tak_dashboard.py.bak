/* v268 ADS-B menu control cleanup */
(function(){
  const V='v301';
  function field(id){return document.getElementById(id)}
  function setStatus(msg){const box=field('adsbSettingsStatus');if(box)box.textContent=msg||''}
  function localDisabled(){try{return localStorage.getItem('takmap.adsb.localDisabled')==='1'}catch(_){return false}}
  function setLocalDisabled(v){try{localStorage.setItem('takmap.adsb.localDisabled',v?'1':'0')}catch(_){} }
  function otsDisabled(){try{return localStorage.getItem('takmap.adsb.otsJobDisabled')==='1'}catch(_){return false}}
  function css(){
    if(field('v268Style'))return;
    const st=document.createElement('style');st.id='v268Style';st.textContent=`
      .adsb-stepper-buttons button{color:var(--accent)!important;background:linear-gradient(180deg,rgba(255,111,46,.20),rgba(255,111,46,.09))!important;border-color:rgba(255,111,46,.34)!important;opacity:1!important;text-shadow:0 0 7px rgba(255,111,46,.45)!important;font-size:9px!important;font-weight:1000!important;visibility:visible!important}
      .adsb-stepper-buttons button:hover,.adsb-stepper-buttons button:focus{color:#fff!important;background:linear-gradient(180deg,rgba(255,111,46,.36),rgba(255,111,46,.16))!important;border-color:rgba(255,111,46,.62)!important}
      .adsb-stepper-buttons{background:rgba(255,111,46,.06)!important;border-left:1px solid rgba(255,111,46,.34)!important}
      .adsb-v268-actions{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:7px;margin:7px 0 2px}
      .adsb-v268-actions .layer-button{font-size:.70rem!important;padding:6px 8px!important}
      .adsb-v266-actions,.adsb-v266-note,.adsb-v266-sep{display:none!important}
      .panel[data-collapse-key="adsbSettings"] .panel-body > .muted:first-child{display:none!important}
      .adsb-action-active{border-color:rgba(57,217,138,.55)!important}
      .adsb-action-inactive{opacity:.55!important}
    `;document.head.appendChild(st);
  }
  function clearOldText(){try{document.querySelectorAll('.adsb-v266-actions,#adsbLocalToggleBtn,#adsbOtsJobBtn,.adsb-v266-note,.adsb-v266-sep,#adsbV267Actions').forEach(n=>{const row=n.closest&&n.closest('.adsb-v266-actions');(row||n).remove()});const help=document.querySelector('.panel[data-collapse-key="adsbSettings"] .panel-body > .muted');if(help)help.remove()}catch(_){}}
  function ensureApplyButton(){try{const row=document.querySelector('.adsb-apply-row');if(row&&!field('adsbApplyOtsBtn'))row.insertAdjacentHTML('beforeend','<button id="adsbApplyOtsBtn" class="layer-button" type="button" onclick="saveAdsbSettings(true)">Apply to OTS</button>')}catch(_){}}
  function updateButtons(){try{const local=localDisabled();const ots=otsDisabled();const ld=field('adsbDisableLocalBtn'),le=field('adsbEnableLocalBtn'),od=field('adsbDisableOtsJobBtn'),oe=field('adsbEnableOtsJobBtn');if(ld){ld.classList.toggle('adsb-action-inactive',local);ld.classList.toggle('adsb-action-active',!local)}if(le){le.classList.toggle('adsb-action-active',local);le.classList.toggle('adsb-action-inactive',!local)}if(od){od.classList.toggle('adsb-action-inactive',ots);od.classList.toggle('adsb-action-active',!ots)}if(oe){oe.classList.toggle('adsb-action-active',ots);oe.classList.toggle('adsb-action-inactive',!ots)}document.querySelectorAll('.adsb-v266-actions,#adsbLocalToggleBtn,#adsbOtsJobBtn,#adsbV267Actions').forEach(n=>{const row=n.closest&&n.closest('.adsb-v266-actions');(row||n).remove()})}catch(_){}}
  function ensureAdsbControls(){try{clearOldText();const panel=document.querySelector('.panel[data-collapse-key="adsbSettings"]');if(!panel)return;let row=field('adsbV268Actions');if(!row){row=document.createElement('div');row.id='adsbV268Actions';row.className='adsb-v268-actions';row.innerHTML='<button id="adsbDisableLocalBtn" class="layer-button" type="button" onclick="disableTakMapAdsbLocal()">Disable ADS-B</button><button id="adsbEnableLocalBtn" class="layer-button" type="button" onclick="enableTakMapAdsbLocal()">Enable ADS-B</button><button id="adsbDisableOtsJobBtn" class="layer-button" type="button" onclick="setAdsbOtsJobDisabled(true)">Disable OTS Job</button><button id="adsbEnableOtsJobBtn" class="layer-button" type="button" onclick="setAdsbOtsJobDisabled(false)">Enable OTS Job</button>';const status=field('adsbSettingsStatus');if(status&&status.parentElement)status.insertAdjacentElement('beforebegin',row);else{const grid=panel.querySelector('.adsb-settings-grid')||panel;grid.appendChild(row)}}updateButtons()}catch(e){console.warn('v268 adsb controls failed',e)}}
  window.disableTakMapAdsbLocal=function(){setLocalDisabled(true);try{if(state&&state.live)state.live.adsb_aircraft=false}catch(_){};try{if(window.aircraftLayer){aircraftLayer.clearLayers();if(window.map&&map.hasLayer(aircraftLayer))map.removeLayer(aircraftLayer)}}catch(_){};setStatus('ADS-B disabled.');updateButtons()}
  window.enableTakMapAdsbLocal=function(){setLocalDisabled(false);try{if(state&&state.live)state.live.adsb_aircraft=true}catch(_){};setStatus('ADS-B enabled.');updateButtons();try{refreshAdsb()}catch(_){}}
  window.setAdsbOtsJobDisabled=async function(disable){const ids=['adsbDisableOtsJobBtn','adsbEnableOtsJobBtn'];ids.forEach(id=>{const b=field(id);if(b)b.disabled=true});try{setStatus(disable?'Disabling OTS Job...':'Enabling OTS Job...');const r=await fetch('/api/tak-map/adsb-ots-job',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:disable?'disable':'enable'})});const j=await r.json();if(j.ok){localStorage.setItem('takmap.adsb.otsJobDisabled',disable?'1':'0');setStatus(j.message|| (disable?'OTS Job disabled.':'OTS Job enabled.'))}else{setStatus(j.message||j.error||'OTS Job update failed.')}}catch(e){setStatus('OTS Job update failed: '+e)}finally{ids.forEach(id=>{const b=field(id);if(b)b.disabled=false});updateButtons()}}
  window.toggleTakMapAdsbLocal=function(){localDisabled()?window.enableTakMapAdsbLocal():window.disableTakMapAdsbLocal()}
  window.toggleAdsbOtsJob=function(){window.setAdsbOtsJobDisabled(!otsDisabled())}
  const prevRefresh=window.refreshAdsb;window.refreshAdsb=async function(){if(localDisabled()){try{if(window.aircraftLayer)aircraftLayer.clearLayers();const el=field('adsbStatus');if(el)el.textContent='disabled'}catch(_){}return []}return prevRefresh?prevRefresh.apply(this,arguments):[]}
  function boot(){try{css();clearOldText();ensureApplyButton();ensureAdsbControls();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v268 boot failed',e)}}
  boot();if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,350));else setTimeout(boot,350);setTimeout(boot,1300);setInterval(()=>{try{clearOldText();ensureApplyButton();ensureAdsbControls();updateButtons()}catch(_){}},1000);
})();
</script></body></html>""")
