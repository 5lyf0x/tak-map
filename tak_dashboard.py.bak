n featurePopupHtml(sourceName,props,extra){const rows=usefulProps(props,14);let html=`<div class="feature-popup"><h3>${esc(sourceName||\'External source\')}</h3><div class="kvp">`;if(extra){for(const [k,v] of Object.entries(extra)){html+=`<b>${esc(k)}</b><span>${esc(v)}</span>`}}if(rows.length){for(const [k,v] of rows){html+=`<b>${esc(niceKey(k))}</b><span>${esc(v)}</span>`}}else{html+=\'<b>Details</b><span>No feature attributes exposed.</span>\'}html+=\'</div></div>\';return html}function renderExternalRows(){const groups=groupBy(config.external_layers||[],\'group\');let html=\'\';for(const [g,items] of Object.entries(groups)){const filtered=items.filter(i=>visibleText(g+\' \'+i.label+\' \'+i.type));if(!filtered.length)continue;html+=`<div class="subgroup"><div class="subgroup-title">${esc(g)}</div>`+filtered.map(i=>`<div class="row"><label><input type="checkbox" ${state.external[i.id]?\'checked\':\'\'} onchange="toggleExternal(\'${esc(i.id)}\',this.checked)"><span>${esc(i.label)}<small>${esc(i.type)} · ${String(i.type||\'\').toLowerCase().includes(\'mapserver\')?\'tile-only popup note\':\'feature details popup\'}</small></span></label></div>`).join(\'\')+\'</div>\'}document.getElementById(\'externalRows\').innerHTML=html||\'<div class="muted">No default external sources. Import KML/KMZ/GPX/GeoJSON/Shapefile files above to add local external layers.</div>\'}function externalById(id){return (config.external_layers||[]).find(x=>x.id===id)}function toggleExternal(id,on){state.external[id]=on;const item=externalById(id);if(!item)return;if(!on){if(externalLayers[id]){map.removeLayer(externalLayers[id]);delete externalLayers[id]}return}const type=String(item.type||\'\').toLowerCase();if(type.includes(\'mapserver\')||type===\'xyz\'){const url=String(item.url||\'\').replace(/\\/$/,\'\')+\'/tile/{z}/{y}/{x}\';const lyr=L.tileLayer(url,{maxZoom:18,opacity:.72,attribution:item.label}).addTo(map);lyr._takTileOnly=true;lyr._takLabel=item.label;externalLayers[id]=lyr;const note=