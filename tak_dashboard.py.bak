load-browser-item:hover{border-color:var(--accent)}.upload-browser-empty{color:var(--muted);padding:6px}.upload-result{margin-top:10px;white-space:pre-wrap}.upload-lock-row{grid-column:1/-1;display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin:8px 0}.upload-lock-row input{background:#101820;color:var(--text);border:1px solid var(--line);border-radius:999px;padding:8px 11px;min-width:160px}.history-tabs{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}.history-tab{border-radius:999px}.history-tab.active{background:rgba(255,106,42,.25);border-color:rgba(255,106,42,.7)}#commandHistoryOutput{height:500px;min-height:500px;max-height:500px;white-space:pre-wrap}@media(max-width:700px){.section-head{align-items:stretch;flex-direction:column}.inline-config{justify-content:flex-start}.inline-config input{min-width:0;flex:1 1 130px}.cmd-input{min-width:0!important;max-width:100%!important;flex:1 1 100%!important}.upload-grid{grid-template-columns:1fr;justify-content:stretch}.upload-file-field,.upload-destination-field,.upload-grid input[type=file],.upload-grid select,.upload-dest-row #uploadDestLabel,.upload-dest-row #uploadDestPath{max-width:100%;width:100%}.upload-grid #uploadButton{width:152px;min-width:152px;max-width:152px}.upload-dest-row{grid-template-columns:1fr;justify-content:stretch}.upload-lock-row input{min-width:0;flex:1 1 130px}.warning-toggle-grid{grid-template-columns:1fr;max-height:45vh}.top-control-row{gap:8px}}.cert-setup-btn{background:linear-gradient(180deg,#ff9b32,#c45d12)!important;border-color:#ffb15f!important;color:#fff!important;box-shadow:0 0 14px rgba(255,106,42,.22);white-space:nowrap}.floating-cert-btn{order:0;position:relative;z-index:2147483647!important}.cert-modal-backdrop{display:none;position:fixed;z-index:2147483600;inset:0;background:rgba(0,0,0,.68);padding:18px;overflow:auto}.cert-modal-backdrop.active{display:block}.cert-modal{max-width:820px;margin:5vh auto;background:#111922;border:1px solid var(--line);border-radius:16px;padding:16px;box-shadow:0 22px 60px rgba(0,0,0,.65)}.cert-modal-head{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:10px}.cert-modal-head h2{margin:0;font-size:1rem;letter-spacing:.06em;text-transform:uppercase}.cert-grid{display:grid;grid-template-columns:1fr;gap:10px}.cert-grid textarea,.cert-grid input{width:100%;background:#101820;color:var(--text);border:1px solid var(--line);border-radius:10px;padding:9px 10px}.cert-pill-row{display:flex;flex-wrap:wrap;gap:6px}.cert-pill{display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line);border-radius:999px;padding:5px 8px;background:rgba(255,255,255,.025);font-size:.82rem}.cert-pill-x{border:0!important;background:rgba(255,95,87,.18)!important;color:var(--bad)!important;border-radius:999px!important;padding:1px 6px!important;margin:0!important;font-size:.72rem!important;line-height:1.2!important}.cert-pill-x:hover{background:rgba(255,95,87,.35)!important}.cert-actions{display:flex;flex-wrap:wrap;gap:8px;align-items:center}.cert-output{max-height:220px;overflow:auto;white-space:pre-wrap}.service-banner-cell{white-space:nowrap}.service-banner-cell label{display:inline-flex;align-items:center;gap:6px;font-size:.8rem;color:var(--muted)}.service-banner-cell input{accent-color:var(--accent)}@media(max-width:700px){.cert-modal{margin:2vh auto;padding:12px}.cert-modal-head{align-items:flex-start}.cert-actions button{width:100%;}.cert-setup-btn{font-size:.76rem;padding:7px 9px}.floating-cert-btn{font-size:.7rem!important;padding:6px 8px!important}}
/* Responsive desktop/tablet/mobile card layout update */
main{grid-template-columns:repeat(12,minmax(0,1fr));align-items:stretch}.card{min-width:0}.card.span-4,.card.span-6,.card.span-12{min-width:0}
@media(min-width:701px){main{align-items:stretch}.card{height:100%;display:flex;flex-direction:column}.card table,.card .kv,.card pre{flex:0 0 auto}.card.span-12{height:auto}}
@media(min-width:1200px){main{padding:16px;gap:14px}main>section{grid-column:auto}.span-4{grid-column:span 4}.span-6{grid-column:span 6}.span-12{grid-column:span 12}main>section:nth-of-type(1){grid-column:1/-1}main>section:nth-of-type(2),main>section:nth-of-type(3),main>section:nth-of-type(4){grid-column:span 4}main>section:nth-of-type(5){grid-column:span 8}main>section:nth-of-type(6){grid-column:span 4}.card h2{line-height:1.25}}
@media(min-width:701px) and (max-width:1199px){main{grid-template-columns:repeat(6,minmax(0,1fr));padding:12px;gap:10px}.span-4,.span-6,.span-12{grid-column:span 6}main>section:nth-of-type(1){grid-column:1/-1}main>section:nth-of-type(2){grid-column:span 6}main>section:nth-of-type(3),main>section:nth-of-type(4){grid-column:span 3}main>section:nth-of-type(5),main>section:nth-of-type(6){grid-column:span 6}main>section:nth-of-type(11),main>section:nth-of-type(12){grid-column:span 3}.kv{grid-template-columns:135px minmax(0,1fr)}}
@media(max-width:700px){main{display:grid;grid-template-columns:1fr!important;gap:10px;padding:8px}.span-4,.span-6,.span-12,main>section{grid-column:1/-1!important}.card{overflow:hidden}.card h2{font-size:.86rem;line-height:1.25}.kv{grid-template-columns:102px minmax(0,1fr);align-items:start}.section-controls{padding:8px 10px}.top-control-row{gap:8px}.inline-config{justify-content:flex-start}.inline-config input,.cmd-input{width:100%;max-width:100%!important;min-width:0!important}.upload-grid{grid-template-columns:1fr}.upload-dest-row{grid-template-columns:1fr}.upload-lock-row{display:grid;grid-template-columns:1fr;gap:8px;width:100%}button{min-height:42px}.cmd-button-grid{display:grid;grid-template-columns:1fr;gap:8px}.cmd-button-item{border-radius:12px;align-items:flex-start;flex-wrap:wrap}.cmd-button-item button{width:100%;margin-top:4px}pre{max-height:220px;font-size:.76rem}.cert-output{max-height:210px}.history-tabs{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch}.history-tabs button{white-space:nowrap}.cert-actions{display:grid;grid-template-columns:1fr;gap:8px}.cert-actions span{width:100%}.cert-actions a,.cert-actions button{width:100%}}
@media(max-width:420px){.kv{grid-template-columns:92px minmax(0,1fr)}button{min-height:40px}.card{padding:9px}.big{font-size:1.02rem}pre{font-size:.72rem}}
.server-gps-actions{display:flex;flex-wrap:wrap;align-items:center;gap:10px;margin-top:10px}.server-gps-btn{flex:0 0 242px;width:242px;max-width:100%;margin:0;text-align:center;white-space:nowrap}.server-gps-btn.push{border-color:rgba(255,95,87,.50)!important;color:#ffd7dc!important;background:linear-gradient(180deg,rgba(255,95,87,.16),rgba(255,95,87,.07))!important;box-shadow:0 0 14px rgba(255,95,87,.08)!important}@media(max-width:940px){.topology-open-btn{display:none!important}}
@media(max-width:700px){#commandHistoryOutput{height:440px;min-height:440px;max-height:440px}.server-gps-btn{flex:0 0 242px;width:242px;max-width:100%}}
/* Fixed-width action button rows for dashboard cards */
.card-action-buttons{display:flex;flex-wrap:wrap;align-items:flex-start;gap:8px;margin-top:10px}.card-action-buttons button{flex:0 0 220px;width:220px;max-width:100%;margin:0;text-align:center}.card-action-buttons.card-action-buttons-danger button{flex-basis:210px;width:210px}@media(max-width:700px){.card-action-buttons{gap:8px}.card-action-buttons button,.card-action-buttons.card-action-buttons-danger button{flex:0 0 210px;width:210px;max-width:100%;min-height:42px}}@media(max-width:260px){.card-action-buttons button,.card-action-buttons.card-action-buttons-danger button{flex-basis:100%;width:100%}}

.topology-open-btn{margin-left:auto;border-color:rgba(255,106,42,.62);background:linear-gradient(180deg,rgba(255,106,42,.18),rgba(255,106,42,.07));color:#ffd0b0;white-space:nowrap}.topology-open-btn:hover{background:rgba(255,106,42,.16);color:#fff}.topology-backdrop{position:fixed;inset:0;z-index:20;display:none;align-items:center;justify-content:center;padding:18px;background:rgba(0,0,0,.72);backdrop-filter:blur(5px)}.topology-backdrop.open{display:flex}.topology-modal{width:min(1180px,calc(100vw - 28px));max-height:calc(100vh - 34px);overflow:hidden;display:flex;flex-direction:column;border:1px solid rgba(255,106,42,.36);border-radius:18px;background:rgba(12,17,23,.97);box-shadow:0 30px 90px rgba(0,0,0,.65),0 0 34px rgba(255,106,42,.10)}.topology-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;padding:16px 18px 12px;border-bottom:1px solid rgba(255,255,255,.075)}.topology-head h2{margin:0 0 5px;font-size:1rem;letter-spacing:.08em;text-transform:uppercase}.topology-meta{display:flex;gap:8px;flex-wrap:wrap;color:var(--muted);font-size:.78rem}.topology-chip{border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:4px 8px;background:rgba(0,0,0,.16)}.topology-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;justify-content:flex-end}.topology-close{width:34px;height:34px;border-radius:11px;border:1px solid rgba(255,255,255,.12);background:rgba(0,0,0,.22);color:var(--muted);font-size:1.1rem;line-height:1}.topology-legend{display:flex;gap:10px;flex-wrap:wrap;padding:10px 18px;border-bottom:1px solid rgba(255,255,255,.06);color:var(--muted);font-size:.76rem}.topology-dot{display:inline-block;width:8px;height:8px;border-radius:99px;margin-right:4px;background:var(--muted)}.topology-dot.green{background:var(--good)}.topology-dot.orange{background:var(--warn)}.topology-dot.red{background:var(--bad)}.topology-dot.blue{background:#73c7ff}.topology-dot.gray{background:#6f7b86}.topology-canvas{position:relative;height:590px;min-height:590px;overflow:hidden;background:linear-gradient(90deg,rgba(255,255,255,.030) 1px,transparent 1px),linear-gradient(0deg,rgba(255,255,255,.024) 1px,transparent 1px),radial-gradient(circle at 50% 48%,rgba(255,106,42,.075),transparent 48%),#080d13;background-size:36px 36px,36px 36px,auto,auto}.topology-lines{position:absolute;inset:0;width:100%;height:100%;pointer-events:none}.topo-line-good{stroke:rgba(57,217,138,.54);stroke-width:1.8}.topo-line-mid{stroke:rgba(255,204,102,.50);stroke-width:1.8;stroke-dasharray:6 5}.topo-line-bad{stroke:rgba(255,95,87,.50);stroke-width:1.8;stroke-dasharray:3 5}.topo-line-info{stroke:rgba(115,199,255,.45);stroke-width:1.8}.topo-line-muted{stroke:rgba(142,160,173,.28);stroke-width:1.3;stroke-dasharray:5 7}.topology-node{position:absolute;transform:translate(-50%,-50%);min-width:102px;max-width:142px;border:1px solid rgba(255,255,255,.13);border-radius:11px;background:linear-gradient(180deg,rgba(255,255,255,.045),rgba(0,0,0,.10)),#101820;padding:6px 7px;box-shadow:0 12px 26px rgba(0,0,0,.30),0 0 12px rgba(255,106,42,.045);z-index:2}.topology-node.main{min-width:150px;max-width:170px;border-color:rgba(255,106,42,.72);box-shadow:0 0 22px rgba(255,106,42,.18),0 12px 28px rgba(0,0,0,.34)}.topology-node.zone{border-color:rgba(115,199,255,.25);background:linear-gradient(180deg,rgba(115,199,255,.045),rgba(0,0,0,.10)),#101820}.topology-node.small{min-width:92px;max-width:118px;padding:5px 6px}.topology-node.more{border-style:dashed;color:var(--muted)}.topology-title{display:flex;align-items:center;gap:5px;font-size:.64rem;font-weight:900;text-transform:uppercase;letter-spacing:.045em;margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-icon{width:15px;height:15px;min-width:15px;display:inline-flex;align-items:center;justify-content:center;border:1px solid rgba(255,139,77,.36);border-radius:5px;color:#ffd0bb;background:rgba(255,106,42,.07);font-size:.56rem}.topology-sub{font-size:.61rem;color:var(--muted);line-height:1.22;word-break:break-word}.topology-status{margin-top:4px;display:inline-flex;align-items:center;font-size:.60rem;color:#dce7ee;max-width:100%;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-foot{color:#b8c6d0;font-size:.76rem;line-height:1.4;padding:12px 18px 16px;border-top:1px solid rgba(255,255,255,.06)}.topology-empty{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);color:var(--muted);text-align:center;border:1px dashed rgba(255,255,255,.16);border-radius:14px;padding:16px 18px;background:rgba(0,0,0,.18)}

/* v96 topology grouped tactical hub refinements */
.topology-modal{width:min(1200px,calc(100vw - 28px))}.topology-canvas{height:660px;min-height:660px;padding:0;background:linear-gradient(90deg,rgba(255,255,255,.030) 1px,transparent 1px),linear-gradient(0deg,rgba(255,255,255,.024) 1px,transparent 1px),radial-gradient(circle at 50% 44%,rgba(255,106,42,.07),transparent 50%),#080d13;background-size:36px 36px,36px 36px,auto,auto}.topo-line-good{stroke:rgba(57,217,138,.42);stroke-width:1.25}.topo-line-mid{stroke:rgba(255,204,102,.38);stroke-width:1.2;stroke-dasharray:5 6}.topo-line-bad{stroke:rgba(255,95,87,.46);stroke-width:1.2;stroke-dasharray:3 5}.topo-line-info{stroke:rgba(115,199,255,.38);stroke-width:1.25}.topo-line-muted{stroke:rgba(142,160,173,.20);stroke-width:1;stroke-dasharray:5 7}.topo-line-backbone{stroke:rgba(255,106,42,.30);stroke-width:1.1;stroke-dasharray:2 8}.topology-path-row{position:absolute;left:58px;right:58px;top:24px;display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}.topology-server-wrap{position:absolute;left:50%;top:188px;transform:translateX(-50%)}.topology-zone-row{position:absolute;left:28px;right:28px;top:346px;display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.topology-node{position:relative;transform:none;left:auto;top:auto;min-width:0;max-width:none}.topology-node.path{min-height:92px}.topology-node.main{width:230px;min-width:230px;max-width:230px;min-height:114px}.topology-node.zone{min-height:270px}.topology-title{font-size:.66rem}.topology-sub{font-size:.62rem}.topology-zone-list{margin-top:10px;border-top:1px solid rgba(255,255,255,.06);padding-top:7px}.topology-device{display:flex;align-items:center;justify-content:space-between;gap:7px;border:1px solid rgba(255,255,255,.055);border-radius:8px;background:rgba(0,0,0,.14);padding:5px 6px;margin-top:5px;font-size:.62rem;color:#dfe9f0;cursor:help}.topology-device .dev-main{min-width:0;display:flex;flex-direction:column;gap:1px}.topology-device .dev-name{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:780}.topology-device .dev-ip{color:var(--muted);font-size:.58rem}.topology-device .dev-type{color:#9baab6;white-space:nowrap;font-size:.58rem}.topology-device.stale{opacity:.72;border-style:dashed}.topology-device.more{color:#ffd0bb;border-color:rgba(255,106,42,.20);background:rgba(255,106,42,.05)}.topology-node-detail{position:absolute;z-index:35;display:none;min-width:260px;max-width:340px;border:1px solid rgba(255,106,42,.38);border-radius:12px;background:rgba(8,13,19,.97);box-shadow:0 20px 52px rgba(0,0,0,.55),0 0 22px rgba(255,106,42,.10);padding:10px 11px;color:var(--text);font-size:.74rem;line-height:1.35}.topology-node-detail.open{display:block}.topology-node-detail b{color:#ffd0b0}.topology-node-detail .muted{color:var(--muted)}.topology-scan-hint{position:absolute;left:18px;right:18px;bottom:12px;color:#b8c6d0;font-size:.72rem;line-height:1.35;text-align:center}.topology-actions button:nth-child(2){border-color:rgba(115,199,255,.45);color:#d5efff;background:rgba(115,199,255,.07)}body.topology-open #floatingModeCluster{display:none!important}.topology-scan-package-note{margin-top:7px;color:rgba(184,198,208,.74);font-size:.68rem;line-height:1.28}.topology-backdrop{z-index:2147483500!important}@media(max-width:940px){.topology-canvas{height:auto;min-height:auto;padding:14px}.topology-path-row,.topology-server-wrap,.topology-zone-row{position:relative;left:auto;right:auto;top:auto;transform:none;display:grid;grid-template-columns:1fr;gap:10px;margin-bottom:10px}.topology-node.main{width:100%;min-width:0;max-width:none}.topology-node.zone{min-height:0}.topology-lines{display:none}.topology-scan-hint{position:relative;left:auto;right:auto;bottom:auto;margin-top:8px}.topology-node-detail{position:fixed;left:16px!important;right:16px;top:auto!important;bottom:16px;max-width:none}}

/* v103 four-point topology anchor routing */
.topology-modal{width:min(1220px,calc(100vw - 28px));max-height:calc(100vh - 34px)}
.topology-canvas{position:relative;height:min(690px,calc(100vh - 215px));min-height:520px;overflow:auto;background:radial-gradient(circle at 28% 42%,rgba(255,106,42,.14),transparent 36%),radial-gradient(circle at 78% 58%,rgba(255,204,102,.08),transparent 34%),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(0deg,rgba(255,255,255,.028) 1px,transparent 1px),#091016;background-size:auto,auto,34px 34px,34px 34px,auto;scrollbar-color:rgba(255,106,42,.45) rgba(255,255,255,.04)}
.topology-map{position:relative;min-width:1180px;min-height:660px;overflow:hidden}.topology-map:after{content:"";position:absolute;left:-5%;right:-5%;bottom:-18%;height:260px;background:radial-gradient(ellipse at center,rgba(255,106,42,.10),transparent 65%),repeating-radial-gradient(ellipse at center,rgba(255,255,255,.12) 0 2px,transparent 3px 16px);opacity:.22;filter:blur(.4px);pointer-events:none}.topology-map svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1}.topo-map-solid{stroke:rgba(255,220,190,.78);stroke-width:1.55;fill:none;stroke-linecap:round}.topo-map-branch{stroke:rgba(255,220,190,.68);stroke-width:1.25;fill:none;stroke-linecap:round}.topo-map-dashed{stroke:rgba(255,204,102,.78);stroke-width:1.3;fill:none;stroke-dasharray:5 7;stroke-linecap:round}.topo-map-overlay{stroke:rgba(115,199,255,.72);stroke-width:1.3;fill:none;stroke-dasharray:3 6;stroke-linecap:round}.topo-map-stale{stroke:rgba(255,95,87,.48);stroke-width:1.1;fill:none;stroke-dasharray:3 7;stroke-linecap:round}.topo-map-faint{stroke:rgba(255,220,190,.25);stroke-width:1;fill:none;stroke-dasharray:3 8;stroke-linecap:round}.topology-map-node{position:absolute;transform:translate(-50%,-50%);display:flex;align-items:center;gap:9px;min-width:120px;max-width:178px;padding:8px 10px;border-radius:999px;border:1px solid rgba(255,122,34,.35);background:rgba(16,24,31,.82);backdrop-filter:blur(6px);color:#ffd0b2;box-shadow:0 12px 30px rgba(0,0,0,.32);z-index:5;cursor:help}.topology-map-node:hover{border-color:rgba(255,106,42,.72);box-shadow:0 0 0 1px rgba(255,106,42,.20),0 0 22px rgba(255,106,42,.12),0 12px 30px rgba(0,0,0,.40)}.topology-map-node.server{min-width:190px;max-width:235px;border-radius:16px;padding:11px 13px;border-color:rgba(255,106,42,.86);box-shadow:0 0 28px rgba(255,106,42,.20),0 16px 32px rgba(0,0,0,.36)}.topology-map-node.core{border-color:rgba(255,220,190,.52)}.topology-map-node.mid{border-color:rgba(255,204,102,.42)}.topology-map-node.overlay{border-color:rgba(115,199,255,.44);color:#d5efff}.topology-map-node.stale{border-color:rgba(255,95,87,.45);color:#ffd2d2}.topology-map-node.more{border-style:dashed;color:var(--muted)}.topology-map-icon{width:24px;height:24px;border-radius:9px;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;flex:0 0 auto;font-size:13px;opacity:.92;background:rgba(255,106,42,.07)}.topology-map-node.server .topology-map-icon{width:25px;height:25px}.topology-map-copy{min-width:0}.topology-map-name{display:block;font-size:.68rem;font-weight:900;letter-spacing:.045em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-map-ip{display:block;margin-top:2px;font-size:.62rem;opacity:.72;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-map-status{width:8px;height:8px;border-radius:99px;margin-left:auto;flex:0 0 auto;background:var(--good)}.topology-map-status.orange{background:var(--warn)}.topology-map-status.blue{background:#73c7ff}.topology-map-status.red{background:var(--bad)}.topology-map-status.gray{background:#7d8a94}.topology-map-label{position:absolute;font-size:.66rem;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:#ffd0b2;opacity:.72;z-index:3}.topology-map-metric{position:absolute;font-size:.66rem;font-weight:700;color:#ffd0b2;opacity:.76;letter-spacing:.02em;z-index:3}.topology-map-junction{position:absolute;width:11px;height:11px;margin-left:-5.5px;margin-top:-5.5px;border-radius:99px;border:1px solid rgba(255,220,190,.72);background:#0d151c;box-shadow:0 0 14px rgba(255,106,42,.20);z-index:4}.topology-map-junction.blue{border-color:rgba(115,199,255,.72);box-shadow:0 0 14px rgba(115,199,255,.18)}.topology-node-detail{z-index:2147483600!important}.topology-map-foot{position:absolute;left:18px;right:18px;bottom:12px;font-size:.72rem;opacity:.72;display:flex;justify-content:space-between;gap:16px;z-index:3;color:#dfe9f0}.topology-scan-hint{position:relative!important;left:auto!important;right:auto!important;bottom:auto!important;margin-top:0!important;color:#b8c6d0;font-size:.72rem;line-height:1.35;text-align:center}.topology-foot .topology-scan-package-note{margin-top:7px;color:rgba(184,198,208,.74);font-size:.68rem;line-height:1.28}@media(max-width:940px){.topology-canvas{height:min(720px,calc(100vh - 205px));min-height:520px;padding:0}.topology-map{min-width:1050px;min-height:700px}.topology-map-foot{display:none}.topology-node-detail{position:fixed;left:16px!important;right:16px;top:auto!important;bottom:16px;max-width:none}}


/* v103 four-point topology anchor routing */
.topology-modal{width:min(1230px,calc(100vw - 28px));max-height:calc(100vh - 34px)}
.topology-actions button{padding:8px 10px;font-size:.72rem;white-space:nowrap}.topology-actions button:nth-child(2){border-color:rgba(115,199,255,.45);color:#d5efff;background:rgba(115,199,255,.07)}.topology-actions button:nth-child(3){border-color:rgba(255,255,255,.18);background:rgba(255,255,255,.05)}
.topology-canvas{position:relative;height:min(710px,calc(100vh - 215px));min-height:540px;overflow:auto;background:radial-gradient(circle at 28% 42%,rgba(255,106,42,.14),transparent 36%),radial-gradient(circle at 78% 58%,rgba(255,204,102,.08),transparent 34%),linear-gradient(90deg,rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(0deg,rgba(255,255,255,.028) 1px,transparent 1px),#091016;background-size:auto,auto,34px 34px,34px 34px,auto;scrollbar-color:rgba(255,106,42,.45) rgba(255,255,255,.04)}
.topology-map{position:relative;min-width:1120px;min-height:710px;overflow:hidden}.topology-map:after{content:"";position:absolute;left:-5%;right:-5%;bottom:-16%;height:260px;background:radial-gradient(ellipse at center,rgba(255,106,42,.10),transparent 65%),repeating-radial-gradient(ellipse at center,rgba(255,255,255,.12) 0 2px,transparent 3px 16px);opacity:.20;filter:blur(.4px);pointer-events:none;z-index:0}.topology-map svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1}.topology-map-node{position:absolute;transform:none!important;display:flex;align-items:center;gap:9px;min-width:122px;max-width:185px;padding:8px 10px;border-radius:999px;border:1px solid rgba(255,122,34,.35);background:rgba(16,24,31,.84);backdrop-filter:blur(6px);color:#ffd0b2;box-shadow:0 12px 30px rgba(0,0,0,.32);z-index:4;user-select:none;touch-action:none;cursor:grab}.topology-map-node:active{cursor:grabbing}.topology-map-node:hover{border-color:rgba(255,106,42,.72);box-shadow:0 0 0 1px rgba(255,106,42,.20),0 0 22px rgba(255,106,42,.12),0 12px 30px rgba(0,0,0,.40)}.topology-map-node.dragging{z-index:20;border-color:rgba(255,255,255,.88);box-shadow:0 0 0 1px rgba(255,255,255,.24),0 0 30px rgba(255,106,42,.24),0 18px 40px rgba(0,0,0,.48)}.topology-map-node.overlap{border-color:rgba(255,95,87,.92)!important;box-shadow:0 0 0 1px rgba(255,95,87,.35),0 0 30px rgba(255,95,87,.20)!important}.topology-map-node.manual:after{content:"";position:absolute;right:-4px;top:-4px;width:8px;height:8px;border-radius:99px;background:#7d8a94;border:1px solid rgba(255,255,255,.5)}.topology-map-node.server{min-width:190px;max-width:235px;border-radius:16px;padding:11px 13px;border-color:rgba(255,106,42,.86);box-shadow:0 0 28px rgba(255,106,42,.20),0 16px 32px rgba(0,0,0,.36)}.topology-map-node.core{border-radius:16px;border-color:rgba(255,220,190,.52)}.topology-map-node.overlay{border-color:rgba(115,199,255,.44);color:#d5efff}.topology-map-node.mid{border-color:rgba(255,204,102,.42)}.topology-map-node.stale{border-color:rgba(255,95,87,.45);color:#ffd2d2}.topology-map-node.more{border-style:dashed;color:var(--muted)}.topology-map-icon{width:24px;height:24px;border-radius:9px;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;flex:0 0 auto;font-size:13px;opacity:.92;background:rgba(255,106,42,.07)}.topology-map-node.server .topology-map-icon{width:25px;height:25px}.topology-map-copy{min-width:0}.topology-map-name{display:block;font-size:.68rem;font-weight:900;letter-spacing:.045em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-map-ip{display:block;margin-top:2px;font-size:.62rem;opacity:.72;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.topology-map-status{width:8px;height:8px;border-radius:99px;margin-left:auto;flex:0 0 auto;background:var(--good)}.topology-map-status.orange{background:var(--warn)}.topology-map-status.blue{background:#73c7ff}.topology-map-status.red{background:var(--bad)}.topology-map-status.gray{background:#7d8a94}.topology-map-junction{position:absolute;width:12px;height:12px;margin-left:-6px;margin-top:-6px;border-radius:99px;border:1px solid rgba(255,220,190,.72);background:#0d151c;box-shadow:0 0 14px rgba(255,106,42,.20);z-index:3;pointer-events:none}.topology-map-junction.blue{border-color:rgba(115,199,255,.72);box-shadow:0 0 14px rgba(115,199,255,.18)}.topology-map-label{position:absolute;font-size:.66rem;font-weight:900;letter-spacing:.12em;text-transform:uppercase;color:#ffd0b2;opacity:.72;z-index:3;pointer-events:none}.topology-map-metric{position:absolute;font-size:.66rem;font-weight:700;color:#ffd0b2;opacity:.76;letter-spacing:.02em;z-index:3;pointer-events:none}.topology-map-foot{position:absolute;left:18px;right:18px;bottom:12px;font-size:.72rem;opacity:.72;display:flex;justify-content:space-between;gap:16px;z-index:3;color:#dfe9f0;pointer-events:none}.topology-node-detail{position:absolute;z-index:2147483600!important}.topology-node-detail.open{display:block}.topology-map-node-detail-title{font-weight:900;color:#ffd0b0;text-transform:uppercase;letter-spacing:.05em;margin-bottom:7px}.topology-layout-warning{color:#ffd0d0!important}.topology-scan-package-note{margin-top:7px;color:rgba(184,198,208,.74);font-size:.68rem;line-height:1.28}@media(max-width:940px){.topology-canvas{height:min(740px,calc(100vh - 205px));min-height:540px;padding:0}.topology-map{min-width:1050px;min-height:740px}.topology-map-foot{display:none}.topology-node-detail{position:fixed!important;left:16px!important;right:16px!important;top:auto!important;bottom:16px!important;max-width:none!important}.topology-actions{gap:6px}.topology-actions button{font-size:.68rem;padding:7px 8px}}


/* v103 topology four-point anchors and snap grid */
.topology-map-node.manual:after{display:none!important}
#topologySnapGridBtn.topology-snap-active{border-color:rgba(57,217,138,.55);background:rgba(57,217,138,.09);color:#e7fff1}
.topology-map-node{cursor:grab}.topology-map-node:active{cursor:grabbing}
.topology-map-status{box-shadow:0 0 8px currentColor}


/* v105 topology popup no internal scroll */
.topology-canvas{overflow:hidden!important}
.topology-map{width:100%!important;height:100%!important;min-width:0!important;min-height:0!important;overflow:hidden!important}
.topology-map-foot{bottom:10px}
/* v106 topology label simplification */
.topology-map-ip{display:none!important}
.topology-map-copy{display:flex;align-items:center;min-width:0}
.topology-map-name{margin-top:0}
.topology-map-node{min-width:112px;max-width:170px}
.topology-map-node.server{min-width:150px;max-width:210px}

/* v120 TAK Map install/auth robustness */
.status{display:inline-flex;width:fit-content;max-width:100%;align-self:flex-start;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:5px 10px;background:rgba(8,12,18,.48);font-size:.78rem;font-weight:900;letter-spacing:.065em;text-transform:uppercase;white-space:nowrap;box-shadow:inset 0 0 0 1px rgba(255,255,255,.025)}
.status .dot{width:9px;height:9px;border-radius:50%;display:inline-block;flex:0 0 auto;background:var(--muted)}
.status.good{border-color:rgba(57,217,138,.38);background:rgba(57,217,138,.07);color:var(--good)}.status.warn{border-color:rgba(255,204,102,.42);background:rgba(255,204,102,.08);color:var(--warn)}.status.bad{border-color:rgba(255,95,87,.42);background:rgba(255,95,87,.08);color:var(--bad)}.status.unknown{border-color:rgba(142,160,173,.32);background:rgba(142,160,173,.06);color:var(--muted)}
.status.good .dot{background:var(--good);box-shadow:0 0 8px rgba(57,217,138,.7)}.status.warn .dot{background:var(--warn);box-shadow:0 0 8px rgba(255,204,102,.55)}.status.bad .dot{background:var(--bad);box-shadow:0 0 8px rgba(255,95,87,.62)}.status.unknown .dot{background:var(--muted);box-shadow:none}
.internet-card-polished{grid-column:span 4}.internet-layout{display:grid;grid-template-columns:minmax(0,1fr) minmax(235px,43%);gap:12px;align-items:start}.internet-left .kv{margin-top:10px}.internet-graphs{display:grid;gap:12px}.net-history-panel{border:1px solid rgba(255,255,255,.085);border-radius:12px;background:rgba(7,10,15,.44);padding:10px 12px 9px;min-height:130px}.net-history-head{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:6px}.net-history-title{font-size:.66rem;color:var(--muted);font-weight:900;letter-spacing:.10em;text-transform:uppercase}.net-history-value{font-size:.86rem;font-weight:900;color:var(--text);white-space:nowrap}.net-history-chart{width:100%;height:74px;display:block;border-radius:9px;background:linear-gradient(180deg,rgba(255,255,255,.025),rgba(255,255,255,.01));border:1px solid rgba(255,255,255,.055)}.net-history-foot{display:flex;align-items:center;justify-content:space-between;color:rgba(142,160,173,.72);font-size:.66rem;margin-top:5px}.net-history-foot .live{font-weight:900;text-transform:uppercase}.download-value{color:var(--good)!important}.upload-value{color:#ff8b4d!important}.cert-expiry-grid{display:grid;gap:8px;margin-top:6px}.cert-expiry-item{display:flex;align-items:center;justify-content:space-between;gap:10px;border:1px solid rgba(255,255,255,.08);border-radius:12px;background:rgba(7,10,15,.36);padding:9px 10px}.cert-expiry-name{font-weight:850;color:var(--text)}.cert-expiry-date{color:var(--muted);font-size:.76rem;margin-top:2px}.cert-expiry-badge{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:4px 8px;border:1px solid rgba(142,160,173,.35);font-size:.72rem;font-weight:900;letter-spacing:.04em;text-transform:uppercase;white-space:nowrap}.cert-expiry-badge:before{content:"";width:8px;height:8px;border-radius:99px;background:var(--muted)}.cert-expiry-badge.good{color:var(--good);border-color:rgba(57,217,138,.40);background:rgba(57,217,138,.07)}.cert-expiry-badge.good:before{background:var(--good)}.cert-expiry-badge.warn{color:var(--warn);border-color:rgba(255,204,102,.44);background:rgba(255,204,102,.08)}.cert-expiry-badge.warn:before{background:var(--warn)}.cert-expiry-badge.bad,.cert-expiry-badge.expired{color:var(--bad);border-color:rgba(255,95,87,.44);background:rgba(255,95,87,.08)}.cert-expiry-badge.bad:before,.cert-expiry-badge.expired:before{background:var(--bad)}.cert-expiry-badge.unknown,.cert-expiry-badge.missing{color:var(--muted)}
.cmd-maintenance-tools{grid-column:1/-1;border:1px solid rgba(255,106,42,.22);border-radius:13px;background:linear-gradient(180deg,rgba(255,106,42,.08),rgba(7,10,15,.30));padding:12px;margin-bottom:2px}.cmd-maintenance-head{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:8px}.cmd-maintenance-title{font-weight:900;letter-spacing:.06em;text-transform:uppercase;color:#ffd0b0}.cmd-maintenance-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap}.cmd-maintenance-actions input[type=file]{max-width:300px;color:var(--muted);border:1px solid var(--line);border-radius:10px;background:#101820;padding:7px 9px}.cmd-maintenance-note{color:var(--muted);font-size:.78rem;line-height:1.35}.cmd-maintenance-result{white-space:pre-wrap;color:#d7e0e7;font-size:.76rem;margin-top:8px;max-height:110px;overflow:auto;border-top:1px solid rgba(255,255,255,.06);padding-top:8px;display:none}.cmd-maintenance-result.active{display:block}
@media(max-width:1120px){.internet-layout{grid-template-columns:1fr}.internet-graphs{grid-template-columns:repeat(2,minmax(0,1fr))}.internet-card-polished{grid-column:span 6}.net-history-panel{min-height:118px}.net-history-chart{height:62px}}
@media(max-width:760px){.internet-card-polished{grid-column:span 12}.internet-graphs{grid-template-columns:1fr}.cmd-maintenance-head{align-items:flex-start}.cmd-maintenance-actions{width:100%}.cmd-maintenance-actions input[type=file]{max-width:100%;width:100%}}


@media(max-width:1024px){.tak-map-top-btn{display:none!important}}
</style></head><body class="privacy"><div id="floatingModeCluster" class="mode-cluster"><span class="release-version">1.1.0</span><button class="cert-setup-btn floating-cert-btn" onclick="openCertSetup()">Cert Setup</button><button class="privacy-toggle tak-map-top-btn" onclick="location.href='/tak-map/login'">TAK Map</button><span id="privacyModeText" class="privacy-mode-text">MODE: PRIVACY</span><button id="privacyToggle" class="privacy-toggle" onclick="togglePrivacyMode()">Normal Mode</button><button class="privacy-toggle" onclick="logoutDashboard()">Logout</button></div><header><div class="header-row"><div><h1>TAK Server Dash</h1><div class="subtitle" id="topline">Loading status...</div></div><div class="release-version" aria-label="Release version">1.1.0</div></div></header><div id="alertBanner" class="alert-banner" aria-live="polite"></div><div id="certModal" class="cert-modal-backdrop" onclick="certBackdropClick(event)"><div class="cert-modal"><div class="cert-modal-head"><h2>HTTPS Certificate Setup</h2><button onclick="closeCertSetup()">Close</button></div><div class="cert-grid"><p class="small">Generate a local dashboard CA and HTTPS server certificate for the current Pi addresses. Cert Setup installs the nginx server certificate/key, reloads nginx, and makes the client CA available through the Download CA Certificate button.</p><div><div class="small">Detected names / IPs included by default</div><div id="certDetected" class="cert-pill-row"><span class="cert-pill">Loading...</span></div></div><div><div class="small">Certificate expiration</div><div id="certExpiryStatus" class="cert-expiry-grid"><div class="cert-expiry-item"><div><div class="cert-expiry-name">Certificate status</div><div class="cert-expiry-date">Loading...</div></div><span class="cert-expiry-badge unknown">Unknown</span></div></div></div><div><div class="small">Optional extra hostnames or IPs, one per line</div><textarea id="certExtraSans" rows="4" placeholder="10.10.10.2&#10;takdash.local&#10;192.168.1.50"></textarea></div><div class="cert-actions"><button class="primary" onclick="generateCertSetup()">Generate / Regenerate Certificate</button><span style="display:inline-flex;flex-direction:column;gap:4px;align-items:flex-start"><a id="certDownloadLink" href="/ca-cert.crt" style="display:none"><button type="button">Download CA Certificate</button></a><span class="small" id="certDownloadHint" style="display:none">To download cert, right-click and select &quot;Save Link as..&quot;</span></span><button onclick="refreshCertSetup()">Refresh</button></div><pre id="certSetupOutput" class="cert-output small">Open this popup and generate the certificate. Then use Download CA Certificate for each laptop, phone, or tablet that should trust the dashboard.</pre></div></div></div><div id="topologyModal" class="topology-backdrop" onclick="topologyBackdropClick(event)"><div class="topology-modal" role="dialog" aria-modal="true" aria-labelledby="topologyTitle"><div class="topology-head"><div><h2 id="topologyTitle">Network Topology</h2><div class="topology-meta"><span class="topology-chip" id="topologyUpdated">Waiting for data</span><span class="topology-chip" id="topologyScanState">Passive mode</span><span class="topology-chip" id="topologyLayoutState">Auto layout</span></div></div><div class="topology-actions"><button id="topologySnapGridBtn" class="topology-snap-active" onclick="toggleTopologySnapGrid()">Snap Grid</button><button onclick="autoArrangeTopology()">Auto Arrange</button><button onclick="saveTopologyLayout()">Save Layout</button><button onclick="resetTopologyLayout()">Reset Layout</button><button onclick="refreshTopology()">Refresh</button><button onclick="scanTopologyDetails()">Scan for Details</button><button onclick="togglePrivacyMode();renderTopology(lastStatusPayload)">Privacy</button><button class="topology-close" onclick="closeTopologyModal()">×</button></div></div><div class="topology-legend"><span><span class="topology-dot green"></span>Online</span><span><span class="topology-dot orange"></span>Limited / standby</span><span><span class="topology-dot red"></span>Down / stale</span><span><span class="topology-dot blue"></span>Overlay</span><span><span class="topology-dot gray"></span>Inferred</span></div><div id="topologyCanvas" class="topology-canvas"><div class="topology-empty">Open after status data loads.</div></div><div class="topology-foot">Passive topology is shown by default. Stale devices remain in their last-known zone.<div class="topology-scan-package-note">Scan for Details uses optional <b>nmap</b> / <b>arp-scan</b> packages when installed.</div></div></div></div><main><section class="card span-12 section-controls" id="sectionControlsCard"><div class="top-control-row"><details class="section-details" id="sectionDetails"><summary><span>Dashboard Sections</span><span class="section-summary" id="sectionSummary">All visible</span></summary><div class="section-menu"><div class="section-toggle-grid" id="sectionToggleGrid"></div></div></details><details class="section-details" id="warningDetails"><summary><span>Banner Warnings</span><span class="section-summary" id="warningSummary">Default warnings</span></summary><div class="section-menu"><div class="warning-toggle-grid" id="warningToggleGrid"></div></div></details><button class="topology-open-btn" onclick="openTopologyModal()">Network Topology</button></div></section><section class="card span-12"><h2>System Health</h2><div class="kv"><div class="k">Uptime</div><div class="v" id="healthUptime">—</div><div class="k">Boot time</div><div class="v" id="healthBoot">—</div><div class="k">CPU load</div><div class="v" id="healthLoad">—</div><div class="k">CPU temp</div><div class="v cpu-temp-value" id="cpuCurrent">—</div><div class="k">CPU 24h high</div><div class="v cpu-temp-value" id="cpuHigh">—</div><div class="k">CPU high time</div><div class="v" id="cpuHighTime">—</div><div class="k">CPU 24h avg</div><div class="v" id="cpuAvg">—</div><div class="k">CPU 24h low</div><div class="v" id="cpuLow">—</div><div class="k">CPU freq.</div><div class="v" id="cpuFreq">—</div><div class="k">CPU samples</div><div class="v" id="cpuSamples">—</div><div class="k">RAM</div><div class="v" id="healthRam">—</div><div class="k">Disk</div><div class="v" id="healthDisk">—</div><div class="k">Voltage</div><div class="v" id="powerVoltage">—</div><div class="k power-current-row">Current</div><div class="v power-current-row" id="powerCurrent">—</div><div class="k power-runtime-row">Runtime est.</div><div class="v power-runtime-row" id="powerRuntime">—</div>
</div><div style="height:1em"></div><div class="small">CPU 24h stats begin collecting after dashboard install/start.</div></section><section class="card span-4 internet-card-polished"><h2>Internet</h2><div class="internet-layout"><div class="internet-left"><div id="internetBadge" class="status"><span class="dot"></span><span>Loading</span></div><div class="kv"><div class="k">IP ping</div><div class="v" id="pingIp">—</div><div class="k">DNS lookup</div><div class="v" id="dnsLookup">—</div><div class="k">Internet Source</div><div class="v" id="netIface">—</div><div class="k">Live download</div><div class="v bandwidth-value download-value" id="netDown">—</div><div class="k">Live upload</div><div class="v bandwidth-value upload-value" id="netUp">—</div><div class="k">4G/LTE state</div><div class="v" id="lteState">—</div><div class="k">4G/LTE bars</div><div class="v big" id="lteBars">—</div><div class="k">4G/LTE signal</div><div class="v" id="lteSignal">—</div><div class="k">4G/LTE tech</div><div class="v" id="lteTech">—</div><div class="k">4G/LTE operator</div><div class="v" id="lteOperator">—</div></div><div class="small" id="lteNote"></div></div><div class="internet-graphs"><div class="net-history-panel"><div class="net-history-head"><span class="net-history-title">Download history</span><span class="net-history-value download-value" id="netDownGraphValue">—</span></div><canvas id="netDownHistory" class="net-history-chart" width="300" height="92"></canvas><div class="net-history-foot"><span id="netDownHistoryWindow">collecting samples</span><span class="live download-value">live</span></div></div><div class="net-history-panel"><div class="net-history-head"><span class="net-history-title">Upload history</span><span class="net-history-value upload-value" id="netUpGraphValue">—</span></div><canvas id="netUpHistory" class="net-history-chart" width="300" height="92"></canvas><div class="net-history-foot"><span id="netUpHistoryWindow">collecting samples</span><span class="live upload-value">live</span></div></div></div></div></section><section class="card span-6"><h2>Wi-Fi / HaLow Connection</h2><div class="kv"><div class="k">SSID</div><div class="v sensitive" id="wifiSsid">—</div><div class="k">Device</div><div class="v">wlan0</div><div class="k">Radio band</div><div class="v" id="wifiRadioBand">—</div><div class="k">IP address</div><div class="v sensitive" id="wifiIp">—</div><div class="k">Subnet mask</div><div class="v sensitive" id="wifiMask">—</div><div class="k">Gateway</div><div class="v sensitive" id="wifiGateway">—</div><div class="k">Gateway Capability</div><div class="v" id="wifiGatewayCapability">—</div><div class="k">WiFi reception</div><div class="v"><span class="big" id="wifiBars">—</span> <span id="wifiSignal"></span></div></div></section><section class="card span-12"><h2>Interfaces</h2><table><thead><tr><th>Interface</th><th>State</th><th>IPv4</th></tr></thead><tbody id="ifaceRows"></tbody></table><div class="small" style="font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin:14px 0 8px;color:var(--muted)">Network Latency</div><table><thead><tr><th>Target</th><th>Host/IP</th><th>Status</th><th>Latency</th><th>Note</th></tr></thead><tbody id="latRows"></tbody></table></section><section class="card span-4"><h2>Server GPS</h2><p class="small">Use <b>Pull GPS</b> to enable/check modem GPS, wait up to 5 minutes for a fix, and display the server location locally. Telit/LE910 modems that report GPS already enabled are polled directly. Use <b>Push GPS to TAK Server</b> only when you want to publish a 5-minute CoT marker to TAK Server.</p><div class="kv"><div class="k">Status</div><div class="v" id="gpsStatus">Not pulled</div><div class="k">Latitude</div><div class="v sensitive" id="gpsLat">—</div><div class="k">Longitude</div><div class="v sensitive" id="gpsLon">—</div><div class="k">Altitude</div><div class="v" id="gpsAlt">—</div><div class="k">Accuracy</div><div class="v" id="gpsAccuracy">—</div><div class="k">Source</div><div class="v" id="gpsSource">—</div><div class="k">Fix time</div><div class="v" id="gpsTime">—</div><div class="k">CoT Push</div><div class="v" id="gpsPushStatus">Not pushed</div></div><div class="server-gps-actions"><button class="primary server-gps-btn" onclick="pullModemGps()">Pull GPS</button><button class="server-gps-btn push" onclick="pushModemGps()">Push GPS to TAK Server</button></div><div class="small" id="gpsNote" style="margin-top:8px">Requires a modem/GNSS source exposed through ModemManager, serial AT/NMEA ports, or gpsd. Pull/Push enables or checks modem GPS when supported, waits up to 5 minutes, and disables it after a successful fix; after a no-fix timeout, GPS is left enabled by default so the modem can keep acquiring for the next pull. Telit/LE910 GPS already-on status is accepted before polling AT$GPSACP. CoT push defaults to local TAK Server TCP ingest at 127.0.0.1:8088 and expires after 5 minutes.</div><pre id="gpsOutput" class="cert-output small" style="margin-top:8px;max-height:180px">GPS diagnostics will appear here after Pull GPS or Push GPS.</pre></section><section class="card span-12"><div class="section-head"><h2>Network Neighbors</h2><label class="header-checkbox"><input type="checkbox" id="includeIpv6Neighbors" onchange="setNeighborIpv6(this.checked)"> Include IPv6</label></div><table><thead><tr><th class="sortable" onclick="setTableSort('neighbors','interface')"><button class="sort-head" type="button" tabindex="-1"><span>Interface</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('neighbors','ip')"><button class="sort-head" type="button" tabindex="-1"><span>IP Address</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('neighbors','hostname')"><button class="sort-head" type="button" tabindex="-1"><span>Hostname / Label</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('neighbors','mac')"><button class="sort-head" type="button" tabindex="-1"><span>MAC Address</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('neighbors','state')"><button class="sort-head" type="button" tabindex="-1"><span>State</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('neighbors','last_seen')"><button class="sort-head" type="button" tabindex="-1"><span>Last Seen</span><span class="sort-icon"></span></button></th><th>Actions</th></tr></thead><tbody id="neighborRows"></tbody></table></section><section class="card span-12"><h2>USB Device Status</h2><table><thead><tr><th>Device</th><th>Status</th><th>Details</th></tr></thead><tbody id="usbRows"></tbody></table></section><section class="card span-12"><div class="section-head"><h2>ZeroTier Clients</h2><div class="inline-config"><input id="ztIpInput" placeholder="Peer IP"><input id="ztCallsignInput" placeholder="Callsign"><button class="primary" onclick="addZtPeer()">Add Peer</button></div></div><table><thead><tr><th class="sortable" onclick="setTableSort('zt','ip')"><button class="sort-head" type="button" tabindex="-1"><span>IP</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('zt','callsign')"><button class="sort-head" type="button" tabindex="-1"><span>Callsign</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('zt','status')"><button class="sort-head" type="button" tabindex="-1"><span>Status</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('zt','last_active')"><button class="sort-head" type="button" tabindex="-1"><span>Last active</span><span class="sort-icon"></span></button></th><th>Actions</th></tr></thead><tbody id="ztRows"></tbody></table></section><section class="card span-12"><div class="section-head"><h2>Services</h2><div class="inline-config"><input id="serviceInput" placeholder="systemd service"><button class="primary" onclick="addServiceMonitor()">Add Service</button></div></div><table><thead><tr><th class="sortable" onclick="setTableSort('services','name')"><button class="sort-head" type="button" tabindex="-1"><span>Service</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('services','load')"><button class="sort-head" type="button" tabindex="-1"><span>Load</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('services','active')"><button class="sort-head" type="button" tabindex="-1"><span>Status</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('services','sub')"><button class="sort-head" type="button" tabindex="-1"><span>Substate</span><span class="sort-icon"></span></button></th><th class="sortable" onclick="setTableSort('services','enabled')"><button class="sort-head" type="button" tabindex="-1"><span>Enabled</span><span class="sort-icon"></span></button></th><th>Banner</th><th>Actions</th></tr></thead><tbody id="svcRows"></tbody></table></section><section class="card span-6"><h2>Backup / Diagnostics</h2><p class="small">Creates a timestamped diagnostics bundle on the TAK server with routes, interfaces, DNS, service status, and recent logs.</p><div class="kv" style="margin:8px 0"><div class="k">Folder size</div><div class="v" id="diagSize">—</div><div class="k">Files</div><div class="v" id="diagFiles">—</div></div><div class="card-action-buttons"><button class="primary" onclick="runDiagnostics()">Generate Diagnostics Bundle</button><button class="stop" onclick="clearDiagnostics()">Clear Old Diagnostics</button></div></section><section class="card span-6"><h2>TAK Server Power Controls</h2><p class="small">These buttons send commands to the Raspberry Pi TAK server. They do not reboot or shut down the computer viewing this webpage.</p><div class="card-action-buttons card-action-buttons-danger"><button class="primary" onclick="systemAction('lock-screen')">Lock Server Screen</button><button class="restart" onclick="systemAction('reboot')">Reboot TAK Server</button><button class="stop" onclick="systemAction('shutdown')">Shutdown TAK Server</button></div></section><section class="card span-12"><div class="section-head"><h2>File Uploads</h2><span class="small" id="uploadLimitText">400 MB limit</span></div><p class="small">Upload files to authenticated Linux-user destinations. User credentials are checked by the server and are not saved. Upload login is HTTPS-only unless explicitly allowed in the environment file.</p><div class="upload-grid"><div class="upload-field upload-file-field"><label for="uploadFiles">Choose Files</label><input type="file" id="uploadFiles" multiple></div><div class="upload-field upload-destination-field"><label for="uploadDestination">Destination</label><select id="uploadDestination" disabled><option value="">Unlock uploads first</option></select></div><button id="uploadButton" class="primary" onclick="uploadSelectedFiles()" disabled>Upload</button><div class="upload-lock-row"><input id="uploadUsername" autocomplete="username" placeholder="Linux username"><input id="uploadPassword" type="password" autocomplete="current-password" placeholder="Password"><button class="primary" onclick="unlockUploads()">Unlock Uploads</button></div><div class="upload-dest-row"><input id="uploadDestLabel" placeholder="Destination label, e.g. Maps"><input id="uploadDestPath" placeholder="Path, e.g. ~/Downloads or /media/usb"><button onclick="openUploadBrowser()">Browse...</button><button class="primary" onclick="addUploadDestination()">Add Destination</button><button class="stop" onclick="removeSelectedUploadDestination()">Remove Selected</button></div><div id="uploadBrowser" class="upload-browser" style="display:none"><div class="upload-browser-head"><div><div class="small">Browse server folders as the authenticated upload user</div><div class="upload-browser-path" id="uploadBrowserPath">—</div></div><div><button onclick="browseUploadDir('~')">Home</button><button onclick="browseUploadParent()">Up</button><button class="primary" onclick="useBrowsedUploadDir()">Use This Folder</button><button onclick="closeUploadBrowser()">Close</button></div></div><div id="uploadBrowserList" class="upload-browser-list"></div></div></div><div id="uploadDestinationHelp" class="small" style="margin-top:8px">Saved destinations can use ~/ paths, absolute paths, or relative paths under the authenticated user home. Outside-home paths must already exist and be writable by that Linux user.</div><div id="uploadResult" class="upload-result small">Choose file(s), unlock with a server account, then choose or add a destination.</div></section><section class="card span-12"><div class="section-head"><h2>Remote Command Execution</h2><div class="inline-config"><input id="cmdLabelInput" placeholder="Button label"><input id="cmdCommandInput" class="cmd-input" placeholder="Command to execute"><button class="primary" onclick="addRemoteCommand()">Add Button</button></div></div><p class="small">Commands run on the server as the dashboard service user. Use the installed sudo wrapper for allowlisted root actions.</p><div class="cmd-restore-wrap"><button class="primary" onclick="restoreDefaultCommands()">Restore Defaults</button><div class="cmd-restore-note"><span>Restores missing default commands only.</span><span>Custom commands are not deleted.</span></div></div><div class="cmd-tabs" id="commandCategoryTabs"></div><div id="commandButtons" class="cmd-command-list"></div></section><section class="card span-12"><div class="section-head"><h2>Command History</h2><button class="primary" onclick="downloadCommandHistory()">Save History ZIP</button></div><div class="history-tabs" id="historyTabs"></div><pre id="commandHistoryOutput">No command history yet.</pre></section>
</main><div class="iteration-marker">v301</div><script>function fmtLoad(v){const n=Number(v);return Number.isFinite(n)?n.toFixed(1):'0.0'}function statusClassGeneric(s){s=String(s||'').toUpperCase();if(s.includes('DISCONNECTED')||s.includes('NO CLIENTS AVAILABLE')||s.includes('UNKNOWN')||s.includes('MODEM DETECTED'))return'warn';if(s.includes('OFFLINE')||s.includes('ERROR')||s.includes('FAIL')||s.includes('NOT FOUND'))return'bad';if(s.includes('ONLINE')||s.includes('CONNECTED')||s.includes('DETECTED')||s.includes('DEVICE')||s.includes('ACTIVE'))return'good';return'warn'}function interfaceStateClass(s){s=String(s||'').toLowerCase();if(s==='connected'||s.includes('connected')||s==='up'||s==='link-up')return'good';if(s==='down'||s.includes('down')||s.includes('not detected'))return'bad';return'warn'}function signalPercentClass(p){p=parseFloat(p);if(isNaN(p))return'';if(p<=40)return'bad';if(p<=70)return'warn';return'good'}function wifiSignalClass(p){return signalPercentClass(p)}
function signalBarsHtml(percent,count){const pct=Number(percent);let bars=Number(count);if(!Number.isFinite(bars)){if(Number.isFinite(pct)){bars=pct<=0?0:pct<=20?1:pct<=40?2:pct<=60?3:pct<=80?4:5}else{return '<span class="signal-text warn">unknown</span>'}}bars=Math.max(0,Math.min(5,Math.round(bars)));let cls='signal-warn';if(Number.isFinite(pct)){cls=pct<=40?'signal-bad':(pct<=70?'signal-warn':'signal-good')}else{cls=bars<=2?'signal-bad':(bars<=3?'signal-warn':'signal-good')}let out='<span class="signal-wrap"><span class="signal-bars '+cls+'" aria-label="'+bars+' of 5 signal bars" title="'+bars+' of 5 signal bars">';for(let i=1;i<=5;i++){out+='<span class="bar '+(i<=bars?'on':'')+'"></span>'}out+='</span></span>';return out}
function titleCaseWords(v){return String(v||'unknown').toLowerCase().replace(/(^|[\s_/-])([a-z])/g,(m,p,c)=>p+c.toUpperCase())}
function neighborStateClass(s){s=String(s||'').toLowerCase();if(s==='reachable'||s==='noarp')return'good';if(['stale','delay','incomplete','probe'].includes(s))return'warn';if(s==='failed'||s==='none')return'bad';return'warn'}
function formatTs(ts){if(!ts)return'unknown';try{return new Date(Number(ts)*1000).toLocaleString()}catch(e){return'unknown'}}
function safeInputId(prefix,key){return prefix+String(key||'').replace(/[^A-Za-z0-9_-]/g,'_')}
function isEditingNeighborHostname(){const a=document.activeElement;return !!(a&&a.id&&String(a.id).startsWith('neighborHost_'));}
async function saveNeighborHostname(key){const input=document.getElementById(safeInputId('neighborHost_',key));if(!input)return;await configAction({action:'set_neighbor_hostname',key,hostname:input.value.trim()});fetchStatus();}
let selectedHistoryDay='';
function formatCommandEntry(item){return `${item.time||''}  ${item.ok?'OK':'FAILED'}  rc=${item.rc??''}  ${item.label||''}
$ ${item.command||''}

STDOUT:
${item.stdout||''}

STDERR:
${item.stderr||''}`;}
let tableSort={neighbors:{key:'hostname',dir:1},zt:{key:'callsign',dir:1},services:{key:'name',dir:1}};
let selectedCommandCategory='Network';
const COMMAND_CATEGORY_ORDER=['Network','TAK','Diagnostics','Pi Power/Hardware','Clean/Maintenance','Custom'];
function tableSortValue(kind,item,key){if(kind==='neighbors'){if(key==='hostname')return item.hostname||'';if(key==='last_seen')return formatTs(item.last_seen_ts);return item[key]||''}if(kind==='zt'){if(key==='last_active')return formatLastActive(item.last_active_ts);return item[key]||''}if(kind==='services'){return item[key]||''}return item[key]||''}
function sortedRows(kind,items){const st=tableSort[kind]||{};const key=st.key;const dir=st.dir||1;return (items||[]).slice().sort((a,b)=>String(tableSortValue(kind,a,key)).localeCompare(String(tableSortValue(kind,b,key)),undefined,{numeric:true,sensitivity:'base'})*dir)}
function setTableSort(kind,key){const st=tableSort[kind]||{key:key,dir:1};tableSort[kind]={key:key,dir:(st.key===key?-st.dir:1)};fetchStatus();}
function updateSortHeaders(){document.querySelectorAll('th.sortable').forEach(th=>th.classList.remove('sort-asc','sort-desc'));const apply=(kind)=>{const st=tableSort[kind];if(!st)return;document.querySelectorAll(`th[onclick*="setTableSort('${kind}','${st.key}')"]`).forEach(th=>th.classList.add(st.dir===1?'sort-asc':'sort-desc'))};apply('neighbors');apply('zt');apply('services')}
function renderCommandTabs(cmds){const tabs=document.getElementById('commandCategoryTabs');if(!tabs)return;const cats=[];for(const c of COMMAND_CATEGORY_ORDER){if((cmds||[]).some(x=>(x.category||'Custom')===c))cats.push(c)}for(const c of (cmds||[]).map(x=>x.category||'Custom')){if(!cats.includes(c))cats.push(c)}if(!cats.includes(selectedCommandCategory))selectedCommandCategory=cats[0]||'Custom';tabs.innerHTML=cats.map(c=>`<button class="cmd-tab ${c===selectedCommandCategory?'active':''}" onclick="selectedCommandCategory='${esc(c)}';renderCommandButtons(lastStatusPayload||{})">${esc(c)}</button>`).join('')}
function commandKind(c){return c.kind || ((c.category||'Custom')==='Custom'?'custom':'default')}
function renderMaintenanceTools(){return `<div class="cmd-maintenance-tools"><div class="cmd-maintenance-head"><div><div class="cmd-maintenance-title">Config backup / restore</div><div class="cmd-maintenance-note">Download or restore dashboard configuration from the Clean up / Maintenance command area. Restore creates a pre-restore backup automatically.</div></div><div class="cmd-maintenance-actions"><button class="primary" onclick="downloadConfigBackup()">Download Config Backup</button><input id="configRestoreFile" type="file" accept=".zip,application/zip"><button class="restart" onclick="restoreConfigBackup()">Restore Config Backup</button></div></div><div id="configBackupRestoreResult" class="cmd-maintenance-result"></div></div>`}
function setConfigBackupRestoreResult(text,bad=false){const el=document.getElementById('configBackupRestoreResult');if(!el)return;el.textContent=String(text||'');el.className='cmd-maintenance-result active '+(bad?'bad':'');}
function downloadConfigBackup(){window.location.href='/api/config-backup'}
async function restoreConfigBackup(){const input=document.getElementById('configRestoreFile');const file=input&&input.files&&input.files[0];if(!file){alert('Choose a backup ZIP first.');return}if(!confirm('Restore dashboard configuration from this ZIP?\n\nA pre-restore backup will be created first. Some changes may require restarting the dashboard.'))return;setConfigBackupRestoreResult('Uploading and validating backup...');try{const r=await fetch('/api/config-restore',{method:'POST',headers:{'Content-Type':'application/zip','X-Backup-Filename':file.name},body:file});const j=await r.json().catch(()=>({ok:false,error:'Bad response'}));const text=(j.ok?'OK':'FAILED')+'\n\n'+(j.message||'')+'\n\nCommand: '+(j.command||'Restore config backup')+'\nReturn code: '+(j.rc??'')+'\n\nSTDOUT:\n'+(j.stdout||'')+'\n\nSTDERR:\n'+(j.stderr||'')+(j.error?'\n\n'+j.error:'');setConfigBackupRestoreResult(text,!j.ok);setOutputText(text);fetchStatus();}catch(e){setConfigBackupRestoreResult('Restore failed: '+e,true);setOutputText('FAILED\n\nConfig restore failed: '+e);}}
function renderCommandButtons(s){const box=document.getElementById('commandButtons');if(!box)return;const cmds=s.custom_commands||((s.config||{}).custom_commands)||[];renderCommandTabs(cmds);const filtered=cmds.filter(c=>(c.category||'Custom')===selectedCommandCategory);const maintenanceTools=(selectedCommandCategory==='Clean/Maintenance')?renderMaintenanceTools():'';const cards=filtered.length?filtered.map(c=>{const kind=commandKind(c);const kindLabel=kind==='default'?'Default':'Custom';return `<div class="cmd-command-card ${esc(kind)}"><div><div class="cmd-command-title-line"><div class="cmd-command-title">${esc(c.label)}</div><span class="cmd-command-kind ${esc(kind)}">${esc(kindLabel)}</span></div><div class="cmd-command-desc">${esc(c.description||'Custom command.')}</div><code class="cmd-command-code">${esc(c.command||'')}</code></div><div class="cmd-command-actions"><button class="primary" onclick="runRemoteCommand('${esc(c.id)}')">Run</button><button class="stop mini-remove" title="Delete" onclick="removeRemoteCommand('${esc(c.id)}')">Delete</button></div></div>`}).join(''):'<span class="small">No commands in this category.</span>';box.innerHTML=maintenanceTools+cards;}
function renderCommandHistory(history){const tabs=document.getElementById('historyTabs');const out=document.getElementById('commandHistoryOutput');if(!tabs||!out)return;const days=Object.keys(history||{}).sort().reverse();if(!days.length){selectedHistoryDay='';tabs.innerHTML='';out.textContent='No command history yet.';return}if(!selectedHistoryDay||!history[selectedHistoryDay])selectedHistoryDay=days[0];tabs.innerHTML=days.map(d=>`<button class="history-tab ${d===selectedHistoryDay?'active':''}" onclick="selectedHistoryDay='${esc(d)}';renderCommandHistory(lastStatusPayload.command_history||{})">${esc(d)}</button>`).join('');const items=(history[selectedHistoryDay]||[]).slice().reverse();out.textContent=items.map(formatCommandEntry).join('\n\n'+'='.repeat(72)+'\n\n')||'No entries for this day.';}
async function addRemoteCommand(){const label=document.getElementById('cmdLabelInput').value.trim();const command=document.getElementById('cmdCommandInput').value.trim();if(!label||!command){alert('Enter both a button label and command.');return}document.getElementById('cmdLabelInput').value='';document.getElementById('cmdCommandInput').value='';await configAction({action:'add_command',label,command});}
async function removeRemoteCommand(id){if(!confirm('Delete this command button from the visible library?'))return;await configAction({action:'remove_command',id});}
async function restoreDefaultCommands(){if(!confirm('Restore missing default commands? Custom commands will not be deleted.'))return;await configAction({action:'restore_default_commands'});}
async function runRemoteCommand(id){if(!confirm('Run this command on the TAK server now?'))return;const r=await fetch('/api/command',{method:'POST',body:new URLSearchParams({id})});const j=await r.json();if(j.history){selectedHistoryDay='';renderCommandHistory(j.history)}if(!j.ok){alert('Command failed. See Command History for output.')}fetchStatus();}
function downloadCommandHistory(){window.location.href='/command-history.zip'}

let certExcludedSans=new Set();
function certSanArg(v){return String(v||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/[\r\n]/g,' ');}
function removeCertDetectedSan(value){certExcludedSans.add(String(value||''));renderCertDetected(lastCertStatusPayload||{});}
function restoreCertDetectedSans(){certExcludedSans.clear();renderCertDetected(lastCertStatusPayload||{});}
let lastCertStatusPayload=null;
function renderCertExpiration(j){
  const box=document.getElementById('certExpiryStatus');if(!box)return;
  const exp=(j&&j.cert_expiration)||{};
  const items=[['Dashboard HTTPS cert',exp.dashboard_server],['Dashboard local CA',exp.dashboard_ca]];
  box.innerHTML=items.map(([name,item])=>{
    item=item||{};
    const cls=esc(item.status||'unknown');
    const label=item.label||'Unknown';
    const date=item.not_after||'Not generated yet';
    return `<div class="cert-expiry-item"><div><div class="cert-expiry-name">${esc(name)}</div><div class="cert-expiry-date">${esc(date)}</div></div><span class="cert-expiry-badge ${cls}">${esc(label)}</span></div>`;
  }).join('');
}
function renderCertDetected(j){
  const det=document.getElementById('certDetected');if(!det)return;
  lastCertStatusPayload=j||{};
  const names=(j.names||[]).map(x=>String(x||'').trim()).filter(Boolean);
  const ips=(j.ips||[]).map(x=>String(x||'').trim()).filter(Boolean);
  const html=[];
  for(const name of names){
    if(certExcludedSans.has(name))continue;
    html.push(`<span class="cert-pill">${esc(name)} <button class="cert-pill-x" title="Remove from certificate" onclick="removeCertDetectedSan('${certSanArg(name)}')">X</button></span>`);
  }
  for(const ip of ips){
    if(certExcludedSans.has(ip))continue;
    html.push(`<span class="cert-pill">${esc(ip)} <button class="cert-pill-x" title="Remove from certificate" onclick="removeCertDetectedSan('${certSanArg(ip)}')">X</button></span>`);
  }
  const hidden=[...names,...ips].filter(x=>certExcludedSans.has(x));
  if(hidden.length){html.push(`<span class="cert-pill warn">Excluded: ${hidden.map(esc).join(', ')} <button class="cert-pill-x" title="Restore excluded names/IPs" onclick="restoreCertDetectedSans()">X</button></span>`)}
  det.innerHTML=html.length?html.join(''):'<span class="cert-pill">No addresses detected</span>';
}
async function refreshCertSetup(){
  const out=document.getElementById('certSetupOutput');
  const link=document.getElementById('certDownloadLink');
  if(out)out.textContent='Loading certificate status...';
  try{
    const r=await fetch('/api/cert-status');
    const j=await r.json();
    renderCertDetected(j);
    renderCertExpiration(j);
    if(link)link.style.display=j.ca_exists?'inline-block':'none';
    const hint=document.getElementById('certDownloadHint');
    if(hint)hint.style.display=j.ca_exists?'inline-block':'none';
    if(out)out.textContent=`CA certificate: ${j.ca_exists?'available':'not generated yet'}
Server certificate: ${j.server_cert_exists?'available':'not generated yet'}
Server key: ${j.server_key_exists?'available':'not generated yet'}

Nginx server cert:
  ${j.server_cert_path||''}
Nginx server key:
  ${j.server_key_path||''}
Client CA source:
  ${j.ca_path||''}
Client CA download:
  ${j.ca_download_url||'Generate certificate first, then use Download CA Certificate.'}

${j.cert_info||'Generate a certificate to see certificate details.'}`;
  }catch(e){if(out)out.textContent='Failed to load certificate status: '+e;}
}
function openCertSetup(){const m=document.getElementById('certModal');if(m)m.classList.add('active');refreshCertSetup();}
function closeCertSetup(){const m=document.getElementById('certModal');if(m)m.classList.remove('active');}
function certBackdropClick(e){if(e.target&&e.target.id==='certModal')closeCertSetup();}
async function generateCertSetup(){
  const out=document.getElementById('certSetupOutput');
  const extra=(document.getElementById('certExtraSans')||{}).value||'';
  const exclude=[...certExcludedSans].join('\n');
  if(out)out.textContent='Generating certificate and reloading Nginx...';
  try{
    const r=await fetch('/api/cert-setup',{method:'POST',body:new URLSearchParams({extra_sans:extra,exclude_sans:exclude})});
    const j=await r.json().catch(()=>({ok:false,error:'Bad response'}));
    if(out)out.textContent=(j.ok?'OK':'FAILED')+'\n\n'+(j.stdout||'')+(j.stderr?'\n\nSTDERR:\n'+j.stderr:'')+(j.error?'\n\n'+j.error:'');
    await refreshCertSetup();
  }catch(e){if(out)out.textContent='Certificate setup failed: '+e;}
}

let uploadToken='';let uploadUser='';let uploadDestinations=[];
function secureUploadUrl(){const host=location.hostname||location.host;return `https://${host}:9443${location.pathname||'/'}`}
function setUploadResult(msg,isBad=false){const el=document.getElementById('uploadResult');if(el){el.textContent=msg;el.className='upload-result small '+(isBad?'bad':'')}}
function resizeUploadDestinationSelect(){
  const sel=document.getElementById('uploadDestination');if(!sel)return;
  const texts=Array.from(sel.options||[]).map(o=>o.textContent||'');
  const longest=texts.reduce((a,b)=>b.length>a.length?b:a,'');
  if(!longest){sel.style.width='';return}
  const probe=document.createElement('span');
  probe.textContent=longest;
  probe.style.position='absolute';probe.style.visibility='hidden';probe.style.whiteSpace='nowrap';
  probe.style.font=getComputedStyle(sel).font;
  document.body.appendChild(probe);
  const measured=probe.getBoundingClientRect().width;
  probe.remove();
  const target=Math.min(Math.ceil(measured*1.3+54),520);
  sel.style.width=target+'px';
}
function renderUploadDestinationSelect(items, unlocked=false){
  uploadDestinations=items||uploadDestinations||[];
  const sel=document.getElementById('uploadDestination');if(!sel)return;
  const current=sel.value;
  if(!unlocked&&!uploadToken){sel.innerHTML='<option value="">Unlock uploads first</option>';sel.disabled=true;requestAnimationFrame(resizeUploadDestinationSelect);return}
  sel.innerHTML=(uploadDestinations||[]).map(d=>{const p=d.path||d.resolved_path||'';return `<option value="${esc(d.id)}">${esc(d.label)}: ${esc(p)}</option>`}).join('')||'<option value="">No destinations configured</option>';
  if(current && [...sel.options].some(o=>o.value===current))sel.value=current;
  sel.disabled=false;
  requestAnimationFrame(resizeUploadDestinationSelect);
}
function renderUploadMeta(s){const u=(s&&s.upload)||{};const limit=document.getElementById('uploadLimitText');if(limit)limit.textContent=(u.limit_mb||400)+' MB limit';if(!uploadToken)renderUploadDestinationSelect(u.destinations||[],false);else if(u.destinations)uploadDestinations=u.destinations;}
let uploadBrowseCurrent='~';let uploadBrowseParent='';
function closeUploadBrowser(){const el=document.getElementById('uploadBrowser');if(el)el.style.display='none'}
async function openUploadBrowser(){
  if(!uploadToken){setUploadResult('Unlock uploads before browsing server folders.',true);return}
  const el=document.getElementById('uploadBrowser');if(el)el.style.display='block';
  const start=(document.getElementById('uploadDestPath').value||'~').trim()||'~';
  await browseUploadDir(start);
}
async function browseUploadDir(path){
  if(!uploadToken){setUploadResult('Unlock uploads before browsing server folders.',true);return}
  const list=document.getElementById('uploadBrowserList');if(list)list.innerHTML='<div class="upload-browser-empty">Loading...</div>';
  const q=new URLSearchParams({token:uploadToken,path:path||'~'});
  const r=await fetch('/api/upload-browse?'+q.toString());
  let j={};try{j=await r.json()}catch(e){}
  if(!r.ok||!j.ok){if(list)list.innerHTML='<div class="upload-browser-empty">'+esc(j.error||('Browse failed. HTTP '+r.status))+'</div>';return}
  uploadBrowseCurrent=j.display_path||j.path||'~';uploadBrowseParent=j.parent_display||'';
  const pathEl=document.getElementById('uploadBrowserPath');if(pathEl)pathEl.textContent=uploadBrowseCurrent;
  const entries=j.entries||[];
  if(!list)return;
  if(!entries.length){list.innerHTML='<div class="upload-browser-empty">No accessible subfolders found.</div>';return}
  list.innerHTML=entries.map(e=>`<div class="upload-browser-item" data-path="${escAttr(e.display_path||e.path||e.name)}" onclick="browseUploadDir(this.getAttribute('data-path'))"><span>📁 ${esc(e.name||'folder')}</span><span class="small">Open</span></div>`).join('');
}
function browseUploadParent(){if(uploadBrowseParent)browseUploadDir(uploadBrowseParent)}
function useBrowsedUploadDir(){
  const p=document.getElementById('uploadDestPath');if(p)p.value=uploadBrowseCurrent||'~';
  closeUploadBrowser();
  setUploadResult('Destination path selected. Enter a label and click Add Destination.');
}
async function addUploadDestination(){
  const label=document.getElementById('uploadDestLabel').value.trim();
  const path=document.getElementById('uploadDestPath').value.trim();
  if(!label||!path){alert('Enter a destination label and path.');return}
  const r=await fetch('/api/config',{method:'POST',body:new URLSearchParams({action:'add_upload_destination',label,path})});
  const j=await r.json().catch(()=>({ok:false,error:'Bad response'}));
  if(!j.ok){alert(j.error||'Config update failed');return}
  document.getElementById('uploadDestLabel').value='';document.getElementById('uploadDestPath').value='';
  const dests=((j.config||{}).upload_destinations)||[];
  if(uploadToken){renderUploadDestinationSelect(dests,true);setUploadResult('Destination saved. Choose it from the dropdown and upload.');}
  else{renderUploadDestinationSelect(dests,false);setUploadResult('Destination saved. Unlock uploads before uploading.');}
  fetchStatus();
}
async function removeSelectedUploadDestination(){
  const sel=document.getElementById('uploadDestination');const id=sel?sel.value:'';
  if(!id){alert('Select a destination to remove.');return}
  const d=(uploadDestinations||[]).find(x=>x.id===id);
  if(!confirm('Remove upload destination '+(d?d.label:id)+'?'))return;
  const r=await fetch('/api/config',{method:'POST',body:new URLSearchParams({action:'remove_upload_destination',id})});
  const j=await r.json().catch(()=>({ok:false,error:'Bad response'}));
  if(!j.ok){alert(j.error||'Config update failed');return}
  const dests=((j.config||{}).upload_destinations)||[];
  if(uploadToken){renderUploadDestinationSelect(dests,true);setUploadResult('Destination removed. Choose another destination and upload.');}
  else{renderUploadDestinationSelect(dests,false);setUploadResult('Destination removed. Unlock uploads before uploading.');}
  fetchStatus();
}
async function unlockUploads(){
  const username=document.getElementById('uploadUsername').value.trim();
  const password=document.getElementById('uploadPassword').value;
  if(!username||!password){setUploadResult('Enter a Linux username and password.',true);return}
  if(location.protocol!=='https:' && !(lastStatusPayload.upload||{}).allow_insecure_auth){setUploadResult('File upload login requires HTTPS. Open the secure Nginx proxy, usually: '+secureUploadUrl(),true);return}
  setUploadResult('Checking login...');
  const r=await fetch('/api/upload-login',{method:'POST',body:new URLSearchParams({username,password})});
  let j={};try{j=await r.json()}catch(e){}
  if(!r.ok||!j.ok){setUploadResult(j.error||('Login failed. HTTP '+r.status),true);return}
  uploadToken=j.token;uploadUser=j.username;document.getElementById('uploadPassword').value='';
  renderUploadDestinationSelect(j.destinations||[],true);
  document.getElementById('uploadButton').disabled=false;
  setUploadResult(`Uploads unlocked for ${j.username}. Choose destination and upload file(s). Session expires in about ${Math.round((j.expires_in||900)/60)} minutes.`);
}
async function uploadSelectedFiles(){
  const files=document.getElementById('uploadFiles').files;
  const dest=document.getElementById('uploadDestination').value;
  if(!uploadToken){setUploadResult('Unlock uploads first.',true);return}
  if(!files||!files.length){setUploadResult('Choose at least one file.',true);return}
  if(!dest){setUploadResult('Choose an upload destination.',true);return}
  if(location.protocol!=='https:' && !(lastStatusPayload.upload||{}).allow_insecure_auth){setUploadResult('Uploads require HTTPS. Open: '+secureUploadUrl(),true);return}
  const completed=[];
  for(let i=0;i<files.length;i++){
    const f=files[i];
    setUploadResult(`Uploading ${i+1}/${files.length}: ${f.name}...`);
    const q=new URLSearchParams({token:uploadToken,destination:dest,filename:f.name});
    const r=await fetch('/api/upload-file?'+q.toString(),{method:'POST',headers:{'Content-Type':'application/octet-stream'},body:f});
    let j={};try{j=await r.json()}catch(e){}
    if(!r.ok||!j.ok){setUploadResult(j.error||(`Upload failed for ${f.name}. HTTP ${r.status}`),true);return}
    completed.push(`${j.file.filename} -> ${j.file.path}`);
  }
  setUploadResult('Upload complete.\n'+completed.join('\n'));
  document.getElementById('uploadFiles').value='';
}

function includeNeighborIpv6(){return localStorage.getItem('takDashboardIncludeIpv6Neighbors')==='true'}function setNeighborIpv6(v){localStorage.setItem('takDashboardIncludeIpv6Neighbors',v?'true':'false');fetchStatus()}function setupNeighborIpv6Toggle(){const cb=document.getElementById('includeIpv6Neighbors');if(cb){cb.checked=includeNeighborIpv6()}}let dashboardApiRetryTimer=null;async function fetchStatus(retry){retry=Number(retry||0);try{const url='/api/status?include_ipv6='+(includeNeighborIpv6()?'1':'0')+'&_ts='+Date.now();const r=await fetch(url,{cache:'no-store',credentials:'same-origin'});let j=null;const txt=await r.text();try{j=txt?JSON.parse(txt):null}catch(_){j=null}if(r.status===401||(j&&j.auth_required)){location.href='/login?next='+encodeURIComponent(location.pathname+location.search);return}if(!r.ok){const msg=(j&&(j.error||j.message))||('HTTP '+r.status);throw new Error(msg)}if(dashboardApiRetryTimer){clearTimeout(dashboardApiRetryTimer);dashboardApiRetryTimer=null}render(j||{})}catch(e){const m=String(e&&e.message?e.message:e);const transient=/HTTP 502|502|Failed to fetch|NetworkError|Load failed/i.test(m);if(transient&&retry<3){const wait=(retry+1)*1800;const top=document.getElementById('topline');if(top)top.textContent='Dashboard API reconnecting... retry '+(retry+1)+' of 3';if(dashboardApiRetryTimer)clearTimeout(dashboardApiRetryTimer);dashboardApiRetryTimer=setTimeout(()=>fetchStatus(retry+1),wait);return}let friendly=m;if(/HTTP 502|502/.test(m))friendly='Dashboard API unavailable (HTTP 502). The page will keep retrying; restart tak-map.service only if it persists.';const top=document.getElementById('topline');if(top)top.textContent='Dashboard error: '+friendly}}
function boolText(v){return v?'PASS':'FAIL'}function clsForInternet(s){if(s==='UP')return'status good';if((s||'').includes('DNS'))return'status warn';if(!s||s==='UNKNOWN')return'status unknown';return'status bad'}function statusPill(label,cls){const text=String(label||'UNKNOWN').toUpperCase();let c=cls||statusClassGeneric(text);if(!c||c==='')c='unknown';return `<span class="status ${esc(c)}"><span class="dot"></span><span>${esc(text)}</span></span>`}function lteStateClass(s){const v=String(s||'').trim();if(v==='Connected'||v==='Connected (not default route)')return'lte-state-good';if(v==='Modem Connected')return'lte-state-warn';if(v==='No IP/Default Route'||v==='Link Detected')return'lte-state-warn-bold';if(v==='Modem Detected'||v==='Up/Dormant'||v==='Not Detected')return'lte-state-bad-bold';return'warn'}function clsForSvc(a,l){if(l!=='loaded')return'bad';if(a==='active')return'good';if(a==='failed')return'bad';return'warn'}function esc(x){return String(x??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
function escAttr(x){return String(x??'').replace(/[&<>\"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'}[c]))}
function formatLastActive(ts){if(!ts)return'never';const d=new Date(ts*1000);const s=Math.max(0,Math.floor((Date.now()-d.getTime())/1000));let age=s<60?`${s}s ago`:s<3600?`${Math.floor(s/60)}m ago`:s<86400?`${Math.floor(s/3600)}h ago`:`${Math.floor(s/86400)}d ago`;return `${age} · ${d.toLocaleString()}`}
function ztStatusClass(i){if(i.status==='ONLINE')return'zt-online';if(i.status==='OFFLINE')return'zt-offline';return'zt-unknown'}


function topologyBackdropClick(e){if(e.target&&e.target.id==='topologyModal')closeTopologyModal()}
function openTopologyModal(){const m=document.getElementById('topologyModal');if(m){document.body.classList.add('topology-open');m.classList.add('open');renderTopology(lastStatusPayload)}}
function closeTopologyModal(){const m=document.getElementById('topologyModal');if(m)m.classList.remove('open');document.body.classList.remove('topology-open');hideTopologyDetail()}
function refreshTopology(){fetchStatus();setTimeout(()=>safeRenderTopology(lastStatusPayload,true),250)}
function safeRenderTopology(s,force=false){const tm=document.getElementById('topologyModal');if(!tm||!tm.classList.contains('open'))return;if(!force&&(topologyDrag||Date.now()<topologyEditingUntil)){topologyPendingRender=true;return}renderTopology(s)}
let topologyScanCache=null;let topologyScanRunning=false;
function firstIpv4FromInterface(iface){const ips=(iface&&iface.ipv4)||[];return ips.length?String(ips[0]).split('/')[0]:''}
function bestInterfaceByPrefix(ifs,prefixes){for(const [name,iface] of Object.entries(ifs||{})){if(prefixes.some(p=>String(name).startsWith(p))){const ip=firstIpv4FromInterface(iface);if(ip)return {name,iface,ip}}}return null}
function topologyInterfaceLabel(dev){dev=String(dev||'');if(dev.startsWith('zt'))return'ZeroTier';if(/^wlan[0-9]*/.test(dev)||/^wl/.test(dev))return'Wi-Fi / HaLow';if(/^eth[0-9]*/.test(dev)||/^en/.test(dev))return'LAN';if(/^wwan[0-9]*/.test(dev))return'LTE / 4G';return dev||'Network'}
function topologyVendorHint(mac){const m=String(mac||'').toLowerCase().replace(/-/g,':');const p=m.split(':').slice(0,3).join(':');const map={'b8:27:eb':'Raspberry Pi','dc:a6:32':'Raspberry Pi','e4:5f:01':'Raspberry Pi','2c:cf:67':'Raspberry Pi','d8:3a:dd':'Raspberry Pi','f4:5c:89':'Apple','a4:83:e7':'Apple','3c:22:fb':'Apple','28:cf:e9':'Apple','60:f8:1d':'Apple','ac:bc:32':'Apple','f0:18:98':'Apple','cc:20:e8':'Apple','f8:ff:c2':'Apple','00:1b:63':'Apple','8c:85:90':'Apple','40:98:ad':'Apple','00:50:56':'VMware','00:05:69':'VMware','00:0c:29':'VMware','dc:21:48':'Intel','f8:bc:12':'Dell','b8:ca:3a':'Dell','3c:2c:30':'Dell','00:1a:a0':'Dell','e0:d5:5e':'Lenovo','60:45:cb':'Lenovo','fc:45:96':'Samsung','cc:6e:a4':'Samsung','88:32:9b':'Samsung','f4:f5:d8':'Google','da:a1:19':'Google'};return map[p]||''}
function osFamilyFromText(x){const v=String(x||'').toLowerCase();if(/android/.test(v))return'Android';if(/iphone|ios/.test(v))return'iOS';if(/ipad|ipados/.test(v))return'iPadOS';if(/mac os|macos|darwin|apple/.test(v))return'macOS';if(/windows|microsoft/.test(v))return'Windows';if(/raspbian|raspberry/.test(v))return'Raspberry Pi OS';if(/linux|ubuntu|debian/.test(v))return'Linux';return''}
function guessTopologyDevice(name,source,mac,scan){const n=String(name||'').toLowerCase();const vendor=String((scan&&scan.manufacturer)||topologyVendorHint(mac)||'');const vf=vendor.toLowerCase();const scanType=String((scan&&scan.device_type)||'');const scanOs=String((scan&&scan.os_family)||'');if(scanType||scanOs){let icon='•';const t=(scanType+' '+scanOs+' '+n).toLowerCase();if(/phone/.test(t))icon='◫';else if(/tablet|eud/.test(t))icon='▯';else if(/server|raspberry|linux/.test(t))icon='▣';else if(/computer|workstation|laptop|desktop|general purpose/.test(t))icon='▭';else if(/router|gateway|wap|access point/.test(t))icon='⇄';return {type:scanType||'Endpoint',icon,os:scanOs||osFamilyFromText(vendor)||'unknown',manufacturer:vendor||'',confidence:(scan&&scan.confidence)||'medium'}}if(/iphone|android|pixel|galaxy|phone/.test(n)||/samsung|google/.test(vf))return {type:'Phone',icon:'◫',os:/iphone/.test(n)||vf.includes('apple')?'iOS':(/pixel|galaxy|android/.test(n)||vf.includes('samsung')||vf.includes('google')?'Android':'mobile'),manufacturer:vendor,confidence:'low'};if(/ipad|tablet|tab|eud|atak/.test(n))return {type:'Tablet / EUD',icon:'▯',os:/ipad/.test(n)||vf.includes('apple')?'iPadOS':(/android|galaxy|tab/.test(n)?'Android':'mobile'),manufacturer:vendor,confidence:'low'};if(/head.?unit|joying|vehicle|car/.test(n))return {type:'Vehicle head unit',icon:'▭',os:'Android',manufacturer:vendor,confidence:'medium'};if(/laptop|desktop|pc|admin|workstation|macbook|thinkpad|latitude|surface/.test(n))return {type:'Computer',icon:'▭',os:/macbook/.test(n)||vf.includes('apple')?'macOS':(/surface|win|pc/.test(n)?'Windows':'desktop'),manufacturer:vendor,confidence:'low'};if(/raspberry|rpi|pi-|tak-server|server|linux|ubuntu|debian/.test(n)||vf.includes('raspberry'))return {type:'Server / Linux',icon:'▣',os:vf.includes('raspberry')?'Raspberry Pi OS':'Linux',manufacturer:vendor,confidence:'medium'};if(String(source||'').toLowerCase().includes('zerotier'))return {type:'Remote device',icon:'◇',os:'unknown',manufacturer:vendor,confidence:'low'};return {type:'Endpoint',icon:'•',os:vendor?topologyVendorHint(mac):'unknown',manufacturer:vendor,confidence:vendor?'medium':'low'}}
function topologyStateClass(status){const v=String(status||'').toLowerCase();if(v.includes('fail')||v.includes('offline')||v.includes('down'))return 'red';if(v.includes('stale')||v.includes('delay')||v.includes('limited')||v.includes('standby')||v.includes('not default')||v.includes('unknown'))return 'orange';if(v.includes('overlay'))return 'blue';return 'green'}
function topologyLineClassForSource(src,status){const st=topologyStateClass(status);if(String(src||'').toLowerCase().includes('zerotier'))return 'topo-line-info';if(st==='red')return 'topo-line-bad';if(st==='orange')return 'topo-line-mid';return 'topo-line-muted'}
function lineSvg(x1,y1,x2,y2,cls){return `<line class="${cls}" x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}"/>`}
function getTopologyScan(s){return topologyScanCache||(s&&s.topology_scan)||{}}
function scanNodeForIp(ip,s){const scan=getTopologyScan(s);const nodes=(scan&&scan.nodes)||{};return nodes[String(ip||'')]||null}
function topologyDetailHtml(e){return `<b>${esc(e.title||'Endpoint')}</b><br><span class="muted">IP:</span> <span class="sensitive">${esc(e.ip||'unknown')}</span><br><span class="muted">MAC:</span> <span class="sensitive">${esc(e.mac||'unknown')}</span><br><span class="muted">Manufacturer:</span> ${esc(e.manufacturer||'unknown')}<br><span class="muted">Device type:</span> ${esc(e.type||'unknown')}<br><span class="muted">OS family:</span> ${esc(e.os||'unknown')}<br><span class="muted">Interface/zone:</span> ${esc(e.source||'unknown')}<br><span class="muted">State:</span> ${esc(e.state||'unknown')}<br><span class="muted">Source:</span> ${esc(e.scanSource||'passive')}<br><span class="muted">Confidence:</span> ${esc(e.confidence||'low')}`}
function showTopologyDetail(event,detail){const box=document.getElementById('topologyDetailBox');if(!box)return;box.innerHTML=detail;box.classList.add('open');const modal=document.querySelector('.topology-modal');const r=(modal||document.body).getBoundingClientRect();let x=(event.clientX||r.left+40)-r.left+12;let y=(event.clientY||r.top+40)-r.top+12;if(x>r.width-360)x=Math.max(12,r.width-360);if(y>r.height-240)y=Math.max(12,y-220);box.style.left=x+'px';box.style.top=y+'px'}
function hideTopologyDetail(){const box=document.getElementById('topologyDetailBox');if(box)box.classList.remove('open')}
function collectTopologyEndpoints(s){const out=[];const seen=new Set();const skipEndpoint=(title,src)=>{const v=(String(title||'')+' '+String(src||'')).toLowerCase();return /(^|[\s_-])(gateway|router|modem|sixfab|gps|wwan|lte|4g|5g|cellular|connection)([\s_-]|$)/.test(v)||/4g connection|lte connection|default route/.test(v)};const add=(obj)=>{const key=String(obj.ip||obj.title||'').toLowerCase();if(!key||seen.has(key)||skipEndpoint(obj.title,obj.source))return;seen.add(key);const scan=scanNodeForIp(obj.ip,s);const g=guessTopologyDevice(obj.title,obj.source,obj.mac,scan);obj.type=g.type;obj.os=g.os;obj.icon=g.icon;obj.manufacturer=g.manufacturer||(scan&&scan.manufacturer)||topologyVendorHint(obj.mac)||'';obj.confidence=(scan&&scan.confidence)||g.confidence||'low';obj.scanSource=scan?'scan + passive':'passive';out.push(obj)};(s.network_neighbors||[]).forEach(n=>{const state=String(n.state||'');if(/failed|incomplete/i.test(state))return;const title=n.hostname||n.ip||n.mac||'neighbor';const src=topologyInterfaceLabel(n.interface||'');add({title,ip:n.ip,source:src,mac:n.mac,state:state||'Seen',raw:n})});(s.zerotier_devices||[]).forEach(z=>{const status=String(z.status||'');if(!z.ip)return;const title=z.callsign&&z.callsign!=='ZeroTier'?z.callsign:z.ip;add({title,ip:z.ip,source:'ZeroTier',mac:'',state:status||'Overlay',raw:z})});return out}
function endpointZone(e){if(/zerotier/i.test(e.source))return'zt';if(/wifi|halow|wlan/i.test(e.source))return'wifi';if(/lte|wwan|4g|5g/i.test(e.source))return'lte';if(/ethernet|eth|lan/i.test(e.source))return'lan';return'lan'}
function deviceRow(e){const color=/zerotier/i.test(e.source)?'blue':topologyStateClass(e.state);const stale=/stale|offline|down/i.test(e.state||'');const detail=topologyDetailHtml(e);return `<div class="topology-device ${stale?'stale':''}" data-detail="${escAttr(detail)}" onmouseenter="showTopologyDetail(event,this.dataset.detail)" onmousemove="showTopologyDetail(event,this.dataset.detail)" onmouseleave="hideTopologyDetail()" onclick="showTopologyDetail(event,this.dataset.detail)"><div class="dev-main"><span class="dev-name"><span class="topology-dot ${esc(color)}"></span>${esc(e.title||'endpoint')}</span><span class="dev-ip sensitive">${esc(e.ip||'')}</span></div><span class="dev-type">${esc(e.type||'Endpoint')}</span></div>`}
function zonePanel(title,icon,sub,status,statusColor,items,max){const shown=items.slice(0,max||5);const rows=shown.map(deviceRow);if(items.length>shown.length)rows.push(`<div class="topology-device more"><div class="dev-main"><span class="dev-name">+${items.length-shown.length} more</span><span class="dev-ip">Use tables for full list</span></div><span class="dev-type">more</span></div>`);if(!rows.length)rows.push(`<div class="topology-device more"><div class="dev-main"><span class="dev-name">No endpoint nodes</span><span class="dev-ip">interface/path only</span></div><span class="dev-type">none</span></div>`);return `<div class="topology-node zone"><div class="topology-title"><span class="topology-icon">${esc(icon)}</span><span>${esc(title)}</span></div><div class="topology-sub">${sub}</div><div class="topology-status"><span class="topology-dot ${esc(statusColor)}"></span>${esc(status)}</div><div class="topology-zone-list">${rows.join('')}</div></div>`}
async function scanTopologyDetails(){if(topologyScanRunning)return;topologyScanRunning=true;const chip=document.getElementById('topologyScanState');if(chip)chip.textContent='Scanning...';try{const r=await fetch('/api/topology-scan',{method:'POST'});const j=await r.json();if(j.ok&&j.scan){topologyScanCache=j.scan;if(chip){const n=Object.keys((j.scan.nodes)||{}).length;chip.textContent=`Scan details: ${n} node(s)`}}else{if(chip)chip.textContent='Scan unavailable';alert((j.error||j.stderr||'Topology scan failed').slice(0,500))}}catch(e){if(chip)chip.textContent='Scan failed';alert('Topology scan failed: '+e)}finally{topologyScanRunning=false;renderTopology(lastStatusPayload)}}
function renderTopology(s){const canvas=document.getElementById('topologyCanvas');if(!canvas)return;if(!s){canvas.innerHTML='<div class="topology-empty">Waiting for dashboard status data...</div>';return}const updated=document.getElementById('topologyUpdated');if(updated)updated.textContent='Updated '+new Date((s.timestamp||Date.now()/1000)*1000).toLocaleTimeString();const scan=getTopologyScan(s);const chip=document.getElementById('topologyScanState');if(chip&&!topologyScanRunning){if(scan&&scan.timestamp){const n=Object.keys(scan.nodes||{}).length;chip.textContent=`Scan details: ${n} node(s)`}else{chip.textContent='Passive mode'}}const ifs=s.interfaces||{};const eth=bestInterfaceByPrefix(ifs,['eth','en']);const wifi=bestInterfaceByPrefix(ifs,['wlan','wl']);const zt=bestInterfaceByPrefix(ifs,['zt']);const wwan=bestInterfaceByPrefix(ifs,['wwan']);const inet=s.internet||{};const lte=s.lte||{};const gw=(inet.gateway||inet.default_gateway||((inet.bandwidth||{}).gateway)||'');const serverIp=[eth&&eth.ip,wifi&&wifi.ip,zt&&zt.ip,wwan&&wwan.ip].filter(Boolean).slice(0,4).join('<br>')||'No local IP detected';const endpoints=collectTopologyEndpoints(s);const groups={lan:[],wifi:[],zt:[],lte:[]};endpoints.forEach(e=>{groups[endpointZone(e)].push(e)});const lteState=lte.state||((wwan&&wwan.ip)?'Connected':'Standby');const topPaths=[];topPaths.push(`<div class="topology-node path"><div class="topology-title"><span class="topology-icon">☁</span><span>Internet</span></div><div class="topology-sub">Reachability / WAN<br>${esc(String(inet.state||'unknown'))}</div><div class="topology-status"><span class="topology-dot ${String(inet.state||'').toUpperCase()==='UP'?'green':'orange'}"></span>${String(inet.state||'').toUpperCase()==='UP'?'Online':'Unknown'}</div></div>`);topPaths.push(`<div class="topology-node path"><div class="topology-title"><span class="topology-icon">⇄</span><span>Gateway</span></div><div class="topology-sub"><span class="sensitive">${esc(gw||'detected route')}</span><br>${eth?'via '+esc(eth.name):'default route'}</div><div class="topology-status"><span class="topology-dot green"></span>Active</div></div>`);const hasLteNodes=groups.lte.length>0;topPaths.push(`<div class="topology-node path"><div class="topology-title"><span class="topology-icon">↯</span><span>LTE / 4G Path</span></div><div class="topology-sub">${wwan?esc(wwan.name):'wwan0'}<br>hardware folded into server</div><div class="topology-status"><span class="topology-dot ${String(lteState).includes('Connected')?'orange':'gray'}"></span>${esc(hasLteNodes?'active endpoints':'standby / dead-end')}</div></div>`);const server=`<div class="topology-node main"><div class="topology-title"><span class="topology-icon">▣</span><span>TAK Server</span></div><div class="topology-sub">${esc(s.hostname||'tak-server')}<br><span class="sensitive">${serverIp}</span></div><div class="topology-status"><span class="topology-dot green"></span>Hub online</div></div>`;const zones=[zonePanel('LAN','▭',`${eth?esc(eth.name):'eth'}<br>local network neighbors`,groups.lan.length?`${groups.lan.length} endpoint(s)`:'no endpoints',eth?'green':'orange',groups.lan,5),zonePanel('Wi-Fi / HaLow','⌁',`${wifi?esc(wifi.name):'wlan'}<br>wireless endpoint path`,groups.wifi.length?`${groups.wifi.length} endpoint(s)`:'no endpoints',groups.wifi.length?'green':(wifi?'orange':'gray'),groups.wifi,5),zonePanel('ZeroTier','◇',`${zt?esc(zt.name):'overlay'}<br>overlay network`,groups.zt.length?`${groups.zt.length} endpoint(s)`:'no endpoints',zt?'blue':'gray',groups.zt,5),zonePanel('LTE / 4G','↯',`${wwan?esc(wwan.name):'wwan0'}<br>path/interface status`,hasLteNodes?`${groups.lte.length} endpoint(s)`:'standby / no clients',hasLteNodes?'orange':'gray',groups.lte,5)];const lines=[lineSvg(19,14,50,30,'topo-line-good'),lineSvg(50,14,50,30,'topo-line-good'),lineSvg(81,14,50,30,'topo-line-mid'),lineSvg(50,47,14,55,'topo-line-good'),lineSvg(50,47,38,55,'topo-line-mid'),lineSvg(50,47,62,55,'topo-line-info'),lineSvg(50,47,86,55,'topo-line-mid'),lineSvg(50,47,50,53,'topo-line-backbone')];canvas.innerHTML=`<svg class="topology-lines" viewBox="0 0 100 100" preserveAspectRatio="none">${lines.join('')}</svg><div class="topology-path-row">${topPaths.join('')}</div><div class="topology-server-wrap">${server}</div><div class="topology-zone-row">${zones.join('')}</div><div id="topologyDetailBox" class="topology-node-detail"></div><div class="topology-scan-hint">Passive topology shown. Scan for Details uses optional nmap/arp-scan to identify OS family, device type, and manufacturer.</div>`}


/* v99 topology map renderer overrides */

function topologyNormalizeMac(mac){return String(mac||'').toLowerCase().replace(/-/g,':').replace(/[^0-9a-f:]/g,'').split(':').filter(Boolean).slice(0,6).join(':')}
function topologyIsHardwarePath(title,src){const v=(String(title||'')+' '+String(src||'')).toLowerCase();return /(^|[\s_-])(gateway|router|modem|sixfab|gps|wwan|lte|4g|5g|cellular|connection)([\s_-]|$)/.test(v)||/4g connection|lte connection|default route/.test(v)}
function stableTopologyId(e){const mac=topologyNormalizeMac(e.mac);const ip=String(e.ip||'').toLowerCase().trim();const title=String(e.title||'node').toLowerCase().replace(/[^a-z0-9_.:@-]+/g,'_').slice(0,42);if(mac)return'mac_'+mac.replace(/:/g,'');if(ip)return'ip_'+ip.replace(/[^a-z0-9]+/g,'_');return'name_'+title}
function mergeEndpointRecord(a,b){a.aliases=a.aliases||[];a.sources=a.sources||[];a.ips=a.ips||[];a.macs=a.macs||[];[b.title,b.callsign].filter(Boolean).forEach(x=>{if(!a.aliases.includes(x))a.aliases.push(x)});[b.source].filter(Boolean).forEach(x=>{if(!a.sources.includes(x))a.sources.push(x)});[b.ip].filter(Boolean).forEach(x=>{if(!a.ips.includes(x))a.ips.push(x)});[topologyNormalizeMac(b.mac)].filter(Boolean).forEach(x=>{if(!a.macs.includes(x))a.macs.push(x)});if(!a.title||String(a.title).match(/^\d+\.\d+\.\d+\.\d+$/))a.title=b.title||a.title;if(!a.ip&&b.ip)a.ip=b.ip;if(!a.mac&&b.mac)a.mac=b.mac;if(!a.source&&b.source)a.source=b.source;if(!a.state&&b.state)a.state=b.state;return a}
function collectTopologyEndpoints(s){const candidates=[];const push=(o)=>{if(!o||topologyIsHardwarePath(o.title,o.source))return;if(!o.ip&&!o.mac&&!o.title)return;candidates.push(o)};(s.network_neighbors||[]).forEach(n=>{const state=String(n.state||'');if(/failed|incomplete/i.test(state))return;push({title:n.hostname||n.ip||n.mac||'neighbor',ip:n.ip||'',source:topologyInterfaceLabel(n.interface||''),mac:n.mac||'',state:state||'Seen',raw:n})});(s.zerotier_devices||[]).forEach(z=>{const status=String(z.status||'');if(!z.ip)return;push({title:(z.callsign&&z.callsign!=='ZeroTier')?z.callsign:z.ip,ip:z.ip||'',source:'ZeroTier',mac:z.mac||'',state:status||'Overlay',raw:z})});const merged=[];const byIp=new Map();const byMac=new Map();for(const c of candidates){const ip=String(c.ip||'').toLowerCase();const mac=topologyNormalizeMac(c.mac);let e=(ip&&byIp.get(ip))||(mac&&byMac.get(mac));if(e){mergeEndpointRecord(e,c)}else{e=mergeEndpointRecord({aliases:[],sources:[],ips:[],macs:[]},c);merged.push(e)}if(ip)byIp.set(ip,e);if(mac)byMac.set(mac,e)}return merged.map(e=>{const scan=scanNodeForIp(e.ip,s);const g=guessTopologyDevice(e.title,e.source,e.mac,scan);e.type=g.type;e.os=g.os;e.icon=g.icon;e.manufacturer=g.manufacturer||(scan&&scan.manufacturer)||topologyVendorHint(e.mac)||'';e.confidence=(scan&&scan.confidence)||g.confidence||'low';e.scanSource=scan?'scan + passive':'passive';e.id=stableTopologyId(e);return e})}
function topologyDetailHtml(e){const aliases=(e.aliases&&e.aliases.length)?`<br><span class="muted">Aliases:</span> ${esc(e.aliases.join(', '))}`:'';const sources=(e.sources&&e.sources.length)?`<br><span class="muted">Sources:</span> ${esc(e.sources.join(', '))}`:'';return `<div class="topology-map-node-detail-title">${esc(e.title||'Endpoint')}</div><span class="muted">IP:</span> <span class="sensitive">${esc(e.ip||'unknown')}</span><br><span class="muted">MAC:</span> <span class="sensitive">${esc(e.mac||'unknown')}</span>${aliases}${sources}<br><span class="muted">Manufacturer:</span> ${esc(e.manufacturer||'unknown')}<br><span class="muted">Device type:</span> ${esc(e.type||'unknown')}<br><span class="muted">OS family:</span> ${esc(e.os||'unknown')}<br><span class="muted">Interface/zone:</span> ${esc(e.source||'unknown')}<br><span class="muted">State:</span> ${esc(e.state||'unknown')}<br><span class="muted">Source:</span> ${esc(e.scanSource||'passive')}<br><span class="muted">Confidence:</span> ${esc(e.confidence||'low')}`}
function showTopologyDetail(event,detail){const box=document.getElementById('topologyDetailBox');const canvas=document.getElementById('topologyCanvas');if(!box||!canvas)return;box.innerHTML=detail;box.classList.add('open');const c=canvas.getBoundingClientRect();let x=(event.clientX||c.left+40)-c.left+canvas.scrollLeft+12;let y=(event.clientY||c.top+40)-c.top+canvas.scrollTop+12;const pad=12;const maxX=canvas.scrollLeft+canvas.clientWidth-box.offsetWidth-pad;const maxY=canvas.scrollTop+canvas.clientHeight-box.offsetHeight-pad;x=Math.max(canvas.scrollLeft+pad,Math.min(x,maxX));if(y>maxY)y=Math.max(canvas.scrollTop+pad,y-box.offsetHeight-28);y=Math.max(canvas.scrollTop+pad,y);box.style.left=x+'px';box.style.top=y+'px'}
function hideTopologyDetail(){const box=document.getElementById('topologyDetailBox');if(box)box.classList.remove('open')}
function topologyMapStatusClass(e){const s=String(e.state||e.status||'').toLowerCase();if(e.more)return'gray';if(/stale|offline|down|failed|timeout|expired/.test(s))return'red';if(/zero|overlay/.test(String(e.source||'').toLowerCase()))return'blue';if(/warn|limited|standby|unknown|no endpoint/.test(s))return'orange';return'green'}
function topologyNodeKind(e){const z=endpointZone(e);if(z==='zt')return'overlay remote';if(topologyMapStatusClass(e)==='red')return'stale';if(e.more)return'more';return''}
function topologyNodeHtml(n){const st=n.status||'green';const detail=escAttr(n.detail||'');const classes=['topology-map-node',n.kind||'',st==='orange'?'mid':'',st==='blue'?'overlay':'',st==='red'?'stale':'',n.more?'more':'',topologyManualPositions[n.id]?'manual':''].filter(Boolean).join(' ');return `<div class="${classes}" style="left:${n.x}px;top:${n.y}px" data-node-id="${escAttr(n.id)}" data-auto-x="${n.autoX}" data-auto-y="${n.autoY}" data-detail="${detail}" onmouseenter="showTopologyDetail(event,this.dataset.detail)" onmousemove="showTopologyDetail(event,this.dataset.detail)" onmouseleave="hideTopologyDetail()" onclick="showTopologyDetail(event,this.dataset.detail)"><span class="topology-map-icon">${esc(n.icon||'•')}</span><span class="topology-map-copy"><span class="topology-map-name">${esc(n.title||'node')}</span><span class="topology-map-ip sensitive">${esc(n.ip||'')}</span></span><span class="topology-map-status ${st}"></span></div>`}
let topologyManualPositions={};let topologyLinks=[];let topologyDrag=null;let topologyAutoLayout={};let topologyHasUnsavedLayout=false;let topologyEditingUntil=0;let topologyPendingRender=false;let topologySnapGrid=true;const TOPOLOGY_SNAP_GRID=16;
function topologySetLayoutState(txt,warn){const e=document.getElementById('topologyLayoutState');if(e){e.textContent=txt;e.classList.toggle('topology-layout-warning',!!warn)}}
function topologyLoadLayout(s){if(topologyHasUnsavedLayout){topologySetLayoutState('Manual edit',false);return}const layout=(s&&s.topology_layout&&typeof s.topology_layout==='object')?s.topology_layout:{};topologyManualPositions=layout||{};topologySetLayoutState(Object.keys(topologyManualPositions).length?'Saved layout':'Auto layout',false)}
function endpointZone(e){const src=String(e.source||'').toLowerCase();if(src.includes('zerotier'))return'zt';if(src.includes('wi-fi')||src.includes('halow')||src.includes('wlan'))return'wifi';if(src.includes('lte')||src.includes('4g')||src.includes('wwan'))return'lte';return'lan'}
function nodePos(id,auto){const m=topologyManualPositions[id];return m&&Number.isFinite(Number(m.x))&&Number.isFinite(Number(m.y))?{x:Number(m.x),y:Number(m.y)}:auto}
function boxForNode(el){return{x:parseFloat(el.style.left)||0,y:parseFloat(el.style.top)||0,w:el.offsetWidth,h:el.offsetHeight,id:el.dataset.nodeId}}
function centerBox(b){return{x:b.x+b.w/2,y:b.y+b.h/2}}
function clampTopo(v,min,max){return Math.max(min,Math.min(max,v))}
function topoSnap(v){return topologySnapGrid?Math.round(v/TOPOLOGY_SNAP_GRID)*TOPOLOGY_SNAP_GRID:v}
function topologyAnchorPoints(b){
  return[
    {side:'left',x:b.x,y:b.y+b.h/2},
    {side:'right',x:b.x+b.w,y:b.y+b.h/2},
    {side:'top',x:b.x+b.w/2,y:b.y},
    {side:'bottom',x:b.x+b.w/2,y:b.y+b.h}
  ].map(p=>({side:p.side,x:Math.round(p.x*10)/10,y:Math.round(p.y*10)/10}))
}
function pointInRect(p,r,pad=0){return p.x>=r.x-pad&&p.x<=r.x+r.w+pad&&p.y>=r.y-pad&&p.y<=r.y+r.h+pad}
function segmentIntersectsRect(a,b,r,pad=5){
  const rr={x:r.x-pad,y:r.y-pad,w:r.w+pad*2,h:r.h+pad*2};
  if(a.x===b.x){const x=a.x,y1=Math.min(a.y,b.y),y2=Math.max(a.y,b.y);return x>=rr.x&&x<=rr.x+rr.w&&y2>=rr.y&&y1<=rr.y+rr.h}
  if(a.y===b.y){const y=a.y,x1=Math.min(a.x,b.x),x2=Math.max(a.x,b.x);return y>=rr.y&&y<=rr.y+rr.h&&x2>=rr.x&&x1<=rr.x+rr.w}
  // Fallback for unexpected non-orthogonal segments.
  const minX=Math.min(a.x,b.x),maxX=Math.max(a.x,b.x),minY=Math.min(a.y,b.y),maxY=Math.max(a.y,b.y);
  return maxX>=rr.x&&minX<=rr.x+rr.w&&maxY>=rr.y&&minY<=rr.y+rr.h;
}
function routeIntersectsNodes(points,fromId,toId){
  const boxes={};document.querySelectorAll('.topology-map-node').forEach(el=>{boxes[el.dataset.nodeId]=boxForNode(el)});
  for(let i=0;i<points.length-1;i++){
    for(const [id,b] of Object.entries(boxes)){
      if(id===fromId||id===toId)continue;
      if(segmentIntersectsRect(points[i],points[i+1],b,6))return true;
    }
  }
  return false;
}
function cleanTopoPoints(points){
  const out=[];
  for(const p of points){
    const q={x:Math.round(p.x*10)/10,y:Math.round(p.y*10)/10};
    const last=out[out.length-1];
    if(!last||Math.abs(last.x-q.x)>0.5||Math.abs(last.y-q.y)>0.5)out.push(q);
  }
  return out;
}
function routeLength(points){let n=0;for(let i=0;i<points.length-1;i++)n+=Math.abs(points[i+1].x-points[i].x)+Math.abs(points[i+1].y-points[i].y);return n+(points.length-2)*12}
function pathFromPoints(points){points=cleanTopoPoints(points);let d=`M${points[0].x} ${points[0].y}`;for(let i=1;i<points.length;i++)d+=` L${points[i].x} ${points[i].y}`;return d}
function topoAnchorPenalty(a,b){
  if((a.side==='right'&&b.side==='left')||(a.side==='left'&&b.side==='right')||(a.side==='bottom'&&b.side==='top')||(a.side==='top'&&b.side==='bottom'))return 0;
  if(a.side===b.side)return 34;
  return 12;
}
function topoLinePointInsideNode(p,overlap=8){
  const q={side:p.side,x:p.x,y:p.y};
  if(p.side==='left')q.x+=overlap;
  else if(p.side==='right')q.x-=overlap;
  else if(p.side==='top')q.y+=overlap;
  else if(p.side==='bottom')q.y-=overlap;
  return q;
}
function topoRouteCandidates(p1,p2){
  // Keep the selected four-point anchors, but extend each path slightly inside
  // the endpoint node. Because SVG lines render under nodes, this removes the
  // visible anti-alias/gap at the node border while still logically anchoring
  // at center-left/center-right/center-top/center-bottom.
  const s=topoLinePointInsideNode(p1,8),e=topoLinePointInsideNode(p2,8);
  const midX=Math.round((s.x+e.x)/2),midY=Math.round((s.y+e.y)/2);
  return[
    [s,{x:e.x,y:s.y},e],
    [s,{x:s.x,y:e.y},e],
    [s,{x:midX,y:s.y},{x:midX,y:e.y},e],
    [s,{x:s.x,y:midY},{x:e.x,y:midY},e],
    [s,{x:midX-20,y:s.y},{x:midX-20,y:e.y},e],
    [s,{x:midX+20,y:s.y},{x:midX+20,y:e.y},e],
    [s,{x:s.x,y:midY-20},{x:e.x,y:midY-20},e],
    [s,{x:s.x,y:midY+20},{x:e.x,y:midY+20},e]
  ].map(cleanTopoPoints)
}
function topologyPathFor(fromId,toId,idx){
  const aEl=document.querySelector(`[data-node-id="${CSS.escape(fromId)}"]`);const bEl=document.querySelector(`[data-node-id="${CSS.escape(toId)}"]`);if(!aEl||!bEl)return'';
  const a=boxForNode(aEl),b=boxForNode(bEl);const aPts=topologyAnchorPoints(a),bPts=topologyAnchorPoints(b);
  let best=null;
  for(const aa of aPts){
    for(const bb of bPts){
      const candidates=topoRouteCandidates(aa,bb);
      for(const c of candidates){
        const hits=routeIntersectsNodes(c,fromId,toId);
        const score=routeLength(c)+topoAnchorPenalty(aa,bb)+(hits?5000:0);
        if(!best||score<best.score)best={points:c,score,hits};
      }
    }
  }
  return pathFromPoints(best.points);
}
function updateTopologyLines(){const svg=document.getElementById('topologySvg');const junctions=document.getElementById('topologyJunctions');if(!svg)return;const map=document.querySelector('.topology-map');if(map)svg.setAttribute('viewBox',`0 0 ${Math.max(1,map.clientWidth)} ${Math.max(1,map.clientHeight)}`);svg.innerHTML=topologyLinks.map((l,i)=>`<path class="${l.cls}" d="${topologyPathFor(l.from,l.to,i)}"/>`).join('');if(junctions)junctions.innerHTML='';topologyCheckOverlaps()}
function toggleTopologySnapGrid(){topologySnapGrid=!topologySnapGrid;const b=document.getElementById('topologySnapGridBtn');if(b){b.classList.toggle('topology-snap-active',topologySnapGrid);b.textContent=topologySnapGrid?'Snap Grid':'Free Drag'}topologySetLayoutState(topologySnapGrid?'Snap grid on':'Free drag',false)}
function topologyCheckOverlaps(){const els=Array.from(document.querySelectorAll('.topology-map-node'));els.forEach(e=>e.classList.remove('overlap'));let hit=false;for(let i=0;i<els.length;i++){for(let j=i+1;j<els.length;j++){const a=boxForNode(els[i]),b=boxForNode(els[j]);if(!(a.x+a.w+10<b.x||b.x+b.w+10<a.x||a.y+a.h+10<b.y||b.y+b.h+10<a.y)){els[i].classList.add('overlap');els[j].classList.add('overlap');hit=true}}}if(hit)topologySetLayoutState('Overlap detected',true);return hit}
function topologyEnableDrag(){document.querySelectorAll('.topology-map-node').forEach(el=>{el.onpointerdown=(ev)=>{ev.preventDefault();el.setPointerCapture(ev.pointerId);const map=document.querySelector('.topology-map');const r=map.getBoundingClientRect();topologyDrag={el,id:el.dataset.nodeId,dx:ev.clientX-r.left+document.getElementById('topologyCanvas').scrollLeft-(parseFloat(el.style.left)||0),dy:ev.clientY-r.top+document.getElementById('topologyCanvas').scrollTop-(parseFloat(el.style.top)||0)};el.classList.add('dragging');hideTopologyDetail()};el.onpointermove=(ev)=>{if(!topologyDrag||topologyDrag.el!==el)return;const map=document.querySelector('.topology-map');const canvas=document.getElementById('topologyCanvas');const r=map.getBoundingClientRect();let x=ev.clientX-r.left+canvas.scrollLeft-topologyDrag.dx;let y=ev.clientY-r.top+canvas.scrollTop-topologyDrag.dy;x=Math.max(10,Math.min(map.clientWidth-el.offsetWidth-10,topoSnap(x)));y=Math.max(10,Math.min(map.clientHeight-el.offsetHeight-32,topoSnap(y)));el.style.left=x+'px';el.style.top=y+'px';topologyManualPositions[el.dataset.nodeId]={x:Math.round(x*10)/10,y:Math.round(y*10)/10};topologyHasUnsavedLayout=true;topologyEditingUntil=Date.now()+3000;topologySetLayoutState('Manual edit',false);updateTopologyLines()};el.onpointerup=()=>{if(!topologyDrag)return;topologyDrag.el.classList.remove('dragging');topologyDrag=null;topologyEditingUntil=Date.now()+3000;updateTopologyLines();if(topologyPendingRender){topologyPendingRender=false;setTimeout(()=>{if(!topologyDrag&&lastStatusPayload)renderTopology(lastStatusPayload)},350)}}})}
function topologyMakeNode(e,auto,kind='',status=null){const id=e.id||stableTopologyId(e);const p=nodePos(id,auto);topologyAutoLayout[id]=auto;return{id,x:p.x,y:p.y,autoX:auto.x,autoY:auto.y,title:e.title||'endpoint',ip:e.ip||'',icon:e.icon||'•',status:status||topologyMapStatusClass(e),kind:kind||topologyNodeKind(e),more:e.more,detail:topologyDetailHtml(e)}}
function addVisibleGroup(group,autos,nodes,parentId,cls,kind){const max=autos.length;let visible=[];if(group.length>max){visible=group.slice(0,max-1);visible.push({title:`+${group.length-(max-1)} more`,ip:'endpoints',icon:'+',type:'collapsed endpoints',os:'mixed / unknown',source:kind,state:'More',manufacturer:'',confidence:'summary',scanSource:'summary',aliases:[],ips:[],macs:[],more:true,id:'more_'+kind.toLowerCase().replace(/[^a-z0-9]+/g,'_')})}else visible=group;visible.forEach((e,i)=>{const n=topologyMakeNode(e,autos[i],e.more?'more':'',e.more?'gray':null);nodes.push(n);topologyLinks.push({from:parentId,to:n.id,cls})})}
function renderTopology(s){const canvas=document.getElementById('topologyCanvas');if(!canvas)return;if(!s){canvas.innerHTML='<div class="topology-empty">Waiting for dashboard status data...</div>';return}const updated=document.getElementById('topologyUpdated');if(updated)updated.textContent='Updated '+new Date((s.timestamp||Date.now()/1000)*1000).toLocaleTimeString();const scan=getTopologyScan(s);const chip=document.getElementById('topologyScanState');if(chip&&!topologyScanRunning){if(scan&&scan.timestamp){const n=Object.keys(scan.nodes||{}).length;chip.textContent=`Scan details: ${n} node(s)`}else{chip.textContent='Passive mode'}}topologyLoadLayout(s);topologyAutoLayout={};topologyLinks=[];const ifs=s.interfaces||{};const eth=bestInterfaceByPrefix(ifs,['eth','en']);const wifi=bestInterfaceByPrefix(ifs,['wlan','wl']);const zt=bestInterfaceByPrefix(ifs,['zt']);const wwan=bestInterfaceByPrefix(ifs,['wwan']);const inet=s.internet||{};const lte=s.lte||{};const gw=(inet.gateway||inet.default_gateway||((inet.bandwidth||{}).gateway)||'');const serverIp=[eth&&eth.ip,wifi&&wifi.ip,zt&&zt.ip,wwan&&wwan.ip].filter(Boolean).slice(0,4).join(' · ')||'No local IP';const endpoints=collectTopologyEndpoints(s);const groups={lan:[],wifi:[],zt:[],lte:[]};endpoints.forEach(e=>{groups[endpointZone(e)].push(e)});const lteState=lte.state||((wwan&&wwan.ip)?'Connected':'Standby');const nodes=[];const internet=topologyMakeNode({id:'internet_gateway',title:'Internet / Gateway',ip:gw||'default route',icon:'☁',type:'Gateway / upstream path',os:'Router / unknown',manufacturer:'',state:String(inet.state||'unknown'),source:'route table + reachability',scanSource:'passive',confidence:'medium'}, {x:42,y:292}, 'upstream', String(inet.state||'').toUpperCase()==='UP'?'green':'orange');const ltePath=topologyMakeNode({id:'lte_path',title:'LTE / 4G Path',ip:wwan?wwan.name:'standby',icon:'◌',type:'Standby interface path',os:'not endpoint hardware',state:String(lteState||'standby'),source:'interface + route status',scanSource:'passive',confidence:'medium'}, {x:82,y:160}, 'mid', 'orange');const server=topologyMakeNode({id:'tak_server',title:'TAK Server',ip:serverIp,icon:'▣',aliases:[s.hostname||'tak-server'],type:'Server / Linux',os:'Raspberry Pi OS / Linux',manufacturer:'Raspberry Pi',state:'Hub online',source:'local host',scanSource:'local',confidence:'high'}, {x:250,y:270}, 'server', 'green');const core=topologyMakeNode({id:'core',title:'Core Links',ip:'LAN · Wi-Fi · ZT',icon:'⇄',aliases:['LAN','Wi-Fi / HaLow','ZeroTier'],type:'Network junction',os:'not applicable',state:'Active',source:'interfaces + routes',scanSource:'passive',confidence:'high'}, {x:470,y:275}, 'core', 'green');const ztHub=topologyMakeNode({id:'ztbranch',title:'ZeroTier',ip:zt?zt.ip||zt.name:'overlay',icon:'◇',type:'Overlay branch',os:'not applicable',state:groups.zt.length?'Active endpoints':'No endpoints',source:zt?zt.name:'ZeroTier',scanSource:'passive',confidence:'medium'}, {x:675,y:277}, 'overlay', zt?'blue':'gray');nodes.push(internet,ltePath,server,core,ztHub);topologyLinks.push({from:internet.id,to:server.id,cls:'topo-map-solid'},{from:ltePath.id,to:server.id,cls:'topo-map-dashed'},{from:server.id,to:core.id,cls:'topo-map-solid'},{from:core.id,to:ztHub.id,cls:'topo-map-overlay'});addVisibleGroup(groups.lan,[{x:365,y:88},{x:400,y:172},{x:330,y:438},{x:435,y:525},{x:590,y:520},{x:250,y:520}],nodes,core.id,'topo-map-branch','LAN');addVisibleGroup(groups.wifi,[{x:620,y:390},{x:700,y:455},{x:760,y:525},{x:820,y:585},{x:560,y:565}],nodes,core.id,'topo-map-dashed','Wi-Fi / HaLow');addVisibleGroup(groups.zt,[{x:875,y:115},{x:955,y:205},{x:980,y:282},{x:1040,y:360},{x:1010,y:455},{x:965,y:550}],nodes,ztHub.id,'topo-map-overlay','ZeroTier');const labels=`<div class="topology-map-label" style="left:58px;top:256px">UPSTREAM / STANDBY</div><div class="topology-map-label" style="left:470px;top:236px">TAK CORE</div><div class="topology-map-label" style="right:180px;top:322px;color:#d5efff">ENDPOINTS / OVE