@media(max-width:900px){.zoom-indicator{top:112px!important;right:12px!important;font-size:.68rem!important}.floating-toolbar-dock{right:10px;top:154px}.map-tool-readout{left:50%;max-width:calc(100vw - 88px);overflow:auto;font-size:.68rem}.tool-label{display:none}}

/* v228 map UI refinements */
.measure-seg-label{background:transparent!important;border:0!important;box-shadow:none!important;text-shadow:0 1px 3px #000,0 -1px 3px #000,1px 0 3px #000,-1px 0 3px #000!important;padding:0!important;font-weight:850!important;opacity:.96!important}.measure-popup-dock{position:fixed;z-index:10050;display:none;cursor:grab;touch-action:none}.measure-popup-dock:active{cursor:grabbing}.measure-popup-box{width:248px!important;max-width:248px!important;border:1px solid rgba(111,131,139,.56)!important;border-radius:14px!important;background:rgba(6,10,14,.94)!important;box-shadow:0 16px 38px rgba(0,0,0,.44)!important;padding:9px!important;font-size:.70rem!important;color:#c7d1d7!important}.measure-popup-box h3{margin:0 0 6px!important;color:#d0d9de!important;font-size:.74rem!important;text-transform:uppercase!important;letter-spacing:.07em!important}.measure-popup-row{display:flex!important;justify-content:space-between!important;gap:8px!important;padding:3px 0!important;border-bottom:1px solid rgba(255,255,255,.06)!important;color:var(--muted)!important}.measure-popup-row span:last-child{color:#d2dce1!important;font-weight:400!important}.measure-popup-total{margin-top:6px!important;padding-top:6px!important;border-top:1px solid rgba(155,170,178,.25)!important;color:#d2dce1!important;font-weight:400!important}.basemap-button-row{display:grid!important;grid-template-columns:repeat(3,minmax(0,1fr))!important;gap:6px!important;margin-top:7px!important}.basemap-button-row .layer-button{font-size:.68rem!important;padding:5px 5px!important;white-space:nowrap!important}.basemap-import-status{grid-column:1/-1}.export-check-list{display:grid;gap:5px;margin-top:7px}.export-check-list label{display:flex;align-items:center;gap:7px;color:var(--muted);font-size:.76rem}.export-options{margin-top:7px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(255,255,255,.025);padding:0 8px 7px}.export-options summary{cursor:pointer;color:var(--muted);font-size:.74rem;font-weight:850;letter-spacing:.04em;text-transform:uppercase;list-style:none;padding:7px 0}.export-options summary::-webkit-details-marker{display:none}.export-options summary:before{content:'▸';display:inline-block;margin-right:6px;color:#ff9f86}.export-options[open] summary:before{content:'▾'}.export-options{margin-top:7px;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(255,255,255,.025);padding:0 8px 7px}.export-options summary{cursor:pointer;color:var(--muted);font-size:.74rem;font-weight:850;letter-spacing:.04em;text-transform:uppercase;list-style:none;padding:7px 0}.export-options summary::-webkit-details-marker{display:none}.export-options summary:before{content:'▸';display:inline-block;margin-right:6px;color:#ff9f86;transition:transform .16s ease}.export-options[open] summary:before{transform:rotate(90deg)}.leaflet-popup{z-index:890!important}.leaflet-popup-content-wrapper{max-width:min(340px,calc(100vw - 28px))}.feature-popup .kvp b{white-space:nowrap}

/* v233 ADS-B settings/icons/timing + status dropdown refinements */
.terrain3d-elevation{top:64px!important;left:56px!important;z-index:6!important}
.terrain3d-status{left:82px!important;bottom:28px!important;z-index:4!important;max-width:430px!important}
.terrain3d-pane .cesium-credit-logoContainer,.terrain3d-pane .cesium-credit-textContainer,.terrain3d-pane .cesium-credit-expand-link{z-index:9!important}
.adsb-settings-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:7px;margin-top:8px;width:100%;max-width:100%;overflow:hidden}
.adsb-settings-grid label{display:flex;flex-direction:column;gap:4px;color:var(--muted);font-size:.70rem;text-transform:uppercase;letter-spacing:.07em;font-weight:850;min-width:0}
.adsb-settings-grid input,.adsb-settings-grid select{background:#091018;border:1px solid #334553;border-radius:10px;color:var(--text);padding:8px 9px;min-width:0;width:100%;max-width:100%;font-size:.78rem}.adsb-settings-grid input[type=number]{min-height:36px;font-size:.9rem}.adsb-coord-input{appearance:textfield;-moz-appearance:textfield}.adsb-coord-input::-webkit-outer-spin-button,.adsb-coord-input::-webkit-inner-spin-button{display:none;-webkit-appearance:none;margin:0}.adsb-apply-row .layer-button{font-weight:600}
.adsb-apply-row{display:flex;gap:7px;align-items:center;margin-top:8px;flex-wrap:wrap}
</style></head><body><div class="topbar"><div class="title"><img src="/tak-map-logo.png" alt=""><span>TAK Map</span></div><div class="top-actions"><a href="/">Dashboard</a><button onclick="logoutTakMap()">Map Logout</button></div></div><div id="mapStatusBanner" class="map-status-banner"><span class="status-item status-dropdown-trigger" id="bannerEudsItem" onclick="toggleStatusDropdown('euds',event)"><span class="status-dot unknown" id="bannerEudsDot"></span>EUDs: <b id="bannerEuds">0 Connected</b></span><span class="status-item status-dropdown-trigger" id="bannerNonTakItem" onclick="toggleStatusDropdown('nontak',event)"><span class="status-dot unknown" id="bannerNonTakDot"></span>Non-TAK Sensor: <b id="bannerNonTak">0</b></span><span class="status-item" id="bannerTakItem"><span class="status-dot unknown" id="bannerTakDot"></span>TAK Server: <b id="bannerTak">Checking</b></span><span class="status-item" id="bannerInternetItem"><span class="status-dot unknown" id="bannerInternetDot"></span>Internet: <b id="bannerInternet">Checking</b></span><span class="status-item status-dropdown-trigger" id="bannerAdsbItem" onclick="toggleStatusDropdown('adsb',event)"><span class="status-dot unknown" id="bannerAdsbDot"></span>ADS-B: <b id="bannerAdsb">0 Aircraft</b></span><span class="status-item" id="bannerDownloadsItem"><span class="status-dot unknown" id="bannerDownloadsDot"></span>Downloads: <b id="bannerDownloads">0 Active</b></span></div><div id="statusDropdown" class="status-dropdown"></div><aside id="sidebar" class="sidebar"><div class="panel"><div class="search-wrap"><input id="layerSearch" class="search" placeholder="Search callsign / mission / route / source..." oninput="handleMapSearch()" autocomplete="off"><button class="search-clear" onclick="clearMapSearch()" title="Clear search">×</button><div id="searchResults" class="search-results"></div></div><div class="muted" id="mapStatus">Loading map configuration...</div></div><div class="panel"><h2>Basemap</h2><select id="basemapSelect" class="select" onchange="setBasemap(this.value)"></select><div class="relief-controls"><label><input type="checkbox" id="reliefOverlayToggle" onchange="toggleReliefOverlay(this.checked)"> USGS Shaded Relief</label><input id="reliefOpacity" type="range" min="0" max="100" value="35" oninput="setReliefOpacity(this.value)"></div><input id="basemapXmlInput" type="file" accept=".xml,.txt" multiple style="display:none" onchange="importBasemapXmlFiles()"><div class="basemap-button-row"><button class="layer-button" onclick="openSendLiveBasemapSource()">Send Map</button><button class="layer-button" onclick="triggerBasemapXmlImport()">Add Basemap</button><button class="layer-button" onclick="clearCustomBasemaps()">Clear Custom</button><small id="customBasemapStatus" class="basemap-import-status"></small></div></div><div class="panel"><h2>Live TAK</h2><div id="liveRows"></div></div><div class="panel collapsible" data-collapse-key="adsbSettings"><h2 onclick="togglePanelCollapse(this)">ADS-B <span class="panel-toggle">▾</span></h2><div class="panel-body"><div class="muted">TAK Map-side ADS-B display filter only. Does not modify OTS config.yml.</div><div class="adsb-settings-grid"><label>Radius miles<input id="adsbRadiusMiles" class="adsb-radius-input" type="number" min="1" max="250" step="1" value="5" inputmode="numeric"></label><label>Update Interval (sec)<input id="adsbUpdateInterval" class="adsb-radius-input" type="number" min="1" max="300" step="1" value="5" inputmode="numeric"></label><label>Center source<select id="adsbCenterSource"><option value="manual">Manual lat/lon</option><option value="map_center">Current map center</option><option value="receiver">ADS-B receiver/default</option></select></label><label>Center lat<input id="adsbCenterLat" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="34.000000"></label><label>Center lon<input id="adsbCenterLon" class="adsb-coord-input" type="text" inputmode="decimal" placeholder="-118.000000"></label></div><div class="adsb-apply-row"><button class="layer-button" onclick="useMapCenterForAdsb()">Use Map Center</button><button class="layer-button" onclick="saveAdsbSettings(false)">Save Filter</button></div><div id="adsbSettingsStatus" class="muted" style="margin-top:7px"></div></div></div><div class="panel"><h2>Data Sync</h2><div class="row"><button class="layer-button" onclick="refreshDataSync()">Refresh Data Sync</button><span class="chip" id="missionCount">0 missions</span></div><div class="row"><label><input type="checkbox" checked onchange="toggleDataSyncObjects(this.checked)"><span>Show Data Sync objects</span></label><span class="chip" id="dataSyncObjectCount">0 objects</span></div><div id="dataSyncRows" class="sync-list"><div class="muted">Loading missions...</div></div></div><div class="panel"><h2>Local Data</h2><div class="row"><button class="layer-button" onclick="refreshLocalData()">Refresh local data</button><span class="chip" id="localDataCount">0</span></div><input id="importFileInput" type="file" multiple style="display:none" onchange="uploadImportFiles()"><div id="localDataRows"><div class="muted">Loading local data...</div></div></div><div class="panel"><h2>Offline Maps</h2><div class="subgroup-title">Create Offline Map Pack</div><input id="offlinePackName" class="search" placeholder="Pack name, e.g. Big Bear Topo"><div class="row"><span class="muted">Source basemap</span><span class="chip" id="offlineSourceText">Current basemap</span></div><div class="row"><span class="muted">Area</span><button class="layer-button" onclick="useCurrentViewForOffline()">Current View</button><button class="layer-button" onclick="startOfflineAreaDraw()">Draw Area</button><button class="layer-button" onclick="clearOfflineArea()">Clear</button></div><div id="offlineDrawHelp" class="draw-help" style="display:none">Drag on the map to draw the download rectangle.</div><div class="row"><span class="muted" id="offlineBoundsText">No area selected yet.</span></div><div id="offlineEstimate" class="muted">Use Current View or Draw Area, then choose zoom range to estimate download size.</div><div class="row"><label><span>Min zoom</span></label><input id="offlineMinZoom" class="search offline-zoom-input" type="number" min="0" max="19" value="8" style="width:88px" onchange="scheduleOfflineEstimate()" oninput="scheduleOfflineEstimate()"></div><div class="row"><label><span>Max zoom</span></label><input id="offlineMaxZoom" class="search offline-zoom-input" type="number" min="0" max="19" value="13" style="width:88px" onchange="scheduleOfflineEstimate()" oninput="scheduleOfflineEstimate()"></div><div class="row"><button class="layer-button" onclick="previewOfflineZoom()">Preview Max Zoom</button><button class="layer-button" onclick="startOfflineDownload()">Download Pack</button></div><div id="offlineJobStatus" class="muted" style="margin-top:7px"></div><div class="row"><button class="layer-button" onclick="refreshOfflineMaps()">Refresh Offline Maps</button></div><div id="offlineMapRows" class="offline-list"><div class="muted">No offline map packs downloaded yet.</div></div></div><div class="panel"><h2>External Sources</h2><div id="externalRows"></div></div><div class="panel"><h2>Tools</h2><div class="row"><button class="layer-button" onclick="fitVisible()">Fit visible</button><button class="layer-button" onclick="clearExternalLayers()">Clear external</button></div><div class="row local-elev-tools-row"><button id="localElevAddBtn" class="layer-button" type="button" onclick="openLocalElevationDialog()">Add Elevation Data</button><span id="localElevToolStatus" class="chip local-elev-tool-chip">Local: 0</span></div><div class="row"><button class="layer-button" onclick="exportAllData()">Export All Data</button></div><details class="export-options"><summary>Export options</summary><div class="export-check-list"><label><input id="exportDataSync" type="checkbox" checked> Data Sync</label><label><input id="exportLocalData" type="checkbox" checked> Local Data</label><label><input id="exportBasemaps" type="checkbox" checked> Added basemap files</label><label><input id="exportOfflineMaps" type="checkbox" checked> Offline maps</label><label><input id="exportExternal" type="checkbox" checked> External source files</label></div></details><span id="adsbStatus" style="display:none">auto</span><span id="eudStatus" style="display:none">0</span></div><div class="panel version-panel"><div class="version-product">TAK Server Dashboard</div><div class="version-row"><span class="release-main">1.1.0</span><span class="iteration-chip">v301</span></div></div></aside><button id="sidebarTab" class="sidebar-tab" onclick="toggleSidebar()" title="Collapse / expand menu">‹</button><div id="map"></div><div id="terrain3dPane" class="terrain3d-pane"><div id="terrain3dCanvas"></div><div class="terrain3d-zoom"><button onclick="terrain3DZoom(1)" title="Zoom in">+</button><button onclick="terrain3DZoom(-1)" title="Zoom out">−</button></div><div id="terrain3dCompass" class="terrain3d-compass" onclick="terrain3DResetNorth()" title="Reset north"><div class="ring"></div><div class="north">N</div><div id="terrain3dCompassNeedle" class="needle"></div></div><div id="terrain3dElevation" class="terrain3d-elevation">Terrain Elev: —</div><div id="terrain3dStatus" class="terrain3d-status">3D Terrain is off.</div><div class="terrain3d-controls"><label for="terrain3dQuality">Terrain Quality</label><select id="terrain3dQuality" onchange="setTerrain3DQuality(this.value)"><option value="low">Low</option><option value="medium" selected>Medium</option><option value="high">High</option></select></div><button class="layer-button terrain3d-refresh" onclick="refreshTerrain3DAll()">Refresh Terrain</button><button class="layer-button terrain3d-close" onclick="toggleTerrain3D(false)">2D Map</button></div><div id="floatingToolbarDock" class="floating-toolbar-dock"><div id="coordsMiniToolbar" class="map-mini-toolbar" aria-label="Coordinates tools"><button class="tool-btn" onclick="coordPinCurrent()" title="Pin Coordinate"><svg viewBox="0 0 24 24"><path d="M12 21s6-6.1 6-11a6 6 0 0 0-12 0c0 4.9 6 11 6 11Z"/><circle cx="12" cy="10" r="1.8"/></svg><span class="tool-label">Pin Coordinate</span></button><button class="tool-btn" onclick="coordClearPin()" title="Clear Pin"><svg viewBox="0 0 24 24"><path d="M12 21s6-6.1 6-11a6 6 0 0 0-12 0c0 4.9 6 11 6 11Z"/><circle cx="12" cy="10" r="1.8"/><path d="M4 20 20 4"/></svg><span class="tool-label">Clear Pin</span></button><button class="tool-btn" onclick="coordCopy()" title="Copy Coordinate"><svg viewBox="0 0 24 24"><rect x="8" y="5" width="11" height="13" rx="2"/><rect x="5" y="8" width="11" height="13" rx="2"/></svg><span class="tool-label">Copy Coordinate</span></button><button class="tool-btn" onclick="coordFormatToggle()" title="Format Toggle"><svg viewBox="0 0 24 24"><text x="2" y="8" font-size="6.5" font-weight="900" fill="currentColor" stroke="none">DD</text><text x="2" y="20" font-size="5" font-weight="900" fill="currentColor" stroke="none">MGRS</text><path d="M17.5 5.5l4 4-4 4"/><path d="M17.5 18.5l4-4-4-4" opacity=".82"/></svg><span class="tool-label">Format Toggle</span></button><button class="tool-btn" onclick="coordSaveLocalPoint()" title="Save Local Point"><svg viewBox="0 0 24 24"><path d="M9 20s5-5.2 5-9a5 5 0 0 0-10 0c0 3.8 5 9 5 9Z"/><circle cx="9" cy="11" r="1.4"/><rect x="12" y="12" width="8" height="8" rx="1"/><path d="M14 12v3h4v-3"/><path d="M14 18h4"/></svg><span class="tool-label">Save Local Point</span></button><button class="tool-btn" onclick="coordGoTo()" title="Go To Coordinate"><svg viewBox="0 0 24 24"><circle cx="11" cy="12" r="5"/><path d="M11 3v4"/><path d="M11 17v4"/><path d="M2 12h4"/><path d="M16 12h6"/><path d="M18 8l4 4-4 4"/></svg><span class="tool-label">Go To Coordinate</span></button></div><div id="measureMiniToolbar" class="map-mini-toolbar" aria-label="Measure tools"><button class="tool-btn" onclick="measureUndo()" title="Undo Last Point"><svg viewBox="0 0 24 24"><path d="M4 12 10 5h10v14H10Z"/><path d="M12 9l5 5"/><path d="M17 9l-5 5"/></svg><span class="tool-label">Undo Last Point</span></button><button class="tool-btn" onclick="measureClear()" title="Clear Measurement"><svg viewBox="0 0 24 24"><path d="M4 7h16"/><path d="M9 7V4h6v3"/><path d="M7 7l1 14h8l1-14"/><path d="M10 11v6"/><path d="M14 11v6"/></svg><span class="tool-label">Clear Measurement</span></button><button class="tool-btn" onclick="measureLock()" title="Finish / Lock"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg><span class="tool-label">Finish / Lock</span></button><button class="tool-btn" onclick="measureResume()" title="Resume Edit"><svg viewBox="0 0 24 24"><path d="M4 20h4l11-11-4-4L4 16v4Z"/><path d="m14 6 4 4"/></svg><span class="tool-label">Resume Edit</span></button><button class="tool-btn" onclick="measureCopy()" title="Copy Measurement"><svg viewBox="0 0 24 24"><rect x="8" y="5" width="11" height="13" rx="2"/><rect x="5" y="8" width="11" height="13" rx="2"/></svg><span class="tool-label">Copy Measurement</span></button><button class="tool-btn" onclick="measureUnitsToggle()" title="Units Toggle"><svg viewBox="0 0 24 24"><text x="3" y="10" font-size="6.4" font-weight="900" fill="currentColor" stroke="none">mi</text><text x="11" y="19" font-size="6.4" font-weight="900" fill="currentColor" stroke="none">km</text><path d="M18 5v4h-4"/><path d="M6 19v-4h4"/></svg><span class="tool-label">Units Toggle</span></button><label class="tool-color" title="Line/Text Color"><input type="color" value="#b9c4c9" onchange="setMeasureLineColor(this.value)"><span class="tool-label">Line/Text Color</span></label></div><div id="floatingMapToolbar" class="floating-map-toolbar"><div id="toolbarDragGrip" class="toolbar-grip">⋮⋮</div><button id="toolMove" class="tool-btn active" onclick="toggleMapTool('move')" title="Move / Pan"><svg viewBox="0 0 24 24"><path d="M8 12V6.8a1.4 1.4 0 0 1 2.8 0V12"/><path d="M10.8 11V5.8a1.4 1.4 0 0 1 2.8 0V12"/><path d="M13.6 11.5V7a1.4 1.4 0 0 1 2.8 0v6"/><path d="M16.4 12.5V10a1.4 1.4 0 0 1 2.8 0v4.6c0 3.4-2.3 5.4-5.5 5.4h-2.3c-2 0-3.4-.8-4.6-2.4L4.3 14a1.5 1.5 0 0 1 2.3-1.9L8 13.5"/></svg><span class="tool-label">Move / Pan</span></button><button id="toolCoords" class="tool-btn" onclick="toggleMapTool('coords')" title="Coordinates"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5.2"/><circle cx="12" cy="12" r="1.2"/><path d="M12 2.5v5"/><path d="M12 16.5v5"/><path d="M2.5 12h5"/><path d="M16.5 12h5"/></svg><span class="tool-label">Coordinates</span></button><button id="toolMeasure" class="tool-btn" onclick="toggleMapTool('measure')" title="Measure"><svg viewBox="0 0 24 24"><path d="M4 17 17 4l3 3L7 20z"/><path d="m7 14 3 3"/><path d="m10 11 2 2"/><path d="m13 8 3 3"/></svg><span class="tool-label">Measure</span></button><button id="toolFit" class="tool-btn" onclick="fitVisible()" title="Fit All Data"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3.8"/><path d="M12 3.2v4.2"/><path d="M12 16.6v4.2"/><path d="M3.2 12h4.2"/><path d="M16.6 12h4.2"/><path d="M7.2 7.2 4.3 4.3"/><path d="M16.8 7.2l2.9-2.9"/><path d="M7.2 16.8l-2.9 2.9"/><path d="M16.8 16.8l2.9 2.9"/></svg><span class="tool-label">Fit All Data</span></button><button id="tool3d" class="tool-btn" onclick="toggleTerrain3D()" title="3D Terrain"><svg viewBox="0 0 24 24"><path d="M3 18 9 7l4 7 3-4 5 8Z"/><path d="M7 18h13"/><path d="M9 18l4-4 3 4"/></svg><span class="tool-label">3D Terrain</span></button><button id="toolClearHidden" class="tool-btn" onclick="clearHiddenMapItems()" title="Clear Hidden"><svg viewBox="0 0 24 24"><path d="M3 3l18 18"/><path d="M10.6 10.6a2 2 0 0 0 2.8 2.8"/><path d="M9.4 5.2A10.6 10.6 0 0 1 12 5c5 0 8 4.5 9 7a14 14 0 0 1-2.2 3.3"/><path d="M6.1 6.4C4.4 7.6 3.2 9.7 3 12c1 2.5 4 7 9 7 1.4 0 2.7-.3 3.8-.9"/></svg><span class="tool-label">Clear Hidden</span></button></div></div><div id="coordReadout" class="map-tool-readout"><span class="mode">Coordinates</span><span id="coordLiveText">Move pointer over map</span><span id="coordPinnedText" class="pinned" style="display:none"></span></div><div class="zoom-indicator" id="zoomIndicator">Zoom z--</div><div id="sendModal" class="send-modal" onclick="sendModalBackdrop(event)"><div class="send-box"><h3>Send Offline Map</h3><div class="muted" id="sendMapName">Select EUDs to receive this offline map package.</div><div id="sendMapDetails"></div><div id="sendEudRows" style="margin-top:8px"></div><div class="send-footer"><span id="sendFooterCount" class="muted">Loading EUDs...</span><div class="row"><button id="sendConfirmBtn" class="layer-button" onclick="confirmSendOfflineMap()">Send (0)</button><button class="layer-button" onclick="closeSendModal()">Cancel</button></div></div><div id="sendStatus" class="muted"></div></div></div><script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script><script>



let map,config=null,baseLayer=null,reliefLayer=null,activeBasemap='',basemapUserChanged=false,externalLayers={},routeLayers={},aircraftLayer=L.layerGroup(),takMarkerLayer=L.layerGroup(),dataSyncLayer=L.layerGroup(),importedLayer=L.layerGroup(),selectedAircraftId='',mapSearchItems=[],offlineMaps=[],offlineDownloadBounds=null,offlineJobTimer=null,lastOfflineEstimate=null,lastTakMarkers=[],offlineAreaRect=null,offlineDrawRect=null,offlineDrawStart=null,offlineDrawing=false,activeSendMapId='',activeSendMode='offline',activeSendBasemapId='',lastBanner=null,activeMapTool='move',lastPointerLatLng=null,pinnedCoordinate=null,coordFormatMode='DD',measurePoints=[],measureLocked=false,measureUnitsMode='all',measureLayer=null,measureLineColor='#b9c4c9',measureTextColor='#c6d0d5',measureDragIndex=null,lastDataSyncSuccessMs=0,lastDataSyncSuccessReason='',customBasemapImportStatus='',terrain3DActive=false,terrain3DViewer=null,terrain3DLoading=false,terrain3DLayerReady=false,terrain3DQuality='medium',terrain3DLastObjectHash='',terrain3DLastObjectRefreshMs=0,terrain3DRefreshTimer=null,terrain3DLastRenderableCount=0,terrain3DMoving=false,terrain3DDeferredRefresh=false,terrain3DClusterBuckets=null,terrain3DClusteredCount=0,terrain3DElevationHandler=null,terrain3DLastElevationMs=0;const state={dataSync:true,imported:true,live:{cot_markers:true,euds:true,server_gps:true,webform_reports:false,adsb_aircraft:false},external:{},routes:{},local:{routes:{},points:{},shapes:{},hidden:{}},localRouteColors:{},localCollapsed:{routes:false,points:false,shapes:false},dataSyncCollapsed:{missions:false,pointers:false,routes:false,shapes:false,files:false,other:true}};let activePopupEditBox=null;
function uiPrefGetJson(key,fallback){try{const v=localStorage.getItem(key);if(!v)return fallback;return JSON.parse(v)}catch(e){return fallback}}
function uiPrefSetJson(key,val){try{localStorage.setItem(key,JSON.stringify(val))}catch(e){}}
function loadTakMapUiPrefs(){try{Object.assign(state.localCollapsed,uiPrefGetJson('takMapLocalCollapsed',{}));Object.assign(state.dataSyncCollapsed,uiPrefGetJson('takMapDataSyncCollapsed',{}))}catch(e){}}
function saveTakMapUiPrefs(){try{uiPrefSetJson('takMapLocalCollapsed',state.localCollapsed);uiPrefSetJson('takMapDataSyncCollapsed',state.dataSyncCollapsed)}catch(e){}}
loadTakMapUiPrefs();
try{terrain3DQuality=localStorage.getItem('takMapTerrain3DQuality')||terrain3DQuality}catch(e){}
function clearPinnedPopup(){try{const lyr=window._takPinnedPopupLayer;if(lyr){lyr._takPopupPinned=false;if(!popupEditActiveInLayer(lyr)&&lyr.closePopup)lyr.closePopup()}window._takPinnedPopupLayer=null}catch(e){}}
function closeUnpinnedPopup(layer){try{if(layer&&layer._takPopupPinned)return;if(layer&&layer._takPopupHover)return;if(popupEditActiveInLayer(layer))return;if(layer&&layer.closePopup)layer.closePopup()}catch(e){}}
function formatLastSyncTime(){return lastDataSyncSuccessMs?shortDateTime24(lastDataSyncSuccessMs):'Never'}
function esc(s){return String(s??'').replace(/[&<>\"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}[c]||c))}function cookieVal(name){try{return ('; '+document.cookie).split('; '+name+'=').pop().split(';')[0]||''}catch(e){return''}}function basemapExists(id){try{return !!(config&&Array.isArray(config.basemaps)&&(config.basemaps||[]).some(b=>String(b.id)===String(id)))}catch(e){return true}}function savedBasemap(){try{const server=String((config&&config.last_basemap)||'').trim();if(server&&basemapExists(server)){try{localStorage.setItem('takMapBasemap',server);localStorage.setItem('tak-map-last-basemap',server);localStorage.setItem('lastBasemap',server);const ts=Date.parse(config.last_basemap_updated||config.updated||'')||Date.now();localStorage.setItem('takMapBasemap:ts',String(ts));localStorage.setItem('tak-map-last-basemap:ts',String(ts));localStorage.setItem('lastBasemap:ts',String(ts));document.cookie='takMapBasemap='+encodeURIComponent(server)+'; path=/; max-age=31536000; SameSite=Lax';document.cookie='tak-map-last-basemap='+encodeURIComponent(server)+'; path=/; max-age=31536000; SameSite=Lax';document.cookie='takMapBasemapTs='+String(ts)+'; path=/; max-age=31536000; SameSite=Lax'}catch(e){}return server}}catch(e){}const cand=[];const add=(v,ts,src)=>{v=String(v||'').trim();if(!v)return;ts=Number(ts||0);cand.push({v,ts,src})};const keys=['takMapBasemap','tak-map-last-basemap','lastBasemap'];try{for(const k of keys){add(localStorage.getItem(k),localStorage.getItem(k+':ts')||localStorage.getItem('takMapBasemap:ts')||0,k)}}catch(e){}try{add(decodeURIComponent(cookieVal('takMapBasemap')||''),Number(cookieVal('takMapBasemapTs')||0),'cookie');add(decodeURIComponent(cookieVal('tak-map-last-basemap')||''),Number(cookieVal('takMapBasemapTs')||0),'cookie2')}catch(e){}cand.sort((a,b)=>(b.ts||0)-(a.ts||0));for(const c of cand){if(basemapExists(c.v))return c.v}return''}function basemapPrefUrls(id,ts){const q='last_basemap='+encodeURIComponent(id)+'&basemap='+encodeURIComponent(id)+'&id='+encodeURIComponent(id)+'&ts='+encodeURIComponent(String(ts))+'&_='+encodeURIComponent(String(Date.now()));return ['/api/tak-map/preferences-save?'+q,'/api/tak-map/basemap-save?'+q,'/api/tak-map/basemap.gif?'+q]}
function setBasemapSaveStatus(msg,ok){try{window._takMapLastBasemapSaveStatus={msg,ok,ts:Date.now()}}catch(e){}}
async function saveBasemap(id){id=String(id||'').trim();if(!id)return {ok:false,error:'empty basemap id'};const ts=Date.now();try{localStorage.setItem('takMapBasemap',id);localStorage.setItem('takMapBasemap:ts',String(ts));localStorage.setItem('tak-map-last-basemap',id);localStorage.setItem('tak-map-last-basemap:ts',String(ts));localStorage.setItem('lastBasemap',id);localStorage.setItem('lastBasemap:ts',String(ts))}catch(e){}try{document.cookie='takMapBasemap='+encodeURIComponent(id)+'; path=/; max-age=31536000; SameSite=Lax';document.cookie='tak-map-last-basemap='+encodeURIComponent(id)+'; path=/; max-age=31536000; SameSite=Lax';document.cookie='takMapBasemapTs='+String(ts)+'; path=/; max-age=31536000; SameSite=Lax'}catch(e){}const body=JSON.stringify({last_basemap:id,lastBasemap:id,basemap:id,id,ts});const urls=basemapPrefUrls(id,ts);let best=null;try{const r=await fetch('/api/tak-map/preferences',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'},body,cache:'no-store'});best=await r.json().catch(()=>({ok:r.ok,status:r.status}));if(r.ok&&best&&best.ok){if(best.prefs&&best.prefs.last_basemap){config.last_basemap=best.prefs.last_basemap;config.last_basemap_updated=best.prefs.last_basemap_updated||best.prefs.updated||new Date(ts).toISOString()}setBasemapSaveStatus((basemapById(id)?.label||id)+' · basemap saved',true);return best}}catch(e){best={ok:false,error:String(e)}}for(const url of urls){try{const r=await fetch(url,{method:'GET',credentials:'include',cache:'no-store'});const j=await r.json().catch(()=>({ok:r.ok,status:r.status}));if(r.ok&&j&&j.ok){if(j.prefs&&j.prefs.last_basemap){config.last_basemap=j.prefs.last_basemap;config.last_basemap_updated=j.prefs.last_basemap_updated||j.prefs.updated||new Date(ts).toISOString()}setBasemapSaveStatus((basemapById(id)?.label||id)+' · basemap saved',true);return j}best=j}catch(e){best={ok:false,error:String(e)}}}
try{for(const url of urls){const img=document.createElement('img');img.alt='';img.style.cssText='position:absolute;width:1px;height:1px;opacity:0;pointer-events:none;left:-9999px;top:-9999px';img.src=url+'&img=1';document.body.appendChild(img);setTimeout(()=>{try{img.remove()}catch(e){}},15000)}}catch(e){}
try{if(navigator.sendBeacon){navigator.sendBeacon('/api/tak-map/preferences',new Blob([body],{type:'application/json'}))}}catch(e){}
setBasemapSaveStatus((basemapById(id)?.label||id)+' · basemap saved locally; server save pending',false);return best||{ok:false,error:'server preference save did not confirm'}}
try{window.addEventListener('beforeunload',()=>{})}catch(e){}function layerSearchText(){return (document.getElementById('layerSearch')?.value||'').toLowerCase().trim()}function visibleText(txt){return true}function searchBlob(item){return String([item.label,item.kind,item.source,item.uid,item.type].filter(Boolean).join(' ')).toLowerCase()}function clearSearchSource(src){mapSearchItems=mapSearchItems.filter(x=>x.source!==src)}function addSearchItem(src,kind,label,lat,lon,layer,meta){if(lat==null||lon==null||!layer)return;mapSearchItems.push({id:src+':'+mapSearchItems.length,source:src,kind:kind||src,label:String(label||kind||src),lat:Number(lat),lon:Number(lon),layer,uid:meta?.uid||meta?.id||'',type:meta?.type||'',sourceLabel:meta?.source||src})}function clearMapSearch(){const i=document.getElementById('layerSearch');if(i)i.value='';handleMapSearch()}function handleMapSearch(){renderSearchResults();applySearchStyles()}function searchMatches(item,q){return !q||searchBlob(item).includes(q)}function renderSearchResults(){const box=document.getElementById('searchResults');if(!box)return;const q=layerSearchText();if(!q){box.style.display='none';box.innerHTML='';return}const matches=mapSearchItems.filter(i=>searchMatches(i,q)).slice(0,24);box.style.display='block';box.innerHTML=matches.length?matches.map(i=>`<button class="search-result-item" onclick="chooseSearchItem('${esc(i.id)}')"><span><b>${esc(i.label)}</b><small>${esc(i.kind)} · ${esc(i.sourceLabel)}</small></span><span class="search-result-chip">${esc(i.type||i.source)}</span></button>`).join(''):'<div class="muted" style="padding:8px">No matching map objects.</div>'}function chooseSearchItem(id){const item=mapSearchItems.find(x=>x.id===id);if(!item)return;map.panTo([item.lat,item.lon],{animate:true});setTimeout(()=>{try{item.layer.openPopup&&item.layer.openPopup()}catch(e){}},220)}function applySearchStyles(){const q=layerSearchText();for(const item of mapSearchItems){try{const el=item.layer.getElement&&item.layer.getElement();if(!el)continue;el.classList.remove('search-dim','search-hit');if(q){el.classList.add(searchMatches(item,q)?'search-hit':'search-dim')}}catch(e){}}}function toggleSidebar(){const sb=document.getElementById('sidebar');const tab=document.getElementById('sidebarTab');const banner=document.getElementById('mapStatusBanner');sb.classList.toggle('collapsed');const collapsed=sb.classList.contains('collapsed');if(tab)tab.textContent=collapsed?'›':'‹';if(banner)banner.style.left=collapsed?'66px':(window.matchMedia('(max-width:900px)').matches?'66px':'462px');setTimeout(()=>map&&map.invalidateSize(),220)}async function logoutTakMap(){try{await fetch('/api/tak-map/logout',{method:'POST'});}catch(e){}location.href='/tak-map/login'}
function sectionIdFromTitle(t){return String(t||'section').toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')||'section'}function makeMenuCollapsible(){document.querySelectorAll('.sidebar .panel').forEach((panel,idx)=>{if(panel.dataset.collapsibleReady)return;const h=panel.querySelector('h2');if(!h)return;const id=sectionIdFromTitle(h.textContent||('section-'+idx));panel.dataset.sectionId=id;const body=document.createElement('div');body.className='panel-body';const nodes=[];let n=h.nextSibling;while(n){const next=n.nextSibling;nodes.push(n);n=next}nodes.forEach(x=>body.appendChild(x));panel.appendChild(body);panel.classList.add('collapsible');const key='takMapPanelCollapsed:'+id;const saved=localStorage.getItem(key);if(saved==='1')panel.classList.add('collapsed');const title=h.textContent;h.innerHTML=`<span>${esc(title)}</span><span class="panel-toggle">${panel.classList.contains('collapsed')?'▸':'▾'}</span>`;h.addEventListener('click',()=>{panel.classList.toggle('collapsed');localStorage.setItem(key,panel.classList.contains('collapsed')?'1':'0');const t=panel.querySelector('.panel-toggle');if(t)t.textContent=panel.classList.contains('collapsed')?'▸':'▾';setTimeout(()=>{try{map.invalidateSize()}catch(e){}},50)});panel.dataset.collapsibleReady='1'})}
function pad2(n){return String(n).padStart(2,'0')}
function shortDateTime24(value){try{let d=null;if(value==null||value==='')return'Unknown';if(typeof value==='number'){d=new Date(value>100000000000?value:value*1000)}else{let s=String(value).trim();if(/^\d+$/.test(s)){const n=Number(s);d=new Date(n>100000000000?n:n*1000)}else{d=new Date(s)}}if(!d||isNaN(d.getTime()))return String(value).slice(0,16);return pad2(d.getMonth()+1)+'/'+pad2(d.getDate())+'/'+d.getFullYear()+' '+pad2(d.getHours())+':'+pad2(d.getMinutes())}catch(e){return'Unknown'}}
function missionNameFromAny(m){return rowLabel(m)||m.name||m.title||m.uid||m.guid||'Mission'}
function missionUpdatedValue(m){for(const k of ['updated','updateTime','update_time','updated_at','last_update','lastUpdated','modified','modified_at','createTime','create_time','create_datetime','created','created_at','timestamp']){if(m&&m[k])return m[k]}return''}
function missionServerName(m){return String((m&&(m.server_name||m.server||m.host||m.source_server))||(config&&(config.server_name||config.hostname||config.tak_server_name))||location.hostname||'TAK Server')}
function missionDisplayMeta(m){return missionServerName(m)+' - Last Sync '+formatLastSyncTime()}
function setActiveMapTool(tool){activeMapTool=tool||'move';if(activeMapTool!=='coords'){}if(activeMapTool!=='measure'){}updateToolUi()}
function toggleMapTool(tool){setActiveMapTool(activeMapTool===tool?'move':tool)}
function updateToolUi(){try{['Move','Coords','Measure'].forEach(n=>{const el=document.getElementById('tool'+n);if(el)el.classList.remove('active')});const mapEl={move:'toolMove',coords:'toolCoords',measure:'toolMeasure'}[activeMapTool]||'toolMove';const active=document.getElementById(mapEl);if(active)active.classList.add('active');const main=document.getElementById('floatingMapToolbar');if(main)main.style.display='block';const cr=document.getElementById('coordReadout');if(cr)cr.classList.toggle('active',activeMapTool==='coords');const cm=document.getElementById('coordsMiniToolbar');if(cm)cm.classList.toggle('active',activeMapTool==='coords');const mm=document.getElementById('measureMiniToolbar');if(mm)mm.classList.toggle('active',activeMapTool==='measure');if(map&&map.getContainer){const c=map.getContainer();c.classList.toggle('coords-tool-active',activeMapTool==='coords');c.classList.toggle('measure-tool-active',activeMapTool==='measure')}if(activeMapTool==='coords')updateCoordReadout(pinnedCoordinate||lastPointerLatLng,!!pinnedCoordinate);if(activeMapTool==='measure')drawMeasure();const t3d=document.getElementById('tool3d');if(t3d)t3d.classList.toggle('active',!!terrain3DActive);try{document.body.classList.toggle('terrain-3d-active',!!terrain3DActive)}catch(_){}}catch(e){try{console.warn('updateToolUi failed',e)}catch(_){}}}
function initFloatingToolbar(){try{const dock=document.getElementById('floatingToolbarDock');const grip=document.getElementById('toolbarDragGrip');if(dock&&grip){let drag=null;grip.addEventListener('pointerdown',ev=>{drag={x:ev.clientX,y:ev.clientY,left:dock.getBoundingClientRect().left,top:dock.getBoundingClientRect().top};try{grip.setPointerCapture(ev.pointerId)}catch(_){ }ev.preventDefault()});grip.addEventListener('pointermove',ev=>{if(!drag)return;dock.style.left=Math.max(8,Math.min(window.innerWidth-60,drag.left+ev.clientX-drag.x))+'px';dock.style.top=Math.max(94,Math.min(window.innerHeight-80,drag.top+ev.clientY-drag.y))+'px';dock.style.right='auto'});grip.addEventListener('pointerup',()=>{drag=null});grip.addEventListener('pointercancel',()=>{drag=null})}if(map){map.on('mousemove',e=>{lastPointerLatLng=e.latlng;if(activeMapTool==='coords'&&!pinnedCoordinate)updateCoordReadout(e.latlng,false)});map.on('click',e=>{if(activeMapTool==='coords'){pinnedCoordinate=e.latlng;updateCoordReadout(e.latlng,true);return}else if(activeMapTool==='measure'){measureAddPoint(e.latlng);return}clearPinnedPopup()})}updateToolUi()}catch(e){try{console.warn('initFloatingToolbar failed',e)}catch(_){}}}
function formatDmsPart(v,lat){const hemi=lat?(v>=0?'N':'S'):(v>=0?'E':'W');v=Math.abs(Number(v));const deg=Math.floor(v);const minF=(v-deg)*60;const min=Math.floor(minF);const sec=(minF-min)*60;return deg+'°'+pad2(min)+"'"+sec.toFixed(1)+'"'+hemi}
function latBand(lat){const bands='CDEFGHJKLMNPQRSTUVWX';let i=Math.floor((Number(lat)+80)/8);if(i<0)i=0;if(i>bands.length-1)i=bands.length-1;return bands[i]}
function latLonToUtm(lat,lon){lat=Number(lat);lon=Number(lon);const a=6378137,f=1/298.257223563,k0=.9996,e=Math.sqrt(f*(2-f)),e2=e*e,ep2=e2/(1-e2);const zone=Math.floor((lon+180)/6)+1;const lon0=(zone-1)*6-180+3;const p=Math.PI/180;const phi=lat*p,lam=lon*p,lam0=lon0*p;const N=a/Math.sqrt(1-e2*Math.sin(phi)**2),T=Math.tan(phi)**2,C=ep2*Math.cos(phi)**2,A=Math.cos(phi)*(lam-lam0);const M=a*((1-e2/4-3*e2*e2/64-5*e2**3/256)*phi-(3*e2/8+3*e2*e2/32+45*e2**3/1024)*Math.sin(2*phi)+(15*e2*e2/256+45*e2**3/1024)*Math.sin(4*phi)-(35*e2**3/3072)*Math.sin(6*phi));let E=k0*N*(A+(1-T+C)*A**3/6+(5-18*T+T*T+72*C-58*ep2)*A**5/120)+500000;let Nn=k0*(M+N*Math.tan(phi)*(A*A/2+(5-T+9*C+4*C*C)*A**4/24+(61-58*T+T*T+600*C-330*ep2)*A**6/720));if(lat<0)Nn+=10000000;return{zone,band:latBand(lat),easting:E,northing:Nn}}
function formatUtm(lat,lon){try{const u=latLonToUtm(lat,lon);return u.zone+u.band+' '+Math.round(u.easting)+'E '+Math.round(u.northing)+'N'}catch(e){return Number(lat).toFixed(5)+', '+Number(lon).toFixed(5)}}
function formatMgrs(lat,lon){try{const u=latLonToUtm(lat,lon);const sets=['ABCDEFGH','JKLMNPQR','STUVWXYZ'];const colSet=sets[(u.zone-1)%3];const col=colSet[Math.max(0,Math.min(7,Math.floor(u.easting/100000)-1))]||'Z';const rows='ABCDEFGHJKLMNPQRSTUV';const row=rows[(Math.floor(u.northing/100000)+((u.zone%2)===0?5:0))%20]||'Z';const er=String(Math.floor(u.easting%100000)).padStart(5,'0');const nr=String(Math.floor(u.northing%100000)).padStart(5,'0');return u.zone+u.band+' '+col+row+' '+er+' '+nr}catch(e){return formatUtm(lat,lon)}}
function formatCoordMode(ll){if(!ll)return'Move pointer over map';const lat=Number(ll.lat),lng=Number(ll.lng);if(coordFormatMode==='DMS')return formatDmsPart(lat,true)+' '+formatDmsPart(lng,false);if(coordFormatMode==='UTM')return formatUtm(lat,lng);if(coordFormatMode==='MGRS')return formatMgrs(lat,lng);return lat.toFixed(6)+', '+lng.toFixed(6)}
function updateCoordReadout(ll,pinned){const live=document.getElementById('coordLiveText');const pin=document.getElementById('coordPinnedText');if(live)live.textContent=(pinned?'Pinned: ':'Live: ')+formatCoordMode(ll);if(pin){pin.style.display=pinnedCoordinate?'inline':'none';pin.textContent=pinnedCoordinate?'Pinned '+coordFormatMode:''}}
function coordPinCurrent(){if(lastPointerLatLng){pinnedCoordinate=lastPointerLatLng;updateCoordReadout(pinnedCoordinate,true)}else alert('Move the pointer over the map first.')}function coordClearPin(){pinnedCoordinate=null;updateCoordReadout(lastPointerLatLng,false)}
async function copyText(text){try{await navigator.clipboard.writeText(text);return true}catch(e){try{const t=document.createElement('textarea');t.value=text;document.body.appendChild(t);t.select();document.execCommand('copy');t.remove();return true}catch(_){return false}}}
async function coordCopy(){const ll=pinnedCoordinate||lastPointerLatLng;if(!ll){alert('No coordinate selected yet.');return}const ok=await copyText(formatCoordMode(ll));if(!ok)alert(formatCoordMode(ll))}
function coordFormatToggle(){const modes=['DD','DMS','MGRS','UTM'];coordFormatMode=modes[(modes.indexOf(coordFormatMode)+1)%modes.length];updateCoordReadout(pinnedCoordinate||lastPointerLatLng,!!pinnedCoordinate)}
function parseCoordinateText(s){const nums=String(s||'').match(/-?\d+(?:\.\d+)?/g)||[];if(nums.length<2)return null;let a=Number(nums[0]),b=Number(nums[1]);if(!Number.isFinite(a)||!Number.isFinite(b))return null;if(Math.abs(a)<=90&&Math.abs(b)<=180)return L.latLng(a,b);if(Math.abs(b)<=90&&Math.abs(a)<=180)return L.latLng(b,a);return null}
function coordGoTo(){const s=prompt('Go to coordinate (lat, lon):',pinnedCoordinate?formatCoordMode(pinnedCoordinate):(lastPointerLatLng?formatCoordMode(lastPointerLatLng):''));const ll=parseCoordinateText(s);if(!ll){if(s!==null)alert('Could not parse coordinate. Use lat, lon.');return}pinnedCoordinate=ll;map.setView(ll,Math.max(map.getZoom(),14));updateCoordReadout(ll,true)}
async function coordSaveLocalPoint(){const ll=pinnedCoordinate||lastPointerLatLng;if(!ll){alert('Pin or hover a coordinate first.');return}const name=(prompt('Save Local Point name:','Coordinate '+shortDateTime24(Date.now()).replace(/[/:]/g,'-'))||'').trim();if(!name)return;try{const feature={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'Point',coordinates:[Number(ll.lng),Number(ll.lat)]},properties:{name,source:'TAK Map Coordinates',kind:'point',format:coordFormatMode,coordinate:formatCoordMode(ll)}}]};const blob=new Blob([JSON.stringify(feature,null,2)],{type:'application/geo+json'});const file=new File([blob],name.replace(/[\\/:*?"<>|]+/g,'-')+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));lastImports=j.imports||lastImports;await refreshLocalData();drawImportedObjects()}catch(e){alert('Save Local Point failed: '+e)}}
function fmtDistance(m,mode){m=Number(m||0);const ft=m*3.280839895,mi=m/1609.344,km=m/1000;if(mode==='imperial')return mi>=0.1?mi.toFixed(2)+' mi':Math.round(ft)+' ft';if(mode==='metric')return km>=0.1?km.toFixed(2)+' km':Math.round(m)+' m';return mi.toFixed(2)+' mi / '+Math.round(m)+' m'}
function measureSegments(){const seg=[];for(let i=1;i<measurePoints.length;i++){seg.push({a:measurePoints[i-1],b:measurePoints[i],m:map.distance(measurePoints[i-1],measurePoints[i])})}return seg}
function measureSummaryHtml(){const seg=measureSegments();const total=seg.reduce((a,s)=>a+s.m,0);let html='<div class="measure-popup-box" style="color:'+esc(measureTextColor)+'"><h3>Measure Path</h3>';seg.forEach((s,i)=>{html+='<div class="measure-popup-row"><span>Segment '+(i+1)+'</span><b>'+fmtDistance(s.m,'imperial')+' · '+fmtDistance(s.m,'metric')+'</b></div>'});html+='<div class="measure-popup-total">Total: '+(total/1609.344).toFixed(2)+' mi · '+Math.round(total*3.280839895).toLocaleString()+' ft · '+(total/1000).toFixed(2)+' km · '+Math.round(total).toLocaleString()+' m</div></div>';return html}
function drawMeasure(){if(!measureLayer||!map)return;measureLayer.clearLayers();if(!measurePoints.length)return;for(let i=0;i<measurePoints.length;i++){const p=measurePoints[i];const marker=L.marker(p,{interactive:true,draggable:!measureLocked,zIndexOffset:10020,icon:L.divIcon({className:'',html:'<div class="measure-point-dot" style="border-color:#071014;background:'+esc(measureLineColor)+'"></div>',iconSize:[14,14],iconAnchor:[7,7]})}).addTo(measureLayer);marker.on('click',ev=>{try{L.DomEvent.stop(ev)}catch(_){}});marker.on('dragstart',()=>{measureDragIndex=i});marker.on('drag',ev=>{if(measureDragIndex===i){measurePoints[i]=ev.target.getLatLng()}});marker.on('dragend',ev=>{measurePoints[i]=ev.target.getLatLng();measureDragIndex=null;drawMeasure()})}if(measurePoints.length>=2){L.polyline(measurePoints,{color:measureLineColor||'#b9c4c9',weight:3,opacity:.86,dashArray:measureLocked?'6 6':null}).addTo(measureLayer);measureSegments().forEach((s,i)=>{const mid=L.latLng((s.a.lat+s.b.lat)/2,(s.a.lng+s.b.lng)/2);L.marker(mid,{interactive:false,zIndexOffset:10030,icon:L.divIcon({className:'',html:'<div class="measure-seg-label" style="color:'+esc(measureTextColor)+';border-color:'+esc(measureTextColor)+';background:rgba(6,10,14,.94)">'+esc(fmtDistance(s.m,measureUnitsMode))+'</div>',iconAnchor:[0,0]})}).addTo(measureLayer)});L.marker(measurePoints[measurePoints.length-1],{interactive:false,zIndexOffset:10040,icon:L.divIcon({className:'',html:measureSummaryHtml(),iconAnchor:[0,-8]})}).addTo(measureLayer)}}
function setMeasureLineColor(v){measureLineColor=String(v||'#b9c4c9');drawMeasure()}
function setMeasureTextColor(v){measureTextColor=String(v||'#c6d0d5');drawMeasure()}
function measureAddPoint(ll){if(measureLocked){alert('Measurement is locked. Use Resume Edit to add points.');return}measurePoints.push(ll);drawMeasure()}function measureUndo(){if(measureLocked)return alert('Measurement is locked. Use Resume Edit first.');measurePoints.pop();drawMeasure()}function measureClear(){measurePoints=[];measureLocked=false;drawMeasure();updateToolUi()}function measureLock(){if(measurePoints.length<2)return alert('Add at least two measurement points.');measureLocked=true;drawMeasure();updateToolUi()}function measureResume(){measureLocked=false;drawMeasure();updateToolUi()}async function measureCopy(){const seg=measureSegments();if(!seg.length){alert('No measurement to copy.');return}const total=seg.reduce((a,s)=>a+s.m,0);let text='Measurement\n';seg.forEach((s,i)=>{text+='Segment '+(i+1)+': '+fmtDistance(s.m,'imperial')+' / '+fmtDistance(s.m,'metric')+'\n'});text+='Total: '+(total/1609.344).toFixed(2)+' mi / '+Math.round(total*3.280839895)+' ft / '+(total/1000).toFixed(2)+' km / '+Math.round(total)+' m';const ok=await copyText(text);if(!ok)alert(text)}function measureUnitsToggle(){const modes=['all','imperial','metric'];measureUnitsMode=modes[(modes.indexOf(measureUnitsMode)+1)%modes.length];drawMeasure()}
function terrainStatus(msg,bad){try{const el=document.getElementById('terrain3dStatus');if(el){el.textContent=msg;el.style.borderColor=bad?'rgba(255,95,87,.65)':'rgba(53,69,86,.88)';el.style.color=bad?'#ffd2d2':'#c7d1d7'}}catch(e){}}
function loadCssOnce(id,href){return new Promise((resolve,reject)=>{try{if(document.getElementById(id))return resolve();const l=document.createElement('link');l.id=id;l.rel='stylesheet';l.href=href;l.onload=()=>resolve();l.onerror=()=>reject(new Error('Could not load '+href));document.head.appendChild(l)}catch(e){reject(e)}})}
function loadScriptOnce(id,src){return new Promise((resolve,reject)=>{try{if(window.Cesium)return resolve();if(document.getElementById(id)){const wait=()=>window.Cesium?resolve():setTimeout(wait,120);return wait()}const s=document.createElement('script');s.id=id;s.src=src;s.async=true;s.onload=()=>resolve();s.onerror=()=>reject(new Error('Could not load '+src));document.head.appendChild(s)}catch(e){reject(e)}})}
async function loadCesiumAssets(){await loadCssOnce('cesiumCss','https://cdn.jsdelivr.net/npm/cesium@1.119.0/Build/Cesium/Widgets/widgets.css');await loadScriptOnce('cesiumJs','https://cdn.jsdelivr.net/npm/cesium@1.119.0/Build/Cesium/Cesium.js');if(!window.Cesium)throw new Error('Cesium did not load')}
function cesiumBasemapProvider(){const b=basemapById(activeBasemap)||basemapById(config?.default_basemap)||{};const url=String(b.url||'');if(!url.includes('{z}')||!url.includes('{x}')||!url.includes('{y}'))return null;return new Cesium.UrlTemplateImageryProvider({url:url,minimumLevel:Number(b.minZoom||0),maximumLevel:basemapMaxZoom(b),credit:b.attribution||b.label||'Basemap'})}
async function cesiumTerrainProvider(){const url='https://elevation3d.arcgis.com/arcgis/rest/services/WorldElevation3D/Terrain3D/ImageServer';if(Cesium.ArcGISTiledElevationTerrainProvider&&Cesium.ArcGISTiledElevationTerrainProvider.fromUrl)return await Cesium.ArcGISTiledElevationTerrainProvider.fromUrl(url);if(Cesium.ArcGISTiledElevationTerrainProvider)return new Cesium.ArcGISTiledElevationTerrainProvider({url});return new Cesium.EllipsoidTerrainProvider()}
async function ensureTerrain3DViewer(){if(terrain3DViewer)return terrain3DViewer;if(terrain3DLoading)throw new Error('3D terrain is already loading');terrain3DLoading=true;terrainStatus('Loading 3D terrain engine...');try{await loadCesiumAssets();const box=document.getElementById('terrain3dCanvas');if(!box)throw new Error('3D terrain container missing');box.innerHTML='';const imagery=cesiumBasemapProvider();const terrain=await cesiumTerrainProvider();terrain3DViewer=new Cesium.Viewer(box,{animation:false,timeline:false,geocoder:false,homeButton:false,sceneModePicker:false,baseLayerPicker:false,navigationHelpButton:false,fullscreenButton:false,selectionIndicator:false,infoBox:false,shouldAnimate:false,requestRenderMode:true,maximumRenderTimeChange:Infinity,imageryProvider:imagery||undefined,terrainProvider:terrain||undefined});terrain3DViewer.scene.globe.depthTestAgainstTerrain=false;terrain3DViewer.scene.globe.enableLighting=false;terrain3DViewer.scene.screenSpaceCameraController.enableCollisionDetection=true;try{terrain3DViewer.scene.moon.show=false;terrain3DViewer.scene.sun.show=false;terrain3DViewer.shadows=false;terrain3DViewer.scene.shadowMap.enabled=false}catch(_){ }try{terrain3DViewer.camera.moveStart.addEventListener(()=>terrain3DStartMoving());terrain3DViewer.camera.moveEnd.addEventListener(()=>terrain3DEndMoving());terrain3DViewer.scene.preRender.addEventListener(()=>{try{if(terrain3DActive)updateTerrain3DCompass(false)}catch(_){}})}catch(_){ }try{initTerrain3DElevationReadout()}catch(_){ }applyTerrain3DQuality(false);terrainStatus('3D Terrain: Esri World Elevation online terrain · Quality '+terrain3DQuality.toUpperCase());terrain3DLayerReady=true;return terrain3DViewer}catch(e){terrainStatus('3D terrain failed: '+String(e.message||e),true);throw e}finally{terrain3DLoading=false}}

function terrainQualitySettings(q){q=String(q||terrain3DQuality||'medium').toLowerCase();if(q==='low')return {label:'Low',sse:16,movingSse:80,resolution:.70,atmosphere:false,fog:false,labelMeters:12000,clamp:false,deferWhileMoving:true,clusterMeters:26000,clusterDeg:.08,maxFarDots:90,clusterLabels:false,simplifyMeters:22000,maxRouteVerts:90,maxShapeVerts:70};if(q==='high')return {label:'High',sse:5,movingSse:10,resolution:1.0,atmosphere:true,fog:true,labelMeters:65000,clamp:true,deferWhileMoving:false,clusterMeters:90000,clusterDeg:.025,maxFarDots:450,clusterLabels:true,simplifyMeters:80000,maxRouteVerts:650,maxShapeVerts:420};return {label:'Medium',sse:10,movingSse:55,resolution:.80,atmosphere:true,fog:false,labelMeters:28000,clamp:false,deferWhileMoving:true,clusterMeters:42000,clusterDeg:.05,maxFarDots:160,clusterLabels:false,simplifyMeters:36000,maxRouteVerts:160,maxShapeVerts:120}}
function terrainRequestRender(){try{if(terrain3DViewer&&terrain3DViewer.scene&&terrain3DViewer.scene.requestRender)terrain3DViewer.scene.requestRender()}catch(e){}}
function applyTerrain3DQuality(save){try{terrain3DQuality=String(terrain3DQuality||'medium').toLowerCase();if(!['low','medium','high'].includes(terrain3DQuality))terrain3DQuality='medium';if(save!==false)localStorage.setItem('takMapTerrain3DQuality',terrain3DQuality);const sel=document.getElementById('terrain3dQuality');if(sel&&sel.value!==terrain3DQuality)sel.value=terrain3DQuality;if(!terrain3DViewer||!window.Cesium)return;const q=terrainQualitySettings(terrain3DQuality);terrain3DViewer.resolutionScale=q.resolution;terrain3DViewer.scene.globe.maximumScreenSpaceError=q.sse;terrain3DViewer.scene.globe.enableLighting=false;try{terrain3DViewer.scene.skyAtmosphere.show=!!q.atmosphere}catch(_){ }try{terrain3DViewer.scene.fog.enabled=!!q.fog}catch(_){ }try{terrain3DViewer.shadows=false;terrain3DViewer.scene.shadowMap.enabled=false}catch(_){ }terrainStatus('3D Terrain active · Quality '+q.label+' · Terrain detail '+q.sse+' SSE · '+terrain3DLastRenderableCount+' objects');terrainRequestRender()}catch(e){try{console.warn('Terrain quality update failed',e)}catch(_){}}}
function setTerrain3DQuality(v){terrain3DQuality=String(v||'medium').toLowerCase();applyTerrain3DQuality(true);refreshTerrain3DObjects(true,'quality')}
function terrain3DIsDeferredQuality(){return terrainQualitySettings(terrain3DQuality).deferWhileMoving}
function terrain3DStartMoving(){try{terrain3DMoving=true;const q=terrainQualitySettings(terrain3DQuality);if(terrain3DViewer&&q.deferWhileMoving){terrain3DViewer.scene.globe.maximumScreenSpaceError=q.movingSse;try{terrain3DViewer.scene.globe.preloadSiblings=false;terrain3DViewer.scene.globe.preloadAncestors=false;terrain3DViewer.scene.globe.loadingDescendantLimit=0}catch(_){ }terrainStatus('3D Terrain moving · Quality '+q.label+' · terrain/detail loading deferred')}}catch(e){}}
function terrain3DEndMoving(){try{terrain3DMoving=false;applyTerrain3DQuality(false);updateTerrain3DCompass(true);if(terrain3DDeferredRefresh){terrain3DDeferredRefresh=false;scheduleTerrain3DObjectsRefresh(350,true)}else{scheduleTerrain3DObjectsRefresh(450,false)}terrainRequestRender()}catch(e){}}
function terrainCameraDistanceTo(lat,lon){try{if(!terrain3DViewer||!window.Cesium||!isFiniteLatLon(lat,lon))return Number.POSITIVE_INFINITY;const p=Cesium.Cartesian3.fromDegrees(Number(lon),Number(lat));return Cesium.Cartesian3.distance(terrain3DViewer.camera.position,p)}catch(e){return Number.POSITIVE_INFINITY}}
function terrainSimplifyCoordList(pts,closed){try{pts=(pts||[]).filter(p=>p&&isFiniteLatLon(p[0],p[1]));if(pts.length<2)return pts;const cen=[pts.reduce((a,p)=>a+Number(p[0]),0)/pts.length,pts.reduce((a,p)=>a+Number(p[1]),0)/pts.length];const q=terrainQualitySettings(terrain3DQuality);const dist=terrainCameraDistanceTo(cen[0],cen[1]);if(dist<q.simplifyMeters)return pts;const max=Math.max(8,Number(closed?q.maxShapeVerts:q.maxRouteVerts)||120);if(pts.length<=max)return pts;const step=Math.ceil(pts.length/max);const out=[];for(let i=0;i<pts.length;i+=step)out.push(pts[i]);const last=pts[pts.length-1];if(last&&out[out.length-1]!==last)out.push(last);return out}catch(e){return pts||[]}}
function terrainQueueCluster(lat,lon,color,label){try{const q=terrainQualitySettings(terrain3DQuality);terrain3DClusterBuckets=terrain3DClusterBuckets||{};const key=(Math.round(Number(lat)/q.clusterDeg)*q.clusterDeg).toFixed(3)+','+(Math.round(Number(lon)/q.clusterDeg)*q.clusterDeg).toFixed(3);const b=terrain3DClusterBuckets[key]||(terrain3DClusterBuckets[key]={lat:0,lon:0,count:0,color:color||'#c7d1d7',label:label||''});b.lat+=Number(lat);b.lon+=Number(lon);b.count++;terrain3DClusteredCount++}catch(e){}}
function terrainFlushClusters(){try{if(!terrain3DClusterBuckets||!terrain3DViewer||!window.Cesium)return;const q=terrainQualitySettings(terrain3DQuality);const buckets=Object.values(terrain3DClusterBuckets).map(b=>({lat:b.lat/b.count,lon:b.lon/b.count,count:b.count,color:b.color,dist:terrainCameraDistanceTo(b.lat/b.count,b.lon/b.count)})).sort((a,b)=>a.dist-b.dist).slice(0,q.maxFarDots);for(const b of buckets){const size=Math.max(3,Math.min(10,3+Math.sqrt(b.count)));const ent={position:Cesium.Cartesian3.fromDegrees(Number(b.lon),Number(b.lat)),point:{pixelSize:size,color:cesiumColor(b.color||'#c7d1d7',b.count>1?.55:.46),outlineColor:Cesium.Color.BLACK.withAlpha(.55),outlineWidth:1,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}};if(q.clusterLabels&&b.count>1){ent.label={text:String(b.count),font:'11px sans-serif',fillColor:Cesium.Color.WHITE.withAlpha(.72),outlineColor:Cesium.Color.BLACK.withAlpha(.65),outlineWidth:2,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-14),showBackground:true,backgroundColor:Cesium.Color.BLACK.withAlpha(.25),heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}}terrain3DViewer.entities.add(ent)}}catch(e){}finally{terrain3DClusterBuckets=null}}
function terrain3DZoom(dir){try{if(!terrain3DViewer||!window.Cesium)return;const h=Math.max(100,terrain3DViewer.camera.positionCartographic.height||2500);if(Number(dir)>0)terrain3DViewer.camera.zoomIn(Math.max(50,h*.28));else terrain3DViewer.camera.zoomOut(Math.max(80,h*.32));terrainRequestRender()}catch(e){}}
function terrain3DResetNorth(){try{if(!terrain3DViewer||!window.Cesium)return;const c=terrain3DViewer.camera.positionCartographic;terrain3DViewer.camera.setView({destination:Cesium.Cartesian3.fromRadians(c.longitude,c.latitude,c.height),orientation:{heading:0,pitch:terrain3DViewer.camera.pitch,roll:0}});updateTerrain3DCompass(true);terrainRequestRender()}catch(e){}}
function updateTerrain3DCompass(force){try{const el=document.getElementById('terrain3dCompassNeedle');if(!el||!terrain3DViewer||!window.Cesium)return;const deg=Cesium.Math.toDegrees(terrain3DViewer.camera.heading||0);el.style.transform='rotate('+(-deg).toFixed(1)+'deg)'}catch(e){}}
function formatTerrainElevation(m){const n=Number(m);if(!Number.isFinite(n))return 'Terrain Elev: —';const ft=n*3.280839895;return 'Terrain Elev: '+Math.round(ft).toLocaleString()+' ft / '+Math.round(n).toLocaleString()+' m'}
function updateTerrain3DElevationFromWindowPosition(pos,force){try{const el=document.getElementById('terrain3dElevation');if(!el||!terrain3DViewer||!window.Cesium||!pos)return;const now=Date.now();if(!force&&now-terrain3DLastElevationMs<180)return;terrain3DLastElevationMs=now;const ray=terrain3DViewer.camera.getPickRay(pos);if(!ray){el.textContent='Terrain Elev: —';return}const cart=terrain3DViewer.scene.globe.pick(ray,terrain3DViewer.scene);if(!cart){el.textContent='Terrain Elev: —';return}const carto=Cesium.Cartographic.fromCartesian(cart);let h=terrain3DViewer.scene.globe.getHeight(carto);if(!Number.isFinite(Number(h)))h=carto.height;el.textContent=formatTerrainElevation(h)}catch(e){}}
function initTerrain3DElevationReadout(){try{if(terrain3DElevationHandler||!terrain3DViewer||!window.Cesium)return;terrain3DElevationHandler=new Cesium.ScreenSpaceEventHandler(terrain3DViewer.scene.canvas);terrain3DElevationHandler.setInputAction(m=>updateTerrain3DElevationFromWindowPosition(m.endPosition,false),Cesium.ScreenSpaceEventType.MOUSE_MOVE);terrain3DElevationHandler.setInputAction(m=>updateTerrain3DElevationFromWindowPosition(m.position,true),Cesium.ScreenSpaceEventType.LEFT_CLICK)}catch(e){}}
function refreshTerrain3DAll(){try{terrain3DLastObjectHash='';refreshTerrain3DBaseLayer();applyTerrain3DQuality(false);refreshTerrain3DObjects(true,'manual-refresh');terrainStatus('3D Terrain refreshed · Quality '+terrainQualitySettings(terrain3DQuality).label)}catch(e){terrainStatus('3D refresh failed: '+String(e.message||e),true)}}

function terrainViewHash(){try{if(!terrain3DViewer||!window.Cesium)return 'none';const r=terrain3DViewer.camera.computeViewRectangle(terrain3DViewer.scene.globe.ellipsoid);if(!r)return 'view';const w=180/Math.PI;return [r.west*w,r.south*w,r.east*w,r.north*w].map(n=>Math.round(n*100)/100).join(',')+'@'+terrain3DQuality}catch(e){return 'view@'+terrain3DQuality}}
function terrain3DDataHash(){try{const parts=[terrainViewHash(),String(state.dataSync),String(state.imported),JSON.stringify(state.live||{})];const fp=o=>{try{const cen=objectCenter(o)||[];const coords=collectCoordPairs(o&&o.coords);const first=coords[0]||[],last=coords[coords.length-1]||[];return [o&& (o.uid||o.id||o.name||o.callsign||o.filename||''),o&&(o.updated||o.timestamp||o.time||o.version||''),cen[0],cen[1],coords.length,first[0],first[1],last[0],last[1],o&&o.color].join(':')}catch(e){return String(Math.random())}};(lastTakMarkers||[]).forEach(o=>parts.push('t:'+fp(o)));(((lastDataSync||{}).objects)||[]).forEach(o=>parts.push('d:'+fp(o)));try{(importedFeatures?importedFeatures():[]).forEach(o=>parts.push('l:'+fp(o)+':'+String(state.local.hidden[String(o._local_id||o.id||o.uid||o.name||'')]||false)))}catch(_){ }return parts.join('|')}catch(e){return String(Date.now())}}
function terrainPointVisible(lat,lon){try{if(!terrain3DViewer||!window.Cesium||!isFiniteLatLon(lat,lon))return true;const r=terrain3DViewer.camera.computeViewRectangle(terrain3DViewer.scene.globe.ellipsoid);if(!r)return true;const rad=Math.PI/180,la=Number(lat)*rad,lo=Number(lon)*rad;let west=r.west,east=r.east,south=r.south,north=r.north;const pad=(north-south+Math.abs(east-west))*.08;south-=pad;north+=pad;west-=pad;east+=pad;if(east<west)return (la>=south&&la<=north&&(lo>=west||lo<=east));return la>=south&&la<=north&&lo>=west&&lo<=east}catch(e){return true}}
function terrainShouldShowLabel(lat,lon){try{if(!terrain3DViewer||!window.Cesium||!isFiniteLatLon(lat,lon))return false;const q=terrainQualitySettings(terrain3DQuality);const p=Cesium.Cartesian3.fromDegrees(Number(lon),Number(lat));const dist=Cesium.Cartesian3.distance(terrain3DViewer.camera.position,p);return dist<q.labelMeters}catch(e){return false}}
function scheduleTerrain3DObjectsRefresh(delay,force){try{if(!terrain3DActive)return;clearTimeout(terrain3DRefreshTimer);terrain3DRefreshTimer=setTimeout(()=>refreshTerrain3DObjects(!!force,'scheduled'),Math.max(250,Number(delay||1000)))}catch(e){}}

function terrainCameraDistance(){try{const z=map?map.getZoom():10;return Math.max(850,Math.min(500000,260000/Math.pow(2,Math.max(0,z-7))))}catch(e){return 12000}}
function syncTerrainCameraFromMap(){try{if(!terrain3DViewer||!map||!window.Cesium)return;const c=map.getCenter();terrain3DViewer.camera.setView({destination:Cesium.Cartesian3.fromDegrees(c.lng,c.lat,terrainCameraDistance()),orientation:{heading:0,pitch:Cesium.Math.toRadians(-58),roll:0}})}catch(e){}}
function syncMapFromTerrainCamera(){try{if(!terrain3DViewer||!map||!window.Cesium)return;const cart=terrain3DViewer.camera.positionCartographic;if(cart){const lat=Cesium.Math.toDegrees(cart.latitude),lon=Cesium.Math.toDegrees(cart.longitude);if(isFiniteLatLon(lat,lon))map.setView([lat,lon],map.getZoom(),{animate:false})}}catch(e){}}
function refreshTerrain3DBaseLayer(){try{if(!terrain3DViewer||!window.Cesium)return;const layers=terrain3DViewer.imageryLayers;layers.removeAll(true);const p=cesiumBasemapProvider();if(p)layers.addImageryProvider(p)}catch(e){try{console.warn('3D basemap refresh failed',e)}catch(_){}}}
function cesiumColor(hex,alpha){try{return Cesium.Color.fromCssColorString(String(hex||'#c7d1d7')).withAlpha(alpha==null?1:alpha)}catch(e){return Cesium.Color.LIGHTGRAY.withAlpha(alpha==null?1:alpha)}}

function terrainPointEntity(lat,lon,label,color){try{if(!isFiniteLatLon(lat,lon)||!terrainPointVisible(lat,lon))return;const q=terrainQualitySettings(terrain3DQuality);const dist=terrainCameraDistanceTo(lat,lon);if(q.clusterMeters&&dist>q.clusterMeters&&q.deferWhileMoving){terrainQueueCluster(lat,lon,color,label);return}const ent={position:Cesium.Cartesian3.fromDegrees(Number(lon),Number(lat)),point:{pixelSize:dist>q.labelMeters?5:8,color:cesiumColor(color||'#c7d1d7',dist>q.labelMeters?.58:.92),outlineColor:Cesium.Color.BLACK.withAlpha(.7),outlineWidth:1,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}};if(dist<=q.labelMeters&&terrainShouldShowLabel(lat,lon)){ent.label={text:String(label||''),font:'12px sans-serif',fillColor:Cesium.Color.WHITE.withAlpha(.86),outlineColor:Cesium.Color.BLACK.withAlpha(.72),outlineWidth:3,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-18),showBackground:true,backgroundColor:Cesium.Color.BLACK.withAlpha(.38),heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}}terrain3DViewer.entities.add(ent)}catch(e){}}
function terrainPolylineEntity(pts,label,color){try{pts=(pts||[]).filter(p=>p&&isFiniteLatLon(p[0],p[1]));if(pts.length<2)return;const cen=[pts.reduce((a,p)=>a+Number(p[0]),0)/pts.length,pts.reduce((a,p)=>a+Number(p[1]),0)/pts.length];if(!terrainPointVisible(cen[0],cen[1]))return;pts=terrainSimplifyCoordList(pts,false);const arr=[];pts.forEach(p=>{arr.push(Number(p[1]),Number(p[0]))});terrain3DViewer.entities.add({name:String(label||'Route'),polyline:{positions:Cesium.Cartesian3.fromDegreesArray(arr),width:terrainCameraDistanceTo(cen[0],cen[1])>terrainQualitySettings(terrain3DQuality).simplifyMeters?2:3,material:cesiumColor(color||'#c7d1d7',.86),clampToGround:!!terrainQualitySettings(terrain3DQuality).clamp}})}catch(e){}}
function terrainPolygonEntity(pts,label,color){try{pts=collectCoordPairs(pts).filter(p=>p&&isFiniteLatLon(p[0],p[1]));if(pts.length<3)return;const cen=[pts.reduce((a,p)=>a+Number(p[0]),0)/pts.length,pts.reduce((a,p)=>a+Number(p[1]),0)/pts.length];if(!terrainPointVisible(cen[0],cen[1]))return;pts=terrainSimplifyCoordList(pts,true);const arr=[];pts.forEach(p=>{arr.push(Number(p[1]),Number(p[0]))});const poly={hierarchy:Cesium.Cartesian3.fromDegreesArray(arr),material:cesiumColor(color||'#c7d1d7',.12),outline:true,outlineColor:cesiumColor(color||'#c7d1d7',.62)};if(terrainQualitySettings(terrain3DQuality).clamp)poly.heightReference=Cesium.HeightReference.CLAMP_TO_GROUND;terrain3DViewer.entities.add({name:String(label||'Shape'),polygon:poly})}catch(e){}}
function terrainAddObject(o,source){try{if(!o)return;const label=o.callsign||o.name||o.uid||o.id||source||'Object';const cat=dataSyncCategory(o);if(cat==='Routes'){terrainPolylineEntity(routeCoords(o),label,o.color||'#c7d1d7');return}if(cat==='Shapes / Areas'){terrainPolygonEntity(shapeCoords(o),label,'#c7d1d7');return}const cen=objectCenter(o);if(cen)terrainPointEntity(cen[0],cen[1],label,source==='tak'?'#c7d1d7':'#d0d9de')}catch(e){}}
function refreshTerrain3DObjects(force,reason){try{if(!terrain3DActive||!terrain3DViewer||!window.Cesium)return;const q=terrainQualitySettings(terrain3DQuality);if(terrain3DMoving&&q.deferWhileMoving){terrain3DDeferredRefresh=terrain3DDeferredRefresh||!!force;terrainStatus('3D Terrain moving · object refresh deferred');return}const now=Date.now();const hash=terrain3DDataHash();if(!force&&hash===terrain3DLastObjectHash){terrainStatus('3D Terrain active · Quality '+q.label+' · '+terrain3DLastRenderableCount+' objects · no data changes');return}if(!force&&terrain3DLastObjectRefreshMs&&(now-terrain3DLastObjectRefreshMs)<10000){scheduleTerrain3DObjectsRefresh(10000-(now-terrain3DLastObjectRefreshMs),false);return}terrain3DLastObjectHash=hash;terrain3DLastObjectRefreshMs=now;terrain3DClusterBuckets={};terrain3DClusteredCount=0;terrain3DViewer.entities.removeAll();for(const m of (lastTakMarkers||[])){const kind=m.kind||'cot';if(kind==='eud'&&state.live.euds===false)continue;if(kind==='server_gps'&&state.live.server_gps===false)continue;if(kind!=='eud'&&kind!=='server_gps'&&state.live.cot_markers===false)continue;terrainAddObject(m,'tak')}if(state.dataSync){for(const o of ((lastDataSync||{}).objects||[]))terrainAddObject(o,'datasync')}if(state.imported){for(const f of (importedFeatures?importedFeatures():[])){const lid=String(f._local_id||f.id||f.uid||f.name||'');if(lid&&state.local.hidden[lid])continue;terrainAddObject(f,'local')}}terrainFlushClusters();terrain3DLastRenderableCount=terrain3DViewer.entities.values.length;const clustered=terrain3DClusteredCount?(' · '+terrain3DClusteredCount+' far points clustered'):'';terrainStatus('3D Terrain active · Esri World Elevation · Quality '+q.label+' · '+terrain3DLastRenderableCount+' visible objects'+clustered);terrainRequestRender()}catch(e){terrainStatus('3D object render failed: '+String(e.message||e),true)}}
async function enableTerrain3D(){try{const pane=document.getElementById('terrain3dPane');if(pane)pane.classList.add('active');terrain3DActive=true;terrain3DLastObjectHash='';updateToolUi();await ensureTerrain3DViewer();setTimeout(()=>{try{terrain3DViewer.resize();syncTerrainCameraFromMap();refreshTerrain3DBaseLayer();applyTerrain3DQuality(false);refreshTerrain3DObjects(true,'enable')}catch(e){}},80)}catch(e){terrain3DActive=false;const pane=document.getElementById('terrain3dPane');if(pane)pane.classList.remove('active');updateToolUi();alert('3D Terrain could not start: '+String(e.message||e))}}
function disableTerrain3D(){try{syncMapFromTerrainCamera()}catch(e){}terrain3DActive=false;const pane=document.getElementById('terrain3dPane');if(pane)pane.classList.remove('active');updateToolUi();setTimeout(()=>{try{drawDataSyncObjects((lastDataSync||{}).objects||[]);drawImportedObjects();refreshCot();if(state.live.adsb_aircraft)drawAircraft(lastAircraft||[])}catch(e){}},80)}
function toggleTerrain3D(force){if(force===false||terrain3DActive){disableTerrain3D();return}enableTerrain3D()}
function clearHiddenMapItems(){state.local.hidden={};renderLocalDataRows();drawImportedObjects()}
function updateZoomIndicator(){const el=document.getElementById('zoomIndicator');if(!el||!map)return;const z=map.getZoom();const c=map.getCenter();el.textContent=`Zoom z${z} · ${c.lat.toFixed(4)}, ${c.lng.toFixed(4)}`}
async function init(){try{const r=await fetch('/api/tak-map/config',{cache:'no-store'});if(r.status===401){location.href='/tak-map/login';return}config=await r.json();applyCustomBasemaps();map=L.map('map',{zoomControl:true}).setView([34.3,-118.6],9);L.control.scale({metric:true,imperial:true,position:'bottomright'}).addTo(map);map.on('zoomend moveend',()=>{updateZoomIndicator();updateTopBannerCached()});takMarkerLayer.addTo(map);dataSyncLayer.addTo(map);importedLayer.addTo(map);measureLayer=L.layerGroup().addTo(map);initFloatingToolbar();if(state.live.adsb_aircraft){aircraftLayer.addTo(map)}initOfflineAreaDrawing();await refreshOfflineMaps(false);makeMenuCollapsible();renderLayerMenu();updateZoomIndicator();const initialBasemap=savedBasemap()||config.default_basemap||'esri_topo';setBasemap(initialBasemap,{skipSave:true,source:'server-initial'});setTimeout(()=>enforceServerBasemap('post-render-1'),350);setTimeout(()=>enforceServerBasemap('post-render-2'),1500);setTimeout(()=>enforceServerBasemap('post-render-3'),4000);renderOfflineMapRows();await forceDataSyncSync('initial-load');setTimeout(()=>forceDataSyncSync('page-load-force'),500);setTimeout(()=>forceDataSyncSync('page-load-force-2'),2500);setTimeout(()=>forceDataSyncSync('page-load-force-3'),5000);scheduleDataSyncAutoRefresh();await refreshImports();await refreshLocalData();refreshCot();updateTopBanner();if(state.live.adsb_aircraft)refreshAdsb();setInterval(refreshDataSyncInterval,5000);setInterval(()=>{if(state.live.adsb_aircraft)refreshAdsb()},30000);setInterval(refreshCot,30000);setInterval(()=>refreshTerrain3DObjects(false,'interval'),10000);setInterval(updateTopBanner,30000);document.getElementById('mapStatus').textContent='Ready';}catch(e){document.getElementById('mapStatus').textContent='Map failed to initialize: '+e}}function scheduleDataSyncAutoRefresh(){const delays=[250,750,1500,3000,6000,10000,20000,45000];for(const d of delays)setTimeout(()=>{try{forceDataSyncSync('auto-load-'+d)}catch(e){}},d);try{window.addEventListener('focus',()=>forceDataSyncSync('focus'));document.addEventListener('visibilitychange',()=>{if(!document.hidden)forceDataSyncSync('visible')});window.addEventListener('pageshow',()=>forceDataSyncSync('pageshow'));window.addEventListener('online',()=>forceDataSyncSync('online'));document.addEventListener('change',e=>{try{if(e&&e.target&&e.target.id==='basemapSelect')setBasemap(e.target.value)}catch(_){}})}catch(e){}}function basemapMaxZoom(b){const z=Number(b&&b.maxZoom);return Number.isFinite(z)?z:19}function basemapDisplayLabel(b){const base=String((b&&b.label)||'Basemap');return base+' (max '+basemapMaxZoom(b)+'x)'}function basemapById(id){return (config.basemaps||[]).find(b=>b.id===id)||(config.basemaps||[])[0]}function serverPreferredBasemap(){return String((config&&config.last_basemap)||config?.default_basemap||'').trim()}function enforceServerBasemap(reason){try{const preferred=serverPreferredBasemap();if(!preferred||basemapUserChanged)return;if(activeBasemap!==preferred&&basemapExists(preferred)){setBasemap(preferred,{skipSave:true,source:'server-enforce:'+reason});}}catch(e){}}function setBasemap(id,opts){opts=opts||{};const b=basemapById(id);if(!b)return;if(!opts.skipSave)basemapUserChanged=true;if(baseLayer){map.removeLayer(baseLayer)}baseLayer=L.tileLayer(b.url,{minZoom:b.minZoom||0,maxZoom:b.maxZoom||19,attribution:b.attribution||'',errorTileUrl:''}).addTo(map);activeBasemap=b.id;renderBasemaps();try{const sel=document.getElementById('basemapSelect');if(sel)sel.value=b.id}catch(e){}if(!opts.skipSave){saveBasemap(b.id).then(j=>{if(j&&j.ok&&j.prefs&&j.prefs.last_basemap){config.last_basemap=j.prefs.last_basemap;config.default_basemap=j.prefs.last_basemap}if(!(j&&j.ok)){setBasemapSaveStatus(b.label+' · basemap changed, but server save failed',false)}}).catch(e=>setBasemapSaveStatus(b.label+' · basemap changed, but server save failed: '+String(e),false))}updateOfflineSourceText();if(offlineDownloadBounds)scheduleOfflineEstimate();refreshReliefOverlay();if(terrain3DActive)refreshTerrain3DBaseLayer()}function renderLayerMenu(){if(!config)return;renderBasemaps();renderLiveRows();renderExternalRows();renderDataSyncRows();renderOfflineSourceOptions();renderOfflineMapRows();try{renderLocalDataRows()}catch(e){try{console.error('Local Data render failed',e)}catch(_){}const box=document.getElementById('localDataRows');if(box)box.innerHTML='<div class="danger">Local Data panel failed: '+esc(e)+'</div>'}}
function loadCustomBasemaps(){try{return JSON.parse(localStorage.getItem('takMapCustomBasemaps')||'[]').filter(b=>b&&b.url&&b.label)}catch(e){return[]}}
function saveCustomBasemaps(list){try{localStorage.setItem('takMapCustomBasemaps',JSON.stringify(list||[]))}catch(e){}}
function applyCustomBasemaps(){try{if(!config)return;const built=(config.basemaps||[]).filter(b=>!String(b.id||'').startsWith('custom_xml_'));const custom=loadCustomBasemaps();config.basemaps=built.concat(custom)}catch(e){}}
function parseBasemapXmlText(txt,nameHint){const doc=new DOMParser().parseFromString(String(txt||''),'text/xml');const textOf=(tag)=>{const n=doc.getElementsByTagName(tag)[0];return n?n.textContent.trim():''};let label=textOf('name')||textOf('title')||nameHint||'Custom basemap';let url=textOf('url')||textOf('URL')||textOf('serverUrl')||textOf('tileUrl')||'';if(!url){const all=[...doc.getElementsByTagName('*')].map(n=>String(n.textContent||'').trim()).find(v=>/^https?:\/\//i.test(v));url=all||''}if(url&&!/[{]z[}].*[{]y[}].*[{]x[}]|\/tile\//i.test(url)){url=url.replace(/\/$/,'')+'/tile/{z}/{y}/{x}'}if(!url)throw new Error('No tile URL found in XML.');return {id:'custom_xml_'+Date.now(),label,group:'Custom',url,minZoom:0,maxZoom:19,attribution:label}}
function renderCustomBasemapStatus(){const el=document.getElementById('customBasemapStatus');if(el)el.textContent=customBasemapImportStatus||''}
function triggerBasemapXmlImport(){const inp=document.getElementById('basemapXmlInput');if(inp){inp.value='';inp.click()}}
async function importBasemapXmlFiles(){const inp=document.getElementById('basemapXmlInput');const files=[...(inp?.files||[])];if(!files.length)return;const list=loadCustomBasemaps();let added=0;for(const file of files){try{const txt=await file.text();const b=parseBasemapXmlText(txt,file.name.replace(/\.[^.]+$/,''));list.push(b);added++}catch(e){customBasemapImportStatus='Import failed for '+file.name+': '+e.message}}saveCustomBasemaps(list);applyCustomBasemaps();renderBasemaps();customBasemapImportStatus=added?('Added '+added+' custom basemap'+(added===1?'':'s')+'.'):customBasemapImportStatus;renderCustomBasemapStatus()}
function clearCustomBasemaps(){if(!confirm('Remove all custom basemaps from this browser?'))return;saveCustomBasemaps([]);applyCustomBasemaps();renderBasemaps();customBasemapImportStatus='Custom basemaps cleared.';renderCustomBasemapStatus()}
function renderBasemaps(){const sel=document.getElementById('basemapSelect');if(!sel)return;const items=(config.basemaps||[]).filter(b=>visibleText(b.label+' '+(b.group||'')));const groups={};for(const b of items){const g=b.group||'Basemaps';(groups[g]=groups[g]||[]).push(b)}const order=['Offline Maps','Imagery','Topo / Terrain','Street / Reference','Basemaps'];let html='';for(const g of [...order,...Object.keys(groups).filter(x=>!order.includes(x)).sort()]){const arr=groups[g];if(!arr||!arr.length)continue;html+=`<optgroup label="${esc(g)}">`;for(const b of arr){html+=`<option value="${esc(b.id)}" ${b.id===activeBasemap?'selected':''}>${esc(basemapDisplayLabel(b))}</option>`}html+='</optgroup>'}sel.innerHTML=html||'<option>No basemaps match</option>';renderCustomBasemapStatus()}function reliefSource(){return (config?.basemaps||[]).find(b=>b.id==='usgs_shaded_relief')||{url:'https://basemap.nationalmap.gov/arcgis/rest/services/USGSShadedReliefOnly/MapServer/tile/{z}/{y}/{x}',attribution:'USGS 3DEP / The National Map',minZoom:0,maxZoom:16}}function setReliefOpacity(v){const op=Math.max(0,Math.min(100,Number(v||35)))/100;if(reliefLayer)reliefLayer.setOpacity(op)}function refreshReliefOverlay(){const cb=document.getElementById('reliefOverlayToggle');if(cb&&cb.checked)toggleReliefOverlay(true)}function toggleReliefOverlay(on){if(!map)return;if(reliefLayer){try{map.removeLayer(reliefLayer)}catch(e){}reliefLayer=null}if(!on)return;const src=reliefSource();const op=Math.max(0,Math.min(100,Number(document.getElementById('reliefOpacity')?.value||35)))/100;reliefLayer=L.tileLayer(src.url,{minZoom:src.minZoom||0,maxZoom:src.maxZoom||16,opacity:op,attribution:src.attribution||'USGS Shaded Relief'}).addTo(map)}function renderLiveRows(){const rows=(config.live_layers||[]).filter(l=>visibleText(l.label)).map(l=>`<div class="row"><label><input type="checkbox" ${state.live[l.id]!==false?'checked':''} onchange="toggleLive('${esc(l.id)}',this.checked)"><span>${esc(l.label)}</span></label><span class="chip">live</span></div>`);document.getElementById('liveRows').innerHTML=rows.join('')||'<div class="muted">No live layers match.</div>'}function toggleLive(id,on){state.live[id]=!!on;if(id==='adsb_aircraft'){if(on){aircraftLayer.addTo(map);refreshAdsb()}else{aircraftLayer.clearLayers();if(map.hasLayer(aircraftLayer))map.removeLayer(aircraftLayer)}return}if(id==='cot_markers'||id==='euds'||id==='webform_reports'||id==='server_gps'){if(!map.hasLayer(takMarkerLayer))takMarkerLayer.addTo(map);refreshCot();return}}function groupBy(arr,k){return arr.reduce((a,x)=>{const g=x[k]||'Other';(a[g]=a[g]||[]).push(x);return a},{})}function niceKey(k){return String(k||'').replace(/_/g,' ').replace(/\b\w/g,c=>c.toUpperCase())}function usefulProps(props,max=12){props=props||{};const skip=/^(objectid|fid|globalid|shape_|shape\.|st_area|st_length|esri|geometry|geom|x|y)$/i;const priority=['name','title','label','type','category','agency','owner','status','incidentname','incident','firename','fire_name','perimeterdate','date','updated','description','road','trail','route','unit'];const out=[];const used=new Set();for(const p of priority){for(const k of Object.keys(props)){if(used.has(k)||skip.test(k))continue;if(k.toLowerCase()===p&&props[k]!=null&&String(props[k]).trim()!==''){out.push([k,props[k]]);used.add(k)}}}for(const k of Object.keys(props)){if(out.length>=max)break;if(used.has(k)||skip.test(k))continue;const v=props[k];if(v==null||String(v).trim()===''||String(v).length>700)continue;out.push([k,v]);used.add(k)}return out}function featurePopupHtml(sourceName,props,extra){const rows=usefulProps(props,14);let html=`<div class="feature-popup"><h3>${esc(sourceName||'External source')}</h3><div class="kvp">`;if(extra){for(const [k,v] of Object.entries(extra)){html+=`<b>${esc(k)}</b><span>${esc(v)}</span>`}}if(rows.length){for(const [k,v] of rows){html+=`<b>${esc(niceKey(k))}</b><span>${esc(v)}</span>`}}else{html+='<b>Details</b><span>No feature attributes exposed.</span>'}html+='</div></div>';return html}function renderExternalRows(){const groups=groupBy(config.external_layers||[],'group');let html='';for(const [g,items] of Object.entries(groups)){const filtered=items.filter(i=>visibleText(g+' '+i.label+' '+i.type));if(!filtered.length)continue;html+=`<div class="subgroup"><div class="subgroup-title">${esc(g)}</div>`+filtered.map(i=>`<div class="row"><label><input type="checkbox" ${state.external[i.id]?'checked':''} onchange="toggleExternal('${esc(i.id)}',this.checked)"><span>${esc(i.label)}<small>${esc(i.type)} · ${String(i.type||'').toLowerCase().includes('mapserver')?'tile-only popup note':'feature details popup'}</small></span></label></div>`).join('')+'</div>'}document.getElementById('externalRows').innerHTML=html||'<div class="muted">No default external sources. Import KML/KMZ/GPX/GeoJSON/Shapefile files above to add local external layers.</div>'}function externalById(id){return (config.external_layers||[]).find(x=>x.id===id)}function toggleExternal(id,on){state.external[id]=on;const item=externalById(id);if(!item)return;if(!on){if(externalLayers[id]){map.removeLayer(externalLayers[id]);delete externalLayers[id]}return}const type=String(item.type||'').toLowerCase();if(type.includes('mapserver')||type==='xyz'){const url=String(item.url||'').replace(/\/$/,'')+'/tile/{z}/{y}/{x}';const lyr=L.tileLayer(url,{maxZoom:18,opacity:.72,attribution:item.label}).addTo(map);lyr._takTileOnly=true;lyr._takLabel=item.label;externalLayers[id]=lyr;const note=L.popup();lyr.on('add',()=>{});map.once('click',e=>{if(state.external[id]&&externalLayers[id]===lyr){note.setLatLng(e.latlng).setContent(featurePopupHtml(item.label,{}, {'Layer type':'Tile-only MapServer','Note':'This source does not expose per-feature details through the tile layer. Use a matching FeatureServer source when available.'})).openOn(map)}})}else if(type.includes('feature')){const url=String(item.url||'').replace(/\/$/,'')+'/query?where=1%3D1&outFields=*&returnGeometry=true&f=geojson';fetch(url).then(r=>r.json()).then(g=>{externalLayers[id]=L.geoJSON(g,{style:{color:'#ff7a1a',weight:2,fillOpacity:.18},pointToLayer:(f,ll)=>L.circleMarker(ll,{radius:6,color:'#ff7a1a',weight:2,fillOpacity:.32}),onEachFeature:(f,l)=>l.bindPopup(featurePopupHtml(item.label,(f&&f.properties)||{}, {'Source':item.group||'External'}))}).addTo(map)}).catch(e=>alert('Could not load '+item.label+': '+e))}else{alert(item.label+' is '+item.type+'. KML/KMZ browser rendering will be added after source-specific testing.')}renderLayerMenu()}function clearExternalLayers(){for(const id of Object.keys(externalLayers)){map.removeLayer(externalLayers[id]);delete externalLayers[id];state.external[id]=false}renderLayerMenu()}let lastDataSync=null;async function refreshDataSync(force,reason){try{const qs=(force?('?force=1&reason='+encodeURIComponent(reason||'manual')+'&_='+Date.now()):('?_='+Date.now()));try{const ms=document.getElementById('mapStatus');if(ms&&force)ms.textContent='Refreshing Data Sync...'}catch(e){}const r=await fetch('/api/tak-map/data-sync'+qs,{cache:'no-store',credentials:'same-origin'});const j=await apiJsonResponse(r);lastDataSync=j;lastDataSyncSuccessMs=Date.now();lastDataSyncSuccessReason=reason||(force?'force':'interval');const objs=j.objects||[];document.getElementById('missionCount').textContent=(j.missions||[]).length+' missions';const oc=document.getElementById('dataSyncObjectCount');if(oc)oc.textContent=objs.length+' objects';renderDataSyncRows();drawDataSyncObjects(objs);return j}catch(e){document.getElementById('dataSyncRows').innerHTML='<div class="danger">Could not load Data Sync: '+esc(e)+'</div>';return {ok:false,error:String(e)}}}function refreshDataSyncInterval(){try{const age=Date.now()-Number(lastDataSyncSuccessMs||0);if(lastDataSyncSuccessMs&&age<10000&&lastDataSyncSuccessReason!=='interval')return Promise.resolve({ok:true,skipped:true,age});return refreshDataSync(false,'interval')}catch(e){return Promise.resolve({ok:false,error:String(e)})}}async function forceDataSyncSync(reason){const statusEls=document.querySelectorAll('.popup-edit-status');try{const j=await refreshDataSync(true,reason||'force');setTimeout(()=>refreshDataSync(true,(reason||'force')+'-followup-1'),750);setTimeout(()=>refreshDataSync(true,(reason||'force')+'-followup-2'),2000);setTimeout(()=>refreshDataSync(true,(reason||'force')+'-followup-3'),5000);return j}catch(e){return {ok:false,error:String(e)}}}function rowLabel(row){return row.name||row.mission_name||row.missionName||row.uid||row.guid||row.id||row.filename||'item'}function toggleDataSyncObjects(on){state.dataSync=!!on;if(on){dataSyncLayer.addTo(map);drawDataSyncObjects((lastDataSync||{}).objects||[])}else{dataSyncLayer.clearLayers();if(map.hasLayer(dataSyncLayer))map.removeLayer(dataSyncLayer)}}function affFromType(t){t=String(t||'').toLowerCase();if(t.includes('a-h-')||t.includes('hostile'))return'Hostile';if(t.includes('a-n-')||t.includes('neutral'))return'Neutral';if(t.includes('a-u-')||t.includes('unknown'))return'Unknown';return'Friendly'}function affKey(t){const a=affFromType(t);return a==='Hostile'?'hostile':a==='Neutral'?'neutral':a==='Unknown'?'unknown':'friendly'}function iconColor(aff){aff=String(aff||'').toLowerCase();return aff==='hostile'?'#ff3b35':(aff==='neutral'?'#77b84a':(aff==='unknown'?'#a7adb4':'#2386ff'))}function battleDimension(o){const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.source].filter(Boolean).join(' ')).toLowerCase();if(/(-a-)|aircraft|air\b|heli/.test(t))return'Air';if(/(-s-)|sea|surface|ship|boat|maritime/.test(t))return'Sea surface';if(/space|satellite/.test(t))return'Space';if(/subsurface|submarine/.test(t))return'Subsurface';return'Ground'}function assetDescriptor(o){if(o&&(o.asset_override||o.asset))return String(o.asset_override||o.asset);const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.callsign,o?.name,o?.title,o?.category,o?.source].filter(Boolean).join(' ')).toLowerCase();if(/air.?defense|airdefense|\bada\b|sam\b|surface.?to.?air|missile|anti.?air|a-[fhnu]-g-u-c-d|a-[fhnu]-g-u-c-v-a|g-u-c-d|g-u-c-v-a|gpucd|airdef|air_def|air-def/.test(t))return'Air defense';if(/sniper|shooter|precision/.test(t))return'Sniper';if(/logistic|supply|fuel|cache|resupply|medical|medevac/.test(t))return'Logistics';if(/radar|sensor|surveillance/.test(t))return'Radar / sensor';if(/artillery|mortar|cannon|howitzer/.test(t))return'Artillery';if(/armor|armou?r|tank|tracked|a-[fhnu]-g-u-c-a|g-u-c-a|gpuca|gpevat/.test(t))return'Armor';if(/vehicle|wheeled|truck|convoy/.test(t))return'Vehicle';if(/infantry|personnel|team|unit|ground|a-[fhnu]-g-u-c-i|g-u-c-i|gpuci/.test(t))return'Ground unit';if(/heli|rotary/.test(t))return'Helicopter';if(/air|aircraft|fixed/.test(t))return'Aircraft';if(/route|track|path|gpx/.test(t))return'Route';if(/shape|polygon|area|sector|circle|rectangle/.test(t))return'Shape / area';if(/hazard|warning|danger|alert/.test(t))return'Hazard';return'Point marker'}function popupEditInputs(box){try{return Array.from((box||document).querySelectorAll('input,textarea,select')).filter(el=>!el.disabled&&!el.readOnly&&el.offsetParent!==null)}catch(e){return[]}}function markPopupEditDirty(el){try{const box=el.closest?el.closest('.popup-edit'):el;if(box)box.dataset.dirty='1'}catch(e){}}function popupEditKeyNav(ev){try{if(!ev||ev.key!=='Enter'||ev.shiftKey)return;const t=ev.target;if(!t||!t.closest||!t.closest('.popup-edit'))return;ev.preventDefault();const box=t.closest('.popup-edit');const inputs=popupEditInputs(box);const idx=inputs.indexOf(t);const next=inputs[idx+1]||box.querySelector('.popup-edit-actions button');if(next&&next.focus)next.focus()}catch(e){}}function popupEditToggle(box){try{if(!box||!box.classList||!box.classList.contains('popup-edit'))return;const popupEl=box.closest('.leaflet-popup');if(box.open){if(activePopupEditBox&&activePopupEditBox!==box)autoSaveActivePopupEdit('switch-edit');activePopupEditBox=box;if(popupEl)popupEl.classList.add('editing')}else{if(activePopupEditBox===box)activePopupEditBox=null;if(popupEl)popupEl.classList.remove('editing')}}catch(e){}}function popupEditActiveInLayer(layer){try{const p=layer&&layer.getPopup&&layer.getPopup();const el=p&&p.getElement&&p.getElement();return !!(el&&el.querySelector('.popup-edit[open]'))}catch(e){return false}}function layerPopupAnchor(layer){try{if(layer&&layer.getLatLng)return layer.getLatLng();if(layer&&layer.getBounds)return layer.getBounds().getCenter();if(layer&&layer.getLatLngs){const pts=[];const walk=x=>{if(Array.isArray(x)){if(x.length>=2&&typeof x[0]==='number'&&typeof x[1]==='number')pts.push(L.latLng(x[0],x[1]));else x.forEach(walk)}else if(x&&typeof x.lat==='number'&&typeof x.lng==='number')pts.push(x)};walk(layer.getLatLngs());if(pts.length)return L.latLng(pts.reduce((a,p)=>a+p.lat,0)/pts.length,pts.reduce((a,p)=>a+p.lng,0)/pts.length)}}catch(e){}return null}
function stabilizeLayerPopup(layer){try{if(!layer||!layer.on)return layer;let anchor=null;const openAnchored=()=>{try{if(!anchor)anchor=layerPopupAnchor(layer);const p=layer.getPopup&&layer.getPopup();if(p&&anchor&&p.setLatLng)p.setLatLng(anchor);if(layer.openPopup){if(anchor)layer.openPopup(anchor);else layer.openPopup()}}catch(e){}};layer.on('mouseover',()=>{if(!layer.isPopupOpen||!layer.isPopupOpen())openAnchored()});layer.on('mouseout',()=>{setTimeout(()=>closeUnpinnedPopup(layer),120)});layer.on('click',ev=>{try{if(window._takPinnedPopupLayer&&window._takPinnedPopupLayer!==layer)closeUnpinnedPopup(window._takPinnedPopupLayer);layer._takPopupPinned=true;window._takPinnedPopupLayer=layer;openAnchored();if(ev&&ev.originalEvent)L.DomEvent.stop(ev.originalEvent)}catch(e){}});layer.on('popupopen',e=>{try{const p=e.popup;if(!anchor)anchor=layerPopupAnchor(layer);if(p&&anchor&&p.setLatLng)p.setLatLng(anchor);const el=p&&p.getElement&&p.getElement();if(!el)return;el.addEventListener('mouseenter',()=>{layer._takPopupHover=true});el.addEventListener('mouseleave',()=>{layer._takPopupHover=false;setTimeout(()=>{if(!layer._takPopupHover)closeUnpinnedPopup(layer)},180)});el.addEventListener('click',ev=>ev.stopPropagation());el.addEventListener('focusin',()=>{})}catch(x){}})}catch(e){}return layer}
async function autoSaveActivePopupEdit(reason){const box=activePopupEditBox;if(!box||box.dataset.dirty!=='1'||box.dataset.autosaving==='1')return;try{box.dataset.autosaving='1';await savePopupEditBox(box,{auto:true,close:false,reason:reason||'auto'})}finally{try{box.dataset.autosaving='0'}catch(e){}}}function closePopupEditBox(box){try{if(box){box.dataset.dirty='0';box.removeAttribute('open');popupEditToggle(box)}if(map&&map.closePopup)map.closePopup()}catch(e){}}function cancelPopupEdit(btn){const box=btn&&btn.closest?btn.closest('.popup-edit'):activePopupEditBox;closePopupEditBox(box)}async function savePopupEditBox(box,opts){opts=opts||{};if(!box)return;const get=n=>box.querySelector(`[name="${n}"]`)?.value||'';const status=box.querySelector('.popup-edit-status');const payload={key:box.dataset.key||'',source:box.dataset.source||'',name:get('name'),type:get('type'),asset:get('asset'),lat:get('lat'),lon:get('lon'),notes:get('notes')};try{if(status)status.textContent=opts.auto?'Auto-saving...':'Saving...';const r=await fetch('/api/tak-map/popup-edit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),cache:'no-store'});const j=await apiJsonResponseAllowFalse(r);if(!j.ok)throw new Error(j.error||'save failed');box.dataset.dirty='0';if(status)status.textContent='Saved · Syncing Data Sync...';await forceDataSyncSync(opts.reason||'popup-edit-save');try{await refreshCot();await refreshImports();await refreshLocalData()}catch(e){}if(status)status.textContent='Saved · Data Sync Refreshed';if(opts.close!==false)closePopupEditBox(box);return j}catch(e){if(status)status.textContent='Save failed: '+String(e);throw e}}async function savePopupEdit(btn){const box=btn.closest('.popup-edit');try{await savePopupEditBox(box,{close:true,reason:'popup-edit-save'})}catch(e){}}async function deletePopupEdit(btn){const box=btn.closest('.popup-edit');if(!box)return;if(!confirm('Delete this item from the TAK Map view?'))return;const status=box.querySelector('.popup-edit-status');try{if(status)status.textContent='Deleting...';const r=await fetch('/api/tak-map/popup-edit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({key:box.dataset.key||'',source:box.dataset.source||'',delete_item:true}),cache:'no-store'});const j=await apiJsonResponseAllowFalse(r);if(!j.ok)throw new Error(j.error||'delete failed');box.dataset.dirty='0';if(status)status.textContent='Deleted · Syncing Data Sync...';await forceDataSyncSync('popup-edit-delete');try{await refreshCot();await refreshImports();await refreshLocalData()}catch(e){}closePopupEditBox(box)}catch(e){if(status)status.textContent='Delete failed: '+String(e)}}async function clearPopupEdit(btn){return deletePopupEdit(btn)}function popupEditKey(o){const base=String(o?.uid||o?.id||o?.callsign||o?.name||o?.filename||'').trim();const src=String(o?.source||o?.source_table||o?.kind||'object').trim();if(base)return src+':'+base;const la=Number(o?.lat),lo=Number(o?.lon);if(Number.isFinite(la)&&Number.isFinite(lo))return src+':coord:'+la.toFixed(6)+','+lo.toFixed(6);return src+':'+Math.random().toString(16).slice(2)}function popupNotes(o){return String(o?.notes||o?.remarks||o?.description||'')}function popupEditForm(o,source){const key=popupEditKey(o);const name=o?.callsign||o?.name||o?.title||o?.uid||o?.id||'';const typ=o?.type||o?.cot_type||o?.category||'';const asset=assetDescriptor(o);const notes=popupNotes(o);const lat=(o?.lat!=null?Number(o.lat).toFixed(6):'');const lon=(o?.lon!=null?Number(o.lon).toFixed(6):'');return `<details class="popup-edit" data-key="${esc(key)}" data-source="${esc(source||o?.source||'tak-map')}" onclick="event.stopPropagation()" ontoggle="popupEditToggle(this)" oninput="markPopupEditDirty(this)" onkeydown="popupEditKeyNav(event)"><summary>Edit Data</summary><label>Name<input name="name" value="${esc(name)}"></label><label>Type<input name="type" value="${esc(typ)}"></label><label>Asset<input name="asset" value="${esc(asset)}"></label><div class="popup-edit-grid"><label>Lat<input name="lat" value="${esc(lat)}"></label><label>Lon<input name="lon" value="${esc(lon)}"></label></div><label>Notes<textarea name="notes" rows="2">${esc(notes)}</textarea></label><div class="popup-edit-actions"><button type="button" onclick="savePopupEdit(this)">Save</button><button type="button" onclick="cancelPopupEdit(this)">Cancel</button><button type="button" class="danger-action" onclick="deletePopupEdit(this)">Delete</button><span class="popup-edit-status"></span></div></details>`}function basicMarkerPopupHtml(m,kind){const name=m?.callsign||m?.name||m?.uid||m?.id||'Marker';return `<div class="feature-popup"><h3>${esc(name)}</h3><div class="kvp"><b>Name</b><span>${esc(name)}</span><b>Kind</b><span>${esc(kind||m?.kind||'marker')}</span><b>Coordinates</b><span>${esc(formatCoords(m?.lat,m?.lon))}</span><b>Source</b><span>${esc(m?.source||'OpenTAKServer')}</span><b>Updated</b><span>${esc(m?.updated||m?.added||'—')}</span>${popupNotes(m)?`<b>Notes</b><span>${esc(popupNotes(m))}</span>`:''}</div>${popupEditForm(m,'cot')}</div>`}function formatCoords(lat,lon){const la=Number(lat),lo=Number(lon);return Number.isFinite(la)&&Number.isFinite(lo)?`${la.toFixed(6)}, ${lo.toFixed(6)}`:'—'}function addedTime(o){return o?.added||o?.updated||o?.time||o?.start||o?.uploaded||'—'}function iconDiagnostic(o){const sidc=explicitSidc(o);const f=generatedMil2525File(o||{})||'';let src='fallback';if(sidc&&sidcFileFromSidc(sidc))src='SIDC '+sidc;else if(cotTypeToSidc(o?.type||o?.cot_type))src='CoT type '+esc(o?.type||o?.cot_type);else if(o?.category||o?.asset||o?.iconsetPath)src='metadata/category';const raw=[o?.sidc||o?.SIDC,o?.type||o?.cot_type,o?.category,o?.asset,o?.iconsetPath].filter(Boolean).join(' | ');return {file:f||'generic affiliation marker',source:src,raw:raw||''}}function pointPopupHtml(o,cat){const name=o?.callsign||o?.name||o?.uid||o?.id||'Point marker';const t=String([o?.type,o?.cot_type,o?.sidc,o?.uid,o?.source].filter(Boolean).join(' '));const diag=iconDiagnostic(o||{});const notes=popupNotes(o);return `<div class="feature-popup"><h3>${esc(name)}</h3><div class="kvp"><b>Name</b><span>${esc(name)}</span><b>Affiliation</b><span>${esc(affFromType(t))}</span><b>Added</b><span>${esc(addedTime(o))}</span><b>Coordinates</b><span>${esc(formatCoords(o?.lat,o?.lon))}</span><b>Battle Dimension</b><span>${esc(battleDimension(o))}</span><b>Asset</b><span>${esc(assetDescriptor(o))}</span><b>Icon</b><span>${esc(diag.file)} · ${esc(diag.source)}${diag.raw?' · raw: '+esc(diag.raw):''}</span>${notes?`<b>Notes</b><span>${esc(notes)}</span>`:''}</div>${popupEditForm(o,cat||'Point Markers')}</div>`}function milShape(aff,body,label){const c=iconColor(aff);let frame='';if(aff==='hostile'){frame=`<polygon points="18,2 34,18 18,34 2,18" fill="rgba(255,59,53,.22)" stroke="${c}" stroke-width="2.5"/>`}else if(aff==='neutral'){frame=`<rect x="4" y="6" width="28" height="24" rx="2" fill="rgba(119,184,74,.20)" stroke="${c}" stroke-width="2.5"/>`}else if(aff==='unknown'){frame=`<rect x="5" y="6" width="26" height="24" rx="4" fill="rgba(167,173,180,.22)" stroke="${c}" stroke-width="2.5"/>`}else{frame=`<rect x="3" y="8" width="30" height="20" rx="1.5" fill="rgba(35,134,255,.20)" stroke="${c}" stroke-width="2.5"/>`}return `<svg class="tak-icon-svg" width="34" height="38" viewBox="0 0 36 40" style="color:${c}"><circle cx="12" cy="2.8" r="2.6" fill="${c}"/><circle cx="24" cy="2.8" r="2.6" fill="${c}"/>${frame}${body||`<path d="M7 10 L29 28 M29 10 L7 28" stroke="#05080b" stroke-width="1.7" opacity=".9"/>`}${label?`<text x="18" y="24" text-anchor="middle" font-size="7" font-weight="900" fill="#061019" font-family="system-ui,Arial">${label}</text>`:''}<circle cx="18" cy="37" r="3" fill="${c}"/></svg>`}const MIL2525_ICON_BY_SIDC={"SFGPEV---------":"friendly-ground-equipment-ground-vehicle.svg","SNGPEV---------":"neutral-ground-equipment-ground-vehicle.svg","SHGPEV---------":"hostile-ground-equipment-ground-vehicle.svg"