ut"><option value="1">Filled</option><option value="0">Unfilled</option></select></label><label>Fill %<input id="drawFillOpacityInput" type="number" min="0" max="100" step="5" value="20"></label></div><div class="tak-floating-actions"><button onclick="v236CloseDrawOptions()">Close</button><button class="primary" onclick="v236ApplyDrawOptions()">Apply</button></div></div>`);[\'drawColorInput\',\'drawWeightInput\',\'drawLineStyleInput\',\'drawFillInput\',\'drawFillOpacityInput\',\'drawNameInput\'].forEach(id=>{const el=document.getElementById(id);if(el)el.addEventListener(\'input\',()=>{v236ReadDrawOptions();v236RedrawDrawTemp()});if(el)el.addEventListener(\'change\',()=>{v236ReadDrawOptions();v236RedrawDrawTemp()})})}catch(e){}}\n  function drawOptions(){const st=window.v233DrawState=window.v233DrawState||{};st.color=st.color||\'#ff6f2e\';st.weight=Number(st.weight||3);st.lineStyle=st.lineStyle||\'solid\';st.fill=st.fill!==false;st.fillOpacity=Number(st.fillOpacity==null?0.20:st.fillOpacity);st.name=st.name||\'\';return st}\n  window.v236OpenDrawOptions=function(){ensureDrawPanel();const st=drawOptions();try{document.getElementById(\'drawNameInput\').value=st.name||\'\';document.getElementById(\'drawColorInput\').value=st.color||\'#ff6f2e\';document.getElementById(\'drawWeightInput\').value=st.weight||3;document.getElementById(\'drawLineStyleInput\').value=st.lineStyle||\'solid\';document.getElementById(\'drawFillInput\').value=st.fill===false?\'0\':\'1\';document.getElementById(\'drawFillOpacityInput\').value=Math.round((st.fillOpacity==null?0.20:st.fillOpacity)*100)}catch(e){}const p=document.getElementById(\'drawOptionsPanel\');if(p)p.classList.add(\'active\')}\n  window.v236CloseDrawOptions=function(){const p=document.getElementById(\'drawOptionsPanel\');if(p)p.classList.remove(\'active\')}\n  window.v236ApplyDrawOptions=function(){v236ReadDrawOptions();v236RedrawDrawTemp();v236CloseDrawOptions()}\n  function v236ReadDrawOptions(){const st=drawOptions();try{st.name=document.getElementById(\'drawNameInput\')?.value||st.name||\'\';st.color=document.getElementById(\'drawColorInput\')?.value||st.color||\'#ff6f2e\';st.weight=Math.max(1,Math.min(12,parseInt(document.getElementById(\'drawWeightInput\')?.value||st.weight||3,10)||3));st.lineStyle=document.getElementById(\'drawLineStyleInput\')?.value||st.lineStyle||\'solid\';st.fill=(document.getElementById(\'drawFillInput\')?.value||\'1\')===\'1\';st.fillOpacity=Math.max(0,Math.min(1,(parseFloat(document.getElementById(\'drawFillOpacityInput\')?.value||20)||0)/100));}catch(e){}return st}\n  function latLngsFromCoords(coords){return coords.map(c=>L.latLng(c[1],c[0]))}\n  function rectPoly235(a,b,square){let x1=a.lng,y1=a.lat,x2=b.lng,y2=b.lat;if(square){const dx=x2-x1,dy=y2-y1;const d=Math.max(Math.abs(dx),Math.abs(dy));x2=x1+(dx>=0?d:-d);y2=y1+(dy>=0?d:-d)}return [[x1,y1],[x2,y1],[x2,y2],[x1,y2],[x1,y1]]}\n  function circlePoly235(c,e,ellipse){const pts=[];const lat=c.lat,lon=c.lng;const dx=e.lng-lon,dy=e.lat-lat;const rx=Math.abs(dx)||0.00001,ry=ellipse?(Math.abs(dy)||0.00001):(Math.sqrt(dx*dx+dy*dy)||0.00001);for(let i=0;i<72;i++){const a=Math.PI*2*i/72;pts.push([lon+Math.cos(a)*rx,lat+Math.sin(a)*ry])}pts.push(pts[0]);return pts}\n  function drawCoordsFromState(){const st=drawOptions();const pts=st.points||[];const end=st.liveEnd;if([\'rectangle\',\'square\'].includes(st.mode)&&pts.length&&end)return rectPoly235(pts[0],end,st.mode===\'square\');if([\'circle\',\'ellipse\'].includes(st.mode)&&pts.length&&end)return circlePoly235(pts[0],end,st.mode===\'ellipse\');if(st.mode===\'freehand\'&&pts.length>1){const c=pts.map(llToCoord); if(c.length>2)c.push(c[0]); return c}if(st.mode===\'polygon\'&&pts.length){const arr=pts.slice(); if(end)arr.push(end); const c=arr.map(llToCoord); if(c.length>2)c.push(c[0]); return c}return pts.map(llToCoord)}\n  window.v236RedrawDrawTemp=function(){try{const st=drawOptions(); if(typeof v234ClearTemp===\'function\')v234ClearTemp(st); else if(typeof v233