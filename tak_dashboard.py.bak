  function sourceIsLocal(){return String(window.terrain3DElevationSource||localStorage.getItem('takMapTerrainElevationSource')||'streamed').toLowerCase()==='local'}
  function currentViewer(){try{return (typeof terrain3DViewer!=='undefined'&&terrain3DViewer)||window.terrain3DViewer||null}catch(_){return window.terrain3DViewer||null}}
  function terrainStatusMsg(msg,bad){try{if(typeof window.terrainStatus==='function')window.terrainStatus(msg,!!bad);else{const el=field('terrain3dStatus');if(el)el.textContent=msg}}catch(_){}}
  function loadScriptOnce(src){return new Promise((resolve,reject)=>{try{if(document.querySelector('script[src="'+src+'"]')){const wait=()=>{if(src.includes('proj4')?window.proj4:true)resolve();else setTimeout(wait,60)};return wait()}const s=document.createElement('script');s.src=src;s.async=false;s.onload=()=>resolve();s.onerror=()=>reject(new Error('Could not load '+src));document.head.appendChild(s)}catch(e){reject(e)}})}
  async function ensureProjectionForLocalTiles(){try{const needs=uniqueTiles().some(t=>String(t.crsMode||'').toLowerCase()==='projected'&&t.proj4String);if(needs&&!window.proj4)await loadScriptOnce('/assets/vendor/proj4.js');}catch(e){console.warn('v295 projected local elevation support failed',e)}}
  async function ensureLocalTiles(){try{if(typeof window.loadLocalElevationTiles==='function')await window.loadLocalElevationTiles();await ensureProjectionForLocalTiles()}catch(e){console.warn('v295 local elevation load failed',e)}return uniqueTiles()}
