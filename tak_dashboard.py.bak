    _v295_patch = r'''<script id="v295LocalDemTerrainMeshPatch">
(function(){
  'use strict';
  const V='v301';
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function field(id){try{return document.getElementById(id)}catch(_){return null}}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V})}catch(_){} }
  function localState(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};if(!(window.takLocalElevation.tiles instanceof Map))window.takLocalElevation.tiles=new Map();return window.takLocalElevation}
  function uniqueTiles(){try{return [...(localState().tiles||new Map()).values()].filter((v,i,a)=>v&&v.id&&a.findIndex(x=>x&&x.id===v.id)===i)}catch(_){return []}}
  function tileBounds(t){try{let lat0=Number(t.lat0),lon0=Number(t.lon0);let lat1=Number(t.lat1),lon1=Number(t.lon1);if(!Number.isFinite(lat0)||!Number.isFinite(lon0))return null;if(!Number.isFinite(lat1))lat1=lat0+1;if(!Number.isFinite(lon1))lon1=lon0+1;const south=Math.max(-90,Math.min(lat0,lat1)),north=Math.min(90,Math.max(lat0,lat1));const west=Math.max(-180,Math.min(180,Math.min(lon0,lon1))),east=Math.max(-180,Math.min(180,Math.max(lon0,lon1)));if(!(north>south)||!(east>west))return null;return {south,north,west,east}}catch(_){return null}}
