    `;document.head.appendChild(st);}
  function bind(){try{if(window.map&&!window._v285AdsbPopupBound){window._v285AdsbPopupBound=true;map.on('popupopen',ev=>setTimeout(()=>patchPopup(ev.popup),0));map.on('click',()=>setTimeout(syncTrackButtons,0));}window._v285TrackClickBound=true; /* v300: legacy ADS-B track click handler disabled; current handler owns tracking */}catch(_){ }}
