    TAK_MAP_HTML = _v303_neutralize_legacy_adsb_track(TAK_MAP_HTML)
    _v303_controller = '<script id="v303StabilizedModuleControllers">\n(function(){\n  \'use strict\';\n  const V=\'v303\';\n  const RELEASE=\'1.1.0\';\n  const CTL=window.TakMapControllers=window.TakMapControllers||{};\n  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}\n  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}\n  function byId(id){try{return document.getElementById(id)}catch(_){return null}}\n  function esc(s){return String(s==null?\'\':s).replace(/[&<>"\']/g,function(c){return {\'&\':\'&amp;\',\'<\':\'&lt;\',\'>\':\'&gt;\',\'"\':\'&quot;\',"\'":\'&#39;\'}[c]})}\n  function num(v){v=Number(v);return Number.isFinite(v)?v:null}\n  function version(){try{qa(\'.iteration-chip,.iteration-marker\').forEach(function(el){el.textContent=V});qa(\'.version-product,.sidebar-version-title\').forEach(function(el){if(/dashboard/i.test(el.textContent||\'\'))el.textContent=\'TAK Map\'});document.documentElement.dataset.takMapIteration=V}catch(_){}}\n  function leafletMap(){try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(typeof map!==\'undefined\'&&map&&map.addLayer){window.takLeafletMap=map;return map}}catch(_){}try{if(window.map&&window.map.addLayer)return window.map}catch(_){}return null}\n  function distanceMeters(points){let m=0;try{for(let i=1;i<(points||[]).length;i++){const a=points[i-1],b=points[i];if(window.L&&L.latLng)m+=L.latLng(a.lat,a.lon).distanceTo(L.latLng(b.lat,b.lon));else{const R=6371000,rad=Math.PI/180;const p1=a.lat*rad,p2=b.lat*rad,dp=(b.lat-a.lat)*rad,dl=(b.lon-a.lon)*rad;const h=Math.sin(dp/2)**2+Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;m+=2*R*Math.atan2(Math.sqrt(h),Math.sqrt(1-h))}}}catch(_){}return m}\n  function distText(m){return (m/1609.344).toFixed(1)+\'mi/\'+(m/1000).toFixed(1)+\'km\'}\n  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flig