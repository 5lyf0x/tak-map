<script id="v290UiPlacementHitboxPatch">
(function(){
  'use strict';
  const V='v301';
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function viewport(){return {w:Math.max(320,window.innerWidth||document.documentElement.clientWidth||320),h:Math.max(320,window.innerHeight||document.documentElement.clientHeight||320)}}
  function sidebarRight(){try{const sb=q('#sidebar');if(!sb||sb.classList.contains('collapsed'))return 0;const r=sb.getBoundingClientRect();return Math.max(0,Math.min((window.innerWidth||0)-80,r.right||0));}catch(_){return 0}}
  function topSafe(){try{const tb=q('.topbar');if(tb){const r=tb.getBoundingClientRect();if(r&&Number.isFinite(r.bottom))return Math.max(64,Math.round(r.bottom)+10)}}catch(_){}return 72}
  function mainToolbarRect(){try{const candidates=[q('#floatingToolbarDock'),q('#floatingMapToolbar'),q('.floating-toolbar-dock'),q('.floating-map-toolbar')].filter(Boolean);for(const el of candidates){const r=el.getBoundingClientRect();if(r&&r.width>8&&r.height>8&&r.right>0&&r.bottom>0)return r;}}catch(_){}return null}
  function addCss(){try{if(q('#v290UiPlacementHitboxStyle'))return;const st=document.createElement('style');st.id='v290UiPlacementHitboxStyle';st.textContent=`
    #viewshedModule.viewshed-module{position:fixed!important;right:auto!important;z-index:910!important;max-width:calc(100vw - 24px)!important;max-height:calc(100vh - 24px)!important;overflow:hidden!important;box-sizing:border-box!important;}
    #viewshedModule.viewshed-module.active{display:block!important;visibility:visible!important;opacity:1!important;}
    #viewshedModule .viewshed-body{overflow-y:auto!important;overscroll-behavior:contain!important;}
    #viewshedMinimized.viewshed-minimized{position:fixed!important;right:74px!important;left:auto!important;bottom:max(12px,env(safe-area-inset-bottom,0px))!important;z-index:910!important;max-width:calc(100vw - 24px)!important;}
    #localElevationDialog.local-elev-dialog{position:fixed!important;left:0!important;right:0!important;top:0!important;bottom:0!important;z-index:2400!important;align-items:flex-start!important;justify-content:center!important;padding:calc(58px + max(16px,env(safe-area-inset-top,0px))) 12px 12px!important;background:rgba(0,0,0,.56)!important;}
    #localElevationDialog.local-elev-dialog.active{display:flex!important;visibility:visible!important;opacity:1!important;pointer-events:auto!important;}
    #localElevationDialog .local-elev-card{position:relative!important;margin:0 auto!important;width:min(560px,calc(100vw - 24px))!important;max-height:calc(100vh - 90px)!important;overflow:hidden!important;z-index:2401!important;}
    #localElevationDialog .local-elev-body{max-height:calc(100vh - 148px)!important;overflow-y:auto!important;overscroll-behavior:contain!important;}
    .leaflet-marker-icon.adsb-v282-marker,.leaflet-marker-icon.adsb-v279-marker,.leaflet-marker-icon.adsb-v278-marker,.leaflet-marker-icon[class*="adsb-v"][class*="marker"]{pointer-events:auto!important;background:rgba(255,255,255,.001)!important;border-radius:12px!important;}
    .leaflet-marker-icon.adsb-v282-marker .aircraft-wrap,.leaflet-marker-icon.adsb-v279-marker .aircraft-wrap,.leaflet-marker-icon.adsb-v278-marker .aircraft-wrap,.leaflet-marker-icon[class*="adsb-v"][class*="marker"] .aircraft-wrap{pointer-events:auto!important;position:relative!important;width:100%!important;height:100%!important;min-width:90px!important;min-height:44px!important;display:flex!important;align-items:center!important;justify-content:center!important;background:rgba(255,255,255,.001)!important;border-radius:12px!important;}
    .leaflet-marker-icon.adsb-v282-marker .aircraft-wrap::before,.leaflet-marker-icon.adsb-v279-marker .aircraft-wrap::before,.leaflet-marker-icon.adsb-v278-marker .aircraft-wrap::before,.leaflet-marker-icon[class*="adsb-v"][class*="marker"] .aircraft-wrap::before{content:''!important;display:block!important;position:absolute!important;inset:0!important;background:rgba(255,255,255,.001)!important;border-radius:12px!important;pointer-events:auto!important;filter:none!important;box-shadow:none!important;}
    .leaflet-marker-icon.adsb-v282-marker img,.leaflet-marker-icon.adsb-v279-marker img,.leaflet-marker-icon.adsb-v278-marker img,.leaflet-marker-icon[class*="adsb-v"][class*="marker"] img{position:relative!important;z-index:1!important;pointer-events:none!important;}
    .leaflet-marker-icon.adsb-v282-marker .aircraft-label,.leaflet-marker-icon.adsb-v279-marker .aircraft-label,.leaflet-marker-icon.adsb-v278-marker .aircraft-label,.leaflet-marker-icon[class*="adsb-v"][class*="marker"] .aircraft-label{position:absolute!important;left:50%!important;bottom:-9px!important;transform:translateX(-50%)!important;z-index:2!important;pointer-events:none!important;}
  `;document.head.appendChild(st)}catch(e){try{console.warn('v290 css failed',e)}catch(_){}}}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V});}catch(_){}}
  function fixSidebarProduct(){try{qa('.version-product').forEach(el=>{if((el.textContent||'').trim()==='TAK Server Dashboard')el.textContent='TAK Map'});}catch(_){}}
  function placeViewshed(){try{const m=q('#viewshedModule'); if(!m||!m.classList.contains('active'))return false;const vp=viewport(), safe=10, gap=12, topMin=topSafe();m.style.right='auto'; m.style.bottom='auto'; m.style.maxWidth='calc(100vw - 24px)'; m.style.maxHeight='calc(100vh - 24px)';let r=m.getBoundingClientRect();let w=Math.max(220,Math.min(r.width||264,Math.min(320,vp.w-safe*2)));const sbRight=sidebarRight();const tb=mainToolbarRect();let left, top;if(tb){const maxWLeft=Math.max(220,Math.floor(tb.left-gap-Math.max(safe,sbRight+safe)));if(maxWLeft>=220){w=Math.min(w,maxWLeft);m.style.width=Math.round(w)+'px';r=m.getBoundingClientRect();left=Math.round(tb.left-gap-(r.width||w));}else {left=Math.max(safe,sbRight+safe);}top=Math.round(Math.max(topMin,Math.min(vp.h-80,(tb.top||topMin))));}else{m.style.width=Math.round(w)+'px';r=m.getBoundingClientRect();left=Math.max(safe,vp.w-(r.width||w)-74);top=Math.max(topMin,96);}r=m.getBoundingClientRect();const body=q('.viewshed-body',m), head=q('.viewshed-head',m); const headH=head?(head.getBoundingClientRect().height||42):42;const maxLeft=Math.max(safe,vp.w-(r.width||w)-safe); const minLeft=Math.max(safe,Math.min(sbRight+safe,maxLeft));const h=Math.min(r.height||360,vp.h-safe-topMin); const maxTop=Math.max(topMin,vp.h-h-safe);left=Math.max(minLeft,Math.min(maxLeft,left)); top=Math.max(topMin,Math.min(maxTop,top));if(body){body.style.maxHeight=Math.max(160,Math.floor(vp.h-top-headH-safe-6))+'px';body.style.overflowY='auto'}m.style.left=Math.round(left)+'px';m.style.top=Math.round(top)+'px';m.style.right='auto';m.style.bottom='auto';try{localStorage.removeItem('takmap.viewshed.modulePos')}catch(_){}return true;}catch(e){try{console.warn('v290 viewshed placement failed',e)}catch(_){}return false}}
  function scheduleViewshedPlace(){[0,40,140,320,650,1100].forEach(ms=>setTimeout(placeViewshed,ms))}
