tTimeout(r,0))}}finally{const st=state();st.pendingFiles=[];if(typeof window.renderLocalElevationSelected==='function')window.renderLocalElevationSelected();if(typeof window.updateLocalElevImportButton==='function')window.updateLocalElevImportButton();if(choose)choose.disabled=false;if(imp){imp.disabled=false;imp.textContent='Import'}}await ensureLoaded();renderList(null,false);const parts=['Imported '+ok+' elevation file'+(ok===1?'':'s')+'.'];if(warnings.length)parts.push('<div>Warnings: '+esc(warnings.join('; '))+'</div>');if(failed.length)parts.push('<div class="local-elev-failed">Failed files:<br>- '+failed.map(esc).join('<br>- ')+'</div>');setStatusHtml(parts.join(''),failed.length>0);setProgress(100,failed.length?'Import complete with failed file(s).':'Import complete.',true);return {ok,failed,warnings}}
