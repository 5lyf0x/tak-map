  window.renderStatusDropdown=function(type){const box=document.getElementById('statusDropdown');if(!box)return;box.dataset.type=type;box.classList.toggle('adsb-table',type==='adsb');if(type==='euds'&&!(window.v236EudCache||[]).length){box.innerHTML='<div class="status-dropdown-title">EUD Callsigns</div><div class="status-dropdown-empty">Loading online EUDs...</div>';fetchEudsForDropdown().then(()=>{if(box.classList.contains('active')&&box.dataset.type==='euds')renderStatusDropdown('euds')});return}const rows=statusDropdownRows(type);let html='<div class="status-dropdown-title">'+E(statusDropdownTitle(type))+'</div>';if(!rows.length)html+='<div class="status-dropdown-empty">No items currently listed.</div>';else if(type==='adsb'){const s=window.v233StatusSort||{key:'icao',dir:1};const ind=k=>s.key===k?'<span class="status-sort-ind">'+(s.dir>0?'▲':'▼')+'</span>':'';html+='<div class="status-adsb-head"><span onclick="setAdsbStatusSort(\'icao\',event)">ICAO'+ind('icao')+'</span><span onclick="setAdsbStatusSort(\'alt\',event)">Altitude'+ind('alt')+'</span><span onclick="setAdsbStatusSort(\'range\',event)">From Center Point'+ind('range')+'</span></div>'+rows.map(r=>'<div class="status-adsb-row" onclick="focusAdsbAircraft(\''+encodeURIComponent(r.id).replace(/'/g,'%27')+'\')"><span class="status-adsb-icao">'+E(r.icao)+'</span><span class="status-adsb-alt">'+E(r.alt)+'</span><span class="status-adsb-range">'+E(r.range)+'</span></div>').join('')}else html+=rows.map(r=>'<div class="status-dropdown-row"><span class="status-dropdown-name '+(r.uidFallback?'uid-fallback':'')+'">'+E(r.name)+'</span><span class="status-dropdown-sub">'+E(r.sub||'')+'</span></div>').join('');box.innerHTML=html}
  function sidcAffil(i){const s=String(i?.sidc||'');return ({F:'Friendly',H:'Hostile',N:'Neutral',U:'Unknown'}[s[1]])||v234MilAffilOf?.(i)||'Friendly'}
