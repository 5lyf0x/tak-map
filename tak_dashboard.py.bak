]

TAK_MAP_EXTERNAL_LAYERS = []


def _safe_offline_id(value=''):
    base=re.sub(r'[^A-Za-z0-9_.-]+','-',str(value or '').strip()).strip('-_.').lower()[:44]
    return base or secrets.token_hex(6)

def _load_offline_maps():
    data=load_json_file(TAK_MAP_OFFLINE_FILE, {'maps':[]})
    maps=data.get('maps') if isinstance(data, dict) else []
    if not isinstance(maps, list):
        maps=[]
    clean=[]
    changed=False
    for m in maps:
        if not isinstance(m, dict):
            continue
        fp=Path(str(m.get('path') or ''))
        if fp.exists() and fp.is_file():
            clean.append(m)
        else:
            changed=True
    if changed:
        TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
        atomic_write_json(TAK_MAP_OFFLINE_FILE, {'maps':clean})
    return clean

def _save_offline_maps(maps):
    TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
    atomic_write_json(TAK_MAP_OFFLINE_FILE, {'maps':maps[-80:]})
    return maps[-80:]

def _mbtiles_metadata(path):
    import sqlite3
    info={'tile_count':0,'min_zoom':None,'max_zoom':None,'format':'unknown','bounds':'','center':'','attribution':''}
    uri='file:' + quote(str(Path(path).resolve()), safe='/') + '?mode=ro'
    conn=sqlite3.connect(uri, uri=True)
    try:
        cur=conn.cursor()
        try:
            cur.execute('select name,value from metadata')
            md={str(k).lower():str(v) for k,v in cur.fetchall()}
        except Exception:
            md={}
        info['name']=md.get('name') or Path(path).stem
        info['format']=(md.get('format') or md.get('tile_format') or 'unknown').lower()
        info['bounds']=md.get('bounds','')
        info['center']=md.get('center','')
        info['attribution']=md.get('attribution') or md.get('description') or ''
        try:
            cur.execute('select count(*), min(zoom_level), max(zoom_level) from tiles')
            cnt, mn, mx = cur.fetchone()
            info['tile_count']=int(cnt or 0)
            info['min_zoom']=int(mn) if mn is not None else None
            info['max_zoom']=int(mx) if mx is not None else None
        except Exception:
            pass
    finally:
        conn.close()
    return info

def _offline_basemap_entries():
    entries=[]
    for m in _load_offline_maps():
        mid=str(m.get('id') or '')
        if not mid:
            continue
        fmt=str(m.get('format') or '').lower()
        label=str(m.get('name') or m.get('filename') or 'Offline map')
        entries.append({
            'id':'offline_'+mid,
            'label':'Offline · ' + label,
            'group':'Offline Maps',
            'type':'mbtiles',
            'url':'/api/tak-map/offline-tile/' + quote(mid, safe='') + '/{z}/{x}/{y}.png',
            'attribution':m.get('attribution') or 'Offline MBTiles',
            'minZoom':m.get('min_zoom'),
            'maxZoom':m.get('max_zoom') or 19,
            'format':fmt,
        })
    return entries

def tak_map_offline_maps():
    return {'ok':True,'maps':_load_offline_maps()}

def handle_tak_map_offline_upload(handler):
    try:
        ctype=handler.headers.get('Content-Type','')
        if 'multipart/form-data' not in ctype.lower():
            return handler._send_json({'ok':False,'error':'Expected multipart/form-data upload.'},400)
        n=int(handler.headers.get('Content-Length','0') or '0')
        if n <= 0:
            return handler._send_json({'ok':False,'error':'No upload body received.'},400)
        if n > UPLOAD_LIMIT_BYTES:
            return handler._send_json({'ok':False,'error':f'Offline map upload is too large. Current limit is {UPLOAD_LIMIT_MB} MB.'},413)
        body=handler.rfile.read(n)
        uploaded=_parse_multipart_files(ctype, body)
        if not uploaded:
            return handler._send_json({'ok':False,'error':'No files found in upload.'},400)
        maps=_load_offline_maps()
        added=[]
        TAK_MAP_OFFLINE_DIR.mkdir(parents=True, exist_ok=True)
        for filename, blob in uploaded:
            if not str(filename).lower().endswith('.mbtiles'):
                added.append({'name':filename,'ok':False,'error':'Only .mbtiles is supported for offline basemap import in this build.'})
                continue
            mid=_safe_offline_id(Path(filename).stem + '-' + secrets.token_hex(3))
            fp=TAK_MAP_OFFLINE_DIR/(mid + '.mbtiles')
            fp.write_bytes(blob)
            try:
                info=_mbtiles_metadata(fp)
            except Exception as e:
                try: fp.unlink()
                except Exception: pass
                added.append({'name':filename,'ok':False,'error':'Invalid MBTiles file: '+str(e)[:180]})
                continue
            rec={
                'id':mid,
                'name':info.get('name') or Path(filename).stem,
                'filename':filename,
                'path':str(fp),
                'uploaded':datetime.now(timezone.utc).isoformat(),
                'size_bytes':len(blob),
                'tile_count':info.get('tile_count') or 0,
                'min_zoom':info.get('min_zoom'),
                'max_zoom':info.get('max_zoom'),
                'format':info.get('format') or 'unknown',
                'bounds':info.get('bounds') or '',
                'center':info.get('center') or '',
                'attribution':info.get('attribution') or '',
                'eud_package_url':'',
            }
            maps.append(rec); added.append({'ok':True,**rec})
        _save_offline_maps(maps)
        return handler._send_json({'ok':True,'added':added,'maps':_load_offline_maps()})
    except Exception as e:
        return handler._send_json({'ok':False,'error':str(e)},500)

def _read_json_body(handler):
    n=int(handler.headers.get('Content-Length','0') or '0')
    raw=handler.rfile.read(n).decode('utf-8','replace') if n else '{}'
    try:
        data=json.loads(raw or '{}')
        return data if isinstance(data, dict) else {}
    except Exception:
        return {}

def tak_map_offline_delete(map_id):
    mid=str(map_id or '').strip()
    maps=_load_offline_maps()
    keep=[]; deleted=False
    for m in maps:
        if str(m.get('id'))==mid:
            deleted=True
            for key in ('path','eud_package_path'):
                try:
                    fp=Path(str(m.get(key) or ''))
                    if fp.exists() and fp.is_file(): fp.unlink()
                except Exception:
                    pass
        else:
            keep.append(m)
    _save_offline_maps(keep)
    return {'ok':deleted,'maps':keep,'error':'' if deleted else 'Offline map not found.'}

def _offline_package_display_names(target):
    base=str(target.get('name') or Path(str(target.get('filename') or 'offline-map')).stem or 'Offline Map').strip()
    base=re.sub(r'[\\/\x00]+','_',base)
    base=re.sub(r'\s+',' ',base).strip(' .')[:120] or 'Offline Map'
    if base.lower().endswith('.sqlite'):
        sqlite_name=base
    elif base.lower().endswith('.mbtiles'):
        sqlite_name=base[:-8] + '.sqlite'
    else:
        sqlite_name=base + '.sqlite'
    return sqlite_name, sqlite_name + '.zip'

def tak_map_offline_eud_package(map_id):
    mid=str(map_id or '').strip()
    maps=_load_offline_maps()
    target=None
    for m in maps:
        if str(m.get('id'))==mid:
            target=m; break
    if not target:
        return {'ok':False,'error':'Offline map not found.'}
    src=Path(str(target.get('path') or ''))
    if not src.exists():
        return {'ok':False,'error':'Offline map file missing on server.'}
    TAK_MAP_OFFLINE_PACKAGE_DIR.mkdir(parents=True, exist_ok=True)
    sqlite_name, zip_name = _offline_package_display_names(target)
    package_id=mid + '-' + datetime.now(timezone.utc).strftime('%Y%m%d%H%M%S')
    pkg=TAK_MAP_OFFLINE_PACKAGE_DIR/(package_id + '.zip')
    # ATAK EUD-to-EUD offline-map share uses a single offline SQLite file inside
    # a .sqlite.zip fileshare. Keep this package intentionally lean so ATAK can
    # recognize it as map/imagery content rather than a generic dashboard bundle.
    with zipfile.ZipFile(pkg,'w',zipfile.ZIP_DEFLATED) as z:
        z.write(src, sqlite_name)
    sha=hashlib.sha256(pkg.read_bytes()).hexdigest()
    for m in maps:
        if str(m.get('id'))==mid:
            m['eud_package_path']=str(pkg)
            m['eud_package_url']='/api/tak-map/offline-package?id=' + quote(package_id, safe='')
            m['eud_package_created']=datetime.now(timezone.utc).isoformat()
            m['eud_package_sha256']=sha
            m['eud_package_filename']=zip_name
            m['eud_package_name']=sqlite_name
    _save_offline_maps(maps)
    return {'ok':True,'package_url':'/api/tak-map/offline-package?id=' + quote(package_id, safe=''),'package_name':zip_name,'content_name':sqlite_name,'path':str(pkg),'sha256':sha,'size_bytes':pkg.stat().st_size,'maps':_load_offline_maps()}


def _ots_upload_folder():
    cfg, _errors = _load_ots_config_values()
    raw=(os.environ.get('UPLOAD_FOLDER','').strip() or cfg.get('UPLOAD_FOLDER','').strip())
    if raw:
        return Path(raw).expanduser()
    data=(os.environ.get('OTS_DATA_FOLDER','').strip() or cfg.get('OTS_DATA_FOLDER','').strip())
    if data:
        return Path(data).expanduser()/'uploads'
    for folder in _ots_data_folder_candidates():
        if (folder/'config.yml').exists() or (folder/'uploads').exists():
            return folder/'uploads'
    return Path(os.environ.get('TAK_DASH_OTS_UPLOAD_FALLBACK','/var/lib/opentakserver/uploads')).expanduser()

def _ots_marti_https_port():
    cfg, _errors = _load_ots_config_values()
    val=(os.environ.get('TAK_DASH_OTS_MARTI_HTTPS_PORT','').strip() or cfg.get('OTS_MARTI_HTTPS_PORT','').strip() or '8443')
    try:
        return int(val)
    except Exception:
        return 8443

def _default_server_host():
    val=os.environ.get('TAK_DASH_OTS_PUBLIC_HOST','').strip() or os.environ.get('TAK_DASH_OTS_HOST','').strip()
    if val:
        return val.split('/')[0].split(':')[0]
    try:
        out=subprocess.run(['hostname','-I'],capture_output=True,text=True,timeout=2).stdout.strip().split()
        for ip in out:
            if ip and not ip.startswith('127.') and ':' not in ip:
                return ip
    except Exception:
        pass
    try:
        return socket.gethostname()
    except Exception:
        return '127.0.0.1'

def _url_host(host):
    host=str(host or '').strip().split('/')[0]
    if ':' in host and not host.startswith('[') and not re.match(r'^\d+\.\d+\.\d+\.\d+$', host):
        return '[' + host.strip('[]') + ']'
    return host.strip('[]') or _default_server_host()

def _dashboard_https_origin(dashboard_origin='', server_host=''):
    """Return the HTTPS origin EUD map sources should use for dashboard-hosted tiles.

    Browser API calls may use the local HTTP fallback on :8091, but any map
    source sent to ATAK should point back to the dashboard HTTPS listener on
    :9443 so EUDs do not receive an HTTP tile URL.
    """
    raw=str(dashboard_origin or '').strip()
    host=''
    try:
        if raw:
            u=urlparse(raw)
            host=u.hostname or ''
            # Preserve an explicit HTTPS non-9443 port, but upgrade HTTP to 9443.
            if u.scheme.lower() == 'https' and u.netloc:
                return 'https://' + u.netloc.rstrip('/')
        if not host:
            host=str(server_host or '').strip().split('/')[0].split(':')[0]
        if not host:
            host=_default_server_host()
    except Exception:
        host=str(server_host or '').strip().split('/')[0].split(':')[0] or _default_server_host()
    return f"https://{_url_host(host)}:9443"


def _multipart_form_data(fields=None, files=None):
    boundary='----TAKDashboardBoundary' + uuid.uuid4().hex
    body=bytearray()
    fields=fields or []
    files=files or []
    def add_line(line):
        if isinstance(line, str):
            line=line.encode('utf-8')
        body.extend(line)
        body.extend(b'\r\n')
    for name, value in fields:
        add_line(f'--{boundary}')
        add_line(f'Content-Disposition: form-data; name="{name}"')
        add_line('')
        add_line(str(value))
    for name, filename, ctype, data in files:
        add_line(f'--{boundary}')
        add_line(f'Content-Disposition: form-data; name="{name}"; filename="{filename}"')
        add_line(f'Content-Type: {ctype or "application/octet-stream"}')
        add_line('')
        if isinstance(data, str):
            data=data.encode('utf-8')
        body.extend(data)
        body.extend(b'\r\n')
    add_line(f'--{boundary}--')
    return bytes(body), f'multipart/form-data; boundary={boundary}'



def _ots_missionupload_and_register_tool(zip_path, package_filename, sha256_hash, creator_uid='', public_host=''):
    """Upload a package using the native ATAK missionupload + metadata/tool flow.

    v205: native registration is always attempted before a dashboard-hosted
    fallback URL is selected. missionupload now uses a real EUD creatorUid
    candidate when available. Field diagnostics showed this OTS returns a valid
    metadata/tool URL from missionupload even when the follow-on PUT /tool
    returns 404, so the missionupload-returned URL is treated as sufficient.

    Successful native EUD-to-EUD transfers on this server follow:
      1. GET  /Marti/sync/missionquery?hash=...       -> 404 when absent
      2. POST /Marti/sync/missionupload?...           -> 200
      3. PUT  /Marti/api/sync/metadata/<hash>/tool    -> 200
      4. Recipient GET /Marti/api/sync/metadata/<hash>/tool?receiver=... -> 200
    """
    zp=Path(str(zip_path))
    if not zp.exists():
        return {'ok':False,'error':'Mission package file missing.','path':str(zp)}
    host_public=_url_host(public_host or _default_server_host())
    port=_ots_marti_https_port()
    cert_pairs=_ots_cert_candidates()
    cert_pair=cert_pairs[0] if cert_pairs else None

    # Prefer the same public/nginx-facing host that ATAK clients use, then loopback
    # fallbacks. Some OTS/Marti metadata handlers depend on nginx TLS client-cert
    # headers and behave differently on localhost vs the public listener.
    upload_hosts=[]
    for h in (host_public.strip('[]'), '127.0.0.1', 'localhost'):
        h=str(h or '').strip()
        if h and h not in upload_hosts:
            upload_hosts.append(h)

    # Use a real EUD creator UID when possible. Field diagnostics showed OTS can
    # return 200 from missionupload without creatorUid, but the follow-on
    # PUT /Marti/api/sync/metadata/<hash>/tool then returns 404. Native ATAK
    # sends include creatorUid=<ANDROID...>, so v205 prefers a selected/online
    # EUD UID or explicit env override, while avoiding dashboard account names
    # such as takdash unless the DB confirms they exist as EUDs.
    creator=''
    creator_source=''
    supplied=str(creator_uid or '').strip()
    env_creator=(
        os.environ.get('TAK_DASH_FILESHARE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_NATIVE_CREATOR_UID','').strip()
        or os.environ.get('TAK_DASH_OTS_CREATOR_UID','').strip()
    )
    candidates=[]
    for val,src in ((env_creator,'env'), (supplied,'argument')):
        val=str(val or '').strip()
        if val and val not in [c[0] for c in candidates]:
            candidates.append((val,src))
    creator_candidates=[{'uid':v,'source':src} for v,src in candidates]
    pg_checked=False
    for cand,src in candidates:
        try:
            pg_uris, _cfg_errors=_candidate_ots_pg_uris()
            if pg_uris:
                pg_checked=True
                cnt, cnt_err=_pg_first_value(pg_uris[0], 'select count(*) from public.euds where uid=' + _pg_sql_literal(cand))
                if not cnt_err and str(cnt or '0').strip() not in ('0',''):
                    creator=cand; creator_source=src + ':euds-match'; break
        except Exception:
            pass
        # If DB could not be checked at all, still allow IDs that look like real
        # EUD/device UIDs. Do not allow known dashboard/account placeholders.
        if not pg_checked:
            low=cand.lower()
            if low not in ('takdash','tak-dashboard','tak_dashboard','tak-dashboard-dashboard','tak-dashboard-server','tak-dashboard-ui'):
                if cand.startswith('ANDROID-') or cand.startswith('WinTAK-') or cand.startswith('ATAK-') or len(cand) >= 16:
                    creator=cand; creator_source=src + ':unverified-device-looking'; break

    # v205: OTS data_packages.filename is unique on this install. Reusing
    # "ESRI Street Map Source.xml.zip" across tests causes missionupload to
    # return a metadata URL while the DB insert fails with duplicate filename,
    # and the receiver /metadata/<hash>/tool endpoint later returns 500. Use a
    # per-hash upload filename for the native OTS inventory/download record while
    # leaving the FileShare display name and internal map source XML unchanged.
    pf=str(package_filename or 'TAK-Map-Source.zip').strip() or 'TAK-Map-Source.zip'
    stem, ext=os.path.splitext(pf)
    if not ext:
        ext='.zip'
    unique_suffix=str(sha256_hash or hashlib.sha256(file_bytes if 'file_bytes' in locals() else zp.read_bytes()).hexdigest())[:12]
    upload_filename=f"{stem}-{unique_suffix}{ext}"

    file_bytes=zp.read_bytes()
    missionquery=[]
    upload_attempts=[]
    metadata_put_attempts=[]
    selected_upload=None

    def make_ctx():
        ctx=ssl.create_default_context()
        ctx.check_hostname=False
        ctx.verify_mode=ssl.CERT_NONE
        if cert_pair:
            ctx.load_cert_chain(str(cert_pair[0]), str(cert_pair[1]))
        return ctx

    def read_preview(resp, n=1200):
        try:
            return decode_http_body(resp.read(n), getattr(resp,'headers',{}) or {})[:n]
        except Exception:
            return ''

    for host in upload_hosts:
        host_url=_url_host(host)
        mq_url=f'https://{host_url}:{port}/Marti/sync/missionquery?hash={quote(str(sha256_hash), safe="")}'
        try:
            req=Request(mq_url, headers={'Accept':'*/*','User-Agent':'TAKDashboard/2.11 missionquery'})
            with urlopen(req, timeout=8, context=make_ctx()) as resp:
                missionquery.append({'host':host,'url':mq_url,'status':int(getattr(resp,'status',None) or resp.getcode()),'ok':True,'body_preview':read_preview(resp,400)})
        except HTTPError as e:
            try: body=decode_http_body(e.read(400), getattr(e,'headers',{}) or {})[:400]
            except Exception: body=''
            missionquery.append({'host':host,'url':mq_url,'status':int(getattr(e,'code',0) or 0),'ok':False,'body_preview':body,'error':str(e)})
        except Exception as e:
            missionquery.append({'host':host,'url':mq_url,'ok':False,'error':str(e)})

        query=f'hash={quote(str(sha256_hash), safe="")}&filename={quote(str(upload_filename), safe="")}'
        if creator:
            query += '&creatorUid=' + quote(creator, safe='')
        up_url=f'https://{host_url}:{port}/Marti/sync/missionupload?{query}'

        upload_variants=[]
        # ATAK/OTS installs have differed on the expected multipart field name.
        # Try the conservative variants, stopping at the first 2xx upload.
        body,ctype=_multipart_form_data([], [('assetfile', upload_filename, 'application/zip', file_bytes)])
        upload_variants.append(('multipart-assetfile', body, ctype))
        body2,ctype2=_multipart_form_data([], [('file', upload_filename, 'application/zip', file_bytes)])
        upload_variants.append(('multipart-file', body2, ctype2))
        upload_variants.append(('raw-zip', file_bytes, 'application/zip'))

        for variant_name, body_bytes, content_type in upload_variants:
            try:
                headers={
                    'Content-Type':content_type,
                    'Content-Length':str(len(body_bytes)),
                    'Accept':'*/*',
                    'User-Agent':'TAKDashboard/2.11 missionupload',
                }
                if variant_name.startswith('multipart'):
                    headers['Expect']='100-continue'
                req=Request(up_url, data=body_bytes, method='POST', headers=headers)
                with urlopen(req, timeout=45, context=make_ctx()) as resp:
                    resp_body=read_preview(resp,1200)
                    code=int(getattr(resp,'status',None) or resp.getcode())
                    rec={'host':host,'url':up_url,'status':code,'ok':200 <= code < 300,'variant':variant_name,'body_preview':resp_body[:1200]}
                    upload_attempts.append(rec)
                    if rec['ok']:
                        selected_upload=rec
                        break
            except HTTPError as e:
                try: body_preview=decode_http_body(e.read(1200), getattr(e,'headers',{}) or {})[:1200]
                except Exception: body_preview=''
                upload_attempts.append({'host':host,'url':up_url,'status':int(getattr(e,'code',0) or 0),'ok':False,'variant':variant_name,'body_preview':body_preview,'error':str(e)})
            except Exception as e:
                upload_attempts.append({'host':host,'url':up_url,'ok':False,'variant':variant_name,'error':str(e)})
        if not selected_upload:
            continue

        # Prefer the exact metadata/tool URL returned by OTS missionupload.
        # It normally matches the reconstructed URL, but using the returned value
        # removes ambiguity around host/proxy routing and future OTS changes.
        returned_url=str((selected_upload or {}).get('body_preview') or '').strip().splitlines()[0].strip() if selected_upload else ''
        if returned_url.startswith('http://') or returned_url.startswith('https://'):
            put_url=returned_url
        else:
            put_url=f'https://{host_url}:{port}/Marti/api/sync/metadata/{quote(str(sha256_hash), safe="")}/tool'
        # The access log for successful ATAK sends shows PUT /tool with a 0-byte
        # response. Request body length is not visible, so try no-body first, then
        # a tiny JSON metadata body. Stop at the first 2xx.
        put_variants=[
            ('empty-no-content-type', None, {}),
            ('empty-json', b'', {'Content-Type':'application/json','Content-Length':'0'}),
            ('tool-json', json.dumps({'tool':'public','filename':str(upload_filename)}).encode('utf-8'), {'Content-Type':'application/json'}),
            ('tool-text', b'public', {'Content-Type':'text/plain'}),
        ]
        for put_variant, put_body, extra_headers in put_variants:
            try:
                headers={'Accept':'*/*','User-Agent':'TAKDashboard/2.11 metadata-tool'}
                headers.update(extra_headers or {})
                if put_body is not None and 'Content-Length' not in headers:
                    headers['Content-Length']=str(len(put_body))
                req=Request(put_url, data=put_body, method='PUT', headers=headers)
                with urlopen(req, timeout=20, context=make_ctx()) as resp:
                    resp_body=read_preview(resp,1200)
                    code=int(getattr(resp,'status',None) or resp.getcode())
                    rec={'host':host,'url':put_url,'status':code,'ok':200 <= code < 300,'variant':put_variant,'body_preview':resp_body[:1200]}
                    metadata_put_attempts.append(rec)
                    if rec['ok']:
                        sender_url=f'https://{host_public}:{port}/Marti/api/sync/metadata/{sha256_hash}/tool'
                        return {
                            'ok':True,
                            'sender_url':sender_url,
                            'preferred_sender_url':sender_url,
                            'path':str(zp),
                            'upload_filename':upload_filename,
                            'original_package_filename':pf,
                            'missionquery':missionquery,
                            'missionupload_attempts':upload_attempts,
                            'metadata_put_attempts':metadata_put_attempts,
                            'creator_uid_used':creator,
                            'creator_uid_source':creator_source,
                            'creator_uid_candidates':creator_candidates,
                            'cert':str(cert_pair[0]) if cert_pair else '',
                            'key':str(cert_pair[1]) if cert_pair else '',
                            'selected_upload':selected_upload,
                            'selected_metadata_put':rec,
                            'selected_sender_url_reason':'native missionupload + metadata/tool PUT succeeded before fallback',
                        }
            except HTTPError as e:
                try: body_preview=decode_http_body(e.read(1200), getattr(e,'headers',{}) or {})[:1200]
                except Exception: body_preview=''
                metadata_put_attempts.append({'host':host,'url':put_url,'status':int(getattr(e,'code',0) or 0),'ok':False,'variant':put_variant,'body_preview':body_preview,'error':str(e)})
            except Exception as e:
                metadata_put_attempts.append({'host':host,'url':put_url,'ok':False,'variant':put_variant,'error':str(e)})

        # v205: On this OTS build, missionupload returns HTTP 200 plus the exact
        # /Marti/api/sync/metadata/<hash>/tool URL, but PUT /tool still returns
        # 404. Native ATAK uses this URL as the receiver download endpoint; the
        # PUT appears to be tool metadata decoration, not a prerequisite for file
        # availability on this server. Accept the returned URL so FileShare CoT
        # can use the native 8443 path instead of the dashboard 9443 fallback.
        if returned_url.startswith('http://') or returned_url.startswith('https://'):
            sender_url=returned_url
            try:
                pu=urlparse(sender_url)
                if pu.hostname in ('127.0.0.1','localhost','::1') and host_public:
                    # Never advertise a loopback senderUrl to EUDs; rewrite to the
                    # public/ZeroTier host while preserving path/query.
                    netloc=f'{_url_host(host_public)}:{pu.port or port}'
                    sender_url=f'{pu.scheme}://{netloc}{pu.path}' + (('?' + pu.query) if pu.query else '')
            except Exception:
                pass
            return {
                'ok':True,
                'sender_url':sender_url,
                'preferred_sender_url':sender_url,
                'path':str(zp),
                'upload_filename':upload_filename,
                'original_package_filename':pf,
                'missionquery':missionquery,
                'missionupload_attempts':upload_attempts,
                'metadata_put_attempts':metadata_put_attempts,
                'creator_uid_used':creator,
                'creator_uid_source':creator_source,
                'creator_uid_candidates':creator_candidates,
                'cert':str(cert_pair[0]) if cert_pair else '',
                'key':str(cert_pair[1]) if cert_pair else '',
                'selected_upload':selected_upload,
                'metadata_put_optional':True,
                'metadata_put_failed_but_missionupload_url_accepted':True,
                'selected_sender_url_reason':'missionupload returned native metadata/tool URL; metadata PUT returned non-2xx but URL accepted before dashboard fallback',
            }

        # If upload succeeded but no usable metadata/tool URL was returned and all
        # PUT variants failed on this host, try the next host.
        selected_upload=None

    return {
        'ok':False,
        'error':'native missionupload/metadata-tool registration failed; dashboard senderUrl fallback will be used',
        'selected_sender_url_reason':'native registration failed before FileShare CoT build',
        'path':str(zp),
        'upload_filename':upload_filename if 'upload_filename' in locals() else str(package_filename or ''),
        'original_package_filename':pf if 'pf' in locals() else str(package_filename or ''),
        'missionquery':missionquery,
        'missionupload_attempts':upload_attempts,
        'metadata_put_attempts':metadata_put_attempts,
        'creator_uid_used':creator,
        'creator_uid_source':creator_source,
        'creator_uid_candidates':creator_candidates,
        'cert':str(cert_pair[0]) if cert_pair else '',
        'key':str(cert_pair[1]) if cert_pair else '',
    }

def _register_ots_data_package(zip_path, package_filename, sha256_hash, size_bytes, creator_uid='tak-dashboard'):
    upload_dir=_ots_upload_folder()
    upload_dir.mkdir(parents=True, exist_ok=True)
    stored=upload_dir/(sha256_hash + '.zip')
    if not stored.exists() or stored.stat().st_size != int(size_bytes or 0):
        shutil.copyfile(zip_path, stored)
    try:
        os.chmod(stored, 0o644)
    except Exception:
        pass
    pg_uris, cfg_errors = _candidate_ots_pg_uris()
    if not pg_uris:
        return {'ok':False,'error':'OpenTAKServer PostgreSQL URI not found; cannot register fileshare package.','path':str(stored),'config_errors':cfg_errors}
    uri=pg_uris[0]
    cols, err=_pg_columns(uri, 'public', 'data_packages')
    if err:
        return {'ok':False,'error':err,'path':str(stored)}
    colmap={c.lower():c for c in cols}
    hash_col=colmap.get('hash')
    if not hash_col:
        return {'ok':False,'error':'OpenTAKServer data_packages table has no hash column.','path':str(stored)}
    exists, err=_pg_first_value(uri, f"select count(*) from public.data_packages where {_pg_ident(hash_col)}={_pg_sql_literal(sha256_hash)}")
    if err:
        return {'ok':False,'error':err,'path':str(stored)}
    if str(exists or '0').strip() not in ('0',''):
        return {'ok':True,'path':str(stored),'registered':False,'message':'Data package already registered.'}
    vals={}
    def set_first(names, value):
        for n in names:
            c=colmap.get(n.lower())
            if c and c not in vals:
                vals[c]=value; return
    set_first(('filename','file_name','name'), package_filename)
    set_first(('hash','sha256'), sha256_hash)
    set_first(('mime_type','mimetype','content_type'), 'application/zip')
    set_first(('size','size_bytes','file_size'), int(size_bytes or 0))
    # data_packages.creator_uid has a foreign-key to euds.uid on OpenTAKServer.
    # The dashboard is not an EUD, so do not insert TAK-DASHBOARD or another synthetic UID here.
    # If a real sender EUD UID is supplied and exists, use it; otherwise leave creator_uid NULL/omitted.
    real_creator_uid=''
    supplied_creator_uid=str(creator_uid or '').strip()
    if supplied_creator_uid and colmap.get('creator_uid'):
        try:
            cnt, cnt_err=_pg_first_value(uri, 'select count(*) from public.euds where uid=' + _pg_sql_literal(supplied_creator_uid))
            if not cnt_err and str(cnt or '0').strip() not in ('0',''):
                real_creator_uid=supplied_creator_uid
        except Exception:
            real_creator_uid=''
    if real_creator_uid:
        set_first(('creator_uid','creatorUid'), real_creator_uid)
    set_first(('keywords','keyword'), 'offline-map')
    if 'expiration' in colmap: vals[colmap['expiration']]=-1
    if 'submission_time' in colmap: vals[colmap['submission_time']]='__NOW__'
    if 'created_at' in colmap: vals[colmap['created_at']]='__NOW__'
    if 'updated_at' in colmap: vals[colmap['updated_at']]='__NOW__'
    if 'uid' in colmap: vals[colmap['uid']]=sha256_hash
    if 'tool' in colmap: vals[colmap['tool']]='TAK Server Dashboard'
    if not vals:
        return {'ok':False,'error':'No compatible columns found in data_packages table.','path':str(stored)}
    cols_sql=', '.join(_pg_ident(k) for k in vals.keys())
    val_sql=[]
    for v in vals.values():
        if v == '__NOW__': val_sql.append('now()')
        elif isinstance(v, int): val_sql.append(str(v))
        else: val_sql.append(_pg_sql_literal(v))
    insert_sql=f"insert into public.data_packages ({cols_sql}) values ({', '.join(val_sql)})"
    ok, err=_pg_exec(uri, insert_sql)
    if not ok:
        # OpenTAKServer commonly enforces a unique filename. For dashboard-generated
        # packages, replace the older row with the same filename so re-sending a
        # corrected package does not fail with data_packages_filename_key.
        filename_col=colmap.get('filename') or colmap.get('file_name') or colmap.get('name')
        if filename_col and 'duplicate key' in str(err or '').lower() and 'filename' in str(err or '').lower():
            del_ok, del_err=_pg_exec(uri, f"delete from public.data_packages where {_pg_ident(filename_col)}={_pg_sql_literal(package_filename)}")
            if del_ok:
                ok2, err2=_pg_exec(uri, insert_sql)
                if ok2:
                    return {'ok':True,'path':str(stored),'registered':True,'replaced_existing_filename':True}
                err=err2
            elif del_err:
                err=str(err) + '; additionally could not replace existing filename: ' + str(del_err)
        return {'ok':False,'error':err,'path':str(stored)}
    return {'ok':True,'path':str(stored),'registered':True}

def _cot_time(dt):
    return dt.astimezone(timezone.utc).strftime('%Y-%m-%dT%H:%M:%S.%f')[:-3] + 'Z'

def _offline_map_center(target):
    try:
        center=str(target.get('center') or '').strip()
        if center:
            bits=[float(x) for x in center.split(',')[:2]]
            if len(bits)>=2:
                # MBTiles center is lon,lat,zoom
                lon,lat=bits[0],bits[1]
                if -90<=lat<=90 and -180<=lon<=180: return lat,lon
    except Exception:
        pass
    try:
        b=target.get('bounds')
        if isinstance(b, str):
            vals=[float(x) for x in b.split(',')[:4]]
            if len(vals)==4:
                west,south,east,north=vals
                return (south+north)/2.0, (west+east)/2.0
        if isinstance(b, dict):
            south=float(b.get('south')); north=float(b.get('north')); west=float(b.get('west')); east=float(b.get('east'))
            return (south+north)/2.0, (west+east)/2.0
    except Exception:
        pass
    return 0.0,0.0

def _tak_team_name(value=''):
    raw=str(value or '').strip()
    if not raw:
        raw=os.environ.get('TAK_DASH_OFFLINE_SENDER_TEAM','').strip()
    if not raw:
        return 'Orange'
    compact=re.sub(r'[^a-z0-9]+',' ',raw.lower()).strip()
    known={
        'white':'White','yellow':'Yellow','orange':'Orange','magenta':'Magenta',
        'red':'Red','maroon':'Maroon','purple':'Purple','dark blue':'Dark Blue',
        'blue':'Blue','cyan':'Cyan','teal':'Teal','green':'Green','brown':'Brown',
    }
    if compact in known:
        return known[compact]
    return raw[:1].upper()+raw[1:]


def _fileshare_cot_filename_for_url(package, sender_url=''):
    """Choose the FileShare filename visible to ATAK for the advertised URL.

    OTS missionupload needs a unique filename for its data_packages table, but
    when the CoT advertises the dashboard-hosted package endpoint, ATAK should
    see the same filename that appears in that URL.  Keeping the CoT filename
    hash-suffixed while the URL ends in the original package name appears to be
    another avoidable mismatch during Send Basemap testing.
    """
    url=str(sender_url or '')
    if '/api/tak-map/fileshare-package/' in url or '/api/tak-map/fileshare-mapsource/' in url:
        return str(package.get('package_name') or package.get('original_package_filename') or package.get('fileshare_filename') or 'TAK Map Source.zip')
    return str(package.get('fileshare_filename') or package.get('native_upload_filename') or package.get('package_name') or 'TAK Map Source.zip')

def _fileshare_cot_display_name(package):
    # Use the selected basemap/package name for the fileshare announcement.
    # The senderUrl is only the downloadable XML ZIP location; the actual tile
    # provider URL remains inside the mapsource XML.
    val=str(package.get('cot_name') or package.get('fileshare_cot_name') or package.get('content_name') or package.get('package_name') or 'TAK Map Source').strip()
    return val or 'TAK Map Source'

def _fileshare_url_with_receiver(sender_url, receiver_callsign='', receiver_uid=''):
    """Append receiver=<callsign> to targeted native metadata/tool sender URLs.

    v205: Successful ATAK receiver downloads on this OTS instance use
    /Marti/api/sync/metadata/<hash>/tool?receiver=<callsign>.  Add that query
    only for targeted CoT and only for native metadata/tool URLs.
    """
    url=str(sender_url or '').strip()
    if not url:
        return url
    if os.environ.get('TAK_DASH_DISABLE_NATIVE_RECEIVER_QUERY','').strip().lower() in ('1','true','yes','on'):
        return url
    if '/Marti/api/sync/metadata/' not in url or not url.split('?',1)[0].rstrip('/').endswith('/tool'):
        return url
    try:
        pu=urlparse(url)
        existing=parse_qs(pu.query, keep_blank_values=True)
        if any(str(k).lower() == 'receiver' for k in existing.keys()):
            return url
        receiver=str(receiver_callsign or '').strip() or str(receiver_uid or '').strip()
        if not receiver:
            return url
        return url + ('&' if pu.query else '?') + 'receiver=' + quote(receiver, safe='')
    except Exception:
        return url


def _ots_metadata_tool_download_check(sender_url, receiver_callsign='', receiver_uid=''):
    """Best-effort receiver-style GET validation for native metadata/tool URLs.

    v205: if the DP is registered but ATAK does not notify/import, we need to
    separate a bad download URL from a CoT routing problem.  This uses the same
    receiver query pattern ATAK uses, with the configured OTS client cert/key.
    """
    url=str(sender_url or '').strip()
    if not url or '/Marti/api/sync/metadata/' not in url:
        return {'ok':False,'skipped':True,'reason':'not a native metadata/tool URL','url':url}
    recv=str(receiver_callsign or '').strip() or str(receiver_uid or '').strip()
    if recv and 'receiver=' not in url:
        url=_fileshare_url_with_receiver(url, recv, receiver_uid)
    cert_pairs=_ots_cert_candidates()
    cert_pair=cert_pairs[0] if cert_pairs else None
    try:
        ctx=ssl.create_default_context()
        ctx.check_hostname=False
        ctx.verify_mode=ssl.CERT_NONE
        if cert_pair:
            ctx.load_cert_chain(str(cert_pair[0]), str(cert_pair[1]))
        req=Request(url, method='GET', headers={'Accept':'application/zip,application/octet-stream,*/*','User-Agent':'TAKDashboard/2.11 metadata-tool-download-check'})
        with urlopen(req, timeout=12, context=ctx) as resp:
            data=resp.read(4096)
            code=int(getattr(resp,'status',None) or resp.getcode())
            ctype=str(resp.headers.get('Content-Type','') if getattr(resp,'headers',None) is not None else '')
            clen=str(resp.headers.get('Content-Length','') if getattr(resp,'headers',None) is not None else '')
            is_zip=data.startswith(b'PK\x03\x04') or data.startswith(b'PK\x05\x06') or data.startswith(b'PK\x07\x08')
            return {'ok':(200 <= code < 300 and is_zip),'status':code,'url':url,'receiver':recv,'content_type':ctype,'content_length':clen,'first_bytes_hex':data[:16].hex(),'is_zip':is_zip,'cert':str(cert_pair[0]) if cert_pair else ''}
    except HTTPError as e:
        try: body=decode_http_body(e.read(600), getattr(e,'headers',{}) or {})[:600]
        except Exception: body=''
        return {'ok':False,'status':int(getattr(e,'code',0) or 0),'url':url,'receiver':recv,'error':str(e),'body_preview':body,'cert':str(cert_pair[0]) if cert_pair else ''}
    except Exception as e:
        return {'ok':False,'url':url,'receiver':recv,'error':str(e),'cert':str(cert_pair[0]) if cert_pair else ''}

def _build_fileshare_cot(target_callsign, package, sender_callsign, sender_uid, server_host, lat=0.0, lon=0.0, target_uid='', target_team='', sender_url_override='', broadcast=False, variant='targeted-metadata'):
    now=datetime.now(timezone.utc)
    try:
        stale_seconds=max(300, int(os.environ.get('TAK_DASH_FILESHARE_STALE_SECONDS','3600') or '3600'))
    except Exception:
        stale_seconds=3600
    stale=now + timedelta(seconds=stale_seconds)
    event_uid=str(uuid.uuid4())
    ack_uid=str(uuid.uuid4())
    port=_ots_marti_https_port()
    host=_url_host(server_host or _default_server_host())
    sender_url=str(sender_url_override or '').strip() or f"https://{host}:{port}/Marti/api/sync/metadata/{package['sha256']}/tool"
    if not broadcast:
        sender_url=_fileshare_url_with_receiver(sender_url, target_callsign, target_uid)
    event=ET.Element('event', {
        'access':'Undefined','how':'h-e','stale':_cot_time(stale),'start':_cot_time(now),'time':_cot_time(now),'type':'b-f-t-r','uid':event_uid,'version':'2.0'
    })
    ET.SubElement(event, 'point', {'ce':'9999999.0','hae':'0.0','lat':f'{float(lat):.8f}','le':'9999999.0','lon':f'{float(lon):.8f}'})
    detail=ET.SubElement(event, 'detail')
    # Include normal contact/group metadata so OTS/ATAK treats the fileshare as a
    # client-originated TAK event instead of a bare XML fragment from an unknown tool.
    ET.SubElement(detail, 'contact', {'callsign':sender_callsign})
    # Use the dashboard sender/group identity for the fileshare request itself,
    # not the recipient EUD's current team. Field tests showed b-f-t-r events
    # that used the recipient team (for example Orange) could be accepted at the
    # socket layer but never appear in public.cot, while the last verified
    # working fileshare CoT used the dashboard-side Cyan group. Allow override
    # for installs that place the dashboard sender cert in a different group.
    sender_team_raw=os.environ.get('TAK_DASH_FILESHARE_SENDER_TEAM','').strip() or os.environ.get('TAK_DASH_OFFLINE_SENDER_TEAM','').strip() or 'Cyan'
    team_name=_tak_team_name(sender_team_raw)
    recipient_team_name=_tak_team_name(target_team) if str(target_team or '').strip() else ''
    content_display_name=_fileshare_cot_display_name(package)
    ET.SubElement(detail, '__group', {'name':team_name, 'role':'Team Member'})
    ET.SubElement(detail, 'status', {'battery':'100'})
    ET.SubElement(detail, 'precisionlocation', {'altsrc':'DTED0','geopointsrc':'TAK Dashboard'})
    ET.SubElement(detail, 'remarks').text='TAK Dashboard fileshare request'
    ET.SubElement(detail, 'fileshare', {
        'filename':_fileshare_cot_filename_for_url(package, sender_url),
        'name':content_display_name,
        'senderCallsign':sender_callsign,
        'senderUid':sender_uid,
        'senderUrl':sender_url,
        'sha256':package['sha256'],
        'sizeInBytes':str(int(package.get('size_bytes') or 0)),
    })
    ET.SubElement(detail, 'ackrequest', {'ackrequested':'true','tag':content_display_name,'uid':ack_uid})
    if not broadcast:
        marti=ET.SubElement(detail, 'marti')
        dest={'callsign':str(target_callsign or '')}
        if str(target_uid or '').strip():
            dest['uid']=str(target_uid).strip()
        ET.SubElement(marti, 'dest', dest)
    xml='<?xml version="1.0" encoding="utf-8"?>' + ET.tostring(event, encoding='unicode', short_empty_elements=True)
    return xml, {'event_uid':event_uid,'ack_uid':ack_uid,'sender_url':sender_url,'sender_url_receiver_query_added':('/Marti/api/sync/metadata/' in str(sender_url) and 'receiver=' in str(sender_url)),'stale_seconds':stale_seconds,'target_uid':str(target_uid or ''),'target_team':recipient_team_name,'fileshare_sender_team':team_name,'fileshare_cot_name':content_display_name,'fileshare_variant':str(variant or ''),'broadcast':bool(broadcast)}



def _build_fileshare_cot_minimal(target_callsign, package, sender_callsign, sender_uid, server_host, lat=0.0, lon=0.0, target_uid='', sender_url_override='', broadcast=True, variant='native-minimal-broadcast'):
    """Build a TAK-native minimal FileShare CoT.

    Several TAK libraries construct FileShare events with only the fileshare
    detail and an ackrequest tag="transfer".  Field testing on OTS showed our
    fuller dashboard-originated b-f-t-r XML can be accepted at the socket layer
    without showing on ATAK, so v205 keeps this native/minimal form first.
    """
    now=datetime.now(timezone.utc)
    try:
        stale_seconds=max(300, int(os.environ.get('TAK_DASH_FILESHARE_STALE_SECONDS','3600') or '3600'))
    except Exception:
        stale_seconds=3600
    stale=now + timedelta(seconds=stale_seconds)
    event_uid=str(uuid.uuid4())
    ack_uid=str(uuid.uuid4())
    port=_ots_marti_https_port()
    host=_url_host(server_host or _default_server_host())
    sender_url=str(sender_url_override or '').strip() or f"https://{host}:{port}/Marti/api/sync/metadata/{package['sha256']}/tool"
    if not broadcast:
        sender_url=_fileshare_url_with_receiver(sender_url, target_callsign, target_uid)
    content_display_name=_fileshare_cot_display_name(package)
    event=ET.Element('event', {
        'version':'2.0',
        'uid':event_uid,
        'type':'b-f-t-r',
        'time':_cot_time(now),
        'start':_cot_time(now),
        'stale':_cot_time(stale),
        'how':'h-e',
    })
    ET.SubElement(event, 'point', {'lat':f'{float(lat or 0.0):.8f}','lon':f'{float(lon or 0.0):.8f}','hae':'9999999.0','ce':'9999999.0','le':'9999999.0'})
    detail=ET.SubElement(event, 'detail')
    ET.SubElement(detail, 'fileshare', {
        'filename':_fileshare_cot_filename_for_url(package, sender_url),
        'name':content_display_name,
        'senderCallsign':sender_callsign,
        'senderUid':sender_uid,
        'senderUrl':sender_url,
        'sha256':package['sha256'],
        'sizeInBytes':str(int(package.get('size_bytes') or 0)),
    })
    # TAK FileShare builders commonly use tag="transfer" here instead of the
    # filename.  Keep this default, with an opt-out for field comparisons.
    ack_tag=os.environ.get('TAK_DASH_FILESHARE_ACK_TAG','transfer').strip() or 'transfer'
    ET.SubElement(detail, 'ackrequest', {'uid':ack_uid,'tag':ack_tag,'ackrequested':'true'})
    if not broadcast:
        marti=ET.SubElement(detail, 'marti')
        dest={'callsign':str(target_callsign or '')}
        if str(target_uid or '').strip():
            dest['uid']=str(target_uid).strip()
        ET.SubElement(marti, 'dest', dest)
    xml='<?xml version="1.0" encoding="utf-8"?>' + ET.tostring(event, encoding='unicode', short_empty_elements=True)
    return xml, {'event_uid':event_uid,'ack_uid':ack_uid,'sender_url':sender_url,'sender_url_receiver_query_added':('/Marti/api/sync/metadata/' in str(sender_url) and 'receiver=' in str(sender_url)),'stale_seconds':stale_seconds,'target_uid':str(target_uid or ''),'fileshare_cot_name':content_display_name,'fileshare_variant':str(variant or ''),'broadcast':bool(broadcast),'native_minimal':True,'ack_tag':ack_tag}


def _build_route_control_marker_cot(target_callsign, package, sender_callsign, sender_uid, server_host, lat=0.0, lon=0.0, target_uid='', target_team='', sender_url_override='', broadcast=True, variant='route-control-marker-broadcast'):
    """Build a plain marker CoT with no <fileshare> tag.

    v216 diagnostic: manual takdash marker CoT reaches public.cot, while every
    event containing <fileshare> has been accepted at socket write level but
    dropped before public.cot.  This control marker uses the same Send Map code
    path and same package URL, but carries it only in remarks so we can prove
    dashboard-originated non-FileShare CoT still routes to OTS/EUD.
    """
    now=datetime.now(timezone.utc)
    try:
        stale_seconds=max(300, int(os.environ.get('TAK_DASH_FILESHARE_STALE_SECONDS','3600') or '3600'))
    except Exception:
        stale_seconds=3600
    stale=now + timedelta(seconds=stale_seconds)
    event_uid='TAKDASH-ROUTE-CONTROL-' + str(uuid.uuid4())
    port=_ots_marti_https_port()
    host=_url_host(server_host or _default_server_host())
    sender_url=str(sender_url_override or '').strip() or f"https://{host}:{port}/Marti/api/sync/metadata/{package['sha256']}/tool"
    if not broadcast:
        sender_url=_fileshare_url_with_receiver(sender_url, target_callsign, target_uid)
    content_display_name=_fileshare_cot_display_name(package)
    filename=_fileshare_cot_filename_for_url(package, sender_url)
    sender_team_raw=os.environ.get('TAK_DASH_FILESHARE_SENDER_TEAM','').strip() or os.environ.get('TAK_DASH_OFFLINE_SENDER_TEAM','').strip() or 'Cyan'
    team_name=_tak_team_name(sender_team_raw)
    event=ET.Element('event', {
        'version':'2.0',
        'uid':event_uid,
        'type':'a-f-G-U-C',
        'time':_cot_time(now),
        'start':_cot_time(now),
        'stale':_cot_time(stale),
        'how':'h-g-i-g-o',
    })
    ET.SubElement(event, 'point', {'lat':f'{float(lat or 0.0):.8f}','lon':f'{float(lon or 0.0):.8f}','hae':'0.0','ce':'9999999.0','le':'9999999.0'})
    detail=ET.SubElement(event, 'detail')
    ET.SubElement(detail, 'contact', {'callsign':sender_callsign or 'takdash'})
    ET.SubElement(detail, '__group', {'name':team_name, 'role':'Team Member'})
    ET.SubElement(detail, 'remarks').text=(
        'TAK Dashboard Send Map route-control marker. '
        f'No fileshare XML in this control event. Package={content_display_name}; filename={filename}; url={sender_url}'
    )
    if not broadcast:
        marti=ET.SubElement(detail, 'marti')
        dest={'callsign':str(target_callsign or '')}
        if str(target_uid or '').strip():
            dest['uid']=str(target_uid).strip()
        ET.SubElement(marti, 'dest', dest)
    xml='<?xml version="1.0" encoding="utf-8"?>' + ET.tostring(event, encoding='unicode', short_empty_elements=True)
    return xml, {'event_uid':event_uid,'ack_uid':'','sender_url':sender_url,'sender_url_receiver_query_added':('/Marti/api/sync/metadata/' in str(sender_url) and 'receiver=' in str(sender_url)),'stale_seconds':stale_seconds,'target_uid':str(target_uid or ''),'target_team':_tak_team_name(target_team) if str(target_team or '').strip() else '','fileshare_sender_team':team_name,'fileshare_cot_name':content_display_name,'fileshare_variant':str(variant or ''),'broadcast':bool(broadcast),'route_control_marker':True,'cot_type':'a-f-G-U-C','contains_fileshare_xml':False}

def _build_fileshare_marker_cot(target_callsign, package, sender_callsign, sender_uid, server_host, lat=0.0, lon=0.0, target_uid='', target_team='', sender_url_override='', broadcast=True, variant='marker-fileshare-broadcast'):
    """Build a normal routable marker CoT carrying FileShare metadata.

    Field test: takdash TLS 8089 can insert normal a-f-G-U-C CoT into public.cot,
    while b-f-t-r / b-m-r FileShare/DataPackage events are accepted at the socket
    layer but not stored/routed.  This diagnostic shape keeps the fileshare
    payload and dashboard package URL, but uses a known-routable friendly marker
    event type so we can separate OTS routing from ATAK FileShare handling.
    """
    now=datetime.now(timezone.utc)
