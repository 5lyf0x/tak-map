    rows.push(rowHtml('Type',a.aircraft_type||a.type||a.t||''));
    rows.push(rowHtml('Alt',a.altitude_ft!=null?valueNum(a.altitude_ft,'ft'):''));
    rows.push(rowHtml('Speed',a.speed_kt!=null?valueNum(a.speed_kt,'kt'):''));
    rows.push(rowHtml('Track',a.track_deg!=null?Math.round(Number(a.track_deg))+'°':''));
    rows.push(rowHtml('Range',a.range_miles!=null?Number(a.range_miles).toFixed(1)+' mi':''));
    rows.push(rowHtml('Owner/Op',a.owner_operator||a.ownOp||a.operator||a.owner||''));
    rows.push(rowHtml('Squawk',a.squawk||''));
    rows.push(rowHtml('Emergency',a.emergency&&String(a.emergency).toLowerCase()!=='none'?a.emergency:''));
    const track=`<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn${active?' active':''}" data-adsb-track-id="${esc(id)}"><span class="adsb-track-light ${active?'active':''}"></span><span>Track</span></button></div>`;
    return `<div class="feature-popup adsb-popup adsb-v286-popup-inner" data-adsb-id="${esc(id)}"><h3>${esc(title)}</h3><div class="kvp">${rows.join('')}</div>${track}</div>`;
  }
  function isAdsbContent(content){return typeof content==='string'&&content.indexOf('adsb-popup')!==-1}
  function patchLeafletPopupSources(){try{
