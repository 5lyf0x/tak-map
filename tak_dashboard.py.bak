  function isHelicopter(a){const cat=String((a&&(a.category_raw||a.adsb_category||a.emitter_category||a.category_code))||'').trim().toUpperCase();if(cat==='A7')return true;if(a&&(a.is_helo===true||a.is_rotor===true||a.rotor===true))return true;const b=textBlob(a);if(/\bA7\b/.test(b))return true;if(/\b(ROTOR|ROTORCRAFT|ROTARY|HELICOPTER|HELI|HELO|GYRO)\b/.test(b))return true;if(/\b(H60|UH60|MH60|HH60|SH60|CH47|AH64|OH58|CH53|UH1|UH72|V22|B206|B407|B412|B429|B505|R22|R44|R66|S76|S92|AS50|AS350|AS355|EC35|EC45|EC120|EC130|EC135|EC145|H125|H130|H135|H145|H155|AW109|AW119|AW139|AW169|AW189|MD50|MD52|MD60)\b/.test(b))return true;if(/\b(BELL|ROBINSON|SIKORSKY|AIRBUS HELICOPTERS|EUROCOPTER|AGUSTA|LEONARDO HELICOPTERS)\b/.test(b))return true;return false}
  function norm(a){try{a=a||{}; if(a.category_raw==null&&a.category&&/^A\d$/i.test(String(a.category)))a.category_raw=a.category; a.category=classKey(a.category); a.is_helo=!!isHelicopter(a); a.aircraft_display_type=a.is_helo?'Helicopter':'Airplane'; return a}catch(_){return a||{}}}
  function filters(){const f={civil:true,military:true,govt:true,unknown:true};try{qa('#adsbV280Menu input[type="checkbox"][data-filter],#adsbV279Menu input[type="checkbox"][data-filter],#adsbV286Menu input[type="checkbox"][data-filter],#adsbV285Menu input[type="checkbox"][data-filter],#adsbV284Menu input[type="checkbox"][data-filter],input[type="checkbox"][data-filter]').forEach(ch=>{if(ch.dataset&&ch.dataset.filter)f[ch.dataset.filter]=!!ch.checked})}catch(_){ }return f}
  function aircraftList(){const f=filters();return (Array.isArray(window.lastAircraft)?window.lastAircraft:[]).map(x=>norm(Object.assign({},x))).filter(a=>f[classKey(a.category)]!==false)}
  function ensureStatusLabel(){try{const bar=q('#mapStatusBanner')||q('.map-status-banner');if(!bar)return;let item=q('#bannerAdsbItem',bar);if(!item){item=document.createElement('span');item.id='bannerAdsbItem';item.className='status-item status-dropdown-trigger';const before=q('#bannerDownloadsItem',bar);if(before&&before.parentElement===bar)bar.insertBefore(item,before);else bar.appendChild(item)}item.classList.add('status-dropdown-trigger');item.setAttribute('data-status-type','adsb');if(!item.dataset.v287Click){item.dataset.v287Click='1';item.addEventListener('click',function(ev){try{ev.preventDefault();ev.stopPropagation();showAdsbDropdown(ev);}catch(_){ }},true)}const n=aircraftList().length;const dotClass=n>0?'good':'unknown';item.innerHTML='<span class="status-dot '+dotClass+'" id="bannerAdsbDot"></span>ADS-B: <b id="bannerAdsb">'+n+' Aircraft</b>'; }catch(_){ }}
  function fmtAlt(a){let v=a.altitude_ft;if(v==null||v==='')v=a.alt_baro??a.alt_geom;if(String(v).toLowerCase()==='ground')return 'Ground';v=Number(v);return Number.isFinite(v)?Math.round(v).toLocaleString()+' ft':'—'}
