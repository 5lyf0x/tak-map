  function ensureLayers(){const m=getLeafletMap();if(!m||!window.L)return null;let g=window[TRACK_LAYER];if(!g){g=L.layerGroup().addTo(m);window[TRACK_LAYER]=g}else if(!m.hasLayer(g))g.addTo(m);let l=window[LABEL_LAYER];if(!l){l=L.layerGroup().addTo(m);window[LABEL_LAYER]=l}else if(!m.hasLayer(l))l.addTo(m);return {map:m,track:g,label:l}}
  function clearTempLayers(){try{const layers=ensureLayers();if(layers){layers.track.clearLayers();layers.label.clearLayers()}state.line=null;state.label=null}catch(_){} }
  function addPointFromAircraft(a){try{if(!state.id||!a||idOf(a)!==state.id)return false;const p=asPoint(a);if(!p)return false;const pts=state.points;const last=pts[pts.length-1];if(last&&dist2(last,p)<3)return false;pts.push(p);if(pts.length>STORE_LIMIT)pts.splice(0,pts.length-STORE_LIMIT);redrawTrack();return true}catch(_){return false}}
