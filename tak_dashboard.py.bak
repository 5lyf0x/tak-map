# --- v273 drawing/local-data/ADS-B direct fixes ---
# Release label remains 1.1.0; only the internal/package iteration marker advances to v273.
for _old in ('v272','v271','v270','v269','v268','v267','v266','v265','v264','v263','v262','v261','v260','v259','v258','v257','v256','v255','v254','v253','v252','v251','v250','v249','v248','v247','v246','v245','v244','v243','v242','v241','v240','v239','v238','v236'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class="iteration-chip">{_old}</span>', '<span class="iteration-chip">v301</span>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v273</span>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v273</span>')

_v273_js = r'''
/* v273 drawing save/local-data and ADS-B client-direct hardening */
(function(){
  const V='v301';
  const field=id=>document.getElementById(id);
  const esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  function st(){return window.v233DrawState=window.v233DrawState||{mode:'',points:[]}}
  function addStyle(){try{if(field('v273Style'))return;const css=`
    #drawToolMenu,#drawToolMenu.tool-submenu,#drawToolMenu.draw-icon-menu{display:none!important;position:absolute!important;right:54px!important;left:auto!important;top:0!important;width:48px!important;min-width:48px!important;max-width:48px!important;padding:5px!important;grid-template-columns:36px!important;grid-auto-rows:36px!important;gap:5px!important;box-sizing:border-box!important;overflow:hidden!important;border-radius:15px!important;border:1px solid rgba(255,255,255,.13)!important;background:rgba(8,13,18,.95)!important;box-shadow:0 14px 34px rgba(0,0,0,.46)!important;white-space:normal!important;z-index:990!important;}
    #drawToolMenu.active,#drawToolMenu.open,#drawToolMenu.draw-icon-menu.active,#drawToolMenu.draw-icon-menu.open{display:grid!important;}
    #drawToolMenu button{width:36px!important;height:36px!important;min-width:0!important;max-width:36px!important;margin:0!important;padding:7px!important;display:grid!important;place-items:center!important;box-sizing:border-box!important;overflow:hidden!important;border-radius:10px!important;border:1px solid #334553!important;background:#121d25!important;color:#b7c7cd!important;font-size:0!important;line-height:1!important;cursor:pointer!important;}
    #drawToolMenu button:hover{border-color:#5b707a!important;background:#17252d!important;color:#e3ecef!important;}
    #drawToolMenu svg{width:21px!important;height:21px!important;max-width:21px!important;max-height:21px!important;display:block!important;stroke:currentColor!important;fill:none!important;stroke-width:2!important;stroke-linecap:round!important;stroke-linejoin:round!important;filter:none!important;}
    #drawToolMenu .tool-label{display:none!important;}
    .draw-options-panel{width:min(330px,calc(100vw - 26px))!important;max-width:330px!important;padding:10px!important;}
    .draw-options-panel .panel-grid.compact{grid-template-columns:1fr 1fr!important;gap:7px!important;}
    .draw-options-panel .draw-poly-help{display:none;grid-column:1/-1;border:1px solid rgba(255,111,46,.25);border-radius:9px;background:rgba(255,111,46,.08);color:#ffd6c0;padding:6px 8px;font-size:.68rem;line-height:1.25;text-transform:none;letter-spacing:0;}
    .draw-options-panel.polygon-mode .draw-poly-help{display:block;}
    .draw-save-backdrop{display:none;position:fixed;inset:0;z-index:1700;background:rgba(0,0,0,.58);align-items:center;justify-content:center;padding:14px;}
    .draw-save-backdrop.active{display:flex;}
    .draw-save-card{width:min(365px,calc(100vw - 28px));border:1px solid rgba(255,255,255,.15);border-radius:16px;background:rgba(9,18,24,.96);box-shadow:0 24px 80px rgba(0,0,0,.58);color:#e9f3f6;overflow:hidden;}
    .draw-save-head{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.10);}
    .draw-save-head h2{margin:0;font-size:.86rem;text-transform:uppercase;letter-spacing:.08em;}
    .draw-save-body{padding:10px 12px;display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .draw-save-body label{display:flex;flex-direction:column;gap:3px;color:#9fb0bd;font-size:.64rem;text-transform:uppercase;letter-spacing:.06em;font-weight:800;}
    .draw-save-body label.wide{grid-column:1/-1;}
    .draw-save-body input,.draw-save-body select,.draw-save-body textarea{min-width:0;background:#091018;border:1px solid #334553;border-radius:9px;color:#e9f0f5;padding:7px 8px;font-size:.78rem;box-sizing:border-box;}
    .draw-save-body textarea{min-height:54px;resize:vertical;text-transform:none;letter-spacing:0;}
    .draw-save-note{grid-column:1/-1;color:#a8bbc2;font-size:.67rem;line-height:1.3;}
    .draw-save-actions{display:flex;justify-content:flex-end;gap:7px;padding:9px 12px;border-top:1px solid rgba(255,255,255,.08);}
    .draw-save-actions button{border:1px solid rgba(255,255,255,.12);border-radius:10px;background:rgba(255,255,255,.05);color:#e9f0f5;padding:7px 10px;font-weight:750;}
    .draw-save-actions .primary{border-color:rgba(255,111,46,.50);background:rgba(255,111,46,.15);color:#ffd6c0;}
  `;const el=document.createElement('style');el.id='v273Style';el.textContent=css;document.head.appendChild(el)}catch(e){console.warn('v273 css failed',e)}}
  function ensureDrawPanelPlus(){try{if(typeof window.v236OpenDrawOptions==='function')window.v236OpenDrawOptions();let p=field('drawOptionsPanel');if(!p)return;p.classList.toggle('polygon-mode',st().mode==='polygon');if(!field('drawFillColorInput')){const grid=p.querySelector('.panel-grid')||p;const fillPct=field('drawFillOpacityInput')?.closest('label');(fillPct||grid).insertAdjacentHTML(fillPct?'beforebegin':'beforeend','<label>Fill Color<input id="drawFillColorInput" type="color" value="#ff6f2e"></label>');grid.insertAdjacentHTML('beforeend','<label class="wide">Notes<textarea id="drawNotesInput" placeholder="Optional notes"></textarea></label><div class="draw-poly-help">Right-click to finish polygon.</div>')}const actions=p.querySelector('.tak-floating-actions');if(actions&&!field('drawOptionsSaveBtn'))actions.insertAdjacentHTML('beforeend','<button id="drawOptionsSaveBtn" class="primary" type="button" onclick="v233FinishDraw()">Save Shape</button>');['drawColorInput','drawFillColorInput','drawWeightInput','drawLineStyleInput','drawFillInput','drawFillOpacityInput','drawNameInput','drawNotesInput'].forEach(id=>{const el=field(id);if(el&&!el.dataset.v273Bound){el.dataset.v273Bound='1';['input','change'].forEach(evt=>el.addEventListener(evt,()=>{try{readDrawOptionsPlus();if(typeof v236RedrawDrawTemp==='function')v236RedrawDrawTemp()}catch(_){}}))}})}catch(e){console.warn('v273 draw panel failed',e)}}
  function setMenuOpen(open=true){try{const m=field('drawToolMenu');if(!m)return;m.classList.add('draw-icon-menu');m.classList.toggle('active',!!open);m.classList.toggle('open',!!open);m.style.right='54px';m.style.left='auto';m.style.top='0px'}catch(_){}}
  function normalizeDrawMenu(){try{const m=field('drawToolMenu');if(!m)return;m.classList.add('draw-icon-menu');const labels=['Square','Rectangle','Circle','Ellipse','Polygon','Freehand'];const icons=['<svg viewBox="0 0 24 24"><rect x="5" y="5" width="14" height="14" rx="1.8"/></svg>','<svg viewBox="0 0 24 24"><rect x="4" y="7" width="16" height="10" rx="1.8"/></svg>','<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="7"/></svg>','<svg viewBox="0 0 24 24"><ellipse cx="12" cy="12" rx="8" ry="5.5"/></svg>','<svg viewBox="0 0 24 24"><path d="M6 18 4.8 9.5 12 4.8l7.2 4.7L17.8 18Z"/></svg>','<svg viewBox="0 0 24 24"><path d="M5 16c1.5-7.2 8.6-10.7 12.7-7.2 4.5 3.8-3.3 9.8-8.6 8.3-2.8-.8-2.3-3.2-.3-3.8"/></svg>'];Array.from(m.querySelectorAll('button')).slice(0,6).forEach((b,i)=>{b.title=labels[i]||'Draw';b.type='button';b.innerHTML=icons[i]||b.innerHTML})}catch(_){}}
  function readDrawOptionsPlus(){const s=st();try{s.name=field('drawNameInput')?.value||s.name||'';s.color=field('drawColorInput')?.value||s.color||'#ff6f2e';s.strokeColor=s.color;s.fillColor=field('drawFillColorInput')?.value||s.fillColor||s.color||'#ff6f2e';s.weight=clamp(field('drawWeightInput')?.value||s.weight,1,18,3);s.lineStyle=field('drawLineStyleInput')?.value||s.lineStyle||'solid';s.fill=(field('drawFillInput')?.value||'1')==='1';s.fillOpacity=Math.max(0,Math.min(1,(parseFloat(field('drawFillOpacityInput')?.value||(s.fillOpacity==null?20:Math.round(s.fillOpacity*100)))||20)/100));s.notes=field('drawNotesInput')?.value||s.notes||''}catch(_){}return s}
  function llToCoord(ll){return [Number(ll.lng),Number(ll.lat)]}function coordsToLL(coords){return coords.map(c=>L.latLng(c[1],c[0]))}
  function projectPoly(mode,a,b){if(!window.map||!a||!b)return [];const p1=map.latLngToLayerPoint(a),p2=map.latLngToLayerPoint(b);let pts=[];if(mode==='rectangle'||mode==='square'){let x2=p2.x,y2=p2.y;if(mode==='square'){const dx=p2.x-p1.x,dy=p2.y-p1.y,d=Math.max(Math.abs(dx),Math.abs(dy))||1;x2=p1.x+(dx>=0?d:-d);y2=p1.y+(dy>=0?d:-d)}pts=[L.point(p1.x,p1.y),L.point(x2,p1.y),L.point(x2,y2),L.point(p1.x,y2),L.point(p1.x,p1.y)]}else if(mode==='circle'||mode==='ellipse'){const dx=p2.x-p1.x,dy=p2.y-p1.y;let rx=Math.abs(dx)||1,ry=Math.abs(dy)||1;if(mode==='circle'){const r=Math.sqrt(dx*dx+dy*dy)||1;rx=r;ry=r}for(let i=0;i<96;i++){const t=Math.PI*2*i/96;pts.push(L.point(p1.x+Math.cos(t)*rx,p1.y+Math.sin(t)*ry))}pts.push(pts[0])}return pts.map(pt=>llToCoord(map.layerPointToLatLng(pt)))}
  function drawCoordsFinal(){const s=st(),pts=s.points||[];let end=s.liveEnd;if(s.mode==='polygon'&&s.polygonFinished)end=null;if(['rectangle','square','circle','ellipse'].includes(s.mode)&&pts.length&&end)return projectPoly(s.mode,pts[0],end);if(s.mode==='freehand'&&pts.length>1){const c=pts.map(llToCoord);if(c.length>2)c.push(c[0]);return c}if(s.mode==='polygon'&&pts.length){const arr=pts.slice();if(end)arr.push(end);const c=arr.map(llToCoord);if(c.length>2)c.push(c[0]);return c}return []}
  function patchPreview(){try{const old=window.v236RedrawDrawTemp;if(typeof old==='function'&&!old._v273Wrapped){const wrap=function(){try{const s=st();if(s.mode==='polygon'&&s.polygonFinished)s.liveEnd=null;if(['rectangle','square','circle','ellipse','polygon','freehand'].includes(s.mode)&&window.map&&window.L){readDrawOptionsPlus();try{if(s.layer)map.removeLayer(s.layer)}catch(_){}const coords=drawCoordsFinal();if(!coords.length)return;const opt={color:s.color||'#ff6f2e',weight:s.weight||3,opacity:.94,dashArray:s.lineStyle==='dashed'?'8 7':null,fill:s.fill!==false,fillColor:s.fillColor||s.color||'#ff6f2e',fillOpacity:s.fill===false?0:Math.max(0,Math.min(.8,s.fillOpacity==null?0.20:s.fillOpacity))};if(s.mode==='polygon'&&coords.length<4)s.layer=L.polyline((s.points||[]).concat(s.liveEnd&&!s.polygonFinished?[s.liveEnd]:[]),opt).addTo(map);else if(coords.length>=4)s.layer=L.polygon(coordsToLL(coords),opt).addTo(map);return}}catch(e){console.warn('v273 draw preview failed',e)}return old.apply(this,arguments)};wrap._v273Wrapped=true;window.v236RedrawDrawTemp=wrap}}catch(_){}}
  function ensureSaveDialog(){let b=field('drawSaveBackdrop');if(b)return b;document.body.insertAdjacentHTML('beforeend',`<div id="drawSaveBackdrop" class="draw-save-backdrop"><div class="draw-save-card"><div class="draw-save-head"><h2>Save Shape</h2><button type="button" onclick="v273CloseDrawSave(false)">×</button></div><div class="draw-save-body"><label class="wide">Name<input id="drawSaveName" placeholder="Shape name"></label><label>Perimeter<input id="drawSaveColor" type="color" value="#ff6f2e"></label><label>Line Width<input id="drawSaveWeight" type="number" min="1" max="18" step="1" value="3"></label><label>Line Style<select id="drawSaveLineStyle"><option value="solid">Solid</option><option value="dashed">Dashed</option></select></label><label>Fill<select id="drawSaveFill"><option value="1">Filled</option><option value="0">Unfilled</option></select></label><label>Fill Color<input id="drawSaveFillColor" type="color" value="#ff6f2e"></label><label>Fill %<input id="drawSaveFillOpacity" type="number" min="0" max="100" step="5" value="20"></label><label class="wide">Notes<textarea id="drawSaveNotes" placeholder="Optional notes"></textarea></label><div id="drawSaveNote" class="draw-save-note"></div></div><div class="draw-save-actions"><button type="button" onclick="v273CloseDrawSave(false)">Cancel</button><button class="primary" type="button" onclick="v273CloseDrawSave(true)">Save to Local Data</button></div></div></div>`);return field('drawSaveBackdrop')}
  window.v273CloseDrawSave=function(ok){try{const b=field('drawSaveBackdrop');if(b)b.classList.remove('active');const cb=window._v273SaveResolve;window._v273SaveResolve=null;if(cb)cb(!!ok)}catch(_){}}
  async function saveDialog(shapeType){const s=readDrawOptionsPlus();ensureSaveDialog();const defaults={name:(s.name||((shapeType||'Shape').replace(/^./,c=>c.toUpperCase())+' '+new Date().toLocaleTimeString())).trim(),color:s.color||'#ff6f2e',fillColor:s.fillColor||s.color||'#ff6f2e',weight:s.weight||3,lineStyle:s.lineStyle||'solid',fill:s.fill!==false,fillOpacity:Math.round((s.fillOpacity==null?0.20:s.fillOpacity)*100),notes:s.notes||''};field('drawSaveName').value=defaults.name;field('drawSaveColor').value=defaults.color;field('drawSaveFillColor').value=defaults.fillColor;field('drawSaveWeight').value=defaults.weight;field('drawSaveLineStyle').value=defaults.lineStyle;field('drawSaveFill').value=defaults.fill?'1':'0';field('drawSaveFillOpacity').value=defaults.fillOpacity;field('drawSaveNotes').value=defaults.notes;field('drawSaveNote').textContent=(shapeType==='polygon')?'Right-click finishes polygon without adding another point.':'Saved shapes appear in Local Data.';const b=field('drawSaveBackdrop');b.classList.add('active');const ok=await new Promise(res=>{window._v273SaveResolve=res});if(!ok)return null;return {name:(field('drawSaveName').value||defaults.name||'Shape').trim()||'Shape',color:field('drawSaveColor').value||defaults.color,fillColor:field('drawSaveFillColor').value||defaults.fillColor,weight:clamp(field('drawSaveWeight').value,1,18,defaults.weight),lineStyle:field('drawSaveLineStyle').value||defaults.lineStyle,fill:(field('drawSaveFill').value||'1')==='1',fillOpacity:Math.max(0,Math.min(1,(parseFloat(field('drawSaveFillOpacity').value||defaults.fillOpacity)||0)/100)),notes:field('drawSaveNotes').value||''}}
  async function uploadShape(name,feature){const fc={type:'FeatureCollection',features:[feature]};const blob=new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'});const safe=String(name||'TAK Map Shape').replace(/[\/:*?"<>|]+/g,'-').slice(0,80)||'TAK Map Shape';const fd=new FormData();fd.append('files',new File([blob],safe+'.geojson',{type:'application/geo+json'}));const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});let j={};try{j=await r.json()}catch(_){j={}}if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));try{if(j&&j.imports){lastImports=j.imports;window.lastImports=j.imports}}catch(_){try{window.lastImports=j.imports}catch(__){}}try{if(typeof renderImportRows==='function')renderImportRows()}catch(_){}try{if(typeof refreshLocalData==='function')await refreshLocalData()}catch(_){}try{if(typeof drawImportedObjects==='function')drawImportedObjects()}catch(_){}try{if(typeof importedLayer!=='undefined'&&importedLayer&&map&&!map.hasLayer(importedLayer)){importedLayer.addTo(map);if(typeof state!=='undefined'&&state.imported===false)state.imported=true}}catch(_){}return j}
  function setDrawStatus(msg){try{let p=field('drawOptionsPanel');if(!p)return;let x=field('drawSaveStatus');if(!x){p.insertAdjacentHTML('beforeend','<div id="drawSaveStatus" class="viewshed-status"></div>');x=field('drawSaveStatus')}x.textContent=msg||''}catch(_){}}
  function keepDrawingOpen(){try{setActiveMapTool('draw')}catch(_){}try{setMenuOpen(true)}catch(_){}try{ensureDrawPanelPlus();const p=field('drawOptionsPanel');if(p)p.classList.add('active','open')}catch(_){}try{if(map&&map.dragging)map.dragging.disable()}catch(_){}}
  function patchDrawLifecycle(){try{if(window.v273DrawPatched)return;window.v273DrawPatched=true;const oldStart=window.v233StartDraw;window.v233StartDraw=function(mode){let r;try{r=oldStart?oldStart.apply(this,arguments):undefined}catch(e){throw e}finally{try{const s=st();s.mode=mode;s.polygonFinished=false;s.liveEnd=null;ensureDrawPanelPlus();setMenuOpen(true);keepDrawingOpen()}catch(_){}}return r};window.v233FinishDraw=async function(){try{ensureDrawPanelPlus();const s=readDrawOptionsPlus();if(s.mode==='polygon'){s.polygonFinished=true;s.liveEnd=null}const coords=drawCoordsFinal();if(coords.length<4){alert('Add or draw more points before finishing.');return}const opts=await saveDialog(s.mode||'shape');if(!opts){keepDrawingOpen();return}const center=(s.points&&s.points[0])?llToCoord(s.points[0]):null;const edge=s.liveEnd?llToCoord(s.liveEnd):null;const props={name:opts.name,kind:'shape',shape_type:s.mode||'shape',color:opts.color,stroke_color:opts.color,fill:opts.fill,fill_color:opts.fillColor,fill_opacity:opts.fillOpacity,weight:opts.weight,line_weight:opts.weight,line_style:opts.lineStyle,notes:opts.notes,remarks:opts.notes,center,edge,source:'TAK Map Drawing Tools'};await uploadShape(opts.name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:props});try{if(typeof v233ClearDraw==='function')v233ClearDraw();else{s.points=[];s.liveEnd=null}}catch(_){s.points=[];s.liveEnd=null}try{s.name='';s.notes='';s.polygonFinished=false;if(field('drawNameInput'))field('drawNameInput').value='';if(field('drawNotesInput'))field('drawNotesInput').value=''}catch(_){}setDrawStatus('Saved to Local Data.');keepDrawingOpen()}catch(e){alert('Save shape failed: '+(e&&e.message?e.message:e));keepDrawingOpen()}};if(window.map&&!window.v273PolygonRightClick){window.v273PolygonRightClick=true;map.on('contextmenu',ev=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&activeMapTool==='draw'&&s.mode==='polygon'){if(ev&&ev.originalEvent){ev.originalEvent.preventDefault();try{L.DomEvent.stop(ev.originalEvent)}catch(_){}}s.polygonFinished=true;s.liveEnd=null;if(typeof v236RedrawDrawTemp==='function')v236RedrawDrawTemp();window.v233FinishDraw();}}catch(e){console.warn('polygon finish failed',e)}})}}catch(e){console.warn('v273 draw lifecycle failed',e)}}
  function adsbSetStatus(msg,ok){try{const box=field('adsbSettingsStatus');if(!box)return;box.textContent=String(msg||'');box.classList.toggle('adsb-status-ok',ok===true);box.classList.toggle('adsb-status-bad',ok===false)}catch(_){}}
  function ensureAdsbLayer(){try{if(typeof terrain3DActive!=='undefined'&&terrain3DActive)return false;if(window.map&&window.aircraftLayer&&!map.hasLayer(aircraftLayer))aircraftLayer.addTo(map);return true}catch(_){return false}}
  function currentCenter(){let lat=null,lon=null;try{const src=field('adsbCenterSource')?.value||'map_center';if(src==='map_center'&&window.map){const c=map.getCenter();lat=Number(c.lat);lon=Number(c.lng);if(field('adsbCenterLat'))field('adsbCenterLat').value=lat.toFixed(6);if(field('adsbCenterLon'))field('adsbCenterLon').value=lon.toFixed(6)}else{lat=Number(field('adsbCenterLat')?.value);lon=Number(field('adsbCenterLon')?.value)}if((!Number.isFinite(lat)||!Number.isFinite(lon))&&window.map){const c=map.getCenter();lat=Number(c.lat);lon=Number(c.lng);if(field('adsbCenterSource'))field('adsbCenterSource').value='map_center';if(field('adsbCenterLat'))field('adsbCenterLat').value=lat.toFixed(6);if(field('adsbCenterLon'))field('adsbCenterLon').value=lon.toFixed(6)}}catch(_){}return Number.isFinite(lat)&&Number.isFinite(lon)?{lat,lon}:null}
  function distMiles(a,b,c,d){const R=3958.7613,toRad=x=>Number(x)*Math.PI/180,p1=toRad(a),p2=toRad(c),dp=toRad(c-a),dl=toRad(d-b);const h=Math.sin(dp/2)**2+Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;return R*2*Math.atan2(Math.sqrt(h),Math.sqrt(1-h))}
  function blob(o){return ['flight','callsign','r','registration','t','type','desc','description','ownOp','operator','owner','squawk','hex'].map(k=>o&&o[k]).filter(Boolean).join(' ').toUpperCase()}
  function cat(o){const f=Number(o?.dbFlags??o?.dbflags??0);if(Number.isFinite(f)&&(f&1))return 'military';const b=blob(o);if(['POLICE','SHERIFF','HIGHWAY PATROL','CHP','CAL FIRE','CALFIRE','FIRE','RESCUE','PUBLIC SAFETY','LAW ENFORCEMENT','EMS','MEDEVAC','USFS','FOREST SERVICE','FEMA','DHS','CBP','BORDER PATROL','DEA','FBI','NOAA','NPS','COAST GUARD','USCG'].some(x=>b.includes(x)))return 'govt';if(!String(o?.hex||o?.flight||o?.r||o?.t||'').trim())return 'unknown';return 'civil'}
  function helo(o){const b=blob(o);const t=String(o?.t||o?.type||'').toUpperCase();return /\b(H|HEL|HELI|HELO|ROTOR)\b/.test(b)||b.includes('HELICOPTER')||b.includes('ROTORCRAFT')||t.startsWith('H')||['B407','B412','B429','B206','R44','R66','S76','S92','H135','H145','AS50','UH60','HH60','CH47','AH64'].some(x=>b.includes(x))}
  function norm(raw,center){try{let lat=Number(raw?.lat),lon=Number(raw?.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180)return null;let alt=raw.alt_baro;if(String(alt).toLowerCase()==='ground')alt=0;if(alt==null)alt=raw.alt_geom??raw.altitude;const c=cat(raw);const hex=String(raw.hex||raw.icao||'').trim().toUpperCase();const reg=String(raw.r||raw.registration||'').trim().toUpperCase();const flight=String(raw.flight||raw.callsign||'').trim();const id=hex||reg||flight||('aircraft-'+lat.toFixed(4)+'-'+lon.toFixed(4));let rng=null;try{rng=distMiles(center.lat,center.lon,lat,lon)}catch(_){}return {id,icao:hex,hex,registration:reg,callsign:flight||reg||hex||'ADS-B',flight,lat,lon,altitude_ft:alt,speed_kt:raw.gs??raw.speed,track_deg:raw.track??raw.true_heading??raw.mag_heading,seen_seconds:raw.seen_pos??raw.seen,seen_pos:raw.seen_pos,seen:raw.seen,category:c,category_class:c,aircraft_class:c,is_military:c==='military',is_govt:c==='govt',is_unknown:c==='unknown',is_helo:helo(raw),is_rotor:helo(raw),type:raw.t||raw.type||'',aircraft_type:raw.t||raw.type||'',description:raw.desc||raw.description||'',owner_operator:raw.ownOp||raw.operator||raw.owner||'',ownOp:raw.ownOp||'',dbFlags:raw.dbFlags??raw.dbflags??0,squawk:raw.squawk||'',emergency:raw.emergency||'',range_miles:Number.isFinite(rng)?Math.round(rng*100)/100:undefined,source:'Airplanes.live Client Direct',updated:new Date().toISOString()}}catch(_){return null}}
  function fstate(){return {civil:field('adsbFilterCivil')?.checked!==false,military:field('adsbFilterMilitary')?.checked!==false,govt:field('adsbFilterGovt')?.checked!==false,unknown:field('adsbFilterUnknown')?.checked!==false}}
  function filtered(items){const f=fstate();return (items||[]).filter(a=>f[String(a.category_class||a.category||'civil').toLowerCase()]!==false)}
  function patchAdsbDirect(){try{if(window.v273AdsbPatched)return;window.v273AdsbPatched=true;if(!localStorage.getItem('takmap.adsb.v273.defaulted')){localStorage.setItem('takmap.adsb.v273.defaulted','1');if(localStorage.getItem('takmap.adsb.localDisabled')==='1')localStorage.setItem('takmap.adsb.localDisabled','0')}['adsbFilterCivil','adsbFilterMilitary','adsbFilterGovt','adsbFilterUnknown'].forEach(id=>{const el=field(id);if(el&&!el.dataset.v273AdsbBound){el.dataset.v273AdsbBound='1';if(el.checked===false){}else el.checked=true;el.addEventListener('change',()=>{try{if(window.drawAircraft)window.drawAircraft(window.lastAircraft||[]);const n=filtered(window.lastAircraft||[]).length;field('adsbStatus')&&(field('adsbStatus').textContent=n+' active');adsbSetStatus(n+' shown after filter.',true)}catch(_){}})}});window.refreshAdsb=async function(){try{ensureAdsbLayer();const disabled=localStorage.getItem('takmap.adsb.localDisabled')==='1';if(disabled){try{field('adsbToggleBtn')&&(field('adsbToggleBtn').textContent='Enable ADS-B');aircraftLayer&&aircraftLayer.clearLayers();field('adsbStatus')&&(field('adsbStatus').textContent='disabled')}catch(_){}adsbSetStatus('ADS-B disabled.',true);return []}field('adsbToggleBtn')&&(field('adsbToggleBtn').textContent='Disable ADS-B');const center=currentCenter();if(!center){adsbSetStatus('Set ADS-B center.',false);return []}const radius=clamp(field('adsbRadiusMiles')?.value||50,1,250,50);const url='https://api.airplanes.live/v2/point/'+center.lat.toFixed(6)+'/'+center.lon.toFixed(6)+'/'+Math.round(radius);adsbSetStatus('ADS-B: Client Direct',true);let resp;try{resp=await fetch(url,{method:'GET',mode:'cors',credentials:'omit',cache:'no-store',headers:{'Accept':'application/json'}})}catch(e){adsbSetStatus('Client fetch failed. Browser/CORS/network.',false);field('adsbStatus')&&(field('adsbStatus').textContent='client fetch failed');return []}if(!resp.ok){adsbSetStatus('Airplanes.live HTTP '+resp.status,false);field('adsbStatus')&&(field('adsbStatus').textContent='HTTP '+resp.status);return []}let data;try{data=await resp.json()}catch(_){adsbSetStatus('Airplanes.live JSON failed.',false);return []}const by={};const sourceList=(data&&Array.isArray(data.ac))?data.ac:((data&&Array.isArray(data.aircraft))?data.aircraft:[]);if(!sourceList.length){try{console.warn('Airplanes.live returned no ac/aircraft array',data)}catch(_){}}for(const raw of sourceList){const a=norm(raw,center);if(!a)continue;const seen=Number(a.seen_seconds);if(Number.isFinite(seen)&&seen>60)continue;const k=String(a.id||'').toLowerCase();if(k&&!by[k])by[k]=a}window.lastAircraft=Object.values(by);try{lastAircraft=window.lastAircraft}catch(_){}window.v270AdsbFilters=fstate();const shown=filtered(window.lastAircraft);ensureAdsbLayer();if(window.drawAircraft)window.drawAircraft(window.lastAircraft);try{field('adsbStatus')&&(field('adsbStatus').textContent=shown.length+' active');if(window.lastBanner){lastBanner.adsb_aircraft=shown.length;if(typeof renderTopBanner==='function')renderTopBanner(lastBanner)}}catch(_){}adsbSetStatus(shown.length+' aircraft · Client Direct',true);return shown}catch(e){adsbSetStatus('ADS-B client error: '+String(e&&e.message?e.message:e),false);return []}}}catch(e){console.warn('v273 ADS-B patch failed',e)}}
  function boot(){try{addStyle();normalizeDrawMenu();/* v276: no Shape Options on load */patchPreview();patchDrawLifecycle();patchAdsbDirect();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v273 boot failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,350));else setTimeout(boot,120);
  setTimeout(boot,900);setTimeout(boot,2200);setTimeout(()=>{try{if(typeof refreshAdsb==='function')refreshAdsb()}catch(_){}},1800);setInterval(()=>{try{normalizeDrawMenu();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(_){}},2500);
})();
'''
_v273_marker='</script></body></html>'
_v273_i=TAK_MAP_HTML.rfind(_v273_marker)
if _v273_i >= 0:
    TAK_MAP_HTML = TAK_MAP_HTML[:_v273_i] + _v273_js + TAK_MAP_HTML[_v273_i:]
# --- end v273 drawing/local-data/ADS-B direct fixes ---


# --- v274 drawing uploader/freehand and ADS-B parser diagnostics ---
# Release label remains 1.1.0; only the internal/package iteration marker advances to v274.
for _old in ('v273','v272','v271','v270','v269','v268','v267','v266'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class=\"iteration-chip\">{_old}</span>', '<span class=\"iteration-chip\">v274</span>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class=\"iteration-marker\">{_old}</div>', '<div class=\"iteration-marker\">v274</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<div class=\"iteration-marker\">{_old}</div>', '<div class=\"iteration-marker\">v274</div>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<div class=\"iteration-marker\">{_old}</div>', '<div class=\"iteration-marker\">v274</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v274</span>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v274</span>')

_v274_js = r'''
/* v274 drawing save/freehand + ADS-B ac parser diagnostics + compact popups */
(function(){
  const V='v301';
  const $=id=>document.getElementById(id);
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  function addCss(){try{if($('v274Style'))return;const css=`
    .feature-popup{min-width:190px;max-width:min(315px,72vw);font-size:.76rem;line-height:1.25;color:#dce8ed;background:linear-gradient(180deg,rgba(13,23,30,.97),rgba(7,12,18,.97));border:1px solid rgba(255,255,255,.13);border-radius:14px;box-shadow:0 14px 42px rgba(0,0,0,.48);overflow:hidden;}
    .feature-popup h3{margin:0;padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.09);font-size:.83rem;letter-spacing:.055em;text-transform:uppercase;color:#f1f8fa;background:rgba(255,255,255,.035);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .feature-popup .kvp{display:grid;grid-template-columns:max-content minmax(0,1fr);gap:4px 8px;padding:8px 10px;align-items:start;}
    .feature-popup .kvp b{font-size:.61rem;color:#8ea2ad;text-transform:uppercase;letter-spacing:.07em;font-weight:850;white-space:nowrap;}
    .feature-popup .kvp span{min-width:0;color:#e7f0f3;overflow-wrap:anywhere;}
    .leaflet-popup-content-wrapper{background:transparent!important;box-shadow:none!important;padding:0!important;border-radius:15px!important;}
    .leaflet-popup-content{margin:0!important;}
    .leaflet-popup-tip{background:rgba(7,12,18,.97)!important;border:1px solid rgba(255,255,255,.12)!important;box-shadow:0 8px 20px rgba(0,0,0,.36)!important;}
    .popup-edit{margin:0 8px 9px;border:1px solid rgba(255,255,255,.11);border-radius:11px;background:rgba(255,255,255,.035);overflow:hidden;}
    .popup-edit summary{cursor:pointer;padding:6px 8px;font-size:.64rem;text-transform:uppercase;letter-spacing:.07em;font-weight:850;color:#ffc2a3;list-style:none;}
    .popup-edit[open] summary{border-bottom:1px solid rgba(255,255,255,.08);}
    .popup-edit label{display:flex;flex-direction:column;gap:3px;padding:5px 8px;color:#9fb0bd;font-size:.61rem;text-transform:uppercase;letter-spacing:.06em;font-weight:800;}
    .popup-edit input,.popup-edit textarea{background:#071018;border:1px solid #2e414e;border-radius:8px;color:#edf5f7;padding:6px 7px;font-size:.74rem;box-sizing:border-box;}
    .popup-edit-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 5px;}
    .popup-edit-actions{display:flex;gap:5px;align-items:center;flex-wrap:wrap;padding:7px 8px;border-top:1px solid rgba(255,255,255,.06);}
    .popup-edit-actions button{border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(255,255,255,.05);color:#eaf2f4;font-size:.68rem;padding:5px 7px;font-weight:800;}
    .popup-edit-actions .danger-action{border-color:rgba(255,70,70,.35);color:#ffb0a8;}
    .popup-edit-status{font-size:.63rem;color:#9fb0bd;}
    #drawOptionsSaveBtn{display:none!important;}
    #adsbTestBtn{border-color:rgba(90,180,255,.36)!important;color:#cdeeff!important;}
  `;const el=document.createElement('style');el.id='v274Style';el.textContent=css;document.head.appendChild(el)}catch(e){console.warn('v274 css failed',e)}}
  function st(){return window.v233DrawState=window.v233DrawState||{mode:'',points:[]}}
  function llToCoord(ll){return [Number(ll.lng),Number(ll.lat)]}
  function coordsToLL(coords){return (coords||[]).map(c=>L.latLng(Number(c[1]),Number(c[0])))}
  function readOpts(){const s=st();s.name=($('drawNameInput')?.value||s.name||'').trim();s.color=$('drawColorInput')?.value||s.color||'#ff6f2e';s.fillColor=$('drawFillColorInput')?.value||s.fillColor||s.color;s.weight=clamp($('drawWeightInput')?.value||s.weight,1,18,3);s.lineStyle=$('drawLineStyleInput')?.value||s.lineStyle||'solid';s.fill=($('drawFillInput')?.value||'1')==='1';s.fillOpacity=Math.max(0,Math.min(1,(parseFloat($('drawFillOpacityInput')?.value||20)||0)/100));s.notes=$('drawNotesInput')?.value||s.notes||'';return s}
  function projectPoly(mode,a,b){if(!window.map||!window.L||!a||!b)return[];const p1=map.latLngToContainerPoint(a),p2=map.latLngToContainerPoint(b),cx=p1.x,cy=p1.y;let dx=p2.x-p1.x,dy=p2.y-p1.y;if(mode==='square'){const d=Math.max(Math.abs(dx),Math.abs(dy));dx=(dx>=0?d:-d);dy=(dy>=0?d:-d);return [[cx,cy],[cx+dx,cy],[cx+dx,cy+dy],[cx,cy+dy],[cx,cy]].map(p=>llToCoord(map.containerPointToLatLng(L.point(p[0],p[1]))))}if(mode==='rectangle'){return [[cx,cy],[cx+dx,cy],[cx+dx,cy+dy],[cx,cy+dy],[cx,cy]].map(p=>llToCoord(map.containerPointToLatLng(L.point(p[0],p[1]))))}const n=mode==='circle'?96:80;let rx=Math.abs(dx),ry=Math.abs(dy);if(mode==='circle'){const r=Math.max(rx,ry);rx=r;ry=r}const out=[];for(let i=0;i<n;i++){const t=Math.PI*2*i/n;out.push(llToCoord(map.containerPointToLatLng(L.point(cx+Math.cos(t)*rx,cy+Math.sin(t)*ry))))}out.push(out[0]);return out}
  function drawCoordsFinal(){const s=st(),pts=s.points||[];let end=s.liveEnd;if(s.mode==='polygon'&&s.polygonFinished)end=null;if(['rectangle','square','circle','ellipse'].includes(s.mode)&&pts.length&&end)return projectPoly(s.mode,pts[0],end);if(s.mode==='freehand'&&pts.length>2){const c=pts.map(llToCoord);c.push(c[0]);return c}if(s.mode==='polygon'&&pts.length){const arr=pts.slice();if(end)arr.push(end);const c=arr.map(llToCoord);if(c.length>2)c.push(c[0]);return c}return []}
  function redrawTemp(){try{const s=readOpts();if(!window.map||!window.L)return;if(s.layer)try{map.removeLayer(s.layer)}catch(_){}const fillOpacityVal=(s.fillOpacity==null?0.20:s.fillOpacity);const opt={color:s.color||'#ff6f2e',weight:s.weight||3,opacity:.94,dashArray:s.lineStyle==='dashed'?'8 7':null,fill:s.fill!==false,fillColor:s.fillColor||s.color||'#ff6f2e',fillOpacity:s.fill===false?0:Math.max(0,Math.min(.8,fillOpacityVal))};const coords=drawCoordsFinal();if(coords.length>=4){s.layer=L.polygon(coordsToLL(coords),opt).addTo(map);return}if(s.mode==='polygon'&&s.points&&s.points.length){s.layer=L.polyline(s.points.concat(s.liveEnd&&!s.polygonFinished?[s.liveEnd]:[]),opt).addTo(map)}else if(s.points&&s.points.length){s.layer=L.polyline(s.points,opt).addTo(map)}}catch(e){console.warn('v274 redraw failed',e)}}
  async function uploadShapeDirect(name,feature){const fc={type:'FeatureCollection',features:[feature]};const blob=new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'});const safe=String(name||'TAK Map Shape').replace(/[\\/:*?\"<>|]+/g,'-').slice(0,80)||'TAK Map Shape';const fd=new FormData();fd.append('files',new File([blob],safe+'.geojson',{type:'application/geo+json'}));const r=await fetch('/api/tak-map/import',{method:'POST',body:fd,cache:'no-store'});let j={};try{j=await r.json()}catch(_){j={}}if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));try{if(j.imports){lastImports=j.imports;window.lastImports=j.imports}}catch(_){try{window.lastImports=j.imports}catch(__){}}try{if(typeof renderImportRows==='function')renderImportRows()}catch(_){}try{if(typeof refreshLocalData==='function')await refreshLocalData()}catch(_){}try{if(typeof drawImportedObjects==='function')drawImportedObjects()}catch(_){}try{if(typeof state!=='undefined'){state.imported=true;if(typeof saveTakMapUiPrefs==='function')saveTakMapUiPrefs()}if(typeof importedLayer!=='undefined'&&importedLayer&&map&&!map.hasLayer(importedLayer))importedLayer.addTo(map)}catch(_){}return j}
  function ensureSaveDialog(){if($('drawSaveBackdrop'))return $('drawSaveBackdrop');document.body.insertAdjacentHTML('beforeend',`<div id="drawSaveBackdrop" class="draw-save-backdrop"><div class="draw-save-card"><div class="draw-save-head"><h2>Save Shape</h2><button type="button" onclick="v274CloseDrawSave(false)">×</button></div><div class="draw-save-body"><label class="wide">Name<input id="drawSaveName" placeholder="Shape name"></label><label>Perimeter<input id="drawSaveColor" type="color" value="#ff6f2e"></label><label>Line Width<input id="drawSaveWeight" type="number" min="1" max="18" step="1" value="3"></label><label>Line Style<select id="drawSaveLineStyle"><option value="solid">Solid</option><option value="dashed">Dashed</option></select></label><label>Fill<select id="drawSaveFill"><option value="1">Filled</option><option value="0">Unfilled</option></select></label><label>Fill Color<input id="drawSaveFillColor" type="color" value="#ff6f2e"></label><label>Fill %<input id="drawSaveFillOpacity" type="number" min="0" max="100" step="5" value="20"></label><label class="wide">Notes<textarea id="drawSaveNotes" placeholder="Optional notes"></textarea></label><div id="drawSaveNote" class="draw-save-note"></div></div><div class="draw-save-actions"><button type="button" onclick="v274CloseDrawSave(false)">Cancel</button><button class="primary" type="button" onclick="v274CloseDrawSave(true)">Save to Local Data</button></div></div></div>`);return $('drawSaveBackdrop')}
  window.v274CloseDrawSave=function(ok){try{const b=$('drawSaveBackdrop');if(b)b.classList.remove('active');const cb=window._v274SaveResolve;window._v274SaveResolve=null;if(cb)cb(!!ok)}catch(_){} }
  async function saveDialog(kind){const s=readOpts();ensureSaveDialog();const name=(s.name||((kind||'Shape').replace(/^./,c=>c.toUpperCase())+' '+new Date().toLocaleTimeString())).trim();$('drawSaveName').value=name;$('drawSaveColor').value=s.color||'#ff6f2e';$('drawSaveWeight').value=s.weight||3;$('drawSaveLineStyle').value=s.lineStyle||'solid';$('drawSaveFill').value=s.fill===false?'0':'1';$('drawSaveFillColor').value=s.fillColor||s.color||'#ff6f2e';$('drawSaveFillOpacity').value=Math.round((s.fillOpacity==null?0.20:s.fillOpacity)*100);$('drawSaveNotes').value=s.notes||'';$('drawSaveNote').textContent=kind==='polygon'?'Right-click finishes polygon.':'Saved shapes appear in Local Data.';const b=$('drawSaveBackdrop');b.classList.add('active');const ok=await new Promise(res=>{window._v274SaveResolve=res});if(!ok)return null;return {name:($('drawSaveName').value||name||'Shape').trim()||'Shape',color:$('drawSaveColor').value||'#ff6f2e',weight:clamp($('drawSaveWeight').value,1,18,3),lineStyle:$('drawSaveLineStyle').value||'solid',fill:($('drawSaveFill').value||'1')==='1',fillColor:$('drawSaveFillColor').value||'#ff6f2e',fillOpacity:Math.max(0,Math.min(1,(parseFloat($('drawSaveFillOpacity').value||20)||0)/100)),notes:$('drawSaveNotes').value||''}}
  function setDrawStatus(msg){try{let p=$('drawOptionsPanel');if(!p)return;let x=$('drawSaveStatus');if(!x){p.insertAdjacentHTML('beforeend','<div id="drawSaveStatus" class="viewshed-status"></div>');x=$('drawSaveStatus')}x.textContent=msg||''}catch(_){} }
  function keepOpen(){try{if(typeof setActiveMapTool==='function')setActiveMapTool('draw')}catch(_){}try{const m=$('drawToolMenu');if(m){m.classList.add('active','open','draw-icon-menu');m.style.left='auto';m.style.right='54px'}}catch(_){}try{const p=$('drawOptionsPanel');if(p)p.classList.add('active','open')}catch(_){} }
  async function finishShape(kindOverride){try{const s=readOpts();if(kindOverride)s.mode=kindOverride;if(s.mode==='polygon'){s.polygonFinished=true;s.liveEnd=null}if(s.mode==='freehand')s.freehandDrawing=false;const coords=drawCoordsFinal();if(coords.length<4){alert('Add or draw more points before finishing.');keepOpen();return}const opts=await saveDialog(s.mode||'shape');if(!opts){keepOpen();return}const center=(s.points&&s.points[0])?llToCoord(s.points[0]):null;const edge=s.liveEnd?llToCoord(s.liveEnd):null;const props={name:opts.name,kind:'shape',shape_type:s.mode||'shape',color:opts.color,stroke_color:opts.color,fill:opts.fill,fill_color:opts.fillColor,fill_opacity:opts.fillOpacity,weight:opts.weight,line_weight:opts.weight,line_style:opts.lineStyle,notes:opts.notes,remarks:opts.notes,center,edge,source:'TAK Map Drawing Tools'};await uploadShapeDirect(opts.name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:props});try{if(s.layer)map.removeLayer(s.layer)}catch(_){}s.points=[];s.liveEnd=null;s.freehandDrawing=false;s.polygonFinished=false;s.name='';s.notes='';try{if($('drawNameInput'))$('drawNameInput').value='';if($('drawNotesInput'))$('drawNotesInput').value=''}catch(_){}setDrawStatus('Saved to Local Data.');keepOpen()}catch(e){alert('Save shape failed: '+(e&&e.message?e.message:e));keepOpen()}}
  function patchDraw(){try{if(window.v274DrawPatched)return;window.v274DrawPatched=true;const oldStart=window.v233StartDraw;window.v233StartDraw=function(mode){let r;try{r=oldStart?oldStart.apply(this,arguments):undefined}catch(e){throw e}finally{const s=st();s.mode=mode;s.points=[];s.liveEnd=null;s.freehandDrawing=false;s.polygonFinished=false;try{if($('drawOptionsSaveBtn'))$('drawOptionsSaveBtn').remove()}catch(_){}keepOpen()}return r};window.v233FinishDraw=function(){return finishShape()};window.v236RedrawDrawTemp=redrawTemp;const oldClick=window.v233DrawMapClick;window.v233DrawMapClick=function(ll){try{const s=st();if(s.mode==='freehand')return;if(window.v274SuppressNextDrawClick){window.v274SuppressNextDrawClick=false;return}if(typeof oldClick==='function')return oldClick.apply(this,arguments)}catch(e){console.warn('v274 draw click failed',e)}};if(window.map&&!window.v274FreehandBound){window.v274FreehandBound=true;map.on('mousedown touchstart',ev=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&activeMapTool==='draw'&&s.mode==='freehand'){if(ev&&ev.originalEvent){try{L.DomEvent.stop(ev.originalEvent)}catch(_){ev.originalEvent.preventDefault&&ev.originalEvent.preventDefault();ev.originalEvent.stopPropagation&&ev.originalEvent.stopPropagation()}}if(map.dragging)map.dragging.disable();s.points=[ev.latlng];s.liveEnd=null;s.freehandDrawing=true;redrawTemp()}}catch(e){console.warn('freehand start failed',e)}});map.on('mousemove touchmove',ev=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&activeMapTool==='draw'&&s.mode==='freehand'&&s.freehandDrawing&&ev.latlng){if(ev&&ev.originalEvent){try{L.DomEvent.stop(ev.originalEvent)}catch(_){}}const last=s.points[s.points.length-1];if(!last||map.distance(last,ev.latlng)>3){s.points.push(ev.latlng);redrawTemp()}}}catch(_){}});const end=ev=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&s.mode==='freehand'&&s.freehandDrawing){if(ev&&ev.originalEvent){try{L.DomEvent.stop(ev.originalEvent)}catch(_){}}s.freehandDrawing=false;window.v274SuppressNextDrawClick=true;if(map.dragging)map.dragging.disable();setTimeout(()=>finishShape('freehand'),25)}}catch(e){console.warn('freehand finish failed',e)}};map.on('mouseup touchend',end);document.addEventListener('mouseup',()=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&activeMapTool==='draw'&&s.mode==='freehand'&&s.freehandDrawing){s.freehandDrawing=false;window.v274SuppressNextDrawClick=true;setTimeout(()=>finishShape('freehand'),25)}}catch(_){}},true);map.on('contextmenu',ev=>{try{const s=st();if(typeof activeMapTool!=='undefined'&&activeMapTool==='draw'&&s.mode==='polygon'){if(ev&&ev.originalEvent){ev.originalEvent.preventDefault();try{L.DomEvent.stop(ev.originalEvent)}catch(_){}}s.polygonFinished=true;s.liveEnd=null;redrawTemp();finishShape('polygon')}}catch(e){console.warn('polygon right-click failed',e)}})}}catch(e){console.warn('v274 draw patch failed',e)}}
  function adsbStatus(msg,ok){try{const box=$('adsbSettingsStatus');if(box){box.textContent=msg;box.classList.toggle('adsb-status-ok',ok===true);box.classList.toggle('adsb-status-bad',ok===false)}}catch(_){} }
  function ensureAdsbTest(){/* v275 removed visible ADS-B diagnostics */}
  function clientUrl(){let lat=null,lon=null;try{if(($('adsbCenterSource')?.value||'map_center')==='map_center'&&window.map){const c=map.getCenter();lat=c.lat;lon=c.lng}else{lat=Number($('adsbCenterLat')?.value);lon=Number($('adsbCenterLon')?.value)}if((!Number.isFinite(lat)||!Number.isFinite(lon))&&window.map){const c=map.getCenter();lat=c.lat;lon=c.lng}const r=clamp($('adsbRadiusMiles')?.value||50,1,250,50);return 'https://api.airplanes.live/v2/point/'+Number(lat).toFixed(6)+'/'+Number(lon).toFixed(6)+'/'+Math.round(r)}catch(_){return ''}}
  window.v274TestAdsb=async function(){const url=clientUrl();try{console.log('ADS-B test URL:',url);adsbStatus('Testing Airplanes.live...',true);const r=await fetch(url,{method:'GET',mode:'cors',credentials:'omit',cache:'no-store',headers:{'Accept':'application/json'}});console.log('ADS-B test HTTP',r.status,r.statusText);if(!r.ok){adsbStatus('Airplanes.live HTTP '+r.status,false);return}const j=await r.json();const list=Array.isArray(j.ac)?j.ac:(Array.isArray(j.aircraft)?j.aircraft:[]);console.log('ADS-B raw response',j);adsbStatus(list.length+' aircraft returned by client.',true);try{if(typeof refreshAdsb==='function')await refreshAdsb()}catch(e){console.warn('refresh after ADS-B test failed',e)}}catch(e){console.error('ADS-B test failed',e);adsbStatus('Client fetch failed: CORS/network.',false)}}
  function patchAdsbAcParser(){try{const old=window.refreshAdsb;if(typeof old==='function'&&!old._v274AcWrapped){const wrapped=async function(){const out=await old.apply(this,arguments);try{if((!window.lastAircraft||!window.lastAircraft.length)&&typeof console!=='undefined')console.debug('ADS-B v274: if fetch was HTTP 200 but zero on map, confirm response key ac is being parsed.')}catch(_){}return out};wrapped._v274AcWrapped=true;window.refreshAdsb=wrapped}}catch(_){} }
  function boot(){try{addCss();patchDraw();patchAdsbAcParser();try{if($('drawOptionsSaveBtn'))$('drawOptionsSaveBtn').remove()}catch(_){}document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v274 boot failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,300));else setTimeout(boot,100);
  setTimeout(boot,900);setTimeout(boot,2200);setInterval(boot,3500);
