  function markPopup(popup){try{const el=(popup&&popup.getElement&&popup.getElement())||qa('.leaflet-popup').find(function(p){return q('.tak-v322-popup,.tak-v321-popup,.tak-v320-popup,.feature-popup',p)});if(!el)return;if(q('.tak-v322-popup,.tak-v321-popup,.tak-v320-popup,.feature-popup',el)){el.classList.add('tak-v322-object-popup');const close=q('.leaflet-popup-close-button',el);if(close){close.innerHTML='×';close.setAttribute('aria-label','Close')}}}catch(_){} }
  function patchLeaflet(){try{if(!window.L||!L.Layer||!L.Layer.prototype||L.Layer.prototype.__takV322BindPopup)return;const old=L.Layer.prototype.bindPopup;L.Layer.prototype.bindPopup=function(content,options){let opts=Object.assign({},options||{});let html='';try{html=String(typeof content==='function'?content():content||'')}catch(_){}if(/tak-v322-popup|tak-v321-popup|tak-v320-popup|feature-popup|adsb-popup/.test(html)){opts.closeButton=true;opts.className=((opts.className||'')+' tak-v322-object-popup').trim()}return old.call(this,content,opts)};L.Layer.prototype.__takV322BindPopup=true}catch(_){}}
