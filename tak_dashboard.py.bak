  function parseLatLon(form){try{const input=form.querySelector('[name="latlon"]');const v=input&&input.value||'';const m=String(v).match(/(-?\d+(?:\.\d+)?)\s*[, ]+\s*(-?\d+(?:\.\d+)?)/);if(m){const lat=form.querySelector('[name="lat"]'),lon=form.querySelector('[name="lon"]');if(lat)lat.value=m[1];if(lon)lon.value=m[2]}}catch(_){} }
  function applyImports(imports){if(!Array.isArray(imports))return;try{window.lastImports=imports}catch(_){}try{window.eval('lastImports=window.lastImports')}catch(_){}try{if(typeof renderImportRows==='function')renderImportRows()}catch(_){}try{if(typeof renderLocalDataRows==='function')renderLocalDataRows()}catch(_){}try{if(typeof drawImportedObjects==='function')drawImportedObjects()}catch(_){}try{if(typeof handleMapSearch==='function')handleMapSearch()}catch(_){} }
