  function milCat(i){const n=String(i?.name||'').toLowerCase();const parts=n.split('-');let cand=parts.slice(2).join('-');if(n.includes('equipment'))cand='equipment';else if(n.includes('installation'))cand='installation';else if(n.includes('unit'))cand='unit';const cats=['infantry','armor','artillery','air-defense','engineer','signal','support','headquarters','equipment','installation','unit','vehicle','aircraft','helicopter','vessel','drone','weapon','facility','site','infrastructure','emergency','sensor','general'];return cats.find(c=>n.includes(c))||cand||'general'}
