function terrainBillboardImage(o){try{const f=(typeof generatedMil2525File==='function')?generatedMil2525File(o||{}):'';return f?mil2525IconFilePath(f):null}catch(e){return null}}
function terrainPointEntity(lat,lon,label,color,o){try{if(!isFiniteLatLon(lat,lon)||!terrainPointVisible(lat,lon))return;const q=terrainQualitySettings(terrain3DQuality);const dist=terrainCameraDistanceTo(lat,lon);if(q.clusterMeters&&dist>q.clusterMeters&&q.deferWhileMoving){terrainQueueCluster(lat,lon,color,label);return}const img=terrainBillboardImage(o||{});const ent={position:Cesium.Cartesian3.fromDegrees(Number(lon),Number(lat)),billboard:img?{image:img,width:30,height:34,verticalOrigin:Cesium.VerticalOrigin.BOTTOM,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}:{image:undefined},point:img?undefined:{pixelSize:dist>q.labelMeters?5:8,color:cesiumColor(color||'#c7d1d7',dist>q.labelMeters?.58:.92),outlineColor:Cesium.Color.BLACK.withAlpha(.7),outlineWidth:1,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}};if(dist<=q.labelMeters&&terrainShouldShowLabel(lat,lon)){ent.label={text:String(label||''),font:'12px sans-serif',fillColor:Cesium.Color.WHITE.withAlpha(.86),outlineColor:Cesium.Color.BLACK.withAlpha(.72),outlineWidth:3,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-36),showBackground:true,backgroundColor:Cesium.Color.BLACK.withAlpha(.38),heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}}terrain3DViewer.entities.add(ent)}catch(e){}}
function terrainAdsbEntity(ac){try{if(!terrain3DViewer||!window.Cesium||!isFiniteLatLon(ac.lat,ac.lon))return;const alt=Number(ac.altitude_ft);const h=Number.isFinite(alt)?alt*0.3048:0;const label=ac.callsign||ac.id||'ADS-B';const military=aircraftIsMilitary(ac);const color=military?'#2386ff':'#8bd742';const deg=Number.isFinite(Number(ac.track_deg))?Number(ac.track_deg):0;terrain3DViewer.entities.add({name:String(label),position:Cesium.Cartesian3.fromDegrees(Number(ac.lon),Number(ac.lat),h),billboard:{image:aircraftBillboardDataUrl(military,aircraftIsHelicopter(ac),deg,color),width:36,height:44,verticalOrigin:Cesium.VerticalOrigin.CENTER,heightReference:Cesium.HeightReference.NONE,disableDepthTestDistance:Number.POSITIVE_INFINITY},label:{text:String(label),font:'12px sans-serif',fillColor:Cesium.Color.WHITE.withAlpha(.86),outlineColor:Cesium.Color.BLACK.withAlpha(.72),outlineWidth:3,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-30),showBackground:true,backgroundColor:Cesium.Color.BLACK.withAlpha(.32),disableDepthTestDistance:Number.POSITIVE_INFINITY}})}catch(e){}}
function aircraftBillboardDataUrl(military,heli,deg,color){try{const c=color||'#8bd742';const body=heli?'<path d="M5 14 H39" stroke="white" stroke-width="3.2" stroke-linecap="round"/><path d="M22 6 V28" stroke="white" stroke-width="2.6" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9" ry="5.3" fill="white"/><path d="M12 34 H32 M22 30 V37" stroke="white" stroke-width="2.3" stroke-linecap="round"/>':'<path d="M22 7 L25 21 L36 26 L25 28 L22 39 L19 28 L8 26 L19 21 Z" fill="white"/><path d="M22 29 L16 38 M22 29 L28 38" stroke="white" stroke-width="2.1" stroke-linecap="round"/>';const svg=`<svg xmlns="http://www.w3.org/2000/svg" width="44" height="54" viewBox="0 0 44 54"><circle cx="22" cy="22" r="16" fill="rgba(5,8,12,.84)" stroke="${c}" stroke-width="2.6"/><g transform="rotate(${deg} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="${c}"/>${body}</g></svg>`;return 'data:image/svg+xml;charset=utf-8,'+encodeURIComponent(svg)}catch(e){return ''}}
function terrainPolylineEntity(pts,label,color){try{pts=(pts||[]).filter(p=>p&&isFiniteLatLon(p[0],p[1]));if(pts.length<2)return;const cen=[pts.reduce((a,p)=>a+Number(p[0]),0)/pts.length,pts.reduce((a,p)=>a+Number(p[1]),0)/pts.length];if(!terrainPointVisible(cen[0],cen[1]))return;pts=terrainSimplifyCoordList(pts,false);const arr=[];pts.forEach(p=>{arr.push(Number(p[1]),Number(p[0]))});terrain3DViewer.entities.add({name:String(label||'Route'),polyline:{positions:Cesium.Cartesian3.fromDegreesArray(arr),width:terrainCameraDistanceTo(cen[0],cen[1])>terrainQualitySettings(terrain3DQuality).simplifyMeters?2:3,material:cesiumColor(color||'#c7d1d7',.86),clampToGround:true}})}catch(e){}}
function terrainPolygonEntity(pts,label,color){try{pts=collectCoordPairs(pts).filter(p=>p&&isFiniteLatLon(p[0],p[1]));if(pts.length<3)return;const cen=[pts.reduce((a,p)=>a+Number(p[0]),0)/pts.length,pts.reduce((a,p)=>a+Number(p[1]),0)/pts.length];if(!terrainPointVisible(cen[0],cen[1]))return;pts=terrainSimplifyCoordList(pts,true);const arr=[];pts.forEach(p=>{arr.push(Number(p[1]),Number(p[0]))});terrain3DViewer.entities.add({name:String(label||'Shape'),polygon:{hierarchy:Cesium.Cartesian3.fromDegreesArray(arr),material:cesiumColor(color||'#c7d1d7',.12),outline:true,outlineColor:cesiumColor(color||'#c7d1d7',.62),heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,perPositionHeight:false}})}catch(e){}}
function terrainAddObject(o,source){try{if(!o)return;const label=o.callsign||o.name||o.uid||o.id||source||'Object';const cat=dataSyncCategory(o);if(cat==='Routes'){terrainPolylineEntity(routeCoords(o),label,o.color||'#c7d1d7');return}if(cat==='Shapes / Areas'){terrainPolygonEntity(shapeCoords(o),label,'#c7d1d7');return}const cen=objectCenter(o);if(cen)terrainPointEntity(cen[0],cen[1],label,source==='tak'?'#c7d1d7':'#d0d9de',o)}catch(e){}}
function refreshTerrain3DObjects(force,reason){try{if(!terrain3DActive||!terrain3DViewer||!window.Cesium)return;const q=terrainQualitySettings(terrain3DQuality);if(terrain3DMoving&&q.deferWhileMoving){terrain3DDeferredRefresh=terrain3DDeferredRefresh||!!force;terrainStatus('3D Terrain moving · object refresh deferred');return}const now=Date.now();const hash=terrain3DDataHash()+':adsb:'+(lastAircraft||[]).length;if(!force&&hash===terrain3DLastObjectHash){terrainStatus('3D Terrain active · Quality '+q.label+' · '+terrain3DLastRenderableCount+' objects · no data changes');return}if(!force&&terrain3DLastObjectRefreshMs&&(now-terrain3DLastObjectRefreshMs)<10000){scheduleTerrain3DObjectsRefresh(10000-(now-terrain3DLastObjectRefreshMs),false);return}terrain3DLastObjectHash=hash;terrain3DLastObjectRefreshMs=now;terrain3DClusterBuckets={};terrain3DClusteredCount=0;terrain3DViewer.entities.removeAll();for(const m of (lastTakMarkers||[])){const kind=m.kind||'cot';if(kind==='eud'&&state.live.euds===false)continue;if(kind==='server_gps'&&state.live.server_gps===false)continue;if(kind!=='eud'&&kind!=='server_gps'&&state.live.cot_markers===false)continue;terrainAddObject(m,'tak')}if(state.dataSync){for(const o of ((lastDataSync||{}).objects||[]))terrainAddObject(o,'datasync')}if(state.imported){for(const f of (importedFeatures?importedFeatures():[])){const lid=String(f._local_id||f.id||f.uid||f.name||'');if(lid&&state.local.hidden[lid])continue;terrainAddObject(f,'local')}}if(state.live.adsb_aircraft!==false){for(const ac of (lastAircraft||[]))terrainAdsbEntity(ac)}terrainFlushClusters();terrain3DLastRenderableCount=terrain3DViewer.entities.values.length;const clustered=terrain3DClusteredCount?(' · '+terrain3DClusteredCount+' far points clustered'):'';terrainStatus('3D Terrain active · Esri World Elevation · Quality '+q.label+' · '+terrain3DLastRenderableCount+' visible objects'+clustered);terrainRequestRender()}catch(e){terrainStatus('3D object render failed: '+String(e.message||e),true)}}
function renderTopBanner(j){const e=document.getElementById('bannerEuds');const eudCount=j.euds_connected??0;if(e)e.textContent=String(eudCount)+' Connected';bannerDot('bannerEudsDot',Number(eudCount)>0?'good':'unknown');const ns=document.getElementById('bannerNonTak');const nsc=Number(j.non_tak_sensor??0);if(ns)ns.textContent=String(nsc);bannerDot('bannerNonTakDot',nsc>0?'warn':'unknown');const tak=String(j.tak_server||'Unknown');const t=document.getElementById('bannerTak');if(t)t.textContent=titleWords(tak);bannerDot('bannerTakDot',/online|up|running/i.test(tak)?'good':/check|unknown/i.test(tak)?'unknown':'bad');const internet=String(j.internet||'Unknown');const inet=document.getElementById('bannerInternet');if(inet)inet.textContent=titleWords(internet);bannerDot('bannerInternetDot',/connected|online|up/i.test(internet)?'good':/dns|limited|degraded/i.test(internet)?'warn':/unknown|check/i.test(internet)?'unknown':'bad');const a=document.getElementById('bannerAdsb');const aircraft=Number(j.adsb_aircraft??0);if(a)a.textContent=aircraft+' Aircraft';bannerDot('bannerAdsbDot',aircraft>0?'good':'unknown');const d=document.getElementById('bannerDownloads');if(d){const dl=j.downloads||{};d.textContent=Number(dl.active||0)?titleWords(dl.active+' Active'+(dl.eta?' · '+dl.eta:'')):'0 Active';bannerDot('bannerDownloadsDot',Number(dl.active||0)>0?'warn':'unknown')}updateOpenStatusDropdown()}
async function loadAdsbSettings(){try{const r=await fetch('/api/tak-map/adsb-settings',{cache:'no-store'});const j=await r.json();const s=j.settings||config?.adsb?.settings||{};window.lastAdsbSettings=s;if(config&&config.adsb)config.adsb.settings=s;const rm=document.getElementById('adsbRadiusMiles');if(rm)rm.value=Math.max(1,parseInt(s.radius_miles||5,10)||5);const ui=document.getElementById('adsbUpdateInterval');if(ui)ui.value=Math.max(1,parseInt(s.update_interval_seconds||5,10)||5);const cs=document.getElementById('adsbCenterSource');if(cs)cs.value=s.center_source||'manual';const la=document.getElementById('adsbCenterLat');if(la&&s.center_lat!=null)la.value=Number(s.center_lat).toFixed(6);const lo=document.getElementById('adsbCenterLon');if(lo&&s.center_lon!=null)lo.value=Number(s.center_lon).toFixed(6);scheduleAdsbRefreshTimer()}catch(e){}}
function useMapCenterForAdsb(){try{const c=map.getCenter();document.getElementById('adsbCenterLat').value=c.lat.toFixed(6);document.getElementById('adsbCenterLon').value=c.lng.toFixed(6);document.getElementById('adsbCenterSource').value='map_center'}catch(e){}}
async function saveAdsbSettings(applyToOts){const box=document.getElementById('adsbSettingsStatus');try{if(box)box.textContent='Saving ADS-B filter...';applyToOts=false;const payload={radius_miles:Math.max(1,parseInt(document.getElementById('adsbRadiusMiles')?.value||5,10)||5),update_interval_seconds:Math.max(1,parseInt(document.getElementById('adsbUpdateInterval')?.value||5,10)||5),center_source:document.getElementById('adsbCenterSource')?.value||'manual',center_lat:Number(document.getElementById('adsbCenterLat')?.value),center_lon:Number(document.getElementById('adsbCenterLon')?.value),apply_to_ots:false};const r=await fetch('/api/tak-map/adsb-settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),cache:'no-store'});const j=await apiJsonResponse(r);window.lastAdsbSettings=j.settings||payload;if(config&&config.adsb)config.adsb.settings=window.lastAdsbSettings;scheduleAdsbRefreshTimer();if(box)box.textContent='ADS-B filter saved.';if(state.live.adsb_aircraft)refreshAdsb();updateTopBanner()}catch(e){if(box)box.textContent='ADS-B settings failed: '+String(e)}}
try{const _oldInit=init;init=async function(){await _oldInit();try{loadAdsbSettings()}catch(e){}}}catch(_){ }
