  function tileBounds(t){try{let lat0=Number(t.lat0),lon0=Number(t.lon0);let lat1=Number(t.lat1),lon1=Number(t.lon1);if(!Number.isFinite(lat0)||!Number.isFinite(lon0))return null;if(!Number.isFinite(lat1))lat1=lat0+1;if(!Number.isFinite(lon1))lon1=lon0+1;const south=Math.max(-90,Math.min(lat0,lat1)),north=Math.min(90,Math.max(lat0,lat1));let west=Math.min(lon0,lon1),east=Math.max(lon0,lon1);west=Math.max(-180,Math.min(180,west));east=Math.max(-180,Math.min(180,east));if(!(north>south)||!(east>west))return null;return {south,north,west,east}}catch(_){return null}}
  async function ensureLocalTiles(){try{if(typeof window.loadLocalElevationTiles==='function')await window.loadLocalElevationTiles()}catch(e){console.warn('v294 local tile load failed',e)}return uniqueTiles()}
