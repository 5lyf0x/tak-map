# --- v304 stabilization/controllers: direct-source ADS-B renderer/track cleanup, no stacked legacy track handlers ---
def _v304_remove_script_block(_html, _script_id):
    import re as _re
    return _re.sub(r'<script\b(?=[^>]*\bid=["\']' + _re.escape(_script_id) + r'["\'])(?:(?!</script>).)*</script>', '', _html, flags=_re.I|_re.S)

def _v304_set_versions(_html):
    import re as _re
    _html = _html.replace('TAK Server Dashboard', 'TAK Map')
    _html = _re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v304', _html)
    _html = _re.sub(r'TAK-Map/1\.1\.0\s+v\d+', 'TAK-Map/1.1.0 v304', _html)
    _html = _re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v304</span>', _html)
    _html = _re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v304</div>', _html)
    _html = _re.sub(r'const\s+V\s*=\s*["\']v\d+["\']', "const V='v304'", _html)
    _html = _re.sub(r'>v\d+<', '>v304<', _html)
    return _html

def _v304_rewrite_legacy_adsb_sources(_html):
    import re as _re
    _proxy_draw = """function drawAircraft(list){
    if(!adsbEnabled)return;
    let shown=[];
    try{if(adsbLayer&&adsbLayer.clearLayers)adsbLayer.clearLayers(); if(markers&&markers.clear)markers.clear()}catch(_){}
    try{shown=filtered(list||[])}catch(_){shown=list||[]}
    try{window.lastAircraft=shown}catch(_){}
    try{if(window.TakMapControllers&&window.TakMapControllers.adsb&&typeof window.TakMapControllers.adsb.renderAircraft==='function')window.TakMapControllers.adsb.renderAircraft(shown);else if(typeof window.drawAircraft==='function')window.drawAircraft(shown)}catch(e){try{console.warn('v304 ADS-B proxy render failed',e)}catch(_){}}
    try{if($('adsbStatus'))$('adsbStatus').textContent=shown.length+' active'; if($('bannerAdsb'))$('bannerAdsb').textContent=shown.length+' Aircraft'}catch(_){}
  }
  """
    _html = _re.sub(r'function drawAircraft\(list\)\{if\(!adsbEnabled\)return;const layer=ensureLayer\(\);(?:(?!\n\s*function bindMap\(\)).)*?\}\s*(?=\n\s*function bindMap\(\))', _proxy_draw, _html, count=1, flags=_re.S)
    _html = _re.sub(r'function updateTrackFromStable\(\)\{(?:(?!\n\s*function syncTrackButtons\(\)).)*?\}\s*(?=\n\s*function syncTrackButtons\(\))',
                    "function updateTrackFromStable(){try{if(window.TakMapControllers&&window.TakMapControllers.adsb&&window.TakMapControllers.adsb.track)window.TakMapControllers.adsb.track.update()}catch(_){}}\n  ", _html, count=2, flags=_re.S)
    _html = _re.sub(r'function syncTrackButtons\(\)\{(?:(?!\n\s*window\.v303LegacyToggleAdsbTrackDisabled)).*?\}\s*(?=\n\s*window\.v303LegacyToggleAdsbTrackDisabled)',
                    "function syncTrackButtons(){try{if(window.TakMapControllers&&window.TakMapControllers.adsb&&window.TakMapControllers.adsb.track)window.TakMapControllers.adsb.track.syncButtons()}catch(_){}}\n  ", _html, count=2, flags=_re.S)
    _html = _re.sub(r'function patchPopupElement\(el\)\{(?:(?!\n\s*function patchOpenPopups\(\)).)*?\}\s*(?=\n\s*function patchOpenPopups\(\))',
                    "function patchPopupElement(el){try{if(window.TakMapControllers&&window.TakMapControllers.adsb&&window.TakMapControllers.adsb.track)window.TakMapControllers.adsb.track.patchPopups()}catch(_){}}\n  ", _html, count=2, flags=_re.S)
    return _html

try:
    for _sid in ('v303StabilizedModuleControllers','v304StabilizedModuleControllers'):
        TAK_MAP_HTML = _v304_remove_script_block(TAK_MAP_HTML, _sid)
    TAK_MAP_HTML = _v304_rewrite_legacy_adsb_sources(TAK_MAP_HTML)
    _v304_controller = '<script id="v304StabilizedModuleControllers">\n(function(){\n  \'use strict\';\n  const V=\'v304\';\n  const CTL=window.TakMapControllers=window.TakMapControllers||{};\n  const ADSB=CTL.adsb=CTL.adsb||{};\n  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}\n  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}\n  function byId(id){try{return document.getElementById(id)}catch(_){return null}}\n  function esc(s){return String(s==null?\'\':s).replace(/[&<>"\']/g,function(c){return {\'&\':\'&amp;\',\'<\':\'&lt;\',\'>\':\'&gt;\',\'"\':\'&quot;\',"\'":\'&#39;\'}[c]})}\n  function num(v){v=Number(v);return Number.isFinite(v)?v:null}\n  function leafletMap(){try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(typeof map!==\'undefined\'&&map&&map.addLayer){window.takLeafletMap=map;return map}}catch(_){}try{if(window.map&&window.map.addLayer)return window.map}catch(_){}return null}\n  function version(){try{qa(\'.iteration-chip,.iteration-marker\').forEach(function(el){el.textContent=V});qa(\'.version-product,.sidebar-version-title\').forEach(function(el){if(/dashboard/i.test(el.textContent||\'\'))el.textContent=\'TAK Map\'});document.documentElement.dataset.takMapIteration=V}catch(_){}}\n  function distMeters(pts){let d=0;try{for(let i=1;i<(pts||[]).length;i++){const a=pts[i-1],b=pts[i];if(window.L&&L.latLng)d+=L.latLng(a.lat,a.lon).distanceTo(L.latLng(b.lat,b.lon));else{const R=6371000,rad=Math.PI/180,p1=a.lat*rad,p2=b.lat*rad,dp=(b.lat-a.lat)*rad,dl=(b.lon-a.lon)*rad,h=Math.sin(dp/2)**2+Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;d+=2*R*Math.atan2(Math.sqrt(h),Math.sqrt(1-h))}}}catch(_){}return d}\n  function distText(m){return (m/1609.344).toFixed(1)+\'mi/\'+(m/1000).toFixed(1)+\'km\'}\n  function rawId(a){return (a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.r||a.callsign||a.flight))||\'\'}\n  function idOf(a){return String(rawId(a)).trim().toLowerCase()}\n  function titleOf(a){return String((a&&(a.callsign||a.flight||a.registration||a.r||a.hex||a.icao||a.id))||\'ADS-B\').trim()||\'ADS-B\'}\n  function normalize(a){a=Object.assign({},a||{});a.lat=num(a.lat);a.lon=num(a.lon);if(!a.id&&rawId(a))a.id=rawId(a);return a}\n  function arrays(input){const out=[];function add(x){if(Array.isArray(x))out.push.apply(out,x)}add(input);add(window.lastAircraft);add(window.v298StableAdsb);add(window._v296StableAdsb);add(window._v294StableAdsb);return out}\n  function aircraftList(input){const by=new Map();arrays(input).forEach(function(x){const a=normalize(x);const id=idOf(a);if(id&&a.lat!=null&&a.lon!=null)by.set(id,Object.assign(by.get(id)||{},a))});return Array.from(by.values())}\n  const classById=ADSB.classById instanceof Map?ADSB.classById:new Map();\n  const shapeById=ADSB.shapeById instanceof Map?ADSB.shapeById:new Map();\n  function detectedClass(a){const blob=String(Object.values(a||{}).join(\' \'));const cat=String((a&&(a.category||a.category_class||a.aircraft_class||a.classification||a.owner_category||a.affiliation))||\'\').toLowerCase();if(a&&a.is_military)return \'mil\';if(/\\b(military|usaf|usn|usmc|army|navy|air force|coast guard|rch|mil-?|a-f-a)\\b/i.test(blob)||/mil/.test(cat))return \'mil\';if(a&&a.is_govt)return \'gov\';if(/\\b(law enforcement|police|sheriff|state police|highway patrol|fire dept|fire department|public safety|ems|rescue|chp|cal fire|calfire|usfs|forest service|medical|hospital|response|fema|dhs|cbp|customs|border patrol|nasa|noaa|nps|park service)\\b/i.test(blob)||/gov/.test(cat)||/govt/.test(cat))return \'gov\';if(/unknown|unk/.test(cat))return \'unk\';return \'civ\'}\n  function classKey(a){const id=idOf(a);const now=detectedClass(a);const prev=id?classById.get(id):null;let next=prev||now;if(now===\'mil\')next=\'mil\';else if(prev===\'mil\')next=\'mil\';else if(now===\'gov\')next=\'gov\';else if(prev===\'gov\')next=\'gov\';else if(now===\'unk\'&&prev)next=prev;else if(!prev)next=now||\'civ\';if(id)classById.set(id,next);return next||\'civ\'}\n  function rotorEvidence(a){const vals=[a&&a.is_helo,a&&a.is_rotor,a&&a.rotorcraft,a&&a.type,a&&a.aircraft_type,a&&a.description,a&&a.emitter_category,a&&a.category,a&&a.t,a&&a.model,a&&a.aircraft_model].filter(Boolean).join(\' \');return /\\b(helicopter|heli|helo|rotor|rotorcraft|rotary|gyro|h60|uh-?60|mh-?60|hh-?60|ch-?47|ah-?64|bell|b206|b407|b412|b429|ec-?135|ec-?145|h135|h145|as350|aw139|r22|r44|r66|s76|s92)\\b/i.test(vals)}\n  function fixedEvidence(a){const vals=[a&&a.type,a&&a.aircraft_type,a&&a.description,a&&a.emitter_category,a&&a.category,a&&a.t].filter(Boolean).join(\' \');return /\\b(fixed[- ]?wing|airplane|aeroplane|jet|turboprop|glider|ultralight)\\b/i.test(vals)}\n  function shapeKey(a){const id=idOf(a);let prev=id?shapeById.get(id):null;if(rotorEvidence(a))prev=\'helo\';else if(prev===\'helo\')prev=\'helo\';else if(!prev)prev=fixedEvidence(a)?\'fixed\':\'fixed\';if(id)shapeById.set(id,prev);return prev||\'fixed\'}\n  function iconPath(a){const c=classKey(a),s=shapeKey(a);return \'/assets/adsb/adsb_\'+(c===\'mil\'?\'mil\':c===\'gov\'?\'gov\':c===\'unk\'?\'unk\':\'civ\')+\'_\'+(s===\'helo\'?\'helo\':\'fixed\')+\'.png\'}\n  function altText(a){let v=a&&(a.altitude_ft??a.alt_baro??a.alt_geom??a.alt);if(String(v).toLowerCase()===\'ground\')return \'Ground\';v=num(v);return v==null?\'—\':Math.round(v).toLocaleString()+\' ft\'}\n  function spdText(a){let v=a&&(a.speed_kt??a.groundspeed_kt??a.gs??a.ground_speed??a.speed);v=num(v);return v==null?\'—\':Math.round(v)+\' kt\'}\n  function popupHtml(a){const id=esc(idOf(a));return \'<div class="adsb-popup"><h3>\'+esc(titleOf(a))+\'</h3><div class="popup-grid"><div>Class</div><div>\'+esc(classKey(a)===\'mil\'?\'Military\':classKey(a)===\'gov\'?\'Govt\':classKey(a)===\'unk\'?\'Unknown\':\'Civil\')+\'</div><div>Type</div><div>\'+esc(shapeKey(a)===\'helo\'?\'Helicopter\':\'Airplane\')+\'</div><div>Alt</div><div>\'+esc(altText(a))+\'</div><div>Speed</div><div>\'+esc(spdText(a))+\'</div></div><div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn" data-adsb-track-id="\'+id+\'" aria-pressed="false"><span class="adsb-track-light"></span><span>Track</span></button></div></div>\'}\n  function iconFor(a){if(!window.L)return null;return L.divIcon({className:\'adsb-marker-hitbox\',iconSize:[46,46],iconAnchor:[23,23],popupAnchor:[0,-20],html:\'<div class="adsb-hitbox"><img draggable="false" src="\'+esc(iconPath(a))+\'" alt=""/></div>\'})}\n  ADSB.markers=ADSB.markers instanceof Map?ADSB.markers:new Map();ADSB.data=ADSB.data instanceof Map?ADSB.data:new Map();ADSB.tracking=ADSB.tracking||{id:null,meta:null,points:[],layer:null,label:null};ADSB.classById=classById;ADSB.shapeById=shapeById;\n  function ensureLayer(){const m=leafletMap();if(!m||!window.L)return null;if(!ADSB.layer){ADSB.layer=L.layerGroup().addTo(m)}else if(!m.hasLayer(ADSB.layer))ADSB.layer.addTo(m);return ADSB.layer}\n  function markerGlobals(){try{const o={};ADSB.markers.forEach(function(v,k){o[k]=v});window.v304AircraftLayersById=o;window.v303AircraftLayersById=o;window.v298AircraftLayersById=o;window.v240AircraftLayersById=o;window.v238AircraftLayersById=o;window.v236AircraftLayersById=o}catch(_){}}\n  function clearLegacyAircraftLayer(){try{if(typeof aircraftLayer!==\'undefined\'&&aircraftLayer&&aircraftLayer.clearLayers)aircraftLayer.clearLayers()}catch(_){}}\n  function renderAircraft(input){clearLegacyAircraftLayer();const rows=aircraftList(input);const layer=ensureLayer();if(!layer)return rows;const seen=new Set();rows.forEach(function(a){const id=idOf(a);seen.add(id);ADSB.data.set(id,a);let mk=ADSB.markers.get(id);const ll=[a.lat,a.lon];if(!mk){mk=L.marker(ll,{icon:iconFor(a),zIndexOffset:900,interactive:true,riseOnHover:true}).addTo(layer);ADSB.markers.set(id,mk)}else{try{mk.setLatLng(ll);mk.setIcon(iconFor(a))}catch(_){}}try{mk._takAdsbAircraft=a;mk._takAdsbId=id;mk.bindPopup(popupHtml(a),{autoPan:true,maxWidth:330,className:\'tak-object-popup adsb-object-popup\'});if(!mk._takAdsbClick){mk._takAdsbClick=true;mk.on(\'popupopen\',function(){setTimeout(patchPopups,0)});mk.on(\'click\',function(){setTimeout(patchPopups,0)})}}catch(_){} });Array.from(ADSB.markers.keys()).forEach(function(id){if(!seen.has(id)){try{layer.removeLayer(ADSB.markers.get(id))}catch(_){}ADSB.markers.delete(id);ADSB.data.delete(id)}});markerGlobals();syncButtons();updateTrack(rows);return rows}\n  function findAircraft(id){id=String(id||\'\').toLowerCase();return ADSB.data.get(id)||aircraftList().find(function(a){return idOf(a)===id})||null}\n  function ensureTrackLayer(){const m=leafletMap();if(!m||!window.L)return false;const t=ADSB.tracking;if(!t.layer){t.layer=L.polyline([],{color:\'#ff4b2b\',weight:4,opacity:.95,interactive:false}).addTo(m)}if(!t.label){t.label=L.marker([0,0],{interactive:false,icon:L.divIcon({className:\'adsb-track-distance-label\',html:\'0.0mi/0.0km\',iconSize:null,iconAnchor:[-10,10]})}).addTo(m)}return true}\n  function drawTrack(){const t=ADSB.tracking;if(!t.id||!ensureTrackLayer())return;const pts=t.points.map(function(p){return [p.lat,p.lon]});try{t.layer.setLatLngs(pts);if(pts.length){const txt=distText(distMeters(t.points));t.label.setLatLng(pts[pts.length-1]);t.label.setIcon(L.divIcon({className:\'adsb-track-distance-label\',html:txt,iconSize:null,iconAnchor:[-10,10]}))}}catch(e){try{console.warn(\'v304 draw track failed\',e)}catch(_){}}}\n  function addPoint(a){const t=ADSB.tracking;if(!t.id||!a||a.lat==null||a.lon==null)return;const last=t.points[t.points.length-1];if(last&&Math.abs(last.lat-a.lat)<1e-7&&Math.abs(last.lon-a.lon)<1e-7){drawTrack();return}t.points.push({lat:a.lat,lon:a.lon,alt:num(a.altitude_ft??a.alt_baro??a.alt_geom??a.alt)||0,t:Date.now()});if(t.points.length>900)t.points=t.points.slice(-900);drawTrack()}\n  function updateTrack(rows){const t=ADSB.tracking;if(!t.id)return;const a=(rows||aircraftList()).find(function