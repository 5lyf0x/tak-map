import http.cookiejar as _v269_cookiejar
import urllib.request as _v269_urllib_request


def _v269_clamp_interval_seconds(value, default=30):
    try:
        n=int(round(float(value)))
    except Exception:
        try:
            n=int(default)
        except Exception:
            n=30
    return max(1, min(86400, n))


def _v269_scheduler_api_base_from_login_url(login_url):
    url=str(login_url or '').strip().rstrip('/')
    if not url:
        return ''
    if url.endswith('/login'):
        return url[:-len('/login')]
    return url.rsplit('/', 1)[0]


def _v269_ots_api_login(username, password, timeout=8):
    username=str(username or '').strip()
    password=str(password or '')
    if not username or not password:
        return {'ok':False,'error':'No active OTS admin credentials available.'}
    errors=[]
    for login_url in _candidate_ots_api_login_urls():
        for as_json in (True, False):
            cookiejar=_v269_cookiejar.CookieJar()
            opener=_v269_urllib_request.build_opener(_v269_urllib_request.HTTPCookieProcessor(cookiejar))
            headers={'Accept':'application/json','User-Agent':'tak-map/1.1.0 v269'}
            if as_json:
                body=json.dumps({'username':username,'password':password}).encode('utf-8')
                headers['Content-Type']='application/json'
            else:
                body=urlencode({'username':username,'password':password}).encode('utf-8')
                headers['Content-Type']='application/x-www-form-urlencoded'
            try:
                req=Request(login_url, data=body, headers=headers, method='POST')
                with opener.open(req, timeout=timeout) as resp:
                    status=getattr(resp,'status',200)
                    raw=resp.read().decode('utf-8','replace')
                if status < 200 or status >= 300:
                    errors.append(f'{login_url} returned HTTP {status}')
                    continue
                try:
                    data=json.loads(raw or '{}')
                except Exception:
                    data={}
                csrf=''
                if isinstance(data,dict):
                    for obj in (data, data.get('response') if isinstance(data.get('response'),dict) else {}, data.get('meta') if isinstance(data.get('meta'),dict) else {}):
                        for key in ('csrf_token','csrf','csrfToken','token'):
                            if isinstance(obj,dict) and obj.get(key):
                                csrf=str(obj.get(key)); break
                        if csrf: break
                if not list(cookiejar) and not csrf:
                    meta=data.get('meta') if isinstance(data,dict) else None
                    code=meta.get('code') if isinstance(meta,dict) else status
                    if str(code) != '200':
                        errors.append(f'{login_url} login response did not include a usable session cookie/token')
                        continue
                return {'ok':True,'opener':opener,'csrf':csrf,'login_url':login_url,'api_base':_v269_scheduler_api_base_from_login_url(login_url)}
            except HTTPError as e:
                try:
                    raw=e.read().decode('utf-8','replace')
                except Exception:
                    raw=''
                errors.append(f'{login_url} HTTP {getattr(e,"code","")}: '+raw[:120].replace('\n',' '))
            except Exception as e:
                errors.append(f'{login_url} failed: {e}')
    return {'ok':False,'error':'OTS API login failed. '+ ' | '.join(errors[:4])}


def _v269_ots_api_request(session, path, method='GET', payload=None, timeout=12):
    if not session or not session.get('ok'):
        return {'ok':False,'error':'No authenticated OTS API session.'}
    base=str(session.get('api_base') or '').rstrip('/')
    url=base + '/' + str(path or '').lstrip('/')
    headers={'Accept':'application/json','User-Agent':'tak-map/1.1.0 v269'}
    data_bytes=None
    if payload is not None:
        data_bytes=json.dumps(payload).encode('utf-8')
        headers['Content-Type']='application/json'
        headers['Content-Length']=str(len(data_bytes))
    csrf=str(session.get('csrf') or '')
    if csrf:
        headers['X-CSRFToken']=csrf
        headers['X-CSRF-Token']=csrf
    try:
        req=Request(url, data=data_bytes, headers=headers, method=method)
        with session['opener'].open(req, timeout=timeout) as resp:
            status=getattr(resp,'status',200)
            raw=resp.read().decode('utf-8','replace')
        try:
            body=json.loads(raw or '{}')
        except Exception:
            body={'raw':raw}
        if status < 200 or status >= 300:
            return {'ok':False,'status':status,'url':url,'body':body,'error':f'OTS API returned HTTP {status}'}
        return {'ok':True,'status':status,'url':url,'body':body}
    except HTTPError as e:
        try:
            raw=e.read().decode('utf-8','replace')
            body=json.loads(raw or '{}')
        except Exception:
            body={'raw':raw if 'raw' in locals() else ''}
        return {'ok':False,'status':getattr(e,'code',0),'url':url,'body':body,'error':f'OTS API HTTP {getattr(e,"code","")}: '+str(body)[:300]}
    except Exception as e:
        return {'ok':False,'url':url,'error':str(e)}


def _v269_extract_scheduler_jobs(obj):
    jobs=[]; seen=set()
    def add_job(x):
        if isinstance(x,dict):
            key=str(x.get('id') or x.get('job_id') or x.get('name') or x.get('func') or json.dumps(x, sort_keys=True)[:300])
            if key not in seen:
                seen.add(key); jobs.append(x)
    def walk(x, depth=0):
        if depth > 5:
            return
        if isinstance(x,list):
            for item in x:
                if isinstance(item,dict):
                    blob=' '.join(str(k) for k in item.keys()).lower()
                    if any(k in item for k in ('id','job_id','name','func','trigger','next_run_time')) or 'job' in blob:
                        add_job(item)
                    walk(item, depth+1)
                else:
                    walk(item, depth+1)
        elif isinstance(x,dict):
            for key in ('jobs','response','data','result','items'):
                if key in x:
                    walk(x.get(key), depth+1)
    walk(obj)
    return jobs


def _v269_find_adsb_scheduler_job(jobs):
    best=None; best_score=-1
    for job in jobs or []:
        try:
            blob=json.dumps(job, default=str).lower()
        except Exception:
            blob=str(job).lower()
        score=0
        if 'airplanes.live' in blob or 'airplanes_live' in blob or 'airplanes live' in blob: score+=100
        if 'ads-b' in blob or 'adsb' in blob: score+=80
        if 'aircraft' in blob: score+=20
        if 'airplanes' in blob: score+=40
        if score>best_score:
            best_score=score; best=job
    if best is not None and best_score>=40:
        return best
    return None


def _v269_job_id(job):
    if not isinstance(job,dict):
        return ''
    for key in ('id','job_id','name'):
        if job.get(key) not in (None,''):
            return str(job.get(key))
    return ''


def _v269_wait_for_ots_scheduler_login(username, password, timeout_seconds=75):
    deadline=time.time()+max(5,int(timeout_seconds or 75))
    last=None
    while time.time() < deadline:
        last=_v269_ots_api_login(username,password,timeout=6)
        if last.get('ok'):
            return last
        time.sleep(2)
    return last or {'ok':False,'error':'Timed out waiting for OTS API login.'}


def _v269_login_ots_api(session=None, timeout_seconds=60):
    username=''; password=''
    if isinstance(session,dict):
        username=str(session.get('username') or '').strip()
        password=str(session.get('password') or '')
    username=username or os.environ.get('TAK_DASH_OTS_API_USERNAME','').strip() or os.environ.get('OTS_USERNAME','').strip()
    password=password or os.environ.get('TAK_DASH_OTS_API_PASSWORD','') or os.environ.get('OTS_PASSWORD','')
    if not username or not password:
        return {'ok':False,'error':'No active OTS admin credentials. Re-login to TAK Map or set TAK_DASH_OTS_API_USERNAME/PASSWORD.'}
    return _v269_wait_for_ots_scheduler_login(username,password,timeout_seconds=timeout_seconds)


def _v269_list_scheduler_jobs(api):
    resp=_v269_ots_api_request(api,'/scheduler/jobs',method='GET',timeout=15)
    if not resp.get('ok'):
        return None, resp
    return _v269_extract_scheduler_jobs(resp.get('body')), resp


def _v269_scheduler_interval_payload(job_id, interval):
    interval=_v269_clamp_interval_seconds(interval,30)
    minutes=interval//60
    seconds=interval%60
    payload={'job_id':job_id,'trigger':'interval'}
    if minutes:
        payload['minutes']=minutes
    if seconds:
        payload['seconds']=seconds
    if not minutes and not seconds:
        payload['seconds']=1
    return payload, minutes, seconds


def _v269_scheduler_interval_update(settings, session=None, run_now=True):
    result={'attempted':True,'ok':False,'modified':False,'ran_now':False,'message':'Scheduler interval was not changed.','job_id':'','interval_seconds':None,'errors':[]}
    try:
        interval=_v269_clamp_interval_seconds((settings or {}).get('update_interval_seconds') or (settings or {}).get('update_interval') or 30, 30)
        result['interval_seconds']=interval
        api=_v269_login_ots_api(session, timeout_seconds=45)
        if not api.get('ok'):
            result['message']='Scheduler update failed: '+str(api.get('error') or 'OTS API login failed.')[:500]
            result['errors'].append(result['message'])
            return result
        jobs, resp=_v269_list_scheduler_jobs(api)
        if jobs is None:
            result['message']='Scheduler update failed: could not list jobs.'
            result['errors'].append(str(resp.get('error') or resp)[:500])
            return result
        job=_v269_find_adsb_scheduler_job(jobs)
        if not job:
            result['message']='Scheduler update failed: ADS-B job not found.'
            result['jobs_seen']=len(jobs)
            return result
        jid=_v269_job_id(job)
        result['job_id']=jid
        if not jid:
            result['message']='Scheduler update failed: ADS-B job has no id/name.'
            return result
        payload, minutes, seconds=_v269_scheduler_interval_payload(jid, interval)
        for path in ('/scheduler/job/modify','/scheduler/job/update','/scheduler/job/reschedule'):
            mod=_v269_ots_api_request(api,path,method='POST',payload=payload,timeout=20)
            result.setdefault('attempts',[]).append({'path':path,'ok':bool(mod.get('ok')),'status':mod.get('status'),'error':str(mod.get('error') or '')[:250]})
            if mod.get('ok'):
                result['modified']=True
                break
        if not result.get('modified'):
            result['message']='Scheduler update failed: modify request failed.'
            return result
        if run_now:
            for path in ('/scheduler/job/run','/scheduler/job/run-now','/scheduler/job/execute'):
                run=_v269_ots_api_request(api,path,method='POST',payload={'job_id':jid},timeout=25)
                result.setdefault('run_attempts',[]).append({'path':path,'ok':bool(run.get('ok')),'status':run.get('status'),'error':str(run.get('error') or '')[:250]})
                if run.get('ok'):
                    result['ran_now']=True
                    break
        result['ok']=bool(result.get('modified'))
        label=(f'{minutes}m {seconds}s' if minutes else f'{seconds}s')
        result['message']='Interval set to '+label+('. Job run now.' if result.get('ran_now') else '. Run now not confirmed.')
        return result
    except Exception as e:
        result['message']='Scheduler update failed: '+str(e)
        result['errors'].append(traceback.format_exc()[-1200:])
        return result


def _v269_apply_adsb_settings_to_ots_config(settings):
    res={'attempted':True,'ok':False,'config_path':'','backup_path':'','restarted':False,'message':''}
    cfg=_find_ots_config_file()
    if not cfg:
        res['message']='OTS config.yml not found.'
        return res
    res['config_path']=str(cfg)
    helper=Path('/usr/local/sbin/tak-map-action')
    lat=settings.get('center_lat'); lon=settings.get('center_lon'); radius=settings.get('radius_miles')
    if lat is None or lon is None:
        res['message']='Valid ADS-B center required.'
        return res
    if helper.exists():
        args=['sudo','-n',str(helper),'adsb-update-ots-config',str(cfg),str(lat),str(lon),str(radius or '')]
        r=run_cmd(args,90)
        out=(str(r.get('stdout') or '')+'\n'+str(r.get('stderr') or '')).strip()
        for line in str(r.get('stdout') or '').splitlines():
            if line.startswith('BACKUP_PATH='):
                res['backup_path']=line.split('=',1)[1].strip()
        res['restarted']=bool(r.get('ok'))
        res['ok']=bool(r.get('ok'))
        res['message']='config.yml updated; backup made; OTS restarted.' if r.get('ok') else ('config.yml update failed: '+out[:500])
        return res
    try:
        raw=cfg.read_text()
        backups=CONFIG_BACKUP_DIR/'opentakserver'
        backups.mkdir(parents=True, exist_ok=True)
        stamp=datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')
        backup=backups/(cfg.name+'.adsb-'+stamp+'.bak')
        shutil.copy2(cfg, backup)
        res['backup_path']=str(backup)
        def update_yaml_scalar(text, key, value):
            value=str(value)
            pat=re.compile(r'^(\s*'+re.escape(key)+r'\s*:\s*)([^#\r\n]*)(\s*(?:#.*)?)$', re.M)
            if pat.search(text):
                return pat.sub(lambda m: m.group(1)+value+(m.group(3) or ''), text, count=1)
            if text and not text.endswith('\n'):
                text+='\n'
            return text+f'{key}: {value}\n'
        rendered=update_yaml_scalar(raw,'OTS_ADSB_LAT',f'{float(lat):.6f}')
        rendered=update_yaml_scalar(rendered,'OTS_ADSB_LON',f'{float(lon):.6f}')
        rendered=update_yaml_scalar(rendered,'OTS_ADSB_RADIUS',str(int(round(float(radius or 5)))))
        tmp=cfg.with_name(cfg.name+f'.takmap-{os.getpid()}.tmp')
        tmp.write_text(rendered)
        shutil.copystat(cfg, tmp, follow_symlinks=True)
        os.replace(tmp, cfg)
        r=run_cmd(['sudo','-n','systemctl','restart','opentakserver'],60)
        res['restarted']=bool(r.get('ok'))
        res['ok']=bool(r.get('ok'))
        res['message']='config.yml updated; backup made; OTS restarted.' if r.get('ok') else ('config.yml updated; backup made; OTS restart failed: '+str(r.get('stderr') or r.get('stdout') or r.get('rc'))[:500])
        return res
    except Exception as e:
        res['message']='config.yml update failed: '+str(e)
        return res

_apply_adsb_settings_to_ots_config = _v269_apply_adsb_settings_to_ots_config

_v269_prev_save_adsb_settings = _save_adsb_settings

def _save_adsb_settings(payload, session=None, *args, **kwargs):
    payload=payload or {}
    try:
        result=_v269_prev_save_adsb_settings(payload, session=session)
    except TypeError as e:
        msg=str(e)
        if 'positional argument' in msg or 'unexpected keyword argument' in msg:
            result=_v269_prev_save_adsb_settings(payload)
        else:
            raise
    try:
        settings=dict(result.get('settings') or _load_adsb_settings()) if isinstance(result,dict) else _load_adsb_settings()
        if payload.get('interval_only') or payload.get('save_interval'):
            result.setdefault('interval', _v269_scheduler_interval_update(settings, session=session, run_now=True))
        elif payload.get('apply_to_ots'):
            result.setdefault('interval', _v269_scheduler_interval_update(settings, session=session, run_now=True))
            ots=result.get('ots') if isinstance(result.get('ots'),dict) else {}
            if ots.get('backup_path'):
                msg=str(ots.get('message') or '')
                if 'backup' not in msg.lower():
                    ots['message']=(msg+' ' if msg else '')+'config.yml backup made.'
                result['ots']=ots
    except Exception as e:
        if isinstance(result,dict):
            result.setdefault('interval', {'attempted':True,'ok':False,'message':'Scheduler update failed: '+str(e)})
    return result


def _v269_adsb_ots_job_control(action, session=None):
    action=str(action or '').strip().lower()
    if action not in ('disable','enable'):
        return {'ok':False,'error':'Invalid ADS-B OTS job action.'}
    out={'ok':False,'action':action,'attempted':True,'job_id':'','message':'','attempts':[]}
    try:
        api=_v269_login_ots_api(session, timeout_seconds=25)
        if not api.get('ok'):
            out['message']='OTS Job update failed: '+str(api.get('error') or 'OTS API login failed.')[:400]
            return out
        jobs, resp=_v269_list_scheduler_jobs(api)
        if jobs is None:
            out['message']='OTS Job update failed: could not list scheduler jobs.'
            out['attempts'].append({'step':'list_jobs','ok':False,'error':str(resp.get('error') or resp)[:500]})
            return out
        job=_v269_find_adsb_scheduler_job(jobs)
        if not job:
            out['message']='OTS Job update failed: ADS-B scheduler job not found.'
            out['jobs_seen']=len(jobs)
            return out
        jid=_v269_job_id(job)
        out['job_id']=jid
        if not jid:
            out['message']='OTS Job update failed: ADS-B job has no id/name.'
            return out
        attempts = [('/scheduler/job/disable', {'job_id':jid}),('/scheduler/job/pause', {'job_id':jid}),('/scheduler/job/modify', {'job_id':jid,'enabled':False,'active':False,'disabled':True})] if action=='disable' else [('/scheduler/job/enable', {'job_id':jid}),('/scheduler/job/resume', {'job_id':jid}),('/scheduler/job/modify', {'job_id':jid,'enabled':True,'active':True,'disabled':False})]
        for path,payload2 in attempts:
            r=_v269_ots_api_request(api,path,method='POST',payload=payload2,timeout=18)
            out['attempts'].append({'path':path,'ok':bool(r.get('ok')),'status':r.get('status'),'error':str(r.get('error') or '')[:300]})
            if r.get('ok'):
                out['ok']=True
                out['message']='OTS Job '+('disabled.' if action=='disable' else 'enabled.')
                return out
        out['message']='OTS Job update not confirmed.'
        return out
    except Exception as e:
        out['message']='OTS Job update failed: '+str(e)
        out['traceback']=traceback.format_exc()[-1200:]
        return out

_v266_adsb_ots_job_control = _v269_adsb_ots_job_control

_v269_js = r'''

/* v269 ADS-B scheduler/status, Terrain incline slider, Viewshed toolbar restore */
(function(){
  const V='v301';
  function field(id){return document.getElementById(id)}
  function panel(){return document.querySelector('.panel[data-collapse-key="adsbSettings"]')}
  function adsbBody(){return panel()?.querySelector('.panel-body')||panel()}
  function clamp(v,min,max,d){v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):d}
  function setStatus(msg,ok){const box=field('adsbSettingsStatus');if(!box)return;box.textContent=String(msg||'');box.classList.toggle('adsb-status-ok',ok===true);box.classList.toggle('adsb-status-bad',ok===false)}
  function statusFromError(prefix,e){setStatus(prefix+': '+String((e&&e.message)||e||'failed'),false)}
  function apiJson(r){return r.json().catch(()=>({ok:false,error:'Invalid JSON'})).then(j=>{if(!r.ok||j.ok===false)throw new Error(j.error||j.message||('HTTP '+r.status));return j})}
  async function postAdsb(payload){const r=await fetch('/api/tak-map/adsb-settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),cache:'no-store'});return await apiJson(r)}
  function intervalVal(){return Math.round(clamp(field('adsbUpdateInterval')?.value||field('adsbIntervalMinutes')?.value||30,1,86400,30))}
  function radiusVal(){return Math.round(clamp(field('adsbRadiusMiles')?.value||5,1,250,5))}
  function setIntervalInputs(v){v=String(Math.round(clamp(v,1,86400,30)));['adsbUpdateInterval','adsbIntervalMinutes'].forEach(id=>{const el=field(id);if(el)el.value=v})}
  function centerValues(){const lat=Number(field('adsbCenterLat')?.value),lon=Number(field('adsbCenterLon')?.value);return {lat:Number.isFinite(lat)?lat:null,lon:Number.isFinite(lon)?lon:null}}
  function readCats(){const out=[];document.querySelectorAll('.adsb-cat-checkbox:checked').forEach(x=>out.push(x.value));return out}
  function applySettings(s,opts){opts=opts||{};if(!s)return;window.lastAdsbSettings=s;try{if(typeof config!=='undefined'&&config.adsb)config.adsb.settings=s}catch(_){}if(!opts.skipRadius&&field('adsbRadiusMiles')&&s.radius_miles!=null)field('adsbRadiusMiles').value=s.radius_miles;if(!opts.skipCenter){if(field('adsbCenterSource')&&s.center_source)field('adsbCenterSource').value=s.center_source;if(field('adsbCenterLat')&&s.center_lat!=null)field('adsbCenterLat').value=Number(s.center_lat).toFixed(6);if(field('adsbCenterLon')&&s.center_lon!=null)field('adsbCenterLon').value=Number(s.center_lon).toFixed(6)}if(s.update_interval_seconds!=null)setIntervalInputs(s.update_interval_seconds)}
  function backupText(j){const p=j&&j.ots&&j.ots.backup_path;return p?' config.yml backup made.':''}
  function intervalText(j){const s=j&&j.interval;if(!s)return '';return s.message||((s.ok?'Interval updated.':'Interval update failed.'))}
  function applyText(j){const ots=j&&j.ots;const parts=[];if(ots&&ots.message)parts.push(ots.message);else parts.push('OTS apply complete.');const it=intervalText(j);if(it)parts.push(it);const b=backupText(j);if(b&&!parts.join(' ').toLowerCase().includes('backup'))parts.push(b.trim());return parts.join(' ')}
  function ensureStatusBottom(){try{const body=adsbBody();if(!body)return;let st=field('adsbSettingsStatus');if(!st){st=document.createElement('div');st.id='adsbSettingsStatus';st.className='muted'}st.classList.add('adsb-status-v269');if(body.lastElementChild!==st)body.appendChild(st)}catch(_){} }
  function ensureUpdateIntervalButton(){try{const p=panel();if(!p)return;let btn=field('adsbUpdateIntervalBtn')||field('adsbSaveIntervalBtn');const interval=field('adsbUpdateInterval')?.closest('label,.adsb-interval-group')||field('adsbIntervalMinutes')?.closest('label,.adsb-interval-group');let row=p.querySelector('.adsb-interval-action-row');if(!row){row=document.createElement('div');row.className='adsb-interval-action-row';if(interval)interval.insertAdjacentElement('afterend',row);else (p.querySelector('.adsb-settings-grid')||p).appendChild(row)}if(!btn){btn=document.createElement('button');btn.className='layer-button';btn.type='button';row.appendChild(btn)}btn.id='adsbUpdateIntervalBtn';btn.type='button';btn.textContent='Update Interval';btn.onclick=()=>window.saveAdsbInterval();if(btn.parentElement!==row)row.appendChild(btn)}catch(e){console.warn('interval button failed',e)}}
  function ensureApplyAndActions(){try{const row=document.querySelector('.adsb-apply-row');if(row&&!field('adsbApplyOtsBtn'))row.insertAdjacentHTML('beforeend','<button id="adsbApplyOtsBtn" class="layer-button" type="button">Apply to OTS</button>');if(field('adsbApplyOtsBtn'))field('adsbApplyOtsBtn').onclick=()=>window.saveAdsbSettings(true);['adsbDisableOtsJobBtn','adsbEnableOtsJobBtn'].forEach(id=>{const b=field(id);if(b)b.type='button'})}catch(_){} }
  function css(){if(field('v269Style'))return;const st=document.createElement('style');st.id='v269Style';st.textContent=`
    .adsb-status-v269{grid-column:1/-1;margin-top:8px!important;min-height:17px;font-size:.70rem!important;line-height:1.25;border-top:1px solid rgba(255,255,255,.08);padding-top:6px;color:#9fb1b9!important}.adsb-status-v269.adsb-status-ok{color:#9ff2c1!important}.adsb-status-v269.adsb-status-bad{color:#ffad9f!important}.adsb-interval-action-row{grid-column:1/-1!important;display:flex!important;justify-content:flex-end!important;margin:-3px 0 5px!important}.adsb-interval-action-row .layer-button{padding:5px 8px!important;font-size:.70rem!important}
    #toolViewshed svg{width:19px;height:19px;display:block;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linejoin:round;stroke-linecap:round}.terrain-incline-control{display:grid;grid-template-columns:auto minmax(110px,1fr) 42px auto;align-items:center;gap:8px;margin-top:8px;padding:8px 9px;border:1px solid rgba(255,111,46,.22);border-radius:12px;background:linear-gradient(180deg,rgba(255,111,46,.12),rgba(5,12,18,.58));box-shadow:inset 0 0 18px rgba(255,111,46,.04)}.terrain-incline-control label{font-size:.67rem;text-transform:uppercase;letter-spacing:.08em;color:#d5e5ea;font-weight:850}.terrain-incline-control input[type=range]{accent-color:#ff6f2e;width:100%;height:20px}.terrain-incline-control span{font-size:.72rem;color:#ffb287;font-weight:850;text-align:right}.terrain-incline-reset{padding:4px 7px!important;font-size:.65rem!important}@media(max-width:720px){.terrain-incline-control{grid-template-columns:1fr 42px}.terrain-incline-control label,.terrain-incline-reset{grid-column:1/-1}.terrain-incline-control span{align-self:center}}`;
    document.head.appendChild(st)}
  window.saveAdsbInterval=async function(){const ids=['adsbUpdateIntervalBtn','adsbSaveIntervalBtn'];try{ids.forEach(id=>{const b=field(id);if(b)b.disabled=true});setIntervalInputs(intervalVal());setStatus('Updating ADS-B interval...',null);const payload={interval_only:true,save_interval:true,update_interval_seconds:intervalVal(),radius_miles:radiusVal(),category_filters:readCats(),update_center:false,apply_to_ots:false};const j=await postAdsb(payload);applySettings(j.settings||payload,{skipCenter:true,skipRadius:true});try{if(typeof scheduleAdsbRefreshTimer==='function')scheduleAdsbRefreshTimer()}catch(_){}try{await refreshAdsb()}catch(_){}setStatus(intervalText(j)||'Interval updated.',j.interval?!!j.interval.ok:true);return j}catch(e){statusFromError('Interval update failed',e);return {ok:false,error:String(e)}}finally{ids.forEach(id=>{const b=field(id);if(b)b.disabled=false})}}
  window.saveAdsbSettings=async function(applyToOts){try{setIntervalInputs(intervalVal());if(applyToOts){const cv=centerValues();if(cv.lat===null||cv.lon===null){setStatus('Apply to OTS needs valid lat/lon.',false);return}setStatus('Applying ADS-B to OTS...',null);const payload={radius_miles:radiusVal(),update_interval_seconds:intervalVal(),category_filters:readCats(),center_source:field('adsbCenterSource')?.value||'manual',center_lat:cv.lat,center_lon:cv.lon,update_center:true,apply_to_ots:true};const j=await postAdsb(payload);applySettings(j.settings||payload,{skipCats:true});try{localStorage.setItem('takmap.adsb.lastCenter',JSON.stringify({lat:cv.lat,lon:cv.lon,ts:Date.now()}))}catch(_){}try{await refreshAdsb()}catch(_){}try{if(typeof updateTopBanner==='function')updateTopBanner()}catch(_){}setStatus(applyText(j),!!(j.ots&&j.ots.ok));return j}
    const cats=readCats();try{if(typeof renderAdsbFromCache==='function')renderAdsbFromCache();else if(typeof renderCached248==='function')renderCached248()}catch(_){}setStatus('ADS-B filter saved locally.',true);const payload={radius_miles:radiusVal(),update_interval_seconds:intervalVal(),category_filters:cats,update_center:false,apply_to_ots:false};postAdsb(payload).then(j=>{applySettings(j.settings||payload,{skipCenter:true});try{if(typeof scheduleAdsbRefreshTimer==='function')scheduleAdsbRefreshTimer()}catch(_){};setStatus('ADS-B filter saved locally.',true)}).catch(e=>setStatus('Filter local; save failed: '+String(e.message||e),false));return window.lastAircraft||[]
    }catch(e){statusFromError('ADS-B settings failed',e);return {ok:false,error:String(e)}}}
  window.useMapCenterForAdsb=async function(){try{if(!window.map)return;const c=map.getCenter();const lat=Number(c.lat),lon=Number(c.lng);if(field('adsbCenterLat'))field('adsbCenterLat').value=lat.toFixed(6);if(field('adsbCenterLon'))field('adsbCenterLon').value=lon.toFixed(6);if(field('adsbCenterSource'))field('adsbCenterSource').value='map_center';setStatus('Saving map center...',null);const payload={radius_miles:radiusVal(),update_interval_seconds:intervalVal(),category_filters:readCats(),center_source:'map_center',center_lat:lat,center_lon:lon,update_center:true,apply_to_ots:false};const j=await postAdsb(payload);applySettings(j.settings||payload);try{localStorage.setItem('takmap.adsb.lastCenter',JSON.stringify({lat,lon,ts:Date.now()}))}catch(_){}try{await refreshAdsb()}catch(_){}setStatus('Map center saved.',true);return j}catch(e){statusFromError('Map center failed',e)}}
  window.setAdsbOtsJobDisabled=async function(disable){const ids=['adsbDisableOtsJobBtn','adsbEnableOtsJobBtn'];try{ids.forEach(id=>{const b=field(id);if(b)b.disabled=true});setStatus(disable?'Disabling OTS Job...':'Enabling OTS Job...',null);const r=await fetch('/api/tak-map/adsb-ots-job',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:disable?'disable':'enable'}),cache:'no-store'});const j=await apiJson(r);try{localStorage.setItem('takmap.adsb.otsJobDisabled',disable?'1':'0')}catch(_){}setStatus(j.message||(disable?'OTS Job disabled.':'OTS Job enabled.'),!!j.ok);return j}catch(e){statusFromError('OTS Job update failed',e);return {ok:false,error:String(e)}}finally{ids.forEach(id=>{const b=field(id);if(b)b.disabled=false})}}
  function viewshedSvg(){return '<svg viewBox="0 0 24 24"><path d="M4 18 10 7l4 7 2.5-3.5L21 18Z"/><circle cx="10" cy="8" r="1.7"/><path d="M10 8c3.8 1 6.5 3.2 8.2 6.4"/><path d="M10 8c1.4 3.1 1.7 6 .9 8.5"/></svg>'}
  function ensureViewshedToolbar(){try{let btn=field('toolViewshed');const bar=field('floatingMapToolbar');if(!bar)return;if(!btn){btn=document.createElement('button');btn.id='toolViewshed';btn.className='tool-btn';btn.type='button';btn.title='Viewshed'}btn.type='button';btn.onclick=function(ev){try{ev&&ev.stopPropagation&&ev.stopPropagation()}catch(_){};if(typeof toggleViewshedModule==='function')toggleViewshedModule();else setStatus('Viewshed unavailable.',false)};btn.innerHTML=viewshedSvg()+'<span class="tool-label">Viewshed</span>';const anchor=field('tool3d')||field('toolClearHidden');if(anchor&&anchor.parentElement===bar&&btn.parentElement!==bar)bar.insertBefore(btn,anchor);else if(anchor&&btn.nextSibling!==anchor)bar.insertBefore(btn,anchor);else if(!btn.parentElement)bar.appendChild(btn);document.querySelectorAll('#toolViewshed').forEach((n,i)=>{if(i>0)n.remove()})}catch(e){console.warn('viewshed toolbar restore failed',e)}}
  function terrainIncline(){return clamp(localStorage.getItem('takmap.terrain.inclineDeg')||58,25,85,58)}
  function updateInclineLabel(){const v=Math.round(terrainIncline());if(field('terrainInclineValue'))field('terrainInclineValue').textContent=v+'°';if(field('terrainInclineSlider'))field('terrainInclineSlider').value=v}
  window.setTerrainIncline=function(v){v=clamp(v,25,85,58);try{localStorage.setItem('takmap.terrain.inclineDeg',String(Math.round(v)))}catch(_){}updateInclineLabel();try{if(window.terrain3DViewer&&window.Cesium){const cam=terrain3DViewer.camera;cam.setView({destination:cam.positionWC.clone(),orientation:{heading:cam.heading,pitch:Cesium.Math.toRadians(-v),roll:cam.roll||0}});if(typeof terrainRequestRender==='function')terrainRequestRender()}}catch(e){}}
  window.resetTerrainIncline=function(){window.setTerrainIncline(58)}
  function ensureTerrainInclineSlider(){try{const controls=document.querySelector('.terrain3d-controls');if(!controls||field('terrainInclineSlider'))return;const wrap=document.createElement('div');wrap.className='terrain-incline-control';wrap.innerHTML='<label for="terrainInclineSlider">View Incline</label><input id="terrainInclineSlider" type="range" min="25" max="85" step="1" value="58" oninput="setTerrainIncline(this.value)"><span id="terrainInclineValue">58°</span><button class="layer-button terrain-incline-reset" type="button" onclick="resetTerrainIncline()">Reset</button>';controls.appendChild(wrap);updateInclineLabel()}catch(e){console.warn('terrain incline slider failed',e)}}
  const oldSync=window.syncTerrainCameraFromMap;if(typeof oldSync==='function'){window.syncTerrainCameraFromMap=function(){const r=oldSync.apply(this,arguments);setTimeout(()=>{try{window.setTerrainIncline(terrainIncline())}catch(_){}},0);return r}}
  function boot(){try{css();ensureUpdateIntervalButton();ensureApplyAndActions();ensureStatusBottom();ensureViewshedToolbar();ensureTerrainInclineSlider();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){console.warn('v269 boot failed',e)}}
  boot();if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,250));else setTimeout(boot,250);setTimeout(boot,1200);setTimeout(boot,3200);setInterval(boot,2500);
  try{const bar=field('floatingMapToolbar');if(bar&&window.MutationObserver){new MutationObserver(()=>ensureViewshedToolbar()).observe(bar,{childList:true})}}catch(_){}
})();
'''
_v269_marker='</script></body></html>'
_v269_i=TAK_MAP_HTML.rfind(_v269_marker)
if _v269_i >= 0:
    TAK_MAP_HTML = TAK_MAP_HTML[:_v269_i] + _v269_js + TAK_MAP_HTML[_v269_i:]
# --- end v269 queued TAK Map fixes ---


# --- v270 ADS-B Airplanes.live Direct + drawing geometry fix ---
# Release label remains 1.1.0; only the internal/package iteration marker advances to v270.
for _old in ('v269','v268','v267','v266','v265','v264','v263','v262','v261','v260','v259','v258','v257','v256','v255','v254','v253','v252','v251','v250','v249','v248','v247','v246','v245','v244','v243','v242','v241','v240','v239','v238','v236'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class=\"iteration-chip\">{_old}</span>', '<span class=\"iteration-chip\">v270</span>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class=\"iteration-marker\">{_old}</div>', '<div class=\"iteration-marker\">v270</div>')
TAK_MAP_HTML = TAK_MAP_HTML.replace("const V='v301';", "const V='v301';")
TAK_MAP_HTML = TAK_MAP_HTML.replace("console.warn('v269 boot failed',e)", "console.warn('v270 boot failed',e)")
TAK_MAP_HTML = TAK_MAP_HTML.replace("console.warn('v269 ui boot failed',e)", "console.warn('v270 ui boot failed',e)")
TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('<div class=\"iteration-marker\">v269</div>', '<div class=\"iteration-marker\">v270</div>')
LOGIN_HTML = LOGIN_HTML.replace('<div class=\"iteration-marker\">v269</div>', '<div class=\"iteration-marker\">v270</div>')

_ADSB_AIRPLANES_CACHE={'key':'','ts':0.0,'data':None}
_ADSB_AIRPLANES_LOCK=threading.Lock()

def _v270_default_adsb_filters():
    return {'civil':True,'military':True,'govt':True,'unknown':True}

def _v270_filter_map(value):
    out=_v270_default_adsb_filters()
    if isinstance(value, dict):
        for k in tuple(out.keys()):
            if k in value:
                out[k]=bool(value.get(k))
    return out

_v270_prev_load_adsb_settings = _load_adsb_settings

def _load_adsb_settings():
    d=_v270_prev_load_adsb_settings()
    # v270 removes the OpenTAKServer ADS-B plugin/scheduler/config.yml workflow entirely.
    for _k in ('apply_to_ots','apply_result','ots_job_disabled','ots_job','scheduler','config_backup','backup_path','ots_restart','interval_only','save_interval'):
        try: d.pop(_k, None)
        except Exception: pass
    if d.get('center_source') not in ('manual','map_center'):
        d['center_source']='manual'
    d['source_mode']='airplanes_live_direct'
    d['category_filters']=_v270_filter_map(d.get('category_filters') or d.get('filters'))
    d['stale_seconds']=60
    return d

def _save_adsb_settings(payload, session=None, *args, **kwargs):
    payload=payload or {}
    cur=_load_adsb_settings()
    out={}
    try:
        out['radius_miles']=max(1, min(250, int(round(float(payload.get('radius_miles', cur.get('radius_miles') or 5))))))
    except Exception:
        out['radius_miles']=int(cur.get('radius_miles') or 5)
    try:
        out['update_interval_seconds']=max(1, min(300, int(round(float(payload.get('update_interval_seconds', payload.get('update_interval', cur.get('update_interval_seconds') or 5)))))))
    except Exception:
        out['update_interval_seconds']=int(cur.get('update_interval_seconds') or 5)
    out['center_source']=str(payload.get('center_source') or cur.get('center_source') or 'manual').strip()[:64]
    out['center_lat']=_coerce_float(payload.get('center_lat', cur.get('center_lat')))
    out['center_lon']=_coerce_float(payload.get('center_lon', cur.get('center_lon')))
    if out['center_lat'] is not None and not (-90 <= out['center_lat'] <= 90): out['center_lat']=None
    if out['center_lon'] is not None and not (-180 <= out['center_lon'] <= 180): out['center_lon']=None
    out['category_filters']=_v270_filter_map(payload.get('category_filters') if 'category_filters' in payload else cur.get('category_filters'))
    out['stale_seconds']=60
    out['source_mode']='airplanes_live_direct'
    out['updated']=datetime.now(timezone.utc).isoformat()
    TAK_MAP_ADSB_SETTINGS_FILE.parent.mkdir(parents=True, exist_ok=True)
    atomic_write_json(TAK_MAP_ADSB_SETTINGS_FILE, out)
    return {'ok':True,'settings':_load_adsb_settings(),'message':'ADS-B settings saved.','source':'airplanes.live direct'}

def _v270_airplanes_url(settings):
    lat=settings.get('center_lat'); lon=settings.get('center_lon')
    if lat is None or lon is None:
        return ''
    radius=max(1, min(250, int(round(float(settings.get('radius_miles') or 5)))))
    return f'https://api.airplanes.live/v2/point/{float(lat):.6f}/{float(lon):.6f}/{radius}'

def _v270_json_url(url, timeout=8):
    req=Request(url, headers={'Accept':'application/json','User-Agent':'TAK-Map/1.1.0 v301 Airplanes.live Direct'})
    ctx=ssl.create_default_context()
    with urlopen(req, timeout=timeout, context=ctx) as resp:
        raw=resp.read(8*1024*1024)
    return json.loads(raw.decode('utf-8','replace'))

def _v270_airplanes_fetch(settings):
    url=_v270_airplanes_url(settings)
    if not url:
        return None, {'source':'airplanes.live','ok':False,'error':'ADS-B center not set. Use Map Center or enter lat/lon.'}
    key=url
    now=time.time()
    with _ADSB_AIRPLANES_LOCK:
        if _ADSB_AIRPLANES_CACHE.get('key') == key and _ADSB_AIRPLANES_CACHE.get('data') is not None and (now-float(_ADSB_AIRPLANES_CACHE.get('ts') or 0.0)) < 1.0:
            return _ADSB_AIRPLANES_CACHE.get('data'), {'source':'airplanes.live','url':url,'ok':True,'cached':True}
        try:
            data=_v270_json_url(url, timeout=10)
            _ADSB_AIRPLANES_CACHE.update({'key':key,'ts':time.time(),'data':data})
            return data, {'source':'airplanes.live','url':url,'ok':True,'cached':False}
        except Exception as e:
            return None, {'source':'airplanes.live','url':url,'ok':False,'error':str(e)[:240]}

def _v270_bool_flags(item):
    try:
        return int(item.get('dbFlags') or item.get('dbflags') or 0)
    except Exception:
        return 0

def _v270_text_blob(item):
    parts=[]
    for k in ('flight','callsign','r','registration','t','type','desc','description','ownOp','operator','owner','squawk','hex'):
        v=item.get(k)
        if v is not None:
            parts.append(str(v))
    return ' '.join(parts).upper()

def _v270_aircraft_is_helo(item):
    text=_v270_text_blob(item)
    t=str(item.get('t') or item.get('type') or item.get('desc') or '').upper()
    rotor_tokens=('HELICOPTER','ROTORCRAFT','GYROPLANE','HELO','HELI','ROTOR','B407','B412','B429','B206','B205','B212','B222','B230','B234','R22','R44','R66','S76','S92','EC35','EC45','H135','H145','AS50','AS55','AS65','A109','A119','A139','A169','A189','UH60','MH60','HH60','CH47','AH64')
    return bool(re.search(r'\b(H|HEL|HELI|HELO|ROTOR)\b', text) or t.startswith(('H','R')) or any(x in text for x in rotor_tokens))

def _v270_aircraft_category(item):
    flags=_v270_bool_flags(item)
    if flags & 1:
        return 'military'
    text=_v270_text_blob(item)
    govt_terms=(
        'POLICE','SHERIFF','STATE POLICE','HIGHWAY PATROL','CHP','CAL FIRE','CALFIRE','FIRE','FIRE DEPT','FIRE DEPARTMENT',
        'RESCUE','SEARCH AND RESCUE','PUBLIC SAFETY','LAW ENFORCEMENT','EMS','MEDEVAC','AIR AMBULANCE','AMBULANCE',
        'USFS','FOREST SERVICE','BUREAU OF LAND MANAGEMENT',' BLM','NIFC','FEMA','DHS','CBP','CUSTOMS','BORDER PATROL',
        'DEA','FBI','MARSHAL','NASA','NOAA','NPS','PARK SERVICE','COAST GUARD','USCG','LIFE FLIGHT','LIFEGUARD'
    )
    if any(term in text for term in govt_terms):
        return 'govt'
    ident=' '.join(str(item.get(k) or '').strip() for k in ('hex','flight','r','t')).strip()
    if not ident or (not item.get('flight') and not item.get('r') and not item.get('t')):
        return 'unknown'
    return 'civil'

def _normalize_adsb_aircraft(item, source='airplanes.live'):
    if not isinstance(item, dict):
        return None
    lat=item.get('lat'); lon=item.get('lon')
    if lat is None or lon is None:
        return None
    try:
        lat=float(lat); lon=float(lon)
    except Exception:
        return None
    if not (-90 <= lat <= 90 and -180 <= lon <= 180) or (abs(lat)<0.000001 and abs(lon)<0.000001):
        return None
    flight=str(item.get('flight') or item.get('callsign') or '').strip()
    hexid=str(item.get('hex') or item.get('icao') or '').strip().upper()
    reg=str(item.get('r') or item.get('registration') or '').strip().upper()
    ident=flight or reg or hexid or 'aircraft'
    alt=item.get('alt_baro')
    if alt in ('ground','GND'):
        alt=0
    if alt is None:
        alt=item.get('alt_geom') or item.get('altitude')
    cat=_v270_aircraft_category(item)
    helo=_v270_aircraft_is_helo(item)
    seen=item.get('seen_pos') if item.get('seen_pos') is not None else item.get('seen')
    return {
        'id': hexid or reg or ident,
        'icao': hexid,
        'hex': hexid,
        'registration': reg,
        'callsign': ident,
        'flight': flight,
        'lat': lat,
        'lon': lon,
        'altitude_ft': alt,
        'speed_kt': item.get('gs') or item.get('speed'),
        'track_deg': item.get('track') or item.get('true_heading') or item.get('mag_heading'),
        'seen_seconds': seen,
        'seen_pos': item.get('seen_pos'),
        'seen': item.get('seen'),
        'category': cat,
        'category_class': cat,
        'aircraft_class': cat,
        'is_military': cat == 'military',
        'is_govt': cat == 'govt',
        'is_unknown': cat == 'unknown',
        'is_helo': helo,
        'is_rotor': helo,
        'type': item.get('t') or item.get('type') or '',
        'aircraft_type': item.get('t') or item.get('type') or '',
        'description': item.get('desc') or item.get('description') or '',
        'dbFlags': _v270_bool_flags(item),
        'squawk': item.get('squawk') or '',
        'emergency': item.get('emergency') or '',
        'source': source,
        'updated': datetime.now(timezone.utc).isoformat(),
    }

def tak_map_adsb(query_settings=None):
    settings=_load_adsb_settings()
    if isinstance(query_settings, dict):
        qlat=_coerce_float(query_settings.get('center_lat'))
        qlon=_coerce_float(query_settings.get('center_lon'))
        if qlat is not None and qlon is not None and -90 <= qlat <= 90 and -180 <= qlon <= 180:
            settings['center_lat']=qlat; settings['center_lon']=qlon; settings['has_center']=True
        if query_settings.get('radius_miles') is not None:
            try: settings['radius_miles']=max(1,min(250,int(round(float(query_settings.get('radius_miles'))))))
            except Exception: pass
    stale_seconds=_adsb_stale_seconds(settings)
    data,note=_v270_airplanes_fetch(settings)
    source_notes=[note]
    aircraft_by_id={}
    if isinstance(data, dict):
        for item in data.get('aircraft') or []:
            ac=_normalize_adsb_aircraft(item, 'Airplanes.live')
            if not ac:
                continue
            try:
                if ac.get('seen_seconds') is not None and float(ac.get('seen_seconds') or 999999) > stale_seconds:
                    continue
            except Exception:
                pass
            if not _adsb_in_radius(ac, settings):
                continue
            key=str(ac.get('id') or ac.get('callsign') or '').strip().lower()
            if key:
                old=aircraft_by_id.get(key)
                def rank(x):
                    try: return float(x.get('seen_seconds'))
                    except Exception: return 999999
                if old is None or rank(ac)<rank(old):
                    aircraft_by_id[key]=ac
    final=list(aircraft_by_id.values())
    final.sort(key=lambda x:(str(x.get('category_class') or ''), str(x.get('callsign') or x.get('id') or '')))
    return {'ok':True,'source_mode':'airplanes_live_direct','aircraft':final,'count':len(final),'sources':source_notes,'stale_seconds':stale_seconds,'settings':settings}

_v270_prev_handler_get = Handler.do_GET

def _v270_handler_get(self):
    parsed=urlparse(self.path)
    if parsed.path == '/api/tak-map/adsb':
        if not self._tak_map_auth_ok():
            return self._require_tak_map_login()
        q=parse_qs(parsed.query or '')
        qs={}
        for key in ('center_lat','center_lon','radius_miles'):
            if key in q and q.get(key):
                qs[key]=(q.get(key) or [''])[0]
        return self._send_json(tak_map_adsb(qs))
    return _v270_prev_handler_get(self)

Handler.do_GET = _v270_handler_get

def _v270_adsb_ots_job_control(action, session=None):
    return {'ok':False,'attempted':False,'message':'OTS ADS-B plugin controls are removed. TAK Map uses Airplanes.live Direct.'}

_v266_adsb_ots_job_control = _v270_adsb_ots_job_control

_v270_adsb_icons = {"adsb_gov_fixed":"data:image/png;base64,","adsb_gov_helo":"data:image/png;base64,","adsb_unk_fixed":"data:image/png;base64,","adsb_unk_helo":"data:image/png;base64,"}
_v270_js = r'''
/* v270 ADS-B Airplanes.live Direct, compact filters, popup behavior, drawing geometry fix */
(function(){
  const V='v301';
  const GOV_UNK_ICONS=__V270_ADSB_ICONS__;
  const field=id=>document.getElementById(id);
  const esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  window.v270AdsbFilters=window.v270AdsbFilters||{civil:true,military:true,govt:true,unknown:true};
  function settings(){return window.lastAdsbSettings||((typeof config!=='undefined'&&config.adsb&&config.adsb.settings)||{})}
  function categoryFilters(){const s=settings();const f=s.category_filters||window.v270AdsbFilters||{};return {civil:f.civil!==false,military:f.military!==false,govt:f.govt!==false,unknown:f.unknown!==false}}
  function setStatus(msg,ok){const box=field('adsbSettingsStatus');if(!box)return;box.textContent=String(msg||'');box.classList.toggle('adsb-status-ok',ok===true);box.classList.toggle('adsb-status-bad',ok===false)}
  function disabled(){return localStorage.getItem('takmap.adsb.localDisabled')==='1'||(typeof state!=='undefined'&&state.live&&state.live.adsb_aircraft===false)}
  function setDisabled(v){try{localStorage.setItem('takmap.adsb.localDisabled',v?'1':'0')}catch(_){};try{if(typeof state!=='undefined'&&state.live)state.live.adsb_aircraft=!v}catch(_){}}
  function adsbCategory(ac){let c=String(ac&& (ac.category_class||ac.aircraft_class||ac.category)||'').toLowerCase();if(c==='mil')c='military';if(c==='government')c='govt';if(!['civil','military','govt','unknown'].includes(c)){if(ac&&ac.is_military)c='military';else if(ac&&ac.is_govt)c='govt';else c='civil'}return c}
  function aircraftIsHeloLocal(ac){if(ac&&(ac.is_helo||ac.is_rotor))return true;try{if(typeof aircraftIsHelicopter==='function'&&aircraftIsHelicopter(ac))return true}catch(_){}const blob=String([ac?.type,ac?.aircraft_type,ac?.description,ac?.callsign].filter(Boolean).join(' ')).toUpperCase();return /\b(H|HEL|HELI|HELO|ROTOR)\b/.test(blob)||blob.includes('HELICOPTER')||blob.includes('ROTORCRAFT')}
  window.aircraftIsMilitary=function(ac){return adsbCategory(ac)==='military'};
  window.aircraftIsHelicopter=function(ac){return aircraftIsHeloLocal(ac)};
  function track(ac){const n=Number(ac&&ac.track_deg);return Number.isFinite(n)?n:0}
  function key(ac){return String(ac&&(ac.id||ac.hex||ac.icao||ac.registration||ac.callsign)||'')}
  function label(ac){return String(ac&&(ac.callsign||ac.registration||ac.id)||'ADS-B')}
  function iconUrl(ac){const c=adsbCategory(ac), h=aircraftIsHeloLocal(ac); if(c==='govt')return h?GOV_UNK_ICONS.adsb_gov_helo:GOV_UNK_ICONS.adsb_gov_fixed; if(c==='unknown')return h?GOV_UNK_ICONS.adsb_unk_helo:GOV_UNK_ICONS.adsb_unk_fixed; try{if(typeof window.v239AdsbIconUrl==='function')return window.v239AdsbIconUrl(ac)}catch(_){} return GOV_UNK_ICONS.adsb_unk_fixed}
  window.v270AdsbIconUrl=iconUrl;
  function classText(ac){const c=adsbCategory(ac);return (c==='military'?'Military':c==='govt'?'Govt':c==='unknown'?'Unknown':'Civil')+' · '+(aircraftIsHeloLocal(ac)?'Rotor':'Fixed wing')}
  function fmtAlt(ac){let v=ac&&ac.altitude_ft;if(v===null||v===undefined||v===''||ac.altitude_unknown)return 'Unknown';if(String(v).toLowerCase()==='ground')return 'Ground';v=Number(v);return Number.isFinite(v)?Math.round(v)+' ft':'Unknown'}
  function fmtSpeed(ac){const v=Number(ac&&ac.speed_kt);return Number.isFinite(v)?Math.round(v)+' kt':'—'}
  function fmtTrack(ac){const v=Number(ac&&ac.track_deg);return Number.isFinite(v)?Math.round(v)+'°':'—'}
  function fmtCoords(ac){try{if(typeof formatCoords==='function')return formatCoords(ac.lat,ac.lon)}catch(_){}const la=Number(ac&&ac.lat),lo=Number(ac&&ac.lon);return Number.isFinite(la)&&Number.isFinite(lo)?la.toFixed(6)+', '+lo.toFixed(6):'—'}
  function fmtRange(ac){const v=Number(ac&&ac.range_miles);return Number.isFinite(v)?v.toFixed(v<10?1:0)+' mi':'—'}
  window.adsbPopupHtml=function(ac){return `<div class="feature-popup adsb-popup compact"><h3>${esc(label(ac))}</h3><div class="kvp"><b>Class</b><span>${esc(classText(ac))}</span><b>ICAO</b><span>${esc(ac?.icao||ac?.hex||ac?.id||'—')}</span><b>Reg/Type</b><span>${esc([ac?.registration,ac?.aircraft_type||ac?.type].filter(Boolean).join(' · ')||'—')}</span><b>Alt / Speed</b><span>${esc(fmtAlt(ac)+' · '+fmtSpeed(ac))}</span><b>Track</b><span>${esc(fmtTrack(ac))}</span><b>Coords</b><span>${esc(fmtCoords(ac))}</span><b>Range</b><span>${esc(fmtRange(ac))}</span><b>Source</b><span>Airplanes.live</span></div></div>`}
  window.aircraftIcon=function(ac){const id=key(ac);const selected=id&&id===window.selectedAircraftId?' selected':'';const cat=adsbCategory(ac);const cls='aircraft-'+cat+(aircraftIsHeloLocal(ac)?' aircraft-rotor':' aircraft-fixed');return L.divIcon({className:'',html:`<div class="aircraft-wrap v270-adsb ${cls}${selected}"><img class="adsb-png-icon" src="${iconUrl(ac)}" style="transform:rotate(${track(ac)}deg)"><div class="aircraft-label">${esc(label(ac))}</div></div>`,iconSize:[96,70],iconAnchor:[48,33]})};
  try{aircraftIcon=window.aircraftIcon}catch(_){}
  function currentFilterPass(ac){const f=categoryFilters();return f[adsbCategory(ac)]!==false}
  window.v270FilteredAircraft=function(items){return (items||window.lastAircraft||[]).filter(currentFilterPass)};
  window.drawAircraft=function(items){if(typeof terrain3DActive!=='undefined'&&terrain3DActive)return;const list=window.v270FilteredAircraft(items||[]);try{aircraftLayer.clearLayers()}catch(_){}window.v270AircraftLayersById={};window.v240AircraftLayersById=window.v270AircraftLayersById;window.v238AircraftLayersById=window.v270AircraftLayersById;window.v236AircraftLayersById=window.v270AircraftLayersById;try{clearSearchSource('aircraft')}catch(_){};for(const ac of list){if(ac.lat==null||ac.lon==null)continue;const id=key(ac);const m=L.marker([ac.lat,ac.lon],{icon:window.aircraftIcon(ac),autoPan:false}).addTo(aircraftLayer);window.v270AircraftLayersById[id]=m;m.bindPopup(window.adsbPopupHtml(ac),{autoPan:false,closeButton:false,className:'tak-object-popup adsb-object-popup'});try{if(typeof stabilizeLayerPopup==='function')stabilizeLayerPopup(m)}catch(_){}m.on('click',ev=>{try{L.DomEvent.stopPropagation(ev);window.selectedAircraftId=id;m.setIcon(window.aircraftIcon(ac));m.openPopup()}catch(_){}});try{addSearchItem('aircraft','ADS-B '+classText(ac),label(ac),ac.lat,ac.lon,m,ac)}catch(_){}}try{handleMapSearch()}catch(_){}}
  window.focusAdsbAircraft=function(id){try{id=decodeURIComponent(String(id||''));const ac=(window.lastAircraft||[]).find(a=>key(a)===id);if(!ac||ac.lat==null||ac.lon==null)return;window.selectedAircraftId=key(ac);map.setView([Number(ac.lat),Number(ac.lon)],Math.max(map.getZoom(),12),{animate:true});setTimeout(()=>{try{window.drawAircraft(window.lastAircraft||[]);const m=window.v270AircraftLayersById&&window.v270AircraftLayersById[window.selectedAircraftId];if(m)m.openPopup()}catch(_){}},220)}catch(_){}}
  function readUi(){return {radius_miles:clamp(field('adsbRadiusMiles')?.value,1,250,5),update_interval_seconds:clamp(field('adsbUpdateInterval')?.value,1,300,5),center_source:field('adsbCenterSource')?.value||'manual',center_lat:field('adsbCenterLat')?.value||'',center_lon:field('adsbCenterLon')?.value||'',category_filters:{civil:!!field('adsbFilterCivil')?.checked,military:!!field('adsbFilterMilitary')?.checked,govt:!!field('adsbFilterGovt')?.checked,unknown:!!field('adsbFilterUnknown')?.checked},apply_to_ots:false}}
  async function postSettings(payload){const r=await fetch('/api/tak-map/adsb-settings',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload),cache:'no-store'});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||j.message||('HTTP '+r.status));window.lastAdsbSettings=j.settings||payload;try{if(typeof config!=='undefined'&&config.adsb)config.adsb.settings=window.lastAdsbSettings}catch(_){}return j}
  let saveTimer=null;function saveSoon(reason){clearTimeout(saveTimer);saveTimer=setTimeout(async()=>{try{await postSettings(readUi());if(reason==='filters'){window.v270AdsbFilters=readUi().category_filters;window.drawAircraft(window.lastAircraft||[]);setStatus('Filters updated.',true)}else setStatus('ADS-B settings saved.',true);schedule()}catch(e){setStatus('Settings save failed: '+String(e.message||e),false)}},reason==='filters'?0:450)}
  window.toggleTakMapAdsbLocal=function(){const off=!disabled();setDisabled(off);const b=field('adsbToggleBtn');if(b)b.textContent=off?'Enable ADS-B':'Disable ADS-B';if(off){try{if(window.aircraftLayer)aircraftLayer.clearLayers();if(field('adsbStatus'))field('adsbStatus').textContent='disabled'}catch(_){}setStatus('ADS-B disabled.',true)}else{setStatus('ADS-B enabled.',true);refreshAdsb()}}
  window.disableTakMapAdsbLocal=function(){if(!disabled())window.toggleTakMapAdsbLocal()};window.enableTakMapAdsbLocal=function(){if(disabled())window.toggleTakMapAdsbLocal()};
  window.useMapCenterForAdsb=async function(){try{if(!window.map)return;const c=map.getCenter();field('adsbCenterLat').value=Number(c.lat).toFixed(6);field('adsbCenterLon').value=Number(c.lng).toFixed(6);field('adsbCenterSource').value='map_center';setStatus('Map center set.',true);await postSettings(readUi());await refreshAdsb()}catch(e){setStatus('Map center failed: '+String(e.message||e),false)}}
  function fetchUrl(){let q='?_='+Date.now();try{if((field('adsbCenterSource')?.value||'')==='map_center'&&window.map){const c=map.getCenter();q+='&center_lat='+encodeURIComponent(Number(c.lat).toFixed(6))+'&center_lon='+encodeURIComponent(Number(c.lng).toFixed(6));q+='&radius_miles='+encodeURIComponent(field('adsbRadiusMiles')?.value||'5')}}catch(_){}return '/api/tak-map/adsb'+q}
  window.refreshAdsb=async function(){if(disabled()){try{if(window.aircraftLayer)aircraftLayer.clearLayers();if(field('adsbStatus'))field('adsbStatus').textContent='disabled'}catch(_){}return []}try{const r=await fetch(fetchUrl(),{cache:'no-store'});const j=await r.json();window.lastAdsbSettings=j.settings||settings();window.lastAircraft=j.aircraft||[];window.v270AdsbFilters=categoryFilters();const filtered=window.v270FilteredAircraft(window.lastAircraft);const el=field('adsbStatus');if(el)el.textContent=filtered.length+' active';if(window.lastBanner){lastBanner.adsb_aircraft=filtered.length;try{renderTopBanner(lastBanner)}catch(_){}}window.drawAircraft(window.lastAircraft);const src=(j.sources||[])[0]||{};if(src.ok)setStatus(filtered.length+' aircraft · Airplanes.live',true);else setStatus(src.error||'Airplanes.live unavailable.',false);return filtered}catch(e){const el=field('adsbStatus');if(el)el.textContent='error';setStatus('ADS-B fetch failed: '+String(e.message||e),false);return []}}
  let refreshTimer=null;function schedule(){clearTimeout(refreshTimer);const sec=clamp(field('adsbUpdateInterval')?.value||settings().update_interval_seconds,1,300,5);refreshTimer=setTimeout(async()=>{await refreshAdsb();schedule()},sec*1000)}window.scheduleAdsbRefreshTimer=schedule;
  function ensureCss(){if(field('v270Style'))return;const st=document.createElement('style');st.id='v270Style';st.textContent=`
    .adsb-v270-menu{display:grid;gap:8px}.adsb-v270-top{display:flex;justify-content:flex-end;align-items:center;gap:7px}#adsbToggleBtn{min-width:112px}.adsb-v270-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}.adsb-v270-grid label{font-size:.68rem;text-transform:uppercase;letter-spacing:.065em;color:#9fb1b9;font-weight:850}.adsb-v270-grid input,.adsb-v270-grid select{width:100%;margin-top:4px;background:#091018;border:1px solid #334553;border-radius:9px;color:#e9f0f5;padding:7px 8px;font-size:.78rem}.adsb-v270-grid input[type=number]{appearance:auto;-moz-appearance:auto}.adsb-v270-grid input[type=number]::-webkit-inner-spin-button,.adsb-v270-grid input[type=number]::-webkit-outer-spin-button{opacity:1;filter:drop-shadow(0 0 3px rgba(255,111,46,.35));cursor:pointer}.adsb-v270-actions{display:flex;justify-content:flex-end;gap:7px}.adsb-filter-box{border:1px solid rgba(255,111,46,.18);border-radius:11px;background:rgba(255,255,255,.025);padding:6px 8px}.adsb-filter-row{display:grid;grid-template-columns:1fr auto;align-items:center;gap:12px;padding:5px 0;border-bottom:1px solid rgba(255,255,255,.055);font-size:.76rem;color:#dbe6ea}.adsb-filter-row:last-child{border-bottom:0}.adsb-filter-row input{accent-color:#ff6f2e;transform:scale(1.02)}.adsb-status-v270{min-height:18px;font-size:.70rem;line-height:1.25;border-top:1px solid rgba(255,255,255,.08);padding-top:6px;color:#9fb1b9}.adsb-status-v270.adsb-status-ok{color:#9ff2c1}.adsb-status-v270.adsb-status-bad{color:#ffad9f}.aircraft-wrap.v270-adsb{display:flex;flex-direction:column;align-items:center;pointer-events:none;color:#eaf3f7}.aircraft-wrap.v270-adsb .adsb-png-icon{width:44px;height:44px;object-fit:contain;filter:drop-shadow(0 0 8px rgba(0,0,0,.92)) drop-shadow(0 0 7px currentColor);transform-origin:center center}.aircraft-wrap.v270-adsb.aircraft-civil{color:#25d66e}.aircraft-wrap.v270-adsb.aircraft-military{color:#1692ff}.aircraft-wrap.v270-adsb.aircraft-govt{color:#ff9c38}.aircraft-wrap.v270-adsb.aircraft-unknown{color:#aeb8c2}.adsb-popup.compact .kvp{grid-template-columns:72px minmax(0,1fr);font-size:.76rem}.adsb-popup.compact h3{font-size:.9rem;margin-bottom:6px}.panel[data-collapse-key="adsbSettings"] .panel-body>.muted:first-child,.adsb-v268-actions,#adsbV268Actions,.adsb-v266-actions,#adsbV267Actions,.adsb-interval-action-row,#adsbApplyOtsBtn,#adsbUpdateIntervalBtn,#adsbSaveIntervalBtn,#adsbDisableOtsJobBtn,#adsbEnableOtsJobBtn,#adsbDisableLocalBtn,#adsbEnableLocalBtn{display:none!important}
    @media(max-width:720px){.adsb-v270-grid{grid-template-columns:1fr}.adsb-v270-actions,.adsb-v270-top{justify-content:stretch}#adsbToggleBtn,.adsb-v270-actions .layer-button{width:100%}}
  `;document.head.appendChild(st)}
  function ensureMenu(){try{ensureCss();const body=document.querySelector('.panel[data-collapse-key="adsbSettings"] .panel-body');if(!body)return;body.querySelectorAll('.panel-body>.muted:first-child,.adsb-v268-actions,#adsbV268Actions,.adsb-v266-actions,#adsbV267Actions,.adsb-interval-action-row,#adsbApplyOtsBtn,#adsbUpdateIntervalBtn,#adsbSaveIntervalBtn,#adsbDisableOtsJobBtn,#adsbEnableOtsJobBtn,#adsbDisableLocalBtn,#adsbEnableLocalBtn').forEach(n=>n.remove());let wrap=field('adsbV270Menu');if(!wrap){body.innerHTML='';wrap=document.createElement('div');wrap.id='adsbV270Menu';wrap.className='adsb-v270-menu';body.appendChild(wrap);wrap.innerHTML=`<div class="adsb-v270-top"><button id="adsbToggleBtn" class="layer-button" type="button">Disable ADS-B</button></div><div class="adsb-v270-grid"><label>Radius miles<input id="adsbRadiusMiles" type="number" min="1" max="250" step="1" inputmode="numeric"></label><label>Poll sec<input id="adsbUpdateInterval" type="number" min="1" max="300" step="1" inputmode="numeric"></label><label>Center source<select id="adsbCenterSource"><option value="manual">Manual</option><option value="map_center">Map center</option></select></label><label>Center lat<input id="adsbCenterLat" type="text" inputmode="decimal" placeholder="34.000000"></label><label>Center lon<input id="adsbCenterLon" type="text" inputmode="decimal" placeholder="-118.000000"></label></div><div class="adsb-v270-actions"><button class="layer-button" type="button" onclick="useMapCenterForAdsb()">Use Map Center</button><button class="layer-button" type="button" onclick="refreshAdsb()">Refresh</button></div><div class="adsb-filter-box"><label class="adsb-filter-row"><span>Civil</span><input id="adsbFilterCivil" type="checkbox"></label><label class="adsb-filter-row"><span>Military</span><input id="adsbFilterMilitary" type="checkbox"></label><label class="adsb-filter-row"><span>Govt</span><input id="adsbFilterGovt" type="checkbox"></label><label class="adsb-filter-row"><span>Unknown</span><input id="adsbFilterUnknown" type="checkbox"></label></div><div id="adsbSettingsStatus" class="adsb-status-v270"></div>`}const s=settings();if(field('adsbRadiusMiles')&&!field('adsbRadiusMiles').dataset.ready){field('adsbRadiusMiles').value=s.radius_miles||5;field('adsbRadiusMiles').dataset.ready='1'}if(field('adsbUpdateInterval')&&!field('adsbUpdateInterval').dataset.ready){field('adsbUpdateInterval').value=s.update_interval_seconds||5;field('adsbUpdateInterval').dataset.ready='1'}if(field('adsbCenterSource')&&!field('adsbCenterSource').dataset.ready){field('adsbCenterSource').value=s.center_source||'manual';field('adsbCenterSource').dataset.ready='1'}if(field('adsbCenterLat')&&!field('adsbCenterLat').dataset.ready){if(s.center_lat!=null)field('adsbCenterLat').value=Number(s.center_lat).toFixed(6);field('adsbCenterLat').dataset.ready='1'}if(field('adsbCenterLon')&&!field('adsbCenterLon').dataset.ready){if(s.center_lon!=null)field('adsbCenterLon').value=Number(s.center_lon).toFixed(6);field('adsbCenterLon').dataset.ready='1'}const f=categoryFilters();[['Civil','civil'],['Military','military'],['Govt','govt'],['Unknown','unknown']].forEach(([id,k])=>{const cb=field('adsbFilter'+id);if(cb&&!cb.dataset.ready){cb.checked=f[k]!==false;cb.dataset.ready='1';cb.addEventListener('change',()=>saveSoon('filters'))}});['adsbRadiusMiles','adsbUpdateInterval','adsbCenterSource','adsbCenterLat','adsbCenterLon'].forEach(id=>{const el=field(id);if(el&&!el.dataset.bound){el.dataset.bound='1';el.addEventListener('change',()=>saveSoon('settings'));if(id==='adsbRadiusMiles'||id==='adsbUpdateInterval')el.addEventListener('input',()=>saveSoon('settings'))}});const b=field('adsbToggleBtn');if(b){b.textContent=disabled()?'Enable ADS-B':'Disable ADS-B';b.onclick=window.toggleTakMapAdsbLocal}let st=field('adsbSettingsStatus');if(st){st.className='adsb-status-v270';if(st.parentElement&&st.parentElement.lastElementChild!==st)st.parentElement.appendChild(st)}}catch(e){console.warn('v270 ADS-B menu failed',e)}}
  function redrawFromCache(){try{window.drawAircraft(window.lastAircraft||[])}catch(_){}}
  function boot(){try{ensureMenu();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V);document.querySelectorAll('#adsbApplyOtsBtn,#adsbDisableOtsJobBtn,#adsbEnableOtsJobBtn,#adsbDisableLocalBtn,#adsbEnableLocalBtn,#adsbV268Actions,#adsbV267Actions,.adsb-v268-actions,.adsb-v266-actions,.adsb-interval-action-row').forEach(n=>n.remove());redrawFromCache()}catch(e){console.warn('v270 boot failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,250));else setTimeout(boot,100);setTimeout(boot,800);setTimeout(boot,2000);setInterval(boot,1600);setTimeout(()=>{try{refreshAdsb();schedule()}catch(_){}},1200);

  function drawState(){return window.v233DrawState=window.v233DrawState||{mode:'',points:[]}}
  function readDrawOptions(){const st=drawState();st.name=field('drawNameInput')?.value||st.name||'';st.color=field('drawColorInput')?.value||st.color||'#ff6f2e';st.weight=clamp(field('drawWeightInput')?.value||st.weight,1,12,3);st.lineStyle=field('drawLineStyleInput')?.value||st.lineStyle||'solid';st.fill=(field('drawFillInput')?.value||'1')==='1';const curPct=(st.fillOpacity==null?20:Math.round(st.fillOpacity*100));st.fillOpacity=Math.max(0,Math.min(1,(parseFloat(field('drawFillOpacityInput')?.value||curPct)||20)/100));return st}
  function llToCoord(ll){return [Number(ll.lng),Number(ll.lat)]}function coordsToLL(coords){return coords.map(c=>L.latLng(c[1],c[0]))}
  function projectPoly(mode,a,b){if(!window.map||!a||!b)return [];const p1=map.latLngToLayerPoint(a),p2=map.latLngToLayerPoint(b);let pts=[];if(mode==='rectangle'||mode==='square'){let x2=p2.x,y2=p2.y;if(mode==='square'){const dx=p2.x-p1.x,dy=p2.y-p1.y,d=Math.max(Math.abs(dx),Math.abs(dy))||1;x2=p1.x+(dx>=0?d:-d);y2=p1.y+(dy>=0?d:-d)}pts=[L.point(p1.x,p1.y),L.point(x2,p1.y),L.point(x2,y2),L.point(p1.x,y2),L.point(p1.x,p1.y)]}else if(mode==='circle'||mode==='ellipse'){const dx=p2.x-p1.x,dy=p2.y-p1.y;let rx=Math.abs(dx)||1,ry=Math.abs(dy)||1;if(mode==='circle'){const r=Math.sqrt(dx*dx+dy*dy)||1;rx=r;ry=r}for(let i=0;i<96;i++){const t=Math.PI*2*i/96;pts.push(L.point(p1.x+Math.cos(t)*rx,p1.y+Math.sin(t)*ry))}pts.push(pts[0])}return pts.map(pt=>llToCoord(map.layerPointToLatLng(pt)))}
  function drawCoords(){const st=drawState(),pts=st.points||[],end=st.liveEnd;if(['rectangle','square','circle','ellipse'].includes(st.mode)&&pts.length&&end)return projectPoly(st.mode,pts[0],end);if(st.mode==='freehand'&&pts.length>1){const c=pts.map(llToCoord);if(c.length>2)c.push(c[0]);return c}if(st.mode==='polygon'&&pts.length){const arr=pts.slice();if(end)arr.push(end);const c=arr.map(llToCoord);if(c.length>2)c.push(c[0]);return c}return pts.map(llToCoord)}
  function clearTemp(st){try{if(st.layer){map.removeLayer(st.layer);st.layer=null}}catch(_){}}
  window.v236RedrawDrawTemp=function(){try{const st=readDrawOptions();clearTemp(st);const coords=drawCoords();if(!coords.length)return;const opt={color:st.color||'#ff6f2e',weight:st.weight||3,opacity:.94,dashArray:st.lineStyle==='dashed'?'8 7':null,fill:st.fill!==false,fillOpacity:st.fill===false?0:Math.max(0,Math.min(.8,st.fillOpacity==null?0.20:st.fillOpacity))};if(['rectangle','square','circle','ellipse','freehand'].includes(st.mode)&&coords.length>=3)st.layer=L.polygon(coordsToLL(coords),opt).addTo(map);else if(st.mode==='polygon')st.layer=(coords.length>=3?L.polygon(coordsToLL(coords),opt):L.polyline((st.points||[]).concat(st.liveEnd?[st.liveEnd]:[]),opt)).addTo(map);else if(st.points&&st.points.length)st.layer=L.polyline(st.points,opt).addTo(map)}catch(e){console.warn('draw preview failed',e)}}
  async function uploadFeature(name,feature){const fc={type:'FeatureCollection',features:[feature]};const blob=new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'});const safe=String(name||'TAK Map Object').replace(/[\\/:*?"<>|]+/g,'-').slice(0,80)||'TAK Map Object';const fd=new FormData();fd.append('files',new File([blob],safe+'.geojson',{type:'application/geo+json'}));const r=await fetch('/api/tak-map/import',{method:'POST',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));try{window.lastImports=j.imports||window.lastImports;await refreshLocalData();drawImportedObjects()}catch(_){}return j}
  window.v233FinishDraw=async function(){try{const st=readDrawOptions();const coords=drawCoords();if(coords.length<4){alert('Add or draw more points before finishing.');return}const center=(st.points&&st.points[0])?llToCoord(st.points[0]):null;const edge=st.liveEnd?llToCoord(st.liveEnd):null;const name=(st.name||prompt('Shape name:',(st.mode||'Shape')+' '+new Date().toLocaleTimeString())||'Shape').trim()||'Shape';await uploadFeature(name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:{name,kind:'shape',shape_type:st.mode,color:st.color||'#ff6f2e',fill:st.fill!==false,fill_opacity:st.fillOpacity==null?0.20:st.fillOpacity,weight:st.weight||3,line_style:st.lineStyle||'solid',center,edge,source:'TAK Map Drawing Tools'}});if(typeof v233ClearDraw==='function')v233ClearDraw();try{if(typeof v236CloseDrawOptions==='function')v236CloseDrawOptions()}catch(_){}setActiveMapTool('move')}catch(e){alert('Save shape failed: '+e)}}
  window.v270DrawingGeometryReady=true;
})();
'''.replace('__V270_ADSB_ICONS__', json.dumps(_v270_adsb_icons, separators=(',',':')))
