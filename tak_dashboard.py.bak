  window.setAdsbStatusSort=function(key,ev){try{ev&&ev.stopPropagation&&ev.stopPropagation();const cur=window.v240AdsbSort||{key:'icao',dir:1};window.v240AdsbSort={key,dir:(cur.key===key?-(cur.dir||1):1)};window.v233StatusSort=window.v240AdsbSort;window.renderStatusDropdown('adsb')}catch(_){}};
  const oldRows=window.statusDropdownRows;
  window.statusDropdownRows=function(type){if(type==='euds')return eudTableRows();if(type==='adsb')return adsbRows();return oldRows?oldRows(type):[]};
  const oldRender=window.renderStatusDropdown;
  window.renderStatusDropdown=function(type){const box=document.getElementById('statusDropdown');if(!box)return oldRender?oldRender(type):undefined;box.dataset.type=type;box.classList.toggle('adsb-table',type==='adsb');box.classList.toggle('eud-table',type==='euds');if(type==='euds'){const rows=eudTableRows();let html='<div class="status-dropdown-title">EUDs</div>';html+=rows.length?'<div class="status-eud-head"><span>Callsign</span><span>Team</span><span>Role</span><span>ATAK Version</span></div>'+rows.map(r=>`<div class="status-eud-row"><span>${esc(r.callsign)}</span><span>${esc(r.team||'—')}</span><span>${esc(r.role||'—')}</span><span>${esc(r.version||'—')}</span></div>`).join(''):'<div class="status-dropdown-empty">No online EUDs.</div>';box.innerHTML=html;return}
    if(type==='adsb'){const rows=adsbRows();const s=window.v240AdsbSort||{key:'icao',dir:1};const ind=k=>s.key===k?'<span class="status-sort-ind">'+(s.dir>0?'▲':'▼')+'</span>':'';let html='<div class="status-dropdown-title">ADS-B Aircraft</div>';html+=rows.length?'<div class="status-adsb-head v240"><span onclick="setAdsbStatusSort(\'icao\',event)">ICAO'+ind('icao')+'</span><span onclick="setAdsbStatusSort(\'type\',event)">Aircraft Type'+ind('type')+'</span><span onclick="setAdsbStatusSort(\'alt\',event)">Altitude'+ind('alt')+'</span><span onclick="setAdsbStatusSort(\'range\',event)">From Center Point'+ind('range')+'</span></div>'+rows.map(r=>`<div class="status-adsb-row v240" onclick="focusAdsbAircraft('${encodeURIComponent(r.id).replace(/'/g,'%27')}')"><span class="status-adsb-icao">${esc(r.icao)}</span><span>${esc(r.type)}</span><span class="status-adsb-alt">${esc(r.alt)}</span><span class="status-adsb-range">${esc(r.range)}</span></div>`).join(''):'<div class="status-dropdown-empty">No aircraft currently listed.</div>';box.innerHTML=html;return}
    return oldRender?oldRender(type):undefined};
  function injectCss(){if(document.getElementById('v240Style'))return;document.head.insertAdjacentHTML('beforeend',`<style id="v240Style">.aircraft-wrap.v240-adsb{display:flex;flex-direction:column;align-items:center;pointer-events:none;color:#eaf3f7}.aircraft-wrap.v240-adsb .adsb-png-icon{width:44px;height:44px;object-fit:contain;filter:drop-shadow(0 0 8px rgba(0,0,0,.92)) drop-shadow(0 0 7px currentColor);transform-origin:center center}.aircraft-wrap.v240-adsb.aircraft-civil{color:#25d66e}.aircraft-wrap.v240-adsb.aircraft-military{color:#1692ff}.status-dropdown.eud-table{min-width:560px;max-width:min(760px,calc(100vw - 24px));font-weight:400!important}.status-eud-head,.status-eud-row{display:grid;grid-template-columns:minmax(110px,1.1fr) 78px minmax(120px,1fr) minmax(160px,1.4fr);gap:10px;align-items:center;padding:6px 7px}.status-eud-head{position:sticky;top:-8px;z-index:2;margin:0 -2px 3px;border-bottom:1px solid rgba(255,255,255,.12);background:rgba(8,13,18,.96);color:#ffd9c5;font-size:.66rem;font-weight:850;text-transform:uppercase;letter-spacing:.07em}.status-eud-row{font-weight:400!important;border-bottom:1px solid rgba(255,255,255,.055);border-radius:8px}.status-eud-row:hover{background:rgba(255,255,255,.05)}.status-eud-row span{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:400!important}.status-dropdown.adsb-table{min-width:520px;max-width:min(740px,calc(100vw - 24px))}.status-adsb-head.v240,.status-adsb-row.v240{grid-template-columns:minmax(92px,1fr) 96px 80px 122px}#drawToolMenu.draw-icon-menu{display:none!important;position:absolute!important;right:54px!important;left:auto!important;top:0!important;grid-template-columns:1fr!important;grid-auto-rows:38px!important;width:46px!important;min-width:46px!important;max-width:46px!important;padding:5px!important;border-radius:16px!important;background:rgba(8,13,18,.92)!important;border:1px solid rgba(255,255,255,.13)!important;box-shadow:0 14px 34px rgba(0,0,0,.42)!important}#drawToolMenu.draw-icon-menu.active,#drawToolMenu.draw-icon-menu.open{display:grid!important}#drawToolMenu.draw-icon-menu button{width:36px!important;height:36px!important;padding:7px!important;border-radius:10px!important;display:grid!important;place-items:center!important}#drawToolMenu.draw-icon-menu svg{width:21px!important;height:21px!important}</style>`)}
  function after(){try{injectCss();if(lastAircraft&&lastAircraft.length)window.drawAircraft(lastAircraft);const box=document.getElementById('statusDropdown');if(box&&box.classList.contains('active'))window.renderStatusDropdown(box.dataset.type||'')}catch(_){}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(after,500));else setTimeout(after,500);setTimeout(after,1600);
})();
/* end v239 focused patch */

</script></body></html>''')
