    TAK_MAP_HTML = TAK_MAP_HTML.replace('3D terrain', 'Terrain Mode')

    _v293_patch = r'''<script id="v293TerrainElevationAdsbPatch">
(function(){
  'use strict';
  const V='v301';
  const MB=1024*1024, WARN_MB=250, CONFIRM_MB=500, HARD_MB=1024;
  function q(sel,root){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function field(id){try{return document.getElementById(id)}catch(_){return null}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function bytes(n){n=Number(n)||0;if(n>=1024*1024*1024)return (n/(1024*1024*1024)).toFixed(1)+' GB';if(n>=1024*1024)return Math.round(n/(1024*1024))+' MB';if(n>=1024)return Math.round(n/1024)+' KB';return n+' B'}
  function state(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};if(!(window.takLocalElevation.tiles instanceof Map))window.takLocalElevation.tiles=new Map();return window.takLocalElevation}
  function uniqueTiles(){try{return [...(state().tiles||new Map()).values()].filter((v,i,a)=>v&&v.id&&a.findIndex(x=>x&&x.id===v.id)===i)}catch(_){return []}}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V});}catch(_){} }
  function renameTerrainText(){try{qa('button,.tool-label,#terrain3dStatus,#terrain3dElevation,.terrain3d-status,.terrain3d-elevation,label,option').forEach(el=>{if(el.childNodes&&el.childNodes.length===1&&el.childNodes[0].nodeType===3){el.textContent=el.textContent.replace(/3D Terrain/g,'Terrain Mode').replace(/3D terrain/g,'Terrain Mode')}});const b=field('tool3d');if(b){b.title=(b.title||'Terrain Mode').replace(/3D Terrain/g,'Terrain Mode').replace(/3D terrain/g,'Terrain Mode');const lab=q('.tool-label',b);if(lab)lab.textContent='Terrain Mode'}}catch(_){} }
  function addCss(){try{if(field('v293TerrainElevationStyle'))return;const st=document.createElement('style');st.id='v293TerrainElevationStyle';st.textContent=`
    #localElevationDialog .local-elev-progress{display:none;margin:7px 0 8px;padding:7px 8px;border:1px solid rgba(255,255,255,.10);border-radius:10px;background:rgba(255,255,255,.035)}
    #localElevationDialog .local-elev-progress.active{display:block!important}
    #localElevationDialog .local-elev-progress-track{height:7px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;border:1px solid rgba(255,255,255,.08)}
    #localElevationDialog .local-elev-progress-bar{height:100%;width:0%;border-radius:999px;background:linear-gradient(90deg,rgba(255,111,46,.92),rgba(255,204,102,.80));box-shadow:0 0 10px rgba(255,111,46,.35);transition:width .18s ease}
    #localElevationDialog .local-elev-progress-label{margin-top:5px;color:#aebdc3;font-size:.66rem;font-weight:800;white-space:pre-wrap}
    #localElevationDialog .local-elev-status.error,.local-elev-failed{color:#ff8f83!important;font-weight:850!important}
    #localElevationDialog .local-elev-status.ok{color:#bdebd0!important}
    #localElevationDialog .local-elev-list{display:flex;flex-direction:column;gap:5px}
    #localElevationDialog .local-elev-index-row{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:6px 7px;border:1px solid rgba(255,255,255,.075);border-radius:9px;background:rgba(255,255,255,.035);font-size:.68rem;line-height:1.25}
    #localElevationDialog .local-elev-index-info{min-width:0;overflow:hidden;text-overflow:ellipsis;color:#d5e1e6}
    #localElevationDialog .local-elev-index-meta{display:block;color:#8fa0aa;font-size:.62rem;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    #localElevationDialog .local-elev-remove{flex:0 0 auto;border:1px solid rgba(255,95,87,.45);background:rgba(255,95,87,.10);color:#ffc0bb;border-radius:999px;padding:4px 8px;font-size:.64rem;font-weight:900;cursor:pointer}
    #localElevationDialog .local-elev-remove:hover{background:rgba(255,95,87,.18);border-color:rgba(255,95,87,.72)}
    .terrain3d-controls.v293-terrain-panel{top:12px!important;right:76px!important;bottom:auto!important;z-index:6!important;display:grid!important;grid-template-columns:1fr!important;gap:7px!important;min-width:236px!important;max-width:min(264px,calc(100vw - 180px))!important;padding:9px!important;border-color:rgba(255,111,46,.28)!important;border-radius:15px!important;background:linear-gradient(180deg,rgba(14,23,30,.94),rgba(6,10,14,.92))!important;box-shadow:0 14px 34px rgba(0,0,0,.40),inset 0 1px 0 rgba(255,255,255,.08)!important;backdrop-filter:blur(10px)}
    .terrain3d-controls .terrain3d-panel-title{font-size:.66rem;text-transform:uppercase;letter-spacing:.09em;color:#ffd9c5;font-weight:950;margin-bottom:1px}
    .terrain3d-controls .terrain3d-control-row{display:grid;grid-template-columns:82px minmax(0,1fr);align-items:center;gap:7px}
    .terrain3d-controls .terrain3d-control-row label{color:#aebdc3;font-size:.66rem;font-weight:900;text-transform:uppercase;letter-spacing:.05em}
    .terrain3d-controls.v293-terrain-panel select{width:100%;min-width:0;padding:5px 7px!important;font-size:.7rem!important;background:#111b23!important;color:#e9f0f5!important;border:1px solid rgba(255,255,255,.14)!important;border-radius:9px!important}
    .terrain3d-controls .terrain3d-source-chip{font-size:.62rem;color:#8fa0aa;line-height:1.22;margin-top:-1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .terrain3d-refresh,.terrain3d-close{font-size:.72rem!important;padding:6px 9px!important}
    @media(max-width:720px){.terrain3d-controls.v293-terrain-panel{top:74px!important;right:12px!important;max-width:calc(100vw - 24px)!important}.terrain3d-elevation{top:126px!important;left:12px!important}.terrain3d-status{left:12px!important;right:12px!important;max-width:none!important}}
  `;document.head.appendChild(st)}catch(e){console.warn('v293 css failed',e)} }
  function ensureProgress(){try{const body=q('#localElevationDialog .local-elev-body');if(!body)return null;let box=field('localElevProgress');if(!box){const status=field('localElevStatus');const html='<div id="localElevProgress" class="local-elev-progress"><div class="local-elev-progress-track"><div id="localElevProgressBar" class="local-elev-progress-bar"></div></div><div id="localElevProgressLabel" class="local-elev-progress-label">Ready.</div></div>';if(status)status.insertAdjacentHTML('beforebegin',html);else body.insertAdjacentHTML('beforeend',html);box=field('localElevProgress')}return box}catch(e){console.warn('v293 progress ensure failed',e);return null}}
  function setProgress(pct,label,active){try{const box=ensureProgress(),bar=field('localElevProgressBar'),lab=field('localElevProgressLabel');if(box)box.classList.toggle('active',active!==false);if(bar)bar.style.width=Math.max(0,Math.min(100,Number(pct)||0))+'%';if(lab)lab.textContent=label||''}catch(_){} }
  function setStatus(msg,isError){try{const el=field('localElevStatus');if(!el)return;el.textContent=msg||'';el.classList.toggle('error',!!isError);el.classList.toggle('ok',!isError&&!!msg)}catch(_){} }
  function setStatusHtml(html,isError){try{const el=field('localElevStatus');if(!el)return;el.innerHTML=html||'';el.classList.toggle('error',!!isError);el.classList.toggle('ok',!isError&&!!html)}catch(_){} }
  async function openDb(){if(typeof window.openLocalElevDb==='function')return window.openLocalElevDb();return new Promise((resolve,reject)=>{try{const req=indexedDB.open('takmapLocalElevationV1',1);req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains('tiles'))db.createObjectStore('tiles',{keyPath:'id'});};req.onsuccess=()=>resolve(req.result);req.onerror=()=>reject(req.error||new Error('IndexedDB open failed'))}catch(e){reject(e)}})}
  async function deleteTile(id){id=String(id||'');if(!id)throw new Error('missing elevation source id');const db=await openDb();await new Promise((resolve,reject)=>{try{const tx=db.transaction(['tiles'],'readwrite');tx.objectStore('tiles').delete(id);tx.oncomplete=()=>{try{db.close()}catch(_){};resolve(true)};tx.onerror=()=>reject(tx.error||new Error('IndexedDB delete failed'))}catch(e){reject(e)}});const st=state();try{for(const [k,v] of Array.from(st.tiles.entries())){if(k===id||(v&&v.id===id))st.tiles.delete(k)}}catch(_){}st.meta=uniqueTiles().map(t=>({id:t.id,name:t.name,type:t.type,lat0:t.lat0,lon0:t.lon0,lat1:t.lat1,lon1:t.lon1,width:t.width||t.size,height:t.height||t.size,size:t.size||Math.max(Number(t.width)||0,Number(t.height)||0),bytes:t.bytes||0,imported:t.imported||0}));if(typeof window.updateLocalElevationUi==='function')window.updateLocalElevationUi('Removed elevation file.',false);return true}
  function renderList(msg,isError){try{const list=field('localElevList');const tiles=uniqueTiles();if(field('localElevToolStatus'))field('localElevToolStatus').textContent='Local: '+tiles.length;if(msg!=null)setStatus(msg,isError);if(!list)return;list.innerHTML=tiles.length?tiles.map(t=>{const wh=(t.width||t.size||'?')+'×'+(t.height||t.size||'?');const b=(Number.isFinite(Number(t.lat0))&&Number.isFinite(Number(t.lon0))&&Number.isFinite(Number(t.lat1))&&Number.isFinite(Number(t.lon1)))?(Number(t.lat0).toFixed(4)+','+Number(t.lon0).toFixed(4)+' to '+Number(t.lat1).toFixed(4)+','+Number(t.lon1).toFixed(4)):'bounds unknown';return '<div class="local-elev-index-row" data-elev-id="'+esc(t.id)+'"><div class="local-elev-index-info" title="'+esc(t.name||t.id)+'">'+esc(t.name||t.id)+'<span class="local-elev-index-meta">'+esc(t.type||'Elevation')+' · '+esc(wh)+' · '+esc(b)+'</span></div><button type="button" class="local-elev-remove" data-local-elev-remove="'+esc(t.id)+'">Remove</button></div>'}).join(''):'<div>No local files indexed.</div>'}catch(e){console.warn('v293 render local elevation list failed',e)} }
  window.updateLocalElevationUi=renderList;
  async function ensureLoaded(){try{if(typeof window.loadLocalElevationTiles==='function')await window.loadLocalElevationTiles()}catch(e){console.warn('v293 local load failed',e)}}
  function fileSupported(name){return /\.(hgt|dt0|dt1|dt2|tif|tiff)$/i.test(String(name||''))}
