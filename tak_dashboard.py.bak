  function hasSkewOrRotation(image){try{const m=image.fileDirectory&&image.fileDirectory.ModelTransformation;if(m&&m.length>=16){return Math.abs(Number(m[1])||0)>1e-12||Math.abs(Number(m[4])||0)>1e-12}}catch(_){}return false}
  function isGeographicGeoTiff(image,geoKeys,bbox){try{const mt=geoKeys.ModelTypeGeoKey;const g=geoKeys.GeographicTypeGeoKey||geoKeys.GeodeticCRSGeoKey;const unit=geoKeys.GeogAngularUnitsGeoKey;const xok=bbox&&bbox[0]>=-180.5&&bbox[2]<=180.5;const yok=bbox&&bbox[1]>=-90.5&&bbox[3]<=90.5;if(mt===2||mt==='ModelTypeGeographic')return true;if((g===4326||g===4269||String(g)==='4326'||String(g)==='4269')&&xok&&yok)return true;if(xok&&yok&&(unit===9102||unit==null))return true}catch(_){}return false}
  function geoKeysToProjString(geoKeys){try{if(window.geokeysToProj4&&typeof window.geokeysToProj4.toProj4==='function'){const obj=window.geokeysToProj4.toProj4(geoKeys||{});if(obj&&obj.errors&&Object.keys(obj.errors).some(k=>obj.errors[k]))throw new Error('unsupported GeoTIFF CRS geokeys');if(obj&&obj.shouldConvertCoordinates)throw new Error('GeoTIFF CRS coordinate-unit conversion is not supported offline yet');if(obj&&obj.proj4)return obj.proj4}}catch(e){throw e}return ''}
