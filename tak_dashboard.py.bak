        for _old in ('v314','v313','v312','v311','v310'):
            _html = _html.replace(_old + 'AdsbSingleOwnerPatch', 'v315AdsbSingleOwnerPatch')
            _html = _html.replace("window.__takMapAdsbSingleOwner='"+_old+"'", "window.__takMapAdsbSingleOwner='v315'")
