    return {callsign:cleanCallsign(e),team:String((e&&e.team_color)||(e&&e.team)||'').trim(),role:String((e&&e.team_role)||(e&&e.role)||'').trim(),version:label,uidFallback:cleanCallsign(e).startsWith('UID ')};
