# --- TAK Map v319 ADS-B popup/dropdown/classification + local terrain restore ---
try:
    import re as _v319_re

    _V319='v319'

    def _v319_versions(_html):
        if not isinstance(_html, str):
            return _html
        _html = _v319_re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v319</span>', _html)
        _html = _v319_re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v319</div>', _html)
        _html = _v319_re.sub(r"const\s+V\s*=\s*['\"]v\d+['\"]", "const V='v319'", _html)
        _html = _v319_re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v319', _html)
        _html = _v319_re.sub(r'TAK-Map/1\.1\.0 v\d+', 'TAK-Map/1.1.0 v319', _html)
        for _old in ('v318','v317','v316','v315','v314','v313','v312','v311','v310','v309'):
            _html = _html.replace(_old + 'AdsbSingleOwnerPatch', 'v319AdsbSingleOwnerPatch')
            _html = _html.replace("window.__takMapAdsbSingleOwner='"+_old+"'", "window.__takMapAdsbSingleOwner='v319'")
            _html = _html.replace("window.__takMapAdsbSingleOwner = '"+_old+"'", "window.__takMapAdsbSingleOwner = 'v319'")
            _html = _html.replace("window.__takMapAdsbOwnerRendering==='"+_old+"'", "window.__takMapAdsbOwnerRendering==='v319'")
            _html = _html.replace("version:'"+_old+"'", "version:'v319'")
            _html = _html.replace('version:"'+_old+'"', 'version:"v319"')
            _html = _html.replace('__'+_old+'AdsbLegacySrcGuard', '__v319AdsbLegacySrcGuard')
            _html = _html.replace(_old + ' blocked legacy ADS-B icon downgrade', 'v319 blocked legacy ADS-B icon downgrade')
            _html = _html.replace(_old + ' legacy src guard failed', 'v319 legacy src guard failed')
            _html = _html.replace(_old + ' ignored legacy ADS-B', 'v319 ignored legacy ADS-B')
            _html = _html.replace(_old + ' ADS-B refresh failed', 'v319 ADS-B refresh failed')
            _html = _html.replace(_old + ' polling failed', 'v319 polling failed')
            _html = _html.replace(_old + 'AdsbViewshedStyle', 'v319AdsbViewshedStyle')
        _html = _html.replace('v318AdsbControlsRuntime', 'v319AdsbControlsRuntime')
        _html = _html.replace('v318AdsbControlsStyle', 'v319AdsbControlsStyle')
        _html = _html.replace('v318AdsbPopupLabelPolish', 'v319AdsbPopupLabelPolish')
        _html = _html.replace('v318AdsbPopupLabelStyle', 'v319AdsbPopupLabelStyle')
        _html = _html.replace('adsb-v318-', 'adsb-v319-')
        _html = _html.replace('adsb-v317-', 'adsb-v319-')
        _html = _html.replace('v318', 'v319')
        return _html

    _V319_GOVT_TERMS = (
        'GOV','GOVT','GOVERNMENT','CITY OF','COUNTY OF','COUNTY SHERIFF','DISTRICT OF','SPECIAL DISTRICT',
        'PUBLIC SAFETY','PUBLIC WORKS','MUNICIPAL','MUNICIPALITY','STATE OF','STATE POLICE','HIGHWAY PATROL',
        'PATROL','POLICE','POLICE DEPT','POLICE DEPARTMENT','SHERIFF','MARSHAL','LAW ENFORCEMENT','LAPD','CHP',
        'FIRE','FIRE DEPT','FIRE DEPARTMENT','CAL FIRE','CALFIRE','EMS','RESCUE','SEARCH AND RESCUE','MEDEVAC',
        'AIR AMBULANCE','AMBULANCE','HOSPITAL','MEDICAL','RESPONSE','USFS','FOREST SERVICE','USGS','BLM',
        'BUREAU','BUREAU OF LAND MANAGEMENT','NIFC','FEMA','DHS','CBP','CUSTOMS','BORDER PATROL','DEA','FBI',
        'NASA','NOAA','NPS','PARK SERVICE','COAST GUARD','USCG','LIFE FLIGHT','LIFEGUARD','WATER DISTRICT',
        'FLOOD CONTROL','SANITATION DISTRICT','TRANSIT AUTHORITY','PORT AUTHORITY','TRIBAL POLICE'
    )

    def _v319_text_blob(item):
        try:
            keys=('flight','callsign','r','registration','tail','hex','icao','t','type','category','emitter_category','desc','description','model','ownOp','operator','owner','owner_operator','op','squawk','source')
            return ' '.join(str(item.get(k) or '') for k in keys if isinstance(item, dict)).upper()
        except Exception:
            return ''

    def _v319_adsb_govt_match(text):
        text=str(text or '').upper()
        if not text:
            return False
        if any(term in text for term in _V319_GOVT_TERMS):
            return True
        if _v319_re.search(r'\b(CITY|COUNTY|BOROUGH|PARISH|TOWNSHIP|VILLAGE|DISTRICT)\s+(OF|AIR|FIRE|POLICE|SHERIFF|PUBLIC|WATER|SANITATION|TRANSIT|RESCUE)\b', text):
            return True
        if _v319_re.search(r'\b[A-Z .-]+\s+(CITY|COUNTY|DISTRICT)\b', text) and _v319_re.search(r'\b(POLICE|SHERIFF|FIRE|PATROL|PUBLIC SAFETY|PUBLIC WORKS|EMS|RESCUE)\b', text):
            return True
        return False

    try:
        _v319_prev_v270_aircraft_category = _v270_aircraft_category
    except Exception:
        _v319_prev_v270_aircraft_category = None

    def _v270_aircraft_category(item):
        try:
            flags=_v270_bool_flags(item)
            if flags & 1:
                return 'military'
        except Exception:
            pass
        text=_v319_text_blob(item)
        if _v319_adsb_govt_match(text):
            return 'govt'
        if _v319_prev_v270_aircraft_category:
            try:
                old=_v319_prev_v270_aircraft_category(item)
                if old and str(old).strip().lower() != 'unknown':
                    return old
            except Exception:
                pass
        ident=' '.join(str((item or {}).get(k) or '').strip() for k in ('hex','icao','flight','callsign','r','registration','t','type')).strip()
        return 'civil' if ident else 'unknown'

    try:
        _v319_prev_normalize_adsb_aircraft = _normalize_adsb_aircraft
    except Exception:
        _v319_prev_normalize_adsb_aircraft = None

    def _normalize_adsb_aircraft(item, source='airplanes.live'):
        ac=_v319_prev_normalize_adsb_aircraft(item, source) if _v319_prev_normalize_adsb_aircraft else None
        if not ac:
            return ac
        try:
            cat=_v270_aircraft_category(item if isinstance(item, dict) else {})
            ac['category']=cat
            ac['category_class']=cat
            ac['aircraft_class']=cat
            ac['is_military']=cat=='military'
            ac['is_govt']=cat=='govt'
            ac['is_unknown']=cat=='unknown'
            if isinstance(item, dict):
                owner=item.get('ownOp') or item.get('operator') or item.get('owner') or item.get('owner_operator') or ac.get('owner_operator') or ''
                ac['owner_operator']=owner
                ac['ownOp']=item.get('ownOp') or ac.get('ownOp') or ''
                ac['operator']=item.get('operator') or ac.get('operator') or ''
                ac['owner']=item.get('owner') or ac.get('owner') or ''
                ac['category_raw']=item.get('category') or item.get('emitter_category') or ac.get('category_raw') or ''
                ac['emitter_category']=item.get('emitter_category') or item.get('category') or ac.get('emitter_category') or ''
        except Exception:
            pass
        return ac

    def _v319_patch_html(_html):
        if not isinstance(_html, str):
            return _html
