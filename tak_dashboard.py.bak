  function renderAdsbDropdown(){try{const box=q('#statusDropdown');if(!box)return;const rows=aircraftList().sort((a,b)=>fmtTitle(a).localeCompare(fmtTitle(b)));let html='<div class="status-dropdown-title">ADS-B Aircraft</div>';if(!rows.length){html+='<div class="status-dropdown-empty">No aircraft currently listed.</div>'}else{html+='<div class="status-adsb-head v287"><span>Aircraft</span><span>Class</span><span>Type</span><span>Alt</span><span>Range</span></div>';html+=rows.map(a=>{const id=esc(idOf(a));return '<div class="status-adsb-row v287" data-adsb-id="'+id+'"><span class="status-adsb-icao">'+esc(fmtTitle(a))+'</span><span>'+esc(classLabel(a.category))+'</span><span>'+esc(a.is_helo?'Helicopter':'Airplane')+'</span><span class="status-adsb-alt">'+esc(fmtAlt(a))+'</span><span class="status-adsb-range">'+esc(fmtRange(a))+'</span></div>'}).join('')}box.innerHTML=html;return box}catch(_){return null}}
  function positionDropdown(ev){try{const box=q('#statusDropdown'),item=q('#bannerAdsbItem');if(!box)return;const r=(ev&&ev.currentTarget&&ev.currentTarget.getBoundingClientRect&&ev.currentTarget.getBoundingClientRect())||(item&&item.getBoundingClientRect&&item.getBoundingClientRect());box.classList.add('active','open');box.style.display='block';box.style.visibility='visible';if(r){const w=Math.min(520,window.innerWidth-16);box.style.minWidth=Math.min(420,w)+'px';box.style.maxWidth=w+'px';box.style.left=Math.max(8,Math.min(window.innerWidth-w-8,r.left))+'px';box.style.top=(r.bottom+8)+'px';}}catch(_){ }}
  function showAdsbDropdown(ev){ensureStatusLabel();renderAdsbDropdown();positionDropdown(ev)}
  function patchStatusDropdown(){try{if(window._v287StatusDropdownPatched)return;window._v287StatusDropdownPatched=true;const oldToggle=window.toggleStatusDropdown;window.toggleStatusDropdown=function(type,ev){if(String(type||'').toLowerCase()==='adsb'){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation()}}catch(_){ }showAdsbDropdown(ev);return false;}return typeof oldToggle==='function'?oldToggle.apply(this,arguments):false};const oldRender=window.renderStatusDropdown;window.renderStatusDropdown=function(type){if(String(type||'').toLowerCase()==='adsb')return renderAdsbDropdown();return typeof oldRender==='function'?oldRender.apply(this,arguments):undefined};if(!window._v287StatusRowClick){window._v287StatusRowClick=true;document.addEventListener('click',ev=>{const row=ev.target&&ev.target.closest&&ev.target.closest('.status-adsb-row.v287[data-adsb-id]');if(!row)return;ev.preventDefault();ev.stopPropagation();focusAircraft(row.dataset.adsbId);},true)}}catch(_){ }}
  function distanceMeters(latlngs){let m=0;try{for(let i=1;i<latlngs.length;i++){const a=latlngs[i-1],b=latlngs[i];if(window.map&&typeof map.distance==='function')m+=map.distance(a,b);else{const R=6371000,la1=a.lat*Math.PI/180,la2=b.lat*Math.PI/180,dl=(b.lng-a.lng)*Math.PI/180,dp=(b.lat-a.lat)*Math.PI/180;const h=Math.sin(dp/2)**2+Math.cos(la1)*Math.cos(la2)*Math.sin(dl/2)**2;m+=2*R*Math.atan2(Math.sqrt(h),Math.sqrt(1-h));}}}catch(_){ }return m}
  function milesText(m){return (Number(m||0)/1609.344).toFixed(1)+' mi'}
  function trackLayer(){return window.adsbTrackLayerV285||window.adsbTrackLayerV286||window.adsbTrackLayerV287||null}
  function trackPolyline(){let found=null;try{const g=trackLayer();if(g&&typeof g.eachLayer==='function'){g.eachLayer(l=>{if(!found&&l&&typeof l.getLatLngs==='function')found=l})}}catch(_){ }return found}
  function trackLatLngs(){try{const l=trackPolyline();if(!l)return [];let pts=l.getLatLngs();if(Array.isArray(pts)&&pts.length&&Array.isArray(pts[0]))pts=pts.flat();return (pts||[]).filter(p=>p&&Number.isFinite(Number(p.lat))&&Number.isFinite(Number(p.lng)))}catch(_){return []}}
  function labelLayer(){try{if(!window.L||!window.map)return null;if(!window.adsbTrackDistanceLayerV287)window.adsbTrackDistanceLayerV287=L.layerGroup().addTo(map);else if(!map.hasLayer(window.adsbTrackDistanceLayerV287))window.adsbTrackDistanceLayerV287.addTo(map);return window.adsbTrackDistanceLayerV287}catch(_){return null}}
  function updateTrackDistanceLabel(){try{const layer=labelLayer();if(!layer)return;layer.clearLayers();const pts=trackLatLngs();if(pts.length<2)return;const m=distanceMeters(pts),txt=milesText(m);const p=pts[Math.max(1,Math.floor(pts.length*0.66))]||pts[pts.length-1];L.marker(p,{interactive:false,zIndexOffset:1200,icon:L.divIcon({className:'adsb-track-distance-label-wrap',html:'<div class="adsb-track-distance-label">'+esc(txt)+'</div>',iconAnchor:[0,0]})}).addTo(layer)}catch(_){ }}
  function activeTrackId(){try{const b=q('.adsb-track-btn.active[data-adsb-track-id]');if(b)return String(b.dataset.adsbTrackId||'').toLowerCase();if(window._v286TrackedId)return String(window._v286TrackedId).toLowerCase();}catch(_){ }return ''}
  async function saveTrackToLocalData(id,pts){try{if(!pts||pts.length<2)return;const a=aircraftList().find(x=>idOf(x)===id)||{};const m=distanceMeters(pts);const name=(fmtTitle(a)+' ADS-B Track '+new Date().toISOString().slice(0,19).replace(/[T:]/g,'-')).replace(/[\\/:*?"<>|]+/g,'-');const feature={type:'FeatureCollection',features:[{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(p=>[Number(p.lng),Number(p.lat)])},properties:{name,source:'TAK Map ADS-B',kind:'route',geometry:'route',route_type:'adsb_aircraft_track',callsign:a.callsign||a.flight||'',hex:(a.hex||a.id||id||'').toString().toUpperCase(),class:classLabel(a.category),aircraft_type:a.is_helo?'Helicopter':'Airplane',start_time:new Date().toISOString(),end_time:new Date().toISOString(),point_count:pts.length,distance_miles:Number((m/1609.344).toFixed(3)),distance_text:milesText(m)}}]};const blob=new Blob([JSON.stringify(feature,null,2)],{type:'application/geo+json'});const file=new File([blob],name+'.geojson',{type:'application/geo+json'});const fd=new FormData();fd.append('files',file,file.name);const r=await fetch('/api/tak-map/import',{method:'POST',body:fd});const j=await r.json().catch(()=>({}));if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));try{window.lastImports=j.imports||window.lastImports}catch(_){ }try{if(typeof window.refreshLocalData==='function')await window.refreshLocalData()}catch(_){ }try{if(typeof window.drawImportedObjects==='function')window.drawImportedObjects()}catch(_){ }}catch(e){try{alert('Save ADS-B track failed: '+(e&&e.message||e))}catch(_){ }}}
  function patchTrackToggle(){try{if(window._v287TrackTogglePatched)return;const old=window.toggleAdsbTrack;if(typeof old!=='function')return;window._v287TrackTogglePatched=true;window.toggleAdsbTrack=function(id){id=String(id||'').toLowerCase();const was=(activeTrackId()===id);const ptsBefore=was?trackLatLngs().slice():[];const res=old.apply(this,arguments);setTimeout(updateTrackDistanceLabel,80);if(was){try{if(window.adsbTrackDistanceLayerV287)window.adsbTrackDistanceLayerV287.clearLayers()}catch(_){ }if(ptsBefore.length>=2){setTimeout(()=>{try{if(confirm('Save aircraft track to Local Data routes?'))saveTrackToLocalData(id,ptsBefore)}catch(_){ }},80)}}return res}}catch(_){ }}
  function addCss(){try{if(q('#v287AdsbStatusTrackStyle'))return;const st=document.createElement('style');st.id='v287AdsbStatusTrackStyle';st.textContent=`
    .status-adsb-head.v287,.status-adsb-row.v287{display:grid!important;grid-template-columns:minmax(96px,1.35fr) 70px 86px 82px 76px!important;gap:8px!important;align-items:center!important;min-width:430px!important;}
    .status-adsb-head.v287{font-size:.62rem!important;text-transform:uppercase!important;color:#8ea3ac!important;font-weight:850!important;padding:6px 8px!important;border-bottom:1px solid rgba(255,255,255,.08)!important;}
    .status-adsb-row.v287{font-size:.72rem!important;color:#eaf2f5!important;padding:7px 8px!important;border-bottom:1px solid rgba(255,255,255,.055)!important;cursor:pointer!important;}
    .status-adsb-row.v287:hover{background:rgba(255,111,46,.10)!important;}
    .status-adsb-row.v287 span{min-width:0!important;overflow:hidden!important;text-overflow:ellipsis!important;white-space:nowrap!important;}
    .adsb-track-distance-label{font-size:.68rem!important;font-weight:850!important;color:#f1f7fa!important;background:rgba(6,10,14,.72)!important;border:1px solid rgba(255,255,255,.16)!important;border-radius:999px!important;padding:2px 6px!important;box-shadow:0 5px 16px rgba(0,0,0,.32)!important;backdrop-filter:blur(8px)!important;white-space:nowrap!important;pointer-events:none!important;}
  `;document.head.appendChild(st)}catch(_){ }}
  function boot(){addCss();patchStatusDropdown();patchTrackToggle();ensureStatusLabel();updateTrackDistanceLabel();qa('.iteration-chip,.iteration-marker').forEach(el=>{try{el.textContent=V}catch(_){}})}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,80),{once:true});else setTimeout(boot,80);
  setTimeout(boot,700);setTimeout(boot,1700);setTimeout(boot,2600);setInterval(()=>{ensureStatusLabel();updateTrackDistanceLabel();},1000);
})();
</script>
"""
    if 'id="v287AdsbStatusTrackSavePatch"' not in TAK_MAP_HTML:
        TAK_MAP_HTML = TAK_MAP_HTML.replace('</body></html>', _v287_adsb_patch + '</body></html>')
    try:
        TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace('v286','v287').replace('v285','v287').replace('v284','v287')
        LOGIN_HTML = LOGIN_HTML.replace('v286','v287').replace('v285','v287').replace('v284','v287')
    except Exception:
        pass
except Exception as _v287_exc:
    try: print('v287 ADS-B status/track save patch failed:', _v287_exc)
    except Exception: pass
# --- end v287 ADS-B status list + track save/distance label ---


# --- v288 ADS-B interval/status sorting + Govt keyword classification ---
try:
    # Release label remains 1.1.0; iteration marker is v288.
    for _old in ('v287','v286','v285','v284','v283','v282','v281','v280'):
        TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
        TAK_MAP_HTML = TAK_MAP_HTML.replace('TAK-Map/1.1.0 '+_old, 'TAK-Map/1.1.0 v301')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class=\"iteration-chip\">{_old}</span>', '<span class=\"iteration-chip\">v288</span>')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class=\"iteration-marker\">{_old}</div>', '<div class=\"iteration-marker\">v288</div>')
        TAK_MAP_HTML = TAK_MAP_HTML.replace(f'>{_old}<', '>v288<')
    # Hard lower-bound fix for ADS-B interval controls and legacy ADS-B scheduler code.
    TAK_MAP_HTML = TAK_MAP_HTML.replace('min=\"5\" max=\"300\" step=\"1\" value=\"${esc(interval())}\"', 'min=\"1\" max=\"300\" step=\"1\" value=\"${esc(interval())}\"')
    TAK_MAP_HTML = TAK_MAP_HTML.replace('id=\"adsbUpdateIntervalV281\" type=\"number\" min=\"5\"', 'id=\"adsbUpdateIntervalV281\" type=\"number\" min=\"1\"')
    TAK_MAP_HTML = TAK_MAP_HTML.replace("clamp($('adsbUpdateInterval')?.value||settings().update_interval_seconds||10,5,300,10)", "clamp($('adsbUpdateInterval')?.value||settings().update_interval_seconds||10,1,300,10)")
    TAK_MAP_HTML = TAK_MAP_HTML.replace("clamp($('adsbUpdateIntervalV280')?.value||stored('interval','10'),5,300,10)", "clamp($('adsbUpdateIntervalV280')?.value||stored('interval','10'),1,300,10)")
    TAK_MAP_HTML = TAK_MAP_HTML.replace('Math.max(5,Math.min(300,Math.round(n)))', 'Math.max(1,Math.min(300,Math.round(n)))')
    _v288_adsb_patch = r'''
<script id="v288AdsbStatusSortGovtPatch">
(function(){
  'use strict';
  const V='v301';
  let sortKey='aircraft', sortDir=1;
  function q(sel,root=document){try{return (root||document).querySelector(sel)}catch(_){return null}}
  function qa(sel,root=document){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function idOf(a){return String((a&&(a.id||a.hex||a.icao||a.registration||a.callsign))||'').trim().toLowerCase()}
  function ownerText(a){try{return [a&&a.owner_operator,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.op,a&&a.oper,a&&a.agency,a&&a.organization,a&&a.flight,a&&a.callsign].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function isGovtKeyword(a){const b=ownerText(a);return /\b(LAPD|POLICE|SHERIFF|PUBLIC\s+SAFETY|EMS|RESCUE|CHP|CAL\s*FIRE|USFS|MEDICAL|HOSPITAL|RESPONSE)\b/.test(b)||/\bFIRE\s*(DEPT|DEPARTMENT)?\b/.test(b)||/\b[A-Z]{1,5}\s*(PD|FD)\b/.test(b)||/\b(PD|FD)\b/.test(b)}
  function classKey(v,a){if(a&&isGovtKeyword(a))return 'govt';const s=String(v||'').trim().toLowerCase();if(s==='gov'||s==='govt'||s==='government'||s.includes('government'))return 'govt';if(s==='mil'||s==='military'||s.includes('military'))return 'military';if(s==='unk'||s==='unknown')return 'unknown';if(s==='civil'||s==='civilian'||s.includes('commercial'))return 'civil';return s||'unknown'}
  function classLabel(v,a){return ({govt:'Govt',military:'Military',civil:'Civil',unknown:'Unknown'}[classKey(v,a)]||'Unknown')}
  function textBlob(a){try{return [a&&a.category_raw,a&&a.adsb_category,a&&a.emitter_category,a&&a.category_code,a&&a.category,a&&a.t,a&&a.type,a&&a.aircraft_type,a&&a.desc,a&&a.description,a&&a.model,a&&a.flight,a&&a.callsign,a&&a.r,a&&a.registration,a&&a.ownOp,a&&a.operator,a&&a.owner,a&&a.owner_operator].filter(Boolean).join(' ').toUpperCase()}catch(_){return ''}}
  function isHelicopter(a){const cat=String((a&&(a.category_raw||a.adsb_category||a.emitter_category||a.category_code))||'').trim().toUpperCase();if(cat==='A7')return true;if(a&&(a.is_helo===true||a.is_rotor===true||a.rotor===true))return true;const b=textBlob(a);if(/\bA7\b/.test(b))return true;if(/\b(ROTOR|ROTORCRAFT|ROTARY|HELICOPTER|HELI|HELO|GYRO)\b/.test(b))return true;if(/\b(H60|UH60|MH60|HH60|SH60|CH47|AH64|OH58|CH53|UH1|UH72|V22|B206|B407|B412|B429|B505|R22|R44|R66|S76|S92|AS50|AS350|AS355|EC35|EC45|EC120|EC130|EC135|EC145|H125|H130|H135|H145|H155|AW109|AW119|AW139|AW169|AW189|MD50|MD52|MD60)\b/.test(b))return true;if(/\b(BELL|ROBINSON|SIKORSKY|AIRBUS HELICOPTERS|EUROCOPTER|AGUSTA|LEONARDO HELICOPTERS)\b/.test(b))return true;return false}
  function normalize(a){try{a=a||{};if(a.category_raw==null&&a.category&&/^A\d$/i.test(String(a.category)))a.category_raw=a.category;if(isGovtKeyword(a))a.category='govt';else a.category=classKey(a.category,a);a.is_helo=!!isHelicopter(a);a.is_rotor=a.is_helo;a.aircraft_display_type=a.is_helo?'Helicopter':'Airplane';return a}catch(_){return a||{}}}
  function patchLastAircraftProperty(){try{if(window._v288LastAircraftPatched)return;const desc=Object.getOwnPropertyDescriptor(window,'lastAircraft');if(!desc||!desc.configurable)return;window._v288LastAircraftPatched=true;Object.defineProperty(window,'lastAircraft',{configurable:true,enumerable:true,get:function(){const arr=desc.get?desc.get.call(window):desc.value;try{if(Array.isArray(arr))arr.forEach(normalize)}catch(_){ }return arr},set:function(v){try{if(desc.set)desc.set.call(window,v);else desc.value=v}catch(_){try{desc.value=v}catch(__){}}try{const arr=desc.get?desc.get.call(window):desc.value;if(Array.isArray(arr))arr.forEach(normalize)}catch(_){}}});try{const arr=window.lastAircraft;if(Array.isArray(arr))arr.forEach(normalize)}catch(_){ }}catch(_){ }}
  function sanitizeAircraft(){try{const arr=Array.isArray(window.lastAircraft)?window.lastAircraft:[];arr.forEach(normalize)}catch(_){ }}
  function filters(){const f={civil:true,military:true,govt:true,unknown:true};try{qa('input[type="checkbox"][data-filter],#adsbFilterCivil,#adsbFilterMilitary,#adsbFilterGovt,#adsbFilterUnknown').forEach(ch=>{let k=(ch.dataset&&ch.dataset.filter)||String(ch.id||'').replace(/^adsbFilter/,'').toLowerCase();if(k==='government')k='govt';if(k&&Object.prototype.hasOwnProperty.call(f,k))f[k]=!!ch.checked})}catch(_){ }return f}
  function aircraftList(){sanitizeAircraft();const f=filters();return (Array.isArray(window.lastAircraft)?window.lastAircraft:[]).map(x=>normalize(Object.assign({},x))).filter(a=>f[classKey(a.category,a)]!==false)}
  function fmtTitle(a){return String(a.callsign||a.flight||a.registration||a.hex||a.id||'ADS-B').trim()||'ADS-B'}
  function fmtAlt(a){let v=a.altitude_ft;if(v==null||v==='')v=a.alt_baro??a.alt_geom;if(String(v).toLowerCase()==='ground')return 'Ground';v=Number(v);return Number.isFinite(v)?Math.round(v).toLocaleString()+' ft':'—'}
  function numAlt(a){let v=a.altitude_ft;if(v==null||v==='')v=a.alt_baro??a.alt_geom;if(String(v).toLowerCase()==='ground')return 0;v=Number(v);return Number.isFinite(v)?v:-Infinity}
  function rangeNum(a){let v=a.range_miles;if(v==null||v==='')v=a.range;v=Number(v);return Number.isFinite(v)?v:Infinity}
  function fmtRange(a){const v=rangeNum(a);return Number.isFinite(v)?v.toFixed(1)+' mi':'—'}
  function sortVal(a,k){if(k==='class')return classLabel(a.category,a);if(k==='type')return a.is_helo?'Helicopter':'Airplane';if(k==='alt')return numAlt(a);if(k==='range')return rangeNum(a);return fmtTitle(a)}
  function compare(a,b){const av=sortVal(a,sortKey),bv=sortVal(b,sortKey);if(typeof av==='number'||typeof bv==='number')return ((Number(av)||0)-(Number(bv)||0))*sortDir;return String(av).localeCompare(String(bv),undefined,{numeric:true,sensitivity:'base'})*sortDir}
  function ensureIntervalMin(){try{['adsbUpdateInterval','adsbUpdateIntervalV280','adsbUpdateIntervalV281'].forEach(id=>{const el=document.getElementById(id);if(el){el.min='1';if(Number(el.value)<1)el.value='1';}})}catch(_){ }}
  function ensureStatusLabel(){try{const bar=q('#mapStatusBanner')||q('.map-status-banner');if(!bar)return;let item=q('#bannerAdsbItem',bar);if(!item){item=document.createElement('span');item.id='bannerAdsbItem';item.className='status-item status-dropdown-trigger';const before=q('#bannerDownloadsItem',bar);if(before&&before.parentElement===bar)bar.insertBefore(item,before);else bar.appendChild(item)}item.classList.add('status-dropdown-trigger');item.setAttribute('data-status-type','adsb');if(!item.dataset.v288Click){item.dataset.v288Click='1';item.addEventListener('click',function(ev){try{ev.preventDefault();ev.stopPropagation();showAdsbDropdown(ev)}catch(_){ }},true)}const n=aircraftList().length;const dotClass=n>0?'good':'unknown';item.innerHTML='<span class="status-dot '+dotClass+'" id="bannerAdsbDot"></span>ADS-B: <b id="bannerAdsb">'+n+' Aircraft</b>'; }catch(_){ }}
  function statusBox(){let box=q('#statusDropdown');if(!box){box=document.createElement('div');box.id='statusDropdown';box.className='status-dropdown';document.body.appendChild(box)}return box}
  function renderAdsbDropdown(){try{const box=statusBox();let rows=aircraftList().sort(compare);let html='<div class="status-dropdown-title">ADS-B Aircraft</div>';if(!rows.length){html+='<div class="status-dropdown-empty">No aircraft currently listed.</div>'}else{const arrow=k=>sortKey===k?(sortDir>0?' ▲':' ▼'):'';html+='<div class="status-adsb-head v288"><button data-sort="aircraft">Aircraft'+arrow('aircraft')+'</button><button data-sort="class">Class'+arrow('class')+'</button><button data-sort="type">Type'+arrow('type')+'</button><button data-sort="alt">Alt'+arrow('alt')+'</button><button data-sort="range">mi-&gt;Center'+arrow('range')+'</button></div>';html+=rows.map(a=>{const id=esc(idOf(a));return '<div class="status-adsb-row v288" data-adsb-id="'+id+'"><span class="status-adsb-icao">'+esc(fmtTitle(a))+'</span><span>'+esc(classLabel(a.category,a))+'</span><span>'+esc(a.is_helo?'Helicopter':'Airplane')+'</span><span class="status-adsb-alt">'+esc(fmtAlt(a))+'</span><span class="status-adsb-range">'+esc(fmtRange(a))+'</span></div>'}).join('')}box.innerHTML=html;return box}catch(_){return null}}
  function positionDropdown(ev){try{const box=statusBox(),item=q('#bannerAdsbItem');const r=(ev&&ev.currentTarget&&ev.currentTarget.getBoundingClientRect&&ev.currentTarget.getBoundingClientRect())||(item&&item.getBoundingClientRect&&item.getBoundingClientRect());box.classList.add('active','open');box.style.display='block';box.style.visibility='visible';const w=Math.min(560,window.innerWidth-16);box.style.minWidth=Math.min(460,w)+'px';box.style.maxWidth=w+'px';if(r){box.style.left=Math.max(8,Math.min(window.innerWidth-w-8,r.left))+'px';box.style.top=(r.bottom+8)+'px';}}catch(_){ }}
  function showAdsbDropdown(ev){ensureStatusLabel();renderAdsbDropdown();positionDropdown(ev)}
  function focusAircraft(id){try{id=String(id||'').toLowerCase();const a=aircraftList().find(x=>idOf(x)===id);if(!a||!window.map)return;const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return;map.setView([lat,lon],Math.max(map.getZoom(),13));setTimeout(()=>{try{let opened=false;map.eachLayer(layer=>{if(opened||!layer||typeof layer.getLatLng!=='function'||typeof layer.openPopup!=='function')return;const lid=String(layer._v286AdsbId||layer._v285AdsbId||layer._adsbId||'').toLowerCase();const ll=layer.getLatLng&&layer.getLatLng();if(lid===id||(ll&&Math.abs(ll.lat-lat)<0.0005&&Math.abs(ll.lng-lon)<0.0005)){opened=true;try{layer.openPopup()}catch(_){}}});}catch(_){ }},260)}catch(_){ }}
  function patchStatusDropdown(){try{if(window._v288StatusPatched)return;window._v288StatusPatched=true;const oldToggle=window.toggleStatusDropdown;window.toggleStatusDropdown=function(type,ev){if(String(type||'').toLowerCase()==='adsb'){try{if(ev){ev.preventDefault&&ev.preventDefault();ev.stopPropagation&&ev.stopPropagation()}}catch(_){ }showAdsbDropdown(ev);return false}return typeof oldToggle==='function'?oldToggle.apply(this,arguments):false};const oldRender=window.renderStatusDropdown;window.renderStatusDropdown=function(type){if(String(type||'').toLowerCase()==='adsb')return renderAdsbDropdown();return typeof oldRender==='function'?oldRender.apply(this,arguments):undefined};document.addEventListener('click',ev=>{const head=ev.target&&ev.target.closest&&ev.target.closest('.status-adsb-head.v288 [data-sort]');if(head){ev.preventDefault();ev.stopPropagation();const k=head.dataset.sort;if(sortKey===k)sortDir*=-1;else{sortKey=k;sortDir=1}renderAdsbDropdown();return}const row=ev.target&&ev.target.closest&&ev.target.closest('.status-adsb-row.v288[data-adsb-id]');if(row){ev.preventDefault();ev.stopPropagation();focusAircraft(row.dataset.adsbId);}},true)}catch(_){ }}
  function patchPopupContent(){try{if(!window.L||window._v288PopupPatched)return;window._v288PopupPatched=true;const oldSet=L.Popup&&L.Popup.prototype&&L.Popup.prototype.setContent;if(oldSet){L.Popup.prototype.setContent=function(content){try{if(typeof content==='string'&&content.indexOf('adsb-popup')!==-1){const src=this._source;let a=src&&src._v286AdsbAircraft;if(!a&&src&&src.getLatLng){const ll=src.getLatLng();let best=null,bestD=Infinity;for(const x of aircraftList()){const la=Number(x.lat),lo=Number(x.lon);if(!Number.isFinite(la)||!Number.isFinite(lo))continue;const d=Math.abs(la-ll.lat)+Math.abs(lo-ll.lng);if(d<bestD){best=x;bestD=d}}if(best&&bestD<0.03)a=best}if(a){normalize(a);content=content.replace(/<b>Class<\/b><span>.*?<\/span>/i,'<b>Class</b><span>'+esc(classLabel(a.category,a))+'</span>');if(content.indexOf('<b>Aircraft Type</b>')<0)content=content.replace(/<b>Class<\/b><span>.*?<\/span>/i,'<b>Class</b><span>'+esc(classLabel(a.category,a))+'</span><b>Aircraft Type</b><span>'+esc(a.is_helo?'Helicopter':'Airplane')+'</span>')}}}catch(_){ }return oldSet.call(this,content)}}}catch(_){ }}
  function addCss(){try{if(q('#v288AdsbStatusStyle'))return;const st=document.createElement('style');st.id='v288AdsbStatusStyle';st.textContent=`
    .status-adsb-head.v287{display:none!important;}
