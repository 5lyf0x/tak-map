  function qa(sel,root){try{return Array.from((root||document).querySelectorAll(sel))}catch(_){return []}}
  function field(id){try{return document.getElementById(id)}catch(_){return null}}
  function esc(s){return String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
  function setIteration(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V})}catch(_){} }
  function getMap(){try{if(window.takLeafletMap&&window.takLeafletMap.addLayer)return window.takLeafletMap}catch(_){}try{if(typeof map!=='undefined'&&map&&map.addLayer){window.takLeafletMap=map;return map}}catch(_){}try{if(window.map&&window.map.addLayer){window.takLeafletMap=window.map;return window.map}}catch(_){}return null}
  function idOf(a){try{return String((a&&(a.id||a.hex||a.icao||a.uid||a.registration||a.callsign||a.flight))||'').replace(/^ICAO-/i,'').trim().toLowerCase()}catch(_){return ''}}
  function titleOf(a){try{return String((a&&(a.callsign||a.flight||a.registration||a.hex||a.icao||a.id||a.uid))||'ADS-B').replace(/^ICAO-/i,'').trim()||'ADS-B'}catch(_){return 'ADS-B'}}
  function aircraftList(){try{return (Array.isArray(window.v298StableAdsb)?window.v298StableAdsb:(Array.isArray(window._v296StableAdsb)?window._v296StableAdsb:(Array.isArray(window._v294StableAdsb)?window._v294StableAdsb:(Array.isArray(window.lastAircraft)?window.lastAircraft:[])))).filter(Boolean)}catch(_){return []}}
  function findAircraft(id){id=String(id||'').toLowerCase();return aircraftList().find(a=>idOf(a)===id)||null}
  function titleMatch(t){t=String(t||'').replace(/^ICAO-/i,'').trim().toLowerCase();if(!t)return null;return aircraftList().find(a=>titleOf(a).toLowerCase()===t||idOf(a)===t)||null}
  function idFromButton(btn){try{let id=String(btn&&btn.dataset&&btn.dataset.adsbTrackId||'').replace(/^ICAO-/i,'').trim().toLowerCase();if(id)return id;const row=btn&&btn.closest&&btn.closest('[data-adsb-id]');id=String(row&&row.getAttribute('data-adsb-id')||'').replace(/^ICAO-/i,'').trim().toLowerCase();if(id)return id;const pop=btn&&btn.closest&&btn.closest('.leaflet-popup');const h=pop&&q('.adsb-popup h3,.feature-popup h3,h3',pop);const a=titleMatch(h&&h.textContent);id=idOf(a);if(id)return id;try{if(typeof selectedAircraftId!=='undefined'&&selectedAircraftId)return String(selectedAircraftId).toLowerCase()}catch(_){}return ''}catch(_){return ''}}
  function pointFrom(a){const lat=Number(a&&a.lat),lon=Number(a&&a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return null;let alt=Number(a&&(a.altitude_ft??a.alt_baro??a.alt_geom));if(!Number.isFinite(alt)||String(a&&(a.altitude_ft??a.alt_baro??a.alt_geom)).toLowerCase()==='ground')alt=0;return {lat,lon,alt,t:Date.now()}}
  function rad(x){return x*Math.PI/180}
  function meters(pts){let m=0;pts=pts||[];for(let i=1;i<pts.length;i++){const a=pts[i-1],b=pts[i];if(!a||!b)continue;const R=6371008.8,dLat=rad(b.lat-a.lat),dLon=rad(b.lon-a.lon),la1=rad(a.lat),la2=rad(b.lat);const h=Math.sin(dLat/2)**2+Math.cos(la1)*Math.cos(la2)*Math.sin(dLon/2)**2;m+=2*R*Math.asin(Math.min(1,Math.sqrt(h)));}return m}
  function distText(m){m=Number(m)||0;return (m/1609.344).toFixed(1)+'mi/'+(m/1000).toFixed(1)+'km'}
  function clean(s){return String(s||'ADS-B Track').replace(/[\\/:*?"<>|]+/g,'-').replace(/\s+/g,' ').trim()||'ADS-B Track'}
  function ensureLayers(){const m=getMap();if(!m||!window.L)return null;let g=window[TRACK_LAYER];if(!g){g=L.layerGroup().addTo(m);window[TRACK_LAYER]=g}else if(!m.hasLayer(g))g.addTo(m);let l=window[LABEL_LAYER];if(!l){l=L.layerGroup().addTo(m);window[LABEL_LAYER]=l}else if(!m.hasLayer(l))l.addTo(m);return {map:m,track:g,label:l}}
  function clearVisual(){try{const layers=ensureLayers();if(layers){layers.track.clearLayers();layers.label.clearLayers()}state.line=null;state.label=null}catch(_){} }
  function syncButtons(){try{qa('.adsb-track-btn').forEach(btn=>{let id=String(btn.dataset.adsbTrackId||'').toLowerCase();if(!id){id=idFromButton(btn);if(id)btn.dataset.adsbTrackId=id}const on=!!(state.id&&id===state.id);btn.classList.toggle('active',on);btn.classList.toggle('tracking',on);btn.setAttribute('aria-pressed',on?'true':'false');const light=q('.adsb-track-light',btn);if(light)light.classList.toggle('active',on)})}catch(_){} }
  function redraw(){try{const layers=ensureLayers();if(!layers)return;layers.track.clearLayers();layers.label.clearLayers();const ll=state.points.map(p=>[p.lat,p.lon]);if(ll.length>=2){state.line=L.polyline(ll,{color:COLOR,weight:4,opacity:.98,lineCap:'round',lineJoin:'round',interactive:false}).addTo(layers.track);try{state.line.bringToFront()}catch(_){}}if(ll.length>=1){const txt=distText(meters(state.points));state.label=L.marker(ll[ll.length-1],{interactive:false,zIndexOffset:1800,icon:L.divIcon({className:'adsb-track-distance-label-wrap',html:'<div class="adsb-track-distance-label v301">'+esc(txt)+'</div>',iconAnchor:[0,0]})}).addTo(layers.label)}syncButtons()}catch(e){try{console.warn('v301 ADS-B track redraw failed',e)}catch(_){} }}
  function addPoint(a){try{if(!state.id||!a||idOf(a)!==state.id)return false;const p=pointFrom(a);if(!p)return false;const pts=state.points;const last=pts[pts.length-1];if(last){const d=meters([last,p]);if(d<2)return false}pts.push(p);if(pts.length>LIMIT)pts.splice(0,pts.length-LIMIT);redraw();return true}catch(_){return false}}
