}if(msg)msg.textContent=\'Saved to Local Data → Routes\'}\n  function closeSaveDialog(){const d=byId(\'adsbTrackSaveDialog\');if(d)d.remove()}\n  function showSaveDialog(id,meta,pts){try{closeSaveDialog();pts=(pts||[]).slice();const meters=distMeters(pts);const name=safeName(titleOf(meta,id)+\' ADS-B Track \'+new Date().toISOString().slice(0,19).replace(/[T:]/g,\'-\'));const can=pts.length>=2;const div=document.createElement(\'div\');div.id=\'adsbTrackSaveDialog\';div.className=\'adsb-track-save-overlay\';div.innerHTML=\'<div class="adsb-track-save-card" role="dialog" aria-modal="true"><button type="button" class="adsb-track-save-x" data-action="discard">×</button><div class="adsb-track-save-title">Save ADS-B Track</div><div class="adsb-track-save-sub">\'+esc(titleOf(meta,id))+\' · \'+esc(distText(meters))+\' · \'+esc(String(pts.length))+\' pts</div><input id="adsbTrackRouteName" class="adsb-track-save-input" value="\'+esc(name)+\'" \'+(can?\'\':\'disabled\')+\' />\'+(can?\'\':\'<div class="adsb-track-save-error">At least 2 track points are required to save a route.</div>\')+\'<div id="adsbTrackSaveMsg" class="adsb-track-save-msg"></div><div class="adsb-track-save-actions"><button type="button" class="layer-button" data-action="discard">Discard</button><button type="button" class="layer-button primary" data-action="save" \'+(can?\'\':\'disabled\')+\'>Save</button></div></div>\';document.body.appendChild(div);div.addEventListener(\'click\',function(ev){const a=ev.target&&ev.target.getAttribute&&ev.target.getAttribute(\'data-action\');if(a===\'discard\'||ev.target===div){ev.preventDefault();closeSaveDialog();clearTrackVisual();return}if(a===\'save\'&&can){ev.preventDefault();const msg=byId(\'adsbTrackSaveMsg\');if(msg)msg.textContent=\'Saving…\';saveRoute((byId(\'adsbTrackRouteName\')||{}).value||name,id,meta,pts,msg).then(function(){setTimeout(function(){closeSaveDialog();clearTrackVisual()},650)}).catch(function(e){if(msg){msg.textContent=\'Save failed: \'+String(e&