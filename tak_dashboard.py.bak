# --- TAK Map v320 popup/data/drawing/terrain/adsb fixes ---
try:
    import re as _v320_re

    def _v320_versions(_html):
        if not isinstance(_html, str):
            return _html
        # Keep release at v1.1.0, only advance the iteration marker.
        for _old in ('v319','v318','v317'):
            _html = _html.replace(_old, 'v320')
        _html = _v320_re.sub(r'(iteration\s*[=:]\s*["\'])v\d+(\1?)', lambda m: m.group(1)+'v320'+(m.group(2) if len(m.groups())>1 else ''), _html, flags=_v320_re.I)
