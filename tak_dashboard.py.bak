# --- TAK Map v323 Viewshed direct owner + ADS-B Option C popup/dropdown + timestamp cleanup ---
try:
    import re as _v323_re

    def _v323_versions(_html):
        if not isinstance(_html, str):
            return _html
        for _old in [f'v{i}' for i in range(230, 323)]:
            _html = _html.replace('TAK-Map/1.1.0 '+_old, 'TAK-Map/1.1.0 v323')
        _html = _v323_re.sub(r'TAK-Map/1\.1\.0\s+v\d+', 'TAK-Map/1.1.0 v323', _html)
        _html = _v323_re.sub(r'(<span class="iteration-(?:chip|marker)"[^>]*>)v\d+(</span>)', r'\1v323\2', _html)
        return _html

    def _v323_patch_html(_html):
        if not isinstance(_html, str):
            return _html

