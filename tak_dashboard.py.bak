  let pollTimer=0,pollDebounce=0,pollBusy=false,interactionUntil=0;function interacting(){return Date.now()<interactionUntil}function markInteraction(){interactionUntil=Date.now()+1000}
  async function pollAdsb(){if(!window._v278AdsbEnabled)return [];if(pollBusy)return window.lastAircraft||[];if(interacting()){schedulePoll(1000);return window.lastAircraft||[]}const c=getCenter();if(!c){status('Set ADS-B center.',true);return []}pollBusy=true;try{const res=await workerFetch(c,radius());window.lastAircraft=res.all||[];try{lastAircraft=window.lastAircraft}catch(_){};status(window.lastAircraft.length+' aircraft');requestAnimationFrame(()=>drawAircraftDiff(window.lastAircraft));return window.lastAircraft}catch(e){status(String(e&&e.message||e).startsWith('HTTP')?'Airplanes.live '+String(e.message||e)+'.':'Airplanes.live client fetch failed.',true);return []}finally{pollBusy=false}}
