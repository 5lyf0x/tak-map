/* v237 critical EUD/ADS-B UI patch */
(function(){
  function uidLike(v){v=String(v||'').trim();return /^ANDROID-/i.test(v)||/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v)}
  function badLabel(v){v=String(v||'').trim();if(!v||uidLike(v))return true;let l=v.toLowerCase();if(['none','null','unknown','atak','itak','wintak','cyan','blue','green','red','yellow','orange','white','black','team'].includes(l))return true;if(/\batak\s*\d+(\.\d+)+/.test(l)||/\bitak\s*\d+(\.\d+)+/.test(l)||/\bwintak\s*\d+(\.\d+)+/.test(l))return true;return false}
  function shortUid(v){v=String(v||'').trim();return v.length>14?v.slice(0,12)+'...':v}
  function eudDisplayName(e){let vals=[e&&e.callsign,e&&e.user_callsign,e&&e.contact_callsign,e&&e.eud_callsign,e&&e.username,e&&e.name];for(const v of vals){if(!badLabel(v))return String(v).trim()}let uid=String((e&&e.uid)||'').trim();return uid?'UID '+shortUid(uid):'TAK Client'}
  window.v236PrettyEud=function(e){let name=eudDisplayName(e);let color=String((e&&e.team_color)||(e&&e.team)||'').trim();let role=String((e&&e.team_role)||(e&&e.role)||'').trim();let cl=String((e&&e.client_label)||[e&&e.client,e&&e.version].filter(Boolean).join(' ')||'').trim();let parts=[color,role,cl].filter(Boolean);return {name,sub:parts.join(' - '),uidFallback:name.startsWith('UID ')} };
  window.fetchEudsForDropdown=async function(){try{const r=await fetch('/api/tak-map/euds?online=1&_='+Date.now(),{cache:'no-store'});const j=await r.json();window.v236EudCache=(j.euds||[]);window.v235EudCache=window.v236EudCache;window.v234EudCache=window.v236EudCache;window.v233EudCache=window.v236EudCache;if(lastBanner){lastBanner.euds_connected=window.v236EudCache.length;renderTopBanner(lastBanner)}return window.v236EudCache}catch(e){return window.v236EudCache||window.v235EudCache||[]}};
  const oldRows=window.statusDropdownRows;
  window.statusDropdownRows=function(type){if(type==='euds')return (window.v236EudCache||window.v235EudCache||[]).map(window.v236PrettyEud);return oldRows?oldRows(type):[]};
  const oldRender=window.renderStatusDropdown;
  window.renderStatusDropdown=function(type){if(type==='euds'&&!(window.v236EudCache||window.v235EudCache||[]).length){const box=document.getElementById('statusDropdown');if(box){box.dataset.type='euds';box.innerHTML='<div class="status-dropdown-title">EUD Callsigns</div><div class="status-dropdown-empty">Loading online EUDs...</div>'}fetchEudsForDropdown().then(()=>{const b=document.getElementById('statusDropdown');if(b&&b.classList.contains('active')&&b.dataset.type==='euds')window.renderStatusDropdown('euds')});return}return oldRender?oldRender(type):undefined};
  function drawAdsbNow(items){try{if(typeof window.drawAircraft==='function')window.drawAircraft(items||[])}catch(e){}}
  window.refreshAdsb=async function(){if(state.live.adsb_aircraft===false)return;try{const r=await fetch('/api/tak-map/adsb?_='+Date.now(),{cache:'no-store'});const j=await r.json();window.lastAdsbSettings=j.settings||window.lastAdsbSettings||config?.adsb?.settings||{};lastAircraft=j.aircraft||[];const el=document.getElementById('adsbStatus');if(el)el.textContent=lastAircraft.length+' active';if(lastBanner){lastBanner.adsb_aircraft=lastAircraft.length;renderTopBanner(lastBanner)}drawAdsbNow(lastAircraft);if(terrain3DActive)refreshTerrain3DObjects(true,'adsb-refresh');return lastAircraft}catch(e){const el=document.getElementById('adsbStatus');if(el)el.textContent='error';return []}};
  function boot(){try{fetchEudsForDropdown();setInterval(fetchEudsForDropdown,10000);if(state&&state.live&&state.live.adsb_aircraft!==false)refreshAdsb()}catch(e){}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,500));else setTimeout(boot,500);
})();
/* end v237 critical patch */


/* v238 UI fixes: EUD rows, ADS-B local-only settings, finalized ADS-B icons, drawing menu visibility */
(function(){
  function escHtml(v){try{return (typeof E==='function'?E(v):String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])))}catch(_){return String(v??'')}}
  function shortVersion(v){v=String(v||'').trim();return v.includes('(')?v.split('(',1)[0].trim():v}
  function uidLike(v){v=String(v||'').trim();return /^ANDROID-/i.test(v)||/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v)}
  function cleanCallsign(e){const vals=[e&&e.callsign,e&&e.user_callsign,e&&e.contact_callsign,e&&e.eud_callsign,e&&e.username,e&&e.name];for(const raw of vals){let v=String(raw||'').trim();if(!v||uidLike(v))continue;let l=v.toLowerCase();if(['none','null','unknown','atak','itak','wintak','orange','blue','green','red','yellow','white','black','team'].includes(l))continue;if(/\batak\b.*\d+\.\d+/i.test(v))continue;if(/tak[-_]?dash|tak[-_]?dashboard/i.test(v))continue;return v}let uid=String((e&&e.uid)||'').trim();return uid?'UID '+(uid.length>14?uid.slice(0,12)+'...':uid):'TAK Client'}
  window.v238PrettyEud=function(e){const cs=cleanCallsign(e);const color=String((e&&e.team_color)||(e&&e.team)||'').trim();const role=String((e&&e.team_role)||(e&&e.role)||'').trim();const client=String((e&&e.client)||'').trim();const ver=shortVersion((e&&e.version_short)||(e&&e.version)||'');const cv=String((e&&e.client_label_short)||[client,ver].filter(Boolean).join(' ')||shortVersion((e&&e.client_label)||'')).trim();const parts=[color,role,cv].filter(Boolean);return {name:cs+(parts.length?': '+parts.join(' - '):''),sub:'',uidFallback:cs.startsWith('UID ')} }
  const oldRows=window.statusDropdownRows;
  window.statusDropdownRows=function(type){if(type==='euds')return (window.v236EudCache||window.v235EudCache||window.v234EudCache||[]).map(window.v238PrettyEud);return oldRows?oldRows(type):[]}
  const oldRender=window.renderStatusDropdown;
  window.renderStatusDropdown=function(type){if(type==='euds'){const box=document.getElementById('statusDropdown');const rows=window.statusDropdownRows('euds');if(box&&box.classList.contains('active')){box.dataset.type='euds';box.classList.remove('adsb-table');let html='<div class="status-dropdown-title">EUD Callsigns</div>';html+=rows.length?rows.map(r=>'<div class="status-dropdown-row"><span class="status-dropdown-name '+(r.uidFallback?'uid-fallback':'')+'">'+escHtml(r.name)+'</span></div>').join(''):'<div class="status-dropdown-empty">No online EUDs.</div>';box.innerHTML=html;return}}return oldRender?oldRender(type):undefined}
  // ADS-B altitude display sanitizer.
  window.v238AdsbAltValue=function(a){let n=Number(a&&a.altitude_ft);if(!Number.isFinite(n))return null;if(Math.abs(n)>=900000||n<-2000||n>100000)return null;return n}
  window.adsbAltText=function(a){let n=window.v238AdsbAltValue(a);return n==null?'Unknown':(Math.round(n)+' ft')}
  const oldPopup=window.adsbPopupHtml;
  window.adsbPopupHtml=function(ac){try{const crs=typeof adsbCourse==='function'?adsbCourse(ac):{deg:null,source:'track'};const gs=typeof adsbGroundSpeed==='function'?adsbGroundSpeed(ac):{kt:0};const alt=window.adsbAltText(ac);return `<div class="feature-popup adsb-popup"><h3>${escHtml(ac&& (ac.callsign||ac.id)||'ADS-B aircraft')}</h3><div class="kvp"><b>ICAO/UID</b><span>${escHtml(ac&&(ac.id||ac.uid)||'—')}</span><b>Class</b><span>${aircraftIsMilitary(ac)?'Friendly military':'Civil / commercial'} · ${aircraftIsHelicopter(ac)?'Helicopter':'Airplane'}</span><b>Altitude</b><span>${escHtml(alt)}</span><b>Groundspeed</b><span>${escHtml(gs.kt||'—')} kt</span><b>Track/Course</b><span>${crs.deg==null?'No track/course':escHtml(Math.round(crs.deg)+'° from '+crs.source+(crs.headingOnly?' (heading only)':''))}</span><b>Coordinates</b><span>${escHtml(formatCoords(ac.lat,ac.lon))}</span><b>Source</b><span>${escHtml(ac.source||'ADS-B')}</span><b>Updated</b><span>${escHtml(ac.updated||'—')}</span></div></div>`}catch(e){return oldPopup?oldPopup(ac):''}}
  function adsbKey(a){return String(a&& (a.id||a.icao||a.hex||a.uid||a.callsign)||'')}
  function adsbClass(ac){return {mil:!!aircraftIsMilitary(ac), heli:!!aircraftIsHelicopter(ac)}}
  function v238AircraftSvg(ac, deg){const c=adsbClass(ac);const color=c.mil?'#1692ff':'#25d66e';const ring=c.mil?`<circle cx="22" cy="22" r="17" fill="rgba(4,8,12,.90)" stroke="${color}" stroke-width="5.2" stroke-dasharray="13 5"/>`:`<circle cx="22" cy="22" r="17" fill="rgba(4,8,12,.90)" stroke="${color}" stroke-width="5.0"/><circle cx="22" cy="22" r="19.5" fill="none" stroke="${color}" stroke-width="1.1" opacity=".45"/>`;const jet=`<path d="M22 4 L28 23 L39 30 L27 31 L23 42 L21 42 L17 31 L5 30 L16 23 Z" fill="${color}" stroke="rgba(0,0,0,.75)" stroke-width=".65"/><path d="M22 31 L14 40 M22 31 L30 40" stroke="${color}" stroke-width="2.4" stroke-linecap="round"/>`;const plane=`<path d="M22 5 L25.5 22 L37 27.5 L25.5 30 L22 41 L18.5 30 L7 27.5 L18.5 22 Z" fill="${color}" stroke="rgba(0,0,0,.75)" stroke-width=".65"/><path d="M22 31 L15.5 40 M22 31 L28.5 40" stroke="${color}" stroke-width="2.2" stroke-linecap="round"/>`;const heli=`<path d="M6 13.5 H38" stroke="${color}" stroke-width="4.1" stroke-linecap="round"/><path d="M22 5 V30" stroke="${color}" stroke-width="3.2" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.8" ry="5.5" fill="${color}" stroke="rgba(0,0,0,.75)" stroke-width=".75"/><path d="M12 34 H32 M22 30 V39" stroke="${color}" stroke-width="2.65" stroke-linecap="round"/>`;const glyph=c.heli?heli:(c.mil?jet:plane);return `<svg class="aircraft-glyph" width="44" height="54" viewBox="0 0 44 54">${ring}<g transform="rotate(${Number.isFinite(Number(deg))?Number(deg):0} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="${color}"/>${glyph}</g><circle cx="22" cy="50" r="3.3" fill="${color}"/></svg>`}
  window.v238AircraftSvg=v238AircraftSvg;
  window.aircraftIcon=function(ac){const id=adsbKey(ac);const selected=id&&id===selectedAircraftId?' selected':'';const deg=Number.isFinite(Number(ac&&ac.track_deg))?Number(ac.track_deg):0;const cls=(aircraftIsMilitary(ac)?'aircraft-military':'aircraft-civil')+(aircraftIsHelicopter(ac)?' aircraft-rotor':' aircraft-fixed');const label=escHtml(ac&& (ac.callsign||ac.id)||'');return L.divIcon({className:'',html:`<div class="aircraft-wrap v238-adsb ${cls}${selected}">${v238AircraftSvg(ac,deg)}<div class="aircraft-label">${label}</div></div>`,iconSize:[96,60],iconAnchor:[48,25]})}
  try{aircraftIcon=window.aircraftIcon}catch(_){ }
  window.aircraftBillboardDataUrl=function(military,heli,deg,color){const fake={type:military?'a-f-A':'a-n-A',category:heli?'helicopter':'fixed',track_deg:deg,description:heli?'helicopter':'fixed'};const svg=v238AircraftSvg(fake,deg||0);return 'data:image/svg+xml;charset=utf-8,'+encodeURIComponent(svg)}
  window.drawAircraft=function(items){if(terrain3DActive)return;aircraftLayer.clearLayers();window.v238AircraftLayersById={};window.v236AircraftLayersById=window.v238AircraftLayersById;try{clearSearchSource('aircraft')}catch(_){};for(const ac of items||[]){if(ac.lat==null||ac.lon==null)continue;const id=adsbKey(ac);const m=L.marker([ac.lat,ac.lon],{icon:window.aircraftIcon(ac),autoPan:false}).addTo(aircraftLayer);window.v238AircraftLayersById[id]=m;m.bindPopup(window.adsbPopupHtml(ac),{autoPan:false,closeButton:true,className:'tak-object-popup adsb-object-popup'});try{if(typeof stabilizeLayerPopup==='function')stabilizeLayerPopup(m)}catch(_){};m.on('click',ev=>{try{L.DomEvent.stopPropagation(ev);selectedAircraftId=id;m.setIcon(window.aircraftIcon(ac));m.openPopup()}catch(_){}});try{addSearchItem('aircraft','ADS-B '+(aircraftIsMilitary(ac)?'military':'civil'),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}catch(_){}}try{handleMapSearch()}catch(_){}}
  window.focusAdsbAircraft=function(id){try{id=decodeURIComponent(String(id||''));const ac=(lastAircraft||[]).find(a=>adsbKey(a)===id);if(!ac||ac.lat==null||ac.lon==null)return;selectedAircraftId=adsbKey(ac);map.setView([Number(ac.lat),Number(ac.lon)],Math.max(map.getZoom(),12),{animate:true});setTimeout(()=>{try{window.drawAircraft(lastAircraft||[]);const m=window.v238AircraftLayersById&&window.v238AircraftLayersById[selectedAircraftId];if(m)m.openPopup()}catch(_){}} ,220)}catch(_){}}
  // ADS-B settings are local-only: remove Apply-to-OTS remnants and hide any stale button.
  function v238LocalizeAdsbSettings(){try{document.querySelectorAll('button').forEach(b=>{if((b.textContent||'').trim()==='Apply to OTS')b.remove()});document.querySelectorAll('.panel-body .muted').forEach(el=>{if((el.textContent||'').includes('config.yml')&&(el.textContent||'').includes('OTS'))el.textContent='TAK Map-side ADS-B display filter only. Does not modify OTS config.yml.'})}catch(_){}}
  const oldSave=window.saveAdsbSettings;
  window.saveAdsbSettings=function(applyToOts){return oldSave?oldSave(false):undefined}
  // Drawing submenu/options visibility containment.
  function closeDrawMenus(){const m=document.getElementById('drawToolMenu');if(m)m.classList.remove('active','open');const p=document.getElementById('drawOptionsPanel');if(p)p.classList.remove('active','open')}
  window.v238CloseDrawMenus=closeDrawMenus;
  const oldToggleDraw=window.v233ToggleDrawMenu;
  window.v233ToggleDrawMenu=function(ev){try{ev&&ev.stopPropagation&&ev.stopPropagation();const m=document.getElementById('drawToolMenu');if(!m)return;if(m.classList.contains('active')||m.classList.contains('open')){m.classList.remove('active','open');return}m.classList.add('active','open');m.style.right='54px';m.style.left='auto';m.style.top='0';}catch(e){if(oldToggleDraw)oldToggleDraw(ev)}}
  const oldStartDraw=window.v233StartDraw;
  window.v233StartDraw=function(mode){try{const m=document.getElementById('drawToolMenu');if(m)m.classList.remove('active','open')}catch(_){};return oldStartDraw?oldStartDraw(mode):undefined}
  const oldSet=window.setActiveMapTool;
  window.setActiveMapTool=function(tool){const r=oldSet?oldSet(tool):undefined;try{if((tool||'move')!=='draw')closeDrawMenus()}catch(_){}return r}
  function injectV238Css(){if(document.getElementById('v238Style'))return;document.head.insertAdjacentHTML('beforeend',`<style id="v238Style">#drawToolMenu.draw-icon-menu{display:none!important;position:absolute!important;right:54px!important;left:auto!important;top:0!important}#drawToolMenu.draw-icon-menu.active,#drawToolMenu.draw-icon-menu.open{display:grid!important}.draw-options-panel:not(.active):not(.open){display:none!important}.aircraft-wrap.v238-adsb .aircraft-glyph{filter:drop-shadow(0 0 6px rgba(0,0,0,.85)) drop-shadow(0 0 8px currentColor)}.aircraft-wrap.v238-adsb.aircraft-civil{color:#25d66e}.aircraft-wrap.v238-adsb.aircraft-military{color:#1692ff}.status-dropdown-row .status-dropdown-name{white-space:nowrap}.adsb-apply-row{gap:6px}.adsb-popup .kvp span{color:#edf5fa!important}</style>`)}
  function after(){injectV238Css();v238LocalizeAdsbSettings();try{if(window.v236EudCache&&document.getElementById('statusDropdown')?.dataset?.type==='euds')window.renderStatusDropdown('euds')}catch(_){} }
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(after,600));else setTimeout(after,600);setTimeout(after,1800);
})();
/* end v238 patch */
</script></body></html>'''


class Handler(BaseHTTPRequestHandler):
    server_version='TAKDashboard/2.01'
    def log_message(self,fmt,*args): print('%s - - [%s] %s'%(self.client_address[0],self.log_date_time_string(),fmt%args))

    def _client_ip(self):
        xff=(self.headers.get('X-Forwarded-For') or '').split(',')[0].strip()
        return xff or (self.client_address[0] if self.client_address else '')

    def _cookies(self):
        out={}
        raw=self.headers.get('Cookie') or ''
        for part in raw.split(';'):
            if '=' in part:
                k,v=part.split('=',1)
                out[k.strip()]=v.strip()
        return out

    def _dashboard_token(self):
        return self._cookies().get(DASH_COOKIE_NAME,'')

    def _current_session(self):
        return get_dashboard_session(self._dashboard_token())

    def _auth_ok(self):
        return bool(self._current_session())

    def _session_cookie(self, token, max_age=None):
        if max_age is None:
            max_age = DASH_SESSION_TTL_SECONDS
        return f"{DASH_COOKIE_NAME}={token}; Path=/; Max-Age={int(max_age)}; HttpOnly; Secure; SameSite=Lax"

    def _clear_session_cookie(self):
        return f"{DASH_COOKIE_NAME}=; Path=/; Max-Age=0; HttpOnly; Secure; SameSite=Lax"

    def _tak_map_token(self):
        return self._cookies().get(TAK_MAP_COOKIE_NAME,'')

    def _tak_map_session(self):
        return get_tak_map_session(self._tak_map_token())

    def _tak_map_auth_ok(self):
        return bool(self._tak_map_session())

    def _tak_map_session_cookie(self, token, max_age=None):
        if max_age is None:
            max_age = TAK_MAP_SESSION_TTL_SECONDS
        return f"{TAK_MAP_COOKIE_NAME}={token}; Path=/; Max-Age={int(max_age)}; HttpOnly; Secure; SameSite=Lax"

    def _clear_tak_map_session_cookie(self):
        return f"{TAK_MAP_COOKIE_NAME}=; Path=/; Max-Age=0; HttpOnly; Secure; SameSite=Lax"

    def _require_tak_map_login(self):
        parsed=urlparse(self.path)
        if parsed.path.startswith('/api/tak-map/'):
            return self._send_json({'ok':False,'auth_required':True,'error':'TAK Map login required.'},401)
        return self._redirect('/tak-map/login')

    def _redirect(self, location, headers=None):
        self.send_response(302)
        self.send_header('Location', location)
        self.send_header('Cache-Control','no-store')
        for k,v in (headers or {}).items():
            self.send_header(k,v)
        self.end_headers()

    def _send_html(self, body, code=200, headers=None):
        data=str(body).encode()
        self.send_response(code)
        self.send_header('Content-Type','text/html; charset=utf-8')
        self.send_header('Cache-Control','no-store')
        self.send_header('Content-Length',str(len(data)))
        for k,v in (headers or {}).items():
            self.send_header(k,v)
        self.end_headers(); self.wfile.write(data)

    def _require_auth(self):
        parsed=urlparse(self.path)
        if parsed.path.startswith('/api/'):
            return self._send_json({'ok':False,'auth_required':True,'error':'Dashboard login required.'},401)
        next_path=self.path if self.path.startswith('/') else '/'
        return self._redirect('/login?next='+quote(next_path, safe=''))

    def _send_json(self,data,code=200,headers=None):
        try:
            safe=json_safe(data)
            body=json.dumps(safe,indent=2).encode()
        except Exception as e:
            body=json.dumps({'ok':False,'error':'JSON response serialization failed: '+str(e)}).encode()
            code=500
        try:
            self.send_response(code); self.send_header('Content-Type','application/json'); self.send_header('Cache-Control','no-store'); self.send_header('Content-Length',str(len(body)))
            for k,v in (headers or {}).items(): self.send_header(k,v)
            self.end_headers(); self.wfile.write(body)
        except (BrokenPipeError, ConnectionResetError, ConnectionAbortedError):
            return

    def _send_text(self, text, status=200):
        self.send_response(status); self.send_header('Content-Type','text/plain'); self.end_headers(); self.wfile.write(str(text).encode())

    def _is_secure_request(self):
        proto = (self.headers.get('X-Forwarded-Proto') or '').split(',')[0].strip().lower()
        if proto == 'https':
            return True
        # Direct TLS support is not normally used here; Nginx should set X-Forwarded-Proto.
        return False

    def _upload_auth_allowed(self):
        return ALLOW_INSECURE_UPLOAD_AUTH or self._is_secure_request()

    def _handle_dashboard_login(self):
        if not self._is_secure_request():
            return self._send_json({'ok':False,'error':'Dashboard login requires HTTPS on port 9443.'},403)
        f = self._read_form()
        username = sanitize_linux_username(f.get('computer') or f.get('username',''))
        password = f.get('technology') or f.get('password','')
        client_ip = self._client_ip()
        locked, remaining, count = login_lockout_status(username, client_ip)
        if locked:
            mins = max(1, int((remaining + 59)//60))
            return self._send_json({'ok':False,'error':f'Too many failed login attempts. Try again in about {mins} minute(s).','locked':True,'retry_after_seconds':remaining},429)
        ok, msg, home = authenticate_linux_user(username, password)
        password = None
        if not ok:
            record_login_failure(username, client_ip)
            locked2, remaining2, count2 = login_lockout_status(username, client_ip)
            if locked2:
                return self._send_json({'ok':False,'error':'Too many failed login attempts. Login is locked for 30 minutes.','locked':True,'retry_after_seconds':remaining2},429)
            left = max(0, DASH_LOGIN_FAIL_LIMIT - int(count2 or 0))
            return self._send_json({'ok':False,'error':(msg or 'Login failed.') + (f' Attempts remaining: {left}.' if left else '')},401)
        admin_ok, admin_msg, admin_groups = is_dashboard_admin_user(username)
        if not admin_ok:
            # Authentication succeeded, but authorization failed. Do not count
            # this as a password failure/lockout event; show the detected group
            # details so local admin-group configuration can be fixed quickly.
            return self._send_json({'ok':False,'error':admin_msg,'admin_required':True,'groups':admin_groups},403)
        clear_login_failures(username, client_ip)
        token = create_dashboard_session(username, home)
        return self._send_json({'ok':True,'username':username,'expires_in':DASH_SESSION_TTL_SECONDS},200,headers={'Set-Cookie':self._session_cookie(token)})

    def _handle_dashboard_logout(self):
        destroy_dashboard_session(self._dashboard_token())
        return self._send_json({'ok':True},200,headers={'Set-Cookie':self._clear_session_cookie()})

    def _handle_tak_map_login(self):
        if not self._is_secure_request() and not ALLOW_INSECURE_UPLOAD_AUTH:
            return self._send_json({'ok':False,'error':'TAK Map login requires HTTPS on port 9443.'},403)
        f=self._read_form()
        username=sanitize_ots_username(f.get('username',''))
        password=f.get('password','')
        try:
            ok,msg=authenticate_opentak_admin(username,password)
        except Exception as e:
            traceback.print_exc()
            password=None
            return self._send_json({'ok':False,'error':'TAK Map OpenTAKServer auth error: '+str(e),'admin_required':True},500)
        if not ok:
            password=None
            return self._send_json({'ok':False,'error':msg,'admin_required':True},403)
        token=create_tak_map_session(username, password)
        password=None
        return self._send_json({'ok':True,'username':username,'expires_in':TAK_MAP_SESSION_TTL_SECONDS},200,headers={'Set-Cookie':self._tak_map_session_cookie(token)})

    def _handle_tak_map_logout(self):
        destroy_tak_map_session(self._tak_map_token())
        return self._send_json({'ok':True},200,headers={'Set-Cookie':self._clear_tak_map_session_cookie()})

    def _handle_upload_login(self):
        if not self._upload_auth_allowed():
            return self._send_json({'ok':False,'error':'File upload login requires HTTPS. Use the Nginx HTTPS proxy or set TAK_DASH_ALLOW_INSECURE_UPLOAD_AUTH=true for trusted lab use only.'},403)
        f = self._read_form()
        username = sanitize_linux_username(f.get('username',''))
        password = f.get('password','')
        ok, msg, home = authenticate_linux_user(username, password)
        password = None
        if not ok:
            return self._send_json({'ok':False,'error':msg},401)
        token = create_upload_session(username, home)
        return self._send_json({'ok':True,'username':username,'token':token,'expires_in':UPLOAD_SESSION_TTL_SECONDS,'destinations':upload_destinations_for_user(username, home)})

    def _handle_file_upload(self):
        if not self._upload_auth_allowed():
            return self._send_json({'ok':False,'error':'File upload requires HTTPS.'},403)
        clen = int(self.headers.get('Content-Length','0') or 0)
        if clen <= 0:
            return self._send_json({'ok':False,'error':'No upload data received.'},400)
        if clen > UPLOAD_LIMIT_BYTES:
            return self._send_json({'ok':False,'error':f'Upload exceeds {UPLOAD_LIMIT_MB} MB limit.'},413)
        parsed = urlparse(self.path)
        q = parse_qs(parsed.query or '')
        token = (q.get('token') or [''])[0]
        dest = str((q.get('destination') or [''])[0]).strip()
        original = safe_upload_filename((q.get('filename') or ['upload.bin'])[0])
        sess = get_upload_session(token)
        if not sess:
            return self._send_json({'ok':False,'error':'Upload session expired. Unlock uploads again.'},401)
        dest_item = None
        for item in upload_destinations_for_user(sess['username'], sess['home']):
            if item.get('id') == dest:
                dest_item = item
                break
        if not dest_item:
            return self._send_json({'ok':False,'error':'Invalid upload destination.'},400)
        dest_path = sanitize_upload_destination_path(dest_item.get('path',''))
        if not dest_path:
            return self._send_json({'ok':False,'error':'Invalid upload destination path.'},400)
        UPLOAD_STAGING_DIR.mkdir(parents=True, exist_ok=True)
        os.chmod(UPLOAD_STAGING_DIR, 0o750)
        staging_name = f"{int(time.time())}-{secrets.token_hex(8)}-{original}"
        staging_path = UPLOAD_STAGING_DIR / staging_name
        written = 0
        try:
            with open(staging_path, 'wb') as out:
                remaining = clen
                while remaining > 0:
                    chunk = self.rfile.read(min(1024*1024, remaining))
                    if not chunk:
                        break
                    written += len(chunk)
                    remaining -= len(chunk)
                    out.write(chunk)
            if written != clen:
                try: staging_path.unlink()
                except Exception: pass
                return self._send_json({'ok':False,'error':'Upload ended before all bytes were received.'},400)
            os.chmod(staging_path, 0o640)
            cmd=['sudo','/usr/local/sbin/tak-map-action','upload-file',sess['username'],dest_path,staging_name,original]
            r=run_cmd(cmd,120)
            if not r.get('ok'):
                try: staging_path.unlink()
                except Exception: pass
                return self._send_json({'ok':False,'error':r.get('stderr') or r.get('stdout') or 'Failed to place uploaded file.'},500)
            final_path=(r.get('stdout') or '').strip().splitlines()[-1] if (r.get('stdout') or '').strip() else ''
            return self._send_json({'ok':True,'username':sess['username'],'destination':dest,'file':{'filename':original,'size_bytes':written,'path':final_path}})
        except Exception as e:
            try: staging_path.unlink()
            except Exception: pass
            return self._send_json({'ok':False,'error':'Upload failed while saving file.'},500)


    def _handle_config_backup_download(self):
        cmd=['sudo','-n','/usr/local/sbin/tak-map-action','config-backup']
        r=run_cmd(cmd,60)
        if not r.get('ok'):
            r['command']='Create dashboard config backup'
            return self._send_json(r,500)
        path=''
        for line in (r.get('stdout') or '').splitlines():
            if line.startswith('BACKUP_PATH='):
                path=line.split('=',1)[1].strip()
        if not path:
            # Backward-compatible fallback: last stdout line.
            path=(r.get('stdout') or '').strip().splitlines()[-1].strip() if (r.get('stdout') or '').strip() else ''
        fp=Path(path)
        if not fp.exists() or not fp.is_file():
            return self._send_json({'ok':False,'error':'Backup was created but file could not be read by dashboard.','stdout':r.get('stdout',''),'stderr':r.get('stderr',''),'path':path},500)
        body=fp.read_bytes()
        fn=fp.name
        self.send_response(200)
        self.send_header('Content-Type','application/zip')
        self.send_header('Content-Disposition',f'attachment; filename="{fn}"')
        self.send_header('Cache-Control','no-store')
        self.send_header('Content-Length',str(len(body)))
        self.end_headers(); self.wfile.write(body)

    def _handle_config_restore_upload(self):
        clen=int(self.headers.get('Content-Length','0') or '0')
        if clen <= 0:
            return self._send_json({'ok':False,'error':'No backup file uploaded.'},400)
        if clen > 25*1024*1024:
            return self._send_json({'ok':False,'error':'Backup file is too large.'},413)
        UPLOAD_STAGING_DIR.mkdir(parents=True, exist_ok=True)
        original=safe_upload_filename(self.headers.get('X-Backup-Filename') or 'config-backup.zip')
        staging=UPLOAD_STAGING_DIR / f"restore-{int(time.time())}-{secrets.token_hex(8)}-{original}"
        try:
            with open(staging,'wb') as f:
                remaining=clen
                while remaining>0:
                    chunk=self.rfile.read(min(1024*1024, remaining))
                    if not chunk:
                        break
                    f.write(chunk); remaining-=len(chunk)
            if staging.stat().st_size != clen:
                try: staging.unlink()
                except Exception: pass
                return self._send_json({'ok':False,'error':'Upload ended before all bytes were received.'},400)
            os.chmod(staging,0o640)
            cmd=['sudo','-n','/usr/local/sbin/tak-map-action','config-restore',str(staging)]
            r=run_cmd(cmd,90); r['command']='Restore dashboard config backup'
            r['message']='Restore complete. Restart the dashboard if environment-file changes should take effect.' if r.get('ok') else 'Restore failed. No changes should be applied unless stdout says otherwise.'
            try: staging.unlink()
            except Exception: pass
            return self._send_json(r,200 if r.get('ok') else 500)
        except Exception as e:
            try: staging.unlink()
            except Exception: pass
            return self._send_json({'ok':False,'error':'Restore upload failed: '+str(e)},500)

    def _handle_config_post(self):
        f=self._read_form()
        action=f.get('action','')
        cfg=load_runtime_config()

        if action=='add_zt':
            ip=sanitize_host_value(f.get('ip',''))
            callsign=str(f.get('callsign') or ip).strip()[:80]
            if not ip:
                return self._send_json({'ok':False,'error':'Invalid IP/host value'},400)
            peers=[p for p in cfg.get('zerotier_devices',[]) if p.get('ip')!=ip]
            peers.append({'ip':ip,'callsign':callsign or ip})
            cfg['zerotier_devices']=peers
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='remove_zt':
            ip=sanitize_host_value(f.get('ip',''))
            cfg['zerotier_devices']=[p for p in cfg.get('zerotier_devices',[]) if p.get('ip')!=ip]
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='add_service':
            svc=sanitize_service_name(f.get('service',''))
            if not svc:
                return self._send_json({'ok':False,'error':'Invalid service name'},400)
            services=cfg.get('services',[])
            if svc not in services:
                services.append(svc)
            cfg['services']=services
            req=cfg.get('required_services',[])
            if f.get('required','true').lower() in ('1','true','yes','on') and svc not in req:
                req.append(svc)
            cfg['required_services']=req
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='remove_service':
            svc=sanitize_service_name(f.get('service',''))
            cfg['services']=[s for s in cfg.get('services',[]) if s!=svc]
            cfg['required_services']=[s for s in cfg.get('required_services',[]) if s!=svc]
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='add_command':
            label=sanitize_command_label(f.get('label',''))
            command=sanitize_command_text(f.get('command',''))
            if not label or not command:
                return self._send_json({'ok':False,'error':'Button label and command are required'},400)
            commands=migrate_custom_commands(cfg.get('custom_commands', normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS)))
            cid=make_command_id(label, command)
            existing={c.get('id') for c in commands}
            if cid in existing:
                cid=make_command_id(label, command + str(time.time()))
            commands.append({'id':cid,'label':label,'category':'Custom','description':'Custom command.','command':command})
            cfg['custom_commands']=commands
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='remove_command':
            cid=str(f.get('id','')).strip()
            if is_default_command_id(cid):
                hidden = normalize_deleted_default_command_ids(cfg.get('deleted_default_command_ids', []))
                if cid not in hidden:
                    hidden.append(cid)
                cfg['deleted_default_command_ids'] = hidden
                cfg['custom_commands'] = migrate_custom_commands(cfg.get('custom_commands', normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS)), ensure_defaults=True)
            else:
                cfg['custom_commands']=[c for c in cfg.get('custom_commands',[]) if c.get('id')!=cid]
                if not cfg['custom_commands']:
                    cfg['custom_commands']=[]
            saved = save_runtime_config(cfg)
            return self._send_json({'ok':True,'config':saved,'custom_commands':effective_custom_commands()})

        if action=='restore_default_commands':
            cfg['custom_commands'] = migrate_custom_commands(cfg.get('custom_commands', normalize_custom_commands(DEFAULT_CUSTOM_COMMANDS)), ensure_defaults=True)
            cfg['deleted_default_command_ids'] = []
            saved = save_runtime_config(cfg)
            return self._send_json({'ok':True,'config':saved,'custom_commands':effective_custom_commands()})

        if action=='set_neighbor_hostname':
            key=str(f.get('key','')).strip()[:180]
            hostname=sanitize_neighbor_hostname(f.get('hostname',''))
            if not key:
                return self._send_json({'ok':False,'error':'Invalid neighbor key'},400)
            labels=normalize_neighbor_hostnames(cfg.get('neighbor_hostnames',{}))
            if hostname:
                labels[key]=hostname
            elif key in labels:
                labels.pop(key,None)
            cfg['neighbor_hostnames']=labels
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})


        if action=='add_upload_destination':
            label=sanitize_upload_destination_label(f.get('label',''))
            path=sanitize_upload_destination_path(f.get('path',''))
            if not label or not path:
                return self._send_json({'ok':False,'error':'Destination label and path are required'},400)
            dests=normalize_upload_destinations(cfg.get('upload_destinations', normalize_upload_destinations(DEFAULT_UPLOAD_DESTINATIONS)))
            did=make_upload_destination_id(label,path)
            existing={d.get('id') for d in dests}
            if did in existing:
                did=make_upload_destination_id(label, path + str(time.time()))
            dests.append({'id':did,'label':label,'path':path})
            cfg['upload_destinations']=dests
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='remove_upload_destination':
            did=str(f.get('id','')).strip()
            if did in ('desktop','downloads','home'):
                return self._send_json({'ok':False,'error':'Default upload destinations cannot be removed'},400)
            cfg['upload_destinations']=[d for d in normalize_upload_destinations(cfg.get('upload_destinations',[])) if d.get('id')!=did]
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='set_required_service':
            svc=sanitize_service_name(f.get('service',''))
            if not svc or svc not in cfg.get('services',[]):
                return self._send_json({'ok':False,'error':'Invalid service name'},400)
            enabled=str(f.get('enabled','')).lower() in ('1','true','yes','on')
            req=normalize_services(cfg.get('required_services',[]))
            if enabled and svc not in req:
                req.append(svc)
            if not enabled:
                req=[s for s in req if s!=svc]
            cfg['required_services']=req
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        if action=='set_warning':
            key=str(f.get('key','')).strip()
            if key not in DEFAULT_WARNING_SETTINGS:
                return self._send_json({'ok':False,'error':'Invalid warning key'},400)
            enabled=str(f.get('enabled','')).lower() in ('1','true','yes','on')
            warnings=cfg.get('warning_settings',dict(DEFAULT_WARNING_SETTINGS))
            warnings[key]=enabled
            cfg['warning_settings']=warnings
            return self._send_json({'ok':True,'config':save_runtime_config(cfg)})

        return self._send_json({'ok':False,'error':'Invalid config action'},400)


    def _read_form(self):
        n=int(self.headers.get('Content-Length','0')); raw=self.rfile.read(n).decode() if n else ''; return {k:v[0] for k,v in parse_qs(raw).items()}
    def do_GET(self):
        parsed=urlparse(self.path)
        if parsed.path=='/login':
            if self._auth_ok():
                q=parse_qs(parsed.query or '')
                nxt=(q.get('next') or ['/'])[0]
                return self._redirect(nxt if str(nxt).startswith('/') else '/')
            return self._send_html(LOGIN_HTML)
        if parsed.path=='/ca-cert.crt':
            if not self._auth_ok():
                return self._require_dashboard_login()
            if not CA_CERT_FILE.exists():
                return self._send_json({'ok':False,'error':'CA certificate has not been generated yet.'},404)
            body=CA_CERT_FILE.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/x-x509-ca-cert'); self.send_header('Content-Disposition','attachment; filename="takdash-local-ca.crt"'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if parsed.path=='/lockscreen-bg.png':
            fp=LOCKSCREEN_IMAGE_FILE
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/lockscreen/tactical-topo-swaylock-1920x1080.png')
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','image/png'); self.send_header('Cache-Control','no-store'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if parsed.path=='/tak-map-logo.png':
            fp=TAK_MAP_LOGO_FILE
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/lockscreen/tak-map-logo.png')
            if not fp.exists():
                fp=Path(__file__).resolve().parent/'assets'/'lockscreen'/'tak-map-logo.png'
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','image/png'); self.send_header('Cache-Control','no-store'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return

        m_adsb_asset=re.match(r'^/assets/adsb/([A-Za-z0-9._-]+\.png)$', parsed.path)
        if m_adsb_asset:
            name=m_adsb_asset.group(1)
            aliases={
                'adsb_civil_fixed.png':'adsb_civ_fixed.png',
                'adsb_civil_rotor.png':'adsb_civ_helo.png',
                'adsb_civil_helo.png':'adsb_civ_helo.png',
                'adsb_military_fixed.png':'adsb_mil_fixed.png',
                'adsb_military_rotor.png':'adsb_mil_helo.png',
                'adsb_military_helo.png':'adsb_mil_helo.png',
                'adsb_gov_rotor.png':'adsb_gov_helo.png',
                'adsb_unknown_fixed.png':'adsb_unk_fixed.png',
                'adsb_unknown_rotor.png':'adsb_unk_helo.png',
                'adsb_unknown_helo.png':'adsb_unk_helo.png',
            }
            name=aliases.get(name, name)
            fp=Path(__file__).resolve().parent/'assets'/'adsb'/name
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/adsb')/name
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','image/png'); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        m_vendor_asset=re.match(r'^/assets/vendor/([A-Za-z0-9._-]+\.js)$', parsed.path)
        if m_vendor_asset:
            name=m_vendor_asset.group(1)
            fp=Path(__file__).resolve().parent/'assets'/'vendor'/name
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/vendor')/name
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/javascript; charset=utf-8'); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        m_mil2525=re.match(r'^/mil2525/svg/([A-Za-z0-9._-]+\.svg)$', parsed.path)
        if m_mil2525:
            fp=Path(__file__).resolve().parent/'assets'/'mil2525'/'svg'/m_mil2525.group(1)
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/mil2525/svg')/m_mil2525.group(1)
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','image/svg+xml; charset=utf-8'); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if parsed.path=='/mil2525/icons.json':
            fp=Path(__file__).resolve().parent/'assets'/'mil2525'/'icons.json'
            if not fp.exists():
                fp=Path('/usr/share/tak-server-dash/mil2525/icons.json')
            if not fp.exists():
                self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/json'); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        m_fileshare_xml=re.match(r'^/api/tak-map/fileshare-mapsource/([A-Fa-f0-9]{64})/([^/]+\.xml)$', parsed.path)
        if m_fileshare_xml:
            sha=m_fileshare_xml.group(1).lower()
            requested_name=unquote(m_fileshare_xml.group(2)) or (sha + '.xml')
            candidates=[]
            try:
                candidates.extend(sorted(TAK_MAP_OFFLINE_PACKAGE_DIR.glob('*.xml'), key=lambda x: x.stat().st_mtime, reverse=True))
            except Exception:
                pass
            target=None
            for fp in candidates:
                try:
                    if fp and fp.exists() and fp.is_file():
                        h=hashlib.sha256(fp.read_bytes()).hexdigest().lower()
                        if h == sha:
                            target=fp; break
                except Exception:
                    continue
            if not target:
                self.send_response(404); self.send_header('Content-Type','text/plain; charset=utf-8'); self.send_header('Cache-Control','no-store'); self.end_headers(); self.wfile.write(b'Mapsource XML not found'); return
            try:
                body=target.read_bytes()
            except Exception:
                self.send_response(500); self.send_header('Content-Type','text/plain; charset=utf-8'); self.send_header('Cache-Control','no-store'); self.end_headers(); self.wfile.write(b'Could not read mapsource XML'); return
            self.send_response(200)
            self.send_header('Content-Type','application/xml; charset=utf-8')
            self.send_header('Content-Disposition', 'attachment; filename="' + requested_name.replace('"','') + '"')
            self.send_header('Cache-Control','no-store')
            self.send_header('Content-Length',str(len(body)))
            self.end_headers()
            if getattr(self, 'command', 'GET') != 'HEAD':
                self.wfile.write(body)
            return
        m_fileshare_pkg=re.match(r'^/api/tak-map/fileshare-package/([A-Fa-f0-9]{64})/([^/]+\.zip)$', parsed.path)
        if m_fileshare_pkg:
            sha=m_fileshare_pkg.group(1).lower()
            requested_name=unquote(m_fileshare_pkg.group(2)) or (sha + '.zip')
            candidates=[]
            try:
                candidates.append(_ots_upload_folder()/(sha + '.zip'))
            except Exception:
                pass
            try:
                candidates.extend(sorted(TAK_MAP_OFFLINE_PACKAGE_DIR.glob('*.zip'), key=lambda x: x.stat().st_mtime, reverse=True))
            except Exception:
                pass
            target=None
            for fp in candidates:
                try:
                    if fp and fp.exists() and fp.is_file():
                        if fp.name == sha + '.zip':
                            target=fp; break
                        h=hashlib.sha256(fp.read_bytes()).hexdigest().lower()
                        if h == sha:
                            target=fp; break
                except Exception:
                    continue
            if not target:
                self.send_response(404); self.send_header('Content-Type','text/plain; charset=utf-8'); self.send_header('Cache-Control','no-store'); self.end_headers(); self.wfile.write(b'Fileshare package not found'); return
            try:
                body=target.read_bytes()
            except Exception:
                self.send_response(500); self.send_header('Content-Type','text/plain; charset=utf-8'); self.send_header('Cache-Control','no-store'); self.end_headers(); self.wfile.write(b'Could not read fileshare package'); return
            self.send_response(200)
            self.send_header('Content-Type','application/zip')
            self.send_header('Content-Disposition', 'attachment; filename="' + requested_name.replace('"','') + '"')
            self.send_header('Cache-Control','no-store')
            self.send_header('Content-Length',str(len(body)))
            self.end_headers()
            if getattr(self, 'command', 'GET') != 'HEAD':
                self.wfile.write(body)
            return
        m_live_tile=re.match(r'^/api/tak-map/live-tile/([^/]+)/(\d+)/(\d+)/(\d+)\.(?:png|jpg|jpeg|webp)$', parsed.path)
        if m_live_tile:
            data,ctype,err=tak_map_live_tile(unquote(m_live_tile.group(1)), int(m_live_tile.group(2)), int(m_live_tile.group(3)), int(m_live_tile.group(4)))
            if not data:
                self.send_response(404); self.send_header('Content-Type','text/plain; charset=utf-8'); self.send_header('Cache-Control','public, max-age=60'); self.end_headers(); self.wfile.write((err or 'Tile not found').encode()); return
            self.send_response(200); self.send_header('Content-Type',ctype); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(data))); self.end_headers(); self.wfile.write(data); return
        # v216: allow this narrow basemap preference save without TAK Map session auth.
        # It stores only a validated basemap id, fixing browsers/reverse proxies that
        # dropped the HttpOnly TAK Map session cookie on image/beacon saves.
        if parsed.path in ('/api/tak-map/basemap-save','/api/tak-map/basemap.gif','/api/tak-map/preferences-save'):
            res=tak_map_preferences_save_public_from_query(parsed.query or '')
            if parsed.path.endswith('.gif') or (parse_qs(parsed.query or '').get('img') or [''])[0]=='1':
                # 1x1 transparent GIF, so an <img> beacon definitely completes.
                body=base64.b64decode('R0lGODlhAQABAPAAAP///wAAACH5BAAAAAAALAAAAAABAAEAAAICRAEAOw==')
                self.send_response(200 if res.get('ok') else 400)
                self.send_header('Content-Type','image/gif')
                self.send_header('Cache-Control','no-store')
                self.send_header('Content-Length',str(len(body)))
                self.end_headers(); self.wfile.write(body); return
            return self._send_json(res, 200 if res.get('ok') else 400)
        if parsed.path=='/tak-map/login':
            if self._tak_map_auth_ok():
                return self._redirect('/tak-map')
            return self._send_html(TAK_MAP_LOGIN_HTML)
        if parsed.path=='/tak-map':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_html(TAK_MAP_HTML)
        if parsed.path=='/api/tak-map/config':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_config())
        if parsed.path=='/api/tak-map/preferences-save':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            payload={'last_basemap':(q.get('last_basemap') or q.get('basemap') or [''])[0], 'ts':(q.get('ts') or [''])[0]}
            return self._send_json(tak_map_preferences_update(payload))
        if parsed.path=='/api/tak-map/preferences-debug':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            prefs=_load_tak_map_prefs()
            return self._send_json({'ok':True,'prefs':prefs,'config_preview':tak_map_config(),'canonical':str(TAK_MAP_PREFS_FILE),'compat':str(TAK_MAP_PREFS_FILE_COMPAT),'canonical_exists':TAK_MAP_PREFS_FILE.exists(),'compat_exists':TAK_MAP_PREFS_FILE_COMPAT.exists()})
        if parsed.path=='/api/tak-map/data-packages':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_data_packages())
        if parsed.path=='/api/tak-map/data-sync':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_data_sync())
        if parsed.path=='/api/tak-map/routes':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            try:
                return self._send_json(tak_map_routes())
            except Exception as e:
                return self._send_json({'ok':True,'routes':[],'roots':[],'scanner':'disabled'})
        if parsed.path in ('/api/tak-map/imported','/api/tak-map/import'):
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_imported())
        if parsed.path=='/api/tak-map/offline-maps':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_offline_maps())
        if parsed.path=='/api/tak-map/offline-jobs':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            return self._send_json(tak_map_offline_job_status((q.get('id') or [''])[0]))
        m_offtile=re.match(r'^/api/tak-map/offline-tile/([^/]+)/(\d+)/(\d+)/(\d+)\.(?:png|jpg|jpeg|webp)$', parsed.path)
        if m_offtile:
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            data,ctype=_mbtiles_tile_bytes(unquote(m_offtile.group(1)), int(m_offtile.group(2)), int(m_offtile.group(3)), int(m_offtile.group(4)))
            if not data:
                self.send_response(404); self.send_header('Cache-Control','public, max-age=120'); self.end_headers(); return
            self.send_response(200); self.send_header('Content-Type',ctype); self.send_header('Cache-Control','public, max-age=86400'); self.send_header('Content-Length',str(len(data))); self.end_headers(); self.wfile.write(data); return
        if parsed.path=='/api/tak-map/offline-package':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            pid=(q.get('id') or [''])[0]
            fp=_offline_package_path(pid)
            if not fp:
                return self._send_json({'ok':False,'error':'Offline EUD package not found.'},404)
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/zip'); self.send_header('Content-Disposition',f'attachment; filename="{fp.name}"'); self.send_header('Cache-Control','no-store'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if parsed.path=='/api/tak-map/adsb':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_adsb())
        if parsed.path=='/api/tak-map/adsb-settings':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json({'ok':True,'settings':_load_adsb_settings()})
        if parsed.path=='/api/tak-map/cot':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_cot_markers())
        if parsed.path=='/api/tak-map/euds':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            online_only=str((q.get('online') or q.get('send') or q.get('fresh') or ['0'])[0]).lower() in ('1','true','yes','on')
            data=tak_map_euds()
            if online_only:
                data['euds']=[e for e in (data.get('euds') or []) if _is_online_send_eud(e)]
                data['online_only']=True
            return self._send_json(data)
        if parsed.path=='/api/tak-map/status-banner':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            return self._send_json(tak_map_status_banner())
        if parsed.path=='/api/tak-map/offline-send-status':
            if not self._tak_map_auth_ok():
                return self._require_tak_map_login()
            q=parse_qs(parsed.query or '')
            return self._send_json(tak_map_offline_send_status((q.get('id') or [''])[0]))
        if not self._auth_ok(): return self._require_auth()
        if self.path=='/' or self.path.startswith('/?'):
            body=INDEX_HTML.encode(); self.send_response(200); self.send_header('Content-Type','text/html; charset=utf-8'); self.send_header('Cache-Control','no-store'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if parsed.path=='/api/status':
            q=parse_qs(parsed.query or '')
            include_ipv6=str((q.get('include_ipv6') or ['0'])[0]).lower() in ('1','true','yes','on')
            return self._send_json(get_status(include_ipv6))
        if parsed.path=='/api/cert-status':
            return self._send_json(get_cert_status())
        if parsed.path=='/api/upload-browse':
            q=parse_qs(parsed.query or '')
            token=(q.get('token') or [''])[0]
            path_spec=(q.get('path') or ['~'])[0]
            sess=get_upload_session(token)
            if not sess:
                return self._send_json({'ok':False,'error':'Upload session expired. Unlock uploads again.'},401)
            return self._send_json(browse_upload_directory_for_session(sess, path_spec))
        if parsed.path=='/api/config-backup':
            return self._handle_config_backup_download()
        if self.path=='/api/config': return self._send_json(load_runtime_config())
        if self.path=='/api/command-history': return self._send_json(grouped_command_history())
        if self.path=='/api/topology-layout': return self._send_json(load_json_file(TOPOLOGY_LAYOUT_FILE,{}))
        if self.path=='/command-history.zip':
            body=command_history_zip_bytes(); self.send_response(200); self.send_header('Content-Type','application/zip'); self.send_header('Content-Disposition','attachment; filename="tak-server-dash-command-history.zip"'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        if self.path.startswith('/diagnostics/'):
            fn=os.path.basename(self.path.split('/diagnostics/',1)[1].split('?',1)[0]); fp=DIAG_DIR/fn
            if not fp.exists() or not fp.is_file(): self.send_response(404); self.end_headers(); return
            body=fp.read_bytes(); self.send_response(200); self.send_header('Content-Type','application/gzip'); self.send_header('Content-Disposition',f'attachment; filename="{fn}"'); self.send_header('Content-Length',str(len(body))); self.end_headers(); self.wfile.write(body); return
        self.send_response(404); self.end_headers()
    def do_HEAD(self):
        return self.do_GET()
    def do_POST(self):
        if self.path=='/api/login':
            return self._handle_dashboard_login()
        if self.path=='/api/logout':
            return self._handle_dashboard_logout()
        if self.path=='/api/tak-map/login':
            return self._handle_tak_map_login()
        if self.path=='/api/tak-map/logout':
            return self._handle_tak_map_logout()
        if self.path.startswith('/api/tak-map/') and not self._tak_map_auth_ok():
            return self._require_tak_map_login()
        if self.path=='/api/tak-map/preferences':
            payload=_read_json_body(self)
            return self._send_json(tak_map_preferences_update(payload))
        if self.path=='/api/tak-map/popup-edit':
            payload=_read_json_body(self)
            return self._send_json(tak_map_popup_edit_update(payload))
        if self.path=='/api/tak-map/import':
            return handle_tak_map_import_upload(self)
        if self.path=='/api/tak-map/local-data-delete':
            payload=_read_json_body(self)
            return self._send_json(tak_map_local_data_delete(payload.get('ids') or []))
        if self.path=='/api/tak-map/local-data-mission-publish':
            try:
                payload=_read_json_body(self)
                return self._send_json(tak_map_local_data_mission_publish(payload.get('ids') or [], payload.get('kind') or '', payload.get('missionName') or payload.get('mission') or '', payload.get('serverHost') or ''))
            except Exception as e:
                return self._send_json({'ok':False,'error':'Local Data Mission publish failed before a JSON response could be created: '+str(e),'traceback':traceback.format_exc()},500)
        if self.path=='/api/tak-map/import-clear':
            return self._send_json(tak_map_clear_imports())
        if self.path=='/api/tak-map/offline-upload':
            return handle_tak_map_offline_upload(self)
        if self.path=='/api/tak-map/offline-estimate':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_download_estimate(payload))
        if self.path=='/api/tak-map/offline-download':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_download_start(payload))
        if self.path=='/api/tak-map/offline-control':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_job_control(payload.get('id'), payload.get('action')))
        if self.path=='/api/tak-map/offline-resume':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_resume(payload.get('id')))
        if self.path=='/api/tak-map/offline-delete':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_delete(payload.get('id')))
        if self.path=='/api/tak-map/offline-eud-package':
            payload=_read_json_body(self)
            return self._send_json(tak_map_offline_eud_package(payload.get('id')))
        if self.path=='/api/tak-map/offline-send':
            try:
                payload=_read_json_body(self)
                return self._send_json(tak_map_offline_send(payload.get('id'), payload.get('targets') or [], payload.get('serverHost') or ''))
            except Exception as e:
                return self._send_json({'ok':False,'error':'Offline map send failed before a JSON response could be created: '+str(e)},500)
        if self.path=='/api/tak-map/offline-mission-publish':
            try:
                payload=_read_json_body(self)
                return self._send_json(tak_map_offline_mission_publish(payload.get('id'), payload.get('missionName') or payload.get('mission') or '', payload.get('serverHost') or ''))
            except Exception as e:
                return self._send_json({'ok':False,'error':'Offline map Data Sync publish failed before a JSON response could be created: '+str(e),'traceback':traceback.format_exc()},500)
        if self.path=='/api/tak-map/adsb-settings':
            try:
                payload=_read_json_body(self)
                return self._send_json(_save_adsb_settings(payload, self._tak_map_session()))
            except Exception as e:
                return self._send_json({'ok':False,'error':'ADS-B settings update failed: '+str(e)},500)
        if self.path=='/api/tak-map/live-basemap-source-send':
            try:
                payload=_read_json_body(self)
                return self._send_json(tak_map_live_basemap_source_send(payload.get('basemap_id'), payload.get('targets') or [], payload.get('dashboardOrigin') or '', payload.get('serverHost') or ''))
            except Exception as e:
                return self._send_json({'ok':False,'error':'Live basemap send failed before a JSON response could be created: '+str(e)},500)
        if self.path=='/api/tak-map/live-basemap-source-mission-publish':
            try:
                payload=_read_json_body(self)
                return self._send_json(tak_map_live_basemap_source_mission_publish(payload.get('basemap_id'), payload.get('missionName') or payload.get('mission') or '', payload.get('dashboardOrigin') or '', payload.get('serverHost') or ''))
            except Exception as e:
                return self._send_json({'ok':False,'error':'Live basemap Data Sync publish failed before a JSON response could be created: '+str(e),'traceback':traceback.format_exc()},500)
        if not self._auth_ok(): return self._require_auth()
        if self.path=='/api/cert-setup':
            f=self._read_form(); extra=str(f.get('extra_sans',''))[:1000]; exclude=str(f.get('exclude_sans',''))[:1000]
            cmd=['sudo','/usr/local/sbin/tak-map-action','cert-setup',extra,exclude]
            r=run_cmd(cmd,60); r['command']='Generate TAK Server Dash local HTTPS certificate'; return self._send_json(r)
        if self.path=='/api/config':
            return self._handle_config_post()
        if self.path=='/api/config-restore':
            return self._handle_config_restore_upload()
        if self.path=='/api/upload-login':
            return self._handle_upload_login()
        if urlparse(self.path).path=='/api/upload-file':
            return self._handle_file_upload()

        if self.path=='/api/topology-layout':
            n=int(self.headers.get('Content-Length','0') or '0')
            raw=self.rfile.read(n).decode('utf-8','replace') if n else '{}'
            try:
                payload=json.loads(raw or '{}')
            except Exception:
                return self._send_json({'ok':False,'error':'Invalid JSON'},400)
            action=str(payload.get('action') or 'save')
            if action=='reset':
                atomic_write_json(TOPOLOGY_LAYOUT_FILE,{})
                return self._send_json({'ok':True,'layout':{}})
            if action!='save':
                return self._send_json({'ok':False,'error':'Invalid topology layout action'},400)
            positions=payload.get('positions') or {}
            if not isinstance(positions,dict):
                return self._send_json({'ok':False,'error':'positions must be an object'},400)
            clean={}
            for k,v in positions.items():
                key=re.sub(r'[^A-Za-z0-9_.:@-]+','_',str(k or '').strip())[:96]
                if not key or not isinstance(v,dict):
                    continue
                try:
                    x=max(0,min(2000,float(v.get('x',0))))
                    y=max(0,min(2000,float(v.get('y',0))))
                except Exception:
                    continue
                clean[key]={'x':round(x,1),'y':round(y,1)}
            atomic_write_json(TOPOLOGY_LAYOUT_FILE, clean)
            return self._send_json({'ok':True,'layout':clean})

        if self.path=='/api/topology-scan':
            cmd=['sudo','-n','/usr/local/sbin/tak-map-action','topology-scan']
            r=run_cmd(cmd,180)
            r['command']='Scan topology details'
            scan=None
            if r.get('stdout'):
                try:
                    scan=json.loads(r.get('stdout') or '{}')
                except Exception as e:
                    r['stderr']=(r.get('stderr') or '')+'\nFailed to parse topology scan JSON: '+str(e)
            if scan and isinstance(scan,dict):
                scan.setdefault('timestamp', int(time.time()))
                atomic_write_json(TOPOLOGY_SCAN_CACHE_FILE, scan)
                return self._send_json({'ok':bool(scan.get('ok', True)),'scan':scan,'rc':r.get('rc'),'stderr':r.get('stderr','')})
            return self._send_json({'ok':False,'error':'Topology scan did not return usable JSON','rc':r.get('rc'),'stdout':r.get('stdout',''),'stderr':r.get('stderr','')},500)
        if self.path=='/api/command':
            f=self._read_form(); cid=str(f.get('id','')).strip(); return self._send_json(run_remote_command(cid))
        if self.path=='/api/service':
            f=self._read_form(); svc=f.get('service',''); act=f.get('action','')
            if svc not in effective_services() or act not in ('start','stop','restart'): return self._send_json({'ok':False,'stderr':'Invalid service/action','rc':2},400)
            cmd=['sudo','/usr/local/sbin/tak-map-action','service',act,svc]; r=run_cmd(cmd,45); r['command']=' '.join(cmd); return self._send_json(r)
        if self.path=='/api/dhclient':
            cmd=['sudo','/usr/local/sbin/tak-map-action','dhclient']; r=run_cmd(cmd,90); r['command']='sudo dhclient -v wwan0'; return self._send_json(r)
        if self.path=='/api/modem-gps':
            cmd=['sudo','/usr/local/sbin/tak-map-action','modem-gps']; r=run_cmd(cmd,450)
            stdout=(r.get('stdout') or '').strip()
            stderr=(r.get('stderr') or '').strip()
            payload=None
            if stdout:
                try:
                    payload=json.loads(stdout)
                except Exception:
                    payload=None
            if not isinstance(payload, dict):
                note='GPS wrapper produced no JSON output.' if not stdout else 'GPS wrapper output was not valid JSON.'
                if stderr:
                    note += ' Check STDERR below for the real failure.'
                payload={'ok':False,'status':'GPS pull failed','source':'wrapper','note':note,'stdout':stdout,'stderr':stderr,'rc':r.get('rc'),'attempts':[{'method':'GPS wrapper','ok':False,'note':note,'rc':r.get('rc'),'stdout':stdout[:900],'stderr':stderr[:900]}]}
            payload.setdefault('ok', bool(payload.get('latitude') is not None and payload.get('longitude') is not None))
            payload.setdefault('rc', r.get('rc'))
            payload.setdefault('stdout', stdout)
            payload.setdefault('stderr', stderr)
            payload.setdefault('command', 'Pull Server GPS')
            if not payload.get('attempts'):
                payload['attempts']=[{'method':'GPS wrapper','ok':bool(payload.get('ok')),'note':payload.get('note') or 'No detailed attempts were returned by the wrapper.','rc':r.get('rc'),'stdout':stdout[:900],'stderr':stderr[:900]}]
            return self._send_json(payload)
        if self.path=='/api/modem-gps-push':
            cmd=['sudo','/usr/local/sbin/tak-map-action','modem-gps-push']; r=run_cmd(cmd,520)
            stdout=(r.get('stdout') or '').strip()
            stderr=(r.get('stderr') or '').strip()
            payload=None
            if stdout:
                try:
                    payload=json.loads(stdout)
                except Exception:
                    payload=None
            if not isinstance(payload, dict):
                note='GPS push wrapper produced no JSON output.' if not stdout else 'GPS push wrapper output was not valid JSON.'
                if stderr:
                    note += ' Check STDERR below for the real failure.'
                payload={'ok':False,'status':'GPS push failed','source':'wrapper','note':note,'stdout':stdout,'stderr':stderr,'rc':r.get('rc'),'attempts':[{'method':'GPS push wrapper','ok':False,'note':note,'rc':r.get('rc'),'stdout':stdout[:900],'stderr':stderr[:900]}]}
            payload.setdefault('ok', bool(payload.get('ok')))
            payload.setdefault('rc', r.get('rc'))
            payload.setdefault('stdout', stdout)
            payload.setdefault('stderr', stderr)
            payload.setdefault('command', 'Push Server GPS to TAK Server')
            if not payload.get('attempts'):
                payload['attempts']=[{'method':'GPS push wrapper','ok':bool(payload.get('ok')),'note':payload.get('note') or 'No detailed attempts were returned by the wrapper.','rc':r.get('rc'),'stdout':stdout[:900],'stderr':stderr[:900]}]
            return self._send_json(payload)
        if self.path=='/api/diagnostics':
            cmd=['sudo','/usr/local/sbin/tak-map-action','diagnostics']; r=run_cmd(cmd,90); r['command']='Generate diagnostics bundle on TAK server'
            if r['ok'] and r['stdout']: r['download_url']='/diagnostics/'+os.path.basename(r['stdout'].splitlines()[-1].strip())
            return self._send_json(r)
        if self.path=='/api/system':
            f=self._read_form(); act=f.get('action','')
            if act not in ('reboot','shutdown','lock-screen'): return self._send_json({'ok':False,'stderr':'Invalid system action','rc':2},400)
            cmd=['sudo','/usr/local/sbin/tak-map-action','system',act]; r=run_cmd(cmd,15); r['command']=('Lock TAK server screen' if act=='lock-screen' else f'Schedule TAK server {act}'); return self._send_json(r)
        self.send_response(404); self.end_headers()


# --- v237 critical EUD/ADS-B restore patch ---
def _v236_uid_like(value):
    try:
        return _v233_uid_like(value)
    except Exception:
        v=str(value or '').strip()
        return bool(v.upper().startswith('ANDROID-') or re.match(r'^[0-9a-f]{8}-[0-9a-f-]{27,}$', v, re.I))

def _v236_bad_callsign(value):
    v=str(value or '').strip()
    if not v:
        return True
    vl=v.lower()
    if _v236_uid_like(v):
        return True
    if vl in ('none','null','unknown','tak client','atak','itak','wintak','cyan','blue','green','red','yellow','orange','magenta','white','black','team'):
        return True
    if re.search(r'\batak\s*\d+(?:\.\d+)+', vl) or re.search(r'\bitak\s*\d+(?:\.\d+)+', vl) or re.search(r'\bwintak\s*\d+(?:\.\d+)+', vl):
        return True
    if re.fullmatch(r'(friendly|hostile|neutral|unknown|cyan|blue|green|red|yellow|orange|white|black|purple|magenta)(\s+team)?', vl):
        return True
    return False

def _v236_best_callsign_from_values(*values):
    for v in values:
        if isinstance(v, (list,tuple)):
            c=_v236_best_callsign_from_values(*v)
            if c: return c
            continue
        txt=str(v or '').strip()
        if txt and not _v236_bad_callsign(txt):
            return txt
    return ''

def _v236_explicit_online(row):
    """Return True/False for real connection-state fields, or None when unknown."""
    if not isinstance(row, dict):
        return None
    # Do not treat account active/enabled as connection-online; only connection/session-like columns.
    truth_cols=('online','is_online','connected','is_connected','currently_connected','client_connected','socket_connected','logged_in','is_logged_in','authenticated','session_active','has_connection')
    false_cols=truth_cols
    for c in truth_cols:
        v=_row_ci_get(row, (c,), None)
        if v in (None,''):
            continue
        sv=str(v).strip().lower()
        if sv in ('1','true','yes','y','online','connected','active','authenticated','logged_in','current'):
            return True
        if sv in ('0','false','no','n','offline','disconnected','inactive','logged_out','none'):
            return False
    status=_row_ci_get(row, ('status','connection_status','client_status','state','connection_state','session_status'), None)
    if status not in (None,''):
        sv=str(status).strip().lower()
        if any(x in sv for x in ('online','connected','authenticated','logged in','logged_in','active')) and not any(x in sv for x in ('offline','disconnected','inactive','logged out','logged_out')):
            return True
        if any(x in sv for x in ('offline','disconnected','inactive','logged out','logged_out')):
            return False
    return None

def _v236_row_recent_age(row):
    if not isinstance(row, dict):
        return None, ''
    # Prefer connection/heartbeat fields over generic updated timestamps.
    names=('last_seen','last_seen_at','last_connection','last_connected','last_heartbeat','heartbeat','heartbeat_at','last_ping','last_contact','current_login_at','login_time','connected_at','updated','update_time','start','timestamp')
    best_age=None; best_name=''
    for name in names:
        v=_row_ci_get(row, (name,), None)
        if v in (None,''):
            continue
        age=_age_seconds_from_value(v)
        if age is None:
            continue
        if best_age is None or age < best_age:
            best_age=age; best_name=name
    return best_age, best_name

def _v236_eud_online_window_seconds():
    try:
        # Longer than previous location-only window so a locked ATAK screen does not disappear immediately.
        return max(120, min(3600, int(os.environ.get('TAK_DASH_EUD_ONLINE_SECONDS','900'))))
    except Exception:
        return 900

def _v236_extract_eud_identity_maps(limit=3000):
    """Build UID -> callsign/client/team maps from current TAKV/PLI CoT rows.

    Only TAKV-bearing rows are allowed to update callsigns, so mission points created
    by an ATAK user do not overwrite the EUD callsign with a marker name.
    """
    callsigns={}; client={}; team={}; ages={}
    try:
        uris,_errs=_candidate_ots_pg_uris()
        for uri in uris[:2]:
            rows,err=_pg_table_rows(uri,'cot',limit)
            if err:
                continue
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                xml=str(row.get('xml') or row.get('event') or row.get('detail') or '')
                if '<takv' not in xml.lower():
                    continue
                typ=str(row.get('type') or '')
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')):
                    continue
                parsed=_parse_cot_text_fields(row)
                extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                if not uid:
                    continue
                cs=_v236_best_callsign_from_values(row.get('sender_callsign'), parsed.get('callsign'), extra.get('callsign'))
                age=_age_seconds_from_value(row.get('timestamp') or row.get('start') or row.get('time') or '')
                old_age=ages.get(uid.lower())
                if cs and (old_age is None or age is None or age <= old_age):
                    callsigns[uid.lower()]=cs
                    ages[uid.lower()]=age if age is not None else old_age if old_age is not None else 999999
                if extra.get('client') or extra.get('version'):
                    client[uid.lower()]={'client':extra.get('client') or '', 'version':extra.get('version') or '', 'client_label':' '.join(x for x in (extra.get('client') or '', extra.get('version') or '') if x).strip()}
                if extra.get('team'):
                    team[uid.lower()]=extra.get('team')
            if callsigns or client:
                break
    except Exception:
        pass
    return callsigns, client, team

def _v236_make_eud_record(row, table, callsign_map, client_map, team_map):
    row=row or {}
    parsed=_parse_cot_text_fields(row)
    extra=_parse_takv_and_team(row)
    uid=str(_row_ci_get(row, ('uid','client_uid','clientUid','clientuid','device_uid','cot_uid','sender_uid'), '') or parsed.get('uid') or '').strip()
    row_cs=_row_ci_get(row, ('callsign','call_sign','contact_callsign','eud_callsign','name','username','title','sender_callsign'), '')
    cs=_v236_best_callsign_from_values(row_cs, extra.get('callsign'), parsed.get('callsign'), callsign_map.get(uid.lower() if uid else ''))
    if not uid and not cs:
        return None
    cinfo=client_map.get(uid.lower() if uid else '', {})
    client_name=str(extra.get('client') or _row_ci_get(row, ('platform','client','takv_platform','app','application'), '') or cinfo.get('client') or '').strip()
    version=str(extra.get('version') or _row_ci_get(row, ('version','takv_version','app_version','client_version'), '') or cinfo.get('version') or '').strip()
    client_label=' '.join(x for x in (client_name, version) if x).strip() or cinfo.get('client_label','')
    tm=str(extra.get('team') or _row_ci_get(row, ('team','team_name','group','color','team_color'), '') or team_map.get(uid.lower() if uid else '', '') or '').strip().lower()
    age, age_col=_v236_row_recent_age(row)
    explicit=_v236_explicit_online(row)
    online=False
    if explicit is True:
        online=True
    elif explicit is False:
        online=False
    elif age is not None and age <= _v236_eud_online_window_seconds():
        online=True
    # CoT TAKV rows can be used as live PLI if recent, but euds table connection fields are preferred above.
    if not online:
        return None
    lat=_coerce_float(_row_ci_get(row, ('lat','latitude','point_lat'), None) or parsed.get('lat'))
    lon=_coerce_float(_row_ci_get(row, ('lon','lng','longitude','point_lon'), None) or parsed.get('lon'))
    if not cs:
        cs='UID '+(uid[:12]+'...' if len(uid)>12 else uid) if uid else 'TAK Client'
    return {
        'uid': uid,
        'callsign': cs,
        'user_callsign': cs,
        'client': client_name,
        'version': version,
        'client_label': client_label,
        'team': tm,
        'lat': lat,
        'lon': lon,
        'updated': str(_row_ci_get(row, ('last_seen','last_seen_at','last_connection','last_connected','last_heartbeat','current_login_at','updated','timestamp','start'), '') or ''),
        'location_age_seconds': age,
        'online_age_seconds': age,
        'online_source': ('explicit' if explicit is True else age_col or table),
        'status': 'Online',
        'source': table,
        'online': True,
    }

def tak_map_euds():
    """v237: online EUD list from OTS client/EUD identity tables, with callsign-first display.

    This intentionally does not depend only on recent map-position CoT rows, so a
    locked ATAK screen can remain listed when OTS still has the client online/recent.
    """
    notes=[]; out_by_key={}
    callsign_map, client_map, team_map = _v236_extract_eud_identity_maps()
    uris,cfg_errors=_candidate_ots_pg_uris()
    if cfg_errors:
        notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    for uri in uris[:2]:
        # Main source: OTS EUD/client tables.
        for table in ('euds','eud_stats'):
            rows,err=_pg_table_rows(uri, table, 1500)
            if err:
                continue
            notes.append({'source':'postgres:'+table,'ok':True,'rows':len(rows)})
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                rec=_v236_make_eud_record(row, table, callsign_map, client_map, team_map)
                if not rec:
                    continue
                blob=' '.join(str(rec.get(k) or '') for k in ('uid','callsign','client','client_label','source')).lower()
                if any(x in blob for x in ('webform','ads-b','adsb','aircraft','icao','tak-dashboard','server gps','server_gps')):
                    continue
                key=(rec.get('uid') or rec.get('callsign') or '').lower()
                old=out_by_key.get(key)
                if old is None:
                    out_by_key[key]=rec
                else:
                    # Prefer real callsign and richer client metadata.
                    if _v236_bad_callsign(old.get('callsign')) and not _v236_bad_callsign(rec.get('callsign')):
                        old['callsign']=rec.get('callsign'); old['user_callsign']=rec.get('callsign')
                    for k,v in rec.items():
                        if v not in (None,'') and old.get(k) in (None,''):
                            old[k]=v
        # Fallback: recent TAKV PLI CoT rows only. Does not include mission point rows.
        rows,err=_pg_table_rows(uri,'cot',2000)
        if not err:
            notes.append({'source':'postgres:cot-takv-fallback','ok':True,'rows':len(rows)})
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                xml=str(row.get('xml') or row.get('event') or row.get('detail') or '')
                if '<takv' not in xml.lower():
                    continue
                typ=str(row.get('type') or '')
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')):
                    continue
                age=_age_seconds_from_value(row.get('timestamp') or row.get('start') or '')
                if age is None or age > _v236_eud_online_window_seconds():
                    continue
                parsed=_parse_cot_text_fields(row); extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                cs=_v236_best_callsign_from_values(row.get('sender_callsign'), parsed.get('callsign'), extra.get('callsign'), callsign_map.get(uid.lower() if uid else ''))
                if not uid and not cs:
                    continue
                key=(uid or cs).lower()
                if key in out_by_key:
                    continue
                out_by_key[key]={'uid':uid,'callsign':cs or ('UID '+uid[:12]+'...'),'user_callsign':cs,'client':extra.get('client') or '', 'version':extra.get('version') or '', 'client_label':' '.join(x for x in (extra.get('client') or '', extra.get('version') or '') if x).strip(),'team':extra.get('team') or '', 'lat':_coerce_float(parsed.get('lat')), 'lon':_coerce_float(parsed.get('lon')), 'updated':str(row.get('timestamp') or row.get('start') or ''), 'location_age_seconds':age, 'online_age_seconds':age, 'online_source':'recent TAKV CoT', 'status':'Online', 'source':'cot', 'online':True}
        if out_by_key:
            break
    out=list(out_by_key.values())
    out.sort(key=lambda e: (_v236_bad_callsign(e.get('callsign')), str(e.get('callsign') or '').lower()))
    return {'ok':True,'euds':out,'sources':notes,'online_only':True,'online_seconds':_v236_eud_online_window_seconds(),'callsign_source':'euds/eud_stats plus TAKV CoT map'}

def _v236_valid_adsb(ac):
    try:
        lat=float(ac.get('lat')); lon=float(ac.get('lon'))
        if not (-90 <= lat <= 90 and -180 <= lon <= 180) or (abs(lat)<0.000001 and abs(lon)<0.000001):
            return False
        ac['lat']=lat; ac['lon']=lon
        return True
    except Exception:
        return False

def _v236_adsb_dedupe(candidates):
    seen={}
    for ac in candidates or []:
        if not isinstance(ac, dict) or not _v236_valid_adsb(ac):
            continue
        key=str(ac.get('id') or ac.get('icao') or ac.get('uid') or ac.get('callsign') or '').strip().lower()
        if not key:
            continue
        old=seen.get(key)
        def score(x):
            try: s=float(x.get('seen_seconds'))
            except Exception: s=999999
            age=_age_seconds_from_value(x.get('updated') or x.get('timestamp') or x.get('start') or '')
            if age is None: age=999999
            return min(s, age)
        if old is None or score(ac) < score(old):
            seen[key]=ac
    return list(seen.values())

def tak_map_adsb():
    """v236: restore ADS-B display while keeping lightweight validation/dedupe.

    The previous update-interval+1 filter could hide all OTS-backed aircraft when
    OTS timestamps lag or the feed does not expose seen_seconds. Use strict age
    checks only when the source provides seen_seconds. For OTS CoT/DB rows without
    seen_seconds, keep valid-position aircraft and let the configured radius apply;
    if radius/stale filters would blank the map, fall back to valid deduped aircraft
    rather than showing no ADS-B at all.
    """
    settings=_load_adsb_settings()
    stale_seconds=_adsb_stale_seconds(settings)
    notes=[]; raw=[]
    try:
        pg_aircraft, pg_notes=_ots_pg_aircraft()
        notes.extend(pg_notes)
        for ac in pg_aircraft or []:
            if isinstance(ac, dict):
                cp=dict(ac); cp.setdefault('source','OpenTAKServer ADS-B/CoT'); cp['_ots_db']=True; raw.append(cp)
    except Exception as e:
        notes.append({'source':'postgres:adsb','ok':False,'error':str(e)[:180]})
    for source_name,url in _candidate_aircraft_json_sources():
        data=_read_json_url(url)
        if not isinstance(data,dict):
            notes.append({'source':source_name,'url':url,'ok':False})
            continue
        notes.append({'source':source_name,'url':url,'ok':True})
        for item in data.get('aircraft') or []:
            if not isinstance(item,dict):
                continue
            ac=_normalize_adsb_aircraft(item, source_name)
            if not ac:
                continue
            raw.append(ac)
    candidates=_v236_adsb_dedupe(raw)
    filtered=[]
    for ac in candidates:
        strict_ok=True
        if ac.get('seen_seconds') is not None:
            try:
                if float(ac.get('seen_seconds') or 999999) > stale_seconds:
                    strict_ok=False
            except Exception:
                pass
        # Do not drop OTS DB aircraft only because their database timestamp is older
        # than update_interval+1; OTS often stores ADS-B CoT rows with timestamp lag.
        if strict_ok and _adsb_in_radius(ac, settings):
            filtered.append(ac)
    # Safety fallback: never let a bad center/radius/stale interpretation blank ADS-B completely.
    final=filtered if filtered else candidates
    final=final[:800]
    return {'ok':True,'aircraft':final,'count':len(final),'sources':notes,'stale_seconds':stale_seconds,'settings':settings,'raw_count':len(raw),'deduped_count':len(candidates),'filter_relaxed':bool(candidates and not filtered)}


# --- v237 focused EUD callsign/status and ADS-B stale fix ---
def _v237_ts_is_future(value):
    ts=_parse_ts_epoch(value)
    return ts is not None and ts > time.time()

def _v237_clean_dashboard_identity(value):
    v=str(value or '').strip().lower()
    if not v:
        return False
    return bool(re.match(r'^(tak[-_]?dash|tak[-_]?dashboard)(?:[-_].*)?$', v))

def _v237_platform_is_tak(*values):
    blob=' '.join(str(v or '') for v in values).lower()
    return any(x in blob for x in ('atak','itak','wintak','takv'))

def _v237_extract_eud_maps(limit=3000):
    callsigns={}; client={}; team={}; role={}; stale={}; seen_age={}
    try:
        uris,_errs=_candidate_ots_pg_uris()
        for uri in uris[:2]:
            rows,err=_pg_table_rows(uri,'cot',limit)
            if err:
                continue
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                xml=str(row.get('xml') or '')
                if '<takv' not in xml.lower():
                    continue
                typ=str(row.get('type') or '')
                if _is_aircraft_type(typ, row.get('uid'), row.get('sender_callsign')):
                    continue
                parsed=_parse_cot_text_fields(row)
                extra=_parse_takv_and_team(row)
                uid=str(row.get('sender_uid') or parsed.get('uid') or row.get('uid') or '').strip()
                if not uid:
                    continue
                age=_age_seconds_from_value(row.get('timestamp') or row.get('start') or '')
                old=seen_age.get(uid.lower())
                if old is not None and age is not None and age > old:
                    continue
                cs=_v236_best_callsign_from_values(row.get('sender_callsign'), parsed.get('callsign'), extra.get('callsign'))
                if cs:
                    callsigns[uid.lower()]=cs
                if extra.get('client') or extra.get('version'):
                    client[uid.lower()]={'client':extra.get('client') or '', 'version':extra.get('version') or '', 'client_label':' '.join(x for x in (extra.get('client') or '', extra.get('version') or '') if x).strip()}
                if extra.get('team'):
                    team[uid.lower()]=extra.get('team')
                if extra.get('role'):
                    role[uid.lower()]=extra.get('role')
                if row.get('stale'):
                    stale[uid.lower()]=row.get('stale')
                seen_age[uid.lower()]=age if age is not None else old if old is not None else 999999
            if callsigns or client:
                break
    except Exception:
        pass
    return callsigns, client, team, role, stale

def _v237_eud_record_from_euds_row(row, callsign_map, client_map, team_map, role_map, stale_map):
    row=row or {}
    uid=str(_row_ci_get(row, ('uid','client_uid','clientUid','clientuid','device_uid','cot_uid','sender_uid'), '') or '').strip()
    if not uid:
        return None
    row_cs=_row_ci_get(row, ('callsign','call_sign','contact_callsign','eud_callsign','name','username','title','sender_callsign'), '')
    cs=_v236_best_callsign_from_values(row_cs, callsign_map.get(uid.lower(), ''))
    if not cs:
        cs='UID '+(uid[:12]+'...' if len(uid)>12 else uid)
    blob=' '.join([uid, cs]).lower()
    if _v237_clean_dashboard_identity(cs) or _v237_clean_dashboard_identity(uid):
        return None
    if any(x in blob for x in ('webform','ads-b','adsb','aircraft','icao')):
        return None
    cinfo=client_map.get(uid.lower(), {})
    client_name=str(_row_ci_get(row, ('platform','client','takv_platform','app','application'), '') or cinfo.get('client') or '').strip()
    version=str(_row_ci_get(row, ('version','takv_version','app_version','client_version'), '') or cinfo.get('version') or '').strip()
    if not _v237_platform_is_tak(client_name, version, cinfo.get('client_label')):
        return None
    color=str(_row_ci_get(row, ('team','team_name','group','color','team_color'), '') or team_map.get(uid.lower(), '') or '').strip()
    role=str(_row_ci_get(row, ('team_role','role','group_role'), '') or role_map.get(uid.lower(), '') or '').strip()
    status=str(_row_ci_get(row, ('last_status','status','connection_status','client_status','state'), '') or '').strip()
    is_connected=(status.lower() == 'connected')
    cot_live=_v237_ts_is_future(stale_map.get(uid.lower()))
    if not (is_connected or cot_live):
        return None
    client_label=' '.join(x for x in (client_name, version) if x).strip() or cinfo.get('client_label','')
    return {
        'uid':uid,
        'callsign':cs,
        'user_callsign':cs,
        'contact_callsign':callsign_map.get(uid.lower(), ''),
        'client':client_name,
        'version':version,
        'client_label':client_label,
        'team':color,
        'team_color':color,
        'role':role,
        'team_role':role,
        'updated':str(_row_ci_get(row, ('last_event_time','last_seen','last_seen_at','updated','timestamp','start'), '') or ''),
        'location_age_seconds':_age_seconds_from_value(_row_ci_get(row, ('last_event_time','last_seen','last_seen_at','updated','timestamp','start'), '') or ''),
        'online_source':'last_status' if is_connected else 'cot_stale',
        'status':'Online',
        'last_status':status,
        'source':'euds',
        'online':True,
        'display_line': cs + ': ' + ' - '.join([x for x in (color, role, client_label) if x]),
    }

def tak_map_euds():
    """v237: confirmed OTS logic: euds.callsign + last_status/cot_stale online state."""
    notes=[]; out=[]; seen=set()
    callsign_map, client_map, team_map, role_map, stale_map = _v237_extract_eud_maps()
    uris,cfg_errors=_candidate_ots_pg_uris()
    if cfg_errors:
        notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
    for uri in uris[:2]:
        rows,err=_pg_table_rows(uri,'euds',1500)
        if err:
            notes.append({'source':'postgres:euds','ok':False,'error':err[:180]})
            continue
        notes.append({'source':'postgres:euds','ok':True,'rows':len(rows)})
        for row in rows or []:
            if not isinstance(row, dict):
                continue
            rec=_v237_eud_record_from_euds_row(row, callsign_map, client_map, team_map, role_map, stale_map)
            if not rec:
                continue
            key=(rec.get('uid') or rec.get('callsign') or '').lower()
            if key and key not in seen:
                seen.add(key); out.append(rec)
        break
    out.sort(key=lambda e: str(e.get('callsign') or '').lower())
    return {'ok':True,'euds':out,'sources':notes,'online_only':True,'callsign_source':'euds.callsign fallback latest TAKV contact callsign','online_rule':'euds.last_status=Connected OR latest TAKV cot_stale > now()'}

def _v237_ots_pg_aircraft_direct(limit=1200):
    aircraft=[]; notes=[]
    try:
        uris,cfg_errors=_candidate_ots_pg_uris()
        if cfg_errors:
            notes.extend({'source':'ots-config','ok':False,'error':e} for e in cfg_errors[:3])
        for uri in uris[:2]:
            sql="""
select row_to_json(q) from (
  select distinct on (uid)
    id, uid, type, sender_uid, sender_callsign, start, stale, timestamp, xml
  from public.cot
  where uid is not null
    and (uid like 'ICAO-%' or type like '%-A-%' or xml ilike '%ICAO-%')
  order by uid, id desc
  limit %d
) q
""" % max(1, min(int(limit), 2000))
            rows,err=_pg_rows_json(uri, sql)
            if err:
                notes.append({'source':'postgres:adsb-direct','ok':False,'error':err[:180]})
                continue
            notes.append({'source':'postgres:adsb-direct','ok':True,'rows':len(rows)})
            for row in rows or []:
                if not isinstance(row, dict):
                    continue
                uid=str(row.get('uid') or '').strip()
                typ=str(row.get('type') or '').strip()
                if not uid and not _is_aircraft_type(typ, uid, row.get('sender_callsign')):
                    continue
                parsed=_parse_cot_text_fields(row)
                lat=_coerce_float(parsed.get('lat')); lon=_coerce_float(parsed.get('lon'))
                if lat is None or lon is None:
                    continue
                callsign=parsed.get('callsign') or row.get('sender_callsign') or uid
                alt=_coerce_float(parsed.get('hae'))
                sp=_coerce_float(parsed.get('speed_mps'))
                tr=_coerce_float(parsed.get('course'))
                aircraft.append({'id':uid,'uid':uid,'callsign':callsign,'type':typ,'lat':lat,'lon':lon,'altitude_ft':alt,'speed_kt':round(sp*1.94384,1) if sp is not None else None,'track_deg':tr,'seen_seconds':None,'source':'OpenTAKServer ADS-B/CoT','updated':str(row.get('timestamp') or row.get('start') or ''),'stale':str(row.get('stale') or ''),'category':typ,'aircraft_type':typ,'description':callsign,'emitter_category':typ,'_ots_db':True})
            if aircraft:
                break
    except Exception as e:
        notes.append({'source':'postgres:adsb-direct','ok':False,'error':str(e)[:180]})
    return aircraft, notes

def tak_map_adsb():
    """v237: latest ICAO CoT rows, fixed 60-second stale, no update-derived stale."""
    settings=_load_adsb_settings()
    stale_seconds=60
    notes=[]; raw=[]
    try:
        pg, pg_notes=_v237_ots_pg_aircraft_direct()
        notes.extend(pg_notes); raw.extend(pg or [])
    except Exception as e:
        notes.append({'source':'postgres:adsb-direct','ok':False,'error':str(e)[:180]})
    if not raw:
        try:
            pg, pg_notes=_ots_pg_aircraft()
            notes.extend(pg_notes); raw.extend(pg or [])
        except Exception as e:
            notes.append({'source':'postgres:adsb-fallback','ok':False,'error':str(e)[:180]})
    for source_name,url in _candidate_aircraft_json_sources():
        data=_read_json_url(url)
        if not isinstance(data,dict):
            notes.append({'source':source_name,'url':url,'ok':False})
            continue
        notes.append({'source':source_name,'url':url,'ok':True})
        for item in data.get('aircraft') or []:
            ac=_normalize_adsb_aircraft(item, source_name) if isinstance(item,dict) else None
            if ac:
                raw.append(ac)
    final=[]
    for ac in _v236_adsb_dedupe(raw):
        if not _v236_valid_adsb(ac):
            continue
        fresh=True
        if ac.get('seen_seconds') is not None:
            try:
                fresh=float(ac.get('seen_seconds') or 999999) <= stale_seconds
            except Exception:
                fresh=True
        else:
            age=_age_seconds_from_value(ac.get('updated') or ac.get('timestamp') or ac.get('start') or '')
            fresh=(age is None or age <= stale_seconds)
        if not fresh:
            continue
        if not _adsb_in_radius(ac, settings):
            continue
        final.append(ac)
    final=final[:800]
    return {'ok':True,'aircraft':final,'count':len(final),'sources':notes,'stale_seconds':stale_seconds,'settings':settings,'raw_count':len(raw),'deduped_count':len(_v236_adsb_dedupe(raw))}


# --- v238 EUD display / ADS-B safety patch ---
def _v238_short_atak_version(value):
    txt=str(value or '').strip()
    if '(' in txt:
        txt=txt.split('(',1)[0].strip()
    return txt

def _v238_display_line_for_eud(e):
    e=e or {}
    cs=str(e.get('callsign') or e.get('user_callsign') or e.get('contact_callsign') or e.get('uid') or 'TAK Client').strip()
    color=str(e.get('team_color') or e.get('team') or '').strip()
    role=str(e.get('team_role') or e.get('role') or '').strip()
    client=str(e.get('client') or '').strip()
    version=_v238_short_atak_version(e.get('version') or '')
    cv=' '.join(x for x in (client, version) if x).strip() or _v238_short_atak_version(e.get('client_label') or '')
    parts=[x for x in (color, role, cv) if x]
    return cs + (': ' + ' - '.join(parts) if parts else '')

_v238_prev_tak_map_euds = tak_map_euds
def tak_map_euds():
    data=_v238_prev_tak_map_euds() or {'ok':True,'euds':[],'sources':[]}
    out=[]
    for e in data.get('euds') or []:
        if not isinstance(e, dict):
            continue
        # Hard exclude dashboard/system/test senders from EUDs.
        blob=' '.join(str(e.get(k) or '') for k in ('uid','callsign','user_callsign','contact_callsign','source')).lower()
        if any(x in blob for x in ('takdash-test','tak-dashboard-test','tak-dashboard','takdash')):
            continue
        e=dict(e)
        # Ensure the backend exposes a clean first-class display string and shortened ATAK version.
        e['version_short']=_v238_short_atak_version(e.get('version') or '')
        if e.get('client') and e.get('version_short'):
            e['client_label_short']=str(e.get('client')).strip()+' '+e['version_short']
        else:
            e['client_label_short']=_v238_short_atak_version(e.get('client_label') or '')
        e['display_line']=_v238_display_line_for_eud(e)
        out.append(e)
    data['euds']=out
    data['eud_row_format']='Callsign: color - role - ATAK version'
    return data

def _v238_sanitize_altitude_ft(value):
    try:
        if value is None or value == '':
            return None
        n=float(value)
        if not math.isfinite(n):
            return None
        # Common CoT/ADS-B sentinel values and impossible displayed aircraft altitudes.
        if abs(n) in (999999.0, 9999999.0, 99999999.0):
            return None
        if abs(n) >= 900000:
            return None
        if n < -2000 or n > 100000:
            return None
        return round(n, 1)
    except Exception:
        return None

_v238_prev_tak_map_adsb = tak_map_adsb
def tak_map_adsb():
    data=_v238_prev_tak_map_adsb() or {'ok':True,'aircraft':[]}
    out=[]
    for ac in data.get('aircraft') or []:
        if not isinstance(ac, dict):
            continue
        ac=dict(ac)
        alt=_v238_sanitize_altitude_ft(ac.get('altitude_ft'))
        if alt is None:
            ac['altitude_ft']=None
            ac['altitude_unknown']=True
            ac['altitude_text']='Unknown'
        else:
            ac['altitude_ft']=alt
            ac['altitude_unknown']=False
            ac['altitude_text']=str(int(round(alt)))+' ft'
        out.append(ac)
    data['aircraft']=out
    data['count']=len(out)
    data['stale_seconds']=60
    return data
# --- end v238 EUD display / ADS-B safety patch ---

# keep send-map target filtering aligned with the v237 EUD list
def _is_online_send_eud(e):
    return isinstance(e, dict) and bool(e.get('online') or str(e.get('status') or '').lower()=='online')
# --- end v237 focused patch ---


# --- v239 UI patch injection ---
TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/v301', 'TAKDashboard/v301')
TAK_MAP_HTML = TAK_MAP_HTML.replace('</script></body></html>', r'''
/* v239 focused UI fixes */
(function(){
  const ADSB_ICON_PNG={"civ_fixed": "data:image/png;base64,", "civ_helo": "data:image/png;base64,", "mil_fixed": "data:image/png;base64,", "mil_helo": "data:image/png;base64,"};
  function esc(v){try{return (typeof E==='function'?E(v):String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])));}catch(e){return String(v??'')}}
  function shortVer(v){v=String(v||'').trim();return v.includes('(')?v.split('(',1)[0].trim():v}
  function uidLike(v){v=String(v||'').trim();return /^ANDROID-/i.test(v)||/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v)}
  function cleanCallsign(e){
    const vals=[e&&e.callsign,e&&e.user_callsign,e&&e.contact_callsign,e&&e.eud_callsign,e&&e.username,e&&e.name];
    for(const raw of vals){let v=String(raw||'').trim();if(!v||uidLike(v))continue;let l=v.toLowerCase();if(['none','null','unknown','atak','itak','wintak','orange','blue','green','red','yellow','white','black','team'].includes(l))continue;if(/tak[-_]?dash|tak[-_]?dashboard/i.test(v))continue;if(/\batak\b.*\d+\.\d+/i.test(v))continue;return v;}
    let uid=String((e&&e.uid)||'').trim();return uid?'UID '+(uid.length>14?uid.slice(0,12)+'...':uid):'TAK Client';
  }
