tDraw; window.v233StartDraw=function(mode){try{drawOptions(); window.v233DrawState.mode=mode; window.v233DrawState.points=[]; window.v233DrawState.liveEnd=null; if(typeof v234ClearTemp===\'function\')v234ClearTemp(window.v233DrawState); else if(typeof v233ClearTemp===\'function\')v233ClearTemp(window.v233DrawState); const m=document.getElementById(\'drawToolMenu\');if(m)m.classList.remove(\'active\'); ensureDrawPanel(); setActiveMapTool(\'draw\'); v236OpenDrawOptions(); hookDrawingEvents();}catch(e){if(oldStart)oldStart(mode)}};\n  window.v233DrawMapClick=function(ll){try{if(Date.now()<(window.v236SuppressClickUntil||0))return; const st=drawOptions(); if([\'rectangle\',\'square\',\'circle\',\'ellipse\',\'freehand\'].includes(st.mode))return; st.points=st.points||[]; st.points.push(ll); st.liveEnd=null; v236RedrawDrawTemp()}catch(e){}}\n  window.v233UndoDraw=function(){const st=drawOptions();st.points=(st.points||[]).slice(0,-1);st.liveEnd=null;v236RedrawDrawTemp()};window.v233ClearDraw=function(){const st=drawOptions();st.points=[];st.liveEnd=null;if(typeof v234ClearTemp===\'function\')v234ClearTemp(st);else if(typeof v233ClearTemp===\'function\')v233ClearTemp(st)};\n  window.v233FinishDraw=async function(){try{const st=v236ReadDrawOptions();let coords=drawCoordsFromState();if(coords.length<4){alert(\'Add or draw more points before finishing.\');return}const name=(st.name||prompt(\'Shape name:\',(st.mode||\'Shape\')+\' \'+new Date().toLocaleTimeString())||\'Shape\').trim()||\'Shape\';await uploadGeoJson(name,{type:\'Feature\',geometry:{type:\'Polygon\',coordinates:[coords]},properties:{name,kind:\'shape\',shape_type:st.mode,color:st.color||\'#ff6f2e\',fill:st.fill!==false,fill_opacity:st.fillOpacity==null?0.20:st.fillOpacity,weight:st.weight||3,line_style:st.lineStyle||\'solid\',source:\'TAK Map Drawing Tools\'}});v233ClearDraw();v236CloseDrawOptions();setActiveMapTool(\'move\')}catch(e){alert(\'Save shape failed: \'+e)}};\n  function v236StyleLocalObject(o,opt){try{const p=o?.properties||o||{};if(p.color)opt.color=p.color;if(p.weight||p.line_width)opt.weight=Number(p.weight||p.line_width)||opt.weight;if(p.line_style===\'dashed\'||p.lineStyle===\'dashed\'||p.style===\'dashed\')opt.dashArray=\'8 7\';if(\'fill\' in p)opt.fill=!(p.fill===false||p.fill===\'0\'||p.fill===\'false\');if(p.fill_opacity!=null||p.fillOpacity!=null)opt.fillOpacity=Number(p.fill_opacity??p.fillOpacity);return opt}catch(e){return opt}}\n  const oldAddObject=window.addObjectLayer; if(oldAddObject&&!window.v236AddObjectWrapped){window.v236AddObjectWrapped=true; window.addObjectLayer=function(group,o,sourceKey){try{const p=o?.properties||{};o.lineStyle=o.lineStyle||o.line_style||p.line_style||p.lineStyle||p.style;o.style=o.style||o.lineStyle;o.color=o.color||p.color;o.weight=o.weight||p.weight; if((dataSyncCategory(o)===\'Shapes / Areas\')&&o.coords){/* original renderer may ignore styles; handled below if needed */}}catch(e){}return oldAddObject(group,o,sourceKey)}}\n  const oldFinishRoute=window.v233FinishRoute; window.v233FinishRoute=async function(){try{const pts=window.v233RouteState?.points||[];if(pts.length<2){alert(\'Add at least two route points.\');return}const name=(document.getElementById(\'routeNameInput\')?.value||\'Route \'+new Date().toLocaleTimeString()).trim();const notes=document.getElementById(\'routeNotesInput\')?.value||\'\';const method=document.getElementById(\'routeMethodInput\')?.value||\'Driving\';const direction=document.getElementById(\'routeDirectionInput\')?.value||\'Infil\';const routeType=document.getElementById(\'routeTypeInput\')?.value||\'Primary\';const order=document.getElementById(\'routeOrderInput\')?.value||\'Ascending Check Points\';const prefix=document.getElementById(\'routePrefixInput\')?.value||\'CP\';const color=document.getElementById(\'routeColorInput\')?.value||\'#ff6f2e\';const style=document.getElementById(\'routeStyleInput\')?.value||window.v233RouteState?.style||\'solid\';await v233UploadGeoJson(name,{type