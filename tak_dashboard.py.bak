      }
      let row=q('.adsb-track-row',el); if(!row){content.insertAdjacentHTML('beforeend',trackButtonHtml(id));} else {const btn=q('.adsb-track-btn',row);if(btn&&id)btn.dataset.adsbTrackId=id;const light=q('.adsb-track-light',row);if(light)light.classList.toggle('active',!!(trackedId&&id&&trackedId===id));}
    }catch(_){ }
  }
  function getTrackLayer(){try{if(!window.L||!window.map)return null;let g=window[TRACK_LAYER_NAME];if(!g){g=L.layerGroup().addTo(map);window[TRACK_LAYER_NAME]=g;}else if(!map.hasLayer(g))g.addTo(map);return g}catch(_){return null}}
  function redrawTrack(id){try{const layer=getTrackLayer(); if(!layer||!id)return;const pts=trackPoints.get(id)||[];let line=trackLines.get(id);const a=(window.lastAircraft||[]).find(x=>idOf(x)===id);const color=classColor(a&&a.category);if(pts.length<2){if(line){layer.removeLayer(line);trackLines.delete(id)};return;}if(!line){line=L.polyline(pts,{color,weight:3,opacity:.88,lineCap:'round',lineJoin:'round',interactive:false}).addTo(layer);trackLines.set(id,line)}else{line.setLatLngs(pts);line.setStyle({color});}try{line.bringToFront()}catch(_){ }}catch(_){ }}
  function addTrackPoint(id,a){try{if(!id||!a)return;const lat=Number(a.lat),lon=Number(a.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return;let pts=trackPoints.get(id);if(!pts){pts=[];trackPoints.set(id,pts)}const last=pts[pts.length-1];if(last&&Math.abs(last[0]-lat)<1e-6&&Math.abs(last[1]-lon)<1e-6)return;pts.push([lat,lon]);if(pts.length>720)pts.splice(0,pts.length-720);redrawTrack(id)}catch(_){ }}
  function syncTrackButtons(){try{qa('.adsb-track-btn').forEach(btn=>{const on=trackedId&&btn.dataset.adsbTrackId===trackedId;btn.classList.toggle('active',!!on);const l=q('.adsb-track-light',btn);if(l)l.classList.toggle('active',!!on);});}catch(_){ }}
  window.toggleAdsbTrack=function(id){id=String(id||'').toLowerCase();if(!id)return false;try{if(trackedId===id){trackedId=null;const line=trackLines.get(id);if(line&&window[TRACK_LAYER_NAME])window[TRACK_LAYER_NAME].removeLayer(line);trackLines.delete(id);trackPoints.delete(id);syncTrackButtons();stopTrackTimer();return false;}if(trackedId&&trackedId!==id){const old=trackedId;const line=trackLines.get(old);if(line&&window[TRACK_LAYER_NAME])window[TRACK_LAYER_NAME].removeLayer(line);trackLines.delete(old);trackPoints.delete(old);}trackedId=id;const a=(window.lastAircraft||[]).map(normalizeAircraft).find(x=>idOf(x)===id);if(a)addTrackPoint(id,a);startTrackTimer();syncTrackButtons();return true;}catch(_){return false}};
  function getIntervalSec(){const n=Number(q('#adsbUpdateIntervalV280')?.value||q('#adsbUpdateInterval')?.value||10);return Number.isFinite(n)?Math.max(1,Math.min(300,Math.round(n))):10}
  function generalRefreshConflict(now){try{if(!lastGeneralAt)return false;if(now-lastGeneralAt<1150)return true;const due=lastGeneralAt+getIntervalSec()*1000;if(now>=due-850)return true;}catch(_){ }return false;}
  async function fetchTrackedAircraft(id){const base=(window.lastAircraft||[]).find(a=>idOf(a)===id)||{};const hex=String(base.hex||id||'').replace(/[^A-Fa-f0-9]/g,'').toUpperCase();if(!hex||hex.length<3)return null;const r=await fetch('https://api.airplanes.live/v2/hex/'+encodeURIComponent(hex),{mode:'cors',credentials:'omit',cache:'no-store',headers:{Accept:'application/json'}});if(!r.ok)throw new Error('HTTP '+r.status);const j=await r.json();const arr=Array.isArray(j.ac)?j.ac:(Array.isArray(j.aircraft)?j.aircraft:[]);if(!arr.length)return null;const raw=arr[0];let a={id:(raw.hex||hex).toLowerCase(),hex:String(raw.hex||hex).toUpperCase(),registration:String(raw.r||'').toUpperCase(),callsign:String(raw.flight||raw.r||raw.hex||hex||'ADS-B').trim(),flight:String(raw.flight||'').trim(),lat:Number(raw.lat),lon:Number(raw.lon),altitude_ft:String(raw.alt_baro).toLowerCase()==='ground'?0:(raw.alt_baro??raw.alt_geom),speed_kt:raw.gs,track_deg:raw.track,seen_seconds:raw.seen_pos??raw.seen,category:base.category||raw.category||raw.emitter_category||'unknown',category_raw:raw.category||raw.emitter_category||'',aircraft_type:raw.t||raw.type||'',owner_operator:raw.ownOp||raw.operator||raw.owner||'',squawk:raw.squawk||'',emergency:raw.emergency||''};a.category=classKey(a.category);normalizeAircraft(a);return a;}
  async function trackTick(){if(!trackedId||trackBusy)return;const now=Date.now();if(generalRefreshConflict(now))return;trackBusy=true;try{const a=await fetchTrackedAircraft(trackedId);if(a)addTrackPoint(trackedId,a);}catch(_){ }finally{trackBusy=false;}}
  function startTrackTimer(){if(trackTimer)return;trackTimer=setInterval(trackTick,1000);setTimeout(trackTick,150)}
  function stopTrackTimer(){if(trackTimer){clearInterval(trackTimer);trackTimer=null}}
  function css(){if(q('#v285AdsbTrackStyle'))return;const st=document.createElement('style');st.id='v285AdsbTrackStyle';st.textContent=`
      .leaflet-popup.adsb-object-popup .leaflet-popup-close-button,.leaflet-popup.adsb-object-popup .adsb-v284-close,.leaflet-popup.adsb-object-popup .adsb-v283-close{display:none!important;visibility:hidden!important;pointer-events:none!important;}
      .adsb-track-row{padding:7px 10px 9px;border-top:1px solid rgba(255,255,255,.09);display:flex;justify-content:flex-end;background:rgba(255,255,255,.025)}
      .adsb-track-btn{display:inline-flex!important;align-items:center!important;gap:7px!important;padding:5px 10px!important;min-width:86px!important;justify-content:center!important;}
      .adsb-track-light{width:9px;height:9px;border-radius:999px;background:#404a52;border:1px solid rgba(255,255,255,.28);box-shadow:inset 0 0 4px rgba(0,0,0,.8)}
