<script id="v307AdsbTrackReliabilityPatch">
(function(){
  const V='v307';
  const q=(s,r=document)=>r.querySelector(s), qa=(s,r=document)=>Array.from(r.querySelectorAll(s));
  const esc=s=>String(s==null?'':s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  function version(){try{qa('.iteration-chip,.iteration-marker').forEach(el=>{el.textContent=V});}catch(_){}}
  function mapObj(){try{if(typeof map!=='undefined'&&map){window.map=map;window.takLeafletMap=map;return map}}catch(_){}return window.takLeafletMap||window.map||null}
  const S=window.takAdsbTrackV307||{id:null,meta:null,points:[],trackLayer:null,labelLayer:null,line:null,label:null,lastPointerAt:0,lastPointerId:'',lastEventAt:0};
