_v272_viewshed_js = r'''
(function(){
  const V='v301';
  function field(id){return document.getElementById(id)}
  function clamp(n,min,max,def){n=Number(n);if(!Number.isFinite(n))n=def;return Math.max(min,Math.min(max,n))}
  function css(){if(field('v249Style'))return;document.head.insertAdjacentHTML('beforeend',`<style id="v249Style">
    .iteration-chip,.iteration-marker{font-variant-numeric:tabular-nums}
    .leaflet-marker-icon .aircraft-wrap,.aircraft-wrap{z-index:1000000!important}.adsb-object-popup{z-index:1000001!important}.leaflet-popup.adsb-object-popup{z-index:1000001!important}
    #drawToolMenu.draw-icon-menu{background:rgba(8,13,18,.94)!important;border-color:rgba(53,69,86,.96)!important;box-shadow:0 14px 34px rgba(0,0,0,.46)!important}
    #drawToolMenu.draw-icon-menu button{color:#9aaab1!important;background:#121d25!important;border:1px solid #334553!important;border-radius:10px!important;box-shadow:none!important;cursor:pointer!important;transition:.12s ease!important}
    #drawToolMenu.draw-icon-menu button:hover{border-color:#5b707a!important;background:#17252d!important;color:#c7d1d7!important}
    #drawToolMenu.draw-icon-menu svg{stroke:currentColor!important;fill:none!important;stroke-width:2.1!important;stroke-linecap:round!important;stroke-linejoin:round!important;filter:none!important}
    .adsb-settings-grid .adsb-center-row{grid-column:1/-1!important;display:grid!important;grid-template-columns:minmax(0,1fr) minmax(0,1fr)!important;gap:7px!important;align-items:end!important}
    .adsb-settings-grid .adsb-center-row label,.adsb-center-source-row{min-width:0!important}.adsb-center-source-row{grid-column:1/-1!important;margin-top:-2px!important}.adsb-center-source-row select{width:100%!important}.adsb-interval-action-row{grid-column:1/-1!important;display:flex!important;justify-content:flex-end!important;margin:-3px 0 5px!important}.adsb-interval-action-row .layer-button{padding:5px 8px!important;font-size:.70rem!important}.adsb-interval-center-separator{margin:5px 0 6px!important}
    .viewshed-module{position:fixed;right:14px;top:96px;z-index:905;width:264px;max-width:calc(100vw - 28px);border:1px solid rgba(255,255,255,.14);border-radius:16px;background:rgba(9,18,24,.82);backdrop-filter:blur(16px);box-shadow:0 22px 70px rgba(0,0,0,.52);color:var(--text);overflow:hidden;display:none}.viewshed-module.active{display:block}.viewshed-head{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:9px 11px;border-bottom:1px solid rgba(255,255,255,.08);background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,0));cursor:grab}.viewshed-head.dragging{cursor:grabbing}.viewshed-title{display:flex;align-items:center;gap:7px;margin:0;font-size:.80rem;font-weight:850;letter-spacing:.015em}.viewshed-glyph{width:21px;height:21px;display:grid;place-items:center;border:1px solid rgba(255,111,46,.34);border-radius:8px;color:#ffd6ca;background:rgba(255,111,46,.15)}.viewshed-glyph svg,.viewshed-option-c-icon{width:17px;height:17px;display:block}.viewshed-option-c-icon path{fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}.viewshed-option-c-icon path:nth-child(n+3){stroke:#ffb29d}.viewshed-head-actions{display:flex;gap:5px}.viewshed-ghost{width:23px;height:23px;border:1px solid rgba(255,255,255,.11);border-radius:8px;color:#b6c6cc;background:rgba(255,255,255,.045);font-size:.76rem;line-height:1;cursor:pointer}.viewshed-body{padding:9px 10px 10px}.viewshed-tabs{display:flex;gap:5px;align-items:center;margin-bottom:7px;overflow:hidden}.viewshed-tab{border:1px solid rgba(255,255,255,.10);border-radius:9px;background:rgba(255,255,255,.045);color:#cbd9dd;padding:4px 7px;font-size:.68rem;line-height:1;min-height:25px;max-width:72px;display:flex;align-items:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer}.viewshed-tab.active{color:#fff;border-color:rgba(255,111,46,.45);background:rgba(255,111,46,.16)}.viewshed-tab.add{flex:0 0 auto}.viewshed-tab input{width:60px;background:transparent;border:0;color:#fff;font-size:.68rem;outline:none;padding:0;margin:0}.viewshed-section{border:1px solid rgba(255,255,255,.09);background:rgba(255,255,255,.035);border-radius:12px;padding:7px;margin-bottom:7px}.viewshed-section-title{margin:0 0 6px;color:#ffb29d;font-size:.62rem;font-weight:850;text-transform:uppercase;letter-spacing:.07em}.viewshed-row{display:flex;gap:5px;align-items:center;margin-bottom:6px}.viewshed-row:last-child{margin-bottom:0}.viewshed-row label{color:#b9cbd1;font-size:.66rem;min-width:37px}.viewshed-input,.viewshed-select{min-width:0;height:24px;border:1px solid rgba(255,255,255,.11);border-radius:8px;background:#101d25;color:#edf6f8;padding:3px 6px;font-size:.68rem}.viewshed-input{flex:1}.viewshed-input.short{width:52px;flex:0 0 auto}.viewshed-select{width:52px;flex:0 0 auto}.viewshed-select.quality,.viewshed-select.source{flex:1;width:auto}.viewshed-elevation-source-row label{min-width:37px}.viewshed-btn{height:25px;border:1px solid rgba(255,111,46,.45);border-radius:9px;background:linear-gradient(180deg,rgba(255,111,46,.27),rgba(255,111,46,.12));color:#fff;padding:0 8px;font-size:.67rem;font-weight:800;white-space:nowrap;cursor:pointer}.viewshed-btn.alt{border-color:rgba(255,255,255,.13);background:rgba(255,255,255,.055);color:#d8e5ea}.viewshed-btn-row{display:flex;gap:6px;margin-top:7px}.viewshed-btn-row .viewshed-btn{flex:1}.viewshed-color{width:22px;height:22px;border:1px solid rgba(255,255,255,.18);border-radius:7px;background:#46d16c;padding:0;box-shadow:inset 0 0 0 2px rgba(0,0,0,.17)}.viewshed-range{appearance:none;height:4px;flex:1;border-radius:999px;background:linear-gradient(90deg,rgba(255,255,255,.18),var(--accent));direction:ltr}.viewshed-range::-webkit-slider-thumb{appearance:none;width:12px;height:12px;border-radius:50%;border:1px solid #fff;background:var(--accent)}.viewshed-range.visible{background:linear-gradient(90deg,rgba(255,255,255,.18),rgba(70,209,108,.95))}.viewshed-range.blocked{background:linear-gradient(90deg,rgba(255,255,255,.18),rgba(239,81,77,.95))}.viewshed-cache-row{display:flex;align-items:center;gap:6px;margin-top:4px;color:#a8bbc2;font-size:.62rem;line-height:1.2}.viewshed-cache-row input{accent-color:var(--accent);margin:0}.viewshed-stepper{flex:0 0 auto}.viewshed-stepper.adsb-stepper input.viewshed-input{min-height:24px!important;height:24px!important;padding:3px 6px!important}.viewshed-stepper.adsb-stepper .viewshed-input.short{width:52px!important}.viewshed-stepper .adsb-stepper-buttons button{min-height:0!important;height:12px!important;line-height:10px!important;font-size:.48rem!important;padding:0!important}.viewshed-status{margin-top:6px;color:#71868e;font-size:.62rem;line-height:1.3;min-height:1.3em}.viewshed-minimized{display:none;position:fixed;left:50%;bottom:16px;transform:translateX(-50%);z-index:905;border:1px solid rgba(255,255,255,.14);border-radius:999px;background:rgba(9,18,24,.84);backdrop-filter:blur(14px);box-shadow:0 12px 34px rgba(0,0,0,.38);color:#dfeaf0;padding:7px 12px;font-size:.76rem;font-weight:850;cursor:pointer}.viewshed-minimized.active{display:flex;gap:8px;align-items:center}.viewshed-pick-active{cursor:crosshair!important}.viewshed-raster-overlay{pointer-events:none;image-rendering:auto}.viewshed-observer-marker{filter:drop-shadow(0 0 8px rgba(255,111,46,.45))}
    .local-elev-dialog{display:none;position:fixed;inset:0;z-index:1400;background:rgba(0,0,0,.42);align-items:center;justify-content:center}.local-elev-dialog.active{display:flex}.local-elev-card{width:min(520px,calc(100vw - 28px));border:1px solid rgba(255,255,255,.16);border-radius:16px;background:rgba(9,18,24,.92);backdrop-filter:blur(16px);box-shadow:0 24px 80px rgba(0,0,0,.55);color:#e9f3f6;overflow:hidden}.local-elev-head{display:flex;justify-content:space-between;align-items:center;padding:10px 12px;border-bottom:1px solid rgba(255,255,255,.10);background:linear-gradient(180deg,rgba(255,255,255,.07),transparent)}.local-elev-head h2{font-size:.9rem;margin:0;font-weight:850}.local-elev-body{padding:12px}.local-elev-note{color:#a8bbc2;font-size:.72rem;line-height:1.35;margin:0 0 10px}.local-elev-format-list{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:9px 0}.local-elev-format-list span{border:1px solid rgba(255,255,255,.09);border-radius:9px;background:rgba(255,255,255,.04);padding:6px 8px;font-size:.68rem;color:#d8e5ea}.local-elev-actions{display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap}.local-elev-import{border-color:rgba(82,107,117,.45)!important;background:linear-gradient(180deg,rgba(82,107,117,.32),rgba(31,42,50,.18))!important}.local-elev-import:disabled,.layer-button:disabled{opacity:.48!important;cursor:not-allowed!important}.local-elev-status{margin-top:10px;color:#71868e;font-size:.66rem;line-height:1.35;white-space:pre-wrap}.local-elev-list,.local-elev-selected{max-height:150px;overflow:auto;border:1px solid rgba(255,255,255,.08);border-radius:10px;background:rgba(0,0,0,.16);margin-top:6px;padding:7px}.local-elev-selected{max-height:108px}.local-elev-list div,.local-elev-selected div{font-size:.66rem;color:#cbd9dd;margin:3px 0}.local-elev-list-title{color:#f0b39e;font-size:.62rem;text-transform:uppercase;letter-spacing:.06em;margin:9px 0 0}.local-elev-close{width:26px;height:26px;border:1px solid rgba(255,255,255,.12);border-radius:8px;background:rgba(255,255,255,.05);color:#dfeaf0}.local-elev-tool-chip{font-size:.62rem!important}.local-elev-primary{border-color:rgba(255,111,46,.45)!important;background:linear-gradient(180deg,rgba(255,111,46,.27),rgba(255,111,46,.12))!important}
    @media(max-width:760px){.viewshed-module{right:8px;top:88px;width:250px}.viewshed-minimized{bottom:26px}}
  </style>`)}

  function geodesicDestination(lat,lng,bearingDeg,distM){const R=6371008.8,br=bearingDeg*Math.PI/180,phi1=lat*Math.PI/180,lam1=lng*Math.PI/180,d=distM/R;const sinPhi2=Math.sin(phi1)*Math.cos(d)+Math.cos(phi1)*Math.sin(d)*Math.cos(br);const phi2=Math.asin(sinPhi2);const y=Math.sin(br)*Math.sin(d)*Math.cos(phi1);const x=Math.cos(d)-Math.sin(phi1)*sinPhi2;let lam2=lam1+Math.atan2(y,x);lam2=(lam2+3*Math.PI)%(2*Math.PI)-Math.PI;return {lat:phi2*180/Math.PI,lng:lam2*180/Math.PI}}
  function geodesicCircleCoords(center,radius,steps){const out=[];for(let i=0;i<steps;i++){const p=geodesicDestination(Number(center.lat),Number(center.lng),360*i/steps,radius);out.push([p.lng,p.lat])}out.push(out[0]);return out}

  function viewshedIconSvg(){return `<svg class="viewshed-option-c-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3.5 18.3 8.3 10.9l3.1 4.2 4.1-7.1 5 10.3Z"/><path d="M4.5 18.3h16"/><path d="M7.2 12.4A8.7 8.7 0 0 1 17.2 7.7"/><path d="M8.8 14.6A6.0 6.0 0 0 15.8 11.4"/><path d="M12 18.2V6.6"/><path d="M12 18.2 7.8 13.7"/><path d="M12 18.2l4.2-6.6"/></svg>`}
  function addViewshedToolbar(){try{const icon=viewshedIconSvg();if(field('toolViewshed')){field('toolViewshed').innerHTML=icon+'<span class="tool-label">Viewshed</span>';return}const btn=document.createElement('button');btn.id='toolViewshed';btn.className='tool-btn';btn.title='Viewshed';btn.innerHTML=icon+'<span class="tool-label">Viewshed</span>';btn.onclick=function(ev){ev&&ev.stopPropagation&&ev.stopPropagation();toggleViewshedModule()};const anchor=field('tool3d')||field('toolClearHidden')||field('toolFit');if(anchor&&anchor.parentElement)anchor.parentElement.insertBefore(btn,anchor);else field('floatingToolbarDock')?.appendChild(btn)}catch(_){} }

  function forceAdsbOnTop(){try{if(map&&aircraftLayer&&map.hasLayer&&map.hasLayer(aircraftLayer)){try{aircraftLayer.addTo(map)}catch(_){}};if(aircraftLayer&&aircraftLayer.eachLayer){aircraftLayer.eachLayer(l=>{try{if(l.setZIndexOffset)l.setZIndexOffset(1000000);if(l._icon)l._icon.style.zIndex='1000000';if(l._shadow)l._shadow.style.zIndex='999999'}catch(_){}})}}catch(_){}}
  function wrapAdsbDraw(){try{if(window._v249AdsbWrapped)return;const old=window.drawAircraft;window.drawAircraft=function(items){const r=old?old.call(this,items):undefined;setTimeout(forceAdsbOnTop,0);setTimeout(forceAdsbOnTop,80);return r};window._v249AdsbWrapped=true;forceAdsbOnTop()}catch(_){}}

  function restyleDrawingTools(){try{const m=field('drawToolMenu');if(m){m.classList.add('draw-icon-menu');m.querySelectorAll('button').forEach(b=>{b.classList.add('tool-btn');b.querySelectorAll('svg').forEach(svg=>{svg.setAttribute('fill','none');svg.setAttribute('stroke','currentColor')})})}}catch(_){}}
  function wrapDrawingNameAndCircle(){try{if(window._v249DrawWrapped)return;window._v249DrawWrapped=true;const oldStart=window.v233StartDraw;window.v233StartDraw=function(mode){let r=oldStart?oldStart.apply(this,arguments):undefined;try{window.v233DrawState=window.v233DrawState||{};window.v233DrawState.name='';const el=field('drawNameInput');if(el)el.value=''}catch(_){}return r};const oldOpen=window.v236OpenDrawOptions;window.v236OpenDrawOptions=function(){const r=oldOpen?oldOpen.apply(this,arguments):undefined;try{const el=field('drawNameInput');if(el&&!(window.v233DrawState||{}).name)el.value=''}catch(_){}return r};const oldRedraw=window.v236RedrawDrawTemp;window.v236RedrawDrawTemp=function(){try{const st=window.v233DrawState||{};if(st.mode==='circle'&&st.points&&st.points.length&&st.liveEnd&&map&&window.L){try{if(st.layer)map.removeLayer(st.layer)}catch(_){};const radius=Math.max(0.5,map.distance(st.points[0],st.liveEnd));const opt={color:st.color||field('drawColorInput')?.value||'#ff6f2e',weight:Math.max(1,parseInt(st.weight||field('drawWeightInput')?.value||3,10)||3),opacity:.94,dashArray:(st.lineStyle||field('drawLineStyleInput')?.value)==='dashed'?'8 7':null,fill:st.fill!==false,fillOpacity:st.fill===false?0:Math.max(0,Math.min(.8,st.fillOpacity==null?((parseFloat(field('drawFillOpacityInput')?.value||20)||0)/100):st.fillOpacity))};st.layer=L.circle(st.points[0],Object.assign({radius},opt)).addTo(map);return}}catch(_){}return oldRedraw?oldRedraw.apply(this,arguments):undefined};const oldFinish=window.v233FinishDraw;window.v233FinishDraw=async function(){try{const st=window.v233DrawState||{};if(st.mode==='circle'&&st.points&&st.points.length&&st.liveEnd&&map){const center=st.points[0];const radius=Math.max(0.5,map.distance(center,st.liveEnd));const coords=geodesicCircleCoords(center,radius,96);const name=(st.name||field('drawNameInput')?.value||prompt('Shape name:','Circle '+new Date().toLocaleTimeString())||'Circle').trim()||'Circle';const color=field('drawColorInput')?.value||st.color||'#ff6f2e';const fill=(field('drawFillInput')?.value||'1')==='1';const fillOpacity=Math.max(0,Math.min(1,(parseFloat(field('drawFillOpacityInput')?.value||20)||0)/100));const weight=Math.max(1,parseInt(field('drawWeightInput')?.value||st.weight||3,10)||3);const lineStyle=field('drawLineStyleInput')?.value||st.lineStyle||'solid';const uploader=window.uploadGeoJson||window.v233UploadGeoJson;if(!uploader)throw new Error('Drawing upload function unavailable');await uploader(name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:{name,kind:'shape',shape_type:'circle',center_lat:Number(center.lat),center_lon:Number(center.lng),radius_meters:radius,color,fill,fill_opacity:fillOpacity,weight,line_style:lineStyle,source:'TAK Map Drawing Tools'}});try{window.v233ClearDraw&&window.v233ClearDraw();window.v236CloseDrawOptions&&window.v236CloseDrawOptions();setActiveMapTool('move')}catch(_){}return}}catch(e){alert('Save circle failed: '+e);return}return oldFinish?oldFinish.apply(this,arguments):undefined}}catch(_){} }

  function layoutAdsb(){try{const panel=document.querySelector('.panel[data-collapse-key="adsbSettings"]');if(!panel)return;const grid=panel.querySelector('.adsb-settings-grid');if(!grid)return;const lat=field('adsbCenterLat'),lon=field('adsbCenterLon'),src=field('adsbCenterSource');if(lat&&lon){let row=grid.querySelector('.adsb-center-row');if(!row){row=document.createElement('div');row.className='adsb-center-row'}const latLab=lat.closest('label'),lonLab=lon.closest('label');if(latLab&&lonLab){if(!row.parentElement)latLab.insertAdjacentElement('beforebegin',row);row.appendChild(latLab);row.appendChild(lonLab)}}if(src){const srcLab=src.closest('label');if(srcLab){srcLab.classList.add('adsb-center-source-row');const row=grid.querySelector('.adsb-center-row');if(row)row.insertAdjacentElement('afterend',srcLab)}}const interval=field('adsbIntervalMinutes')?.closest('.adsb-interval-group') || field('adsbUpdateInterval')?.closest('label,.adsb-interval-group');const saveRow=panel.querySelector('.adsb-interval-action-row');if(interval&&saveRow)interval.insertAdjacentElement('afterend',saveRow);document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(_){} }

  function ensureViewshedModule(){try{if(field('viewshedModule'))return;document.body.insertAdjacentHTML('beforeend',`<div id="viewshedModule" class="viewshed-module"><div class="viewshed-head"><h2 class="viewshed-title"><span class="viewshed-glyph">${viewshedIconSvg()}</span>Viewshed</h2><div class="viewshed-head-actions"><button class="viewshed-ghost" id="viewshedHideBtn" title="Hide">−</button><button class="viewshed-ghost" id="viewshedCloseBtn" title="Close">×</button></div></div><div class="viewshed-body"><div id="viewshedTabs" class="viewshed-tabs"></div><div class="viewshed-section"><p class="viewshed-section-title">Quick setup</p><div class="viewshed-row"><button id="viewshedSetPoint" class="viewshed-btn">Set observer</button><button id="viewshedSelectPoint" class="viewshed-btn alt">Select point</button></div><div class="viewshed-row"><label>Lat</label><input id="viewshedLat" class="viewshed-input" inputmode="decimal" placeholder="34.000000"></div><div class="viewshed-row"><label>Lon</label><input id="viewshedLon" class="viewshed-input" inputmode="decimal" placeholder="-118.000000"></div><div class="viewshed-row"><label>Height</label><input id="viewshedHeight" class="viewshed-input short" type="number" step="1" value="6"><select id="viewshedHeightUnit" class="viewshed-select"><option value="ft">ft</option><option value="m">m</option></select></div><div class="viewshed-row"><label>Radius</label><input id="viewshedRadius" class="viewshed-input short" type="number" min="1" step="0.1" value="2.0"><select id="viewshedRadiusUnit" class="viewshed-select"><option value="mi">mi</option><option value="ft">ft</option><option value="m">m</option><option value="km">km</option></select></div><div class="viewshed-row"><label>Quality</label><select id="viewshedQuality" class="viewshed-select quality"><option value="Ultra">Ultra</option><option value="High">High</option><option value="Medium">Medium</option><option value="Low">Low</option></select></div></div><div class="viewshed-section"><p class="viewshed-section-title">Style</p><div class="viewshed-row"><label>Visible</label><input id="viewshedVisibleColor" class="viewshed-color" type="color" value="#46d16c"><input id="viewshedVisibleOpacity" class="viewshed-range visible" type="range" min="0" max="100" value="68" title="Transparent → Opaque"></div><div class="viewshed-row"><label>Blocked</label><input id="viewshedBlockedColor" class="viewshed-color" type="color" value="#ef514d"><input id="viewshedBlockedOpacity" class="viewshed-range blocked" type="range" min="0" max="100" value="44" title="Transparent → Opaque"></div></div><div class="viewshed-btn-row"><button id="viewshedCalc" class="viewshed-btn">Calculate</button><button id="viewshedHideOverlay" class="viewshed-btn alt">Hide</button></div><button id="viewshedClearAll" class="viewshed-btn alt" style="width:100%;margin-top:6px">Clear All Viewsheds</button><div class="viewshed-row viewshed-elevation-source-row" style="margin-top:7px"><label>Elev</label><select id="viewshedElevationSource" class="viewshed-select source"><option value="Auto">Auto</option><option value="Esri">Esri World Elevation 3D</option><option value="USGS">USGS 3DEP DEM</option><option value="Local">Local Elevation Data</option></select></div><div class="viewshed-row viewshed-acceleration-row" style="margin-top:6px"><label>Accel</label><select id="viewshedAcceleration" class="viewshed-select source"><option value="Auto">Auto</option><option value="WebGPU">WebGPU</option><option value="WebCPU">WebCPU</option></select></div><label class="viewshed-cache-row"><input id="viewshedCacheElevation" type="checkbox" checked> Cache elevation data</label><div id="viewshedStatus" class="viewshed-status">Elevation: ready. Set an observer point to begin.</div></div></div><button id="viewshedMinimized" class="viewshed-minimized"><span class="viewshed-glyph">${viewshedIconSvg()}</span><span>Viewshed</span></button>`);bindViewshedUi();initViewshedState();renderViewshedUi()}catch(e){console.warn('viewshed module init failed',e)} }
  function defaultView(n){return {id:'vs'+Date.now()+Math.random().toString(16).slice(2),name:'View '+n,lat:null,lon:null,height:6,heightUnit:'ft',radius:2,radiusUnit:'mi',quality:'High',qualityManual:false,visibleColor:'#46d16c',blockedColor:'#ef514d',visibleOpacity:.68,blockedOpacity:.44,elevationSource:'Auto',acceleration:'Auto',cacheElevation:true,hidden:false,observer:null,status:'',elevationStatus:'Elevation: ready.'}}
  function initViewshedState(){window.v249Viewshed=window.v249Viewshed||{views:[defaultView(1)],active:0,pickMode:null,layerGroup:null,renderer:null,terrainProvider:null,worker:null,workerSeq:0,workerJobs:{}};try{if(!window.v249Viewshed.layerGroup){window.v249Viewshed.layerGroup=L.layerGroup().addTo(map)}window.v249Viewshed.renderer=null}catch(_){} }
  function activeVs(){initViewshedState();let st=window.v249Viewshed;if(!st.views.length)st.views.push(defaultView(1));st.active=Math.max(0,Math.min(st.active,st.views.length-1));return st.views[st.active]}
  function wrapViewshedNumberInput(id){try{const input=field(id);if(!input||input.closest('.adsb-stepper'))return;const wrap=document.createElement('span');wrap.className='adsb-stepper unified-stepper viewshed-stepper';input.parentNode.insertBefore(wrap,input);wrap.appendChild(input);const buttons=document.createElement('span');buttons.className='adsb-stepper-buttons';buttons.innerHTML=`<button type="button" data-step-field="${id}" data-step-delta="1">▲</button><button type="button" data-step-field="${id}" data-step-delta="-1">▼</button>`;wrap.appendChild(buttons)}catch(_){}}
  function wrapViewshedNumberControls(){['viewshedHeight','viewshedRadius'].forEach(wrapViewshedNumberInput)}
  function bindViewshedUi(){const ids=['viewshedSetPoint','viewshedSelectPoint','viewshedCalc','viewshedHideOverlay','viewshedClearAll','viewshedHideBtn','viewshedCloseBtn','viewshedMinimized'];ids.forEach(id=>{const el=field(id);if(el)el.onclick=viewshedClick});['viewshedLat','viewshedLon','viewshedHeight','viewshedHeightUnit','viewshedRadius','viewshedRadiusUnit','viewshedQuality','viewshedVisibleColor','viewshedBlockedColor','viewshedVisibleOpacity','viewshedBlockedOpacity','viewshedElevationSource','viewshedAcceleration','viewshedCacheElevation'].forEach(id=>{const el=field(id);if(!el)return;el.addEventListener('input',()=>{readViewshedFields(id);if(id.includes('Color')||id.includes('Opacity'))renderViewshedLayers(false)});el.addEventListener('change',()=>{readViewshedFields(id);if(id==='viewshedQuality')setViewshedStatus('Quality set to '+(field('viewshedQuality')?.value||'High')+'.');if(id.includes('Color')){try{el.blur()}catch(_){}}if(id.includes('Color')||id.includes('Opacity'))renderViewshedLayers(false)})});wrapViewshedNumberControls();makeViewshedDraggable();try{map.on('click',viewshedMapClick)}catch(_){} }
  function viewshedClick(ev){const id=ev&&ev.currentTarget&&ev.currentTarget.id;const st=window.v249Viewshed||{};if(id==='viewshedSetPoint'){st.pickMode='observer';setViewshedStatus('Click map to set observer point.');map.getContainer().classList.add('viewshed-pick-active')}else if(id==='viewshedSelectPoint'){st.pickMode='select';setViewshedStatus('Click near an existing point object.');map.getContainer().classList.add('viewshed-pick-active')}else if(id==='viewshedCalc'){calculateActiveViewshed()}else if(id==='viewshedHideOverlay'){const v=activeVs();v.hidden=!v.hidden;renderViewshedLayers(false);field('viewshedHideOverlay').textContent=v.hidden?'Show':'Hide'}else if(id==='viewshedClearAll'){clearAllViewsheds()}else if(id==='viewshedHideBtn'){minimizeViewshed()}else if(id==='viewshedCloseBtn'){toggleViewshedModule(false)}else if(id==='viewshedMinimized'){restoreViewshed()}}
  function setViewshedStatus(msg){const el=field('viewshedStatus');if(el)el.textContent=msg||'';try{activeVs().status=msg||''}catch(_){} }
  function renderTabs(){const box=field('viewshedTabs');if(!box)return;const st=window.v249Viewshed;box.innerHTML='';st.views.forEach((v,i)=>{const tab=document.createElement('div');tab.className='viewshed-tab'+(i===st.active?' active':'');tab.title='Click to rename/select';tab.textContent=v.name||('View '+(i+1));tab.onclick=()=>{st.active=i;renderViewshedUi();editViewshedTab(i)};box.appendChild(tab)});const add=document.createElement('div');add.className='viewshed-tab add';add.textContent='+';add.onclick=()=>{st.views.push(defaultView(st.views.length+1));st.active=st.views.length-1;renderViewshedUi();};box.appendChild(add)}
  function editViewshedTab(i){const box=field('viewshedTabs');if(!box)return;const tab=box.children[i];if(!tab||tab.querySelector('input'))return;const st=window.v249Viewshed;const inp=document.createElement('input');inp.value=st.views[i].name||('View '+(i+1));tab.innerHTML='';tab.appendChild(inp);inp.focus();inp.select();function commit(){const val=(inp.value||'').trim()||('View '+(i+1));st.views[i].name=val;renderViewshedUi()}inp.addEventListener('blur',commit,{once:true});inp.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();inp.blur()}if(e.key==='Escape'){e.preventDefault();renderViewshedUi()}})}
  function renderViewshedUi(){try{renderTabs();const v=activeVs();field('viewshedLat').value=v.lat==null?'':Number(v.lat).toFixed(6);field('viewshedLon').value=v.lon==null?'':Number(v.lon).toFixed(6);field('viewshedHeight').value=v.height;field('viewshedHeightUnit').value=v.heightUnit;field('viewshedRadius').value=v.radius;field('viewshedRadiusUnit').value=v.radiusUnit;v.quality=v.quality||autoViewshedQuality(v.radius,v.radiusUnit);if(field('viewshedQuality'))field('viewshedQuality').value=v.quality;field('viewshedVisibleColor').value=v.visibleColor;field('viewshedBlockedColor').value=v.blockedColor;field('viewshedVisibleOpacity').value=Math.round((v.visibleOpacity??.68)*100);field('viewshedBlockedOpacity').value=Math.round((v.blockedOpacity??.44)*100);if(field('viewshedElevationSource'))field('viewshedElevationSource').value=v.elevationSource||'Auto';if(field('viewshedAcceleration'))field('viewshedAcceleration').value=v.acceleration||'Auto';if(field('viewshedCacheElevation'))field('viewshedCacheElevation').checked=v.cacheElevation!==false;field('viewshedHideOverlay').textContent=v.hidden?'Show':'Hide';setViewshedStatus(v.status||v.elevationStatus||'Elevation: ready.')}catch(_){} }
  function readViewshedFields(changedId){try{const v=activeVs();const lat=Number(field('viewshedLat').value),lon=Number(field('viewshedLon').value);v.lat=Number.isFinite(lat)?lat:null;v.lon=Number.isFinite(lon)?lon:null;const oldRadius=v.radius,oldUnit=v.radiusUnit;v.height=clamp(field('viewshedHeight').value,0,100000,6);v.heightUnit=field('viewshedHeightUnit').value||'ft';v.radius=clamp(field('viewshedRadius').value,0.01,99999,2);v.radiusUnit=field('viewshedRadiusUnit').value||'mi';if(changedId==='viewshedQuality'){v.quality=field('viewshedQuality').value||'High';v.qualityManual=true}else if(!v.qualityManual&&(changedId==='viewshedRadius'||changedId==='viewshedRadiusUnit'||oldRadius!==v.radius||oldUnit!==v.radiusUnit)){v.quality=autoViewshedQuality(v.radius,v.radiusUnit);if(field('viewshedQuality'))field('viewshedQuality').value=v.quality}else{v.quality=v.quality||autoViewshedQuality(v.radius,v.radiusUnit);if(field('viewshedQuality'))field('viewshedQuality').value=v.quality}v.visibleColor=field('viewshedVisibleColor').value||'#46d16c';v.blockedColor=field('viewshedBlockedColor').value||'#ef514d';v.visibleOpacity=clamp(field('viewshedVisibleOpacity').value,0,100,68)/100;v.blockedOpacity=clamp(field('viewshedBlockedOpacity').value,0,100,44)/100;if(field('viewshedElevationSource'))v.elevationSource=field('viewshedElevationSource').value||'Auto';if(field('viewshedAcceleration'))v.acceleration=field('viewshedAcceleration').value||'Auto';if(field('viewshedCacheElevation'))v.cacheElevation=!!field('viewshedCacheElevation').checked;return v}catch(_){return activeVs()}}
  function viewshedMapClick(ev){try{const st=window.v249Viewshed;if(!st||!st.pickMode)return;const v=activeVs();if(st.pickMode==='select'){const found=findNearestPoint(ev.latlng);if(!found){setViewshedStatus('No point object found near click. Try closer to a marker.');return}v.lat=found.lat;v.lon=found.lng;setViewshedStatus('Observer set from map point.')}else{v.lat=ev.latlng.lat;v.lon=ev.latlng.lng;setViewshedStatus('Observer point set.')}st.pickMode=null;map.getContainer().classList.remove('viewshed-pick-active');renderViewshedUi();renderViewshedLayers(false);L.DomEvent.stop(ev)}catch(e){console.warn(e)}}
  function findNearestPoint(ll){let best=null,bestD=Infinity;const groups=[(typeof takMarkerLayer!=='undefined'?takMarkerLayer:window.takMarkerLayer),(typeof dataSyncLayer!=='undefined'?dataSyncLayer:window.dataSyncLayer),(typeof importedLayer!=='undefined'?importedLayer:window.importedLayer)];groups.forEach(g=>{try{g&&g.eachLayer&&g.eachLayer(l=>{try{let p=null;if(l.getLatLng)p=l.getLatLng();else return;const d=map.latLngToContainerPoint(ll).distanceTo(map.latLngToContainerPoint(p));if(d<bestD){bestD=d;best=p}}catch(_){}})}catch(_){}});return bestD<=30?best:null}
  function unitMeters(v,u){v=Number(v)||0;if(u==='ft')return v*0.3048;if(u==='mi')return v*1609.344;if(u==='km')return v*1000;return v}
  function radiusMiles(v,u){const m=unitMeters(v,u);return m/1609.344}
  function autoViewshedQuality(v,u){const mi=radiusMiles(v,u);if(mi<1.0)return 'Ultra';if(mi<=2.0)return 'High';if(mi<=4.0)return 'Medium';return 'Low'}
  function viewshedQualitySettings(q,radiusM){
    q=String(q||'High');
    const profiles={
      'Low':{quality:'Low',gridSize:480,losSamples:120},
      'Medium':{quality:'Medium',gridSize:680,losSamples:200},
      'High':{quality:'High',gridSize:1024,losSamples:300},
      'Ultra':{quality:'Ultra',gridSize:1280,losSamples:400}
    };
    const base=profiles[q]||profiles.High;
    const gridSize=base.gridSize;
    const cellM=(2*Math.max(1,radiusM))/gridSize;
    const estimatedCells=Math.round(0.78539816339*gridSize*gridSize);
    return Object.assign({},base,{gridSize,cellM,estimatedCells,angleBins:Math.max(720,Math.min(8192,gridSize*3))});
  }
  function viewshedElevationCacheKey(center,radiusM,gridSize,source){return [String(source||'Auto'),Number(center.lat).toFixed(6),Number(center.lng).toFixed(6),Math.round(radiusM),gridSize,'raster'].join('|')}
  function viewshedElevationStatus(text){const el=field('viewshedStatus');if(el)el.textContent=text;try{const v=activeVs();v.elevationStatus=text;v.status=text}catch(_){}}
  function normalizeViewshedElevationSource(src){src=String(src||'Auto');if(src==='Local'||/local|dted|srtm|hgt/i.test(src))return 'Local';if(src==='USGS'||/usgs/i.test(src))return 'USGS';if(src==='Esri'||/esri/i.test(src))return 'Esri';return 'Auto'}
  function parseUsgsSampleValue(sample){try{if(sample==null)return null;if(typeof sample==='number')return Number.isFinite(sample)?sample:null;if(sample.value!=null&&Number.isFinite(Number(sample.value)))return Number(sample.value);if(sample.values&&sample.values.length&&Number.isFinite(Number(sample.values[0])))return Number(sample.values[0]);if(sample.attributes){for(const k of ['value','Value','Pixel Value','PixelValue','RASTERVALU']){if(sample.attributes[k]!=null&&Number.isFinite(Number(sample.attributes[k])))return Number(sample.attributes[k])}}}catch(_){}return null}
  function normalizeViewshedPointSet(pointMsg,center){try{if(pointMsg&&pointMsg.latArray&&pointMsg.lngArray){return {latArray:(pointMsg.latArray instanceof Float64Array)?pointMsg.latArray:new Float64Array(pointMsg.latArray),lngArray:(pointMsg.lngArray instanceof Float64Array)?pointMsg.lngArray:new Float64Array(pointMsg.lngArray),length:Number(pointMsg.length)||((pointMsg.latArray&&pointMsg.latArray.length)||0)}}}catch(_){}return [center]}
  function viewshedPointCount(points){try{if(points&&points.latArray&&points.lngArray)return Math.min(points.latArray.length,points.lngArray.length,Number(points.length)||Infinity);if(Array.isArray(points))return points.length}catch(_){}return 0}
  function viewshedPointAt(points,i){try{if(points&&points.latArray&&points.lngArray)return {lat:Number(points.latArray[i]),lng:Number(points.lngArray[i])};return points[i]}catch(_){return null}}
  function viewshedPointSlice(points,start,end){const out=[];const n=viewshedPointCount(points);const lim=Math.min(n,end);for(let i=start;i<lim;i++){const p=viewshedPointAt(points,i);if(p)out.push(p)}return out}
  function viewshedTimeout(promise, ms, label){
    let t;
    return Promise.race([
      promise,
      new Promise((_, reject)=>{t=setTimeout(()=>reject(new Error((label||'operation')+' timed out')), ms||45000)})
    ]).finally(()=>{try{clearTimeout(t)}catch(_){}});
  }
  async function viewshedFetchWithTimeout(url, options, ms){
    options=options||{};
    let ctrl=null,t=null;
    try{
      if(typeof AbortController!=='undefined'){
        ctrl=new AbortController();
        options=Object.assign({},options,{signal:ctrl.signal});
        t=setTimeout(()=>{try{ctrl.abort()}catch(_){}} , ms||45000);
      }
      return await fetch(url,options);
    }finally{try{if(t)clearTimeout(t)}catch(_){}}
  }
  async function sampleElevationsEsri(points,opts){opts=opts||{};const st=window.v249Viewshed;try{if(typeof loadCesiumAssets==='function'&&typeof cesiumTerrainProvider==='function'){await loadCesiumAssets();if(!window.Cesium)return {ok:false,source:'Esri World Elevation 3D unavailable',elev:null};if(!st.terrainProvider)st.terrainProvider=await cesiumTerrainProvider();const pointCount=viewshedPointCount(points);const out=new Array(pointCount);const chunk=4000;const useMost=!!Cesium.sampleTerrainMostDetailed;const source=useMost?'Esri World Elevation 3D high-res terrain':'Esri World Elevation 3D coarse terrain';let min=Infinity,max=-Infinity,valid=0;for(let i=0;i<pointCount;i+=chunk){const slice=viewshedPointSlice(points,i,i+chunk);const cart=slice.map(p=>Cesium.Cartographic.fromDegrees(p.lng,p.lat));const terrainPromise=useMost?Cesium.sampleTerrainMostDetailed(st.terrainProvider,cart):Cesium.sampleTerrain(st.terrainProvider,11,cart);const sampled=await viewshedTimeout(terrainPromise,45000,'Esri terrain sample');for(let j=0;j<sampled.length;j++){const h=Number(sampled[j].height);const val=Number.isFinite(h)?h:0;out[i+j]=val;if(Number.isFinite(h)){valid++;if(val<min)min=val;if(val>max)max=val}}if(field('viewshedStatus')){const pct=Math.min(99,Math.round(((i+sampled.length)/pointCount)*100));field('viewshedStatus').textContent='Sampling elevation ('+source+')... '+pct+'%'}await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;return {ok:valid>0,cached:false,source:source+(spread<0.5?' · flat/low variation':''),elev:out,valid,spread}}}catch(e){console.warn('Esri viewshed terrain sample unavailable',e)}return {ok:false,source:'Esri World Elevation 3D unavailable',elev:null}}
  async function sampleElevationsUsgs(points,opts){opts=opts||{};const endpoint='https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/getSamples';const pointCount=viewshedPointCount(points);const out=new Array(pointCount);const chunk=500;let valid=0,min=Infinity,max=-Infinity;try{for(let i=0;i<pointCount;i+=chunk){const slice=viewshedPointSlice(points,i,i+chunk);const geometry=JSON.stringify({points:slice.map(p=>[Number(p.lng),Number(p.lat)]),spatialReference:{wkid:4326}});const body=new URLSearchParams();body.set('f','json');body.set('geometryType','esriGeometryMultipoint');body.set('geometry',geometry);body.set('returnFirstValueOnly','true');body.set('interpolation','RSP_BilinearInterpolation');body.set('outFields','*');const res=await viewshedFetchWithTimeout(endpoint,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded;charset=UTF-8'},body:body.toString()},45000);if(!res.ok)throw new Error('USGS 3DEP HTTP '+res.status);const json=await res.json();if(json.error)throw new Error(json.error.message||'USGS 3DEP error');const samples=json.samples||json.sampleLocations||[];for(let j=0;j<slice.length;j++){const h=parseUsgsSampleValue(samples[j]);const val=Number.isFinite(h)?h:0;out[i+j]=val;if(Number.isFinite(h)){valid++;if(val<min)min=val;if(val>max)max=val}}if(field('viewshedStatus')){const pct=Math.min(99,Math.round(((i+slice.length)/pointCount)*100));field('viewshedStatus').textContent='Sampling elevation (USGS 3DEP DEM)... '+pct+'%'}await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;return {ok:valid>0,cached:false,source:'USGS 3DEP DEM'+(spread<0.5?' · flat/low variation':''),elev:out,valid,spread}}catch(e){console.warn('USGS 3DEP viewshed terrain sample unavailable',e);return {ok:false,source:'USGS 3DEP DEM unavailable: '+String(e&&e.message||e),elev:null}}}
  
  const LOCAL_ELEV_DB='takmapLocalElevationV1';
  function localElevState(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};return window.takLocalElevation}
  function localElevKey(lat0,lon0,size){return 'hgt|'+lat0+'|'+lon0+'|'+size}
  function localElevTileId(lat0,lon0){return 'hgt|'+Math.floor(lat0)+'|'+Math.floor(lon0)}
  function openLocalElevDb(){return new Promise((resolve,reject)=>{try{const req=indexedDB.open(LOCAL_ELEV_DB,1);req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains('tiles'))db.createObjectStore('tiles',{keyPath:'id'});if(!db.objectStoreNames.contains('meta'))db.createObjectStore('meta',{keyPath:'id'})};req.onsuccess=()=>resolve(req.result);req.onerror=()=>reject(req.error||new Error('IndexedDB open failed'))}catch(e){reject(e)}})}
  async function localElevDbPut(tile){const db=await openLocalElevDb();return new Promise((resolve,reject)=>{try{const tx=db.transaction(['tiles'],'readwrite');tx.objectStore('tiles').put(tile);tx.oncomplete=()=>{try{db.close()}catch(_){};resolve(true)};tx.onerror=()=>reject(tx.error||new Error('IndexedDB put failed'))}catch(e){reject(e)}})}
  async function localElevDbClear(){const db=await openLocalElevDb();return new Promise((resolve,reject)=>{try{const tx=db.transaction(['tiles'],'readwrite');tx.objectStore('tiles').clear();tx.oncomplete=()=>{try{db.close()}catch(_){};resolve(true)};tx.onerror=()=>reject(tx.error||new Error('IndexedDB clear failed'))}catch(e){reject(e)}})}
  async function loadLocalElevationTiles(){const st=localElevState();if(st.loaded)return st;if(st.loading)return st.loading;st.loading=(async()=>{try{const db=await openLocalElevDb();await new Promise((resolve,reject)=>{const tx=db.transaction(['tiles'],'readonly');const req=tx.objectStore('tiles').openCursor();req.onsuccess=e=>{const cur=e.target.result;if(cur){const tile=cur.value;if(tile&&tile.id){st.tiles.set(tile.id,tile);st.tiles.set(localElevTileId(tile.lat0,tile.lon0),tile);};cur.continue()}else resolve()};req.onerror=()=>reject(req.error||new Error('IndexedDB cursor failed'));tx.oncomplete=()=>{try{db.close()}catch(_){}}});st.meta=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).map(t=>({id:t.id,name:t.name,type:t.type,lat0:t.lat0,lon0:t.lon0,size:t.size}));st.loaded=true;updateLocalElevationUi();return st}catch(e){console.warn('local elevation load failed',e);st.loaded=true;updateLocalElevationUi('Local elevation load failed: '+String(e&&e.message||e));return st}})();return st.loading}
  function parseHgtName(name){const m=String(name||'').match(/([NS])(\d{2})([EW])(\d{3})/i);if(!m)return null;let lat=Number(m[2]),lon=Number(m[4]);if(m[1].toUpperCase()==='S')lat=-lat;if(m[3].toUpperCase()==='W')lon=-lon;return {lat0:lat,lon0:lon}}
  async function importHgtFile(file){const loc=parseHgtName(file.name);if(!loc)throw new Error(file.name+': HGT filename must include tile origin like N34W118.hgt');const buf=await file.arrayBuffer();const samples=buf.byteLength/2;const size=Math.round(Math.sqrt(samples));if(size*size!==samples||![1201,3601].includes(size))throw new Error(file.name+': unsupported HGT dimensions '+size+'×'+size);const dv=new DataView(buf);const vals=new Int16Array(samples);for(let i=0;i<samples;i++)vals[i]=dv.getInt16(i*2,false);const tile={id:localElevKey(loc.lat0,loc.lon0,size),type:'SRTM HGT',name:file.name,lat0:loc.lat0,lon0:loc.lon0,size,buffer:vals.buffer,bytes:buf.byteLength,imported:Date.now()};await localElevDbPut(tile);const st=localElevState();st.tiles.set(tile.id,tile);st.tiles.set(localElevTileId(tile.lat0,tile.lon0),tile);st.meta=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).map(t=>({id:t.id,name:t.name,type:t.type,lat0:t.lat0,lon0:t.lon0,size:t.size}));return tile}
  function tileForLocalPoint(lat,lng){const st=localElevState();const lat0=Math.floor(Number(lat)),lon0=Math.floor(Number(lng));return st.tiles.get(localElevTileId(lat0,lon0))||null}
  function sampleHgtTile(tile,lat,lng){try{if(!tile)return null;const size=Number(tile.size);if(!(size>1))return null;const lat0=Number(tile.lat0),lon0=Number(tile.lon0);if(lat<lat0||lat>lat0+1||lng<lon0||lng>lon0+1)return null;const vals=new Int16Array(tile.buffer);const col=(lng-lon0)*(size-1);const row=(lat0+1-lat)*(size-1);let c0=Math.floor(col),r0=Math.floor(row);let c1=Math.min(size-1,c0+1),r1=Math.min(size-1,r0+1);c0=Math.max(0,Math.min(size-1,c0));r0=Math.max(0,Math.min(size-1,r0));const tx=col-c0,ty=row-r0;function v(r,c){const n=vals[r*size+c];return n<=-32768?NaN:Number(n)}const v00=v(r0,c0),v10=v(r0,c1),v01=v(r1,c0),v11=v(r1,c1);const arr=[v00,v10,v01,v11].filter(Number.isFinite);if(!arr.length)return null;if(arr.length<4)return arr.reduce((a,b)=>a+b,0)/arr.length;const a=v00*(1-tx)+v10*tx,b=v01*(1-tx)+v11*tx;return a*(1-ty)+b*ty}catch(_){return null}}
  async function sampleElevationsLocal(points,opts){opts=opts||{};await loadLocalElevationTiles();const st=localElevState();const pointCount=viewshedPointCount(points);const out=new Float32Array(pointCount);let valid=0,min=Infinity,max=-Infinity,missing=0;const used=new Set();if(!st.tiles||st.tiles.size===0)return {ok:false,source:'Local elevation data unavailable: no local SRTM HGT tiles imported',elev:null};for(let i=0;i<pointCount;i++){const p=viewshedPointAt(points,i);const tile=p?tileForLocalPoint(p.lat,p.lng):null;let h=tile?sampleHgtTile(tile,Number(p.lat),Number(p.lng)):null;if(Number.isFinite(h)){out[i]=h;valid++;used.add(tile.id);if(h<min)min=h;if(h>max)max=h}else{out[i]=0;missing++}if(i%25000===0&&field('viewshedStatus')){const pct=Math.min(99,Math.round((i/Math.max(1,pointCount))*100));field('viewshedStatus').textContent='Sampling elevation (Local DTED/SRTM)... '+pct+'%'}if(i%50000===0)await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;const cov=Math.round((valid/Math.max(1,pointCount))*100);return {ok:valid>0,cached:false,source:'Local SRTM HGT · '+used.size+' tile'+(used.size===1?'':'s')+' · '+cov+'% coverage'+(spread<0.5?' · flat/low variation':''),elev:out,valid,spread,coverage:cov,missing}}
  function ensureLocalElevationDialog(){try{if(field('localElevationDialog'))return;document.body.insertAdjacentHTML('beforeend',`<div id="localElevationDialog" class="local-elev-dialog"><div class="local-elev-card"><div class="local-elev-head"><h2>Add Local Elevation Data</h2><button id="localElevClose" class="local-elev-close">×</button></div><div class="local-elev-body"><p class="local-elev-note"><b>Files stay on this computer/browser and are not uploaded to the TAK server.</b><br>Use local elevation data as a Viewshed source. Terrain Mode local terrain rendering is pending.</p><div class="local-elev-format-list"><span>SRTM HGT (.hgt) usable now</span><span>DTED (.dt0/.dt1/.dt2) parser pending</span><span>GeoTIFF DEM (.tif/.tiff) parser pending</span><span>ZIP package parser pending</span></div><input id="localElevFileInput" type="file" multiple accept=".hgt,.dt0,.dt1,.dt2,.tif,.tiff" style="display:none"><div class="local-elev-actions"><button id="localElevChoose" class="layer-button local-elev-primary">Choose Files</button><button id="localElevImport" class="layer-button local-elev-import" disabled>Import Selected Files</button><button id="localElevClear" class="layer-button">Clear Local Elevation</button></div><div id="localElevStatus" class="local-elev-status">No local elevation data loaded yet.</div><div class="local-elev-list-title">Selected files</div><div id="localElevSelected" class="local-elev-selected">No selected files.</div><div class="local-elev-list-title">Local files indexed</div><div id="localElevList" class="local-elev-list"></div></div></div></div>`);field('localElevClose').onclick=()=>field('localElevationDialog')?.classList.remove('active');field('localElevChoose').onclick=()=>field('localElevFileInput')?.click();field('localElevImport').onclick=async()=>{const st=localElevState();await importLocalElevationFiles(st.pendingFiles||[]);st.pendingFiles=[];renderLocalElevationSelected();updateLocalElevImportButton();};field('localElevClear').onclick=async()=>{try{await localElevDbClear();const st=localElevState();st.tiles=new Map();st.meta=[];st.loaded=true;st.pendingFiles=[];renderLocalElevationSelected();updateLocalElevImportButton();updateLocalElevationUi('Local elevation data cleared.')}catch(e){updateLocalElevationUi('Clear failed: '+String(e&&e.message||e))}};field('localElevFileInput').onchange=(ev)=>{const st=localElevState();st.pendingFiles=[...(ev.target.files||[])];renderLocalElevationSelected();updateLocalElevImportButton();const supported=st.pendingFiles.filter(f=>/\.hgt$/i.test(String(f.name||''))).length;const pending=st.pendingFiles.length-supported;const stat=field('localElevStatus');if(stat)stat.textContent=st.pendingFiles.length?('Selected '+st.pendingFiles.length+' file'+(st.pendingFiles.length===1?'':'s')+'. '+supported+' importable SRTM HGT, '+pending+' parser pending/unsupported. Click Import Selected Files to continue.'):'No selected files.';ev.target.value=''};}catch(e){console.warn('local elevation dialog failed',e)}}
  function localElevFileSupportLabel(name){name=String(name||'');if(/\.hgt$/i.test(name))return 'SRTM HGT - ready to import';if(/\.(dt0|dt1|dt2)$/i.test(name))return 'DTED parser pending';if(/\.(tif|tiff)$/i.test(name))return 'GeoTIFF parser pending';if(/\.zip$/i.test(name))return 'ZIP parser pending';return 'unsupported'}
  function renderLocalElevationSelected(){try{const box=field('localElevSelected');if(!box)return;const files=(localElevState().pendingFiles||[]);if(!files.length){box.textContent='No selected files.';return;}box.innerHTML=files.map(f=>{const name=String(f.name||'file');const label=localElevFileSupportLabel(name);const dim=/\.hgt$/i.test(name)?'':' style="color:#98a6ad"';return `<div${dim}>- ${esc(name)} <span class="muted">(${esc(label)})</span></div>`}).join('')}catch(e){console.warn('render local elevation selected failed',e)}}
  function updateLocalElevImportButton(){try{const b=field('localElevImport');if(!b)return;const files=(localElevState().pendingFiles||[]);const supported=files.filter(f=>/\.hgt$/i.test(String(f.name||''))).length;b.disabled=!supported;b.textContent='Import Selected Files'}catch(e){}}
  async function importLocalElevationFiles(files){ensureLocalElevationDialog();files=[...(files||[])];let ok=0,unsupported=[];const stat=field('localElevStatus');for(const f of files){const name=String(f.name||'');try{if(/\.hgt$/i.test(name)){if(stat)stat.textContent='Importing '+name+'...';await importHgtFile(f);ok++}else if(/\.(dt0|dt1|dt2)$/i.test(name)){unsupported.push(name+' (DTED parser pending)')}else if(/\.(tif|tiff)$/i.test(name)){unsupported.push(name+' (GeoTIFF parser pending)')}else if(/\.zip$/i.test(name)){unsupported.push(name+' (ZIP parser pending)')}else{unsupported.push(name+' (unsupported)')}}catch(e){unsupported.push(name+' ('+String(e&&e.message||e)+')')}}const msg='Imported '+ok+' SRTM HGT tile'+(ok===1?'':'s')+'.'+(unsupported.length?'\nNot imported:\n- '+unsupported.join('\n- '):'');updateLocalElevationUi(msg)}
  function updateLocalElevationUi(msg){try{const st=localElevState();const list=field('localElevList');const count=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).length;if(field('localElevToolStatus'))field('localElevToolStatus').textContent='Local: '+count;if(field('localElevStatus'))field('localElevStatus').textContent=msg||((count?('Loaded '+count+' local elevation tile'+(count===1?'':'s')+'.'):'No local elevation data loaded yet.'));if(list){const tiles=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i);list.innerHTML=tiles.length?tiles.map(t=>'<div>'+esc(t.name||t.id)+' · '+esc(t.type||'Elevation')+' · '+t.size+'×'+t.size+' · '+(t.lat0>=0?'N':'S')+Math.abs(t.lat0)+' '+(t.lon0>=0?'E':'W')+Math.abs(t.lon0)+'</div>').join(''):'<div>No local files indexed.</div>'}}catch(_){} }
  function openLocalElevationDialog(){ensureLocalElevationDialog();field('localElevationDialog')?.classList.add('active');loadLocalElevationTiles();renderLocalElevationSelected();updateLocalElevImportButton();updateLocalElevationUi()}
  function ensureLocalElevationToolsButton(){try{ensureLocalElevationDialog();if(field('localElevAddBtn')){field('localElevAddBtn').onclick=openLocalElevationDialog;updateLocalElevationUi();return;}const panels=[...document.querySelectorAll('.panel')];const p=panels.find(el=>(el.querySelector('h2')?.textContent||'').trim()==='Tools');if(!p)return;const row=document.createElement('div');row.className='row local-elev-tools-row';row.innerHTML='<button id="localElevAddBtn" class="layer-button" type="button">Add Elevation Data</button><span id="localElevToolStatus" class="chip local-elev-tool-chip">Local: 0</span>';const exportButton=[...p.querySelectorAll('button')].find(b=>(b.textContent||'').trim()==='Export All Data');if(exportButton){const exportButtonRow=exportButton.closest('.row')||exportButton;exportButtonRow.insertAdjacentElement('beforebegin',row);}else{const exportRow=field('exportDataSync')?.closest('.export-check-list,.export-options');if(exportRow)exportRow.insertAdjacentElement('beforebegin',row);else p.appendChild(row);}field('localElevAddBtn').onclick=openLocalElevationDialog;updateLocalElevationUi()}catch(e){console.warn('local elevation tools button failed',e)}}
  function localElevationBoot(){try{ensureLocalElevationToolsButton();loadLocalElevationTiles();setTimeout(ensureLocalElevationToolsButton,1500);setTimeout(ensureLocalElevationToolsButton,3500)}catch(e){console.warn('local elevation boot failed',e)}}
  try{window.openLocalElevationDialog=openLocalElevationDialog;window.ensureLocalElevationToolsButton=ensureLocalElevationToolsButton;window.localElevationBoot=localElevationBoot}catch(_){}
async function sampleElevations(points,opts){opts=opts||{};const st=window.v249Viewshed;const useCache=!!opts.cache;const key=opts.key||'';const requested=normalizeViewshedElevationSource(opts.source||'Auto');try{if(useCache&&key){st.elevationCache=st.elevationCache||new Map();if(st.elevationCache.has(key)){const cached=st.elevationCache.get(key);viewshedElevationStatus('Elevation: using cached '+(cached.source||'terrain samples')+'.');return Object.assign({ok:true,cached:true},cached)}}let result=null;if(requested==='Local'){result=await sampleElevationsLocal(points,opts)}else if(requested==='USGS'){result=await sampleElevationsUsgs(points,opts)}else if(requested==='Esri'){result=await sampleElevationsEsri(points,opts)}else{result=await sampleElevationsEsri(points,opts);if(!(result&&result.ok)){viewshedElevationStatus('Elevation: Esri unavailable; trying USGS 3DEP DEM...');result=await sampleElevationsUsgs(points,opts);}}if(result&&result.ok&&useCache&&key){st.elevationCache=st.elevationCache||new Map();if(result.elev&&!(result.elev instanceof Float32Array))result.elev=new Float32Array(result.elev);st.elevationCache.set(key,{source:result.source,elev:result.elev,valid:result.valid,spread:result.spread,coverage:result.coverage});while(st.elevationCache.size>12){const first=st.elevationCache.keys().next().value;st.elevationCache.delete(first)}}return result||{ok:false,source:'unavailable',elev:null}}catch(e){console.warn('viewshed terrain sample unavailable',e);return {ok:false,source:String(e&&e.message||e)||'unavailable',elev:null}}}
  function viewshedWorkerCode(){return `
const R=6371008.8;
function dest(lat,lng,bearingDeg,distM){const br=bearingDeg*Math.PI/180,phi1=lat*Math.PI/180,lam1=lng*Math.PI/180,d=distM/R;const sinPhi2=Math.sin(phi1)*Math.cos(d)+Math.cos(phi1)*Math.sin(d)*Math.cos(br);const phi2=Math.asin(sinPhi2);const y=Math.sin(br)*Math.sin(d)*Math.cos(phi1);const x=Math.cos(d)-Math.sin(phi1)*sinPhi2;let lam2=lam1+Math.atan2(y,x);lam2=(lam2+3*Math.PI)%(2*Math.PI)-Math.PI;return {lat:phi2*180/Math.PI,lng:lam2*180/Math.PI}}
function gridLatLng(center,dxM,dyM){const lat=center.lat+(dyM/R)*180/Math.PI;const lng=center.lng+(dxM/(R*Math.cos(center.lat*Math.PI/180)))*180/Math.PI;return {lat,lng}}
function makeRasterPoints(m){const center=m.center,radiusM=m.radiusM,n=m.gridSize;const cellM=(2*radiusM)/n;const half=n/2;const maxPts=Math.ceil(Math.PI*n*n/4)+8;let latArr=new Float64Array(maxPts);let lngArr=new Float64Array(maxPts);let pixArr=new Int32Array(Math.max(2,(maxPts-1)*2));let count=1,pi=0;latArr[0]=Number(center.lat)||0;lngArr[0]=Number(center.lng)||0;let minLat=90,maxLat=-90,minLng=180,maxLng=-180;const nw=gridLatLng(center,-radiusM,radiusM),se=gridLatLng(center,radiusM,-radiusM);minLat=Math.min(nw.lat,se.lat);maxLat=Math.max(nw.lat,se.lat);minLng=Math.min(nw.lng,se.lng);maxLng=Math.max(nw.lng,se.lng);for(let y=0;y<n;y++){const dy=(half-y-0.5)*cellM;for(let x=0;x<n;x++){const dx=(x+0.5-half)*cellM;if(dx*dx+dy*dy>radiusM*radiusM)continue;if(count>=latArr.length){const nl=new Float64Array(latArr.length+Math.ceil(n*n*.05)+1024);nl.set(latArr);latArr=nl;const ng=new Float64Array(lngArr.length+Math.ceil(n*n*.05)+1024);ng.set(lngArr);lngArr=ng;const np=new Int32Array(pixArr.length+Math.ceil(n*n*.10)+2048);np.set(pixArr);pixArr=np}const p=gridLatLng(center,dx,dy);latArr[count]=p.lat;lngArr[count]=p.lng;count++;pixArr[pi++]=x;pixArr[pi++]=y}}return {latArray:latArr.slice(0,count),lngArray:lngArr.slice(0,count),length:count,pixels:pixArr.slice(0,pi),bounds:[[minLat,minLng],[maxLat,maxLng]],width:n,height:n,cellM}}
function prepRasterGrid(m){const n=m.width,h=m.height;const pix=m.pixels instanceof Int32Array?m.pixels:new Int32Array(m.pixels||[]);let elev;if(m.elevBuffer)elev=new Float32Array(m.elevBuffer);else if(m.elev instanceof Float32Array)elev=m.elev;else if(Array.isArray(m.elev))elev=new Float32Array(m.elev);else elev=new Float32Array(0);const gridElev=new Float32Array(n*h);const validU8=new Uint8Array(n*h);const validU32=new Uint32Array(n*h);const terrainOk=!!m.terrainOk;const centerElev=terrainOk?(Number(elev[0])||0):0;for(let i=0,ei=1;i<pix.length;i+=2,ei++){const x=pix[i],y=pix[i+1],idx=y*n+x;validU8[idx]=1;validU32[idx]=1;gridElev[idx]=terrainOk?(Number(elev[ei])||0):0}return {pix,elev,gridElev,validU8,validU32,centerElev,terrainOk}}
function solveRasterCpu(m){const n=m.width,h=m.height,cellM=m.cellM||((2*m.radiusM)/n),radiusM=m.radiusM,heightM=m.heightM||0;const prep=prepRasterGrid(m);const out=new Uint8ClampedArray(n*h);const centerElev=prep.centerElev;const bins=m.angleBins||Math.max(720,Math.min(8192,n*3));const maxAng=new Float32Array(bins);for(let i=0;i<bins;i++)maxAng[i]=-3.402823466e38;const c=(n-1)/2;const maxRing=Math.ceil(n/2);let processed=0,total=prep.pix.length/2;function processCell(x,y){if(x<0||y<0||x>=n||y>=n)return;const idx=y*n+x;if(!prep.validU8[idx])return;const dx=x+0.5-n/2,dy=n/2-y-0.5;const distCells=Math.sqrt(dx*dx+dy*dy);const distM=distCells*cellM;if(distM<0.5||distM>radiusM){out[idx]=0;return}let isVis=true;if(prep.terrainOk){let br=Math.atan2(dx,dy);if(br<0)br+=Math.PI*2;const bin=Math.max(0,Math.min(bins-1,Math.floor(br/(Math.PI*2)*bins)));const ang=(prep.gridElev[idx]-(centerElev+heightM))/Math.max(1,distM);isVis=ang>=maxAng[bin]-0.000001;if(ang>maxAng[bin])maxAng[bin]=ang}out[idx]=isVis?1:2;processed++}
for(let r=0;r<=maxRing;r++){const x0=Math.floor(c-r),x1=Math.ceil(c+r),y0=Math.floor(c-r),y1=Math.ceil(c+r);for(let x=x0;x<=x1;x++){processCell(x,y0);if(y1!==y0)processCell(x,y1)}for(let y=y0+1;y<=y1-1;y++){processCell(x0,y);if(x1!==x0)processCell(x1,y)}if(r%64===0){self.postMessage({id:m.id,ok:true,progress:true,pct:Math.min(99,Math.round((processed/Math.max(1,total))*100)),acceleration:'WebCPU'})}}
return {classData:out,terrainOk:prep.terrainOk,width:n,height:h,processed,acceleration:'WebCPU'}}
async function solveRasterWebGpu(m){throw new Error('WebGPU disabled in v260 stability fallback')}
async function solveRaster(m){const mode=String(m.acceleration||'Auto');if(mode==='WebGPU'){self.postMessage({id:m.id,ok:true,progress:true,pct:1,acceleration:'WebCPU',message:'WebGPU unavailable; using WebCPU stability path'});}else{self.postMessage({id:m.id,ok:true,progress:true,pct:1,acceleration:'WebCPU',message:'Using WebCPU'});}return solveRasterCpu(m)}
self.onmessage=async function(ev){const m=ev.data||{};try{if(m.cmd==='rasterPoints'){const r=makeRasterPoints(m);self.postMessage({id:m.id,ok:true,latArray:r.latArray,lngArray:r.lngArray,length:r.length,pixels:r.pixels,bounds:r.bounds,width:r.width,height:r.height,cellM:r.cellM},[r.latArray.buffer,r.lngArray.buffer,r.pixels.buffer]);return}if(m.cmd==='rasterSolve'){const r=await solveRaster(m);self.postMessage({id:m.id,ok:true,classData:r.classData,terrainOk:r.terrainOk,width:r.width,height:r.height,processed:r.processed,acceleration:r.acceleration||'WebCPU'},[r.classData.buffer]);return}}catch(e){self.postMessage({id:m.id,ok:false,error:String(e&&e.message||e)})}}
`}

  function getViewshedWorker(){try{const st=window.v249Viewshed;if(st.worker)return st.worker;const blob=new Blob([viewshedWorkerCode()],{type:'text/javascript'});st.worker=new Worker(URL.createObjectURL(blob));st.workerSeq=0;st.workerJobs={};st.worker.onmessage=function(ev){const d=ev.data||{},job=st.workerJobs&&st.workerJobs[d.id];if(d.progress){try{const acc=d.acceleration?(' · Acceleration: '+d.acceleration):'';field('viewshedStatus')&&(field('viewshedStatus').textContent=(d.message||'Rendering raster viewshed... '+(d.pct||0)+'%')+acc)}catch(_){};return}if(job){delete st.workerJobs[d.id];d.ok?job.resolve(d):job.reject(new Error(d.error||'Viewshed worker failed'))}};st.worker.onerror=function(ev){try{const msg=(ev&&ev.message)||'Viewshed worker error';setViewshedStatus('Viewshed worker error: '+msg);Object.keys(st.workerJobs||{}).forEach(k=>{try{st.workerJobs[k].reject(new Error(msg))}catch(_){}});st.workerJobs={};}catch(_){}};return st.worker}catch(e){console.warn('viewshed worker unavailable',e);return null}}
  function runViewshedWorker(cmd,payload,transfers){const st=window.v249Viewshed,w=getViewshedWorker();if(!w)return Promise.reject(new Error('Web Worker unavailable'));const id=++st.workerSeq;return new Promise((resolve,reject)=>{st.workerJobs[id]={resolve,reject};try{w.postMessage(Object.assign({id,cmd},payload||{}),Array.isArray(transfers)?transfers:[])}catch(e){delete st.workerJobs[id];reject(e);return}setTimeout(()=>{if(st.workerJobs&&st.workerJobs[id]){delete st.workerJobs[id];reject(new Error('Viewshed worker timed out'))}},600000)})}
  function viewshedStepStatus(stage, detail){
    try{
      const msg=String(stage||'').trim()+((detail&&String(detail).trim())?' · '+String(detail).trim():'');
      setViewshedStatus(msg);
    }catch(_){try{field('viewshedStatus')&&(field('viewshedStatus').textContent=String(stage||''))}catch(__){}}
  }
  function viewshedAccelerationMode(v){
    try{
      const raw=(v&&v.acceleration)||field('viewshedAcceleration')?.value||'Auto';
      return ['Auto','WebGPU','WebCPU'].includes(raw)?raw:'Auto';
    }catch(_){return 'Auto'}
  }
  function viewshedGridLatLngMain(center,dxM,dyM){
    const R=6371008.8;
    const lat=Number(center.lat)+(dyM/R)*180/Math.PI;
    const lng=Number(center.lng)+(dxM/(R*Math.cos(Number(center.lat)*Math.PI/180)))*180/Math.PI;
    return {lat,lng};
  }
  async function buildViewshedRasterPointsMain(center,radiusM,gridSize){
    const n=Number(gridSize)||480;
    const cellM=(2*radiusM)/n;
    const half=n/2;
    const maxPts=Math.ceil(Math.PI*n*n/4)+8;
    let latArr=new Float64Array(maxPts);
    let lngArr=new Float64Array(maxPts);
    let pixArr=new Int32Array(Math.max(2,(maxPts-1)*2));
    let count=1,pi=0;
    latArr[0]=Number(center.lat)||0;
    lngArr[0]=Number(center.lng)||0;
    const nw=viewshedGridLatLngMain(center,-radiusM,radiusM), se=viewshedGridLatLngMain(center,radiusM,-radiusM);
    const minLat=Math.min(nw.lat,se.lat), maxLat=Math.max(nw.lat,se.lat), minLng=Math.min(nw.lng,se.lng), maxLng=Math.max(nw.lng,se.lng);
    for(let y=0;y<n;y++){
      const dy=(half-y-0.5)*cellM;
      for(let x=0;x<n;x++){
        const dx=(x+0.5-half)*cellM;
        if(dx*dx+dy*dy>radiusM*radiusM)continue;
        const p=viewshedGridLatLngMain(center,dx,dy);
        latArr[count]=p.lat;
        lngArr[count]=p.lng;
        count++;
        pixArr[pi++]=x;
        pixArr[pi++]=y;
      }
      if(y>0 && y%80===0){
        viewshedStepStatus('Grid generated','building '+Math.round((y/n)*100)+'%');
        await new Promise(r=>setTimeout(r,0));
      }
    }
    return {latArray:latArr.slice(0,count),lngArray:lngArr.slice(0,count),length:count,pixels:pixArr.slice(0,pi),bounds:[[minLat,minLng],[maxLat,maxLng]],width:n,height:n,cellM};
  }
  async function calculateViewshedPass(v,center,radiusM,heightM,qs){
    const accMode=viewshedAccelerationMode(v);
    viewshedStepStatus(accMode+' ready', qs.quality+' '+qs.gridSize+'×'+qs.gridSize+' grid (~'+qs.estimatedCells.toLocaleString()+' cells)');
    await new Promise(r=>setTimeout(r,20));
    let pointMsg;
    const st=window.v249Viewshed;
    const pointKey=['points',Number(center.lat).toFixed(6),Number(center.lng).toFixed(6),Math.round(radiusM),qs.gridSize,'main'].join('|');
    try{
      st.rasterPointCache=st.rasterPointCache||new Map();
      const cachedPoints=st.rasterPointCache.get(pointKey);
      if(cachedPoints){
        pointMsg={latArray:new Float64Array(cachedPoints.latArray),lngArray:new Float64Array(cachedPoints.lngArray),length:cachedPoints.length,pixels:new Int32Array(cachedPoints.pixels),bounds:cachedPoints.bounds,width:cachedPoints.width,height:cachedPoints.height,cellM:cachedPoints.cellM};
        viewshedStepStatus('Grid generated','cached '+pointMsg.width+'×'+pointMsg.height+' · '+(Number(pointMsg.length)||0).toLocaleString()+' samples');
      }else{
        pointMsg=await buildViewshedRasterPointsMain(center,radiusM,qs.gridSize);
        viewshedStepStatus('Grid generated',(pointMsg.width||qs.gridSize)+'×'+(pointMsg.height||qs.gridSize)+' · '+((Number(pointMsg.length)||0).toLocaleString())+' samples');
        st.rasterPointCache.set(pointKey,{latArray:new Float64Array(pointMsg.latArray),lngArray:new Float64Array(pointMsg.lngArray),length:pointMsg.length,pixels:new Int32Array(pointMsg.pixels),bounds:pointMsg.bounds,width:pointMsg.width,height:pointMsg.height,cellM:pointMsg.cellM});
        while(st.rasterPointCache.size>8){const first=st.rasterPointCache.keys().next().value;st.rasterPointCache.delete(first)}
      }
    }catch(e){
      viewshedStepStatus('Grid generation failed',String(e&&e.message||e));
      throw e;
    }
    const points=normalizeViewshedPointSet(pointMsg,center);
    const pointCount=viewshedPointCount(points);
    const elevSource=v.elevationSource||'Auto';
    const elevKey=viewshedElevationCacheKey(center,radiusM,qs.gridSize,elevSource);
    let elevResult;
    try{
      viewshedStepStatus('Elevation sampling',(elevSource||'Auto')+' · '+pointCount.toLocaleString()+' samples');
      elevResult=await sampleElevations(points,{cache:v.cacheElevation!==false,key:elevKey,source:elevSource});
    }catch(e){
      viewshedStepStatus('Elevation sampling failed',String(e&&e.message||e));
      throw e;
    }
    let elev=elevResult&&elevResult.elev;
    if(elev&&!(elev instanceof Float32Array))elev=new Float32Array(elev);
    let terrainOk=!!(elevResult&&elevResult.ok&&elev&&elev.length===pointCount);
    if(terrainOk)viewshedStepStatus('Elevation sampling','complete · '+((elevResult&&elevResult.cached)?'cached ':'')+(elevResult&&elevResult.source?elevResult.source:'terrain'));
    else viewshedStepStatus('Elevation sampling','unavailable / fallback');
    let elevForWorker=terrainOk?new Float32Array(elev):new Float32Array(0);
    let pixelsForWorker=pointMsg.pixels instanceof Int32Array?pointMsg.pixels:new Int32Array(pointMsg.pixels||[]);
    let solved;
    try{
      viewshedStepStatus('Raster solve','Acceleration: '+accMode);
      solved=await runViewshedWorker('rasterSolve',{center,radiusM,heightM,gridSize:qs.gridSize,width:pointMsg.width,height:pointMsg.height,cellM:pointMsg.cellM,pixels:pixelsForWorker,angleBins:qs.angleBins,losSamples:qs.losSamples,terrainOk,elevBuffer:elevForWorker.buffer,acceleration:accMode},[pixelsForWorker.buffer,elevForWorker.buffer]);
    }catch(e){
      viewshedStepStatus('Raster solve failed',String(e&&e.message||e));
      throw e;
    }
    try{
      viewshedStepStatus('Overlay drawing',(solved.width||pointMsg.width)+'×'+(solved.height||pointMsg.height));
