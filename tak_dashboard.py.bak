# --- v280 stability cleanup baked TAK Map HTML override ---
# Built from v279 final HTML after pruning legacy ADS-B/runtime patch blocks.
TAK_MAP_HTML = '<!doctype html><html lang="en"><head><meta charset="utf-8"><title>TAK Map</title><meta name="viewport" content="width=device-width, initial-scale=1"><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"><style>\n:root{--bg:#06090d;--panel:#101923;--panel2:#14202b;--text:#e9f0f5;--muted:#8da0ad;--line:#273642;--accent:#ff6f2e;--good:#39d98a;--warn:#ffcc66;--bad:#ff5f57}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}.topbar{height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 14px;border-bottom:1px solid var(--line);background:rgba(4,8,12,.92);position:fixed;top:0;left:0;right:0;z-index:900}.title{display:flex;align-items:center;gap:11px;text-transform:uppercase;font-weight:900;letter-spacing:.08em}.title img{width:42px;height:42px;object-fit:contain}.top-actions{display:flex;align-items:center;gap:8px}.top-actions a,.top-actions button,.layer-button{background:#1d2833;color:var(--text);border:1px solid #354556;border-radius:999px;padding:6px 9px;text-decoration:none;font-weight:800;cursor:pointer;font-size:.78rem;line-height:1.15}.top-actions a:hover,.top-actions button:hover,.layer-button:hover{border-color:var(--accent)}#map{position:fixed;top:86px;left:396px;right:0;bottom:0;background:#081018}.sidebar{position:fixed;top:86px;left:0;bottom:0;width:396px;overflow:auto;background:linear-gradient(180deg,rgba(12,19,27,.98),rgba(6,10,14,.98));border-right:1px solid var(--line);z-index:800;padding:12px;transition:transform .2s ease}.sidebar.collapsed{transform:translateX(-396px)}.sidebar.collapsed~#map{left:0}.panel{border:1px solid var(--line);border-radius:14px;background:rgba(255,255,255,.035);padding:12px;margin-bottom:10px}.panel h2{margin:0 0 10px;font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:#c8d2da}.panel.collapsible h2{display:flex;align-items:center;justify-content:space-between;gap:8px;cursor:pointer;user-select:none}.panel-toggle{color:var(--accent);font-weight:1000}.panel.collapsed .panel-body{display:none}.panel.collapsed h2{margin-bottom:0}.zoom-indicator{position:fixed;right:14px;top:72px;z-index:700;min-width:312px;text-align:center;background:linear-gradient(180deg,rgba(255,255,255,.11),rgba(8,13,18,.90) 46%,rgba(4,8,12,.96));border:1px solid rgba(255,111,46,.38);border-radius:999px;color:#ffd9c5;padding:8px 14px;font-weight:900;letter-spacing:.025em;box-shadow:inset 0 1px 0 rgba(255,255,255,.18),inset 0 -1px 0 rgba(0,0,0,.62),0 14px 34px rgba(0,0,0,.42);backdrop-filter:blur(10px);text-shadow:0 1px 2px rgba(0,0,0,.9)}.zoom-indicator::before{content:\'\';display:inline-block;width:9px;height:9px;margin-right:8px;border-radius:999px;background:var(--good);box-shadow:0 0 7px rgba(57,217,138,.78)}.search-wrap{position:relative}.search,.select{width:100%;background:#091018;border:1px solid #334553;border-radius:10px;color:var(--text);padding:9px 10px}.search{padding-right:38px}.select{cursor:pointer}.search-clear{position:absolute;right:7px;top:7px;width:24px;height:24px;border-radius:999px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.05);color:var(--muted);font-weight:900;cursor:pointer}.search-clear:hover{color:var(--accent);border-color:rgba(255,111,46,.45)}.search-results{display:none;position:absolute;top:43px;left:0;right:0;z-index:1200;max-height:260px;overflow:auto;border:1px solid rgba(255,111,46,.38);border-radius:13px;background:rgba(6,10,14,.86);backdrop-filter:blur(10px);box-shadow:0 18px 40px rgba(0,0,0,.52);padding:6px}.search-result-item{display:flex;align-items:center;justify-content:space-between;gap:10px;width:100%;text-align:left;border:0;border-bottom:1px solid rgba(255,255,255,.055);background:transparent;color:var(--text);padding:8px 9px;border-radius:9px;cursor:pointer}.search-result-item:last-child{border-bottom:0}.search-result-item:hover{background:rgba(255,111,46,.13)}.search-result-item b{display:block;font-size:.82rem}.search-result-item small{display:block;color:var(--muted);font-size:.72rem}.search-result-chip{color:#ffd0b0;border:1px solid rgba(255,111,46,.35);border-radius:999px;padding:2px 6px;font-size:.66rem;white-space:nowrap}.sidebar,.sync-list,.search-results,.status-dropdown{scrollbar-width:thin;scrollbar-color:rgba(255,111,46,.62) rgba(255,255,255,.04)}.sidebar::-webkit-scrollbar,.sync-list::-webkit-scrollbar,.search-results::-webkit-scrollbar,.status-dropdown::-webkit-scrollbar{width:10px;height:10px}.sidebar::-webkit-scrollbar-track,.sync-list::-webkit-scrollbar-track,.search-results::-webkit-scrollbar-track,.status-dropdown::-webkit-scrollbar-track{background:rgba(255,255,255,.035);border-radius:999px}.sidebar::-webkit-scrollbar-thumb,.sync-list::-webkit-scrollbar-thumb,.search-results::-webkit-scrollbar-thumb,.status-dropdown::-webkit-scrollbar-thumb{background:linear-gradient(180deg,rgba(255,111,46,.75),rgba(255,204,102,.42));border-radius:999px;border:2px solid rgba(6,10,14,.92)}.search-dim{opacity:.24;filter:grayscale(.72)}.search-hit{filter:drop-shadow(0 0 12px rgba(255,111,46,.80))}.muted{color:var(--muted);font-size:.84rem}.danger{color:var(--bad);font-size:.84rem}.row{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:7px 0;border-bottom:1px solid rgba(255,255,255,.055)}.row:last-child{border-bottom:0}.row label{display:flex;align-items:center;gap:8px;min-width:0}.row span{min-width:0}.row small{display:block;color:var(--muted);font-size:.72rem;margin-top:1px}.row input{accent-color:var(--accent)}.chip{border:1px solid rgba(255,111,46,.4);background:rgba(255,111,46,.08);border-radius:999px;padding:3px 8px;color:#ffd0b0;font-size:.72rem;white-space:nowrap}.subgroup{margin-top:8px}.subgroup-title{font-size:.72rem;text-transform:uppercase;letter-spacing:.09em;color:var(--muted);margin:8px 0 3px}.map-footer{display:none!important}.sidebar.collapsed~.map-footer{left:14px}.aircraft-wrap{display:flex;flex-direction:column;align-items:center;pointer-events:none}.aircraft-glyph{width:38px;height:48px;display:block;overflow:visible;filter:drop-shadow(0 0 10px rgba(0,0,0,.82))}.aircraft-glyph.selected{filter:drop-shadow(0 0 12px currentColor)}.aircraft-label{margin-top:-3px;max-width:96px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;border:1px solid currentColor;border-radius:6px;background:rgba(5,8,12,.82);color:currentColor;font-size:10px;font-weight:900;letter-spacing:.03em;padding:1px 5px;text-shadow:0 1px 2px #000}.aircraft-civil{color:#8bd742}.aircraft-military{color:#2386ff}.aircraft-stale{color:#87909a!important;opacity:.72}.sidebar-tab{position:fixed;top:calc(50% + 14px);left:396px;transform:translateY(-50%);z-index:825;display:flex;align-items:center;justify-content:center;width:22px;height:58px;border-radius:0 999px 999px 0;border:1px solid var(--line);border-left:0;background:rgba(8,13,18,.88);color:var(--accent);font-size:24px;font-weight:900;cursor:pointer;box-shadow:0 0 18px rgba(0,0,0,.35)}.sidebar.collapsed~.sidebar-tab{left:0;display:flex}.sidebar-tab:hover{background:rgba(255,111,46,.12)}.map-status-banner{position:fixed;top:64px;left:462px;right:auto;width:max-content;max-width:calc(100vw - 476px);height:42px;z-index:850;display:flex;align-items:center;gap:18px;padding:0 18px;border:1px solid rgba(255,255,255,.10);border-radius:16px;background:rgba(8,13,18,.90);color:#d7e1e8;font-size:.76rem;font-weight:850;letter-spacing:.02em;white-space:nowrap;overflow:hidden;box-shadow:0 14px 34px rgba(0,0,0,.34)}.map-status-banner .status-item{display:inline-flex;align-items:center;gap:7px;min-width:0}.map-status-banner .status-dropdown-trigger{cursor:pointer;border-radius:999px;padding:4px 6px;margin:-4px -6px}.map-status-banner .status-dropdown-trigger:hover{background:rgba(255,255,255,.07)}.status-dropdown{display:none;position:fixed;z-index:930;min-width:210px;max-width:min(360px,calc(100vw - 24px));max-height:300px;overflow:auto;padding:8px;border:1px solid rgba(255,255,255,.12);border-radius:14px;background:rgba(8,13,18,.92);box-shadow:0 18px 40px rgba(0,0,0,.46);backdrop-filter:blur(10px);color:#d7e1e8;font-size:.76rem}.status-dropdown.active{display:block}.status-dropdown.adsb-table{min-width:330px;max-width:min(430px,calc(100vw - 24px));padding:8px}.status-dropdown-title{font-weight:900;text-transform:uppercase;letter-spacing:.08em;color:#c8d2da;margin:2px 4px 7px}.status-dropdown-row{display:flex;justify-content:space-between;gap:10px;padding:6px 7px;border-bottom:1px solid rgba(255,255,255,.055);border-radius:8px}.status-dropdown-row:last-child{border-bottom:0}.status-dropdown-row:hover{background:rgba(255,255,255,.05)}.status-dropdown-name{font-weight:850;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.status-dropdown-sub{color:var(--muted);font-size:.68rem;white-space:nowrap}.status-dropdown-empty{color:var(--muted);padding:8px 7px}.status-adsb-head,.status-adsb-row{display:grid;grid-template-columns:minmax(96px,1fr) 82px 116px;gap:8px;align-items:center;padding:6px 7px}.status-adsb-head{position:sticky;top:-8px;z-index:2;margin:0 -2px 3px;border-bottom:1px solid rgba(255,255,255,.12);background:rgba(8,13,18,.96);color:#ffd9c5;font-size:.66rem;font-weight:900;text-transform:uppercase;letter-spacing:.07em}.status-adsb-row{border-bottom:1px solid rgba(255,255,255,.055);border-radius:8px}.status-adsb-row:hover{background:rgba(255,255,255,.05)}.status-adsb-row span{min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.status-adsb-icao{font-weight:850}.status-adsb-alt,.status-adsb-range{color:var(--muted);text-align:right}.map-status-banner .status-dot{width:9px;height:9px;border-radius:999px;background:var(--muted);box-shadow:0 0 7px rgba(141,160,173,.45);flex:0 0 auto}.map-status-banner .status-dot.good{background:var(--good);box-shadow:0 0 8px rgba(57,217,138,.78)}.map-status-banner .status-dot.warn{background:var(--warn);box-shadow:0 0 8px rgba(255,204,102,.70)}.map-status-banner .status-dot.bad{background:var(--bad);box-shadow:0 0 8px rgba(255,95,87,.70)}.map-status-banner .status-dot.unknown{background:var(--muted);box-shadow:0 0 6px rgba(141,160,173,.42)}.map-status-banner b{color:#fff}.sidebar.collapsed~.map-status-banner{left:66px;max-width:calc(100vw - 80px)}.relief-controls{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center;margin-top:8px}.relief-controls input[type=range]{width:100%}.local-data-list{max-height:190px;overflow:auto;border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:5px;background:rgba(0,0,0,.12)}.local-data-row{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center;border-bottom:1px solid rgba(255,255,255,.05);padding:7px 3px}.local-data-row:last-child{border-bottom:0}.local-data-row small{display:block;color:var(--muted);line-height:1.35}.local-data-main{display:grid;grid-template-columns:24px 1fr;gap:8px;align-items:start;min-width:0;cursor:pointer}.local-data-main span{min-width:0}.local-goto-btn{padding:4px 7px!important;font-size:.66rem!important;align-self:center}.local-actions{position:sticky;bottom:0;display:grid;grid-template-columns:1fr repeat(4,auto);gap:6px;align-items:center;padding:8px 0 2px;margin-top:4px;border-top:1px solid rgba(255,255,255,.08);background:linear-gradient(180deg,rgba(16,25,35,0),rgba(16,25,35,.98) 30%)}.local-actions .layer-button{padding:5px 8px;font-size:.70rem}.local-actions .local-selected-count{justify-self:start}.local-add-row{padding:10px 0 10px;margin:6px 0}.local-section .subgroup-title{cursor:pointer}.local-section.collapsed .local-data-list,.local-section.collapsed .local-actions{display:none}.local-section .toggle{color:var(--accent);font-weight:900;margin-right:5px}.tak-icon-wrap{display:flex;align-items:center;justify-content:center;filter:drop-shadow(0 0 8px rgba(0,0,0,.75))}.tak-icon-svg{display:block;overflow:visible}.tak-mil2525-img{display:block;width:40px;height:40px;object-fit:contain}.tak-icon-selected{filter:drop-shadow(0 0 10px currentColor)}.icon-blue{color:#2386ff}.icon-purple{color:#b56cff}.icon-green{color:#8bd742}.icon-red{color:#ff3b35}.icon-yellow{color:#ffb000}.icon-gray{color:#9aa1a8}.icon-cyan{color:#20d4e8}.sync-list,.import-list,.offline-list{max-height:300px;overflow:auto}.sync-card,.import-card,.offline-card{border:1px solid rgba(255,255,255,.07);border-radius:10px;background:rgba(0,0,0,.18);padding:8px;margin:6px 0}.datasync-section{border:1px solid rgba(255,255,255,.065);border-radius:10px;background:rgba(255,255,255,.018);margin:6px 0;overflow:hidden}.datasync-section-title{display:flex;align-items:center;gap:7px;margin:0!important;padding:7px 8px;cursor:pointer;user-select:none;background:rgba(255,111,46,.055);border-bottom:1px solid rgba(255,255,255,.055)}.datasync-section-title .toggle{color:var(--accent);font-weight:1000;width:13px;text-align:center}.datasync-section-title .section-label{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.datasync-section-list{padding:4px 6px 6px}.datasync-section.collapsed .datasync-section-list{display:none}.datasync-section.collapsed .datasync-section-title{border-bottom:0}.datasync-section .sync-card{padding:6px 8px;margin:4px 0}.datasync-section .sync-card b{display:block;font-size:.77rem;line-height:1.18}.datasync-section .sync-card small{display:block;font-size:.66rem;line-height:1.2;color:var(--muted);margin-top:2px}.datasync-empty{padding:7px 8px}.offline-card .row{justify-content:flex-start;gap:6px;flex-wrap:wrap}.sync-card-actionable{display:grid;grid-template-columns:1fr auto;gap:7px;align-items:start}.sync-card-main{min-width:0}.sync-card-actions{display:flex;gap:4px;flex-wrap:wrap;justify-content:flex-end}.sync-card-actions .layer-button{padding:4px 6px;font-size:.66rem}.offline-packs-title{display:flex;align-items:center;justify-content:space-between;gap:8px}.offline-card-title{display:flex;align-items:center;justify-content:space-between;gap:8px}.offline-card-title b{min-width:0;overflow:hidden;text-overflow:ellipsis}.offline-status-chip{margin-left:auto;text-transform:capitalize}.offline-status-chip.good{border-color:rgba(57,217,138,.55);background:rgba(57,217,138,.14);color:#b8ffd8;box-shadow:0 0 10px rgba(57,217,138,.18)}.offline-zoom-input{padding-right:9px!important}.offline-zoom-input::-webkit-inner-spin-button,.offline-zoom-input::-webkit-outer-spin-button{opacity:1!important;transform:scale(1.18);margin-left:5px;cursor:pointer}.popup-edit-actions .danger-action{border-color:rgba(255,95,87,.55);color:#ffd1cf}.leaflet-popup.editing .leaflet-popup-content-wrapper{box-shadow:0 0 0 1px rgba(255,111,46,.45),0 18px 45px rgba(0,0,0,.65)!important}.draw-help{color:#ffd0b0;font-size:.78rem;margin-top:6px}.send-modal{display:none;position:fixed;inset:0;z-index:2200;background:rgba(0,0,0,.62);align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(3px)}.send-modal.active{display:flex}.send-box{width:min(620px,94vw);max-height:86vh;overflow:auto;border:1px solid rgba(255,111,46,.38);border-radius:18px;background:linear-gradient(180deg,rgba(15,22,31,.99),rgba(7,12,18,.99));box-shadow:0 24px 70px rgba(0,0,0,.62);padding:16px}.send-box h3{margin:0 0 8px}.send-eud-row{display:grid;grid-template-columns:24px 1fr auto;gap:10px;align-items:start;border:1px solid rgba(255,255,255,.08);border-radius:14px;background:rgba(255,255,255,.035);padding:10px;margin:8px 0}.send-eud-row input{margin-top:4px;accent-color:#ff6f2e}.send-eud-main b{display:block;font-size:.94rem}.send-eud-client{color:#ffd0b0;font-size:.74rem;font-weight:800;letter-spacing:.04em}.send-eud-row small{color:var(--muted);display:block;line-height:1.45}.send-eud-status{display:inline-flex;align-items:center;border:1px solid rgba(255,255,255,.10);border-radius:999px;padding:2px 7px;font-size:.68rem;text-transform:uppercase;color:#cfe4ff;background:rgba(35,134,255,.10)}.send-footer{display:flex;justify-content:space-between;align-items:center;