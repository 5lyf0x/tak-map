    TAK_MAP_LOGIN_HTML = _v302_set_versions(TAK_MAP_LOGIN_HTML)
    LOGIN_HTML = _v302_set_versions(LOGIN_HTML)
    TAK_MAP_HTML = TAK_MAP_HTML.replace('<div class="version-product">TAK Server Dashboard</div>', '<div class="version-product">TAK Map</div>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace('<a href="/">Dashboard</a>', '')
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/v301', 'TAKDashboard/v302')
