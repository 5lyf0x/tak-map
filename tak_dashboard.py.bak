    {'id':'esri_topo','label':'ESRI World Topographic','group':'Topo / Terrain','type':'xyz','url':'https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}','attribution':'Tiles © ESRI','minZoom':0,'maxZoom':19},
