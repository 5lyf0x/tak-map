_v274_marker='</script></body></html>'
_v274_i=TAK_MAP_HTML.rfind(_v274_marker)
if _v274_i >= 0:
    TAK_MAP_HTML = TAK_MAP_HTML[:_v274_i] + _v274_js + TAK_MAP_HTML[_v274_i:]
# --- end v274 drawing uploader/freehand and ADS-B parser diagnostics ---

# --- v275 UI stability, single drawing dialog, ADS-B worker/performance/layout polish ---
# Release label remains 1.1.0; only the internal/package iteration marker advances to v275.
for _old in ('v274','v273','v272','v271','v270','v269','v268','v266','v264'):
    TAK_MAP_HTML = TAK_MAP_HTML.replace('TAKDashboard/'+_old, 'TAKDashboard/v301')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<span class="iteration-chip">{_old}</span>', '<span class="iteration-chip">v301</span>')
    TAK_MAP_HTML = TAK_MAP_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<div class="iteration-marker">{_old}</div>', '<div class="iteration-marker">v301</div>')
    TAK_MAP_LOGIN_HTML = TAK_MAP_LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v275</span>')
    LOGIN_HTML = LOGIN_HTML.replace(f'<span>{_old}</span>', '<span>v275</span>')

_v275_js = r'''
/* v275 single drawing dialog, compact popups, stable ADS-B menu, client ADS-B worker */
(function(){
  const V='v301';
  const $=id=>document.getElementById(id);
  const esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  function addCss(){try{if($('v275Style'))return;const css=`
    .leaflet-popup.tak-object-popup .leaflet-popup-content-wrapper,
    .leaflet-popup.adsb-object-popup .leaflet-popup-content-wrapper,
    .leaflet-popup .feature-popup{background:linear-gradient(180deg,rgba(13,22,30,.98),rgba(6,11,17,.985))!important;color:#e8f1f4!important;border:1px solid rgba(255,255,255,.16)!important;border-radius:13px!important;box-shadow:0 16px 44px rgba(0,0,0,.58)!important;backdrop-filter:blur(8px)!important;}
    .leaflet-popup.tak-object-popup .leaflet-popup-tip,
    .leaflet-popup.adsb-object-popup .leaflet-popup-tip{background:rgba(8,14,20,.985)!important;border:1px solid rgba(255,255,255,.12)!important;box-shadow:0 10px 28px rgba(0,0,0,.42)!important;}
    .leaflet-popup.tak-object-popup .leaflet-popup-content,
    .leaflet-popup.adsb-object-popup .leaflet-popup-content{margin:0!important;min-width:258px!important;max-width:min(430px,82vw)!important;}
    .feature-popup{min-width:258px!important;max-width:min(430px,82vw)!important;font-size:.75rem!important;line-height:1.24!important;border-radius:13px!important;overflow:hidden!important;}
    .feature-popup h3{font-size:.86rem!important;letter-spacing:.02em!important;text-transform:none!important;padding:8px 11px!important;white-space:nowrap!important;overflow:hidden!important;text-overflow:ellipsis!important;color:#f3f8fa!important;background:rgba(255,255,255,.045)!important;border-bottom:1px solid rgba(255,255,255,.09)!important;}
    .feature-popup .kvp{grid-template-columns:92px minmax(0,1fr)!important;gap:4px 9px!important;padding:8px 11px!important;}
    .feature-popup .kvp b{font-size:.68rem!important;text-transform:none!important;letter-spacing:.015em!important;color:#9fb0bc!important;font-weight:750!important;}
    .feature-popup .kvp span{font-size:.75rem!important;color:#eaf2f5!important;overflow-wrap:anywhere!important;}
    .feature-popup .v275-area-lines{display:block;line-height:1.35;}
    .feature-popup .v275-area-lines span{display:block!important;}
    body.v275-saving-shape #drawOptionsPanel{display:none!important;}
    #drawOptionsPanel #drawOptionsSaveBtn,#drawOptionsPanel #drawNameInput,#drawOptionsPanel #drawNotesInput,#drawOptionsPanel label:has(#drawNameInput),#drawOptionsPanel label:has(#drawNotesInput){display:none!important;}
    .draw-save-backdrop.active{z-index:5000!important;}
    #adsbV275CenterBlock{display:grid!important;gap:7px!important;margin:6px 0 8px!important;min-height:118px!important;}
    #adsbV275CenterBlock .adsb-v275-row{display:grid!important;gap:8px!important;align-items:center!important;width:100%!important;min-height:32px!important;}
    #adsbV275CenterBlock .adsb-v275-row.top{grid-template-columns:minmax(0,1fr) auto!important;}
    #adsbV275CenterBlock .adsb-v275-row.actions{grid-template-columns:auto auto!important;justify-content:space-between!important;}
    #adsbV275CenterBlock label{margin:0!important;color:#c8d2da!important;font-size:.72rem!important;text-transform:none!important;letter-spacing:.015em!important;}
    #adsbV275CenterBlock select,#adsbV275CenterBlock input[type=text]{width:100%!important;min-height:30px!important;background:#091018!important;border:1px solid #334553!important;border-radius:9px!important;color:var(--text)!important;padding:6px 8px!important;}
    #adsbV275CenterBlock .follow{display:inline-grid!important;grid-template-columns:max-content 18px!important;gap:7px!important;align-items:center!important;white-space:nowrap!important;border:1px solid rgba(255,255,255,.08)!important;border-radius:999px!important;padding:6px 8px!important;background:rgba(255,255,255,.035)!important;}
    #adsbV275CenterBlock .follow input{width:16px!important;height:16px!important;accent-color:var(--accent)!important;}
    #adsbV275CenterBlock .layer-button{margin:0!important;min-width:112px!important;}
    #adsbTestBtn{display:none!important;}
    #adsbSettingsStatus{min-height:26px!important;max-height:26px!important;line-height:24px!important;overflow:hidden!important;}
    .aircraft-glyph,.aircraft-glyph.selected{filter:none!important;}
    .aircraft-label{text-shadow:none!important;box-shadow:none!important;background:rgba(5,8,12,.88)!important;}
  `;const el=document.createElement('style');el.id='v275Style';el.textContent=css;document.head.appendChild(el)}catch(e){}}
  function removeAdsbDiagnostics(){try{document.querySelectorAll('#adsbTestBtn,[onclick*="v274TestAdsb"],.adsb-test-row,.adsb-diagnostic,.adsb-diagnostics').forEach(n=>n.remove())}catch(_){}}
  function resetTransientUiOnce(){try{if(window._v275TransientResetDone)return;window._v275TransientResetDone=true;try{if(typeof setActiveMapTool==='function')setActiveMapTool('move')}catch(_){}try{if(typeof activeMapTool!=='undefined')activeMapTool='move'}catch(_){}['drawOptionsPanel','drawSaveBackdrop','viewshedModule','viewshedMinimized'].forEach(id=>{const n=$(id);if(n){n.classList.remove('active','open');n.style.display=''}});try{document.body.classList.remove('v275-saving-shape')}catch(_){}try{if(window.map&&map.closePopup)map.closePopup()}catch(_){}try{for(const store of [localStorage,sessionStorage]){for(let i=store.length-1;i>=0;i--){const k=store.key(i)||'';if(/takmap\.(draw|shape).*?(open|active|mode|panel|options|dialog)/i.test(k))store.removeItem(k)}}}catch(_){}}catch(e){}}
  function sanitizeDrawOptionsPanel(){try{const p=$('drawOptionsPanel');if(!p)return;try{p.querySelectorAll('#drawOptionsSaveBtn,[onclick*="v233FinishDraw"],[onclick*="Save Shape"]').forEach(n=>n.remove())}catch(_){};['drawNameInput','drawNotesInput'].forEach(id=>{const el=$(id);const lab=el&&el.closest('label');if(lab)lab.remove();else if(el)el.remove()});try{p.querySelectorAll('label,.row,div').forEach(n=>{const t=(n.textContent||'').trim().toLowerCase();if((t==='name'||t.startsWith('name'))&&n.querySelector('input,textarea'))n.remove();if((t==='notes'||t.startsWith('notes'))&&n.querySelector('input,textarea'))n.remove();})}catch(_){};if(document.body.classList.contains('v275-saving-shape'))p.classList.remove('active','open')}catch(e){}}
  function monitorSaveShape(){try{const b=$('drawSaveBackdrop');const active=!!(b&&b.classList.contains('active'));document.body.classList.toggle('v275-saving-shape',active);if(active){const p=$('drawOptionsPanel');if(p)p.classList.remove('active','open')}}catch(_){} }
  function patchDrawingSingleDialog(){try{if(window._v275DrawingPatched)return;window._v275DrawingPatched=true;const oldOpen=window.v236OpenDrawOptions;if(typeof oldOpen==='function'){window.v236OpenDrawOptions=function(){const r=oldOpen.apply(this,arguments);setTimeout(sanitizeDrawOptionsPanel,0);return r}}const oldStart=window.v233StartDraw;if(typeof oldStart==='function'){window.v233StartDraw=function(){const r=oldStart.apply(this,arguments);setTimeout(sanitizeDrawOptionsPanel,0);return r}}const oldFinish=window.v233FinishDraw;if(typeof oldFinish==='function'){window.v233FinishDraw=function(){sanitizeDrawOptionsPanel();monitorSaveShape();return oldFinish.apply(this,arguments)}}}catch(e){}}
  function disableAssetEditors(){try{document.querySelectorAll('label,.popup-edit-row,.edit-row,.kvp').forEach(row=>{const label=(row.querySelector('b,label,span')?.textContent||row.textContent||'').trim().toLowerCase();if(/^asset\b/.test(label)){row.querySelectorAll('input,select,textarea').forEach(el=>{el.disabled=true;el.readOnly=true;el.classList.add('v275-readonly-asset')})}})}catch(_){} }
  function polishFeaturePopups(){try{document.querySelectorAll('.feature-popup .kvp').forEach(kvp=>{const kids=Array.from(kvp.children);for(let i=0;i<kids.length-1;i++){const b=kids[i],s=kids[i+1];if(!b||b.tagName!=='B'||!s)continue;const label=(b.textContent||'').trim().toLowerCase();if(label==='category'){const title=(kvp.closest('.feature-popup')?.querySelector('h3')?.textContent||'').toLowerCase();const txt=(s.textContent||'').toLowerCase();if(title.includes('shape')||txt.includes('shape')){b.remove();s.remove();continue}}if(label==='area'||label==='shape area'){let text=(s.textContent||'').trim();if(text){let parts=text.split(/\s*[|,;•]\s*/).filter(Boolean);if(parts.length<2)parts=text.replace(/\s+(sq\s*ft|square\s*feet|sq\s*m|square\s*meters|acres?|hectares?)/ig,' $1|').split('|').map(x=>x.trim()).filter(Boolean);if(parts.length>1){s.innerHTML='<span class="v275-area-lines">'+parts.map(x=>'<span>'+esc(x)+'</span>').join('')+'</span>'}}}}})}catch(_){} }
  function popupObserver(){try{if(window._v275PopupObserver)return;window._v275PopupObserver=new MutationObserver(()=>{polishFeaturePopups();disableAssetEditors();monitorSaveShape();removeAdsbDiagnostics();sanitizeDrawOptionsPanel()});window._v275PopupObserver.observe(document.body,{childList:true,subtree:true,attributes:true,attributeFilter:['class']})}catch(_){} }
  function readCombinedCenter(){try{const v=String($('adsbCenterLatLon')?.value||'').trim();const m=v.match(/(-?\d+(?:\.\d+)?)\s*[,\s]+\s*(-?\d+(?:\.\d+)?)/);if(m){const lat=Number(m[1]),lon=Number(m[2]);if(Number.isFinite(lat)&&Number.isFinite(lon)&&lat>=-90&&lat<=90&&lon>=-180&&lon<=180)return {lat,lon}}const lat=Number($('adsbCenterLat')?.value),lon=Number($('adsbCenterLon')?.value);if(Number.isFinite(lat)&&Number.isFinite(lon))return {lat,lon}}catch(_){}return null}
  function writeCenter(lat,lon){try{lat=Number(lat);lon=Number(lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return;const str=lat.toFixed(6)+', '+lon.toFixed(6);if($('adsbCenterLatLon'))$('adsbCenterLatLon').value=str;if($('adsbCenterLat'))$('adsbCenterLat').value=lat.toFixed(6);if($('adsbCenterLon'))$('adsbCenterLon').value=lon.toFixed(6)}catch(_){} }
  function followMapCenter(){return !!$('adsbFollowMapCenter')?.checked}
  function getAdsbCenter(){try{if(followMapCenter()&&window.map){const c=map.getCenter();writeCenter(c.lat,c.lng);return {lat:Number(c.lat),lon:Number(c.lng)}}const c=readCombinedCenter();if(c)return c;return null}catch(_){return null}}
  function ensureAdsbCenterLayout(){try{const menu=$('adsbV270Menu')||document.querySelector('[data-collapse-key="adsbSettings"] .panel-body');if(!menu)return;removeAdsbDiagnostics();let block=$('adsbV275CenterBlock');if(!block){block=document.createElement('div');block.id='adsbV275CenterBlock';block.innerHTML=`<div class="adsb-v275-row top"><label>Center Source<select id="adsbCenterSourceV275"><option value="manual">Manual</option><option value="map_center">Map Center</option></select></label><label class="follow">Follow Map Center<input id="adsbFollowMapCenter" type="checkbox"></label></div><label>Center Lat/Lon<input id="adsbCenterLatLon" type="text" inputmode="decimal" placeholder="34.000000, -118.000000"></label><div class="adsb-v275-row actions"><button id="adsbUseMapCenterV275" class="layer-button" type="button">Use Map Center</button><button id="adsbRefreshV275" class="layer-button" type="button">Refresh</button></div>`;const grid=menu.querySelector('.adsb-settings-grid')||menu.firstElementChild;if(grid&&grid.parentElement)grid.parentElement.insertBefore(block,grid.nextSibling);else menu.insertBefore(block,menu.firstChild)}const srcOld=$('adsbCenterSource'),srcNew=$('adsbCenterSourceV275');if(srcOld&&srcNew&&!srcNew.dataset.bound){srcNew.value=srcOld.value||'manual';srcNew.addEventListener('change',()=>{if(srcOld)srcOld.value=srcNew.value;if(srcNew.value==='map_center'&&followMapCenter()&&window.map){const c=map.getCenter();writeCenter(c.lat,c.lng)}try{if(typeof saveAdsbSettings==='function')saveAdsbSettings(false)}catch(_){}});srcNew.dataset.bound='1'}const follow=$('adsbFollowMapCenter');if(follow&&!follow.dataset.bound){follow.checked=false;follow.addEventListener('change',()=>{if(follow.checked&&window.map){const c=map.getCenter();writeCenter(c.lat,c.lng);try{refreshAdsb()}catch(_){}}});follow.dataset.bound='1'}const combo=$('adsbCenterLatLon');if(combo&&!combo.dataset.bound){combo.addEventListener('change',()=>{const c=readCombinedCenter();if(c){writeCenter(c.lat,c.lon);try{if(typeof saveAdsbSettings==='function')saveAdsbSettings(false)}catch(_){}try{refreshAdsb()}catch(_){}}});combo.addEventListener('input',()=>{const c=readCombinedCenter();if(c)writeCenter(c.lat,c.lon)});combo.dataset.bound='1'}const use=$('adsbUseMapCenterV275');if(use&&!use.dataset.bound){use.onclick=()=>{try{if(window.map){const c=map.getCenter();writeCenter(c.lat,c.lng);const src=$('adsbCenterSourceV275');if(src)src.value='map_center';if($('adsbCenterSource'))$('adsbCenterSource').value='map_center';try{if(typeof saveAdsbSettings==='function')saveAdsbSettings(false)}catch(_){}try{refreshAdsb()}catch(_){}}}catch(_){}};use.dataset.bound='1'}const ref=$('adsbRefreshV275');if(ref&&!ref.dataset.bound){ref.onclick=()=>{try{refreshAdsb()}catch(_){}};ref.dataset.bound='1'}const lat=$('adsbCenterLat'),lon=$('adsbCenterLon');if(lat&&lon&&!combo?.value){const la=Number(lat.value),lo=Number(lon.value);if(Number.isFinite(la)&&Number.isFinite(lo))writeCenter(la,lo)}['adsbCenterLat','adsbCenterLon','adsbCenterSource'].forEach(id=>{const el=$(id);const lab=el&&el.closest('label');if(lab)lab.style.display='none'});const oldUse=document.querySelector('[onclick="useMapCenterForAdsb()"]');if(oldUse)oldUse.style.display='none';const oldSave=document.querySelector('[onclick="saveAdsbSettings(false)"]');if(oldSave)oldSave.style.display='none'}catch(e){} }
  window.useMapCenterForAdsb=function(){try{if(!window.map)return;const c=map.getCenter();writeCenter(c.lat,c.lng);if($('adsbCenterSource'))$('adsbCenterSource').value='map_center';if($('adsbCenterSourceV275'))$('adsbCenterSourceV275').value='map_center';try{refreshAdsb()}catch(_){}}catch(_){} }
  function setAdsbStatus(msg,bad){try{const b=$('adsbSettingsStatus');if(b){b.textContent=msg||'';b.classList.toggle('adsb-status-bad',!!bad);b.classList.toggle('adsb-status-ok',!bad)}}catch(_){} }
  function filters(){try{return {civil:$('adsbFilterCivil')?.checked!==false,military:$('adsbFilterMilitary')?.checked!==false,govt:$('adsbFilterGovt')?.checked!==false,unknown:$('adsbFilterUnknown')?.checked!==false}}catch(_){return {civil:true,military:true,govt:true,unknown:true}}}
  function ensureLayer(){try{if(window.aircraftLayer&&window.map&&!map.hasLayer(aircraftLayer))aircraftLayer.addTo(map)}catch(_){} }
  function buildWorkerCode(){return `const govtTerms=['POLICE','SHERIFF','STATE POLICE','HIGHWAY PATROL','CHP','CAL FIRE','CALFIRE','FIRE','FIRE DEPT','FIRE DEPARTMENT','RESCUE','SEARCH AND RESCUE','PUBLIC SAFETY','LAW ENFORCEMENT','EMS','MEDEVAC','AIR AMBULANCE','AMBULANCE','USFS','FOREST SERVICE','BUREAU OF LAND MANAGEMENT',' BLM','NIFC','FEMA','DHS','CBP','CUSTOMS','BORDER PATROL','DEA','FBI','MARSHAL','NASA','NOAA','NPS','PARK SERVICE','COAST GUARD','USCG','LIFE FLIGHT','LIFEGUARD'];function flags(o){try{return parseInt(o.dbFlags??o.dbflags??0)||0}catch(e){return 0}}function blob(o){return ['flight','callsign','r','registration','t','type','desc','description','ownOp','operator','owner','squawk','hex'].map(k=>o&&o[k]).filter(Boolean).join(' ').toUpperCase()}function helo(o){const t=blob(o);return /\\b(H|HEL|HELI|HELO|ROTOR)\\b/.test(t)||['B407','B412','B429','B206','R22','R44','R66','S76','S92','H135','H145','UH60','MH60','HH60','CH47','AH64'].some(x=>t.includes(x))}function cat(o){if(flags(o)&1)return 'military';const t=blob(o);if(govtTerms.some(x=>t.includes(x)))return 'govt';if(!o.flight&&!o.r&&!o.t&&!o.hex)return 'unknown';return 'civil'}function dist(a,b,c,d){const R=3958.7613,rad=Math.PI/180;const x=(c-a)*rad,y=(d-b)*rad;const s=Math.sin(x/2)**2+Math.cos(a*rad)*Math.cos(c*rad)*Math.sin(y/2)**2;return 2*R*Math.atan2(Math.sqrt(s),Math.sqrt(1-s))}function norm(raw,center){let lat=Number(raw&&raw.lat),lon=Number(raw&&raw.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180)return null;let alt=raw.alt_baro;if(String(alt).toLowerCase()==='ground')alt=0;if(alt==null)alt=raw.alt_geom??raw.altitude;const c=cat(raw);const hex=String(raw.hex||raw.icao||'').trim().toUpperCase();const reg=String(raw.r||raw.registration||'').trim().toUpperCase();const flight=String(raw.flight||raw.callsign||'').trim();const id=hex||reg||flight||('aircraft-'+lat.toFixed(4)+'-'+lon.toFixed(4));const seen=raw.seen_pos??raw.seen;return {id,icao:hex,hex,registration:reg,callsign:flight||reg||hex||'ADS-B',flight,lat,lon,altitude_ft:alt,speed_kt:raw.gs??raw.speed,track_deg:raw.track??raw.true_heading??raw.mag_heading,seen_seconds:seen,seen_pos:raw.seen_pos,seen:raw.seen,category:c,category_class:c,aircraft_class:c,is_military:c==='military',is_govt:c==='govt',is_unknown:c==='unknown',is_helo:helo(raw),is_rotor:helo(raw),type:raw.t||raw.type||'',aircraft_type:raw.t||raw.type||'',description:raw.desc||raw.description||'',owner_operator:raw.ownOp||raw.operator||raw.owner||'',ownOp:raw.ownOp||'',dbFlags:raw.dbFlags??raw.dbflags??0,squawk:raw.squawk||'',emergency:raw.emergency||'',range_miles:Math.round(dist(center.lat,center.lon,lat,lon)*100)/100,source:'Airplanes.live Client Direct',updated:new Date().toISOString()}}self.onmessage=async ev=>{const m=ev.data||{};if(m.cmd!=='fetch')return;try{const url='https://api.airplanes.live/v2/point/'+Number(m.center.lat).toFixed(6)+'/'+Number(m.center.lon).toFixed(6)+'/'+Math.round(m.radius||50);const r=await fetch(url,{method:'GET',mode:'cors',credentials:'omit',cache:'no-store',headers:{'Accept':'application/json'}});if(!r.ok){self.postMessage({id:m.id,ok:false,status:r.status,error:'HTTP '+r.status});return}const j=await r.json();const src=Array.isArray(j.ac)?j.ac:(Array.isArray(j.aircraft)?j.aircraft:[]);const by={};for(const raw of src){const a=norm(raw,m.center);if(!a)continue;const seen=Number(a.seen_seconds);if(Number.isFinite(seen)&&seen>60)continue;if(!by[String(a.id).toLowerCase()])by[String(a.id).toLowerCase()]=a}const all=Object.values(by);const f=m.filters||{};const shown=all.filter(a=>f[a.category]!==false);self.postMessage({id:m.id,ok:true,all,shownCount:shown.length,total:all.length})}catch(e){self.postMessage({id:m.id,ok:false,error:String(e&&e.message||e)})}}`}
  function getWorker(){try{if(window._v275AdsbWorker)return window._v275AdsbWorker;const blob=new Blob([buildWorkerCode()],{type:'text/javascript'});const w=new Worker(URL.createObjectURL(blob));window._v275AdsbSeq=0;window._v275AdsbJobs={};w.onmessage=ev=>{const d=ev.data||{},job=window._v275AdsbJobs&&window._v275AdsbJobs[d.id];if(job){delete window._v275AdsbJobs[d.id];d.ok?job.resolve(d):job.reject(new Error(d.error||('HTTP '+(d.status||''))))}};window._v275AdsbWorker=w;return w}catch(e){return null}}
  function workerFetch(center,radius,filters){const w=getWorker();if(!w)return Promise.reject(new Error('worker unavailable'));const id=++window._v275AdsbSeq;return new Promise((resolve,reject)=>{window._v275AdsbJobs[id]={resolve,reject};w.postMessage({cmd:'fetch',id,center,radius,filters});setTimeout(()=>{if(window._v275AdsbJobs&&window._v275AdsbJobs[id]){delete window._v275AdsbJobs[id];reject(new Error('timeout'))}},15000)})}
  function patchAdsbWorker(){try{if(window._v275AdsbPatched)return;window._v275AdsbPatched=true;window.refreshAdsb=async function(){try{removeAdsbDiagnostics();ensureAdsbCenterLayout();ensureLayer();const off=localStorage.getItem('takmap.adsb.localDisabled')==='1';if(off){try{if(window.aircraftLayer)aircraftLayer.clearLayers();$('adsbToggleBtn')&&($('adsbToggleBtn').textContent='Enable ADS-B');$('adsbStatus')&&($('adsbStatus').textContent='disabled')}catch(_){}setAdsbStatus('ADS-B disabled.');return []}$('adsbToggleBtn')&&($('adsbToggleBtn').textContent='Disable ADS-B');const center=getAdsbCenter();if(!center){setAdsbStatus('Set ADS-B center.',true);return []}const radius=clamp($('adsbRadiusMiles')?.value||50,1,250,50);window.v270AdsbFilters=filters();let res;try{res=await workerFetch(center,radius,window.v270AdsbFilters)}catch(e){setAdsbStatus('ADS-B client fetch failed.',true);$('adsbStatus')&&($('adsbStatus').textContent='fetch failed');return []}window.lastAircraft=res.all||[];try{lastAircraft=window.lastAircraft}catch(_){};ensureLayer();if(typeof window.drawAircraft==='function'){const run=()=>{try{window.drawAircraft(window.lastAircraft)}catch(_){}};if(window.requestAnimationFrame)requestAnimationFrame(run);else setTimeout(run,0)}try{$('adsbStatus')&&($('adsbStatus').textContent=(res.shownCount||0)+' active');if(window.lastBanner){lastBanner.adsb_aircraft=res.shownCount||0;if(typeof renderTopBanner==='function')renderTopBanner(lastBanner)}}catch(_){}setAdsbStatus((res.shownCount||0)+' aircraft');return res.all||[]}catch(e){setAdsbStatus('ADS-B error.',true);return []}}}catch(e){} }
  function stabilizeLeftMenu(){try{removeAdsbDiagnostics();ensureAdsbCenterLayout();const panel=document.querySelector('[data-collapse-key="adsbSettings"] .panel-body');if(panel){panel.style.contain='layout paint';panel.style.overflow='hidden visible'}if(followMapCenter()&&window.map){const c=map.getCenter();writeCenter(c.lat,c.lng)}}catch(_){} }
  function bindMapFollow(){try{if(window._v275FollowBound||!window.map)return;window._v275FollowBound=true;map.on('moveend',()=>{try{if(followMapCenter()){const c=map.getCenter();writeCenter(c.lat,c.lng);refreshAdsb()}}catch(_){}})}catch(_){} }
  function boot(){try{addCss();resetTransientUiOnce();patchDrawingSingleDialog();sanitizeDrawOptionsPanel();monitorSaveShape();popupObserver();polishFeaturePopups();disableAssetEditors();ensureAdsbCenterLayout();removeAdsbDiagnostics();patchAdsbWorker();bindMapFollow();stabilizeLeftMenu();document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(e){}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,250));else setTimeout(boot,100);
  setTimeout(boot,900);setTimeout(boot,2200);/* v276: removed broad recurring boot loop */
})();
