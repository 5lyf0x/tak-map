_v277_js = r'''
/* v277: default ADS-B off, no legacy UI churn, stable controls/toolbars/popups */
(function(){
  const V='v301';
  const $=id=>document.getElementById(id);
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  let pollTimer=null, pollBusy=false, pollQueued=false, debounceTimer=null, interactionUntil=0, workerSeq=0;
  let markerBatchTimer=null, lastRenderedHash='';
  function addCss(){try{if($('v277Style'))return;const css=`
    .tak-stepper,.adsb-v276-stepper{display:grid!important;grid-template-columns:minmax(0,1fr) 24px!important;align-items:stretch!important;width:100%!important;min-width:0!important;background:#091018!important;border:1px solid #334553!important;border-radius:10px!important;overflow:hidden!important;box-sizing:border-box!important;}
    .tak-stepper input[type=number],.adsb-v276-stepper input[type=number]{border:0!important;background:transparent!important;border-radius:0!important;min-height:30px!important;padding:6px 8px!important;color:var(--text)!important;width:100%!important;min-width:0!important;appearance:textfield!important;-moz-appearance:textfield!important;}
    .tak-stepper input[type=number]::-webkit-outer-spin-button,.tak-stepper input[type=number]::-webkit-inner-spin-button,.adsb-v276-stepper input[type=number]::-webkit-outer-spin-button,.adsb-v276-stepper input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none!important;margin:0!important;}
    .tak-stepper-controls,.adsb-v276-stepper-controls{display:grid!important;grid-template-rows:1fr 1fr!important;border-left:1px solid rgba(255,255,255,.11)!important;background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(0,0,0,.06))!important;}
    .tak-stepper-controls button,.adsb-v276-stepper-controls button{width:24px!important;min-width:24px!important;height:15px!important;min-height:15px!important;margin:0!important;padding:0!important;border:0!important;border-radius:0!important;background:transparent!important;color:#a9bac4!important;font-size:9px!important;line-height:14px!important;font-weight:850!important;cursor:pointer!important;box-shadow:none!important;text-shadow:none!important;}
    .tak-stepper-controls button:hover,.adsb-v276-stepper-controls button:hover{background:rgba(255,255,255,.09)!important;color:#eaf2f5!important;}
    .leaflet-marker-icon[class*="adsb"],.leaflet-marker-icon .aircraft-wrap,.aircraft-wrap,.aircraft-wrap.v270-adsb,.aircraft-glyph,.adsb-png-icon,.adsb-aircraft-icon,.adsb-marker,.adsb-marker img,.aircraft-wrap img,.aircraft-glyph img{filter:none!important;-webkit-filter:none!important;box-shadow:none!important;text-shadow:none!important;outline:none!important;background:transparent!important;}
    .leaflet-marker-icon[class*="adsb"]::before,.leaflet-marker-icon[class*="adsb"]::after,.aircraft-wrap::before,.aircraft-wrap::after,.aircraft-glyph::before,.aircraft-glyph::after,.adsb-png-icon::before,.adsb-png-icon::after,.adsb-marker::before,.adsb-marker::after{display:none!important;content:none!important;filter:none!important;box-shadow:none!important;background:transparent!important;}
    .aircraft-wrap.selected,.aircraft-wrap.stale,.aircraft-glyph.selected,.adsb-png-icon.selected{filter:none!important;box-shadow:none!important;text-shadow:none!important;outline:none!important;}
    .aircraft-label{box-shadow:none!important;text-shadow:none!important;background:rgba(5,8,12,.86)!important;border:1px solid rgba(255,255,255,.10)!important;}
    #adsbV277CenterBlock{display:grid!important;gap:7px!important;margin:6px 0 8px!important;contain:layout paint!important;}
    #adsbV277CenterBlock label{display:grid!important;gap:4px!important;min-width:0!important;color:#9fb1b9!important;font-size:.68rem!important;font-weight:850!important;letter-spacing:.03em!important;}
    #adsbV277CenterBlock select,#adsbV277CenterBlock input[type=text]{height:31px!important;min-height:31px!important;width:100%!important;background:#091018!important;border:1px solid #334553!important;border-radius:10px!important;color:var(--text)!important;padding:6px 8px!important;box-sizing:border-box!important;}
    #adsbV277CenterBlock .adsb-v277-actions{display:flex!important;justify-content:flex-start!important;gap:8px!important;align-items:center!important;}
    #adsbFollowMapCenter,.follow,#adsbRefreshV275,#adsbTestBtn,#adsbV270Menu button[onclick*="refreshAdsb"],#adsbV270Menu button[id*="Refresh"],#adsbV270Menu .adsb-refresh-btn,#adsbV268Actions,.adsb-v268-actions,.adsb-v266-actions,#adsbDisableLocalBtn,#adsbEnableLocalBtn,#adsbDisableOtsJobBtn,#adsbEnableOtsJobBtn,#adsbApplyOtsBtn,#adsbUpdateIntervalBtn,#adsbSaveIntervalBtn{display:none!important;}
    #adsbSettingsStatus{min-height:20px!important;max-height:22px!important;overflow:hidden!important;text-overflow:ellipsis!important;white-space:nowrap!important;}
    #drawToolMenu,.draw-icon-menu{width:max-content!important;min-width:0!important;max-width:152px!important;grid-template-columns:repeat(3,34px)!important;gap:5px!important;padding:6px!important;box-sizing:border-box!important;overflow:hidden!important;}
    #drawToolMenu button,.draw-icon-menu button{width:34px!important;height:34px!important;min-width:34px!important;min-height:34px!important;margin:0!important;padding:6px!important;box-sizing:border-box!important;}
    .tool-submenu.compact-icon-toolbar,.compact-icon-toolbar{width:max-content!important;min-width:0!important;max-width:220px!important;box-sizing:border-box!important;overflow:hidden!important;}
    #drawOptionsPanel{display:none!important;visibility:hidden!important;pointer-events:none!important;}
    #drawOptionsPanel.active,#drawOptionsPanel.open{display:none!important;visibility:hidden!important;pointer-events:none!important;}
    #toolViewshed{display:grid!important;visibility:visible!important;opacity:1!important;}
    .viewshed-module,.viewshed-card,.viewshed-panel{background:rgba(9,18,24,.92)!important;border-color:rgba(53,69,86,.95)!important;color:var(--text)!important;box-shadow:0 18px 44px rgba(0,0,0,.50)!important;}
    .viewshed-head,.viewshed-titlebar{background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,0))!important;border-color:rgba(255,255,255,.09)!important;color:#e9f0f5!important;}
