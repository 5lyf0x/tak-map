source+\')... \'+pct+\'%\'}await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;return {ok:valid>0,cached:false,source:source+(spread<0.5?\' · flat/low variation\':\'\'),elev:out,valid,spread}}}catch(e){console.warn(\'Esri viewshed terrain sample unavailable\',e)}return {ok:false,source:\'Esri World Elevation 3D unavailable\',elev:null}}\n  async function sampleElevationsUsgs(points,opts){opts=opts||{};const endpoint=\'https://elevation.nationalmap.gov/arcgis/rest/services/3DEPElevation/ImageServer/getSamples\';const pointCount=viewshedPointCount(points);const out=new Array(pointCount);const chunk=500;let valid=0,min=Infinity,max=-Infinity;try{for(let i=0;i<pointCount;i+=chunk){const slice=viewshedPointSlice(points,i,i+chunk);const geometry=JSON.stringify({points:slice.map(p=>[Number(p.lng),Number(p.lat)]),spatialReference:{wkid:4326}});const body=new URLSearchParams();body.set(\'f\',\'json\');body.set(\'geometryType\',\'esriGeometryMultipoint\');body.set(\'geometry\',geometry);body.set(\'returnFirstValueOnly\',\'true\');body.set(\'interpolation\',\'RSP_BilinearInterpolation\');body.set(\'outFields\',\'*\');const res=await viewshedFetchWithTimeout(endpoint,{method:\'POST\',headers:{\'Content-Type\':\'application/x-www-form-urlencoded;charset=UTF-8\'},body:body.toString()},45000);if(!res.ok)throw new Error(\'USGS 3DEP HTTP \'+res.status);const json=await res.json();if(json.error)throw new Error(json.error.message||\'USGS 3DEP error\');const samples=json.samples||json.sampleLocations||[];for(let j=0;j<slice.length;j++){const h=parseUsgsSampleValue(samples[j]);const val=Number.isFinite(h)?h:0;out[i+j]=val;if(Number.isFinite(h)){valid++;if(val<min)min=val;if(val>max)max=val}}if(field(\'viewshedStatus\')){const pct=Math.min(99,Math.round(((i+slice.length)/pointCount)*100));field(\'viewshedStatus\').textContent=\'Sampling elevation (USGS 3DEP DEM)... \'+pct+\'%\'}await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;return {ok:valid>0,cached:false,source:\'USGS 3DEP DEM\'+(spread<0.5?\' · flat/low variation\':\'\'),elev:out,valid,spread}}catch(e){console.warn(\'USGS 3DEP viewshed terrain sample unavailable\',e);return {ok:false,source:\'USGS 3DEP DEM unavailable: \'+String(e&&e.message||e),elev:null}}}\n  \n  const LOCAL_ELEV_DB=\'takmapLocalElevationV1\';\n  function localElevState(){window.takLocalElevation=window.takLocalElevation||{loaded:false,loading:null,tiles:new Map(),meta:[]};return window.takLocalElevation}\n  function localElevKey(lat0,lon0,size){return \'hgt|\'+lat0+\'|\'+lon0+\'|\'+size}\n  function localElevTileId(lat0,lon0){return \'hgt|\'+Math.floor(lat0)+\'|\'+Math.floor(lon0)}\n  function openLocalElevDb(){return new Promise((resolve,reject)=>{try{const req=indexedDB.open(LOCAL_ELEV_DB,1);req.onupgradeneeded=e=>{const db=e.target.result;if(!db.objectStoreNames.contains(\'tiles\'))db.createObjectStore(\'tiles\',{keyPath:\'id\'});if(!db.objectStoreNames.contains(\'meta\'))db.createObjectStore(\'meta\',{keyPath:\'id\'})};req.onsuccess=()=>resolve(req.result);req.onerror=()=>reject(req.error||new Error(\'IndexedDB open failed\'))}catch(e){reject(e)}})}\n  async function localElevDbPut(tile){const db=await openLocalElevDb();return new Promise((resolve,reject)=>{try{const tx=db.transaction([\'tiles\'],\'readwrite\');tx.objectStore(\'tiles\').put(tile);tx.oncomplete=()=>{try{db.close()}catch(_){};resolve(true)};tx.onerror=()=>reject(tx.error||new Error(\'IndexedDB put failed\'))}catch(e){reject(e)}})}\n  async function localElevDbClear(){const db=await openLocalElevDb();return new Promise((resolve,reject)=>{try{const tx=db.transaction([\'tiles\'],\'readwrite\');tx.objectStore(\'tiles\').clear();tx.oncomplete=()=>{try{db.close()}catch(_){};resolve(true)};tx.onerror=()=>reject(tx.error||new Error(\'IndexedDB clear failed\'))}catch(e){reject(e)}})}\n  async function loadLocalElevationTiles(){const st=localElevState();if(st.loaded)return st;if(st.loading)return st.loading;st.loading=(async()=>{try{const db=await openLocalElevDb();await new Promise((resolve,reject)=>{const tx=db.transaction([\'tiles\'],\'readonly\');const req=tx.objectStore(\'tiles\').openCursor();req.onsuccess=e=>{const cur=e.target.result;if(cur){const tile=cur.value;if(tile&&tile.id){st.tiles.set(tile.id,tile);st.tiles.set(localElevTileId(tile.lat0,tile.lon0),tile);};cur.continue()}else resolve()};req.onerror=()=>reject(req.error||new Error(\'IndexedDB cursor failed\'));tx.oncomplete=()=>{try{db.close()}catch(_){}}});st.meta=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).map(t=>({id:t.id,name:t.name,type:t.type,lat0:t.lat0,lon0:t.lon0,size:t.size}));st.loaded=true;updateLocalElevationUi();return st}catch(e){console.warn(\'local elevation load failed\',e);st.loaded=true;updateLocalElevationUi(\'Local elevation load failed: \'+String(e&&e.message||e));return st}})();return st.loading}\n  function parseHgtName(name){const m=String(name||\'\').match(/([NS])(\\d{2})([EW])(\\d{3})/i);if(!m)return null;let lat=Number(m[2]),lon=Number(m[4]);if(m[1].toUpperCase()===\'S\')lat=-lat;if(m[3].toUpperCase()===\'W\')lon=-lon;return {lat0:lat,lon0:lon}}\n  async function importHgtFile(file){const loc=parseHgtName(file.name);if(!loc)throw new Error(file.name+\': HGT filename must include tile origin like N34W118.hgt\');const buf=await file.arrayBuffer();const samples=buf.byteLength/2;const size=Math.round(Math.sqrt(samples));if(size*size!==samples||![1201,3601].includes(size))throw new Error(file.name+\': unsupported HGT dimensions \'+size+\'×\'+size);const dv=new DataView(buf);const vals=new Int16Array(samples);for(let i=0;i<samples;i++)vals[i]=dv.getInt16(i*2,false);const tile={id:localElevKey(loc.lat0,loc.lon0,size),type:\'SRTM HGT\',name:file.name,lat0:loc.lat0,lon0:loc.lon0,size,buffer:vals.buffer,bytes:buf.byteLength,imported:Date.now()};await localElevDbPut(tile);const st=localElevState();st.tiles.set(tile.id,tile);st.tiles.set(localElevTileId(tile.lat0,tile.lon0),tile);st.meta=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).map(t=>({id:t.id,name:t.name,type:t.type,lat0:t.lat0,lon0:t.lon0,size:t.size}));return tile}\n  function tileForLocalPoint(lat,lng){const st=localElevState();const lat0=Math.floor(Number(lat)),lon0=Math.floor(Number(lng));return st.tiles.get(localElevTileId(lat0,lon0))||null}\n  function sampleHgtTile(tile,lat,lng){try{if(!tile)return null;const size=Number(tile.size);if(!(size>1))return null;const lat0=Number(tile.lat0),lon0=Number(tile.lon0);if(lat<lat0||lat>lat0+1||lng<lon0||lng>lon0+1)return null;const vals=new Int16Array(tile.buffer);const col=(lng-lon0)*(size-1);const row=(lat0+1-lat)*(size-1);let c0=Math.floor(col),r0=Math.floor(row);let c1=Math.min(size-1,c0+1),r1=Math.min(size-1,r0+1);c0=Math.max(0,Math.min(size-1,c0));r0=Math.max(0,Math.min(size-1,r0));const tx=col-c0,ty=row-r0;function v(r,c){const n=vals[r*size+c];return n<=-32768?NaN:Number(n)}const v00=v(r0,c0),v10=v(r0,c1),v01=v(r1,c0),v11=v(r1,c1);const arr=[v00,v10,v01,v11].filter(Number.isFinite);if(!arr.length)return null;if(arr.length<4)return arr.reduce((a,b)=>a+b,0)/arr.length;const a=v00*(1-tx)+v10*tx,b=v01*(1-tx)+v11*tx;return a*(1-ty)+b*ty}catch(_){return null}}\n  async function sampleElevationsLocal(points,opts){opts=opts||{};await loadLocalElevationTiles();const st=localElevState();const pointCount=viewshedPointCount(points);const out=new Float32Array(pointCount);let valid=0,min=Infinity,max=-Infinity,missing=0;const used=new Set();if(!st.tiles||st.tiles.size===0)return {ok:false,source:\'Local elevation data unavailable: no local SRTM HGT tiles imported\',elev:null};for(let i=0;i<pointCount;i++){const p=viewshedPointAt(points,i);const tile=p?tileForLocalPoint(p.lat,p.lng):null;let h=tile?sampleHgtTile(tile,Number(p.lat),Number(p.lng)):null;if(Number.isFinite(h)){out[i]=h;valid++;used.add(tile.id);if(h<min)min=h;if(h>max)max=h}else{out[i]=0;missing++}if(i%25000===0&&field(\'viewshedStatus\')){const pct=Math.min(99,Math.round((i/Math.max(1,pointCount))*100));field(\'viewshedStatus\').textContent=\'Sampling elevation (Local DTED/SRTM)... \'+pct+\'%\'}if(i%50000===0)await new Promise(r=>setTimeout(r,0))}const spread=(valid>1&&Number.isFinite(min)&&Number.isFinite(max))?(max-min):0;const cov=Math.round((valid/Math.max(1,pointCount))*100);return {ok:valid>0,cached:false,source:\'Local SRTM HGT · \'+used.size+\' tile\'+(used.size===1?\'\':\'s\')+\' · \'+cov+\'% coverage\'+(spread<0.5?\' · flat/low variation\':\'\'),elev:out,valid,spread,coverage:cov,missing}}\n  function ensureLocalElevationDialog(){try{if(field(\'localElevationDialog\'))return;document.body.insertAdjacentHTML(\'beforeend\',`<div id="localElevationDialog" class="local-elev-dialog"><div class="local-elev-card"><div class="local-elev-head"><h2>Add Local Elevation Data</h2><button id="localElevClose" class="local-elev-close">×</button></div><div class="local-elev-body"><p class="local-elev-note"><b>Files stay on this computer/browser and are not uploaded to the TAK server.</b><br>Use local elevation data as a Viewshed source. Terrain Mode local terrain rendering is pending.</p><div class="local-elev-format-list"><span>SRTM HGT (.hgt) usable now</span><span>DTED (.dt0/.dt1/.dt2) parser pending</span><span>GeoTIFF DEM (.tif/.tiff) parser pending</span><span>ZIP package parser pending</span></div><input id="localElevFileInput" type="file" multiple accept=".hgt,.dt0,.dt1,.dt2,.tif,.tiff" style="display:none"><div class="local-elev-actions"><button id="localElevChoose" class="layer-button local-elev-primary">Choose Files</button><button id="localElevImport" class="layer-button local-elev-import" disabled>Import Selected Files</button><button id="localElevClear" class="layer-button">Clear Local Elevation</button></div><div id="localElevStatus" class="local-elev-status">No local elevation data loaded yet.</div><div class="local-elev-list-title">Selected files</div><div id="localElevSelected" class="local-elev-selected">No selected files.</div><div class="local-elev-list-title">Local files indexed</div><div id="localElevList" class="local-elev-list"></div></div></div></div>`);field(\'localElevClose\').onclick=()=>field(\'localElevationDialog\')?.classList.remove(\'active\');field(\'localElevChoose\').onclick=()=>field(\'localElevFileInput\')?.click();field(\'localElevImport\').onclick=async()=>{const st=localElevState();await importLocalElevationFiles(st.pendingFiles||[]);st.pendingFiles=[];renderLocalElevationSelected();updateLocalElevImportButton();};field(\'localElevClear\').onclick=async()=>{try{await localElevDbClear();const st=localElevState();st.tiles=new Map();st.meta=[];st.loaded=true;st.pendingFiles=[];renderLocalElevationSelected();updateLocalElevImportButton();updateLocalElevationUi(\'Local elevation data cleared.\')}catch(e){updateLocalElevationUi(\'Clear failed: \'+String(e&&e.message||e))}};field(\'localElevFileInput\').onchange=(ev)=>{const st=localElevState();st.pendingFiles=[...(ev.target.files||[])];renderLocalElevationSelected();updateLocalElevImportButton();const supported=st.pendingFiles.filter(f=>/\\.hgt$/i.test(String(f.name||\'\'))).length;const pending=st.pendingFiles.length-supported;const stat=field(\'localElevStatus\');if(stat)stat.textContent=st.pendingFiles.length?(\'Selected \'+st.pendingFiles.length+\' file\'+(st.pendingFiles.length===1?\'\':\'s\')+\'. \'+supported+\' importable SRTM HGT, \'+pending+\' parser pending/unsupported. Click Import Selected Files to continue.\'):\'No selected files.\';ev.target.value=\'\'};}catch(e){console.warn(\'local elevation dialog failed\',e)}}\n  function localElevFileSupportLabel(name){name=String(name||\'\');if(/\\.hgt$/i.test(name))return \'SRTM HGT - ready to import\';if(/\\.(dt0|dt1|dt2)$/i.test(name))return \'DTED parser pending\';if(/\\.(tif|tiff)$/i.test(name))return \'GeoTIFF parser pending\';if(/\\.zip$/i.test(name))return \'ZIP parser pending\';return \'unsupported\'}\n  function renderLocalElevationSelected(){try{const box=field(\'localElevSelected\');if(!box)return;const files=(localElevState().pendingFiles||[]);if(!files.length){box.textContent=\'No selected files.\';return;}box.innerHTML=files.map(f=>{const name=String(f.name||\'file\');const label=localElevFileSupportLabel(name);const dim=/\\.hgt$/i.test(name)?\'\':\' style="color:#98a6ad"\';return `<div${dim}>- ${esc(name)} <span class="muted">(${esc(label)})</span></div>`}).join(\'\')}catch(e){console.warn(\'render local elevation selected failed\',e)}}\n  function updateLocalElevImportButton(){try{const b=field(\'localElevImport\');if(!b)return;const files=(localElevState().pendingFiles||[]);const supported=files.filter(f=>/\\.hgt$/i.test(String(f.name||\'\'))).length;b.disabled=!supported;b.textContent=\'Import Selected Files\'}catch(e){}}\n  async function importLocalElevationFiles(files){ensureLocalElevationDialog();files=[...(files||[])];let ok=0,unsupported=[];const stat=field(\'localElevStatus\');for(const f of files){const name=String(f.name||\'\');try{if(/\\.hgt$/i.test(name)){if(stat)stat.textContent=\'Importing \'+name+\'...\';await importHgtFile(f);ok++}else if(/\\.(dt0|dt1|dt2)$/i.test(name)){unsupported.push(name+\' (DTED parser pending)\')}else if(/\\.(tif|tiff)$/i.test(name)){unsupported.push(name+\' (GeoTIFF parser pending)\')}else if(/\\.zip$/i.test(name)){unsupported.push(name+\' (ZIP parser pending)\')}else{unsupported.push(name+\' (unsupported)\')}}catch(e){unsupported.push(name+\' (\'+String(e&&e.message||e)+\')\')}}const msg=\'Imported \'+ok+\' SRTM HGT tile\'+(ok===1?\'\':\'s\')+\'.\'+(unsupported.length?\'\\nNot imported:\\n- \'+unsupported.join(\'\\n- \'):\'\');updateLocalElevationUi(msg)}\n  function updateLocalElevationUi(msg){try{const st=localElevState();const list=field(\'localElevList\');const count=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i).length;if(field(\'localElevToolStatus\'))field(\'localElevToolStatus\').textContent=\'Local: \'+count;if(field(\'localElevStatus\'))field(\'localElevStatus\').textContent=msg||((count?(\'Loaded \'+count+\' local elevation tile\'+(count===1?\'\':\'s\')+\'.\'):\'No local elevation data loaded yet.\'));if(list){const tiles=[...st.tiles.values()].filter((v,i,a)=>a.findIndex(x=>x.id===v.id)===i);list.innerHTML=tiles.length?tiles.map(t=>\'<div>\'+esc(t.name||t.id)+\' · \'+esc(t.type||\'Elevation\')+\' · \'+t.size+\'×\'+t.size+\' · \'+(t.lat0>=0?\'N\':\'S\')+Math.abs(t.lat0)+\' \'+(t.lon0>=0?\'E\':\'W\')+Math.abs(t.lon0)+\'</div>\').join(\'\'):\'<div>No local files indexed.</div>\'}}catch(_){} }\n  function openLocalElevationDialog(){ensureLocalElevationDialog();field(\'localElevationDialog\')?.classList.add(\'active\');loadLocalElevationTiles();renderLocalElevationSelected();updateLocalElevImportButton();updateLocalElevationUi()}\n  function ensureLocalElevationToolsButton(){try{ensureLocalElevationDialog();if(field(\'localElevAddBtn\')){field(\'localElevAddBtn\').onclick=openLocalElevationDialog;updateLocalElevationUi();return;}const panels=[...document.querySelectorAll(\'.panel\')];const p=panels.find(el=>(el.querySelector(\'h2\')?.textContent||\'\').trim()===\'Tools\');if(!p)return;const row=document.createElement(\'div\');row.className=\'row local-elev-tools-row\';row.innerHTML=\'<button id="localElevAddBtn" class="layer-button" type="button">Add Elevation Data</button><span id="localElevToolStatus" class="chip local-elev-tool-chip">Local: 0</span>\';const exportButton=[...p.querySelectorAll(\'button\')].find(b=>(b.textContent||\'\').trim()===\'Export All Data\');if(exportButton){const exportButtonRow=exportButton.closest(\'.row\')||exportButton;exportButtonRow.insertAdjacentElement(\'beforebegin\',row);}else{const exportRow=field(\'exportDataSync\')?.closest(\'.export-check-list,.export-options\');if(exportRow)exportRow.insertAdjacentElement(\'beforebegin\',row);else p.appendChild(row);}field(\'localElevAddBtn\').onclick=openLocalElevationDialog;updateLocalElevationUi()}catch(e){console.warn(\'local elevation tools button failed\',e)}}\n  function localElevationBoot(){try{ensureLocalElevationToolsButton();loadLocalElevationTiles();setTimeout(ensureLocalElevationToolsButton,1500);setTimeout(ensureLocalElevationToolsButton,3500)}catch(e){console.warn(\'local elevation boot failed\',e)}}\n  try{window.openLocalElevationDialog=openLocalElevationDialog;window.ensureLocalElevationToolsButton=ensureLocalElevationToolsButton;window.localElevationBoot=localElevationBoot}catch(_){}\nasync function sampleElevations(points,opts){opts=opts||{};const st=window.v249Viewshed;const useCache=!!opts.cache;const key=opts.key||\'\';const requested=normalizeViewshedElevationSource(opts.source||\'Auto\');try{if(useCache&&key){st.elevationCache=st.elevationCache||new Map();if(st.elevationCache.has(key)){const cached=st.elevationCache.get(key);viewshedElevationStatus(\'Elevation: using cached \'+(cached.source||\'terrain samples\')+\'.\');return Object.assign({ok:true,cached:true},cached)}}let result=null;if(requested===\'Local\'){result=await sampleElevationsLocal(points,opts)}else if(requested===\'USGS\'){result=await sampleElevationsUsgs(points,opts)}else if(requested===\'Esri\'){result=await sampleElevationsEsri(points,opts)}else{result=await sampleElevationsEsri(points,opts);if(!(result&&result.ok)){viewshedElevationStatus(\'Elevation: Esri unavailable; trying USGS 3DEP DEM...\');result=await sampleElevationsUsgs(points,opts);}}if(result&&result.ok&&useCache&&key){st.elevationCache=st.elevationCache||new Map();if(result.elev&&!(result.elev instanceof Float32Array))result.elev=new Float32Array(result.elev);st.elevationCache.set(key,{source:result.source,elev:result.elev,valid:result.valid,spread:result.spread,coverage:result.coverage});while(st.elevationCache.size>12){const first=st.elevationCache.keys().next().value;st.elevationCache.delete(first)}}return result||{ok:false,source:\'unavailable\',elev:null}}catch(e){console.warn(\'viewshed terrain sample unavailable\',e);return {ok:false,source:String(e&&e.message||e)||\'unavailable\',elev:null}}}\n  function viewshedWorkerCode(){return `\nconst R=6371008.8;\nfunction dest(lat,lng,bearingDeg,distM){const br=bearingDeg*Math.PI/180,phi1=lat*Math.PI/180,lam1=lng*Math.PI/180,d=distM/R;const sinPhi2=Math.sin(phi1)*Math.cos(d)+Math.cos(phi1)*Math.sin(d)*Math.cos(br);const phi2=Math.asin(sinPhi2);const y=Math.sin(br)*Math.sin(d)*Math.cos(phi1);const x=Math.cos(d)-Math.sin(phi1)*sinPhi2;let lam2=lam1+Math.atan2(y,x);lam2=(lam2+3*Math.PI)%(2*Math.PI)-Math.PI;return {lat:phi2*180/Math.PI,lng:lam2*180/Math.PI}}\nfunction gridLatLng(center,dxM,dyM){const lat=center.lat+(dyM/R)*180/Math.PI;const lng=center.lng+(dxM/(R*Math.cos(center.lat*Math.PI/180)))*180/Math.PI;return {lat,lng}}\nfunction makeRasterPoints(m){const center=m.center,radiusM=m.radiusM,n=m.gridSize;const cellM=(2*radiusM)/n;const half=n/2;const maxPts=Math.ceil(Math.PI*n*n/4)+8;let latArr=new Float64Array(maxPts);let lngArr=new Float64Array(maxPts);let pixArr=new Int32Array(Math.max(2,(maxPts-1)*2));let count=1,pi=0;latArr[0]=Number(center.lat)||0;lngArr[0]=Number(center.lng)||0;let minLat=90,maxLat=-90,minLng=180,maxLng=-180;const nw=gridLatLng(center,-radiusM,radiusM),se=gridLatLng(center,radiusM,-radiusM);minLat=Math.min(nw.lat,se.lat);maxLat=Math.max(nw.lat,se.lat);minLng=Math.min(nw.lng,se.lng);maxLng=Math.max(nw.lng,se.lng);for(let y=0;y<n;y++){const dy=(half-y-0.5)*cellM;for(let x=0;x<n;x++){const dx=(x+0.5-half)*cellM;if(dx*dx+dy*dy>radiusM*radiusM)continue;if(count>=latArr.length){const nl=new Float64Array(latArr.length+Math.ceil(n*n*.05)+1024);nl.set(latArr);latArr=nl;const ng=new Float64Array(lngArr.length+Math.ceil(n*n*.05)+1024);ng.set(lngArr);lngArr=ng;const np=new Int32Array(pixArr.length+Math.ceil(n*n*.10)+2048);np.set(pixArr);pixArr=np}const p=gridLatLng(center,dx,dy);latArr[count]=p.lat;lngArr[count]=p.lng;count++;pixArr[pi++]=x;pixArr[pi++]=y}}return {latArray:latArr.slice(0,count),lngArray:lngArr.slice(0,count),length:count,pixels:pixArr.slice(0,pi),bounds:[[minLat,minLng],[maxLat,maxLng]],width:n,height:n,cellM}}\nfunction prepRasterGrid(m){const n=m.width,h=m.height;const pix=m.pixels instanceof Int32Array?m.pixels:new Int32Array(m.pixels||[]);let elev;if(m.elevBuffer)elev=new Float32Array(m.elevBuffer);else if(m.elev instanceof Float32Array)elev=m.elev;else if(Array.isArray(m.elev))elev=new Float32Array(m.elev);else elev=new Float32Array(0);const gridElev=new Float32Array(n*h);const validU8=new Uint8Array(n*h);const validU32=new Uint32Array(n*h);const terrainOk=!!m.terrainOk;const centerElev=terrainOk?(Number(elev[0])||0):0;for(let i=0,ei=1;i<pix.length;i+=2,ei++){const x=pix[i],y=pix[i+1],idx=y*n+x;validU8[idx]=1;validU32[idx]=1;gridElev[idx]=terrainOk?(Number(elev[ei])||0):0}return {pix,elev,gridElev,validU8,validU32,centerElev,terrainOk}}\nfunction solveRasterCpu(m){const n=m.width,h=m.height,cellM=m.cellM||((2*m.radiusM)/n),radiusM=m.radiusM,heightM=m.heightM||0;const prep=prepRasterGrid(m);const out=new Uint8ClampedArray(n*h);const centerElev=prep.centerElev;const bins=m.angleBins||Math.max(720,Math.min(8192,n*3));const maxAng=new Float32Array(bins);for(let i=0;i<bins;i++)maxAng[i]=-3.402823466e38;const c=(n-1)/2;const maxRing=Math.ceil(n/2);let processed=0,total=prep.pix.length/2;function processCell(x,y){if(x<0||y<0||x>=n||y>=n)return;const idx=y*n+x;if(!prep.validU8[idx])return;const dx=x+0.5-n/2,dy=n/2-y-0.5;const distCells=Math.sqrt(dx*dx+dy*dy);const distM=distCells*cellM;if(distM<0.5||distM>radiusM){out[idx]=0;return}let isVis=true;if(prep.terrainOk){let br=Math.atan2(dx,dy);if(br<0)br+=Math.PI*2;const bin=Math.max(0,Math.min(bins-1,Math.floor(br/(Math.PI*2)*bins)));const ang=(prep.gridElev[idx]-(centerElev+heightM))/Math.max(1,distM);isVis=ang>=maxAng[bin]-0.000001;if(ang>maxAng[bin])maxAng[bin]=ang}out[idx]=isVis?1:2;processed++}\nfor(let r=0;r<