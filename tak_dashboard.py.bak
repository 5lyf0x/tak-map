  function setStable(arr,reason){arr=healthyArray(arr);if(suspiciousDrop(arr)){suppressCount++;window._v296AdsbSuppressedDrop={previous:stable.length,incoming:arr.length,reason:reason||'',at:Date.now(),suppressCount};return stable}stable=arr;if(arr.length){lastGoodAt=Date.now();suppressCount=0}window._v296StableAdsb=stable;window._v296StableAdsbAt=lastGoodAt;return stable}
  function installStableLastAircraft(){try{if(window._v296LastAircraftInstalled)return;window._v296LastAircraftInstalled=true;Object.defineProperty(window,'lastAircraft',{configurable:true,enumerable:true,get(){return stable},set(v){setStable(v,'window.lastAircraft setter');updateAdsbBanner();if(isAdsbDropdownOpen())renderAdsbDropdown();updateTrackFromStable();}})}catch(e){console.warn('v296 stable lastAircraft install failed',e)}}
  function statusBox(){let box=field('statusDropdown');if(!box){box=document.createElement('div');box.id='statusDropdown';box.className='status-dropdown';document.body.appendChild(box)}return box}
  function sortRows(rows){const s=window.v296AdsbSort||window.v294AdsbSort||{key:'aircraft',dir:1};rows.sort((a,b)=>{let av,bv;switch(s.key){case'class':av=classText(a);bv=classText(b);break;case'type':av=typeText(a);bv=typeText(b);break;case'alt':av=Number(a.altitude_ft??a.alt_baro??a.alt_geom);bv=Number(b.altitude_ft??b.alt_baro??b.alt_geom);if(!Number.isFinite(av))av=-Infinity;if(!Number.isFinite(bv))bv=-Infinity;return (av-bv)*s.dir;case'range':av=Number(a.range_miles??a.range);bv=Number(b.range_miles??b.range);if(!Number.isFinite(av))av=Infinity;if(!Number.isFinite(bv))bv=Infinity;return (av-bv)*s.dir;default:av=titleText(a);bv=titleText(b)}return String(av).localeCompare(String(bv))*s.dir});return rows}
  function updateAdsbBanner(){try{const rows=stable;const item=field('bannerAdsbItem');if(item){item.classList.add('status-dropdown-trigger');item.setAttribute('data-status-type','adsb');item.removeAttribute('onclick');item.onclick=null}const b=field('bannerAdsb');if(b)b.textContent=rows.length+' Aircraft';const d=field('bannerAdsbDot');if(d)d.className='status-dot '+(rows.length?'good':'unknown');try{if(window.lastBanner)window.lastBanner.adsb_aircraft=rows.length}catch(_){}return rows.length}catch(_){return 0}}
  function isAdsbDropdownOpen(){const box=field('statusDropdown');return !!(box&&(box.dataset.type==='adsb'||/ADS-B Aircraft/i.test(box.textContent||''))&&(box.classList.contains('active')||box.classList.contains('open')||box.style.display==='block'))}
  function closeAdsbDropdown(){const box=field('statusDropdown');if(!box)return;box.classList.remove('active','open');box.style.display='none';box.style.visibility='hidden';if(box.dataset.type==='adsb')box.dataset.type=''}
  function renderAdsbDropdown(){const box=statusBox();box.dataset.type='adsb';box.classList.add('adsb-table');const s=window.v296AdsbSort||window.v294AdsbSort||{key:'aircraft',dir:1};const arrow=k=>s.key===k?(s.dir>0?' ▲':' ▼'):'';let html='<div class="status-dropdown-title">ADS-B Aircraft</div>';const rows=sortRows(stable.slice());if(rows.length){html+='<div class="status-adsb-head v294 v296"><button data-v296-sort="aircraft">Aircraft'+arrow('aircraft')+'</button><button data-v296-sort="class">Class'+arrow('class')+'</button><button data-v296-sort="type">Type'+arrow('type')+'</button><button data-v296-sort="alt">Alt'+arrow('alt')+'</button><button data-v296-sort="range">mi-&gt;Center'+arrow('range')+'</button></div>';html+=rows.map(a=>'<div class="status-adsb-row v294 v296" data-adsb-id="'+esc(idOf(a))+'"><span class="status-adsb-icao">'+esc(titleText(a))+'</span><span>'+esc(classText(a))+'</span><span>'+esc(typeText(a))+'</span><span class="status-adsb-alt">'+esc(altText(a))+'</span><span class="status-adsb-range">'+esc(rangeText(a))+'</span></div>').join('')}else{html+='<div class="status-dropdown-empty">No aircraft currently listed.</div>'}if(window._v296AdsbSuppressedDrop&&stable.length){const sup=window._v296AdsbSuppressedDrop;html+='<div class="status-dropdown-note v294">Holding stable ADS-B list; ignored transient refresh of '+esc(sup.incoming)+' aircraft.</div>'}box.innerHTML=html;return box}
  function positionAdsbDropdown(ev){const box=statusBox(),item=field('bannerAdsbItem');const r=(ev&&ev.currentTarget&&ev.currentTarget.getBoundingClientRect&&ev.currentTarget.getBoundingClientRect())||(item&&item.getBoundingClientRect&&item.getBoundingClientRect());const w=Math.min(560,(window.innerWidth||900)-16);box.style.minWidth=Math.min(500,w)+'px';box.style.maxWidth=w+'px';box.style.display='block';box.style.visibility='visible';box.classList.add('active','open','adsb-table');if(r){box.style.left=Math.max(8,Math.min((window.innerWidth||900)-w-8,r.left))+'px';box.style.top=(r.bottom+8)+'px'}}
  function showAdsbDropdown(ev){updateAdsbBanner();renderAdsbDropdown();positionAdsbDropdown(ev)}
  function toggleAdsbDropdown(ev){try{ev&&ev.preventDefault&&ev.preventDefault();ev&&ev.stopPropagation&&ev.stopPropagation();ev&&ev.stopImmediatePropagation&&ev.stopImmediatePropagation()}catch(_){}if(isAdsbDropdownOpen())closeAdsbDropdown();else showAdsbDropdown(ev||{currentTarget:field('bannerAdsbItem')});return false}
  function focusAircraft(id){try{id=String(id||'').toLowerCase();const a=stable.find(x=>idOf(x)===id);if(!a||!window.map)return;map.setView([Number(a.lat),Number(a.lon)],Math.max(map.getZoom(),13),{animate:true});setTimeout(()=>{try{if(typeof window.focusAdsbAircraft==='function')window.focusAdsbAircraft(encodeURIComponent(id));else if(typeof window.drawAircraft==='function')window.drawAircraft(stable)}catch(_){}},150)}catch(_){}}
  function patchAdsbDropdownEvents(){try{const item=field('bannerAdsbItem');if(item&&!item.dataset.v296AdsbClick){item.dataset.v296AdsbClick='1';item.onclick=null;item.removeAttribute('onclick');item.addEventListener('click',toggleAdsbDropdown,true);item.addEventListener('pointerdown',ev=>{try{ev.stopPropagation()}catch(_){}},true)}if(!window._v296AdsbDropdownEvents){window._v296AdsbDropdownEvents=true;const oldToggle=window.toggleStatusDropdown;window.toggleStatusDropdown=function(type,ev){if(String(type||'').toLowerCase()==='adsb')return toggleAdsbDropdown(ev);return typeof oldToggle==='function'?oldToggle.apply(this,arguments):false};const oldRender=window.renderStatusDropdown;window.renderStatusDropdown=function(type){if(String(type||'').toLowerCase()==='adsb')return renderAdsbDropdown();return typeof oldRender==='function'?oldRender.apply(this,arguments):undefined};document.addEventListener('click',ev=>{try{const t=ev.target;const item=field('bannerAdsbItem'),box=field('statusDropdown');if(item&&item.contains(t))return;const sort=t&&t.closest&&t.closest('[data-v296-sort],[data-v294-sort]');if(sort&&box&&box.dataset.type==='adsb'){ev.preventDefault();ev.stopPropagation();const k=sort.getAttribute('data-v296-sort')||sort.getAttribute('data-v294-sort');const s=window.v296AdsbSort||{key:'aircraft',dir:1};window.v296AdsbSort=(s.key===k)?{key:k,dir:-s.dir}:{key:k,dir:1};window.v294AdsbSort=window.v296AdsbSort;renderAdsbDropdown();return false}const row=t&&t.closest&&t.closest('.status-adsb-row[data-adsb-id]');if(row&&box&&box.dataset.type==='adsb'){ev.preventDefault();ev.stopPropagation();focusAircraft(row.getAttribute('data-adsb-id'));return false}if(box&&isAdsbDropdownOpen()&&!box.contains(t))closeAdsbDropdown()}catch(_){}},true);document.addEventListener('keydown',ev=>{if(ev.key==='Escape'&&isAdsbDropdownOpen())closeAdsbDropdown()},true)}}catch(e){console.warn('v296 ADS-B dropdown events failed',e)}}
