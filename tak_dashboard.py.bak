# --- end TAK Map v302 stabilization/controller cleanup build ---




# --- v303 stabilization/controllers: consolidate ADS-B, Viewshed, and MIL selector without stacking legacy handlers ---
def _v303_remove_script_block(_html, _script_id):
    import re as _re
    return _re.sub(r'<script\b(?=[^>]*\bid=["\']' + _re.escape(_script_id) + r'["\'])(?:(?!</script>).)*</script>', '', _html, flags=_re.I|_re.S)

def _v303_set_versions(_html):
    import re as _re
    _html = _html.replace('TAK Server Dashboard', 'TAK Map')
    _html = _re.sub(r'TAKDashboard/v\d+', 'TAKDashboard/v303', _html)
    _html = _re.sub(r'TAK-Map/1\.1\.0\s+v\d+', 'TAK-Map/1.1.0 v303', _html)
    _html = _re.sub(r'<span class="iteration-chip">v\d+</span>', '<span class="iteration-chip">v303</span>', _html)
    _html = _re.sub(r'<div class="iteration-marker">v\d+</div>', '<div class="iteration-marker">v303</div>', _html)
    _html = _re.sub(r'const\s+V\s*=\s*["\']v\d+["\']', "const V='v303'", _html)
    _html = _re.sub(r'>v\d+<', '>v303<', _html)
    return _html

def _v303_neutralize_legacy_adsb_track(_html):
    import re as _re
    _html = _re.sub(r'window\.toggleAdsbTrack\s*=\s*function\s*\([^)]*\)\s*\{(?:(?!\n\s*function\s+trackButtonHtml\().)*?\}\s*;?\s*(?=\n\s*function\s+trackButtonHtml\()',
                    "window.v303LegacyToggleAdsbTrackDisabled=function(){return false};\n", _html, count=5, flags=_re.S)
    _html = _re.sub(r'function\s+patchTrackButtons\s*\(\)\s*\{(?:(?!\n\s*function\s+addCss\s*\().)*?\}\s*(?=\n\s*function\s+addCss\s*\()',
                    "function patchTrackButtons(){try{window._v303LegacyPatchTrackButtonsDisabled=true}catch(_){}}\n", _html, count=5, flags=_re.S)
    return _html

try:
    _v303_remove_ids = [
        'v285AdsbClassTypeTrackPatch','v286AdsbAuthoritativePopupStatusPatch','v287AdsbStatusTrackSavePatch',
        'v297AdsbTrackRoutePatch','v298AdsbNoBlinkPatch','v300AdsbTrackSaveDialogPatch',
