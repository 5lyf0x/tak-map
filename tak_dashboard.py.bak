  window.v233StatusSort=window.v233StatusSort||{key:'icao',dir:1};window.v233EudCache=[];window.v233MilIcons=[];window.v233MilSelected=null;
  function safeEsc(v){return (typeof esc==='function')?esc(v):String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
  function uidLike(v){v=String(v||'').trim();return /^ANDROID-/i.test(v)||/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v)}
  function prettyEud(e){let cs=String(e?.callsign||e?.name||'').trim();let uid=String(e?.uid||'').trim();if(!cs||uidLike(cs))return {name:uid?('UID '+shortUid(uid)):'TAK Client',sub:[e?.team?('Team '+e.team):'',e?.client_label||e?.client||'TAK Client',e?.status||''].filter(Boolean).join(' · '),uidFallback:true};return {name:cs,sub:[e?.team?('Team '+e.team):'',e?.client_label||e?.client||'',e?.status||''].filter(Boolean).join(' · '),uidFallback:false}}
  async function fetchEudsForDropdown(){try{const r=await fetch('/api/tak-map/euds?_='+Date.now(),{cache:'no-store'});const j=await r.json();window.v233EudCache=(j.euds||[]);if(lastBanner){lastBanner.euds_connected=window.v233EudCache.length;renderTopBanner(lastBanner)}}catch(e){}}
  window.statusDropdownRows=function(type){if(type==='euds')return (window.v233EudCache||[]).map(prettyEud);if(type==='nontak')return (lastTakMarkers||[]).filter(m=>{const k=String(m.kind||'').toLowerCase();if(['eud','server_gps','server-gps','webform','aircraft','datasync'].includes(k))return false;if(m.mission||m.is_mission_object||m.creator_callsign||m.parent_callsign)return false;return true}).map(m=>({name:statusItemLabel(m),sub:statusItemSub(m)}));if(type==='adsb'){let rows=(lastAircraft||[]).map(a=>({icao:adsbIdent(a),alt:adsbAltText(a),range:adsbRangeText(a),altNum:Number(a?.altitude_ft),rangeNum:Number(a?.range_miles)}));const sort=window.v233StatusSort||{key:'icao',dir:1};rows.sort((a,b)=>{let av,bv;if(sort.key==='alt'){av=Number.isFinite(a.altNum)?a.altNum:-999999;bv=Number.isFinite(b.altNum)?b.altNum:-999999}else if(sort.key==='range'){av=Number.isFinite(a.rangeNum)?a.rangeNum:999999;bv=Number.isFinite(b.rangeNum)?b.rangeNum:999999}else{av=a.icao;bv=b.icao}return (typeof av==='string'?av.localeCompare(String(bv)):av-bv)*sort.dir});return rows}return []};
  window.setAdsbStatusSort=function(key,ev){ev&&ev.stopPropagation&&ev.stopPropagation();const s=window.v233StatusSort||{key:'icao',dir:1};if(s.key===key)s.dir*=-1;else{s.key=key;s.dir=key==='icao'?1:-1}window.v233StatusSort=s;renderStatusDropdown('adsb')};
  window.renderStatusDropdown=function(type){const box=document.getElementById('statusDropdown');if(!box)return;box.dataset.type=type;box.classList.toggle('adsb-table',type==='adsb');if(type==='euds'&&!(window.v233EudCache||[]).length){box.innerHTML='<div class="status-dropdown-title">EUD Callsigns</div><div class="status-dropdown-empty">Loading EUDs...</div>';fetchEudsForDropdown().then(()=>{if(box.classList.contains('active')&&box.dataset.type==='euds')renderStatusDropdown('euds')});return}const rows=statusDropdownRows(type);let html='<div class="status-dropdown-title">'+safeEsc(statusDropdownTitle(type))+'</div>';if(!rows.length)html+='<div class="status-dropdown-empty">No items currently listed.</div>';else if(type==='adsb'){const s=window.v233StatusSort||{key:'icao',dir:1};const ind=k=>s.key===k?'<span class="status-sort-ind">'+(s.dir>0?'▲':'▼')+'</span>':'';html+='<div class="status-adsb-head"><span onclick="setAdsbStatusSort(\'icao\',event)">ICAO'+ind('icao')+'</span><span onclick="setAdsbStatusSort(\'alt\',event)">Altitude'+ind('alt')+'</span><span onclick="setAdsbStatusSort(\'range\',event)">From Center Point'+ind('range')+'</span></div>'+rows.map(r=>'<div class="status-adsb-row"><span class="status-adsb-icao">'+safeEsc(r.icao)+'</span><span class="status-adsb-alt">'+safeEsc(r.alt)+'</span><span class="status-adsb-range">'+safeEsc(r.range)+'</span></div>').join('')}else html+=rows.map(r=>'<div class="status-dropdown-row"><span class="status-dropdown-name '+(r.uidFallback?'uid-fallback':'')+'">'+safeEsc(r.name)+'</span><span class="status-dropdown-sub">'+safeEsc(r.sub||'')+'</span></div>').join('');box.innerHTML=html};
  const oldToggle=window.toggleStatusDropdown;window.toggleStatusDropdown=function(type,ev){if(type==='euds')fetchEudsForDropdown().then(()=>updateOpenStatusDropdown());return oldToggle?oldToggle(type,ev):undefined};
  const oldBanner=window.renderTopBanner;window.renderTopBanner=function(j){try{if((window.v233EudCache||[]).length&&j)j.euds_connected=window.v233EudCache.length}catch(e){}return oldBanner?oldBanner(j):undefined};setInterval(fetchEudsForDropdown,30000);setTimeout(fetchEudsForDropdown,1200);
  window.aircraftIcon=function(ac){const label=safeEsc(ac?.callsign||ac?.id||'');const military=aircraftIsMilitary(ac);const heli=aircraftIsHelicopter(ac);const stale=aircraftIsStale(ac);const deg=Number.isFinite(Number(ac?.track_deg))?Number(ac.track_deg):0;const color=stale?'#87909a':(military?'#2386ff':'#77d95b');const selected=ac?.id===selectedAircraftId?' selected':'';const ring=military?`<circle cx="22" cy="22" r="16.2" fill="rgba(5,8,12,.88)" stroke="currentColor" stroke-width="5.1" stroke-dasharray="11 4"/>`:`<circle cx="22" cy="22" r="16.2" fill="rgba(5,8,12,.86)" stroke="currentColor" stroke-width="4.2"/><circle cx="22" cy="22" r="19" fill="none" stroke="#f6fbff" stroke-width="1.4" opacity=".72"/>`;const heliGlyph=`<path d="M5 14 H39" stroke="#f7fbff" stroke-width="3.7" stroke-linecap="round"/><path d="M22 5 V30" stroke="#f7fbff" stroke-width="2.8" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.8" ry="5.5" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".75"/><path d="M12 34 H32 M22 30 V38" stroke="#f7fbff" stroke-width="2.45" stroke-linecap="round"/>`;const jetGlyph=`<path d="M22 4 L28 23 L39 29 L27 31 L23 42 L21 42 L17 31 L5 29 L16 23 Z" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".85"/><path d="M22 30 L14 40 M22 30 L30 40" stroke="#f7fbff" stroke-width="2.25" stroke-linecap="round"/>`;const civGlyph=`<path d="M22 6 L25 22 L36 27 L25 29 L22 40 L19 29 L8 27 L19 22 Z" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".75"/><path d="M22 30 L16 39 M22 30 L28 39" stroke="#f7fbff" stroke-width="2.1" stroke-linecap="round"/>`;const glyph=heli?heliGlyph:(military?jetGlyph:civGlyph);const cls=(military?'aircraft-military':'aircraft-civil')+(heli?' aircraft-rotor':' aircraft-fixed')+(stale?' aircraft-stale':'');return L.divIcon({className:'',html:`<div class="aircraft-wrap ${cls}" style="color:${color}"><svg class="aircraft-glyph${selected}" width="42" height="52" viewBox="0 0 44 54">${ring}<g transform="rotate(${deg} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="currentColor"/>${glyph}</g><circle cx="22" cy="50" r="3.2" fill="currentColor"/></svg><div class="aircraft-label">${label}</div></div>`,iconSize:[96,60],iconAnchor:[48,25]})};
  window.adsbPopupHtml=function(ac){const crs=adsbCourse(ac);const gs=adsbGroundSpeed(ac);return `<div class="feature-popup adsb-popup"><h3>${safeEsc(ac.callsign||ac.id||'ADS-B aircraft')}</h3><div class="kvp"><b>ICAO/UID</b><span>${safeEsc(ac.id||'—')}</span><b>Class</b><span>${aircraftIsMilitary(ac)?'Military':'Civil'} · ${aircraftIsHelicopter(ac)?'Helicopter':'Fixed-wing'}</span><b>Altitude</b><span>${Number.isFinite(Number(ac.altitude_ft))?Math.round(Number(ac.altitude_ft))+' ft':'—'}</span><b>Groundspeed</b><span>${safeEsc(gs.kt||'—')} kt</span><b>Track/Course</b><span>${crs.deg==null?'No track/course':safeEsc(Math.round(crs.deg)+'° from '+crs.source+(crs.headingOnly?' (heading only)':''))}</span><b>Coordinates</b><span>${safeEsc(formatCoords(ac.lat,ac.lon))}</span><b>Source</b><span>${safeEsc(ac.source||'ADS-B')}</span><b>Updated</b><span>${safeEsc(ac.updated||'—')}</span></div></div>`};
  window.drawAircraft=function(items){if(terrain3DActive)return;aircraftLayer.clearLayers();clearSearchSource('aircraft');for(const ac of items||[]){if(ac.lat==null||ac.lon==null)continue;const m=L.marker([ac.lat,ac.lon],{icon:aircraftIcon(ac),autoPan:false}).addTo(aircraftLayer);m.bindPopup(adsbPopupHtml(ac),{autoPan:false,closeButton:true,className:'tak-object-popup adsb-object-popup'});if(typeof stabilizeLayerPopup==='function')stabilizeLayerPopup(m);m.on('click',ev=>{try{L.DomEvent.stopPropagation(ev);selectedAircraftId=ac.id;m.setIcon(aircraftIcon(ac));m.openPopup()}catch(e){}});addSearchItem('aircraft','ADS-B '+(aircraftIsMilitary(ac)?'military':'civil'),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}handleMapSearch()};
  const oldTerrainAdsb=window.terrainAdsbEntity;window.terrainAdsbEntity=function(ac){try{if(!terrain3DViewer||!window.Cesium||!isFiniteLatLon(ac.lat,ac.lon))return;const alt=Number(ac.altitude_ft);const h=Number.isFinite(alt)?alt*0.3048:0;const label=ac.callsign||ac.id||'ADS-B';const military=aircraftIsMilitary(ac);const color=military?'#2386ff':'#77d95b';const deg=Number.isFinite(Number(ac.track_deg))?Number(ac.track_deg):0;terrain3DViewer.entities.add({name:String(label),position:Cesium.Cartesian3.fromDegrees(Number(ac.lon),Number(ac.lat),h),billboard:{image:aircraftBillboardDataUrl(military,aircraftIsHelicopter(ac),deg,color),width:40,height:48,verticalOrigin:Cesium.VerticalOrigin.CENTER,heightReference:Cesium.HeightReference.NONE,disableDepthTestDistance:Number.POSITIVE_INFINITY},label:{text:String(label),font:'12px sans-serif',fillColor:Cesium.Color.WHITE.withAlpha(.9),outlineColor:Cesium.Color.BLACK.withAlpha(.76),outlineWidth:3,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-32),showBackground:true,backgroundColor:Cesium.Color.BLACK.withAlpha(.35),disableDepthTestDistance:Number.POSITIVE_INFINITY}})}catch(e){if(oldTerrainAdsb)oldTerrainAdsb(ac)}};
  function v233TweakAdsBPanel(){try{const lab=document.querySelector('label input#adsbUpdateInterval')?.parentElement;if(lab)lab.childNodes[0].textContent='Update Interval (sec)'}catch(e){}}
  async function v233UploadGeoJson(name, feature){const fc={type:'FeatureCollection',features:[feature]};const blob=new Blob([JSON.stringify(fc,null,2)],{type:'application/geo+json'});const safe=String(name||'TAK Map Object').replace(/[\\/:*?"<>|]+/g,'-').slice(0,80)||'TAK Map Object';const fd=new FormData();fd.append('files',new File([blob],safe+'.geojson',{type:'application/geo+json'}));const r=await fetch('/api/tak-map/import',{method:'POST',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||('HTTP '+r.status));lastImports=j.imports||lastImports;await refreshLocalData();drawImportedObjects();return j}
  window.v233PointState={latlng:null,color:'#ff6f2e',name:'',notes:'',icon:null}; window.v233RouteState={points:[],layer:null,color:'#ff6f2e',style:'solid'}; window.v233DrawState={mode:'',points:[],layer:null,color:'#ff6f2e'};
  function installToolbar(){try{const bar=document.getElementById('floatingMapToolbar');if(!bar||document.getElementById('toolPointDropper'))return;const html=`<button id="toolPointDropper" class="tool-btn" onclick="toggleMapTool('pointdropper')" title="Point Dropper"><svg viewBox="0 0 24 24"><path d="M12 21s6-6.1 6-11a6 6 0 0 0-12 0c0 4.9 6 11 6 11Z"/><circle cx="12" cy="10" r="2"/></svg><span class="tool-label">Point Dropper</span></button><button id="toolDraw" class="tool-btn" onclick="v233ToggleDrawMenu(event)" title="Drawing Tools"><svg viewBox="0 0 24 24"><path d="M4 18 14 8l2 2L6 20H4Z"/><path d="M13 5l2-2 6 6-2 2Z"/><path d="M5 5h6v6H5Z" opacity=".6"/></svg><span class="tool-label">Drawing Tools</span></button><button id="toolRoute" class="tool-btn" onclick="toggleMapTool('route')" title="Route Creation"><svg viewBox="0 0 24 24"><circle cx="5" cy="18" r="2"/><circle cx="12" cy="6" r="2"/><circle cx="19" cy="15" r="2"/><path d="M6 16l5-8M14 7l4 6"/></svg><span class="tool-label">Route</span></button><div id="drawToolMenu" class="tool-submenu"><button onclick="v233StartDraw('square')">Square</button><button onclick="v233StartDraw('rectangle')">Rectangle</button><button onclick="v233StartDraw('circle')">Circle</button><button onclick="v233StartDraw('ellipse')">Ellipse</button><button onclick="v233StartDraw('polygon')">Polygon</button><button onclick="v233StartDraw('freehand')">Freehand Lasso</button></div>`;const fit=document.getElementById('toolFit');fit?fit.insertAdjacentHTML('beforebegin',html):bar.insertAdjacentHTML('beforeend',html);const dock=document.getElementById('floatingToolbarDock');dock.insertAdjacentHTML('afterbegin',`<div id="pointMiniToolbar" class="map-mini-toolbar v233-mini" aria-label="Point Dropper"><button class="tool-btn" onclick="toggleMapTool('pointdropper')">Drop</button><button class="tool-btn" onclick="openMilPicker()">Icon</button><button class="tool-btn" onclick="v233OpenPointPanel()">Name</button><label class="tool-color"> <input type="color" value="#ff6f2e" onchange="v233PointState.color=this.value"><span class="tool-label">Color</span></label><button class="tool-btn" onclick="v233OpenPointPanel()">Notes</button></div><div id="drawMiniToolbar" class="map-mini-toolbar v233-mini" aria-label="Drawing"><button class="tool-btn" onclick="v233FinishDraw()">Finish</button><button class="tool-btn" onclick="v233UndoDraw()">Undo</button><button class="tool-btn" onclick="v233ClearDraw()">Clear</button><label class="tool-color"><input type="color" value="#ff6f2e" onchange="v233DrawState.color=this.value"><span class="tool-label">Color</span></label><button class="tool-btn" onclick="setActiveMapTool('move')">Cancel</button></div><div id="routeMiniToolbar" class="map-mini-toolbar v233-mini" aria-label="Route"><button class="tool-btn" onclick="v233UndoRoute()">Undo</button><button class="tool-btn" onclick="v233OpenRoutePanel()">Fields</button><button class="tool-btn" onclick="v233FinishRoute()">Finish</button><button class="tool-btn" onclick="v233ClearRoute()">Clear</button><button class="tool-btn" onclick="setActiveMapTool('move')">Cancel</button></div>`);document.body.insertAdjacentHTML('beforeend',v233PanelsHtml());v233LoadMilIcons();v233TweakAdsBPanel();}catch(e){console.warn('v233 toolbar install failed',e)}}
  function v233PanelsHtml(){return `<div id="pointEditPanel" class="tak-floating-panel"><h3>Point Dropper</h3><div class="panel-grid"><label class="wide">Point Name<input id="pointNameInput" placeholder="Point label"></label><label>Color<input id="pointColorInput" type="color" value="#ff6f2e"></label><label>Icon<button type="button" class="layer-button" onclick="openMilPicker()">MIL-STD Icon</button></label><label class="wide">Notes / Remarks<textarea id="pointNotesInput" placeholder="Description / remarks"></textarea></label></div><div class="tak-floating-actions"><button onclick="v233ClosePanel('pointEditPanel')">Cancel</button><button class="primary" onclick="v233SavePoint()">Save Point</button></div></div><div id="routeEditPanel" class="tak-floating-panel"><h3>Route Edit</h3><div class="panel-grid"><label class="wide">Route Name<input id="routeNameInput" placeholder="Route name"></label><label>Movement<select id="routeMethodInput"><option>Driving</option><option>Walking</option><option>Flying</option><option>Swimming</option><option>Watercraft</option></select></label><label>Direction<select id="routeDirectionInput"><option>Infil</option><option>Exfil</option></select></label><label>Route Type<select id="routeTypeInput"><option>Primary</option><option>Secondary</option></select></label><label>Order<select id="routeOrderInput"><option>Ascending Check Points</option><option>Descending Check Points</option></select></label><label>Prefix<input id="routePrefixInput" value="CP"></label><label>Color<input id="routeColorInput" type="color" value="#ff6f2e"></label><label>Line Style<select id="routeStyleInput"><option value="solid">Solid</option><option value="dashed">Dashed</option></select></label><label class="wide">Notes / Remarks<textarea id="routeNotesInput"></textarea></label></div><div class="tak-floating-actions"><button onclick="v233ClosePanel('routeEditPanel')">Close</button><button class="primary" onclick="v233FinishRoute()">Save Route</button></div></div><div id="milPicker" class="mil-picker"><div class="mil-head"><div class="mil-title">MIL-STD-2525C Icon Selector</div><button class="mil-close" onclick="closeMilPicker()">×</button></div><div class="mil-top"><div class="mil-preview" id="milPreview"></div><div><div class="mil-selected-name" id="milSelectedName">No symbol selected</div><div class="mil-selected-meta" id="milSelectedMeta">Choose affiliation, domain, and symbol.</div></div><input id="milSearch" class="mil-search" placeholder="Search symbols, names..." oninput="renderMilPicker()"></div><div class="mil-chips" id="milAffilChips"></div><div class="mil-body"><div class="mil-cats" id="milCats"></div><div class="mil-grid" id="milGrid"></div></div><div class="mil-foot"><div id="milDetails">Symbol details</div><button onclick="clearMilSelection()">Clear</button><button class="primary" onclick="applyMilSelection()">Apply</button></div></div>`}
  function updateV233ToolUi(){try{['PointDropper','Draw','Route'].forEach(n=>{const el=document.getElementById('tool'+n);if(el)el.classList.remove('active')});const mapId={pointdropper:'toolPointDropper',draw:'toolDraw',route:'toolRoute'}[activeMapTool];if(mapId){const el=document.getElementById(mapId);if(el)el.classList.add('active')}['pointMiniToolbar','drawMiniToolbar','routeMiniToolbar'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.remove('active')});const mini={pointdropper:'pointMiniToolbar',draw:'drawMiniToolbar',route:'routeMiniToolbar'}[activeMapTool];if(mini){const el=document.getElementById(mini);if(el)el.classList.add('active')}}catch(e){}}
  const oldSet=window.setActiveMapTool;window.setActiveMapTool=function(tool){if(oldSet)oldSet(tool);activeMapTool=tool||'move';updateV233ToolUi()};const oldUpdate=window.updateToolUi;window.updateToolUi=function(){if(oldUpdate)oldUpdate();updateV233ToolUi()};
  window.v233ToggleDrawMenu=function(ev){ev&&ev.stopPropagation&&ev.stopPropagation();const m=document.getElementById('drawToolMenu');if(m)m.classList.toggle('active')};window.v233StartDraw=function(mode){v233DrawState.mode=mode;v233DrawState.points=[];v233ClearTemp(v233DrawState);const m=document.getElementById('drawToolMenu');if(m)m.classList.remove('active');setActiveMapTool('draw')};
  function llToCoord(ll){return [Number(ll.lng),Number(ll.lat)]}function v233ClearTemp(st){try{if(st.layer){map.removeLayer(st.layer);st.layer=null}}catch(e){}}
  function circlePoly(c,e,ellipse){const pts=[];const lat=c.lat,lon=c.lng;const dx=e.lng-lon,dy=e.lat-lat;const rx=Math.abs(dx)||0.001,ry=ellipse?(Math.abs(dy)||0.001):(Math.sqrt(dx*dx+dy*dy)||0.001);for(let i=0;i<64;i++){const a=Math.PI*2*i/64;pts.push([lon+Math.cos(a)*rx,lat+Math.sin(a)*ry])}pts.push(pts[0]);return pts}function rectPoly(a,b,square){let x1=a.lng,y1=a.lat,x2=b.lng,y2=b.lat;if(square){const d=Math.max(Math.abs(x2-x1),Math.abs(y2-y1));x2=x1+(x2>=x1?d:-d);y2=y1+(y2>=y1?d:-d)}return [[x1,y1],[x2,y1],[x2,y2],[x1,y2],[x1,y1]]}
  window.v233DrawMapClick=function(ll){const st=v233DrawState;if(['rectangle','square','circle','ellipse'].includes(st.mode)){st.points.push(ll);if(st.points.length>=2)v233FinishDraw();return}st.points.push(ll);v233RedrawDrawTemp()};function v233RedrawDrawTemp(){const st=v233DrawState;v233ClearTemp(st);if(st.points.length<1)return;st.layer=(st.points.length===1?L.marker(st.points[0]):L.polyline(st.points,{color:st.color||'#ff6f2e',weight:3,dashArray:st.mode==='freehand'?'4 5':''})).addTo(map)}window.v233UndoDraw=function(){v233DrawState.points.pop();v233RedrawDrawTemp()};window.v233ClearDraw=function(){v233DrawState.points=[];v233ClearTemp(v233DrawState)};
  window.v233FinishDraw=async function(){try{const st=v233DrawState;let coords=[];if(['rectangle','square'].includes(st.mode)&&st.points.length>=2)coords=rectPoly(st.points[0],st.points[1],st.mode==='square');else if(['circle','ellipse'].includes(st.mode)&&st.points.length>=2)coords=circlePoly(st.points[0],st.points[1],st.mode==='ellipse');else if(st.points.length>=3){coords=st.points.map(llToCoord);coords.push(coords[0])}else{alert('Add more points before finishing.');return}const name=prompt('Shape name:',(st.mode||'Shape')+' '+new Date().toLocaleTimeString())||'Shape';await v233UploadGeoJson(name,{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]},properties:{name,kind:'shape',shape_type:st.mode,color:st.color||'#ff6f2e',source:'TAK Map Drawing Tools'}});v233ClearDraw();setActiveMapTool('move')}catch(e){alert('Save shape failed: '+e)}};
  window.v233OpenPointPanel=function(){const p=document.getElementById('pointEditPanel');if(p)p.classList.add('active');try{document.getElementById('pointNameInput').value=v233PointState.name||'';document.getElementById('pointNotesInput').value=v233PointState.notes||'';document.getElementById('pointColorInput').value=v233PointState.color||'#ff6f2e'}catch(e){}};window.v233ClosePanel=function(id){const el=document.getElementById(id);if(el)el.classList.remove('active')};
  window.v233SavePoint=async function(){try{const ll=v233PointState.latlng||lastPointerLatLng||map.getCenter();const name=(document.getElementById('pointNameInput')?.value||v233PointState.name||'Dropped Point').trim();const notes=document.getElementById('pointNotesInput')?.value||'';const color=document.getElementById('pointColorInput')?.value||v233PointState.color||'#ff6f2e';const icon=v233PointState.icon||{};await v233UploadGeoJson(name,{type:'Feature',geometry:{type:'Point',coordinates:[Number(ll.lng),Number(ll.lat)]},properties:{name,notes,remarks:notes,kind:'point',source:'TAK Map Point Dropper',color,icon_mode:'milstd2525c',mil2525_name:icon.name||'',mil2525_label:icon.label||'',sidc:icon.sidc||'',cot_type:icon.cot_type||''}});v233ClosePanel('pointEditPanel');setActiveMapTool('move')}catch(e){alert('Save point failed: '+e)}};
  window.v233OpenRoutePanel=function(){const p=document.getElementById('routeEditPanel');if(p)p.classList.add('active')};window.v233UndoRoute=function(){v233RouteState.points.pop();v233RedrawRoute()};window.v233ClearRoute=function(){v233RouteState.points=[];v233ClearTemp(v233RouteState)};window.v233RouteMapClick=function(ll){v233RouteState.points.push(ll);v233RedrawRoute()};function v233RedrawRoute(){const st=v233RouteState;v233ClearTemp(st);if(st.points.length){st.layer=L.polyline(st.points,{color:document.getElementById('routeColorInput')?.value||st.color,weight:4,dashArray:(document.getElementById('routeStyleInput')?.value==='dashed')?'8 7':''}).addTo(map)}}
  window.v233FinishRoute=async function(){try{const pts=v233RouteState.points;if(pts.length<2){alert('Add at least two route points.');return}const name=(document.getElementById('routeNameInput')?.value||'Route '+new Date().toLocaleTimeString()).trim();const notes=document.getElementById('routeNotesInput')?.value||'';const method=document.getElementById('routeMethodInput')?.value||'Driving';const direction=document.getElementById('routeDirectionInput')?.value||'Infil';const routeType=document.getElementById('routeTypeInput')?.value||'Primary';const order=document.getElementById('routeOrderInput')?.value||'Ascending Check Points';const prefix=document.getElementById('routePrefixInput')?.value||'CP';const color=document.getElementById('routeColorInput')?.value||'#ff6f2e';const style=document.getElementById('routeStyleInput')?.value||'solid';await v233UploadGeoJson(name,{type:'Feature',geometry:{type:'LineString',coordinates:pts.map(llToCoord)},properties:{name,kind:'route',source:'TAK Map Route Tool',notes,remarks:`Method: ${method}\nDirection: ${direction}\nRoute Type: ${routeType}\nOrder: ${order}\nPrefix: ${prefix}\nNotes: ${notes}`,route_method:method,route_direction:direction,route_type:routeType,checkpoint_order:order,checkpoint_prefix:prefix,color,line_style:style,atak_cot_type:'b-m-r',atak_route_metadata:{method,direction,routetype:routeType,order,prefix,color,style}}});v233ClearRoute();v233ClosePanel('routeEditPanel');setActiveMapTool('move')}catch(e){alert('Save route failed: '+e)}};
  function attachMapHandler(){try{if(window.v233MapHandlerInstalled||!map)return;window.v233MapHandlerInstalled=true;map.on('click',e=>{try{if(activeMapTool==='pointdropper'){v233PointState.latlng=e.latlng;v233OpenPointPanel();return}if(activeMapTool==='draw'){v233DrawMapClick(e.latlng);return}if(activeMapTool==='route'){v233RouteMapClick(e.latlng);return}}catch(err){console.warn(err)}})}catch(e){}}
  async function v233LoadMilIcons(){try{const r=await fetch('/mil2525/icons.json',{cache:'no-store'});const j=await r.json();window.v233MilIcons=Array.isArray(j)?j:[];renderMilPicker()}catch(e){}}
  function milAffilOf(i){const n=String(i.name||'').toLowerCase();if(n.startsWith('hostile'))return'Hostile';if(n.startsWith('neutral'))return'Neutral';if(n.startsWith('unknown'))return'Unknown';return'Friendly'}function milDomainOf(i){const n=String(i.name||'').toLowerCase();if(n.includes('-air-'))return'Air';if(n.includes('-sea')||n.includes('surface')||n.includes('vessel')||n.includes('boat'))return'Sea Surface';if(n.includes('subsurface')||n.includes('submarine'))return'Subsurface';if(n.includes('space')||n.includes('satellite'))return'Space';return'Ground'}function milCatOf(i){const n=String(i.name||'').toLowerCase();const cats=['infantry','armor','artillery','air-defense','engineer','signal','support','headquarters','vehicle','aircraft','helicopter','vessel','drone','weapon','facility','site','infrastructure','emergency','sensor'];return cats.find(c=>n.includes(c))||'general'}window.v233MilFilter=window.v233MilFilter||{affil:'Friendly',domain:'Ground',cat:''};
  window.openMilPicker=function(){const el=document.getElementById('milPicker');if(el){el.classList.add('active');renderMilPicker()}};window.closeMilPicker=function(){const el=document.getElementById('milPicker');if(el)el.classList.remove('active')};window.clearMilSelection=function(){window.v233MilSelected=null;v233PointState.icon=null;renderMilPicker()};window.applyMilSelection=function(){v233PointState.icon=window.v233MilSelected;closeMilPicker();v233OpenPointPanel()};
  window.renderMilPicker=function(){const icons=window.v233MilIcons||[];const f=window.v233MilFilter||{};const q=String(document.getElementById('milSearch')?.value||'').toLowerCase();const affils=['Friendly','Hostile','Neutral','Unknown'];const domains=['Ground','Air','Sea Surface','Subsurface','Space'];const cats=Array.from(new Set(icons.filter(i=>milAffilOf(i)===(f.affil||'Friendly')&&milDomainOf(i)===(f.domain||'Ground')).map(milCatOf))).sort();const ac=document.getElementById('milAffilChips');if(ac)ac.innerHTML=affils.map(a=>`<button class="mil-chip ${f.affil===a?'active':''}" onclick="v233MilFilter.affil='${a}';renderMilPicker()">${a}</button>`).join('')+domains.map(d=>`<button class="mil-chip ${f.domain===d?'active':''}" onclick="v233MilFilter.domain='${d}';v233MilFilter.cat='';renderMilPicker()">${d}</button>`).join('');const cc=document.getElementById('milCats');if(cc)cc.innerHTML='<button class="mil-cat '+(!f.cat?'active':'')+'" onclick="v233MilFilter.cat=\'\';renderMilPicker()">All</button>'+cats.map(c=>`<button class="mil-cat ${f.cat===c?'active':''}" onclick="v233MilFilter.cat='${c}';renderMilPicker()">${c.replace(/-/g,' ')}</button>`).join('');let list=icons.filter(i=>milAffilOf(i)===(f.affil||'Friendly')&&milDomainOf(i)===(f.domain||'Ground')&&(!f.cat||milCatOf(i)===f.cat));if(q)list=list.filter(i=>String([i.name,i.label,i.sidc].join(' ')).toLowerCase().includes(q));list=list.slice(0,240);const g=document.getElementById('milGrid');if(g)g.innerHTML=list.map(i=>`<div class="mil-icon-card ${(window.v233MilSelected&&window.v233MilSelected.name===i.name)?'selected':''}" title="${safeEsc(i.name)}" onclick="v233SelectMil('${safeEsc(i.name)}')"><img src="/mil2525/svg/${safeEsc(i.name)}.svg"></div>`).join('');const sel=window.v233MilSelected;const pr=document.getElementById('milPreview');if(pr)pr.innerHTML=sel?`<img src="/mil2525/svg/${safeEsc(sel.name)}.svg">`:'';const sn=document.getElementById('milSelectedName');if(sn)sn.textContent=sel?(sel.label||sel.name):'No symbol selected';const sm=document.getElementById('milSelectedMeta');if(sm)sm.textContent=sel?`${milAffilOf(sel)} · ${milDomainOf(sel)} · ${sel.sidc||''}`:'Choose affiliation, domain, and symbol.';const det=document.getElementById('milDetails');if(det)det.textContent=sel?`Symbol: ${sel.sidc||''} · ${sel.name}`:`${list.length} symbols shown`};window.v233SelectMil=function(name){const icons=window.v233MilIcons||[];window.v233MilSelected=icons.find(i=>i.name===name)||null;renderMilPicker()};
  const oldInit=window.init;if(oldInit&&!window.v233InitWrapped){window.v233InitWrapped=true;window.init=async function(){await oldInit();setTimeout(()=>{installToolbar();attachMapHandler();fetchEudsForDropdown();v233TweakAdsBPanel()},150)}}setTimeout(()=>{installToolbar();attachMapHandler();v233TweakAdsBPanel()},1000);
})();

/* v234 TAK Map refinements */
(function(){
  const st=document.createElement('style');st.id='tak-v234-style';st.textContent=`
.tool-submenu{left:auto!important;right:54px!important;min-width:0!important;width:max-content!important;max-width:min(230px,calc(100vw - 88px))!important;white-space:nowrap}.tool-submenu button{white-space:nowrap;width:auto!important;min-width:124px}.map-mini-toolbar.v233-mini#pointMiniToolbar,.map-mini-toolbar.v233-mini#routeMiniToolbar{min-width:0!important;width:max-content!important;max-width:calc(100vw - 26px)!important;padding:5px!important}.map-mini-toolbar.v233-mini#pointMiniToolbar .tool-btn,.map-mini-toolbar.v233-mini#routeMiniToolbar .tool-btn{min-width:38px!important;padding:5px 7px!important}.tak-floating-panel#routeEditPanel{width:min(338px,calc(100vw - 26px))!important;padding:8px!important}.tak-floating-panel#routeEditPanel .panel-grid{grid-template-columns:1fr 1fr!important;gap:6px!important}.tak-floating-panel#routeEditPanel input,.tak-floating-panel#routeEditPanel select,.tak-floating-panel#routeEditPanel textarea{padding:6px 7px!important;font-size:.76rem!important}.tak-floating-panel#routeEditPanel label{font-size:.61rem!important}.tak-floating-panel#routeEditPanel .route-prefix-row{display:none!important}.tak-floating-actions button{font-weight:650!important}.mil-picker{width:min(590px,calc(100vw - 24px))!important;height:min(535px,calc(100vh - 36px))!important;grid-template-rows:auto auto auto auto 1fr auto!important}.mil-top{grid-template-columns:58px minmax(0,1fr) minmax(150px,210px)!important;gap:7px!important;padding:7px 9px!important}.mil-preview{height:48px!important}.mil-preview img{max-width:42px!important;max-height:42px!important}.mil-search{height:30px!important;padding:4px 8px!important;font-size:.74rem!important;border-radius:8px!important}.mil-chips{padding:5px 8px!important;gap:4px!important;flex-wrap:nowrap!important;overflow-x:auto!important}.mil-affil-row{border-bottom:1px solid rgba(255,255,255,.045)!important}.mil-domain-row{border-bottom:1px solid rgba(255,255,255,.06)!important}.mil-chip{padding:4px 7px!important;font-size:.66rem!important;white-space:nowrap!important}.mil-body{grid-template-columns:132px 1fr!important}.mil-cats{padding:6px!important}.mil-cat{text-transform:uppercase!important;font-size:.66rem!important;padding:5px 7px!important}.mil-grid{grid-template-columns:repeat(auto-fill,minmax(58px,1fr))!important;gap:5px!important;padding:6px!important}.mil-icon-card{height:54px!important}.mil-icon-card img{max-width:42px!important;max-height:42px!important}.mil-foot{padding:6px 9px!important}.mil-foot button{padding:6px 9px!important}.status-adsb-row{cursor:pointer}.status-adsb-row:hover{background:rgba(255,111,46,.12)}.route-hit-buffer{pointer-events:stroke}
`;document.head.appendChild(st);
  function v234Esc(v){return (typeof esc==='function')?esc(v):String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
  function v234UidLike(v){v=String(v||'').trim();return /^ANDROID-/i.test(v)||/^[0-9a-f]{8}-[0-9a-f-]{27,}$/i.test(v)}
  function v234Short(v){v=String(v||'');return (typeof shortUid==='function')?shortUid(v):(v.length>14?v.slice(0,8)+'...'+v.slice(-4):v)}
  function v234PrettyEud(e){let cs=String(e?.callsign||e?.user||e?.name||'').trim();let uid=String(e?.uid||'').trim();if(!cs||v234UidLike(cs)){return {name:uid?('UID '+v234Short(uid)):'TAK Client',sub:[e?.client_label||e?.client||'TAK Client',e?.team?('Team '+e.team):'',e?.location_age_seconds!=null?('age '+Math.round(Number(e.location_age_seconds))+'s'):''].filter(Boolean).join(' · '),uidFallback:true}}return {name:cs,sub:[e?.client_label||e?.client||'',e?.team?('Team '+e.team):'',e?.location_age_seconds!=null?('age '+Math.round(Number(e.location_age_seconds))+'s'):''].filter(Boolean).join(' · '),uidFallback:false}}
  window.v234EudCache=[];window.v234EudCacheReady=false;
  window.fetchEudsForDropdown=async function(){try{const r=await fetch('/api/tak-map/euds?online=1&_='+Date.now(),{cache:'no-store'});const j=await r.json();window.v234EudCache=(j.euds||[]);window.v233EudCache=window.v234EudCache;window.v234EudCacheReady=true;if(lastBanner){lastBanner.euds_connected=window.v234EudCache.length;renderTopBanner(lastBanner)}return window.v234EudCache}catch(e){return window.v234EudCache||[]}}
  const _v234OldBanner=window.renderTopBanner||renderTopBanner;window.renderTopBanner=function(j){try{if(j&&window.v234EudCacheReady)j.euds_connected=(window.v234EudCache||[]).length}catch(e){}return _v234OldBanner?_v234OldBanner(j):undefined};
  function v234FreshAircraft(list){try{return (list||[]).filter(a=>{try{return !aircraftIsStale(a)&&a.lat!=null&&a.lon!=null}catch(_){return false}})}catch(e){return list||[]}}
  function v234AircraftSvg(ac){const label=v234Esc(ac?.callsign||ac?.id||'');const military=aircraftIsMilitary(ac);const heli=aircraftIsHelicopter(ac);const deg=Number.isFinite(Number(ac?.track_deg))?Number(ac.track_deg):0;const color=military?'#2386ff':'#77d95b';const selected=ac?.id===selectedAircraftId?' selected':'';const ring=military?`<circle cx="22" cy="22" r="16.2" fill="rgba(5,8,12,.88)" stroke="currentColor" stroke-width="5.2" stroke-dasharray="11 4"/>`:`<circle cx="22" cy="22" r="16.3" fill="rgba(5,8,12,.87)" stroke="currentColor" stroke-width="4.2"/><circle cx="22" cy="22" r="19" fill="none" stroke="#f6fbff" stroke-width="1.3" opacity=".68"/>`;const heliGlyph=`<path d="M5 14 H39" stroke="#f7fbff" stroke-width="3.7" stroke-linecap="round"/><path d="M22 5 V30" stroke="#f7fbff" stroke-width="2.8" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.8" ry="5.5" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".75"/><path d="M12 34 H32 M22 30 V38" stroke="#f7fbff" stroke-width="2.45" stroke-linecap="round"/>`;const jetGlyph=`<path d="M22 4 L28 23 L39 29 L27 31 L23 42 L21 42 L17 31 L5 29 L16 23 Z" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".85"/><path d="M22 30 L14 40 M22 30 L30 40" stroke="#f7fbff" stroke-width="2.25" stroke-linecap="round"/>`;const civGlyph=`<path d="M22 6 L25 22 L36 27 L25 29 L22 40 L19 29 L8 27 L19 22 Z" fill="#f7fbff" stroke="rgba(0,0,0,.75)" stroke-width=".75"/><path d="M22 30 L16 39 M22 30 L28 39" stroke="#f7fbff" stroke-width="2.1" stroke-linecap="round"/>`;const glyph=heli?heliGlyph:(military?jetGlyph:civGlyph);const cls=(military?'aircraft-military':'aircraft-civil')+(heli?' aircraft-rotor':' aircraft-fixed');return `<div class="aircraft-wrap ${cls}" style="color:${color}"><svg class="aircraft-glyph${selected}" width="42" height="52" viewBox="0 0 44 54">${ring}<g transform="rotate(${deg} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="currentColor"/>${glyph}</g><circle cx="22" cy="50" r="3.2" fill="currentColor"/></svg><div class="aircraft-label">${label}</div></div>`}
  aircraftIcon=window.aircraftIcon=function(ac){return L.divIcon({className:'',html:v234AircraftSvg(ac),iconSize:[96,60],iconAnchor:[48,25]})};
  aircraftBillboardDataUrl=window.aircraftBillboardDataUrl=function(military,heli,deg,color){try{const c=color||(military?'#2386ff':'#77d95b');const ring=military?`<circle cx="22" cy="22" r="16.2" fill="rgba(5,8,12,.88)" stroke="${c}" stroke-width="5.2" stroke-dasharray="11 4"/>`:`<circle cx="22" cy="22" r="16.3" fill="rgba(5,8,12,.87)" stroke="${c}" stroke-width="4.2"/><circle cx="22" cy="22" r="19" fill="none" stroke="#f6fbff" stroke-width="1.3" opacity=".68"/>`;const body=heli?'<path d="M5 14 H39" stroke="white" stroke-width="3.7" stroke-linecap="round"/><path d="M22 5 V30" stroke="white" stroke-width="2.8" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.8" ry="5.5" fill="white"/><path d="M12 34 H32 M22 30 V38" stroke="white" stroke-width="2.45" stroke-linecap="round"/>':(military?'<path d="M22 4 L28 23 L39 29 L27 31 L23 42 L21 42 L17 31 L5 29 L16 23 Z" fill="white"/><path d="M22 30 L14 40 M22 30 L30 40" stroke="white" stroke-width="2.25" stroke-linecap="round"/>':'<path d="M22 6 L25 22 L36 27 L25 29 L22 40 L19 29 L8 27 L19 22 Z" fill="white"/><path d="M22 30 L16 39 M22 30 L28 39" stroke="white" stroke-width="2.1" stroke-linecap="round"/>');const svg=`<svg xmlns="http://www.w3.org/2000/svg" width="44" height="54" viewBox="0 0 44 54">${ring}<g transform="rotate(${deg||0} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="${c}"/>${body}</g><circle cx="22" cy="50" r="3.2" fill="${c}"/></svg>`;return 'data:image/svg+xml;charset=utf-8,'+encodeURIComponent(svg)}catch(e){return ''}};
  window.v234AircraftLayersById={};
  drawAircraft=window.drawAircraft=function(items){if(terrain3DActive)return;items=v234FreshAircraft(items);aircraftLayer.clearLayers();window.v234AircraftLayersById={};clearSearchSource('aircraft');for(const ac of items||[]){if(ac.lat==null||ac.lon==null)continue;const id=String(ac.id||ac.icao||ac.uid||ac.callsign||'');const m=L.marker([ac.lat,ac.lon],{icon:aircraftIcon(ac),autoPan:false}).addTo(aircraftLayer);window.v234AircraftLayersById[id]=m;m.bindPopup(adsbPopupHtml(ac),{autoPan:false,closeButton:true,className:'tak-object-popup adsb-object-popup'});if(typeof stabilizeLayerPopup==='function')stabilizeLayerPopup(m);m.on('click',ev=>{try{L.DomEvent.stopPropagation(ev);selectedAircraftId=id;m.setIcon(aircraftIcon(ac));m.openPopup()}catch(e){}});addSearchItem('aircraft','ADS-B '+(aircraftIsMilitary(ac)?'military':'civil'),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}handleMapSearch();}
  refreshAdsb=window.refreshAdsb=async function(){if(state.live.adsb_aircraft===false)return;try{const r=await fetch('/api/tak-map/adsb',{cache:'no-store'});const j=await r.json();window.lastAdsbSettings=j.settings||window.lastAdsbSettings||config?.adsb?.settings||{};const aircraft=v234FreshAircraft(j.aircraft||[]);lastAircraft=aircraft;const el=document.getElementById('adsbStatus');if(el)el.textContent=aircraft.length+' active';if(lastBanner){lastBanner.adsb_aircraft=aircraft.length;renderTopBanner(lastBanner)}drawAircraft(lastAircraft);if(terrain3DActive)refreshTerrain3DObjects(true,'adsb-refresh')}catch(e){const el=document.getElementById('adsbStatus');if(el)el.textContent='error'}};
  window.focusAdsbAircraft=function(id){try{const ac=(lastAircraft||[]).find(a=>String(a.id||a.icao||a.uid||a.callsign||'')===String(id));if(!ac||ac.lat==null||ac.lon==null)return;selectedAircraftId=String(ac.id||ac.icao||ac.uid||ac.callsign||'');if(map){map.setView([Number(ac.lat),Number(ac.lon)],Math.max(map.getZoom(),12),{animate:true})}setTimeout(()=>{try{drawAircraft(lastAircraft||[]);const m=window.v234AircraftLayersById[selectedAircraftId];if(m)m.openPopup()}catch(e){}},220)}catch(e){}};
  statusDropdownRows=window.statusDropdownRows=function(type){if(type==='euds')return (window.v234EudCache||window.v233EudCache||[]).map(v234PrettyEud);if(type==='nontak')return (lastTakMarkers||[]).filter(m=>{const k=String(m.kind||'').toLowerCase();if(['eud','server_gps','server-gps','webform','aircraft','datasync'].includes(k))return false;if(m.mission||m.is_mission_object||m.creator_callsign||m.parent_callsign)return false;return true}).map(m=>({name:statusItemLabel(m),sub:statusItemSub(m)}));if(type==='adsb'){let rows=v234FreshAircraft(lastAircraft||[]).map(a=>{const id=String(a.id||a.icao||a.uid||a.callsign||'');return {id,icao:adsbIdent(a),alt:adsbAltText(a),range:adsbRangeText(a),altNum:Number(a?.altitude_ft),rangeNum:Number(a?.range_miles)}});const sort=window.v233StatusSort||{key:'icao',dir:1};rows.sort((a,b)=>{let av,bv;if(sort.key==='alt'){av=Number.isFinite(a.altNum)?a.altNum:-999999;bv=Number.isFinite(b.altNum)?b.altNum:-999999}else if(sort.key==='range'){av=Number.isFinite(a.rangeNum)?a.rangeNum:999999;bv=Number.isFinite(b.rangeNum)?b.rangeNum:999999}else{av=a.icao;bv=b.icao}return (typeof av==='string'?av.localeCompare(String(bv)):av-bv)*sort.dir});return rows}return []};
  renderStatusDropdown=window.renderStatusDropdown=function(type){const box=document.getElementById('statusDropdown');if(!box)return;box.dataset.type=type;box.classList.toggle('adsb-table',type==='adsb');if(type==='euds'&&!window.v234EudCacheReady){box.innerHTML='<div class="status-dropdown-title">EUD Callsigns</div><div class="status-dropdown-empty">Loading online EUDs...</div>';fetchEudsForDropdown().then(()=>{if(box.classList.contains('active')&&box.dataset.type==='euds')renderStatusDropdown('euds')});return}const rows=statusDropdownRows(type);let html='<div class="status-dropdown-title">'+v234Esc(statusDropdownTitle(type))+'</div>';if(!rows.length)html+='<div class="status-dropdown-empty">No items currently listed.</div>';else if(type==='adsb'){const s=window.v233StatusSort||{key:'icao',dir:1};const ind=k=>s.key===k?'<span class="status-sort-ind">'+(s.dir>0?'▲':'▼')+'</span>':'';html+='<div class="status-adsb-head"><span onclick="setAdsbStatusSort(\'icao\',event)">ICAO'+ind('icao')+'</span><span onclick="setAdsbStatusSort(\'alt\',event)">Altitude'+ind('alt')+'</span><span onclick="setAdsbStatusSort(\'range\',event)">From Center Point'+ind('range')+'</span></div>'+rows.map(r=>'<div class="status-adsb-row" onclick="focusAdsbAircraft(\''+encodeURIComponent(r.id).replace(/'/g,'%27')+'\')"><span class="status-adsb-icao">'+v234Esc(r.icao)+'</span><span class="status-adsb-alt">'+v234Esc(r.alt)+'</span><span class="status-adsb-range">'+v234Esc(r.range)+'</span></div>').join('')}else html+=rows.map(r=>'<div class="status-dropdown-row"><span class="status-dropdown-name '+(r.uidFallback?'uid-fallback':'')+'">'+v234Esc(r.name)+'</span><span class="status-dropdown-sub">'+v234Esc(r.sub||'')+'</span></div>').join('');box.innerHTML=html};
  const _oldFocus=window.focusAdsbAircraft;window.focusAdsbAircraft=function(encId){return _oldFocus(decodeURIComponent(String(encId||'')))};
  function v234ClearTemp(st){try{if(st.layer){map.removeLayer(st.layer);st.layer=null}if(st.hitLayer){map.removeLayer(st.hitLayer);st.hitLayer=null}}catch(e){}}
  window.v234RedrawRoute=function(){const st=window.v233RouteState||{};v234ClearTemp(st);if(st.points&&st.points.length){const color=document.getElementById('routeColorInput')?.value||st.color||'#ff6f2e';const dashed=(document.getElementById('routeStyleInput')?.value||st.style)==='dashed';st.layer=L.polyline(st.points,{color,weight:4,opacity:.94,dashArray:dashed?'8 7':null}).addTo(map);try{st.hitLayer=L.polyline(st.points,{color:'#000',weight:16,opacity:0,interactive:true}).addTo(map);st.hitLayer.on('click',()=>v233OpenRoutePanel())}catch(e){}}};
  window.v233RouteMapClick=function(ll){v233RouteState.points.push(ll);v234RedrawRoute()};window.v233UndoRoute=function(){v233RouteState.points.pop();v234RedrawRoute()};window.v233ClearRoute=function(){v233RouteState.points=[];v234ClearTemp(v233RouteState)};
  function v234AdjustPanels(){try{const pref=document.getElementById('routePrefixInput');if(pref&&pref.parentElement)pref.parentElement.classList.add('route-prefix-row');const rc=document.getElementById('routeColorInput');if(rc&&!rc.dataset.v234){rc.dataset.v234='1';rc.addEventListener('change',e=>{try{e.target.blur();v234RedrawRoute()}catch(_){}});rc.addEventListener('input',()=>v234RedrawRoute())}const rs=document.getElementById('routeStyleInput');if(rs&&!rs.dataset.v234){rs.dataset.v234='1';rs.addEventListener('change',()=>{v233RouteState.style=rs.value;v234RedrawRoute()})}document.querySelectorAll('input[type="color"]').forEach(i=>{if(!i.dataset.blurOnChange){i.dataset.blurOnChange='1';i.addEventListener('change',e=>{try{e.target.blur()}catch(_){}})}})}catch(e){}}
  const _oldOpenRoute=window.v233OpenRoutePanel;window.v233OpenRoutePanel=function(){if(_oldOpenRoute)_oldOpenRoute();v234AdjustPanels()};
  window.v233ToggleDrawMenu=function(ev){try{ev&&ev.stopPropagation&&ev.stopPropagation();const m=document.getElementById('drawToolMenu');if(!m)return;m.classList.toggle('active');const b=document.getElementById('toolDraw');if(b&&m.classList.contains('active')){const br=b.getBoundingClientRect();const mr=m.getBoundingClientRect();m.style.right='54px';m.style.left='auto';m.style.top=Math.max(-4,Math.min(0,window.innerHeight-br.top-mr.height-12))+'px'}}catch(e){}};
  function v234MilAffilOf(i){const n=String(i?.name||'').toLowerCase();if(n.startsWith('hostile'))return'Hostile';if(n.startsWith('neutral'))return'Neutral';if(n.startsWith('unknown'))return'Unknown';return'Friendly'}
  function v234MilDomainOf(i){const n=String(i?.name||'').toLowerCase();if(n.includes('-air-'))return'Air';if(n.includes('subsurface')||n.includes('submarine'))return'Subsurface';if(n.includes('-sea')||n.includes('surface')||n.includes('vessel')||n.includes('boat'))return'Sea Surface';if(n.includes('space')||n.includes('satellite'))return'Space';return'Ground'}
  function v234MilCatOf(i){const n=String(i?.name||'').toLowerCase();const cats=['infantry','armor','artillery','air-defense','engineer','signal','support','headquarters','vehicle','aircraft','helicopter','vessel','drone','weapon','facility','site','infrastructure','emergency','sensor'];return cats.find(c=>n.includes(c))||'general'}
  function v234NiceCat(c){return String(c||'general').replace(/-/g,' ').toUpperCase()}
  function v234EnsureMilRows(){const aff=document.getElementById('milAffilChips');if(aff){aff.classList.add('mil-affil-row');if(!document.getElementById('milDomainChips'))aff.insertAdjacentHTML('afterend','<div class="mil-chips mil-domain-row" id="milDomainChips"></div>')}}
  window.v234SetMilAffil=function(a){window.v233MilFilter.affil=a;window.v233MilFilter.cat='';renderMilPicker()};window.v234SetMilDomain=function(d){window.v233MilFilter.domain=d;window.v233MilFilter.cat='';renderMilPicker()};window.v234SetMilCat=function(c){window.v233MilFilter.cat=c;renderMilPicker()};window.v234SelectMil=function(name){name=decodeURIComponent(String(name||''));window.v233MilSelected=(window.v233MilIcons||[]).find(i=>i.name===name)||null;renderMilPicker()};
  renderMilPicker=window.renderMilPicker=function(){v234EnsureMilRows();const icons=(window.v233MilIcons||[]).filter(i=>i&&i.name&&i.label!=='?'&&!String(i.name).includes('placeholder'));const f=window.v233MilFilter||{affil:'Friendly',domain:'Ground',cat:''};const q=String(document.getElementById('milSearch')?.value||'').toLowerCase();const affils=['Friendly','Hostile','Neutral','Unknown'];const domains=['Ground','Air','Sea Surface','Subsurface','Space'];const cats=Array.from(new Set(icons.filter(i=>v234MilAffilOf(i)===(f.affil||'Friendly')&&v234MilDomainOf(i)===(f.domain||'Ground')).map(v234MilCatOf))).sort();const ac=document.getElementById('milAffilChips');if(ac)ac.innerHTML=affils.map(a=>`<button class="mil-chip ${f.affil===a?'active':''}" onclick="v234SetMilAffil('${a}')">${a}</button>`).join('');const dc=document.getElementById('milDomainChips');if(dc)dc.innerHTML=domains.map(d=>`<button class="mil-chip ${f.domain===d?'active':''}" onclick="v234SetMilDomain('${d}')">${d}</button>`).join('');const cc=document.getElementById('milCats');if(cc)cc.innerHTML='<button class="mil-cat '+(!f.cat?'active':'')+'" onclick="v234SetMilCat(\'\')">ALL</button>'+cats.map(c=>`<button class="mil-cat ${f.cat===c?'active':''}" onclick="v234SetMilCat('${c}')">${v234NiceCat(c)}</button>`).join('');let list=icons.filter(i=>v234MilAffilOf(i)===(f.affil||'Friendly')&&v234MilDomainOf(i)===(f.domain||'Ground')&&(!f.cat||v234MilCatOf(i)===f.cat));if(q)list=list.filter(i=>String([i.name,i.label,i.sidc].join(' ')).toLowerCase().includes(q));list=list.slice(0,240);const g=document.getElementById('milGrid');if(g)g.innerHTML=list.map(i=>`<div class="mil-icon-card ${(window.v233MilSelected&&window.v233MilSelected.name===i.name)?'selected':''}" title="${v234Esc(i.name)}" onclick="v234SelectMil('${encodeURIComponent(i.name)}')"><img src="/mil2525/svg/${v234Esc(i.name)}.svg" onerror="this.closest('.mil-icon-card').style.display='none'"></div>`).join('');const sel=window.v233MilSelected;const pr=document.getElementById('milPreview');if(pr)pr.innerHTML=sel?`<img src="/mil2525/svg/${v234Esc(sel.name)}.svg" onerror="this.style.display='none'">`:'';const sn=document.getElementById('milSelectedName');if(sn)sn.textContent=sel?(sel.label||sel.name):'No symbol selected';const sm=document.getElementById('milSelectedMeta');if(sm)sm.textContent=sel?`${v234MilAffilOf(sel)} · ${v234MilDomainOf(sel)} · ${sel.sidc||''}`:'Choose affiliation, domain, and symbol.';const det=document.getElementById('milDetails');if(det)det.textContent=sel?`Symbol: ${sel.sidc||''} · ${sel.name}`:`${list.length} symbols shown`};
  function v234AfterInit(){try{v234AdjustPanels();fetchEudsForDropdown();setInterval(fetchEudsForDropdown,10000);const m=document.getElementById('milSearch');if(m)m.placeholder='Search...';v234EnsureMilRows();renderMilPicker();if(state.live.adsb_aircraft)refreshAdsb()}catch(e){}}
  const _oldInit=window.init||init;if(_oldInit&&!window.v234InitWrapped){window.v234InitWrapped=true;init=window.init=async function(){await _oldInit();setTimeout(v234AfterInit,250)}}setTimeout(v234AfterInit,1300);
})();

/* v236 EUD/ADS-B/drawing/route/MIL-STD refinements */
(function(){
  const H='http://www.w3.org/2000/svg';
  function E(v){try{return (typeof esc==='function')?esc(v):String(v??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}catch(_){return String(v??'')}}
  function iconSvg(kind){
    const p={drop:'M12 21s6-6.1 6-11a6 6 0 0 0-12 0c0 4.9 6 11 6 11Z|circle:12,10,2',icon:'M4 6h16v12H4Z|M8 10h8|M8 14h5',name:'M5 7h14|M5 12h14|M5 17h9',color:'M12 3a9 9 0 1 0 0 18 3 3 0 0 0 0-6h2a4 4 0 0 0 0-8h-2',notes:'M5 4h14v16H5Z|M8 8h8|M8 12h8|M8 16h5',more:'M6 12h.1|M12 12h.1|M18 12h.1',save:'M20 6 9 17l-5-5',cancel:'M6 6l12 12|M18 6 6 18',undo:'M8 7 4 11l4 4|M4 11h9a5 5 0 1 1-2 9',finish:'M20 6 9 17l-5-5',clear:'M4 7h16|M9 7V4h6v3|M7 7l1 14h8l1-14',options:'M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8|M12 2v3|M12 19v3|M2 12h3|M19 12h3',square:'M6 6h12v12H6Z',rect:'M4 7h16v10H4Z',circle:'M12 5a7 7 0 1 0 0 14 7 7 0 0 0 0-14',ellipse:'M4 12a8 5 0 1 0 16 0 8 5 0 0 0-16 0',poly:'M5 17 8 6l10 3 1 9-8 2Z',lasso:'M5 13c0-5 8-8 13-4 5 4-1 10-8 9-4-.5-6-2-5-5Z'};
    const spec=p[kind]||p.more;let body='';spec.split('|').forEach(part=>{if(part.startsWith('circle:')){const a=part.slice(7).split(',');body+=`<circle cx="${a[0]}" cy="${a[1]}" r="${a[2]}"/>`}else body+=`<path d="${part}"/>`});return `<svg viewBox="0 0 24 24">${body}</svg>`
  }
  function compactToolbars(){try{
