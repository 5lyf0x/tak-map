  }
  function start(id){id=String(id||'').toLowerCase();const a=findAircraft(id);state.id=id;state.meta=a||{id};state.points=[];closeDialog();if(a)addPoint(a);startTimer();syncButtons();patchOpenPopups();return true}
  function stop(){const id=state.id,meta=state.meta,pts=state.points.slice();state.id=null;state.meta=null;state.points=[];stopTimer();syncButtons();patchOpenPopups();saveDialog(id,meta,pts);return false}
