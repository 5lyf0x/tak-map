\');const box=document.getElementById(\'importRows\');if(localBox)localBox.innerHTML=\'<div class="muted">Adding local file...</div>\';if(box)box.innerHTML=\'<div class="muted">Importing files...</div>\';try{const r=await fetch(\'/api/tak-map/import\',{method:\'POST\',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));inp.value=\'\';lastImports=j.imports||lastImports;renderImportRows();await refreshLocalData();try{drawImportedObjects()}catch(drawErr){try{console.warn(\'Local data imported but map draw failed\',drawErr)}catch(_){}}}catch(e){if(localBox)renderLocalDataRows(\'Import failed: \'+e);if(box)box.innerHTML=\'<div class="danger">Import failed: \'+esc(e)+\'</div>\'}}async function clearImportedFiles(){if(!confirm(\'Clear imported TAK Map files?\'))return;await fetch(\'/api/tak-map/import-clear\',{method:\'POST\'});lastImports=[];renderImportRows();drawImportedObjects()}function importedFeatures(){const out=[];for(const imp of lastImports||[]){(imp.features||[]).forEach((f,idx)=>{f.import_id=imp.id;f.import_name=imp.name;f.import_feature_index=idx;f.uploaded=imp.uploaded;f._local_id=(imp.id||imp.name)+\':\'+idx;out.push(f)})}const routeEnds=[];for(const f of out){const s=String(f.kind||f.geometry||f.geometry_type||f.type||\'\').toLowerCase();const coords=Array.isArray(f.coords)?f.coords:[];if((s.includes(\'route\')||s.includes(\'track\')||s.includes(\'linestring\'))&&coords.length>=2){routeEnds.push(coords[0],coords[coords.length-1])}}function nearEndpoint(f){if(f.lat==null||f.lon==null)return false;const lat=Number(f.lat),lon=Number(f.lon);if(!Number.isFinite(lat)||!Number.isFinite(lon))return false;const s=String(f.kind||f.geometry||f.geometry_type||f.type||\'\').toLowerCase();if(s.includes(\'route\')||s.includes(\'linestring\')||s.includes(\'track\'))return false;const name=String(f.name||f.callsign||f.title||\'\').toLowerCase();const endpointName=/^(start|end|finish|route start|route end|start point|end point|begin|destination)$/i.test(name.trim())||name.includes(\'start\')||name.includes(\'end\');return routeEnds.some(pt=>Array.isArray(pt)&&Math.abs(Number(pt[0])-lat)<0.00010&&Math.abs(Number(pt[1])-lon)<0.00010&&(endpointName||true))}return out.filter(f=>!nearEndpoint(f))}function drawImportedObjects(){if(terrain3DActive){const c=document.getElementById(\'importedCount\');if(c)c.textContent=String((importedFeatures?importedFeatures():[]).length);handleMapSearch();refreshTerrain3DObjects(false,\'local\');return}importedLayer.clearLayers();clearSearchSource(\'imported\');if(!state.imported){handleMapSearch();refreshTerrain3DObjects(false,\'local-off\');return}let shown=0;for(const f of importedFeatures()){try{const lid=String(f._local_id||f.id||f.uid||f.name||\'\');if(lid&&state.local.hidden[lid])continue;if(addObjectLayer(importedLayer,f,\'imported\'))shown++}catch(e){try{console.warn(\'Skipped imported feature\',f,e)}catch(_){}}}const c=document.getElementById(\'importedCount\');if(c)c.textContent=String(shown);handleMapSearch();refreshTerrain3DObjects(false,\'local\')}function renderImportRows(){const box=document.getElementById(\'importRows\');if(!box)return;const imports=lastImports||[];let html=`<div class="subgroup-title">Imported files <span class="chip">${imports.length}</span></div>`;if(!imports.length){box.innerHTML=html+\'<div class="muted">No imported files yet.</div>\';return}html+=imports.slice().reverse().map(imp=>`<div class="import-card"><b>${esc(imp.name)}</b><small>Points: ${esc(imp.counts?.point||0)} · Routes: ${esc(imp.counts?.route||0)} · Shapes: ${esc(imp.counts?.shape||0)} · Other: ${esc(imp.counts?.other||0)}</small></div>`).join(\'\');box.innerHTML=html}\n\n\nfunction renderOfflineSourceOptions(){updateOfflineSourceText()}function currentDownloadSource(){const id=activeBasemap||savedBasemap()||config?.default_basemap||\'\';const b=(config?.offline_download_sources||[]).find(s=>s.id===id);return b||null}function updateOfflineSourceText(){const el=document.getElementById(\'offlineSourceText\');const src=currentDownloadSource();if(el)el.textContent=src?src.label:\'Select an online no-key basemap\';}function useCurrentViewForOffline(){if(!map){return}stopOfflineAreaDraw();const b=map.getBounds();offlineDownloadBounds={west:b.getWest(),south:b.getSouth(),east:b.getEast(),north:b.getNorth()};drawOfflineAreaRectangle(b);updateOfflineBoundsText();lastOfflineEstimate=null;estimateOfflineDownload(false)}function updateOfflineBoundsText(){const el=document.getElementById(\'offlineBoundsText\');if(!el)return;if(!offlineDownloadBounds){el.innerHTML=\'No area selected yet.\';return}el.innerHTML=`West: ${offlineDownloadBounds.west.toFixed(5)} &nbsp; South: ${offlineDownloadBounds.south.toFixed(5)}<br>East: ${offlineDownloadBounds.east.toFixed(5)} &nbsp; North: ${offlineDownloadBounds.north.toFixed(5)}`}function setOfflineBoundsFromLeafletBounds(lb){offlineDownloadBounds={west:lb.getWest(),south:lb.getSouth(),east:lb.getEast(),north:lb.getNorth()};updateOfflineBoundsText();lastOfflineEstimate=null;estimateOfflineDownload(false)}function drawOfflineAreaRectangle(lb){if(offlineAreaRect){try{map.removeLayer(offlineAreaRect)}catch(e){}}offlineAreaRect=L.rectangle(lb,{className:\'offline-draw-rect\',color:\'#ff6f2e\',weight:2,fillOpacity:.10}).addTo(map)}function clearOfflineArea(){offlineDownloadBounds=null;lastOfflineEstimate=null;updateOfflineBoundsText();const est=document.getElementById(\'offlineEstimate\');if(est)est.textContent=\'Use Current View or Draw Area, then choose zoom range to estimate download size.\';if(offlineAreaRect){try{map.removeLayer(offlineAreaRect)}catch(e){}offlineAreaRect=null}if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(e){}offlineDrawRect=null}stopOfflineAreaDraw()}function startOfflineAreaDraw(){if(!map)return;stopOfflineAreaDraw();offlineDrawing=true;offlineDrawStart=null;map.dragging.disable();const help=document.getElementById(\'offlineDrawHelp\');if(help)help.style.display=\'block\';map.getContainer().style.cursor=\'crosshair\'}function stopOfflineAreaDraw(){offlineDrawing=false;offlineDrawStart=null;map.getContainer().style.cursor=\'\';try{map.dragging.enable()}catch(e){}const help=document.getElementById(\'offlineDrawHelp\');if(help)help.style.display=\'none\'}function initOfflineAreaDrawing(){map.on(\'mousedown\',e=>{if(!offlineDrawing)return;offlineDrawStart=e.latlng;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}}offlineDrawRect=L.rectangle(L.latLngBounds(offlineDrawStart,offlineDrawStart),{className:\'offline-draw-rect\',color:\'#ff6f2e\',weight:2,fillOpacity:.10}).addTo(map)});map.on(\'mousemove\',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect)return;offlineDrawRect.setBounds(L.latLngBounds(offlineDrawStart,e.latlng))});map.on(\'mouseup\',e=>{if(!offlineDrawing||!offlineDrawStart)return;const lb=L.latLngBounds(offlineDrawStart,e.latlng);stopOfflineAreaDraw();if(lb.getNorth()===lb.getSouth()||lb.getEast()===lb.getWest())return;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}offlineDrawRect=null}drawOfflineAreaRectangle(lb);setOfflineBoundsFromLeafletBounds(lb)});map.on(\'touchstart\',e=>{if(!offlineDrawing||!e.latlng)return;offlineDrawStart=e.latlng;if(offlineDrawRect){try{map.removeLayer(offlineDrawRect)}catch(x){}}offlineDrawRect=L.rectangle(L.latLngBounds(offlineDrawStart,offlineDrawStart),{className:\'offline-draw-rect\',color:\'#ff6f2e\',weight:2,fillOpacity:.10}).addTo(map)});map.on(\'touchmove\',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect||!e.latlng)return;offlineDrawRect.setBounds(L.latLngBounds(offlineDrawStart,e.latlng))});map.on(\'touchend\',e=>{if(!offlineDrawing||!offlineDrawStart||!offlineDrawRect)return;const lb=offlineDrawRect.getBounds();stopOfflineAreaDraw();drawOfflineAreaRectangle(lb);setOfflineBoundsFromLeafletBounds(lb)})}function offlinePayload(){const src=currentDownloadSource();let minz=parseInt(document.getElementById(\'offlineMinZoom\')?.value||\'8\',10);let maxz=parseInt(document.getElementById(\'offlineMaxZoom\')?.value||\'13\',10);if(!Number.isFinite(minz))minz=8;if(!Number.isFinite(maxz))maxz=13;if(maxz<minz){const t=minz;minz=maxz;maxz=t}return {source_id:src?.id||\'\',bounds:offlineDownloadBounds,min_zoom:minz,max_zoom:maxz,name:(document.getElementById(\'offlinePackName\')?.value||\'\').trim()}}function fmtBytes(n){n=Number(n||0);if(n>1073741824)return (n/1073741824).toFixed(2)+\' GB\';if(n>1048576)return (n/1048576).toFixed(1)+\' MB\';if(n>1024)return (n/1024).toFixed(1)+\' KB\';return n+\' B\'}let offlineEstimateTimer=null;function scheduleOfflineEstimate(){if(!offlineDownloadBounds)return;clearTimeout(offlineEstimateTimer);offlineEstimateTimer=setTimeout(()=>estimateOfflineDownload(true),450)}async function estimateOfflineDownload(silent=false){const box=document.getElementById(\'offlineEstimate\');try{updateOfflineSourceText();const payload=offlinePayload();const src=currentDownloadSource();if(!src)throw new Error(\'The current basemap cannot be downloaded. Select an online no-key ESRI/USGS basemap first.\');if(!payload.bounds)throw new Error(\'Select an area first.\');if(box&&!silent)box.textContent=\'Estimating tile count...\';const r=await fetch(\'/api/tak-map/offline-estimate\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify(payload)});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));lastOfflineEstimate=j;const mapType=(src.group||\'Basemap\')+\' · \'+src.label;const msg=`${esc(mapType)}<br>${j.tile_count} tiles · estimated total download ${fmtBytes(j.estimated_bytes)} · limit ${j.max_tiles} tiles`+(j.allowed?\'\':\' · reduce area or zoom range\');if(box)box.innerHTML=`<span class="${j.allowed?\'\':\'danger\'}">${msg}</span>`;return j}catch(e){if(box&&!silent)box.innerHTML=\'<span class="danger">Estimate failed: \'+esc(e)+\'</span>\';return null}}function previewOfflineZoom(){if(!map)return;let z=parseInt(document.getElementById(\'offlineMaxZoom\')?.value||String(map.getZoom()),10);if(!Number.isFinite(z))z=map.getZoom();map.setZoom(z);updateZoomIndicator();scheduleOfflineEstimate()}async function startOfflineDownload(){const status=document.getElementById(\'offlineJobStatus\');try{let est=lastOfflineEstimate;if(!est||!est.allowed)est=await estimateOfflineDownload();if(!est||!est.allowed)return;const payload=offlinePayload();if(status)status.textContent=\'Starting offline map download job...\';const r=await fetch(\'/api/tak-map/offline-download\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify(payload)});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));const nameInput=document.getElementById(\'offlinePackName\');if(nameInput)nameInput.value=\'\';clearOfflineArea();pollOfflineJob(j.job.id)}catch(e){if(status)status.innerHTML=\'<span class="danger">Download failed to start: \'+esc(e)+\'</span>\'}}\nasync function controlOfflineJob(id,action){const status=document.getElementById(\'offlineJobStatus\');try{const r=await fetch(\'/api/tak-map/offline-control\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({id,action})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));if(status)status.textContent=(action===\'pause\'?\'Pause\':\'Cancel\')+\' requested. Saving downloaded tiles as a partial pack...\';pollOfflineJob(id)}catch(e){if(status)status.innerHTML=\'<span class="danger">Offline download control failed: \'+esc(e)+\'</span>\'}}async function resumeOfflineMap(id){const status=document.getElementById(\'offlineJobStatus\');try{const r=await fetch(\'/api/tak-map/offline-resume\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({id})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));if(status)status.textContent=\'Resume started. Existing tiles will be skipped...\';pollOfflineJob(j.job.id)}catch(e){if(status)status.innerHTML=\'<span class="danger">Resume failed: \'+esc(e)+\'</span>\';else alert(\'Resume failed: \'+e)}}\n\nfunction capStatus(s){s=String(s||\'\');return s?s.charAt(0).toUpperCase()+s.slice(1):\'\'}function etaFromJob(job){const total=Number(job.tile_count||0),done=Number(job.done||0);if(!total||!done||done>=total)return\'\';const t=Date.parse(job.started||job.created||\'\');if(!Number.isFinite(t))return\'\';const elapsed=Math.max(1,(Date.now()-t)/1000);const rate=done/elapsed;if(rate<=0)return\'\';let s=Math.max(0,Math.round((total-done)/rate));const h=Math.floor(s/3600);s%=3600;const m=Math.floor(s/60);const sec=s%60;if(h)return`ETA ${h}h ${String(m).padStart(2,\'0\')}m`;return`ETA ${m}m ${String(sec).padStart(2,\'0\')}s`}async function pollOfflineJob(id){if(offlineJobTimer)clearTimeout(offlineJobTimer);const status=document.getElementById(\'offlineJobStatus\');try{const r=await fetch(\'/api/tak-map/offline-jobs?id=\'+encodeURIComponent(id),{cache:\'no-store\'});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));const job=j.job||{};const total=Number(job.tile_count||0),done=Number(job.done||0),saved=Number(job.saved||0),failed=Number(job.failed||0);const pct=total?Math.min(100,Math.round(done/total*100)):0;const label=capStatus(job.status||\'running\');const eta=etaFromJob(job);const controls=(job.status===\'running\'||job.status===\'queued\')?`<br><button class="layer-button" onclick="controlOfflineJob(\'${esc(id)}\',\'pause\')">Pause</button> <button class="layer-button" onclick="controlOfflineJob(\'${esc(id)}\',\'cancel\')">Cancel / save partial</button>`:\'\';if(status)status.innerHTML=`${esc(label)} · ${pct}% · ${done}/${total} checked · saved ${saved} · failed ${failed}${eta?\' · \'+esc(eta):\'\'}<br>${esc(job.message||\'\')}${controls}`;updateTopBannerCached();if([\'done\',\'paused\',\'canceled\',\'error\'].includes(job.status)){await refreshOfflineMaps(true);updateTopBanner();return}offlineJobTimer=setTimeout(()=>pollOfflineJob(id),2500)}catch(e){if(status)status.innerHTML=\'<span class="danger">Could not read offline job status: \'+esc(e)+\'</span>\'}}\nfunction offlineBasemapEntry(m){return {id:\'offline_\'+m.id,label:\'Offline · \'+(m.name||m.filename||\'Map Pack\'),group:\'Offline Maps\',type:\'mbtiles\',url:\'/api/tak-map/offline-tile/\'+encodeURIComponent(m.id)+\'/{z}/{x}/{y}.png\',attribution:m.attribution||\'Offline MBTiles\',minZoom:m.min_zoom||0,maxZoom:m.max_zoom||19,format:m.format||\'\'}}function applyOfflineBasemaps(){if(!config)return;config.basemaps=(config.basemaps||[]).filter(b=>String(b.group||\'\')!==\'Offline Maps\');for(const m of offlineMaps||[]){config.basemaps.push(offlineBasemapEntry(m))}}async function refreshOfflineMaps(render=true){try{const r=await fetch(\'/api/tak-map/offline-maps\',{cache:\'no-store\'});const ct=(r.headers.get(\'content-type\')||\'\').toLowerCase();if(!r.ok)throw new Error(\'HTTP \'+r.status);if(!ct.includes(\'application/json\'))throw new Error(\'Offline Maps API returned non-JSON\');const j=await r.json();offlineMaps=j.maps||[];applyOfflineBasemaps();if(render){renderOfflineMapRows();renderBasemaps()}}catch(e){const box=document.getElementById(\'offlineMapRows\');if(box)box.innerHTML=\'<div class="danger">Could not load offline maps: \'+esc(e)+\'</div>\'}}async function uploadOfflineMaps(){const inp=document.getElementById(\'offlineMapInput\');if(!inp||!inp.files||!inp.files.length){alert(\'Choose one or more .mbtiles files first.\');return}const fd=new FormData();for(const f of inp.files)fd.append(\'files\',f,f.name);const box=document.getElementById(\'offlineMapRows\');if(box)box.innerHTML=\'<div class="muted">Importing offline map pack...</div>\';try{const r=await fetch(\'/api/tak-map/offline-upload\',{method:\'POST\',body:fd});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));inp.value=\'\';offlineMaps=j.maps||[];applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps()}catch(e){if(box)box.innerHTML=\'<div class="danger">Offline map import failed: \'+esc(e)+\'</div>\'}}async function deleteOfflineMap(id){if(!confirm(\'Delete this offline map pack from the TAK server?\'))return;try{const r=await fetch(\'/api/tak-map/offline-delete\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({id})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));offlineMaps=j.maps||[];applyOfflineBasemaps();if(activeBasemap===\'offline_\'+id){setBasemap(config.default_basemap||\'esri_topo\')}renderOfflineMapRows();renderBasemaps()}catch(e){alert(\'Delete failed: \'+e)}}async function ensureOfflinePackage(id){try{const r=await fetch(\'/api/tak-map/offline-eud-package\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({id})});const j=await r.json();if(j.maps){offlineMaps=j.maps;applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps()}return j}catch(e){return {ok:false,error:String(e)}}}\nfunction titleCaseStatus(s){return String(s||\'\').toLowerCase().replace(/\\b\\w/g,c=>c.toUpperCase())}function renderOfflineMapRows(){const box=document.getElementById(\'offlineMapRows\');if(!box)return;const maps=offlineMaps||[];let html=`<div class="subgroup-title offline-packs-title"><span>Offline Map Packs</span><span class="chip">${maps.length}</span></div>`;if(!maps.length){box.innerHTML=html+\'<div class="muted">No offline map packs yet. Download a pack from the current basemap or import MBTiles.</div>\';return}html+=maps.map(m=>{const size=m.size_bytes?((m.size_bytes/1048576).toFixed(m.size_bytes>104857600?0:1)+\' MB\'):\'unknown size\';const zoom=(m.min_zoom!=null&&m.max_zoom!=null)?`z${m.min_zoom}–z${m.max_zoom}`:\'zoom unknown\';const fmt=(m.format||\'format unknown\').toUpperCase();const req=Number(m.requested_tile_count||m.tile_count||0);const got=Number(m.tile_count||0);const failed=Number(m.failed_tile_count||0);const remaining=Number(m.remaining_tile_count!=null?m.remaining_tile_count:Math.max(0,req-got));const rawStatus=m.partial||m.resume_available?`Partial · ${got}/${req||got} Tiles · ${remaining} Remaining · ${failed} Failed`:`Complete · ${got} Tiles${failed?` · ${failed} Failed`:\'\'}`;const status=titleCaseStatus(rawStatus);const statusChip=(m.partial||m.resume_available)?\'<span class="chip offline-status-chip">Partial</span>\':\'<span class="chip good offline-status-chip">Complete</span>\';const resume=(m.resume_available||m.partial)?`<button class="layer-button" onclick="resumeOfflineMap(\'${esc(m.id)}\')">Resume Download</button>`:\'\';return `<div class="offline-card"><div class="offline-card-title"><b>${esc(m.name||m.filename||\'Offline map\')}</b>${statusChip}</div><small>${esc(fmt)} · ${esc(zoom)} · ${esc(size)}<br>${esc(status)}${m.source_label?\' · \'+esc(m.source_label):\'\'}</small><div class="row"><button class="layer-button" onclick="setBasemap(\'offline_${esc(m.id)}\')">Apply</button>${resume}<button class="layer-button" onclick="openSendOfflineMap(\'${esc(m.id)}\')">Send</button><button class="layer-button" onclick="deleteOfflineMap(\'${esc(m.id)}\')">Delete</button></div></div>`}).join(\'\');box.innerHTML=html}\nasync function apiJsonResponse(r){\n  const txt=await r.text();\n  let j=null;\n  try{j=txt?JSON.parse(txt):{};}catch(e){\n    throw new Error(\'HTTP \'+r.status+\' returned non-JSON: \'+txt.slice(0,220).replace(/\\s+/g,\' \'));\n  }\n  if(!r.ok||!j.ok)throw new Error(j.error||j.message||(\'HTTP \'+r.status));\n  return j;\n}\nasync function apiJsonResponseAllowFalse(r){\n  const txt=await r.text();\n  let j=null;\n  try{j=txt?JSON.parse(txt):{};}catch(e){\n    throw new Error(\'HTTP \'+r.status+\' returned non-JSON: \'+txt.slice(0,220).replace(/\\s+/g,\' \'));\n  }\n  if(!r.ok)throw new Error(j.error||j.message||(\'HTTP \'+r.status));\n  return j;\n}\nfunction dashboardHttpsOrigin(){\n  if(location.protocol===\'https:\')return location.origin;\n  return \'https://\'+location.hostname+\':9443\';\n}\nlet sendEudTargets=[];let sendMissionTargets=[];let activeLocalSendKind=\'\';let activeLocalSendIds=[];\nfunction formatAge(seconds){seconds=Number(seconds);if(!Number.isFinite(seconds))return\'unknown\';if(seconds<60)return Math.max(0,Math.round(seconds))+\'s ago\';if(seconds<3600)return Math.round(seconds/60)+\'m ago\';return Math.round(seconds/3600)+\'h ago\'}\nfunction sendCoordLine(e){if(e.lat==null||e.lon==null)return\'Location: unavailable\';return\'at \'+Number(e.lat).toFixed(7)+\', \'+Number(e.lon).toFixed(7)+\' - \'+formatAge(e.location_age_seconds)}\nfunction onlineSendTarget(e){const st=String(e.status||\'\').toLowerCase();const age=Number(e.location_age_seconds);return st===\'online\'||(Number.isFinite(age)&&age<=180)}\nfunction validSendTarget(e){const blob=String([e.kind,e.source,e.type,e.client,e.client_label,e.callsign,e.uid].filter(Boolean).join(\' \')).toLowerCase();if(blob.includes(\'ads-b\')||blob.includes(\'adsb\')||blob.includes(\'aircraft\')||blob.includes(\'icao\')||blob.includes(\'webform\')||blob.includes(\'webform-gw\')||blob.includes(\'tak-dashboard\')||blob.includes(\'cot:\')||blob.includes(\'server_gps\'))return false;const cs=String(e.callsign||\'\').trim().toLowerCase();if(!cs||cs===\'webform\'||cs.startsWith(\'webform\')||cs.includes(\'ads-b\')||cs.includes(\'aircraft\'))return false;return true}\nfunction missionNameFromRow(m){return String(m.name||m.mission_name||m.missionName||m.uid||m.guid||\'\').trim()}\nfunction updateSendSelectedCount(){const f=document.getElementById(\'sendFooterCount\');const b=document.getElementById(\'sendConfirmBtn\');if(activeSendMode===\'live-basemap\'||activeSendMode===\'offline\'||activeSendMode===\'local-data-publish\'){const sel=document.getElementById(\'sendMissionSelect\');const mission=(sel&&sel.value)||\'\';if(f)f.textContent=mission?\'Data Sync Mission: \'+mission:\'Select a Data Sync Mission\';if(b)b.textContent=\'Publish\';return}const total=sendEudTargets.length;let sel=0;document.querySelectorAll(\'[data-send-eud]\').forEach(cb=>{if(cb.checked)sel++});if(f)f.textContent=total+\' online EUD\'+(total===1?\'\':\'s\')+\' found\';if(b)b.textContent=\'Send (\'+sel+\')\'}\nfunction sendModalBackdrop(ev){if(ev.target&&ev.target.id===\'sendModal\')closeSendModal()}\nfunction closeSendModal(){const el=document.getElementById(\'sendModal\');if(el)el.classList.remove(\'active\');activeSendMapId=\'\';activeSendBasemapId=\'\';activeSendMode=\'offline\';sendEudTargets=[];sendMissionTargets=[]}\nasync function loadSendTargets(){const rows=document.getElementById(\'sendEudRows\');const status=document.getElementById(\'sendStatus\');try{if(rows)rows.innerHTML=\'<div class="muted">Loading EUDs from OpenTAKServer...</div>\';const r=await fetch(\'/api/tak-map/euds?send=1&online=1&fresh=1&_=\'+Date.now(),{cache:\'no-store\'});const j=await apiJsonResponse(r);sendEudTargets=(j.euds||[]).filter(e=>validSendTarget(e)&&onlineSendTarget(e));if(rows){rows.innerHTML=sendEudTargets.length?sendEudTargets.map((e,i)=>`<label class="send-eud-row"><input type="checkbox" data-send-eud="${i}" onchange="updateSendSelectedCount()"><span class="send-eud-main"><b>${esc(e.callsign||\'EUD\')}</b><small>${esc(sendCoordLine(e))}</small><small>Team: ${esc(e.team||\'unknown\')}</small></span><span><span class="send-eud-client">${esc(e.client_label||e.client||\'ATAK\')}</span><br><span class="send-eud-status">${esc(e.status||\'Recent\')}</span></span></label>`).join(\'\'):\'<div class="muted">No online EUDs were detected. Confirm the EUD is connected and has reported location within the last 3 minutes.</div>\'}if(status)status.textContent=\'\';updateSendSelectedCount()}catch(e){sendEudTargets=[];if(rows)rows.innerHTML=\'<div class="danger">Could not load EUDs: \'+esc(e)+\'</div>\';if(status)status.textContent=\'\';updateSendSelectedCount()}}\nasync function loadSendMissions(preferred){const rows=document.getElementById(\'sendEudRows\');const status=document.getElementById(\'sendStatus\');const preferredName=preferred||\'\';try{if(rows)rows.innerHTML=\'<div class="muted">Loading Data Sync Missions...</div>\';let missions=[];try{const r=await fetch(\'/api/tak-map/data-sync?_=\'+Date.now(),{cache:\'no-store\'});const j=await apiJsonResponse(r);missions=(j.missions||[]).map(m=>({name:missionNameFromRow(m),guid:m.guid||\'\',raw:m})).filter(m=>m.name)}catch(e){missions=[]}sendMissionTargets=missions;const selectedName=(preferredName&&missions.some(m=>m.name===preferredName))?preferredName:(missions[0]?.name||\'\');const opts=missions.map(m=>`<option value="${esc(m.name)}" ${m.name===selectedName?\'selected\':\'\'}>${esc(m.name)}</option>`).join(\'\');if(rows)rows.innerHTML=`<div class="send-map-summary"><b>Data Sync Mission/Feed</b><br><small>Publish this package into an existing Data Sync Mission. EUDs must have Data Sync installed and be subscribed to the selected mission/feed.</small><br>${missions.length?`<select id="sendMissionSelect" class="select" onchange="updateSendSelectedCount()">${opts}</select>`:\'<div class="danger">No Data Sync Missions found. Create or subscribe to a mission/feed in ATAK Data Sync first.</div>\'}</div>`;if(status)status.textContent=\'\';updateSendSelectedCount()}catch(e){if(rows)rows.innerHTML=\'<div class="danger">Could not load missions: \'+esc(e)+\'</div>\';if(status)status.textContent=\'\';updateSendSelectedCount()}}\nfunction selectedMissionName(){const sel=document.getElementById(\'sendMissionSelect\');return (sel&&sel.value)?sel.value:\'\'}\nfunction openSendOfflineMap(id){activeSendMode=\'offline\';activeSendMapId=id;const m=(offlineMaps||[]).find(x=>String(x.id)===String(id))||{};const modal=document.getElementById(\'sendModal\');const title=document.querySelector(\'#sendModal h3\');const name=document.getElementById(\'sendMapName\');const details=document.getElementById(\'sendMapDetails\');const status=document.getElementById(\'sendStatus\');if(title)title.textContent=\'Publish Offline Map\';if(name)name.textContent=\'Publish this offline map package to a Data Sync Mission/Feed.\';const mb=((Number(m.package_size_bytes||m.size_bytes||0))/(1024*1024));const sizeTxt=mb>0?mb.toFixed(mb>=10?1:2)+\' MB\':\'Unknown size\';const zmin=(m.min_zoom??m.minZoom??\'—\');const zmax=(m.max_zoom??m.maxZoom??\'—\');const base=m.source_label||m.source_basemap_label||m.basemap_label||m.source_basemap||m.basemap||m.source_id||\'Unknown basemap\';if(details)details.innerHTML=`<div class="send-map-summary"><b>${esc(m.name||m.filename||\'Offline map\')}</b><br>Basemap: ${esc(base)}<br>Size: ${esc(sizeTxt)}<br>Zoom levels: ${esc(zmin)}–${esc(zmax)}</div>`;if(status)status.textContent=\'\';if(modal)modal.classList.add(\'active\');loadSendMissions(\'\')}\nfunction openSendLiveBasemapSource(){activeSendMode=\'live-basemap\';activeSendMapId=\'\';activeSendBasemapId=activeBasemap;const b=basemapById(activeBasemap)||{};const modal=document.getElementById(\'sendModal\');const title=document.querySelector(\'#sendModal h3\');const name=document.getElementById(\'sendMapName\');const details=document.getElementById(\'sendMapDetails\');const status=document.getElementById(\'sendStatus\');if(title)title.textContent=\'Publish Basemap\';if(name)name.textContent=\'Publish an ATAK mapsource XML for \'+(b.label||\'current basemap\')+\' to a Data Sync Mission/Feed.\';if(details)details.innerHTML=\'\';if(status)status.textContent=\'\';if(modal)modal.classList.add(\'active\');loadSendMissions(\'\')}\nasync function pollSendStatus(sendId){const status=document.getElementById(\'sendStatus\');if(!sendId)return;let tries=0;const tick=async()=>{tries++;try{const r=await fetch(\'/api/tak-map/offline-send-status?id=\'+encodeURIComponent(sendId),{cache:\'no-store\'});const j=await apiJsonResponse(r);if(j.ok){const delivered=Number(j.delivered||0);const total=(j.targets||[]).length;if(status)status.textContent=\'Sent fileshare request. Delivered \'+delivered+\' of \'+total+\' EUD(s).\';if(total&&delivered>=total){offlineMaps=(await (await fetch(\'/api/tak-map/offline-maps\',{cache:\'no-store\'})).json()).maps||offlineMaps;renderOfflineMapRows();return}}}catch(e){}if(tries<12)setTimeout(tick,2500)};setTimeout(tick,1800)}\nasync function confirmSendOfflineMap(){const status=document.getElementById(\'sendStatus\');try{const mission=selectedMissionName();if(activeSendMode===\'local-data-publish\'){if(!mission){if(status)status.innerHTML=\'<span class="danger">Select a Data Sync Mission.</span>\';return}if(status)status.textContent=\'Publishing local data package to Data Sync Mission...\';const r=await fetch(\'/api/tak-map/local-data-mission-publish\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({ids:activeLocalSendIds,kind:activeLocalSendKind,missionName:mission,serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);if(status){const diag=j.diag_paths&&j.diag_paths.json?(\' Diagnostics: \'+j.diag_paths.json):\'\';status.textContent=(j.message||j.error||\'Local Data publish finished.\')+diag}if(j.ok){forceDataSyncSync(\'mission-publish-local-data\')}return}if(!mission){if(status)status.innerHTML=\'<span class="danger">Select a Data Sync Mission.</span>\';return}if(activeSendMode===\'live-basemap\'){if(status)status.textContent=\'Publishing basemap package to Data Sync Mission...\';const r=await fetch(\'/api/tak-map/live-basemap-source-mission-publish\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({basemap_id:activeSendBasemapId,missionName:mission,dashboardOrigin:dashboardHttpsOrigin(),serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);if(status){const diag=j.diag_paths&&j.diag_paths.json?(\' Diagnostics: \'+j.diag_paths.json):\'\';status.textContent=(j.message||j.error||\'Mission publish finished.\')+diag}if(j.ok){forceDataSyncSync(\'mission-publish-basemap\')}return}if(!activeSendMapId)return;if(status)status.textContent=\'Publishing offline map package to Data Sync Mission...\';const r=await fetch(\'/api/tak-map/offline-mission-publish\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({id:activeSendMapId,missionName:mission,serverHost:location.hostname})});const j=await apiJsonResponseAllowFalse(r);offlineMaps=j.maps||offlineMaps;applyOfflineBasemaps();renderOfflineMapRows();renderBasemaps();if(status){const diag=j.diag_paths&&j.diag_paths.json?(\' Diagnostics: \'+j.diag_paths.json):\'\';status.textContent=(j.message||j.error||\'Mission publish finished.\')+diag}if(j.ok){forceDataSyncSync(\'mission-publish-offline\')}}catch(e){if(status)status.innerHTML=\'<span class="danger">Publish failed: \'+esc(e)+\'</span>\'}}\nfunction openLocalDataSend(kind,ids){activeSendMode=\'local-data\';activeLocalSendKind=kind;activeLocalSendIds=ids.slice();const modal=document.getElementById(\'sendModal\');const title=document.querySelector(\'#sendModal h3\');const name=document.getElementById(\'sendMapName\');const details=document.getElementById(\'sendMapDetails\');const status=document.getElementById(\'sendStatus\');if(title)title.textContent=\'Send Local Data\';if(name)name.textContent=\'Select EUDs to receive \'+ids.length+\' \'+kind+\' item(s).\';if(details)details.innerHTML=\'<div class="send-map-summary">Type: \'+esc(kind)+\'<br>Selected: \'+esc(ids.length)+\'</div>\';if(status)status.textContent=\'\';if(modal)modal.classList.add(\'active\');loadSendTargets()}\nfunction localDataKindForFeature(f){const s=String(f?.kind||f?.geometry||f?.geometry_type||f?.type||\'\').toLowerCase();if(s.includes(\'route\')||s.includes(\'track\')||s.includes(\'linestring\')||s.includes(\'line string\'))return\'routes\';if(s.includes(\'polygon\')||s.includes(\'shape\')||s.includes(\'area\')||s.includes(\'rectangle\')||s.includes(\'ellipse\')||s.includes(\'circle\'))return\'shapes\';return\'points\'}function localDataSets(){const sets={routes:[],points:[],shapes:[]};try{for(const f of importedFeatures()){const id=String(f._local_id||f.id||f.uid||f.name||(\'local-\'+Math.random())).trim();const kind=localDataKindForFeature(f);const item={id,name:String(f.name||f.callsign||f.title||f.uid||id),source:String(f.import_name||f.source||\'Imported\'),shown:state.local.hidden[id]?false:true,feature:f};sets[kind].push(item)}}catch(e){try{console.warn(\'localDataSets failed\',e)}catch(_){}}return sets}function selectedLocal(kind){try{return Object.keys(state.local[kind]||{}).filter(id=>!!state.local[kind][id])}catch(e){return[]}}function localTypeLabel(kind,count){const base={points:\'point\',routes:\'route\',shapes:\'shape\'}[kind]||\'item\';return count===1?base:base+\'s\'}function localSelectedLabel(kind,count){return count+\' \'+localTypeLabel(kind,count)+\' selected\'}function toggleLocalSection(kind){try{state.localCollapsed[kind]=!state.localCollapsed[kind];saveTakMapUiPrefs();renderLocalDataRows()}catch(e){try{console.warn(\'toggleLocalSection failed\',e)}catch(_){}}}function unselectLocalSection(kind,ev){try{if(ev)ev.stopPropagation();state.local[kind]={};renderLocalDataRows()}catch(e){}}function toggleLocalItem(kind,id,on){try{state.local[kind]=state.local[kind]||{};state.local[kind][id]=!!on;renderLocalDataRows()}catch(e){try{console.warn(\'toggleLocalItem failed\',e)}catch(_){}}}function localDataFeatureById(id){try{return importedFeatures().find(f=>String(f._local_id||f.id||f.uid||f.name)===String(id))||null}catch(e){return null}}function localDataExportFilename(kind,feats){try{let base=\'tak-map-local-\'+kind;if((feats||[]).length===1){const f=feats[0]||{};base=String(f.name||f.callsign||f.title||f.uid||base)}else if((feats||[]).length>1){base=\'tak-map-local-\'+localTypeLabel(kind,(feats||[]).length)+\'-\'+(feats||[]).length+\'-items\'}base=base.replace(/[\\/:*?"<>|]+/g,\'-\').replace(/\\n+/g,\' \').trim();base=base.replace(/\\.(kml|kmz|gpx|geojson|json|zip)$/i,\'\').trim();base=base.replace(/[. ]+$/,\'\')||(\'tak-map-local-\'+kind);return base+\'.geojson\'}catch(e){return \'tak-map-local-\'+kind+\'.geojson\'}}function downloadLocalData(kind,ids){try{const feats=(ids||[]).map(localDataFeatureById).filter(Boolean);const gj={type:\'FeatureCollection\',features:feats.map(f=>{let geom=null;const coords=Array.isArray(f.coords)?f.coords:null;if(coords&&coords.length){const k=localDataKindForFeature(f);if(k===\'points\')geom={type:\'Point\',coordinates:[Number(f.lon),Number(f.lat)]};else if(k===\'routes\')geom={type:\'LineString\',coordinates:coords.map(c=>[Number(c[1]??c.lon),Number(c[0]??c.lat)]).filter(c=>Number.isFinite(c[0])&&Number.isFinite(c[1]))};else geom={type:\'Polygon\',coordinates:[coords.map(c=>[Number(c[1]??c.lon),Number(c[0]??c.lat)]).filter(c=>Number.isFinite(c[0])&&Number.isFinite(c[1]))]}}else if(f.lat!=null&&f.lon!=null){geom={type:\'Point\',coordinates:[Number(f.lon),Number(f.lat)]}}return{type:\'Feature\',geometry:geom,properties:{name:f.name||f.callsign||f.title||\'\',source:f.import_name||f.source||\'\',kind:kind}}}).filter(x=>x.geometry)};if(!gj.features.length){alert(\'No exportable geometry found for the selected item(s).\');return}const blob=new Blob([JSON.stringify(gj,null,2)],{type:\'application/geo+json\'});const a=document.createElement(\'a\');a.href=URL.createObjectURL(blob);a.download=localDataExportFilename(kind,feats);document.body.appendChild(a);a.click();setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove()},500)}catch(e){alert(\'Export failed: \'+e)}}function localDataPublishTitle(kind,ids){const map={points:\'Point\',routes:\'Route\',shapes:\'Shape\'};const one=(ids||[]).length===1;return \'Publish \'+(one?(map[kind]||\'Item\'):(map[kind]||\'Item\')+\'s\')+\' to Data Sync/Mission\'}\nfunction openLocalDataPublish(kind,ids){activeSendMode=\'local-data-publish\';activeLocalSendKind=kind;activeLocalSendIds=(ids||[]).slice();const modal=document.getElementById(\'sendModal\');const title=document.querySelector(\'#sendModal h3\');const name=document.getElementById(\'sendMapName\');const details=document.getElementById(\'sendMapDetails\');const status=document.getElementById(\'sendStatus\');if(title)title.textContent=localDataPublishTitle(kind,ids);if(name)name.textContent=\'Publish \'+ids.length+\' selected local \'+kind+\' item(s) into a Data Sync Mission.\';if(details)details.innerHTML=\'<div class="send-map-summary">Type: \'+esc(kind)+\'<br>Selected: \'+esc(ids.length)+\'<br><small>This creates a TAK Mission Package containing KML and GeoJSON for the selected local item(s).</small></div>\';if(status)status.textContent=\'\';if(modal)modal.classList.add(\'active\');loadSendMissions()}\nfunction centerLocalItem(kind,id,ev){if(ev)ev.stopPropagation();const f=localDataFeatureById(id);const cen=objectCenter(f);if(!f||!cen){alert(\'No valid coordinates found for this local item.\');return}try{map.panTo(cen,{animate:true});if(f.__layer){setTimeout(()=>{try{f.__layer.openPopup()}catch(e){}},160)}}catch(e){try{console.warn(\'centerLocalItem failed\',e)}catch(_){}}}\nfunction centerSelectedLocal(kind,ids){const pts=[];for(const id of (ids||[])){const f=localDataFeatureById(id);const cen=objectCenter(f);if(cen)pts.push(cen)}if(!pts.length){alert(\'No valid coordinates found for the selected item(s).\');return}try{if(pts.length===1)map.panTo(pts[0],{animate:true});else map.fitBounds(L.latLngBounds(pts).pad(.22))}catch(e){try{console.warn(\'centerSelectedLocal failed\',e)}catch(_){}}}\nasync function localDataAction(kind,action){const ids=selectedLocal(kind);if(!ids.length){alert(\'Select one or more \'+localTypeLabel(kind,2)+\' first.\');return}if(action===\'goto\'){centerSelectedLocal(kind,ids);return}if(action===\'hide\'||action===\'show\'){for(const id of ids){state.local.hidden[id]=(action===\'hide\')}renderLocalDataRows();drawImportedObjects();return}if(action===\'export\'){downloadLocalData(kind,ids);return}if(action===\'publish\'){openLocalDataPublish(kind,ids);return}if(action===\'delete\'){if(!confirm(\'Delete \'+localSelectedLabel(kind,ids.length)+\'?\'))return;try{const r=await fetch(\'/api/tak-map/local-data-delete\',{method:\'POST\',headers:{\'Content-Type\':\'application/json\'},body:JSON.stringify({ids})});const j=await r.json();if(!r.ok||!j.ok)throw new Error(j.error||(\'HTTP \'+r.status));lastImports=j.imports||lastImports;state.local[kind]={};renderLocalDataRows();drawImportedObjects();return}catch(e){alert(\'Delete failed: \'+e);return}}}\nfunction renderLocalActions(kind,items){const ids=selectedLocal(kind);if(!ids.length)return\'\';const allHidden=ids.every(id=>!!state.local.hidden[id]);const hideShow=allHidden?\'Show\':\'Hide\';return `<div class="local-actions ${kind}"><div class="local-actions-top"><span id="localActionCount_${kind}" class="muted local-selected-count">${esc(localSelectedLabel(kind,ids.length))}</span></div><div class="local-action-buttons"><button class="layer-button" onclick="localDataAction(\'${kind}\',\'goto\')">Go To</button><button class="layer-button" onclick="localDataAction(\'${kind}\',\'publish\')">Publish</button><button class="layer-button" onclick="localDataAction(\'${kind}\',\'export\')">Export</button><button class="layer-button" onclick="localDataAction(\'${kind}\',\'${hideShow.toLowerCase()}\')">${hideShow}</button><button class="layer-button" onclick="localDataAction(\'${kind}\',\'delete\')">Delete</button></div></div>`}\nfunction renderLocalSection(kind,title,items){const collapsed=!!state.localCollapsed[kind];let html=`<div class="local-section ${collapsed?\'collapsed\':\'\'}"><div class="subgroup-title local-section-title" onclick="toggleLocalSection(\'${kind}\')"><span class="subgroup-label"><span class="toggle">${collapsed?\'›\':\'⌄\'}</span>${esc(title)}</span><span class="chip">${items.length}</span><button class="layer-button unselect-local-btn" onclick="unselectLocalSection(\'${kind}\',event)">Unselect All</button></div><div class="local-data-list">`;html+=items.length?items.slice(0,120).map(it=>{const checked=state.local[kind][it.id]?\'checked\':\'\';const vis=it.shown===false?\'hidden\':\'shown\';const colorCtl=\'\';const coords=(kind===\'points\'&&it.lat!=null&&it.lon!=null)?formatCoords(it.lat,it.lon):\'\';const meta=coords||((it.source||\'Local Data\')+\' · \'+vis);return`<div class="local-data-row ${checked?\'selected-local\':\'\'} ${vis===\'hidden\'?\'hidden-local\':\'\'}"><label class="local-data-main"><input type="checkbox" ${checked} onchange="toggleLocalItem(\'${kind}\',\'${esc(it.id)}\',this.checked)"><span><b>${esc(it.name)}</b><small>${esc(meta)}</small></span></label><button class="layer-button local-goto-btn" onclick="centerLocalItem(\'${kind}\',\'${esc(it.id)}\',event)">Go To</button>${colorCtl}</div>`}).join(\'\'):\'<div class="muted" style="padding:8px">No local \'+esc(title.toLowerCase())+\' yet.</div>\';html+=`</div>${renderLocalActions(kind,items)}</div>`;return html}function triggerLocalAdd(kind){const inp=document.getElementById(\'importFileInput\');if(inp){inp.dataset.localKind=kind;inp.value=\'\';inp.click();return}alert(\'Import control is not available.\')}async function refreshLocalData(){try{renderLocalDataRows();return {ok:true}}catch(e){renderLocalDataRows(String(e));return {ok:false,error:String(e)}}}\nfunction renderLocalDataRows(err){const box=document.getElementById(\'localDataRows\');if(!box)return;const sets=localDataSets();const total=sets.routes.length+sets.points.length+sets.shapes.length;const chip=document.getElementById(\'localDataCount\');if(chip)chip.textContent=String(total);let html=\'\';if(err)html+=\'<div class="danger">\'+esc(err)+\'</div>\';html+=`<div class="local-add-grid"><button class="layer-button" onclick="triggerLocalAdd(\'points\')">+ Add Point</button><button class="layer-button" onclick="triggerLocalAdd(\'routes\')">+ Add Route</button><button class="layer-button" onclick="triggerLocalAdd(\'shapes\')">+ Add Shape</button></div>`;html+=renderLocalSection(\'points\',\'Points\',sets.points);html+=renderLocalSection(\'routes\',\'Routes\',sets.routes);html+=renderLocalSection(\'shapes\',\'Shapes\',sets.shapes);box.innerHTML=html}function renderRouteRows(){renderLocalDataRows()}function toggleRoute(idx,on){const r=(lastRoutes||[])[idx];if(!r)return;state.routes[r.path]=on;if(!on&&routeLayers[r.path]){map.removeLayer(routeLayers[r.path]);delete routeLayers[r.path];return}if(on){alert(\'Route file listing is active. Direct overlay rendering will be wired to Local Data actions.\')}}\nlet lastAircraft=[];function refreshAdsbIntervalSeconds(){const s=(window.lastAdsbSettings||config?.adsb?.settings||{});const n=Number(s.update_interval_seconds||s.update_interval||5);return Number.isFinite(n)?Math.max(1,Math.min(300,Math.round(n))):5}function scheduleAdsbRefreshTimer(){try{if(window.adsbRefreshTimer)clearInterval(window.adsbRefreshTimer);const sec=refreshAdsbIntervalSeconds();window.adsbRefreshTimer=setInterval(()=>{if(state.live.adsb_aircraft)refreshAdsb()},sec*1000)}catch(e){}}async function refreshAdsb(){if(state.live.adsb_aircraft===false)return;try{const r=await fetch(\'/api/tak-map/adsb\',{cache:\'no-store\'});const j=await r.json();window.lastAdsbSettings=j.settings||window.lastAdsbSettings||config?.adsb?.settings||{};document.getElementById(\'adsbStatus\').textContent=(j.aircraft||[]).length+\' active\';if(lastBanner){lastBanner.adsb_aircraft=(j.aircraft||[]).length;renderTopBanner(lastBanner)}lastAircraft=j.aircraft||[];drawAircraft(lastAircraft)}catch(e){document.getElementById(\'adsbStatus\').textContent=\'error\'}}function aircraftIsMilitary(ac){const blob=String([ac?.type,ac?.category,ac?.uid,ac?.id,ac?.callsign,ac?.source,ac?.description,ac?.aircraft_type].filter(Boolean).join(\' \')).toLowerCase();return blob.includes(\'a-f-a\')||blob.includes(\'military\')||blob.includes(\'mil-\')||blob.includes(\'usaf\')||blob.includes(\'usn\')||blob.includes(\'usmc\')||blob.includes(\'army\')||blob.includes(\'navy\')||blob.includes(\'afsoc\')||blob.includes(\'viper\')||blob.startsWith(\'rch\')}function aircraftIsHelicopter(ac){const blob=String([ac?.type,ac?.category,ac?.aircraft_type,ac?.description,ac?.emitter_category,ac?.uid,ac?.id,ac?.callsign,ac?.source].filter(Boolean).join(\' \')).toLowerCase();if(blob.includes(\'helicopter\')||blob.includes(\'rotor\')||blob.includes(\'rotary\')||blob.includes(\'gyro\')||blob.includes(\'helo\'))return true;if(/\x08(a7|b7|h1|h2|h3|h4|h5|h6|h7|h8|h9)\x08/.test(blob))return true;if(/\x08(r22|r44|r66|h60|uh60|mh60|ch47|ah64|as50|ec35|ec45|b407|b412|s76|s92|bell|robinson)\x08/.test(blob))return true;return false}function aircraftIsStale(ac){const s=Number(ac?.seen_seconds);const stale=Number((window.lastAdsbSettings||{}).stale_seconds||refreshAdsbIntervalSeconds()+1);return Number.isFinite(s)&&s>stale}function aircraftIcon(ac){const label=esc(ac.callsign||ac.id||\'\');const military=aircraftIsMilitary(ac);const heli=aircraftIsHelicopter(ac);const stale=aircraftIsStale(ac);const selected=ac.id===selectedAircraftId?\' selected\':\'\';const deg=Number.isFinite(Number(ac.track_deg))?Number(ac.track_deg):0;const color=stale?\'#87909a\':(military?\'#2386ff\':\'#8bd742\');const cls=(military?\'aircraft-military\':\'aircraft-civil\')+(heli?\' aircraft-rotor\':\' aircraft-fixed\')+(stale?\' aircraft-stale\':\'\');const ring=military?`<circle cx="22" cy="22" r="16.4" fill="rgba(5,8,12,.86)" stroke="currentColor" stroke-width="4.2" stroke-dasharray="9 4"/>`:`<circle cx="22" cy="22" r="15.8" fill="rgba(5,8,12,.84)" stroke="currentColor" stroke-width="2.8"/><circle cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".45"/>`;const glyph=heli?`<path d="M5 14 H39" stroke="#f5f7f9" stroke-width="3.4" stroke-linecap="round"/><path d="M22 6 V28" stroke="#f5f7f9" stroke-width="2.7" stroke-linecap="round"/><ellipse cx="22" cy="25" rx="9.5" ry="5.4" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".7"/><path d="M12 34 H32 M22 30 V37" stroke="#f5f7f9" stroke-width="2.35" stroke-linecap="round"/>`:(military?`<path d="M22 5 L27 23 L38 29 L27 30 L23 41 L21 41 L17 30 L6 29 L17 23 Z" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".75"/><path d="M22 30 L14 39 M22 30 L30 39" stroke="#f5f7f9" stroke-width="2.2" stroke-linecap="round"/>`:`<path d="M22 6 L25 22 L36 27 L25 29 L22 40 L19 29 L8 27 L19 22 Z" fill="#f5f7f9" stroke="rgba(0,0,0,.70)" stroke-width=".7"/><path d="M22 30 L16 39 M22 30 L28 39" stroke="#f5f7f9" stroke-width="2.05" stroke-linecap="round"/>`);return L.divIcon({className:\'\',html:`<div class="aircraft-wrap ${cls}" style="color:${color}"><svg class="aircraft-glyph${selected}" width="40" height="50" viewBox="0 0 44 54">${ring}<g transform="rotate(${deg} 22 22)"><path d="M22 0 L27 10 L22 8 L17 10 Z" fill="currentColor"/>${glyph}</g><circle cx="22" cy="50" r="3.2" fill="currentColor"/></svg><div class="aircraft-label">${label}</div></div>`,iconSize:[96,60],iconAnchor:[48,25]})}function adsbCourse(ac){const keys=[\'track_deg\',\'track\',\'course\',\'course_deg\',\'cog\',\'true_track\',\'nav_heading\'];for(const k of keys){const v=Number(ac&&ac[k]);if(Number.isFinite(v))return {deg:((v%360)+360)%360,source:k,headingOnly:false}}const h=Number(ac&&ac.heading_deg);if(Number.isFinite(h))return {deg:((h%360)+360)%360,source:\'heading_deg\',headingOnly:true};return {deg:null,source:\'none\',headingOnly:false}}function adsbGroundSpeed(ac){for(const k of [\'groundspeed_kt\',\'gs_kt\',\'speed_kt\',\'ground_speed\',\'gs\']){const v=Number(ac&&ac[k]);if(Number.isFinite(v)&&v>0)return {kt:v,source:k}}return {kt:0,source:\'none\'}}function adsbPopupHtml(ac){const crs=adsbCourse(ac);const gs=adsbGroundSpeed(ac);return `<div class="feature-popup adsb-popup"><h3>${esc(ac.callsign||ac.id||\'ADS-B aircraft\')}</h3><div class="kvp"><b>ICAO/UID</b><span>${esc(ac.id||\'—\')}</span><b>Class</b><span>${aircraftIsMilitary(ac)?\'Friendly military\':\'Civil / commercial\'} · ${aircraftIsHelicopter(ac)?\'Helicopter\':\'Airplane\'}</span><b>Altitude</b><span>${esc(ac.altitude_ft??\'—\')} ft</span><b>Groundspeed</b><span>${esc(gs.kt||\'—\')} kt</span><b>Track/Course</b><span>${crs.deg==null?\'No track/course\':esc(Math.round(crs.deg)+\'° from \'+crs.source+(crs.headingOnly?\' (heading only)\':\'\'))}</span><b>Coordinates</b><span>${esc(formatCoords(ac.lat,ac.lon))}</span><b>Source</b><span>${esc(ac.source||\'ADS-B\')}</span><b>Updated</b><span>${esc(ac.updated||\'—\')}</span></div></div>`}function drawAircraft(items){if(terrain3DActive){return}aircraftLayer.clearLayers();clearSearchSource(\'aircraft\');for(const ac of items){if(ac.lat==null||ac.lon==null)continue;const m=L.marker([ac.lat,ac.lon],{icon:aircraftIcon(ac)}).addTo(aircraftLayer);m.bindPopup(adsbPopupHtml(ac));m.on(\'click\',()=>{selectedAircraftId=ac.id;setTimeout(()=>{try{m.openPopup()}catch(e){}},0)});addSearchItem(\'aircraft\',\'ADS-B \'+(aircraftIsMilitary(ac)?\'military\':\'civil\'),ac.callsign||ac.id,ac.lat,ac.lon,m,ac)}handleMapSearch()}function eudIconHtml(){return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="30" height="40" viewBox="0 0 30 40"><rect x="6" y="3" width="18" height="30" rx="3.5" fill="rgba(10,16,22,.90)" stroke="#2386ff" stroke-width="2.6"/><rect x="10" y="8" width="10" height="18" rx="1.5" fill="rgba(35,134,255,.08)" stroke="rgba(35,134,255,.35)" stroke-width="1"/><circle cx="15" cy="29" r="1.6" fill="#2386ff"/><circle cx="15" cy="37" r="3" fill="#2386ff"/></svg></div>`}function webformIconHtml(){return `<div class="tak-icon-wrap"><svg class="tak-icon-svg" width="34" height="42" viewBox="0 0 34 42"><rect x="7" y="8" width="20" height="25" rx="3" fill="rgba(14,10,22,.90)" stroke="#b56cff" stroke-width="2.7"/><path d="M13 8 V5 H21 V8" fill="none" stroke="#b56cff" stroke-width="2.7" stroke-linecap="round"/><path d="M12 16 l2 2 5-5 M12 22 l2 2 5-5 M12 28 l2 2 5-5" fill="none" stroke="#b56cff" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/><circle cx="17" cy="39" r="3" fill="#b56cff"/></svg></div>`}function serverGpsIconHtml(){return `<d