ion saveCustomBasemaps(list){try{localStorage.setItem(\'takMapCustomBasemaps\',JSON.stringify(list||[]))}catch(e){}}\nfunction applyCustomBasemaps(){try{if(!config)return;const built=(config.basemaps||[]).filter(b=>!String(b.id||\'\').startsWith(\'custom_xml_\'));const custom=loadCustomBasemaps();config.basemaps=built.concat(custom)}catch(e){}}\nfunction parseBasemapXmlText(txt,nameHint){const doc=new DOMParser().parseFromString(String(txt||\'\'),\'text/xml\');const textOf=(tag)=>{const n=doc.getElementsByTagName(tag)[0];return n?n.textContent.trim():\'\'};let label=textOf(\'name\')||textOf(\'title\')||nameHint||\'Custom basemap\';let url=textOf(\'url\')||textOf(\'URL\')||textOf(\'serverUrl\')||textOf(\'tileUrl\')||\'\';if(!url){const all=[...doc.getElementsByTagName(\'*\')].map(n=>String(n.textContent||\'\').trim()).find(v=>/^https?:\\/\\//i.test(v));url=all||\'\'}if(url&&!/[{]z[}].*[{]y[}].*[{]x[}]|\\/tile\\//i.test(url)){url=url.replace(/\\/$/,\'\')+\'/tile/{z}/{y}/{x}\'}if(!url)throw new Error(\'No tile URL found in XML.\');return {id:\'custom_xml_\'+Date.now(),label,group:\'Custom\',url,minZoom:0,maxZoom:19,attribution:label}}\nfunction renderCustomBasemapStatus(){const el=document.getElementById(\'customBasemapStatus\');if(el)el.textContent=customBasemapImportStatus||\'\'}\nfunction triggerBasemapXmlImport(){const inp=document.getElementById(\'basemapXmlInput\');if(inp){inp.value=\'\';inp.click()}}\nasync function importBasemapXmlFiles(){const inp=document.getElementById(\'basemapXmlInput\');const files=[...(inp?.files||[])];if(!files.length)return;const list=loadCustomBasemaps();let added=0;for(const file of files){try{const txt=await file.text();const b=parseBasemapXmlText(txt,file.name.replace(/\\.[^.]+$/,\'\'));list.push(b);added++}catch(e){customBasemapImportStatus=\'Import failed for \'+file.name+\': \'+e.message}}saveCustomBasemaps(list);applyCustomBasemaps();renderBasemaps();customBasemapImportStatus=added?(\'Added \'+added+\' custom basemap\'+(added===1?\'\':\'s\')+\'.\'):customBasemapImportStatus;renderCustomBasemapStatus()}\nfunction clearCustomBasemaps(){if(!confirm(\'Remove all custom basemaps from this browser?\'))return;saveCustomBasemaps([]);applyCustomBasemaps();renderBasemaps();customBasemapImportStatus=\'Custom basemaps cleared.\';renderCustomBasemapStatus()}\nfunction renderBasemaps(){const sel=document.getElementById(\'basemapSelect\');if(!sel)return;const items=(config.basemaps||[]).filter(b=>visibleText(b.label+\' \'+(b.group||\'\')));const groups={};for(const b of items){const g=b.group||\'Basemaps\';(groups[g]=groups[g]||[]).push(b)}const order=[\'Offline Maps\',\'Imagery\',\'Topo / Terrain\',\'Street / Reference\',\'Basemaps\'];let html=\'\';for(const g of [...order,...Object.keys(groups).filter(x=>!order.includes(x)).sort()]){const arr=groups[g];if(!arr||!arr.length)continue;html+=`<optgroup label="${esc(g)}">`;for(const b of arr){html+=`<option value="${esc(b.id)}" ${b.id===activeBasemap?\'selected\':\'\'}>${esc(basemapDisplayLabel(b))}</option>`}html+=\'</optgroup>\'}sel.innerHTML=html||\'<option>No basemaps match</option>\';renderCustomBasemapStatus()}function reliefSource(){return (config?.basemaps||[]).find(b=>b.id===\'usgs_shaded_relief\')||{url:\'https://basemap.nationalmap.gov/arcgis/rest/services/USGSShadedReliefOnly/MapServer/tile/{z}/{y}/{x}\',attribution:\'USGS 3DEP / The National Map\',minZoom:0,maxZoom:16}}function setReliefOpacity(v){const op=Math.max(0,Math.min(100,Number(v||35)))/100;if(reliefLayer)reliefLayer.setOpacity(op)}function refreshReliefOverlay(){const cb=document.getElementById(\'reliefOverlayToggle\');if(cb&&cb.checked)toggleReliefOverlay(true)}function toggleReliefOverlay(on){if(!map)return;if(reliefLayer){try{map.removeLayer(reliefLayer)}catch(e){}reliefLayer=null}if(!on)return;const src=reliefSource();const op=Math.max(0,Math.min(100,Number(document.getElementById(\'reliefOpacity\')?.value||35)))/100;reliefLayer=L.tileLayer(src.url,{minZoom:src.minZoom||0,maxZoom