  function norm(a){a=Object.assign({},a||{});try{if(a.category_raw==null&&a.category&&/^A\d$/i.test(String(a.category)))a.category_raw=a.category;a.is_helo=!!isHelicopter(a);a.is_rotor=a.is_helo;a.aircraft_display_type=a.is_helo?'Helicopter':'Airplane';a.category=classKey(a.category,a)}catch(_){}return a}
