    for(let i=0;i<kids.length-1;i++){if(kids[i].tagName==='B' && (kids[i].textContent||'').trim().toLowerCase()===label.toLowerCase()){b=kids[i];s=kids[i+1];break;}}
    if(b&&s){s.textContent=value||'—';return;}
    b=document.createElement('b');b.textContent=label;s=document.createElement('span');s.textContent=value||'—';
    if(afterLabel){const idx=kids.findIndex(x=>x.tagName==='B'&&(x.textContent||'').trim().toLowerCase()===afterLabel.toLowerCase());if(idx>=0&&kids[idx+1]){kids[idx+1].after(b,s);return;}}
    kvp.appendChild(b);kvp.appendChild(s);
  }
  function removeNativeClose(el){try{qa('.leaflet-popup-close-button,.adsb-v284-close,.adsb-v283-close',el).forEach(n=>n.remove())}catch(_){ }}
  function trackButtonHtml(id){const active=trackedId&&id&&trackedId===id;return `<div class="adsb-track-row"><button type="button" class="layer-button adsb-track-btn${active?' active':''}" data-adsb-track-id="${esc(id)}" onclick="window.toggleAdsbTrack&&window.toggleAdsbTrack('${esc(id)}');return false;"><span class="adsb-track-light ${active?'active':''}"></span><span>Track</span></button></div>`}
  function patchPopup(popup){
    try{
      const el=popup&&popup.getElement&&popup.getElement(); if(!el||!q('.adsb-popup',el))return;
      removeNativeClose(el);
      const a=findAircraftByPopup(popup);
