_v271_js = r'''
/* v271 ADS-B client-only Airplanes.live fetch and stable status footer */
(function(){
  const V='v301';
  const field=id=>document.getElementById(id);
  const esc=s=>String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  const clamp=(v,min,max,def)=>{v=Number(v);return Number.isFinite(v)?Math.max(min,Math.min(max,v)):def};
  const staleSeconds=60;
  let lastClientFetchMs=0;
  function settings(){return window.lastAdsbSettings||((typeof config!=='undefined'&&config.adsb&&config.adsb.settings)||{})||{}}
  function disabled(){try{return localStorage.getItem('takmap.adsb.localDisabled')==='1'||(typeof state!=='undefined'&&state.live&&state.live.adsb_aircraft===false)}catch(_){return false}}
  function setStatus(msg,ok){const box=field('adsbSettingsStatus');if(!box)return;box.textContent=String(msg||'');box.classList.toggle('adsb-status-ok',ok===true);box.classList.toggle('adsb-status-bad',ok===false)}
  function filterState(){return {civil:field('adsbFilterCivil')?.checked!==false,military:field('adsbFilterMilitary')?.checked!==false,govt:field('adsbFilterGovt')?.checked!==false,unknown:field('adsbFilterUnknown')?.checked!==false}}
  function categoryOf(ac){let c=String(ac&&(ac.category_class||ac.aircraft_class||ac.category)||'').toLowerCase();if(c==='mil')c='military';if(c==='government')c='govt';if(!['civil','military','govt','unknown'].includes(c)){if(ac&&ac.is_military)c='military';else if(ac&&ac.is_govt)c='govt';else c='civil'}return c}
  function filtered(items){const f=filterState();return (items||window.lastAircraft||[]).filter(ac=>f[categoryOf(ac)]!==false)}
  function haversineMiles(lat1,lon1,lat2,lon2){try{const R=3958.7613, toRad=x=>Number(x)*Math.PI/180;const p1=toRad(lat1),p2=toRad(lat2),dp=toRad(Number(lat2)-Number(lat1)),dl=toRad(Number(lon2)-Number(lon1));const a=Math.sin(dp/2)**2+Math.cos(p1)*Math.cos(p2)*Math.sin(dl/2)**2;return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a))}catch(_){return null}}
  function textBlob(item){return ['flight','callsign','r','registration','t','type','desc','description','ownOp','operator','owner','squawk','hex'].map(k=>item&&item[k]).filter(v=>v!==undefined&&v!==null).join(' ').toUpperCase()}
  function flags(item){const n=Number(item&&(item.dbFlags??item.dbflags??0));return Number.isFinite(n)?n:0}
  function isHelo(item){const blob=textBlob(item);const t=String(item&&(item.t||item.type||item.desc)||'').toUpperCase();const rotor=['HELICOPTER','ROTORCRAFT','GYROPLANE','HELO','HELI','ROTOR','B407','B412','B429','B206','B205','B212','B222','B230','B234','R22','R44','R66','S76','S92','EC35','EC45','H135','H145','AS50','AS55','AS65','A109','A119','A139','A169','A189','UH60','MH60','HH60','CH47','AH64'];return /\b(H|HEL|HELI|HELO|ROTOR)\b/.test(blob)||t.startsWith('H')||t.startsWith('R')||rotor.some(x=>blob.includes(x))}
  function category(item){if(flags(item)&1)return 'military';const blob=textBlob(item);const gov=['POLICE','SHERIFF','STATE POLICE','HIGHWAY PATROL','CHP','CAL FIRE','CALFIRE','FIRE','FIRE DEPT','FIRE DEPARTMENT','RESCUE','SEARCH AND RESCUE','PUBLIC SAFETY','LAW ENFORCEMENT','EMS','MEDEVAC','AIR AMBULANCE','AMBULANCE','USFS','FOREST SERVICE','BUREAU OF LAND MANAGEMENT',' BLM','NIFC','FEMA','DHS','CBP','CUSTOMS','BORDER PATROL','DEA','FBI','MARSHAL','NASA','NOAA','NPS','PARK SERVICE','COAST GUARD','USCG','LIFE FLIGHT','LIFEGUARD'];if(gov.some(x=>blob.includes(x)))return 'govt';if(!String(item?.hex||item?.flight||item?.r||item?.t||'').trim())return 'unknown';return 'civil'}
  function norm(item,center){try{if(!item||typeof item!=='object')return null;let lat=item.lat,lon=item.lon;if(lat==null||lon==null)return null;lat=Number(lat);lon=Number(lon);if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180||(Math.abs(lat)<0.000001&&Math.abs(lon)<0.000001))return null;let alt=item.alt_baro;if(String(alt).toLowerCase()==='ground')alt=0;if(alt==null)alt=item.alt_geom??item.altitude;const flight=String(item.flight||item.callsign||'').trim();const hex=String(item.hex||item.icao||'').trim().toUpperCase();const reg=String(item.r||item.registration||'').trim().toUpperCase();const id=hex||reg||flight||('aircraft-'+lat.toFixed(4)+'-'+lon.toFixed(4));const cat=category(item);let seen=item.seen_pos??item.seen;let range=null;if(center&&center.lat!=null&&center.lon!=null)range=haversineMiles(center.lat,center.lon,lat,lon);return {id,icao:hex,hex,registration:reg,callsign:flight||reg||hex||'ADS-B',flight,lat,lon,altitude_ft:alt,speed_kt:item.gs??item.speed,track_deg:item.track??item.true_heading??item.mag_heading,seen_seconds:seen,seen_pos:item.seen_pos,seen:item.seen,category:cat,category_class:cat,aircraft_class:cat,is_military:cat==='military',is_govt:cat==='govt',is_unknown:cat==='unknown',is_helo:isHelo(item),is_rotor:isHelo(item),type:item.t||item.type||'',aircraft_type:item.t||item.type||'',description:item.desc||item.description||'',dbFlags:flags(item),squawk:item.squawk||'',emergency:item.emergency||'',range_miles:Number.isFinite(range)?Math.round(range*100)/100:undefined,source:'Airplanes.live Client Direct',updated:new Date().toISOString()}}catch(_){return null}}
  function currentCenter(){let src=field('adsbCenterSource')?.value||settings().center_source||'manual';let lat=null,lon=null;if(src==='map_center'&&window.map){const c=map.getCenter();lat=Number(c.lat);lon=Number(c.lng);try{if(field('adsbCenterLat'))field('adsbCenterLat').value=lat.toFixed(6);if(field('adsbCenterLon'))field('adsbCenterLon').value=lon.toFixed(6)}catch(_){}}else{lat=Number(field('adsbCenterLat')?.value||settings().center_lat);lon=Number(field('adsbCenterLon')?.value||settings().center_lon)}if(!Number.isFinite(lat)||!Number.isFinite(lon)||lat<-90||lat>90||lon<-180||lon>180)return null;return {lat,lon}}
  function airplanesUrl(center){const r=clamp(field('adsbRadiusMiles')?.value||settings().radius_miles,1,250,5);return 'https://api.airplanes.live/v2/point/'+center.lat.toFixed(6)+'/'+center.lon.toFixed(6)+'/'+String(Math.round(r))}
  async function clientFetchJson(url){const minGap=1050;const wait=Math.max(0,minGap-(Date.now()-lastClientFetchMs));if(wait)await new Promise(r=>setTimeout(r,wait));lastClientFetchMs=Date.now();const resp=await fetch(url,{method:'GET',mode:'cors',credentials:'omit',cache:'no-store',headers:{'Accept':'application/json'}});if(!resp.ok)throw new Error('HTTP '+resp.status);return await resp.json()}
  window.refreshAdsb=async function(){
    if(disabled()){try{if(window.aircraftLayer)aircraftLayer.clearLayers();if(field('adsbStatus'))field('adsbStatus').textContent='disabled'}catch(_){}setStatus('ADS-B disabled.',true);return []}
    const center=currentCenter();
    if(!center){try{if(field('adsbStatus'))field('adsbStatus').textContent='center needed'}catch(_){}setStatus('Set ADS-B center.',false);return []}
    const url=airplanesUrl(center);
    try{
      setStatus('ADS-B: Client Direct',true);
      const data=await clientFetchJson(url);
      const byId={};
      for(const raw of (data&&data.aircraft)||[]){const ac=norm(raw,center);if(!ac)continue;try{if(ac.seen_seconds!=null&&Number(ac.seen_seconds)>staleSeconds)continue}catch(_){}const k=String(ac.id||ac.callsign||'').toLowerCase();if(!k)continue;const old=byId[k];const age=x=>{const n=Number(x&&x.seen_seconds);return Number.isFinite(n)?n:999999};if(!old||age(ac)<age(old))byId[k]=ac}
      const all=Object.values(byId).sort((a,b)=>String(a.category_class||'').localeCompare(String(b.category_class||''))||String(a.callsign||a.id||'').localeCompare(String(b.callsign||b.id||'')));
      window.lastAircraft=all;window.v270AdsbFilters=filterState();window.lastAdsbSettings=Object.assign({},settings(),{center_lat:center.lat,center_lon:center.lon,radius_miles:clamp(field('adsbRadiusMiles')?.value||settings().radius_miles,1,250,5),source_mode:'airplanes_live_client'});
      const shown=filtered(all);
      try{if(field('adsbStatus'))field('adsbStatus').textContent=shown.length+' active'}catch(_){}
      try{if(window.lastBanner){lastBanner.adsb_aircraft=shown.length;if(typeof renderTopBanner==='function')renderTopBanner(lastBanner)}}catch(_){}
      try{if(typeof window.drawAircraft==='function')window.drawAircraft(all)}catch(e){console.warn('ADS-B draw failed',e)}
      setStatus(shown.length+' aircraft · Client Direct',true);
      return shown;
    }catch(e){
      const msg=String(e&&e.message||e||'');
      try{if(field('adsbStatus'))field('adsbStatus').textContent='error'}catch(_){}
      if(msg.includes('HTTP 429'))setStatus('Airplanes.live HTTP 429.',false);
      else if(msg.startsWith('HTTP '))setStatus('Airplanes.live '+msg+'.',false);
      else setStatus('Airplanes.live client fetch failed.',false);
      return [];
    }
  };
  function stabilizeMenu(){try{
    const body=document.querySelector('.panel[data-collapse-key="adsbSettings"] .panel-body');const wrap=field('adsbV270Menu');if(!body||!wrap)return;
    Array.from(body.children).forEach(ch=>{if(ch!==wrap)ch.remove()});
    let footer=field('adsbStatusFooterV271');let st=field('adsbSettingsStatus');
    if(!footer){footer=document.createElement('div');footer.id='adsbStatusFooterV271';footer.className='adsb-status-footer-v271';wrap.appendChild(footer)}
    if(st&&st.parentElement!==footer)footer.appendChild(st);
    if(st){st.className='adsb-status-v270';st.setAttribute('aria-live','polite')}
    const upd=field('adsbUpdateInterval');if(upd){upd.min='1';upd.step='1'}
    document.querySelectorAll('#adsbApplyOtsBtn,#adsbDisableOtsJobBtn,#adsbEnableOtsJobBtn,#adsbUpdateIntervalBtn,#adsbSaveIntervalBtn,.adsb-v268-actions,.adsb-v266-actions,.adsb-interval-action-row').forEach(n=>n.remove());
    document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V);
  }catch(e){console.warn('v271 ADS-B stabilize failed',e)}}
  function addCss(){if(field('v271Style'))return;const st=document.createElement('style');st.id='v271Style';st.textContent=`
    .panel[data-collapse-key="adsbSettings"] .panel-body>:not(#adsbV270Menu){display:none!important}
    #adsbV270Menu{display:grid!important;gap:8px!important;align-content:start!important}
    #adsbStatusFooterV271{height:24px;min-height:24px;max-height:24px;border-top:1px solid rgba(255,255,255,.08);display:flex;align-items:center;overflow:hidden;margin-top:0;padding-top:0}
    #adsbStatusFooterV271 #adsbSettingsStatus{border-top:0!important;padding-top:0!important;min-height:0!important;height:18px!important;max-height:18px!important;line-height:18px!important;width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:.70rem;color:#9fb1b9}
    #adsbStatusFooterV271 #adsbSettingsStatus.adsb-status-ok{color:#9ff2c1!important}
    #adsbStatusFooterV271 #adsbSettingsStatus.adsb-status-bad{color:#ffad9f!important}
  `;document.head.appendChild(st)}
  function boot(){try{addCss();stabilizeMenu();if(!window._v271AdsbObserver){const body=document.querySelector('.panel[data-collapse-key="adsbSettings"] .panel-body');if(body&&window.MutationObserver){window._v271AdsbObserver=new MutationObserver(()=>stabilizeMenu());window._v271AdsbObserver.observe(body,{childList:true,subtree:true})}}}catch(e){console.warn('v271 boot failed',e)}}
  if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',()=>setTimeout(boot,350));else setTimeout(boot,150);setTimeout(boot,900);setTimeout(boot,2200);setInterval(()=>{try{document.querySelectorAll('.iteration-chip,.iteration-marker').forEach(el=>el.textContent=V)}catch(_){}},2500);
})();
'''
_v271_marker='</script></body></html>'
_v271_i=TAK_MAP_HTML.rfind(_v271_marker)
if _v271_i >= 0:
    TAK_MAP_HTML = TAK_MAP_HTML[:_v271_i] + _v271_js + TAK_MAP_HTML[_v271_i:]

# Keep the initial ADS-B status in a fixed footer so legacy timed UI cleanups cannot make it jump.
try:
    TAK_MAP_HTML = TAK_MAP_HTML.replace('<div id=\"adsbSettingsStatus\" class=\"adsb-status-v270\"></div></div>', '<div id=\"adsbStatusFooterV271\" class=\"adsb-status-footer-v271\"><div id=\"adsbSettingsStatus\" class=\"adsb-status-v270\"></div></div></div>')
except Exception:
    pass


_v271_prev_load_adsb_settings = _load_adsb_settings

def _load_adsb_settings():
    d=_v271_prev_load_adsb_settings()
    d['source_mode']='airplanes_live_client'
    d['stale_seconds']=60
    return d

def _v271_server_adsb_client_only(query_settings=None):
    settings=_load_adsb_settings()
    return {
        'ok': True,
        'source_mode': 'airplanes_live_client',
        'aircraft': [],
        'count': 0,
        'sources': [{'source':'airplanes.live client','ok':True,'message':'Client-only ADS-B; server proxy disabled.'}],
        'stale_seconds': 60,
        'settings': settings,
    }

# v271: normal ADS-B aircraft loading is client-only. Keep the endpoint harmless for
# older browser code/status paths without allowing the Pi/backend to poll Airplanes.live.
tak_map_adsb = _v271_server_adsb_client_only
# --- end v271 ADS-B client-only fetch + stable status bar ---


# --- v272 drawing/viewshed/terrain/ADS-B regression fixes ---
